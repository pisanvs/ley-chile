{"html": [{"t": "<div><div class=\"p\">AGREGACION DEL JUZGADO DE AGUAS AL DE POLICIA RURAL.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Setiembre 2 de 1823.</div><br><div class=\"p\">&nbsp; &nbsp;  Usando de las facultades que me concede la lei, he acordado y decreto:</div></div>", "i": 10057696}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.o El Juez de polic&#xED;a rural, ejercer&#xE1; el destino de Juez de aguas, en los mismos t&#xE9;rminos en que lo ha desempe&#xF1;ado hasta aqu&#xED; el Rejidor que el Cabildo nombraba por trimestres a este efecto.</div><br><div class=\"p\">&nbsp; &nbsp;  2.o Queda por consiguiente suprimido desde la publicacion de este decreto el cargo de Rejidor juez de aguas. Ins&#xE9;rtese en el Boletin.</div></div>", "i": 10057697}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Ega&#xF1;a.</div></div>", "i": 10057698}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "AGREGACION DEL JUZGADO DE AGUAS AL DE POLICIA RURAL.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-09-02", "doble_articulado": false, "id_norma": "1136081", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-09-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu