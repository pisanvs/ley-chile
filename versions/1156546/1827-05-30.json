{"html": [{"t": "<div><br><div class=\"p\">RESTITUCION DE LOS TERBIOS VENCIDOS.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso nacional con fecha 29 de este mes ha decretado lo siguiente:</div></div>", "i": 10237925}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Se suspenden los efectos del Senadoconsulto de 30 de abril de 1823, y el Gobierno proceder&#xE1; a pagar los tercios vencidos como estime mas conveniente a efecto de que todos sean remediados en sus urgencias.</div><br><div class=\"p\">&nbsp; &nbsp;  Por tanto ordeno que se ejecute insert&#xE1;ndose en el Boletin.&nbsp; </div></div>", "i": 10237926}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Dado en la Sala de Gobierno en Santiago de Chile a 30 de mayo de 1827.</div><div class=\"p\">&nbsp; &nbsp;  PINTO.</div><br><div class=\"p\">&nbsp; &nbsp;  Blanco.</div></div>", "i": 10237927}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "RESTITUCION DE LOS TERBIOS VENCIDOS", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1827-05-30", "doble_articulado": false, "id_norma": "1156546", "numero_fuente": "1827", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1827-05-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1827-05-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1827-05-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fec