{"html": [{"t": "<div><div class=\"p\">&#xFEFF;EXEQUIAS DE LOS HERMANOS CARRERA</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago abril 12 de 1828.</div></div>", "i": 9577265}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Deseando que las exequias acordadas por el Congreso Nacional &#xE1; las cenizas de D. JUAN JOSE, D. JOSE MIGUEL y D. LUIS DE LA CARRERA se hagan en el mejor &#xF3;rden y de un modo correspondiente &#xE1; los servicios que la patria debe &#xE1; tan ilustres ciudadanos, el gobierno encarga &#xE1; los diputados D. Francisco Ruiz Tagle y jeneral D. Francisco Calderon, todos los preparativos necesarios &#xE1; esta ceremonia; en intelijencia que todos los gastos que ella demande, ser&#xE1;n cubiertos &#xE1; su aviso por las rentas fiscales. </div></div>", "i": 9577266}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Refr&#xE9;ndese y t&#xF3;mese raz&#xF3;n.</div><br><div class=\"p\">&nbsp; &nbsp;  PINTO.</div><br><div class=\"p\">&nbsp; &nbsp;  Rodriguez.</div></div>", "i": 9577267}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["RELACIONES EXTERIORES"], "titulo_norma": "EXEQUIAS DE LOS HERMANOS CARRERA", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1828-04-12", "doble_articulado": false, "id_norma": "1075044", "numero_fuente": "", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1828-04-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1828-04-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "182