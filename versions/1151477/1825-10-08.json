{"html": [{"t": "<div><div class=\"p\">OTRO</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de 1825</div></div>", "i": 10182099}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Hall&#xE1;ndose vacante el Ministerio de Estado en el Departamento de Guerra y Marina, y siendo preciso elejir para que lo desempe&#xF1;e un jefe de conocimientos y buena comportacion; concurriendo estas circunstancias en D. Jos&#xE9; Mar&#xED;a Novoa, he venido en nombrarle por tal Ministro de la Guerra y Marina. </div></div>", "i": 10182100}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, comun&#xED;quese e impr&#xED;mase.</div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  ----&nbsp; Astorga.&nbsp; </div></div>", "i": 10182101}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DE INTERIOR"], "titulo_norma": "OTRO", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-10-08", "doble_articulado": false, "id_norma": "1151477", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-10-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-10-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-10-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2020-12-04", "fecha_version": "1825-10-08", "fecha_actualizacion_texto": "2020-12-04", "tipo_tratado": "