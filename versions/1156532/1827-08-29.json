{"html": [{"t": "<div><div class=\"p\">DISPENSACION DE LA FIANZA DE SUPERVIVENCIA A LOS EMPLEADOS DIPLOMATICOS. </div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Agosto 29 de 1827.</div><br><div class=\"p\">&nbsp; &nbsp;  El Vice-Presidente de la Rep&#xFA;blica con anuencia de la Comision nacional ha acordado y decreta: </div></div>", "i": 10245671}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. &#xFA;nico. Los individuos de cuerpo diplom&#xE1;tico no est&#xE1;n obligados a dar fianza de supervivencia por las anticipaciones que reciban para su viaje.</div></div>", "i": 10245672}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Comun&#xED;quese a quienes corresponde, t&#xF3;mese razon y publ&#xED;quese. </div><br><div class=\"p\">&nbsp; &nbsp;  PINTO.&nbsp; &nbsp;  De Zegers.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Sub-secretario encargado </div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; interinamente del Ministerio.</div></div>", "i": 10245673}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES"], "titulo_norma": "DISPENSACION DE LA FIANZA DE SUPERVIVENCIA A LOS EMPLEADOS DIPLOMATICOS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1827-08-29", "doble_articulado": false, "id_norma": "1156532", "numero_fuente": "1827", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1827-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1827-08-29", "fin_