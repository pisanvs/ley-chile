{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; El Presidente de la Rep&#xFA;blica Santiago, Noviembre 23 de 1865 Por cuanto el Congreso Nacional ha aprobado el siguiente</div><br><div class=\"p\">&nbsp; &nbsp; CODIGO DE COMERCIO </div><div class=\"ab\"><a href=\"Navegar/pdf/PDF/29585.PDF\">Descargar C&#xF3;digo de Comercio Original (PDF, 8 M)</a></div></div>", "i": 8725219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien sancionarlo; por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto en todas sus partes como ley de la Rep&#xFA;blica.- JOSE JOAQUIN PEREZ.- Federico Err&#xE1;zuriz.</div><br></div>", "i": 8725858}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=15462-03", "informacion": "Modifica el Código de Comercio, con el objeto de limitar los montos de pago en efectivo en el comercio.", "nroBoletin": "15462-03"}, {"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=15225-03", "informacion": "Modifica el Código de Comercio en materia de costos máximos y reajustabilidad de las primas de seguro automotriz", "nroBoletin": "15225-03"}, {"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=15145-07", "informacion": "Modifica el Código de Comercio, para establecer que los tiempos de espera dispuestos en el contrato de transporte sean de cargo del consignatario.", "nroBoletin": "15145-07"}, {"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=13552-07", "informacion": "Modifica diversos cuerpos legales, en materia de lesión enorme en la venta forzada de inmuebles, y extiende la acción por este concepto a los contratos mercantiles", "nroBoletin": "13552-07"}, {"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=13526-03", "informacion": "Modifica diversos cuerpos legales en materia de gastos asociados a la celebración y liquidación de operaciones de crédito de dinero", "nroBoletin": "13526-03"}, {"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12481-07", "informacion": "Proyecto de ley que incorpora la institución del establecimiento de comercio en la legislación comercial.", "nroBoletin": "12481-07"}, {"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12480-07", "informacion": "Proyecto de ley que norma los contratos de agencia, suministro y franquicia en el derecho privado nacional.", "nroBoletin": "12480-07"}, {"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12479-07", "informacion": "Proyecto de ley que reemplaza la normativa referente a los corredores de comercio del Título III del Libro I del Código de Comercio.", "nroBoletin": "12479-07"}, {"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12441-17", "informacion": "Modifica diversos textos legales con el objeto de eliminar la discriminación en contra de personas con discapacidad intelectual, cognitiva y psicosocial, y consagrar su derecho a la autonomía", "nroBoletin": "12441-17"}, {"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12198-03", "informacion": "Modifica el Código de Comercio en materia de plazo de inscripción y publicación del extracto de la escritura de constitución de las sociedades por acciones", "nroBoletin": "12198-03"}, {"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=11938-03", "informacion": "Modifica el Código de Comercio para disponer la suspensión del pago de la prestación contemplada en el contrato de seguro, en caso de dolo del beneficiario en la generación del siniestro asegurado", "nroBoletin": "11938-03"}, {"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=10726-03", "informacion": "Modifica el Código de Comercio para radicar en la justicia ordinaria el conocimiento de litigios derivados de contratos de seguro automotriz", "nroBoletin": "10726-03"}, {"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=10301-03", "informacion": "Modifica el Código de Comercio, respecto de las menciones que debe contener el estatuto de la sociedad por acciones", "nroBoletin": "10301-03"}, {"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=9343-13", "informacion": "Modifica Libro IV del Código de Comercio, exigiendo la notificación de la quiebra, del empleador a los trabajadores.", "nroBoletin": "9343-13"}, {"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=8759-13", "informacion": "Introduce modificaciones al libro IV del Código de Comercio, ley de quiebras, en materia de despido de trabajadores.", "nroBoletin": "8759-13"}, {"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=7727-18", "informacion": "Modifica el Código Civil y otras leyes en el Régimen de Sociedad Conyugal.", "nroBoletin": "7727-18"}, {"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=7567-07", "informacion": "Modifica Código Civil y otras leyes, regulando el régimen patrimonial de sociedad conyugal", "nroBoletin": "7567-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "10", "numero": "DE COMERCIO", "abreviacion": "COD", "descripcion": "Codigo", "compuesto": "Código-DE COMERCIO"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CODIGO DE COMERCIO", "fuente"