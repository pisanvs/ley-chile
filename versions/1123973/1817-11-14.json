{"html": [{"t": "<div><br><div class=\"p\">Esportacion de sebos</div></div>", "i": 9959352}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago i Noviembre 14 de 1817.</div><br><div class=\"p\">&nbsp; &nbsp;  Deseando el Gobierno promover la esportacion de los art&#xED;culos que produce el pais para fomento del comercio i agricultura, declara libres de todos derechos de salida los sebos que estraigan, debiendo solo satisfacerse por el vendedor el de la alcabala; i para que llegue a noticia de todos, publ&#xED;quese en la Gazeta, tom&#xE1;ndose antes razon en las oficinas que corresponda.-</div></div>", "i": 9959353}, {"t": "<div><div class=\"p\">P&#xE9;rez.- Cruz.- Astorga.- Dr. Vill&#xE9;gas.- Es copia, Dr. Vill&#xE9;gas.</div></div>", "i": 9959354}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Esportacion de sebos", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1817-11-14", "doble_articulado": false, "id_norma": "1123973", "numero_fuente": "1817", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1817-11-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1817-11-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1817-11-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2018-10-29", "fecha_version": "1817-11-14", "fecha_actualizacion_texto": "2018-10-29", "tipo_tratado": ""}, "alertas": [], "aler