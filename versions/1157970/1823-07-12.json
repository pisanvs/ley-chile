{"html": [{"t": "<div><div class=\"p\">NOMBRAMIENTO DE MINISTRO DE ESTADO EN EL DEPARTAMENTO DE HACIENDA.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 12 de 1823.</div></div>", "i": 10235032}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  96 Atendiendo a las instancias de D. Pedro Mena para que tuviese a bien admitirle la renuncia del Ministerio de Hacienda, he venido en nombrar para este destino a D. Diego Benavente, de cuya providad y conocimientos me hallo satisfecho. </div></div>", "i": 10235033}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Comuniquese al nombrado, t&#xF3;mese razon e ins&#xE9;rtese en el Boletin.</div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Ega&#xF1;a.</div></div>", "i": 10235034}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["DEPARTAMENTO DE GOBIERNO Y RELACIONES EXTERIORES"], "titulo_norma": "NOMBRAMIENTO DE MINISTRO DE ESTADO EN EL DEPARTAMENTO DE HACIENDA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-07-12", "doble_articulado": false, "id_norma": "1157970", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-07-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-07-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-07-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "906", "fecha_ingreso": "2021-06-02", "fecha_version": "1823-07-12"