{"html": [{"t": "<div><div class=\"p\">JUNTA DE VACUNA.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Junio 11 de 1830. </div></div>", "i": 10247794}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Conforme al art. 1.&#xB0; del decreto de esta fecha, vengo en nombrar, para que compongan la junta de vacuna a los ciudadanos don Pedro Mena, don Manuel Huici, don Francisco Huidobro, don Vicente I&#xF1;iguez, don Manuel Reyes, don Ambrosio Aldunate y don Juan de Dios Correa de Saa. </div></div>", "i": 10247795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Comun&#xED;quese este nombramiento e impr&#xED;mase.</div><br><div class=\"p\">&nbsp; &nbsp;  OVALLE.&nbsp; &nbsp;  Portales.</div></div>", "i": 10247796}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "JUNTA DE VACUNA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1830-06-11", "doble_articulado": false, "id_norma": "1159505", "numero_fuente": "1830", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1830-06-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1830-06-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1830-06-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-07-02", "fecha_version": "1830-06-11", "fecha_actualizacion_texto": "2021-07-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado