{"html": [{"t": "<div><div class=\"p\">POLICIA RURAL</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 19 de 1823.</div></div>", "i": 10235026}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  111 El Juez de polic&#xED;a rural podr&#xE1; autorizar a los Diputados de justicia con el car&#xE1;cter de tenientes de polic&#xED;a cuando las ocurrencias consiguientes al ramo de su cargo lo exijan, pues no se considera de necesidad que sean tenientes natos como lo proporciones. Se aprueba la propuesta que hace acerca del nombramiento interino de teniente jeneral de policia, con el sueldo de trescientos pesos que indica, en el teniente de aguas D. Juan de Dios Mesias.</div></div>", "i": 10235027}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  R&#xFA;brica de S.E. </div><br><div class=\"p\">&nbsp; &nbsp;  Ega&#xF1;a.</div></div>", "i": 10235028}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "POLICIA RURAL", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-07-19", "doble_articulado": false, "id_norma": "1157969", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-07-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-07-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-07-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "906", "fecha_ingreso": "2021-06-02", "fecha_version": "1823-07-19", "f