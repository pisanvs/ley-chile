{"html": [{"t": "<div><div class=\"p\">VISITA A LA CAJA NACIONAL DE DESCUENTOS.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 4 de 1825.</div><br><div class=\"p\">&nbsp; &nbsp;  El Gobierno ha acordado y decreta:</div></div>", "i": 10108966}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.&#xB0; Que habi&#xE9;ndose mandado por <a href=\"https://www.leychile.cl/Navegar?idNorma=1141506&amp;idParte=&amp;idVersion=\">decreto de 16 de octubre de 1824</a> la incorporacion de los bienes de Regulares a la Hacienda p&#xFA;blica: los Directores de la Caja nacional encargados de su administracion quedan sujetos a la visita mensual, y demas disposiciones establecidas por lei para las oficinas fiscales.</div><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; El Ministro Secretario de Hacienda queda encargado del cumplimiento de este decreto de que se tomara razon en la Contaduria mayor y Caja nacional. Imprimase.</div></div>", "i": 10108967}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Correa de Saa.</div></div>", "i": 10108968}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "VISITA A LA CAJA NACIONAL DE DESCUENTOS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-07-04", "doble_articulado": false, "id_norma": "1143029", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-07-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-07-04", "fin