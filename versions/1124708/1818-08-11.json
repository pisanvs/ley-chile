{"html": [{"t": "<div><div class=\"p\">Int&#xE9;rprete para la plaza de Valparaiso</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Agosto 11 de 1818.</div></div>", "i": 9973498}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Necesit&#xE1;ndose un int&#xE9;rprete que posea con perfeccion las lenguas Francesa e Inglesa para que establecido en la Plaza de Valparaiso sirva en clase de tal, en los negocios que ocurran en aquel Gobierno, i en el departamento de Marina, an&#xFA;nciese por medio de la Gazeta ministerial, a fin de que los que aspiren a este destino, ocurran al Supremo Gobierno, donde se tratar&#xE1; de elejir el mas apto, con una dotacion proporcionada.-</div></div>", "i": 9973499}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  O&apos;Higgins.-Irisarri.</div></div>", "i": 9973500}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Intérprete para la plaza de Valparaiso", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1818-08-11", "doble_articulado": false, "id_norma": "1124708", "numero_fuente": "1818", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1818-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1818-08-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1818-08-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2018-12-03", "fecha_version": "1818-08-11", "fecha_actualizacion_texto": "201