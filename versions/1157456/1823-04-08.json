{"html": [{"t": "<div><br><div class=\"p\">NOMBRAMIENTO DE MINISTROS DE ESTADOS.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Abril 8 de 1823.</div></div>", "i": 10225902}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  23&nbsp; &nbsp;  Atendidas las razones en que fundan su renuncia D. Manuel Vazquez de Novoa y D. Manuel Antonio Gonz&#xE1;lez, vengo en admitirla no obstante lo sensible que es privarme del auxilio que me permit&#xED;an sus luces y amor p&#xFA;blico, y nombrar para ministro de estado en el departamento de hacienda a D. Pedro Nolasco Mena, y en el de guerra y marina al coronel D. Juan de Dios Rivera. T&#xF3;mese raz&#xF3;n, e ins&#xE9;rtese en el Bolet&#xED;n.</div><div class=\"p\">&nbsp; &nbsp; </div></div>", "i": 10225903}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><div class=\"p\">&nbsp; &nbsp;  Ega&#xF1;a.</div></div>", "i": 10225904}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTRO", "descripcion": "Otro", "compuesto": "OTRO-S/N"}], "organismos": ["DEPARTAMENTO DE GOBIERNO Y RELACIONES EXTERIORES"], "titulo_norma": "NOMBRAMIENTO DE MINISTROS DE ESTADOS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-04-08", "doble_articulado": false, "id_norma": "1157456", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-04-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-04-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-04-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":