{"html": [{"t": "<div><div class=\"p\">Nombramiento del Ministro de Hacienda.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Octubre 17 de 1825.</div></div>", "i": 10182884}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Habi&#xE9;ndose aceptado la renuncia interpuesta por D. Diego Jos&#xE9; Benavente del cargo del Ministro de Hacienda, vengo ahora en nombrar para este destino a D. Manuel Jos&#xE9; Gandarillas, de cuya providad y conocimientos me hallo satisfecho. Comun&#xED;quese al nombrado, t&#xF3;mese razon e ins&#xE9;rtese en el Boletin.</div></div>", "i": 10182885}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  ------ Campino.</div></div>", "i": 10182886}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DE INTERIOR"], "titulo_norma": "Nombramiento del Ministro de Hacienda.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-10-17", "doble_articulado": false, "id_norma": "1151523", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-10-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-10-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2020-12-09", "fecha_version": "1825-10-17", "fecha_actualizacion_texto": "2020-12-09", "tipo_tratado": ""}, "alertas": []