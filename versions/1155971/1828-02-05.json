{"html": [{"t": "<div><div class=\"p\">ASIGNACION MENSUAL A LA ACADEMIA MILITAR.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Febrero 5 de 1828.</div><br><div class=\"p\">&nbsp; &nbsp;  El Vice-Presidente de la Rep&#xFA;blica, con aprobacion de la Comision nacional decreta:</div></div>", "i": 10237577}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. &#xFA;nico. Se abonar&#xE1; 15 pesos mensuales al director de la Academia militar para la compra de papel, tinta y dem&#xE1;s art&#xED;culos necesarios al entretenimiento de la clase de dibujo puesta a su cargo. </div></div>", "i": 10237578}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, comun&#xED;quese a quien corresponda e impr&#xED;mase.</div><div class=\"p\">&nbsp; &nbsp;  PINTO&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Obejero.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Pro-Secretario.</div></div>", "i": 10237579}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE LA GUERRA"], "titulo_norma": "ASIGNACION MENSUAL A LA ACADEMIA MILITAR.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1828-02-05", "doble_articulado": false, "id_norma": "1155971", "numero_fuente": "1828", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1828-02-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1828-02-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1828-02-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "