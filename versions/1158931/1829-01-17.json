{"html": [{"t": "<div><br><div class=\"p\">BECAS DEL LICEO DE CHILE</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Enero 17 de 1829.</div></div>", "i": 10245654}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  De las cuarenta y dos becas creadas en el Liceo de Chile por la <a href=\"https://www.leychile.cl/Navegar?idNorma=1158872&amp;idParte=&amp;idVersion=\">lei de 6 de diciembre pr&#xF3;ximo pasado</a>, se concede una a cada uno de los j&#xF3;venes D. Estanislao Appleby, D. Antonio Videla, D. Jos&#xE9; Manuel Solar y Orostiaga, D. Jos&#xE9; Meliton de Santiago Concha, D. Pedro Nolasco Vial, D. Jos&#xE9; Luis Guerrero y D. Remijio Arnelo y Arteaga. T&#xF3;mese razon y comun&#xED;quese.</div><br></div>", "i": 10245655}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  PINTO</div><div class=\"p\">&nbsp; &nbsp;  Rodr&#xED;guez</div></div>", "i": 10245656}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "BECAS DEL LICEO DE CHILE", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1829-01-17", "doble_articulado": false, "id_norma": "1158931", "numero_fuente": "1829", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1829-01-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1829-01-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1829-01-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresado_p