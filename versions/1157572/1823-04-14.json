{"html": [{"t": "<div><div class=\"p\">NUEVA DENOMINACION AL BATALLON DE VALDIVIA.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Abril 14 de 1823.</div></div>", "i": 10227815}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  46 El batallon de infanter&#xED;a de l&#xED;nea conocido hasta ahora con la denominacion de Batallon de Valdivia, se declara: que debe ser reconocido con la de Batallon n&#xFA;m. 8. Hagase saber en la &#xF3;ren jeneral del ej&#xE9;rcito; transcr&#xED;base este decreto a quienes corresponda, y t&#xF3;mese razon.</div></div>", "i": 10227816}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE</div><div class=\"p\">&nbsp; &nbsp;  Rivera</div></div>", "i": 10227817}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "NUEVA DENOMINACION AL BATALLON DE VALDIVIA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-04-14", "doble_articulado": false, "id_norma": "1157572", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-04-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-04-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-04-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "17616", "fecha_ingreso": "2021-05-17", "fecha_version": "1823-04-14", "fecha_actualizacion_texto": "2021-05-17", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [