{"html": [{"t": "<div><div class=\"p\">Pago de diezmos</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Agosto 17 de 1822.</div></div>", "i": 10182890}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Not&#xE1;ndose la morosidad con que algunos subastadores de diezmos han verificado siempre los pagos, los har&#xE1;n en el pr&#xF3;ximo Setiembre dentro de quince dias de cumplido el plazo, i de lo contrario se les cargar&#xE1; un seis por ciento de aumento.</div></div>", "i": 10182891}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon e impr&#xED;mase.- O&apos;Higgins.- Rodr&#xED;guez.</div></div>", "i": 10182892}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Pago de diezmos", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1822-08-17", "doble_articulado": false, "id_norma": "1151905", "numero_fuente": "1822", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1822-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1822-08-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1822-08-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2020-12-09", "fecha_version": "1822-08-17", "fecha_actualizacion_texto": "2020-12-09", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10182890}, {"n": "Artículo", "i": 10182891, "t": 6}, {"n": "Promulgación", "i":