{"html": [{"t": "<div><div class=\"p\">MINISTRO DEL INTERIOR</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Abril 14 de 1832.</div></div>", "i": 10253957}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Cediendo a las repetidas instancias del Ministro del Interior y Relaciones Exteriores, don Ramon Err&#xE1;zuriz, vengo en admitirle la renuncia que hace desde este destino, que ha desempe&#xF1;ado a mi entera satisfaccion. An&#xF3;tese en las oficinas correspondientes y publ&#xED;quese.</div></div>", "i": 10253958}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  PRIETO.</div><br><div class=\"p\">&nbsp; &nbsp;  De orden de S.E.</div><div class=\"p\">&nbsp; &nbsp;  Manuel Carvallo.</div></div>", "i": 10253959}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "MINISTRO DEL INTERIOR", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-04-14", "doble_articulado": false, "id_norma": "1160768", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-04-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-04-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-04-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "17616", "fecha_ingreso": "2021-07-21", "fecha_version": "1832-04-14", "fecha_actualizacion_texto": "2021-07-21", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estru