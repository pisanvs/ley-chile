{"html": [{"t": "<div><div class=\"p\">Derechos de esportacion sobre el cobre </div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Abril 1.&#xB0; de 1822. </div></div>", "i": 10282390}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Conforme a lo acordado con el Excmo. Senado en 4 del mes ante-pr&#xF3;ximo para costear en parte los gastos de la espedicion libertadora del Archipi&#xE9;lago de Chilo&#xE9;, se impone un peso a cada quintal de cobre que se estraiga del Estado, i durar&#xE1; este gravamen por solo el t&#xE9;rmino de un a&#xF1;o contado desde el dia de la fecha.</div></div>", "i": 10282391}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, publ&#xED;quese, impr&#xED;mase i circ&#xFA;lese. &#x2013; O&apos;Higgins. &#x2013; Rodr&#xED;guez.</div></div>", "i": 10282392}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "﻿Derechos de esportacion sobre el cobre", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1822-04-01", "doble_articulado": false, "id_norma": "1167044", "numero_fuente": "1822", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1822-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1822-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1822-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2021-11-08", "fecha_version": "1822-04-01", "fecha_actualizacion_texto