{"html": [{"t": "<div><div class=\"p\">&#xFEFF;AUTORIZACION PARA EL DESPACHO A LOS ACTUALES MINISTROS.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 9 de 1826.</div></div>", "i": 10210840}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Vengo en autorizar para el despacho del Ministerio del Interior y de Relaciones Exteriores, e igualmente para el de Hacienda a los Ministros que se hallan actualmente encargados de ellos, hasta nueva resolucion. T&#xF3;mese razon, comun&#xED;quese e ins&#xE9;rtese en el Boletin.</div></div>", "i": 10210841}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  BLANCO.</div><br><div class=\"p\">&nbsp; &nbsp;  Astorga</div></div>", "i": 10210842}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "﻿AUTORIZACION PARA EL DESPACHO A LOS ACTUALES MINISTROS", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1826-07-09", "doble_articulado": false, "id_norma": "1152036", "numero_fuente": "1826", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1826-07-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1826-07-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1826-07-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2021-03-19", "fecha_version": "1826-07-09", "fecha_actualizacion_texto": "2021-03-19", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura