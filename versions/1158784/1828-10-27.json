{"html": [{"t": "<div><div class=\"p\">EXTINCION DE LA MAYORIA DE PLAZA.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Octubre 27 de 1828.</div></div>", "i": 10237394}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Siendo innecesaria la existencia de la Mayoria de plaza en la capital de la Rep&#xFA;blica, respecto a que las atribuciones que le son inherentes pueden desempe&#xF1;arse por la Inspeccion jeneral del ej&#xE9;rcito, sin que por esto se reagrave en sus principales atenciones; el Gobierno viene en extinguirla, cuidando el Inspector jeneral de llenar los objetos de que aquella estaba encargada.</div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, comun&#xED;quese a quien corresponda e impr&#xED;mase.</div></div>", "i": 10237395}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  PINTO.</div><div class=\"p\">&nbsp; &nbsp;  Borgo&#xF1;o.</div></div>", "i": 10237396}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "EXTINCION DE LA MAYORIA DE PLAZA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1828-10-27", "doble_articulado": false, "id_norma": "1158784", "numero_fuente": "1828", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1828-10-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1828-10-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1828-10-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "17616", "