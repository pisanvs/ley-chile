{"html": [{"t": "<div><br><div class=\"p\">SUELDO AL DIOCESANO.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Diciembre 29 de 1825.</div><br><div class=\"p\">&nbsp; &nbsp;  El Gobierno ha acordado y decreta:</div></div>", "i": 10188733}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1.&#xB0; El Reverendo Obispo D. Jos&#xE9; Santiago Rodriguez continuar&#xE1; gozando, sin embargo de su estra&#xF1;amiento, el sueldo de seis mil pesos anuales, que le estaba se&#xF1;alado.</div><br><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; El apoderado de dicho Obispo, y no habi&#xE9;ndolo dejado, su hermano el Dr. D. Jose Joaquin Rodriguez, ser&#xE1; encargado de percibir dicho sueldo.</div><br><div class=\"p\">&nbsp; &nbsp;  3.&#xB0; Refr&#xE9;ndese este decreto por el Ministerio de Hacienda, t&#xF3;mese razon y comun&#xED;quese.</div><br></div>", "i": 10188734}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  INFANTE.</div><br><div class=\"p\">&nbsp; &nbsp;  Campino</div></div>", "i": 10188735}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE INTERIOR"], "titulo_norma": "SUELDO AL DIOCESANO", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-12-29", "doble_articulado": false, "id_norma": "1151605", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "", "vigencias": [{"desde": "1825-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-12-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "18