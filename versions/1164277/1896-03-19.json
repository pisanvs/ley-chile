{"html": [{"t": "<div><br><div class=\"p\">Cuarta Zona militar</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de Marzo de 1896</div><br><div class=\"p\">&nbsp; &nbsp;  He acordado i decreto:</div></div>", "i": 10330466}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Organ&#xED;zase una cuarta Zona militar que comprender&#xE1; las provincias de Bio-Bio, Arauco, Malleco, Cautin, Valdivia i Llanquihue i tendr&#xE1; su centro militar en el departamento de Victoria de la provincia de Malleco.</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xF3;mbrase jefe de esta Zona i Comandante Jeneral de Armas de Malleco al Coronel de Ej&#xE9;rcito don Salvador Vergara A.</div><br><div class=\"p\">&nbsp; &nbsp;  La indicada Zona tondr&#xE1; el mismo personal que las otras.</div></div>", "i": 10330467}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon i comun&#xED;quese.</div><br><br><div class=\"p\">&nbsp; &nbsp;  MONTT.</div><br><div class=\"p\">&nbsp; &nbsp;  Luis Barros Borgo&#xF1;o.</div></div>", "i": 10330468}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE LA GUERRA"], "titulo_norma": "Cuarta Zona militar", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-03-19", "doble_articulado": false, "id_norma": "1164277", "numero_fuente": "1896", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1896-03-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1896-03-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v