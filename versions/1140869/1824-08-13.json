{"html": [{"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  ESPA&#xD1;OLES.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Agosto 13 de 1824.</div><br><div class=\"p\">&nbsp; &nbsp;  El Gobierno Supremo ha tenido a bien decretar lo siguiente:</div></div>", "i": 10098142}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1.&#xB0; Todos los espa&#xF1;oles que habiten en Valparaiso, seculares o eclesi&#xE1;sticos en clase de transe&#xFA;ntes, o domiciliados ser&#xE1;n trasladados a la ciudad de Quillota.</div><br><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; Son exceptuados solamente los que estuvieren empleados en la lista civil o militar, y aquellos que hayan obtenido carta de ciudadan&#xED;a.</div><br><div class=\"p\">&nbsp; &nbsp;  3&#xB0; El Ministro Secretario de Gobierno queda encargado de la ejecuci&#xF3;n de este decreto que se transcribir&#xE1; a quienes corresponda e insertar&#xE1; en el Boletin.</div><br></div>", "i": 10098143}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  F.A. Pinto.</div><br></div>", "i": 10098144}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["DEPARTAMENTO DEL INTERIOR"], "titulo_norma": "ESPAÑOLES", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-08-13", "doble_articulado": false, "id_norma": "1140869", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-08-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-08-13", "fin_vig