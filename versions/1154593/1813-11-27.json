{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concesion de montep&#xED;os</div><br><br><div class=\"p\">&nbsp; &nbsp;  Talca, 27 de Noviembre de 1813</div></div>", "i": 10224243}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Queriendo el Gobierno dar una prueba de la consideracion, i aprecio que dispensa al m&#xE9;rito de los Ilustres Guerreros, que se han distinguido de un modo brillante en la defensa de la Patria, viene en conceder goce de Montep&#xED;o a las Esposas de los Oficiales Don Pedro Jos&#xE9; Valenzuela, i Don Rafael Valverde que murieron gloriosamente en la accion de Santa Rosa. T&#xF3;mese razon en las oficinas de Hacienda i publ&#xED;quese. - </div></div>", "i": 10224244}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Miguel Infante. - Agustin Eyzaguirre. -Jos&#xE9; Ignacio Cienfuegos. - Mariano Ega&#xF1;a, secretario.</div></div>", "i": 10224245}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Concesion de montepíos", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1813-11-27", "doble_articulado": false, "id_norma": "1154593", "numero_fuente": "1813", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1813-11-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1813-11-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1813-11-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingre