{"html": [{"t": "<div><br><div class=\"p\">RESOLUCIONES SUPREMAS.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Setiembre 16 de 1830. </div><br><div class=\"p\">&nbsp; &nbsp;  Con la publicacion de cada n&#xFA;mero de Boletin no puede hacerse hasta que haya los decretos necesarios para llenarlo, y conviniendo la mas pronta circulacion de muchos de estos, el Gobierno ha decretado: </div></div>", "i": 10253966}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art. &#xFA;nico. Las resoluciones del Gobierno que se publicaren en el per&#xED;odo titulado el Araucano se tendr&#xE1;n como aut&#xE9;nticas y oficialmente comunicadas, para que obligue su cumplimiento a las personas y cuerpos a quienes tocasen.</div><br></div>", "i": 10253967}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  OVALLE.</div><br><div class=\"p\">&nbsp; &nbsp;  Portales.</div></div>", "i": 10253968}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "RESOLUCIONES SUPREMAS", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1830-09-16", "doble_articulado": false, "id_norma": "1159908", "numero_fuente": "1830", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1830-09-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1830-09-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1830-09-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ing