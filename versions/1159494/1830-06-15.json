{"html": [{"t": "<div><div class=\"p\">MINISTRO DE HACIENDA.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Junio 15 de 1830.</div></div>", "i": 10247812}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Hall&#xE1;ndose vacante el Ministerio de Hacienda por renuncia del doctor don Juan Francisco Meneses, y satisfecho de las aptitudes y calidades que concurren en don Manuel Rengifo para el desempe&#xF1;o de este destino, he venido en nombrarle Ministro de Estado en aquel departamento.</div></div>", "i": 10247813}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Comun&#xED;quese y t&#xF3;mese razon.</div><br><div class=\"p\">&nbsp; &nbsp;  OVALLE.&nbsp; &nbsp;  Portales. </div></div>", "i": 10247814}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MINISTRO DE HACIENDA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1830-06-15", "doble_articulado": false, "id_norma": "1159494", "numero_fuente": "1830", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1830-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1830-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1830-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-07-02", "fecha_version": "1830-06-15", "fecha_actualizacion_texto": "2021-07-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i