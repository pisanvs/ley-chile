{"html": [{"t": "<div><div class=\"p\">RECTOR DEL INSTITUTO NACIONAL : SU SEPARACION.</div><br><div class=\"p\">&nbsp; &nbsp;  Valparaiso, marzo 5 de 1829.</div><br><br></div>", "i": 10252493}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  No pudiendo ser indiferente el Gobierno a los perjuicios que por repetidas veces indica el Dr. D. Juan Francisco Meneses seguirsele por su continuacion en el cargo de Rector del Instituto nacional, viene en admitirle la renuncia que hace de su destino, qued&#xE1;ndole reconocido por los servicios que ha prestado en el tiempo que ha estado bajo su desempe&#xF1;o la educacion de la juventud.</div></div>", "i": 10252494}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon y comuniquese.</div><div class=\"p\">&nbsp; &nbsp;  PINTO&nbsp; &nbsp;  Rodr&#xED;guez.</div></div>", "i": 10252495}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTRO", "descripcion": "Otro", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "RECTOR DEL INSTITUTO NACIONAL: SU SEPARACION.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1829-03-05", "doble_articulado": false, "id_norma": "1159248", "numero_fuente": "1829", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1829-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1829-03-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1829-03-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-07-19", "fecha_