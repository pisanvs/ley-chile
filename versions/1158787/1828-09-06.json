{"html": [{"t": "<div><div class=\"p\">UNIFORME DEL BATALLON CONSTITUCION.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Setiembre 6 de 1828.</div><br><div class=\"p\">&nbsp; &nbsp;  El gobierno ha acordado y decreta:</div><br><br></div>", "i": 10237627}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. 1.&#xB0; El uniforme del batallon de la Constitucion, creado con fecha de ayer, constar&#xE1; de chaqueta azul con vivo anteado; pantalon blanco en berano, y azul en el invierno; sombrero redondo con una de las alas levantada, y cucarda con galon de oro.</div><br><br></div>", "i": 10237628}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; Los jefes y oficiales podr&#xE1;n usar de la casaca larga, del color de la chaqueta, y sombrero apuntado con cabos dorados.</div><br><br></div>", "i": 10237629}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  3.&#xB0; El Ministro de la Guerra queda encargado del cumplimiento del presente decreto, que se comunicar&#xE1; a quien corresponda e imprimir&#xE1;.</div><br><br></div>", "i": 10237630}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  PINTO.</div><div class=\"p\">&nbsp; &nbsp;  Borgo&#xF1;o.</div></div>", "i": 10237631}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "UNIFORME DEL BATALLON CONSTITUCION.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1828-09-06", "doble_articulado": false, "id_norma": "1158787", "numero_fuente": "1828", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1828-09-06", "hasta": "", 