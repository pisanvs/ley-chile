{"html": [{"t": "<div><div class=\"p\">SUSTITUCION DE LOS JEFES INTENDENTES.</div><br><div class=\"p\">&nbsp; &nbsp;  EL DIRECTOR SUPREMO DEL ESTADO &amp;c.</div><br><div class=\"p\">&nbsp; &nbsp;  93 Por cuanto de acuerdo con el Senado Conservador he decretado:</div></div>", "i": 10235041}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Que los alcaldes de primera eleccion sustituyan a los jefes Intendentes en ausencias, muertes y enfermedades, poni&#xE9;ndose esto en planta por ahora sin perjuicio de lo que se ordenare y acordare en lo sucesivo.</div></div>", "i": 10235042}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por tanto ordeno que se publique por lei, insert&#xE1;ndose en el Boletin. Dado en el Palacio Directorial de Santiago a 14 de Junio de 1823.</div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Mariano de Ega&#xF1;a</div></div>", "i": 10235043}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "S/N", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "Ley-S/N"}], "organismos": ["DEPARTAMENTO DE GOBIERNO Y RELACIONES EXTERIORES"], "titulo_norma": "SUSTITUCION DE LOS JEFES INTENDENTES.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-06-14", "doble_articulado": false, "id_norma": "1157973", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-06-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-06-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-06-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vin