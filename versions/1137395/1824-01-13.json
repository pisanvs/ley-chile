{"html": [{"t": "<div><div class=\"p\">PAGO DE DIEZMOS.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Enero 13 de 1824.</div><div class=\"p\">&nbsp; &nbsp;  El Gobierno ha acordado y decreta:</div></div>", "i": 10064873}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Ll&#xE9;vese a debido efecto el Senadoconsulto de 16 de Marzo de 1824, en que fija el pago de diezmos a 1.&#xB0; de Diciembre, y que el remate se haga bajo la condicion de pagar el 6% mensual, que empezar&#xE1; a correr despues de pasados quince dias del cumplimiento del plazo, debiendo ser extensivo a todos los part&#xED;cipes de la masa decimal. T&#xF3;mese razon en el Tribunal Mayor de Cuentas, Tesorer&#xED;a jeneral, y trascr&#xED;base a la Junta de Diezmos.</div></div>", "i": 10064874}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  ERRAZURIZ.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Benavente.</div></div>", "i": 10064875}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "PAGO DE DIEZMOS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-01-13", "doble_articulado": false, "id_norma": "1137395", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-01-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-01-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-01-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci