{"html": [{"t": "<div><div class=\"p\">OFICIALES AGREGADOS.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Octubre 23 de 1826.</div></div>", "i": 10211234}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Los jefes y oficiales agregados hasta ahora a los cuerpos de las diferentes armas del ej&#xE9;rcito, seran dados de baja en ellos desde la fecha; y en su virtud pasar&#xE1;n al Estado mayor de plaza con arreglo al decreto de 11 de Agosto de 1824. </div></div>", "i": 10211235}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon y comun&#xED;quese a la Comandancia jeneral de armas.</div><br><div class=\"p\">&nbsp; &nbsp;  EIZAGUIRRE.&nbsp; &nbsp;  Cruz.</div></div>", "i": 10211236}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DE LA GUERRA"], "titulo_norma": "OFICIALES AGREGADOS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1826-10-23", "doble_articulado": false, "id_norma": "1152912", "numero_fuente": "1826", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1826-10-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1826-10-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1826-10-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-03-22", "fecha_version": "1826-10-23", "fecha_actualizacion_texto": "2021-03-22", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 1