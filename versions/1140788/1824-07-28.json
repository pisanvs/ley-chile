{"html": [{"t": "<div><div class=\"p\">&#xFEFF;&nbsp; &nbsp;  DESCUENTO A LOS EMPLEADOS.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 28 de 1824.</div></div>", "i": 10098481}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sostener la guerra de la Independencia, es el objeto preferente de la Rep&#xFA;blica. Por &#xE9;l debe todo ciudadano hacer sacrificios y sufrir privaciones. Cuando todas las clases del Estado, son gravadas con contribuciones, justo es que los empleados contribuyan a minorarlas. La necesidad ha impedido al Gobierno a acordar y decreta:</div><br><div class=\"p\">&nbsp; &nbsp;  Que a todo empleado civil, cuya dotacion pase de trescientos pesos anuales, se le descuenta el seis por ciento sobre sus rentas.</div></div>", "i": 10098482}, {"t": "<div><div class=\"p\"> T&#xF3;mese razon, transcr&#xED;base e impr&#xED;mase en el Boletin.</div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Diego Jos&#xE9; Benavente</div></div>", "i": 10098483}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "DESCUENTO A LOS EMPLEADOS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-07-28", "doble_articulado": false, "id_norma": "1140788", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-07-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-07-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-07-28", "f