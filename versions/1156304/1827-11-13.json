{"html": [{"t": "<div><br><div class=\"p\">SECRETAR&#xCD;AS DE LAS INTENDENCIAS DE PROVINCIA</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Noviembre 13 de 1827.</div><br><div class=\"p\">&nbsp; &nbsp;  El Vice-Presidente de la Rep&#xFA;blica, con anuencia de la Comision Nacional, ha acordado y decreta:</div></div>", "i": 10237836}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art. 1&#xB0; Habr&#xE1; un secretario en cada nueva intendencia con el sueldo provisional de 500 pesos al a&#xF1;o.</div><br></div>", "i": 10237837}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art. 2&#xB0; La provision de estas plazas se har&#xE1;n por el Gobierno nacional a propuesta de los respectivos intendentes.</div></div>", "i": 10237838}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art. 3&#xB0; Comun&#xED;quese a quienes corresponde para su cumplimiento, </div><br></div>", "i": 10237839}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  t&#xF3;mese razon e impr&#xED;mase.</div><div class=\"p\">&nbsp; &nbsp;  En ausencia del Sub-secretario encargado interinamente del Ministerio de interior.</div><br><br><div class=\"p\">&nbsp; &nbsp;  PINTO.</div><br><div class=\"p\">&nbsp; &nbsp;  De Zegers.</div></div>", "i": 10237840}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "SECRETARÍAS DE LAS INTENDENCIAS DE PROVINCIA", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1827-11-13", "doble_articulado": false, "id_norma": "1156304", "numero_fuente": "1827", "tipo_version": "3", "tipo_ver