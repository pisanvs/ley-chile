{"html": [{"t": "<div><br><div class=\"p\">AJENTE FISCAL</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Mayo 27 de 1825</div></div>", "i": 10237790}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Considerando que el Ministerio Fiscal no puede despacharse debidamente sin un Ajente, especialmente para lo criminal, vengo en nombrar para este destino al Licenciado D. Jos&#xE9; Manuel Barros, con el mismo sueldo que disfrutaba su antecesor. Comun&#xED;quese y t&#xF3;mese razon.</div></div>", "i": 10237791}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Vicu&#xF1;a.</div></div>", "i": 10237792}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "AJENTE FISCAL", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-05-27", "doble_articulado": false, "id_norma": "1158385", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-05-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-05-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-05-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2021-06-04", "fecha_version": "1825-05-27", "fecha_actualizacion_texto": "2021-06-04", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10237790}, {"n": "Artículo", "i": 10237791, "t": 6}, {"n": "P