{"html": [{"t": "<div><div class=\"p\">BAJAS MILITARES.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Marzo 27 de 1830.</div></div>", "i": 10250825}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Teniendo consideracion a lo acordado por el Congreso nacional y de plenipotenciarios en 9 del corriente, vengo en decretar, que los jenerales don Jos&#xE9; Manuel Borgo&#xF1;o, don Francisco de la Lastra, don Francisco Calderon, don Juan Gregorio de Las-Heras; los Coroneles don Ramon Picarte, don Manuel Urquizo, y los tenientes coroneles don Eduardo Huitike y don Venancio Escanilla, sean dados de baja desde esta fecha en el ej&#xE9;rcito. </div></div>", "i": 10250826}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon y comun&#xED;quese.</div><br><div class=\"p\">&nbsp; &nbsp;  RUIZ TAGLE.&nbsp; &nbsp;  Mujica.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Sub-Secretario.</div></div>", "i": 10250827}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "BAJAS MILITARES.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1830-03-27", "doble_articulado": false, "id_norma": "1159504", "numero_fuente": "1830", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1830-03-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1830-03-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1830-03-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p