{"html": [{"t": "<div><br><div class=\"p\">COMISARIO DEL EJ&#xC9;RCITO DEL SUR</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Enero 2 de 1829.</div></div>", "i": 10246714}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Habiendo expuesto el Tribunal mayor de cuentas que el Comisario del ej&#xE9;rcito del sur D. Jos&#xE9; Manuel Bazan no ha rendido hasta ahora las fianzas prevenidas por la lei, queda separado de la oficina que se halla a su cargo, debiendo disfrutar la mitad del sueldo de su empleo hasta que sea destinado por el Gobierno, y en su lugar nombrase interinamente a D. Andres Escala con la dotacion que le ha estado se&#xF1;alada a dicho Bazan.</div></div>", "i": 10246715}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Tomese razon, comun&#xED;quese al jeneral en jefe e impr&#xED;mase.</div><br><div class=\"p\">&nbsp; &nbsp;  PINTO</div></div>", "i": 10246716}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "COMISARIO DEL EJÉRCITO DEL SUR", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1829-01-02", "doble_articulado": false, "id_norma": "1159110", "numero_fuente": "1829", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1829-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1829-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1829-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_in