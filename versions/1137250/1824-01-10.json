{"html": [{"t": "<div><br><div class=\"p\">DESPACHO DE LOS FISCALES.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Enero 10 de 1824.</div></div>", "i": 10064852}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  A fin de que no pare el despacho que corria a cargo de los fiscales y que por la Constitucion pol&#xED;tica debe pasar al Procurador nacional, y sus vice-procuradores; vengo en autorizar a los dos fiscales D. Vicente Aguirre y D. Fernando Elizalde para que contin&#xFA;en en el mismo despacho como hasta aqu&#xED;, &#xED;nterin se nombran vice-procuradores, y se nombra tambien la persona que haya de subrogar al actual Procurador nacional durante su ocupacion en el Ministerio de Estado que actualmente sirve. Comun&#xED;quese en la hora, e ins&#xE9;rtese en el Boletin.</div><br></div>", "i": 10064853}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  ERRAZURIZ.</div><br><div class=\"p\">&nbsp; &nbsp;  Ega&#xF1;a.</div><br></div>", "i": 10064854}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "DESPACHO DE LOS FISCALES.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-01-10", "doble_articulado": false, "id_norma": "1137250", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "", "vigencias": [{"desde": "1824-01-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-01-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-01-10", "fin_vigencia": "", "tipo_v