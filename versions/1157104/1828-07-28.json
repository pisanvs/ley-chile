{"html": [{"t": "<div><div class=\"p\">NOMBRAMIENTO DE MINISTRO DE HACIENDA.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 28 de 1828.</div></div>", "i": 10235633}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Hall&#xE1;ndose vacante el empleo de Ministro de Estado de Hacienda por renuncia del que lo serv&#xED;a; y satisfecho plenamente del distinguido m&#xE9;rito, aptitudes y demas circunstancias recomendables del ciudadano D. Francisco Raiz Tagle, despues de haber obtenido del Congreso nacional la aprobacion, vengo en nombrarle por tal Ministro de Estado en el Departamento de Hacienda. T&#xF3;mese razon y comun&#xED;quese.</div></div>", "i": 10235634}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  PINTO.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; Rodr&#xED;guez.</div></div>", "i": 10235635}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "NOMBRAMIENTO DE MINISTRO DE HACIENDA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1828-07-28", "doble_articulado": false, "id_norma": "1157104", "numero_fuente": "1828", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1828-07-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1828-07-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1828-07-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2021-06-02", "fecha_version": "1828-07-28", "fecha_