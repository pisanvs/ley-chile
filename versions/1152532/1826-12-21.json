{"html": [{"t": "<div><br><div class=\"p\">CONSUL DE CHILE EN LA REPUBLICA ARJENTINA.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Diciembre 21 de 1826. </div></div>", "i": 10208926}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Siendo conveniente a los intereses de Chile el nombramiento de un C&#xF3;nsul jeneral que vele sobre los intereses de su comercio con la Rep&#xFA;blica Arjentina, he venido en nombrar al Sr. D. Miguel Riesco y Puente, por tal C&#xF3;nsul jeneral de Chile en dicha Rep&#xFA;blica, y con residencia en Buenos Aires.</div><br><div class=\"p\">&nbsp; &nbsp;  El Ministro Secretario de Estado en el Departamento de Relaciones Exteriores queda encargado del cumplimiento de este decreto. T&#xF3;mese razon donde corresponda, comun&#xED;quese y publ&#xED;quese.</div></div>", "i": 10208927}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  EIZAGUIRRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Gandarillas.</div></div>", "i": 10208928}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES"], "titulo_norma": "CONSUL DE CHILE EN LA REPUBLICA ARJENTINA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1826-12-21", "doble_articulado": false, "id_norma": "1152532", "numero_fuente": "1826", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1826-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1826-12-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1826-12-21", "fin_vigenci