{"html": [{"t": "<div><div class=\"p\">Nombramiento de don Jos&#xE9; Benito V&#xE1;rgas para una comision</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de Febrero de 1820.</div></div>", "i": 10005345}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Adm&#xED;tese la renuncia que hace de la comision para hacer efectivo el pago del pr&#xE9;stamo para la espedicion sobre el Per&#xFA; a don Francisco de Borja Fontecilla, i en su lugar se nombra a don Jos&#xE9; Benito V&#xE1;rgas, a quien se le trascribir&#xE1; para su cumplimiento, con prevencion que los papeles concernientes a dicho cobro est&#xE1;n en poder del secretario del Excmo. Senado para que los recoja.-</div></div>", "i": 10005346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  O&apos;Higgins.- Cruz.</div></div>", "i": 10005347}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Nombramiento de don José Benito Várgas para una comision", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1820-02-28", "doble_articulado": false, "id_norma": "1129365", "numero_fuente": "1820", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1820-02-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1820-02-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1820-02-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2019-03-08", "fecha_version": "1820-02-28", "fecha_actualiza