{"html": [{"t": "<div><div class=\"p\">EXAMENES PUBLICOS.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Febrero 8 de 1832.</div><br><br></div>", "i": 10250794}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Con lo informado por los Rectores de la Universidad y del Instituto nacional se declara: que mientras se acuerda un plan jeneral de estudios, los alumnos de cualquier establecimiento particular que deseen habilitarse para seguir una carrera p&#xFA;blica deber&#xE1;n rendir sus examenes en la capilla del Instituto nacional, con asistencia de los profesores que prevengan la constitucion del establecimiento y del Rector de la Universidad que presidir&#xE1; este acto, y en su ausencia le subrogar&#xE1; el Rector del Instituto. </div><br><br></div>", "i": 10250795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Comun&#xED;quese y devu&#xE9;lvase.</div><br><div class=\"p\">&nbsp; &nbsp;  PRIETO.&nbsp; &nbsp;  Err&#xE1;zuriz.</div></div>", "i": 10250796}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "EXAMENES PUBLICOS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-02-08", "doble_articulado": false, "id_norma": "1160417", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-02-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-02-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-02-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes":