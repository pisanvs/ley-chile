{"html": [{"t": "<div><br><div class=\"p\">ISLAS DE JUAN FERNANDEZ</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso nacional con fecha 30 de Enero ha sancionado lo que sigue:</div><br></div>", "i": 10246859}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art. &#xFA;nico. Se autoriza al Poder Ejecutivo para que apruebe en los t&#xE9;rminos que crea convenientes la propuesta que ha hecho el ciudadano D. Jos&#xE9; Joaquin Larrain sobre las islas de Juan Fernandez.</div><div class=\"p\">&nbsp; &nbsp;  Por tanto ordeno que se cumpla, se tome razon en las oficinas que corresponda y se inserte en el Boletin. Dado en la Sala de Gobierno en Santiago de Chile a 3 de febrero de 1829.</div></div>", "i": 10246860}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  R&#xFA;brica de S.E.</div><div class=\"p\">&nbsp; &nbsp;  Rodr&#xED;guez. </div></div>", "i": 10246861}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "ISLAS DE JUAN FERNANDEZ", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1829-02-03", "doble_articulado": false, "id_norma": "1159107", "numero_fuente": "", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1829-02-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1829-02-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1829-02-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2021-06-29", "fecha_version": "1829-02-03", "f