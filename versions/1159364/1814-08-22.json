{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  D. Jos&#xE9; Ignacio Zenteno</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Agosto 22 de 1814.</div></div>", "i": 10227862}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  D. Jos&#xE9; Ignacio Zenteno ha quedado en la posesion de todos sus empleos como en su inmanchada reputacion, desde que sali&#xF3; del arresto que se levant&#xF3; con buen conocimiento del equ&#xED;voco que se lo caus&#xF3;. Tendr&#xE1;se entendido por los Tribunales, Juzgados, i Corporaciones donde sirviese para que en nada se altere, a pesar de cualquier decreto arrancado en el tiempo de su prisi&#xF3;n. - </div></div>", "i": 10227863}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Correa. - Uribe. - Mu&#xF1;oz.</div></div>", "i": 10227864}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "D. José Ignacio Zenteno", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1814-08-22", "doble_articulado": false, "id_norma": "1159364", "numero_fuente": "1814", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1814-08-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1814-08-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1814-08-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2021-05-17", "fecha_version": "1814-08-22", "fecha_actualizacion_texto": "2021-05-17", "tipo_tratado": ""}