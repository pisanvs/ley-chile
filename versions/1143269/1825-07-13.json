{"html": [{"t": "<div><div class=\"p\">SUPRESION DEL CAPELLAN DE LOS CASTILLOS DE VALPARAISO</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 13 de 1825. </div></div>", "i": 10114295}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Siendo m&#xE9;ramente nominal el t&#xED;tulo de Capellan de los castillos, que ha tenido el P&#xE1;rroco de Valparaiso; se deroga y suprime el sueldo de ciento ochenta pesos, que anualmente ha tirado.</div></div>", "i": 10114296}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, comun&#xED;quese e impr&#xED;mase.</div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  ------ Correa de Saa.</div></div>", "i": 10114297}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "SUPRESION DEL CAPELLAN DE LOS CASTILLOS DE VALPARAISO", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-07-13", "doble_articulado": false, "id_norma": "1143269", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-07-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-07-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-07-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2020-04-13", "fecha_version": "1825-07-13", "fecha_actualizacion_texto": "2020-04-13", "tipo_tratado": ""}, "alertas": [], "a