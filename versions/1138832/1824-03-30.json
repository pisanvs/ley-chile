{"html": [{"t": "<div><div class=\"p\">ALCALDES.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Marzo 30 de 1824.</div></div>", "i": 10075389}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Estando inhibidos los Jefes pol&#xED;ticos de conocer en los negocios judiciales o contenciosos, declaro, que cuando los Alcaldes se hallen subrogando a dichos Jefes pol&#xED;ticos en virtud del art. 207 de la Constitucion, las funciones de la alcald&#xED;a ser&#xE1;n desempe&#xF1;adas por el individuo mas antiguo de la Municipalidad. Ins&#xE9;rtese en el Boletin.</div></div>", "i": 10075390}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  ERRAZUR&#xCD;Z.&nbsp; &nbsp; &nbsp; &nbsp;  Ega&#xF1;a.</div></div>", "i": 10075391}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["DEPARTAMENTO DE GOBIERNO Y RELACIONES EXTERIORES"], "titulo_norma": "ALCALDES.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-03-30", "doble_articulado": false, "id_norma": "1138832", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-03-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-03-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-03-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2019-12-03", "fecha_version": "1824-03-30", "fecha_actualizacion_texto": "2019-12-03", "tipo_tratado": ""}, "alertas": [], "alerta_global": "",