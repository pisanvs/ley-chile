{"html": [{"t": "<div><br><div class=\"p\">PESCA.</div><br><div class=\"p\">&nbsp; &nbsp;  EL PRESIDENTE DE LA REP&#xDA;BLICA, &amp;c. &amp;c.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso nacional con fecha 6 del corriente, ha sancionado la siguiente lei.</div></div>", "i": 10256502}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art. 1.&#xB0; Ser&#xE1;n libres de los derechos de importaci&#xF3;n y exportaci&#xF3;n los productos en bruto de cualquiera clase de pesca que se haga en buque nacional.</div></div>", "i": 10256503}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; De igual libertad gozar&#xE1;n a su exportaci&#xF3;n, para puertos extranjeros, los mismos productos manufacturados en el pa&#xED;s.</div></div>", "i": 10256504}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  3.&#xB0; El Gobierno dictar&#xE1; las reglas que considere justas para evitar todo fraude contra la Hacienda p&#xFA;blica en el jiro que esta lei proteje.</div></div>", "i": 10256505}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por tanto, ordeno y mando se publique y circule para su cumplimiento. Palacio del Gobierno en Santiago, Octubre 18 de 1832.</div><br><div class=\"p\">&nbsp; &nbsp;  JOAQUIN PRIETO.</div><div class=\"p\">&nbsp; &nbsp;  Manuel Rengifo.</div></div>", "i": 10256506}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "33", "numero": "S/N", "abreviacion": "LEI", "descripcion": "Lei", "compuesto": "Lei-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "PESCA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-10-18", "doble_articulado": false, "id_norma": "1161636", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-10-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-10-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-10-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2021-08-03", "fecha_version": "1832-10-18", "fecha_actualizacion_texto": "2021-08-03", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10256502}, {"n": "Artículo 1", "i": 10256503, "t": 6}, {"n": "Artículo 2", "i": 10256504, "t": 6}, {"n": "Artículo 3", "i": 10256505, "t": 6}, {"n": "Promulgación", "i": 10256506}]}