{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  YERBA-MATE Y AZUCARES</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Marzo 21 de 1827.</div><br><div class=\"p\">&nbsp; &nbsp;  Habiendo ocurrido dudas sobre la intelijencia del decreto de 7 de enero de este a&#xF1;o, que rebaja los derechos espec&#xED;ficos de los az&#xFA;cares y yerba-mate al 27 p.%, el Gobierno ha tenido a bien decretar:</div></div>", "i": 10246041}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1.&#xB0; Los art&#xED;culos mencionados gozar&#xE1;n de la rebaja de derechos si cumpliesen el t&#xE9;rmino legal del almacenaje, desde el 1.&#xB0; de julio de este a&#xF1;o en adelante.</div></div>", "i": 10246042}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; Si lo cumpliesen antes de esta fecha quedan sujeto al pago del derecho espec&#xED;fico que hoy se cobra a su introduccion.</div></div>", "i": 10246043}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  3.&#xB0; T&#xF3;mese razon, circ&#xFA;lese e impr&#xED;mase.</div></div>", "i": 10246044}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  PINTO.</div><br><div class=\"p\">&nbsp; &nbsp;  Blanco.</div></div>", "i": 10246045}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "YERBA-MATE Y AZUCARES", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1827-03-21", "doble_articulado": false, "id_norma": "1158626", "numero_fuente": "1827", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde