{"html": [{"t": "<div><div class=\"p\">NOMBRAMIENTO DE FISCAL INTERINO.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Noviembre 5 de 1827.</div></div>", "i": 10245899}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Habiendo admitido a D. Vicente Aguirre su renuncia del empleo de Ministro Fiscal interino, y en virtud de nuevas propuestas que me ha pasado la suprema Corte vengo en nombrar para que desempe&#xF1;e el mismo destino el juez de derecho de la Provincia de Coquimbo D. Manuel Gonzalez, con retencion de este empleo, y goce de sueldo correspondiente al empleo que ahora le confiero, sirvi&#xE9;ndole de bastante t&#xED;tulo el presente decreto.&#x2013; </div></div>", "i": 10245900}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon y comun&#xED;quese.</div><br><div class=\"p\">&nbsp; &nbsp;  PINTO.</div><div class=\"p\">&nbsp; &nbsp;  Ramos.&nbsp; &nbsp;  Pro-secretario.</div></div>", "i": 10245901}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "NOMBRAMIENTO DE FISCAL INTERINO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1827-11-05", "doble_articulado": false, "id_norma": "1156306", "numero_fuente": "1827", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1827-11-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1827-11-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1827-11-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v