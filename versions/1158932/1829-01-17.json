{"html": [{"t": "<div><div class=\"p\">CAMINO CARRIL DE VALPARAISO.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso nacional con fecha 13 de enero ha sancionado lo que sigue:</div></div>", "i": 10245664}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. 1.&#xB0; F&#xF3;rmese un camino carril de Valpara&#xED;so a Aconcagua.</div><br><br></div>", "i": 10245665}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; Del producto del ramo de caminos se destinar&#xE1; anualmente la cantidad que a juicio del Poder Ejecutivo baste para su formacion.</div><div class=\"p\">&nbsp; &nbsp;  Por tanto ordeno que se cumpla, se tome razon en las oficinas que corresponda, y se publique, insert&#xE1;ndose en el Bolet&#xED;n.</div></div>", "i": 10245666}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Dado en la Sala de Gobierno en Santiago de Chile a 17 enero de 1829.</div><br><div class=\"p\">&nbsp; &nbsp;  R&#xFA;brica de S.E. </div><br><div class=\"p\">&nbsp; &nbsp;  Rodr&#xED;guez.</div></div>", "i": 10245667}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "S/N", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "Ley-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "CAMINO CARRIL DE VALPARAISO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1829-01-17", "doble_articulado": false, "id_norma": "1158932", "numero_fuente": "1829", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1829-01-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1829-01-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "18