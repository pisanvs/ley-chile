{"html": [{"t": "<div><div class=\"p\">ADICION AL DECRETO DE 5 DE SETIEMBRE N&#xDA;M. 61.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Setiembre 16 de 1828.</div></div>", "i": 10237619}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  A fin de que el servicio se distribuya con igualdad entre los ciudadanos, respecto a que todos son interesados en el mantenimiento del &#xF3;rden, se declara que adem&#xE1;s de la clase designada para la formacion del batallon de la Constitucion, creado por el decreto enunciado, entrar&#xE1;n en esta los demas vecinos acomodados.</div><div class=\"p\">&nbsp; &nbsp;  Transcribase al Intendente de la provincia.</div></div>", "i": 10237620}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  R&#xFA;brica de S.E.</div><div class=\"p\">&nbsp; &nbsp;  Borgo&#xF1;o.</div></div>", "i": 10237621}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "ADICION AL DECRETO DE 5 DE SETIEMBRE NÚM. 61.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1828-09-16", "doble_articulado": false, "id_norma": "1158786", "numero_fuente": "1828", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1828-09-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1828-09-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1828-09-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresado_por": "10418", "fech