{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6222443}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 752 de 13 de Agosto de 1987 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se autoriza a don Elizardo Bustamante Toledo para efectuar todo tipo de servicio de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.- </div></div>", "i": 6222444}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mariano Varas Hern&#xE1;ndez, Secretario Regional Ministerial (S) de Transportes y Telecomunicaciones Regi&#xF3;n del Maule.</div><br></div>", "i": 6222445}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "752 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-752 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-13", "doble_articulado": false, "id_norma": "152214", "numero_fuente": "32852", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-22", "vigencias": [{"desde": "1987-08-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-08-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-08-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac