{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br><br></div>", "i": 6575645}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 368 de 14 de junio de 2006, de Serviu Metropolitano, orden&#xF3; expropiaci&#xF3;n parcial, conforme D.L. N&#xBA; 2.186 de 1978, del lote N&#xBA; 4 correspondiente del inmueble ubicado en Avda. Larra&#xED;n N&#xBA; 6941, presunto rol de aval&#xFA;o N&#xBA; 4300-37, comuna de La Reina, de dominio de don Hugo Manuel Ilabaca Morales. Por acuerdo, de fecha 6 de marzo de 2006, suscrita por don Hugo Manuel Ilabaca Morales y la jefa del departamento de gesti&#xF3;n inmobiliaria, se conviene como monto definitivo de la indemnizaci&#xF3;n por expropiaci&#xF3;n la cantidad de $77.044.500.- pagadera al contado. </div></div>", "i": 6575646}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 6575647}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "368", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-368"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "ORDENA EXPROPIACIONES PARCIALES DE INMUEBLES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-14", "doble_articulado": false, "id_norma": "251243", "numero_fuente": "38514", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-07-15", "vigencias": [{"desde": "2006-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "20