{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.008 EXENTO, DE 2003 </div></div>", "i": 6571594}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.008 de fecha 18 de diciembre de 2003, de Educaci&#xF3;n, se declara aprobada al Instituto Profesional Instituto Nacional del F&#xFA;tbol la carrera t&#xE9;cnica de nivel superior que se indica:</div><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; : T&#xE9;cnico de Operaci&#xF3;n y Mantenci&#xF3;n de</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Recintos Deportivos y Recreativos.</div><div class=\"p\">T&#xED;tulo T&#xE9;cnico : T&#xE9;cnico de Nivel Superior en Operaci&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  y Mantenci&#xF3;n de Recintos Deportivos y</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Recreativos.</div><br><div class=\"p\">&nbsp; &nbsp;  Dicha carrera podr&#xE1; ser impartida en jornada diurna en su Sede de la ciudad de Santiago, a contar del primer semestre del a&#xF1;o 2004.</div><br></div>", "i": 6571595}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de enero de 2004.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6571596}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1008 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1008 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.008 EXENTO, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-18", "doble_articulado": false, "