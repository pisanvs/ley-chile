{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 312, DE 1986</div><br><br></div>", "i": 6187353}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 312 de 11 de diciembre de 1986 se ha aprobado un plan de estudio especial al Liceo A No. 4, de Santiago, &quot;Isaura Dinator de Guzm&#xE1;n&quot;, para la Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica. La aplicaci&#xF3;n del presente plan de estudio se iniciar&#xE1; en 1987 desde 1&#xB0; a 3&#xB0; a&#xF1;o y se har&#xE1; extensiva hasta 4&#xB0; a&#xF1;o, inclusive, en 1988. </div></div>", "i": 6187354}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de Marzo de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6187355}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "312 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-312 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 312, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-12-11", "fecha_derogacion": "1996-01-29", "doble_articulado": false, "id_norma": "142114", "numero_fuente": "32746", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1987-04-13", "vigencias": [{"desde": "1996-01-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1987-04-13", "hasta": "1996-01-28", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1996-01-29", "fin_vigencia": ""}, "vigencias_version_nor