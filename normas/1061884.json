{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9440230}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.128, de 25 de abril de 2014, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1046027&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.913</a> de 2012, s&#xF3;lo en cuanto autorizaron a PESCA CHILE S.A., para realizar actividades pesqueras extractivas con la nave &quot;Saint Pierre&quot;, respecto del recurso hidrobiol&#xF3;gico Reineta, en el &#xE1;rea mar&#xED;tima comprendida entre el paralelo 44&#xBA;30&apos; L.S. y el paralelo 47&#xBA; L.S., en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum citado en Visto de la resoluci&#xF3;n extractada.</div></div>", "i": 9440231}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de abril de 2014.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9440232}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1128 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1128 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-04-25", "doble_articulado": false, "id_norma": "1061884", "numero_fuente": "40848", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-05-05", "vigencias": [{"desde": "20