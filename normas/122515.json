{"html": [{"t": "<div><br><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A LEONARDO PI&#xD1;ONES GONZALEZ</div><br></div>", "i": 6123705}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La II Direcci&#xF3;n Regional Antofagasta del SII, por resoluci&#xF3;n N&#xBA; Ex. 144 de 15 julio 1998, otorga, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n y hasta el 31 de julio de 1999 a Leonardo Pi&#xF1;ones Gonz&#xE1;lez Rut 6.438.863-0, la calidad de agente retenedor del Impuesto al Valor Agregado en las operaciones de ganado vivo, establecido en la Res. N&#xBA; Ex.</div><div class=\"p\">2.379/98 de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del d&#xED;a 24.04.98, modificada por Res. N&#xBA; Ex. 3.785/98 publicada en el Diario Oficial del 30.06.98.</div><br></div>", "i": 6123706}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Antofagasta, 15 de Julio de 1998.- Ra&#xFA;l Fierro P&#xE9;rez, Director Regional (S).</div><br></div>", "i": 6123707}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "144 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-144 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "II DIRECCIÓN REGIONAL ANTOFAGASTA"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A LEONARDO PIÑONES\nGONZALEZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "LEONARDO PI ONES GONZALEZ"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-15", "doble_articulado": false, "id_norma": "122515", "numero_fuente": "36128", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-07-31", "vigencias": [{"desde