{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESIGNA SUBROGANTES DEL DIRECTOR REGIONAL METROPOLITANO SANTIAGO SUR </div></div>", "i": 6002686}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n D.N. 10 de 5 de Julio de 1994, de la Direcci&#xF3;n Regional Metropolitana Santiago Sur, se ha designado a los siguientes funcionarios que subrogar&#xE1;n al Director Regional:</div><br><div class=\"p\"> 1&#xB0;.-&nbsp;  Sr. Germ&#xE1;n Soto Vilches</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; RUT. N&#xB0; 5.283.812-6 Jefe del Depto. de Resoluciones, Directivo Grado 7&#xB0;</div><br><div class=\"p\"> 2&#xB0;.-&nbsp;  Sr. Urbano Luna Ojeda</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; RUT. N&#xB0; 6.212.762-7 Jefe del Depto. de Fiscalizaci&#xF3;n, Directivo Grado 7&#xB0;</div><br><div class=\"p\"> 3&#xB0;.-&nbsp;  Sr. Fernando Morgado Calder&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; RUT. N&#xB0; 3.018.583-8 Jefe del Depto. de Avaluaciones, Directivo Grado 7&#xB0;</div><br><div class=\"p\"> 4&#xB0;.-&nbsp;  Srta. Mar&#xED;a In&#xE9;s Rubilar Tapia</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; RUT. N&#xB0; 3.486.265-6 Jefe del Depto. Administrativo, Directivo Grado 7&#xB0; </div></div>", "i": 6002687}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; JORGE A. DE CALISTO BRAVO</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Director Regional</div><br></div>", "i": 6002688}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-10"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DESIGNA SUBROGANTES DEL DIRECTOR REGIONAL\nMETROPOLITANO SANTIAGO SUR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SUBROGACION", "DIRECCION REGIONAL", "REGION METROPOLITANA", "SANTIAGO", "SERVICI