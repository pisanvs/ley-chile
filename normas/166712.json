{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;91 EXENTO, DE 2000</div><br><br></div>", "i": 6268942}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA;91, de 21 de marzo del 2000, se ha aprobado el programa de Religi&#xF3;n Cat&#xF3;lica para 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, ambas modalidades, el que podr&#xE1; aplicarse seg&#xFA;n lo dispuesto en el decreto supremo de Educaci&#xF3;n N924, de 1983, respetando la gradualidad establecida en el decreto supremo N&#xBA;220, de 1998 y sus modificaciones. </div></div>", "i": 6268943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de abril de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6268944}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "91 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-91 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº91 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-03-21", "doble_articulado": false, "id_norma": "166712", "numero_fuente": "36645", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-20", "vigencias": [{"desde": "2000-04-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-04-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-04-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2000-04-20", "fecha_version": "2000-04-20", "fecha_act