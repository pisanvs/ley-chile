{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 763 EXENTO, DE 1998</div><br><br><br><br></div>", "i": 7241398}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 763 de fecha 17 de julio de 1998 del Ministerio de Educaci&#xF3;n, se aprobaron las adecuaciones al plan y programas de estudios de la carrera de Turismo del Centro de Formaci&#xF3;n T&#xE9;cnica Centro de Estudios Tur&#xED;sticos CET, modific&#xE1;ndose en consecuencia, el Decreto Exento del Ministerio de Educaci&#xF3;n N&#xBA; 352 del 26 de marzo de 1997. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1998. Santiago, 2 de octubre de 1998.</div><br></div>", "i": 7241399}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7241400}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "763 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-763 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 763 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "CENTRO DE FORMACION TECNICA CENTRO DE ESTUDIOS TURISTICOS CET", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-17", "doble_articulado": false, "id_norma": "126407", "numero_fuente": "36196", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-10-24", "vigencias": [{"desde": "1998-10-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-10-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-10-24