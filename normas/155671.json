{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xB0; 1.734</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Comit&#xE9; Ejecutivo de este Banco Central de Chile en su Sesi&#xF3;n N&#xB0; 1.734, celebrada el 28 de mayo de 1986, adopt&#xF3; los siguientes acuerdos: </div></div>", "i": 6232795}, {"t": "<div><div class=\"p\">1734-11-860528 - Casa de Cambio Travelman Ltda.- Revoca autorizaci&#xF3;n otorgada para operar como tal.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3;, a pedido de los interesados, revocar la autorizaci&#xF3;n N&#xB0; 57 concedida a la Casa de Cambio Travelman Ltda., para operar como tal en su local ubicado en calle Luis Thayer Ojeda N&#xB0; 14, Santiago. </div></div>", "i": 6232796}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de mayo de 1986.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6232797}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1734", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1734"}, {"tipo": "5", "numero": "1734-11", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1734-11"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO;CENTRAL DE CHILE EN SU SESION N° 1.734", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-05-30", "doble_articulado": false, "id_norma": "155671", "numero_fuente": "32485", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-06-02", "vigencias": [{"desde": "1986-06-02", "hasta": "", "tipo_version": "3"