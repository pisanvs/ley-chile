{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 84, DE 1987 </div></div>", "i": 8603879}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 84, de 24 de abril de 1987 se ha aprobado para el Liceo Industrial A No. 96 de San Miguel, provincia de Santiago, Regi&#xF3;n Metropolitana, planes y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar 1987 y hasta el a&#xF1;o escolar de 1992, en las Especialidades de:</div><div class=\"p\">1.- Fotomec&#xE1;nica.</div><div class=\"p\">2.- Impresi&#xF3;n Gr&#xE1;fica.</div><div class=\"p\">3.- Composici&#xF3;n Gr&#xE1;fica.</div><br></div>", "i": 8603880}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 05 de Mayo de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 8603881}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "84 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-84 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 84, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-04-24", "doble_articulado": false, "id_norma": "149102", "numero_fuente": "32769", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-05-13", "vigencias": [{"desde": "1987-05-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-05-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-05-13", "fin_vig