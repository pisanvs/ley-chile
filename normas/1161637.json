{"html": [{"t": "<div><br><div class=\"p\">GANADOS.</div><br><div class=\"p\">&nbsp; &nbsp;  EL PRESIDENTE DE LA REP&#xDA;BLICA, &amp;c.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso nacional, con fecha 16 del presente, ha sancionado la siguiente lei:</div></div>", "i": 10256651}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art. 1.&#xB0; Toda cabeza de ganado vacuno, que se interne por cordillera, pagar&#xE1; cuatro pesos de derechos; cada mula o caballo dos pesos; un peso cada burro, y cuatro reales las ovejas o carneros.</div></div>", "i": 10256652}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; Este derecho principiar&#xE1; a cobrarse treinta d&#xED;as despu&#xE9;s de la promulgaci&#xF3;n de la presente lei.</div></div>", "i": 10256653}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  3.&#xB0; El Gobierno queda encargado de hacer efectiva su recaudaci&#xF3;n, dictando las providencias convenientes.</div></div>", "i": 10256654}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por tanto, ordeno y mando se publique y circule para su cumplimiento. Palacio del Gobierno en Santiago, 18 de Octubre de 1832.</div><div class=\"p\">&nbsp; &nbsp;  JOAQUIN PRIETO.</div><div class=\"p\">&nbsp; &nbsp;  Manuel Rengifo.</div></div>", "i": 10256655}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "33", "numero": "S/N", "abreviacion": "LEI", "descripcion": "Lei", "compuesto": "Lei-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "GANADOS", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-10-18", "doble_articulado": false, "id_norma": "1161637", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-10-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-10-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-10-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2021-08-03", "fecha_version": "1832-10-18", "fecha_actualizacion_texto": "2021-08-03", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10256651}, {"n": "Artículo 1", "i": 10256652, "t": 6}, {"n": "Artículo 2", "i": 10256653, "t": 6}, {"n": "Artículo 3", "i": 10256654, "t": 6}, {"n": "Promulgación", "i": 10256655}]}