{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,696.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6172878}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados por el teniente-coronel de la Independencia, don Estanislao Anguita, conc&#xE9;dese, por gracia, a su hija do&#xF1;a Quiteria Anguita, el goce de una pension anual de dos mil pesos ($ 2,000), en vez de la de montep&#xED;o de que actualmente disfruta.</div><br></div>", "i": 6172879}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, cuatro de setiembre de mil novecientos doce.- Ramon Barros Luco.- Claudio Vicu&#xF1;a S.</div><br></div>", "i": 6172880}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2696", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2696"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-09-04", "doble_articulado": false, "id_norma": "137680", "numero_fuente": "10371", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-09-05", "vigencias": [{"desde": "1912-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-09-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-09-05", "fin_vigencia": "", "tipo_version": "3"