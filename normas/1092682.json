{"html": [{"t": "<div><br><div class=\"p\">REVOCA CALIDAD QUE EXCEPCIONA DEL R&#xC9;GIMEN DE CAMBIO DE SUJETO DE DERECHO</div></div>", "i": 9715711}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional de Temuco del SII, por resoluci&#xF3;n Ex. N&#xB0; 77316059927, de fecha 30.06.2016, deja sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=121053&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n Ex. N&#xB0; 232</a>, del 23.06.1998, de la IX Direcci&#xF3;n Regional de Temuco del Servicio, que excepcion&#xF3; del r&#xE9;gimen de cambio de sujeto de derecho del Impuesto al Valor Agregado en las operaciones de venta de ganado vivo, a contar de la fecha de esta publicaci&#xF3;n, al contribuyente Juan Carlos Morstadt Anwandter, RUT&nbsp; N&#xB0; 7.083.318-2, conforme a lo establecido en la <a href=\"https://www.leychile.cl/Navegar?idNorma=173624&amp;idParte=0&amp;idVersion=\">Res. Ex. N&#xB0; 3.721, de fecha 28.07.2000</a>, de la Direcci&#xF3;n Nacional del Servicio, publicada en el Diario Oficial del d&#xED;a 01.08.2000.-</div><br></div>", "i": 9715712, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lidia del Carmen Castillo Alarc&#xF3;n, Directora Regional.</div></div>", "i": 9715713}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "77316059927 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-77316059927 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "REVOCA CALIDAD QUE EXCEPCIONA DEL RÉGIMEN DE CAMBIO DE SUJETO DE DERECHO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1043225; EXTRACTO"], "derogacion_tacita": [], "derogado": f