{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9305527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. Exento N&#xBA;2186, de 28 de septiembre de 2012, y de conformidad a lo dispuesto en el Art. 105 del DFL. MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;228, superficie 891 m2., Rol de aval&#xFA;o 3564-5, para la obra, &quot;MEJORAMIENTO RUTA F-50, SECTOR LO OROZCO &#x2013; QUILPU&#xC9;, TRAMO 3: KM. 17,57835 A KM. 29,49799&quot;, Comuna de Quilpu&#xE9;, V Regi&#xF3;n. La Comisi&#xF3;n de Peritos integrada por Juan Pablo Navarro Rachow, Antonio D&#xED;az Rozas y Claudia Arellano G&#xF3;mez, fij&#xF3; el valor de la tasaci&#xF3;n con fecha 19 de marzo de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario JAVIER LUCIANO MARGAS LOYOLA, en la cantidad de $23.696.608.- suma que se pagar&#xE1; al contado. </div><br></div>", "i": 9305528}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9305529}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2186 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2186 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-09-28", "doble_articulado": false, "id_norma": "1044854", "numero_fuente": "40386", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-10-16", "vigencias": [{"desde": "2012-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-10-16", "fin_vigencia": ""}, "vigencias_v