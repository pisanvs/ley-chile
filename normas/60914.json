{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8301255}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 144, de 31 de enero de 1997, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2 de la Resoluci&#xF3;n N&#xBA; 1.445 de 1996, de esta Subsecretar&#xED;a, que autoriz&#xF3; a COMPA&#xD1;IA PESQUERA CAMANCHACA S.A., para operar la nave &quot;Huel&#xE9;n&quot;, matr&#xED;cula N&#xBA; 2499, en el sentido de agregar el recurso hidrobiol&#xF3;gico Sardina espa&#xF1;ola, entre los autorizados para pescar en la misma &#xE1;rea y con el mismo arte de pesca se&#xF1;alados en dicho numeral.</div><br></div>", "i": 8301256}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de enero de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8301257}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "144", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-144"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMPA IA PESQUERA CAMANCHACA S.A.", "PESCA", "AUTORIZACION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-01-31", "fecha_derogacion": "2007-11-29", "doble_articulado": false, "id_norma": "60914", "numero_fuente": "35688", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-02-10", "vigencias": [{"desde": "2007-11-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1997-02-10", "hasta": "2007-11-28", "tipo_versi