{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;mero 4,466</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6203690}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Autor&#xED;zase para liberar de derechos de internaci&#xF3;n por la Aduana de Valpara&#xED;so, hasta por la cantidad de treinta mil pesos ($ 30,000), el mobiliario usado, de casa que trae desde Alemania, la se&#xF1;ora Matilde Yunge v. de Korner.</div><br></div>", "i": 6203691}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y, por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veinte de Noviembre de mil novecientos veintiocho.- Carlos Ib&#xE1;&#xF1;ez C.- Pablo Ram&#xED;rez. </div></div>", "i": 6203692}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4466", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4466"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-11-20", "doble_articulado": false, "id_norma": "147249", "numero_fuente": "15231", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-11-23", "vigencias": [{"desde": "1928-11-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-11-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1928-11-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p