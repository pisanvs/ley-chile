{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ACEPTA RENUNCIA A CARGO QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 67.- Santiago, 3 de marzo de 1994.- Vistos: Lo dispuesto en el Art&#xED;culo 32&#xB0;, N&#xB0; 9, de la Constituci&#xF3;n Pol&#xED;tica del Estado.</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 5889827}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Ac&#xE9;ptase, a contar del 11 de marzo de 1994, la renuncia presentada por el Sr. Roberto Pliscoff V&#xE1;squez, al cargo de Subsecretario de Telecomunicaciones. </div></div>", "i": 5889828}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Germ&#xE1;n Molina Valdivieso, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Saluda atentamente a Ud.- Roberto Pliscoff V&#xE1;squez, Subsecretario de Telecomunicaciones.</div><br></div>", "i": 5889829}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "67", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-67"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "ACEPTA RENUNCIA A CARGO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RENUNCIA", "ROBERTO PLISCOFF VASQUEZ", "SUBSECRETARIO", "SUBSECRETARIA TELECOMUNICACIONES", "MINISTERIO TRANSPORTES TELECOMUNICACIONES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-03", "doble_articulado": false, "id_norma": "8600", "numero_fuente": "34833", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-04-07", "vigencias": [{"desde": "1994-0