{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9335746}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 523, de 21 de febrero de 2013, de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA CHILE S.A., para ampliar actividades pesqueras extractivas con la nave &quot;BEC 82-2012&quot; en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 47&#xBA; L. S. y 57&#xBA; L. S., con palangre, por fuera de las l&#xED;neas de base recta, sobre los siguientes recursos hidrobiol&#xF3;gicos: Cojinoba moteada, Cojinoba del sur, Chancharro, Raya Zearaja spp., Raya Dipturus spp., Raya Psammobatis spp., Tollo, Calamar y Pota.</div></div>", "i": 9335747}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de febrero de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9335748}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "523 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-523 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2013-02-21", "fecha_derogacion": "2014-10-28", "doble_articulado": false, "id_norma": "1049215", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2013-03-04", "vigencias": [{"desde": "2014-10-28", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2013-03-04", "hasta": "2014-10-27", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2014-10-28", "fin_vigencia": ""}, "vigenc