{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que concede cincuenta mil pesos para combatir las enfermedades infecciosas</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. I653.- Santiago, a I7 de Junio de I904.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente:</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274549}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la suma de cincuenta mil pesos ($ 50 000) en la adopcion de las medidas necesarias para combatir las enfermedades infecciosas. </div></div>", "i": 8274550}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- M. E. Ballesteros.</div><br></div>", "i": 8274551}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1653", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1653"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "QUE CONCEDE CINCUENTA MIL PESOS PARA COMBATIR LAS ENFERMEDADES INFECCIOSAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ENFERMEDADES INFECCIOSAS", "PREVENCION", "FONDOS", "INVERSION", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-06-17", "doble_articulado": false, "id_norma": "22821", "numero_fuente": "7930", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1904-06-17", "vigencias": [{"desde": "1904-06-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"