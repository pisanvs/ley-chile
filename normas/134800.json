{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,417.- Santiago, 27 de diciembre de 1900.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6163479}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese por gracia, a la viuda e hijos menores del capitan de nav&#xED;o de la Armada Nacional, don Vicente Merino Jarpa, una pension de tres mil pesos anuales, la cual gozar&#xE1;n con arreglo a la lei de montepio militar.</div><br></div>", "i": 6163480}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ E.- Arturo Besa.</div><br></div>", "i": 6163481}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1417", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1417"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-12-27", "doble_articulado": false, "id_norma": "134800", "numero_fuente": "6778", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-12-28", "vigencias": [{"desde": "1900-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-12-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1900-12-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-04-13", "fecha_version":