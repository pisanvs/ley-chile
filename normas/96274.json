{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 179</div><br><div class=\"p\">Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n No. 179, celebrada el 10 de diciembre de 1991, adopt&#xF3; el siguiente acuerdo:</div><br></div>", "i": 6102492}, {"t": "<div><div class=\"p\">179-01-911210 - Elecci&#xF3;n de Vicepresidente del Consejo y del Banco Central de Chile.</div><br><div class=\"p\">El Consejo, acord&#xF3; elegir, a contar del 10 de diciembre de 1991 y por el t&#xE9;rmino que le resta como Consejero del Banco Central de Chile, a don Juan Eduardo Herrera Correa, en el cargo de Vicepresidente del Consejo y del Banco. </div></div>", "i": 6102493}, {"t": "<div><div class=\"p\">Santiago, 10 de diciembre de 1991.- V&#xED;ctor Vial del R&#xED;o, Secretario General.</div><br></div>", "i": 6102494}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "179", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-179"}, {"tipo": "5", "numero": "179-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-179-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE CHILE\nEN SU SESION No. 179", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-12-10", "doble_articulado": false, "id_norma": "96274", "numero_fuente": "34139", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-12-11", "vigencias": [{"desde": "1991-12-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-12-11", "fin_vigencia": ""}, "vigencias_ve