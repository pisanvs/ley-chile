{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6219175}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 264, del 24 de Junio de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la I Regi&#xF3;n, se autoriza a Ruperto Segundo D&#xED;az Cadima, Luis Rafael Godoy Rojas, Mar&#xED;a Adela Vergara Almonte, Ra&#xFA;l Zacar&#xED;as Vald&#xE9;s Tapia para efectuar el servicio p&#xFA;blico urbano de locomoci&#xF3;n colectiva de pasajeros &quot;L&#xED;nea No. 6 de Arica&quot;, cuvo trazado fue autorizado por resoluci&#xF3;n No.</div><div class=\"p\">69, del 24 de Junio de 1984, de esta Secretar&#xED;a Regional.-</div><br></div>", "i": 6219176}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Eliecer Aedo Rivera, Secretario Regional Ministerial de Transportes y Telecomunicaciones I Regi&#xF3;n Tarapac&#xE1;.</div><br></div>", "i": 6219177}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "264 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-264 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-24", "doble_articulado": false, "id_norma": "151281", "numero_fuente": "32824", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-20", "vigencias": [{"desde": "1987-07-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-20", "fin_vigencia