{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6319469}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA;116, de fecha 6 de diciembre del a&#xF1;o 2000, se aprob&#xF3; la disoluci&#xF3;n voluntaria de la Cooperativa de Trabajo La Esquila Limitada, de sigla &apos;&apos;La Esquila Ltda.&apos;&apos;, de Punta Arenas, que consta en la escritura p&#xFA;blica suscrita con fecha 3 de noviembre del a&#xF1;o 2000, ante el Notario P&#xFA;blico de Magallanes y Ant&#xE1;rtica Chilena, don Horacio Silva Reyes.</div><br></div>", "i": 6319470}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Carlos Rubio Estay, Jefe Departamento Cooperativas, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6319471}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "116", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-116"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-12-06", "doble_articulado": false, "id_norma": "181058", "numero_fuente": "36878", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-02-02", "vigencias": [{"desde": "2001-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-02-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-02-02", "fin_vigencia": "", "tipo_