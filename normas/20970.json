{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 312 EXENTO, DE 1995</div><br><br></div>", "i": 5943728}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 312, de fecha 22 de Mayo de 1995, del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; al Centro de Formaci&#xF3;n T&#xE9;cnica INACAP para ofrecer &quot;Plan Especial de Titulaci&#xF3;n&quot;, para los alumnos egresados en el per&#xED;odo 1983-1991 y que de acuerdo a disposiciones reglamentarias se encuentran con su plazo de titulaci&#xF3;n vencido. El per&#xED;odo de ejecuci&#xF3;n de dicho plan deber&#xE1; efectuarse durante el plazo de un a&#xF1;o y se aplicar&#xE1; por &#xFA;nica vez, s&#xF3;lo a las promociones antes indicadas. </div></div>", "i": 5943729}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 1 de Junio de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943730}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "312 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-312 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 312 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TITULACION", "ALUMNOS", "CENTRO FORMACION TECNICA INACAP"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-22", "doble_articulado": false, "id_norma": "20970", "numero_fuente": "35202", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-06-26", "vigencias": [{"desde": "1995-06-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-06-26", "fin_vigencia": ""}, "vigencias_version_norma":