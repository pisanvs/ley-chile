{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,805, que concede derecho a jubilar a don Manuel J. Valdivia L.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,805.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 8276729}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al Inspector del Palacio de la Moneda, don Manuel J. Valdivia Latorre, el derecho a jubilar con una pension equivalente a su sueldo.</div><br></div>", "i": 8276730}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a diez de Octubre de mil novecientos veintiuno.- ARTURO ALESSANDRI.- H&#xE9;ctor Arancibia Laso. </div></div>", "i": 8276731}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3805", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3805"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 3,805, QUE CONCEDE DERECHO A JUBILAR A DON MANUEL J. VALDIVIA L.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MANUEL J. VALDIVIA LATORRE", "JUBILACION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1921-10-10", "doble_articulado": false, "id_norma": "24259", "numero_fuente": "13099", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1921-10-14", "vigencias": [{"desde": "1921-10-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1921-10-14"