{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6588146}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xB0; 585 de fecha 31 de agosto del 2006, se expropi&#xF3; el lote de terreno N&#xB0; 9 superficie 809 m2, Rol N&#xB0; 63-437, comuna de Lonquimay, IX Regi&#xF3;n para la obra &quot;Camino Malalcahuello-Paso Pino Hachado Rutas R891, R-955 y R-89, sector Liucura-Paso Pino Hachado Km. 158,54000 al Km. 179,59862&quot;, correspondiente al Tramo I Km. 158,54000 al Km. 164,75450 y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Edgardo Ca&#xF1;umir Meliqueo, ascendente a la cantidad de $401.795.- para el lote N&#xB0; 9.</div><br></div>", "i": 6588147}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6588148}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "585 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-585 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-08-31", "doble_articulado": false, "id_norma": "254792", "numero_fuente": "38603", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-11-02", "vigencias": [{"desde": "2006-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2006-11-02", "fecha_