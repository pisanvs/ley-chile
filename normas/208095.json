{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6415951}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 410, de 4 de febrero de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a GIOVANNA ANDREA NANJARI MASSOGLIA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en Bandera N&#xBA; 1258, Concepci&#xF3;n, VIII Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Alga seca: Enteromorpha y Carola.</div><br><div class=\"p\">&nbsp; &nbsp;  La materia prima deber&#xE1; provenir de pescadores artesanales, debidamente autorizados.</div><br></div>", "i": 6415952}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de febrero de 2003.- Jessica Fuentes Olmos, Subsecretaria de Pesca (S).</div><br></div>", "i": 6415953}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "410", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-410"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-02-04", "doble_articulado": false, "id_norma": "208095", "numero_fuente": "37498", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-03-01", "vigencias": [{"desde": "2003-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-03-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pend