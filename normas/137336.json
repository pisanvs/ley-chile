{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,388.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6171665}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- El&#xE9;vase, por gracia, a sesenta pesos mensuales la pensi&#xF3;n de que disfruta do&#xF1;a Dolores Rioseco, preceptora jubilada de la escuela n&#xFA;mero 1 de La Laja.</div><br></div>", "i": 6171666}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese&nbsp; a efecto en todas sus partes como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, siete de setiembre de mil novecientos diez.- Emiliano Figueroa.- C&#xE1;rlos Balmaceda S. </div></div>", "i": 6171667}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2388", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2388"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-09-07", "doble_articulado": false, "id_norma": "137336", "numero_fuente": "9793", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-09-14", "vigencias": [{"desde": "1910-09-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-09-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1910-09-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fe