{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; RECONSTRUCCION DEL EDIFICIO DEL CONGRESO NACIONAL Lei n&#xFA;m. 324.-Santiago, a 28 de Diciembre de 1895.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273911}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza al Presidente de la Rep&#xFA;blica para que invierta la cantidad de quinientos ochenta i cinco mil pesos en hacer reconstruir el edificio del Congreso Nacional en el mismo local que ocupaba.</div><div class=\"p\">&nbsp; &nbsp; Esta autorizacion subsistir&#xE1; hasta por dieziocho meses.</div><br><br></div>", "i": 8273912}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORJE MONTT.-</div><div class=\"p\">O. Renjifo.</div><br></div>", "i": 8273913}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "324", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-324"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "RECONSTRUCCION DEL EDIFICIO DEL CONGRESO NACIONAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONGRESO NACIONAL", "EDIFICIO", "RECONSTRUCCION", "FONDOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-12-28", "doble_articulado": false, "id_norma": "22175", "numero_fuente": "5298", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-12-31", "vigencias": [{"desde": "1895-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"ini