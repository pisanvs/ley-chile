{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6532840}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.946, de 23 de junio de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA EMAR LIMITADA para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Chorrillos N&#xBA; 612, Punta Arenas, XII Regi&#xF3;n, en las l&#xED;neas de proceso de Cocido, Fresco enfriado, Fresco refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 751, de 1993, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6532841}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de junio de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6532842}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1946 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1946 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-23", "doble_articulado": false, "id_norma": "240037", "numero_fuente": "38210", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-14", "vigencias": [{"desde": "2005-07-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_