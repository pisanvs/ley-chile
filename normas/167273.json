{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8561586}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.122 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 2&#xB0; de la resoluci&#xF3;n No. 570, de 1987, de esta Subsecretar&#xED;a, en orden a agregar a continuaci&#xF3;n del mismo la siguiente frase &quot;..., pudiendo extraer en una proporci&#xF3;n no superior al 3% de las capturas, especies que constituyan fauna acompa&#xF1;ante&quot;.</div><br></div>", "i": 8561587}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de Septiembre de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8561588}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1122", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1122"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-24", "doble_articulado": false, "id_norma": "167273", "numero_fuente": "32896", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-10-17", "vigencias": [{"desde": "1987-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-10-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-10-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-05-02", "fech