{"html": [{"t": "<div><div class=\"p\">SUPRESION DEL EMPLEO DE ADMINISTRADOR DE LA ADUANA.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 28 de 1824.</div><br><div class=\"p\">&nbsp; &nbsp;  El Gobierno ha acordado y decreta:</div></div>", "i": 10098817}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.&#xB0; Queda suprimido el empleo de Administrador de la Aduana jeneral, reasumiendo sus funciones los Ministros, Contador y Tesorero, como est&#xE1; mandado en decreto de 12 de julio de 1820.</div><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; El actual Administrador gozar&#xE1; un tercio de su sueldo, mi&#xE9;ntras no se le destina a otro empleo. T&#xF3;mese razon, transcr&#xED;base a quienes corresponda e impr&#xED;mase.</div></div>", "i": 10098818}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  FREIRE.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Diego Jos&#xE9; Benavente.</div></div>", "i": 10098819}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "SUPRESION DEL EMPLEO DE ADMINISTRADOR DE LA ADUANA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-07-28", "doble_articulado": false, "id_norma": "1140787", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-07-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-07-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-07-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": 