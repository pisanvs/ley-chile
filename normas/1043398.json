{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9292993}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP Exento N&#xBA;1444 de 31 de julio de 2012, de conformidad lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;2, superficie 598 m2, rol de Aval&#xFA;o N&#xBA;246-152, comuna de Galvarino, para la obra &quot;PASARELA CORRIENTES BLANCAS, CAMINO CHOL-CHOL HUAMAQUI, SECTOR MADILHUE &#x2013; REPOCURA, KM. 28,78220 AL KM. 29,04360&quot;. La Comisi&#xF3;n de peritos, integrada por PABLO ALEJANDRO SEPULVEDA G&#xD3;MEZ, EVALDO ROBERTO CONTRERAS ROA Y C&#xC9;SAR NOLBERTO CAMPOS VERGARA, fij&#xF3; el valor de tasaci&#xF3;n con fecha 31 de marzo de 2010, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietaria OLGA OLIVIA CONTRERAS SAEZ, en la cantidad de $4.045.160.-, suma que se pagar&#xE1; al contado. </div></div>", "i": 9292994}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9292995}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1444 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1444 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-31", "doble_articulado": false, "id_norma": "1043398", "numero_fuente": "40352", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-09-01", "vigencias": [{"desde": "2012-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-09-01", "fin_vigencia": "