{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6414345}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 421, de 6 de febrero de 2003, de esta Subsecretar&#xED;a, rectif&#xED;case la resoluci&#xF3;n N&#xBA; 229 de 2003, de esta Subsecretar&#xED;a, que reconoci&#xF3; la participaci&#xF3;n conjunta de los armadores SOCIEDAD PESQUERA MAR PROFUNDO S.A. y SOCIEDAD PESQUERA SAN ANTONIO S.A. en la unidad de pesquer&#xED;a Merluza de cola, V-X Regiones, para ejercer el l&#xED;mite m&#xE1;ximo de captura establecido por decreto exento N&#xBA; 1.115 de 2002, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, en el sentido de incorporar al grupo de armadores a Friosur VII S.A.</div><br></div>", "i": 6414346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so,&nbsp; 6 de febrero de 2003.- Jessica Fuentes Olmos, Subsecretario de Pesca (S).</div><br></div>", "i": 6414347}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "421", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-421"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-02-06", "doble_articulado": false, "id_norma": "207621", "numero_fuente": "37483", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-02-12", "vigencias": [{"desde": "2003-02-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-02-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-02-12", "fin_vigencia": "", "tipo_