{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6204796}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 473 de 28 de Abril de 1987, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a Derecho de Adquisici&#xF3;n y Sector Expropiado Predio &quot;Hijuela Dos San Francisco de San Jos&#xE9; de Palquibudi&quot; de la comuna de Rauco, VII Regi&#xF3;n; y Derechos Aprovechamiento Aguas que corresponden a parcelas N&#xB0;s. 1 a la 6, sitios N&#xB0;s. 1 al 7 del Proyecto de Parcelaci&#xF3;n &quot;El Cristo&quot;, formado por predio se&#xF1;alado. Los Derechos de Agua se extraen del Canal Palquibudi derivado del r&#xED;o Mataquito. Publicaci&#xF3;n hecha conforme Art. 13 Ley No.</div><div class=\"p\">18.377.</div><br></div>", "i": 6204797}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6204798}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "473 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-473 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-04-28", "doble_articulado": false, "id_norma": "147548", "numero_fuente": "32760", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-05-02", "vigencias": [{"desde": "1987-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "