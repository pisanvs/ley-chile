{"html": [{"t": "<div><div class=\"p\">RESOLUCI&#xD3;N N&#xBA; 3.049, DE 23.11.2022, DE LA DIRECTORA NACIONAL DE ADUANAS, QUE DETERMINA NO CONVOCAR A CONCURSO DE AGENTES DE ADUANA EN EL A&#xD1;O 2022</div></div>", "i": 10385057}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.049, de 23.11.2022, de la Directora Nacional de Aduanas, se determina no convocar a concurso de agentes de aduana en el a&#xF1;o 2022.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n N&#xBA; 3.049, de 23.11.2022, se encuentra publicado en el sitio web del Servicio Nacional de Aduanas, www.aduana.cl.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10385058}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de noviembre de 2022.- Alejandra Arriaza Loeb, Directora Nacional de Aduanas.</div><br></div>", "i": 10385059}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3049 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3049 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "RESOLUCIÓN Nº 3.049, DE 23.11.2022, DE LA DIRECTORA NACIONAL DE ADUANAS, QUE DETERMINA NO CONVOCAR A CONCURSO DE AGENTES DE ADUANA EN EL AÑO 2022", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2229480", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-11-23", "doble_articulado": false, "id_norma": "1185747", "numero_fuente": "43420", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-12-07", "vigencias": [{"desde": "2022-12-07", "hasta": "", "tipo_version": "3", "tipo_version_