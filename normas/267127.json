{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6745558}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 643, de fecha 29 de octubre de 2007, se expropiaron los lotes de terreno N&#xBA; 1 (FM3-6D2) y N&#xBA; 2 (FM3-6D), superficies 368,94 y 194,55 m&#xB2; respectivamente, rol N&#xBA; 314-80, comuna de Pitrufqu&#xE9;n, para la obra &quot;Regad&#xED;o Faja Maisan, Red Terciaria, Sector Huallizada, Obras Canales FM3-A, FM3-A1, FM3-B, FM3-5, FM3-6C, FM3-6C1 FM3-6D, FM3-6D1, FM3-6D2, FM3-6E y FM3-7, comuna de Pitrufqu&#xE9;n, provincia de Caut&#xED;n, IX Regi&#xF3;n de la Araucania&quot;, y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Juan Millac&#xE1;n Burgos, ascendente a la cantidad de $876.411.</div><br></div>", "i": 6745559}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6745560}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "643", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-643"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-10-29", "doble_articulado": false, "id_norma": "267127", "numero_fuente": "38926", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-01", "vigencias": [{"desde": "2007-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones