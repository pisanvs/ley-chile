{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6346844}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 281, de 21 de Febrero de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n se autoriza a don Fernando H&#xE9;ctor Arriagada Bustamante de la Asociaci&#xF3;n Gremial del Transporte de Pasajeros de Curic&#xF3;, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.- </div></div>", "i": 6346845}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Manuel Coloma Amaro, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n del Maule.</div><br></div>", "i": 6346846}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "281 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-281 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-02-25", "doble_articulado": false, "id_norma": "188721", "numero_fuente": "32416", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-03-07", "vigencias": [{"desde": "1986-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-03-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-03-07", "fi