{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Enrique Valdes Vergara Lei n&#xFA;m. 105.- Santiago, a 12 de Setiembre de 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7162508}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza al Presidente de la Rep&#xFA;blica para que invierta hasta la suma de cinco mil pesos ($ 5,000) en la ereccion de un mausoleo destinado a honrar los restos de don Enrique Valdes Vergara.</div><br><br></div>", "i": 7162509}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Manuel Villamil Blanco.</div><br></div>", "i": 7162510}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "105", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-105"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "ENRIQUE VALDES VERGARA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ENRIQUE VALDES VERGARA", "MAUSOLEO", "CONSTRUCCION", "FONDOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-09-12", "doble_articulado": false, "id_norma": "21971", "numero_fuente": "4621", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-09-15", "vigencias": [{"desde": "1893-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-09-15", "fin_vigencia": "", "tipo_version": "3"}], "ev