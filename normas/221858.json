{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 72 EXENTO, DE 2004 </div></div>", "i": 7309411}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 72, de fecha 3 febrero de</div><div class=\"p\">2004, del Ministerio de Educaci&#xF3;n, se rectific&#xF3; el</div><div class=\"p\">art&#xED;culo 1&#xBA; del decreto exento N&#xBA; 160 del 29 de septiembre de 1988, modificado por el decreto exento N&#xBA; 640 de fecha 7 de diciembre de 1993, ambos de Educaci&#xF3;n, en el siguiente sentido:</div><div class=\"p\">Donde Dice&nbsp;  :&nbsp;  Instituto Profesional San Bartolom&#xE9;</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  de La Serena.</div><div class=\"p\">Debe Decir&nbsp;  :&nbsp;  Instituto Profesional de Chile.</div><br><div class=\"p\">Donde Dice&nbsp;  :&nbsp;  Instituto Profesional San Bartolom&#xE9;</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Limitada.</div><div class=\"p\">Debe Decir&nbsp;  :&nbsp;  Instituto Profesional de Chile</div><div class=\"p\">Limitada.</div><br><br></div>", "i": 7309412}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Santiago, 25 de febrero de 2004.- Pedro Henr&#xED;quez Guajardo, Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 7309413}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "72 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-72 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 72 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-03", "doble_articulado": false, "id_norma": "2218