{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 8.656 EXENTA, DE 2001 </div><br></div>", "i": 6345084}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 8.656, de 23 de julio de 2001, se aprueban Planes y Programas Especiales de Estudios para 1&#xBA;, 2&#xBA;, 3&#xBA; y 4&#xBA; A&#xF1;o de Ense&#xF1;anza Media T&#xE9;cnico-Profesional al Liceo Polit&#xE9;cnico Particular &quot;Andes&quot; de la comuna de Renca, de especial singularidad, administrado por la Fundaci&#xF3;n Duoc, los que ser&#xE1;n aplicados en 1&#xBA; y 3&#xBA; a&#xF1;o medio en el a&#xF1;o escolar 2001, y en 2&#xBA; y 4&#xBA; a&#xF1;o a partir del a&#xF1;o escolar 2002.</div><br></div>", "i": 6345085}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de julio de 2001.- Juan Ruz Ruz, Jefe Divisi&#xF3;n Educaci&#xF3;n General.</div><br></div>", "i": 6345086}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8656 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8656 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 8.656 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-07-23", "doble_articulado": false, "id_norma": "188300", "numero_fuente": "37031", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-08-07", "vigencias": [{"desde": "2001-08-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-08-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-08-07", "fin_vigencia": "", "tipo_version": "3"}