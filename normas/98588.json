{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.274 EXENTO, DE 1997 </div></div>", "i": 7232608}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 1.274 de 31 de diciembre de 1997, se ha modificado el decreto supremo exento de Educaci&#xF3;n N&#xBA; 535 de 1997 y aprueba planes y programas de estudio biling&#xFC;es para los cursos de 6&#xBA; a 8&#xBA; a&#xF1;o (NB.4, NB.5 y NB.6) de Ense&#xF1;anza B&#xE1;sica, a los Colegios &apos;&apos;Alliance Francaise&apos;&apos; de Chile. </div></div>", "i": 7232609}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de enero de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7232610}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1274 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1274 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.274 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIOS ALLIANCE FRANCAISE DE CHILE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-31", "doble_articulado": false, "id_norma": "98588", "numero_fuente": "36023", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-03-24", "vigencias": [{"desde": "1998-03-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-03-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-03-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "u