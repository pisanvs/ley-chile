{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aumenta a $ 4,800 anuales la pensi&#xF3;n de que disfrute don Manuel Barahona Calder&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 8277577}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Aum&#xE9;ntase, por gracia, la pensi&#xF3;n de jubilaci&#xF3;n de que actualmente disfruta don Manuel Barahona Calder&#xF3;n, a la suma de cuatro mil ochocientos pesos anuales.</div><br></div>", "i": 8277578}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecisiete de Octubre de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Enrique Berm&#xFA;dez. </div></div>", "i": 8277579}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4669", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4669"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUMENTA A $ 4.800 ANUALES LA PENSIÓN DE QUE DISFRUTE DON MANUEL BARAHONA CALDERON", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MANUEL BARAHONA CALDERON", "PENSION POR GRACIA", "REAJUSTE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-10-17", "doble_articulado": false, "id_norma": "24821", "numero_fuente": "15500", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-10-18", "vigencias": [{"desde": "1929-10-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-10-1