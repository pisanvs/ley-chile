{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6527462}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.417, de 12 de mayo de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a MARCIAL JAIME VEGA SOTO, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Juan Cruz Vega N&#xBA; 150, poblaci&#xF3;n Buen Retiro, Coronel, VIII Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Fresco refrigerado, Congelado y Conserva, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6527463}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de mayo de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6527464}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1417 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1417 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-05-12", "doble_articulado": false, "id_norma": "238356", "numero_fuente": "38173", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-05-31", "vigencias": [{"desde": "2005-05-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-05-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-05-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ing