{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 265 EXENTO, DE 1995 </div></div>", "i": 5943287}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 265 de fecha 2 de mayo de 1995 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a la Sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto AIEP, para impartir plan y programas de estudio aprobado para la instituci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se se&#xF1;ala, a partir del a&#xF1;o 1995:</div><div class=\"p\">&nbsp; &nbsp; - Sede N&#xB0; 2 - Rancagua.</div><div class=\"p\">&nbsp; &nbsp; Carrera: Sonido.</div><div class=\"p\">&nbsp; &nbsp; T&#xED;tulo: T&#xE9;cnico en Sonido.</div><br></div>", "i": 5943288}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 26 de Mayo de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943289}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "265", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-265"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 265 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA", "INSTITUTO AIEP", "CARRERA TECNICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-02", "doble_articulado": false, "id_norma": "20835", "numero_fuente": "35188", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-06-08", "vigencias": [{"desde": "1995-06-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-06-08", "fin_vigencia": ""}, "vigencias_version