{"html": [{"t": "<div><div class=\"p\">AUTORIZA A LOS ORGANISMOS P&#xDA;BLICOS EN LO QUE INDICA</div></div>", "i": 10169021}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n Ex. del Servicio de Impuestos Internos N&#xB0; 134, de 16 de octubre de 2020, establece que:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Autoriza a los organismos p&#xFA;blicos detallados en la resoluci&#xF3;n, como receptores de documentos tributarios electr&#xF3;nicos, debiendo ajustarse a las instrucciones dispuestas en la <a href=\"https://www.leychile.cl/Navegar?idNorma=227838&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 63, de 2004</a>, modificada por la resoluci&#xF3;n exenta N&#xB0; 91, de 2017.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl).- </div><br></div>", "i": 10169022}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Ver&#xF3;nica Valle Sarah, Subdirectora de Asistencia al Contribuyente.</div><div class=\"p\"> </div></div>", "i": 10169023}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "134 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-134 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A LOS ORGANISMOS PÚBLICOS EN LO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1833791", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-10-16", "doble_articulado": false, "id_nor