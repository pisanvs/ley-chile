{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 115, DE 1986 </div></div>", "i": 6231571}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 115, de 11 de junio de 1986 se han aprobado para el Liceo T&#xE9;cnico San Pablo, de Pudahuel, provincia de Santiago, Regi&#xF3;n Metropolitana, planes y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico - Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar 1986 hasta el a&#xF1;o escolar de 1992, en las Especialidades de: Atenci&#xF3;n de P&#xE1;rvulos con menci&#xF3;n en Educaci&#xF3;n Diferencial y Atenci&#xF3;n de P&#xE1;rvulos con menci&#xF3;n en Sala Cuna.</div><br></div>", "i": 6231572}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de Junio de 1986.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6231573}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "115 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-115 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 115, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-27", "doble_articulado": false, "id_norma": "155227", "numero_fuente": "32509", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-06-30", "vigencias": [{"desde": "1986-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-06-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio