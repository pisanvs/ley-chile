{"html": [{"t": "<div><div class=\"p\">DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE SE&#xD1;ALA </div></div>", "i": 6151552}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 1.450 de 29 de Agosto de 1988, conforme Art. 5&#xB0; transitorio C&#xF3;digo de Aguas, modific&#xF3; Resoluci&#xF3;n Exenta No. 91 de 25 de Enero de 1988, que determin&#xF3; Derechos Aprovechamiento Aguas proporcionales para el Proyecto de Parcelaci&#xF3;n &quot;San Miguel de Calleuque&quot; de la comuna de Peralillo, VI Regi&#xF3;n: en el sentido de reasignar los derechos de aguas de las parcelas N&#xB0;s. 7 a la 17 y sitios N&#xB0;s. 11, 12 y 13 formadas en Sector Expropiado predio &quot;San Jorge&quot;. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377. </div></div>", "i": 6151553}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6151554}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1450 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1450 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-29", "doble_articulado": false, "id_norma": "130937", "numero_fuente": "33161", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-09-01", "vigencias": [{"desde": "1988-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig