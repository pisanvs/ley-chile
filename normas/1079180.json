{"html": [{"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N EXENTA N&#xBA;1.247, DE 2015</div></div>", "i": 9619800}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.247, de 28 de mayo de 2015, del Ministerio de Transportes y Telecomunicaciones, se establecen Est&#xE1;ndares T&#xE9;cnicos, de Operaci&#xF3;n y de Acreditaci&#xF3;n de los Sistemas Tecnol&#xF3;gicos de Localizaci&#xF3;n Autom&#xE1;tica de Veh&#xED;culos (AVL) y se establecen las Condiciones de Entrega de Datos e Informaci&#xF3;n Contenida o Proveniente de Dichos Sistemas. Texto &#xED;ntegro de la resoluci&#xF3;n exenta N&#xBA; 1.247 de 2015, se encuentra disponible en el sitio web www.dtpr.gob.cl.</div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 9619801}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Andr&#xE9;s G&#xF3;mez-Lobo Echenique, Ministro de Transportes y Telecomunicaciones.</div></div>", "i": 9619802}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1247", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1247"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN EXENTA Nº1.247, DE 2015", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-05-28", "doble_articulado": false, "id_norma": "1079180", "numero_fuente": "41199", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-07-04", "vigencias": [{"desde": "2015-07-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci