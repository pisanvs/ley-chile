{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5900272}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decretro M.O.P. N&#xB0; 201, de 28 de abril de 1995, se expropiaron los lotes de terreno N&#xB0;s 7, 9, 10,11, 24, 25 y 44-A, superficies 2.383, 210, 348, 5.548, 579, 514, 2.057 M2., respectivamentes roles de aval&#xFA;os 1096-1, 1093-11, 4229-3 y 4227-4, comuna de Cartagena, para la obra Camino Malvilla Orrego Abajo y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Marta Henr&#xED;quez Tobar, Ram&#xF3;n Vera Vera, Marta Enr&#xED;quez Tobar y otra, Luis Alberto Vera Mondaca y Jos&#xE9; Cel&#xED;n D&#xED;az Valenzuela, ascendente a las cantidades de $1.344.630, $229.072, $325.594, $9.299.754, $1.024.898 y $1.003.011. </div></div>", "i": 5900273}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 5900274}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "201", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-201"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "CARTAGENA", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-04-28", "doble_articulado": false, "id_norma": "10889", "numero_fuente": "35182-2", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-06-01", "vigencias": [{"desde": "1995-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-06-01", "fin_vigencia": "", "tipo_version": "3"}], "evento