{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8332358}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;911, de 30 de junio de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a OLGA VERONICA PARADA URTUBIA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en kil&#xF3;metro N&#xBA;60, Ruta 1, Tramo Tocopilla-Iquique, Tocopilla, donde podr&#xE1; procesar en la l&#xED;nea de elaboraci&#xF3;n de Secado y Molienda de Algas, los siguientes recursos hidrobiol&#xF3;gicos: Chasc&#xF3;n, Huiro y Canutillo.</div><div class=\"p\">D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1.996, de 1996, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 8332359}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de junio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br><br></div>", "i": 8332360}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "911", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-911"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "OLGA VERONICA PARADA URTUBIA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-06-30", "doble_articulado": false, "id_norma": "122149", "numero_fuente": "36126", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-07-29", "vigencias": [{"desde": "1998-07-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Únic