{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE DECLARA &#xC1;REA DE PLAGA QUE INDICA</div></div>", "i": 9851362}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.683, de 15 de noviembre de 2017, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1106078&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 2.412, de 2017</a>, de esta Subsecretar&#xED;a, que declar&#xF3; &#xE1;reas de plaga y de riesgo de plaga de la especie Didymosphenia geminata, en los sectores de cuerpos de aguas, ampli&#xE1;ndola a una nueva cuenca de la VIII Regi&#xF3;n, en la forma que se indica en la resoluci&#xF3;n extractada, y publicada &#xED;ntegramente en la p&#xE1;gina web www.subpesca.cl.</div></div>", "i": 9851363}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de noviembre de 2017.- Pablo Berazaluce Maturana, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9851364}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3683 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3683 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE DECLARA ÁREA DE PLAGA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1305305; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-11-15", "doble_articulado": false, "id_norma": "1111079", "numero_fuente": "41913", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-11-21", "vigencias": [{"desde": "2017-11-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vi