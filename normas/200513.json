{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6389153}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;966 de fecha 3 de junio de 2002, se dej&#xF3; sin efecto el decreto MOP N&#xBA;4558 de 29 de septiembre de 2000, que ordena la expropiaci&#xF3;n del lote de terreno N&#xBA;71, necesario para la ejecuci&#xF3;n de la obra &apos;&apos;Camino Los Robles-Huencuecho-Bajo Perquin, tramo Km.</div><div class=\"p\">46.140,00 al 76.107,70&apos;&apos;, VII Regi&#xF3;n, por cuanto su expropiaci&#xF3;n ya hab&#xED;a sido ordenada por el decreto MOP N&#xBA;2670, de 30 de junio de 2000.</div><br></div>", "i": 6389154}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6389155}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "966", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-966"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-03", "doble_articulado": false, "id_norma": "200513", "numero_fuente": "37308", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-15", "vigencias": [{"desde": "2002-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "PSO", "fecha_ingreso": "2002-07-15", "fecha_version": "2002-07-15", "fe