{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.281 EXENTO, DE 2005 </div><br></div>", "i": 6544751}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 1.281 de 13 de septiembre de 2005, se ha aprobado al Colegio Ant&#xE1;rtica Chilena, comuna de Vitacura, Regi&#xF3;n Metropolitana, un plan de estudio biling&#xFC;e para los cursos de 1&#xBA; a 8&#xBA; a&#xF1;o (NB.1, NB.2, NB.3, NB.4, NB.5 y NB.6) de Ense&#xF1;anza B&#xE1;sica, el que se aplicar&#xE1; a contar del a&#xF1;o escolar 2006.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba el programa de estudio del Subsector de Aprendizaje de Filosof&#xED;a para ni&#xF1;os de 1&#xBA; a 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica.</div><br></div>", "i": 6544752}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de octubre de 2005.- Pedro Montt Leiva, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6544753}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1281 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1281 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.281 EXENTO, DE 2005", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-09-13", "fecha_derogacion": "2014-12-19", "doble_articulado": false, "id_norma": "243119", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-10-19", "vigencias": [{"desde": "2014-12-19", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2005-10-19", "hasta": "2014-12-18", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigen