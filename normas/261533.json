{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL 5% ANTICIPO IVA EN LA VENTA DE CARNE A TATTERSALL REMATES S.A.</div><br><div class=\"p\">Certificado N&#xBA; 1 </div></div>", "i": 7344089}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que la empresa Tattersall Remates S.A., RUT N&#xBA;94.424.000-4, cumple con los requisitos establecidos en la resoluci&#xF3;n exenta N&#xBA; 3.722 de 28 de julio de 2000 y que en consecuencia, se le ha otorgado la Calidad de Agente Retenedor de anticipo del 5% del Impuesto al Valor Agregado, en las ventas de carnes, a contar del 1&#xBA; del mes siguiente al de publicaci&#xF3;n de este certificado en el Diario Oficial.</div><br></div>", "i": 7344090}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de junio de 2007.- Bernardo Seaman Gonz&#xE1;lez, Director Regional.</div><br></div>", "i": 7344091}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "1", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-1"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN GRANDES CONTRIBUYENTES"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL 5% ANTICIPO IVA\nEN LA VENTA DE CARNE A TATTERSALL REMATES S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "TATTERSALL REMATES S.A.", "CARNE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-04", "doble_articulado": false, "id_norma": "261533", "numero_fuente": "38784", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-06-09", "vigencias": [{"desde": "2007-06-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"ini