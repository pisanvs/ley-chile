{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede derecho a jubilar al Ministro de la Corte Suprema don Gabriel Palma Guzman</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,996.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7166193}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Conc&#xE9;dese, por gracia, al Ministro de la Corte Suprema de Justicia, don Gabriel Palma Guzman, derecho de jubilar con una pension igual al sueldo &#xED;ntegro asignado a su empleo.</div><br></div>", "i": 7166194}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 3 de Marzo de 1915.- RAMON BARROS LUCO.- Alberto Edwards.</div><br></div>", "i": 7166195}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2996", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2996"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDE DERECHO A JUBILAR AL MINISTRO DE LA CORTE SUPREMA DON GABRIEL PALMA GUZMAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["GABRIEL PALMA GUZMAN", "JUBILACION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1915-03-03", "doble_articulado": false, "id_norma": "23657", "numero_fuente": "11116", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1915-03-11", "vigencias": [{"desde": "1915-03-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_v