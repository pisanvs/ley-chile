{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CONCEDE AMNISTIA AL TENIENTE DE CARABINEROS DON JOAQUIN IZQUIERDO ORELLANA</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5969781}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese amnist&#xED;a al teniente de Carabineros don Joaqu&#xED;n Izquierdo Orellana, por el delito de violencia innecesaria en la persona de don Francisco Conejera N&#xFA;&#xF1;ez, a que fu&#xE9; condenado por sentencia de la Corte Marcial de Santiago, de fecha 29 de Diciembre de 1953&quot;.</div><br></div>", "i": 5969782}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, siete de Octubre de mil novecientos cincuenta y cuatro.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Osvaldo Koch.</div><br></div>", "i": 5969783}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11674", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11674"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDE AMNISTIA AL TENIENTE DE CARABINEROS DON\nJOAQUIN IZQUIERDO ORELLANA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AMNISTIA", "TENIENTE", "CARABINEROS DE CHILE", "DELITOS", "VIOLENCIA INNECESARIA", "SENTENCIA", "CORTE MARCIAL", "FRANCISCO CONEJERA NU EZ", "SANTIAGO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1954-10-07", "doble_articulado": false, "id_norma": "26757", "numero_fuente": "22975", "tipo_version": "3", "tipo_version