{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Monumento a Juan Mart&#xED;nez de Rozas Lei n&#xFA;m. 123.- Santiago, a 28 de Noviembre de 1893.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273748}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Prorr&#xF3;gase hasta el 30 de Abril de 1894 el plazo que la lei de 30 de Agosto de 1892 acord&#xF3; para la ereccion de un monumento a Juan Mart&#xED;nez de Rozas en la ciudad de Concepcion, i aum&#xE9;ntase en mil ochocientos pesos la suma concedida por la misma lei para ese objeto.</div><br><br></div>", "i": 8273749}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Pedro Montt.</div><br></div>", "i": 8273750}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "123", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-123"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MONUMENTO A JUAN MARTINEZ DE ROZAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUAN MARTINEZ DE ROZAS", "MONUMENTO", "ERECCION", "PLAZO", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-11-28", "doble_articulado": false, "id_norma": "21988", "numero_fuente": "4680", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-11-28", "vigencias": [{"desde": "1893-11-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-11-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"i