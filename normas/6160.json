{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplementa el presupuesto del Ministerio del Interior</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 523.- Santiago, 31 de Agosto de 1932.- El Presidente Provisional de la Rep&#xFA;blica ha acordado y dicta el siguiente</div><div class=\"p\">&nbsp; &nbsp; Decreto-ley:</div><br></div>", "i": 8256295}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.o Suplem&#xE9;ntase el presupuesto del Ministerio del Interior en la siguiente forma:</div><div class=\"p\">&nbsp; &nbsp; Ciento cincuenta mil pesos ($ 150,000), al item 04/01/04/v-2), y</div><div class=\"p\">&nbsp; &nbsp; Cien mil pesos ($ 100,000), al &#xED;tem 04/06/01. </div></div>", "i": 8256296, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 2.o Ded&#xFA;zcase el gasto de la Partida II, n&#xFA;mero veinte (20), de la ley n&#xFA;mero 5,105, de 18 de Abril del presente a&#xF1;o.</div><br></div>", "i": 8256297, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 3.o El presente decreto-ley comenzar&#xE1; a regir desde esta fecha.</div><br></div>", "i": 8256298}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de Leyes y Decretos del Gobierno.- CARLOS DAVILA._ Joaqu&#xED;n Fern&#xE1;ndez F.- Ernesto Barros.</div><br></div>", "i": 8256299}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "523", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-523"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "SUPLEMENTA EL PRESUPUESTO DEL MINISTERIO DEL INTERIOR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1932", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-08-31", "doble_articulado": false, "id_norma": "6160", "numero_fuente": "16370", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-09-08", "vigencias": [{"desde": "1932-09-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1932-09-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1932-09-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "fecha_version": "1932-09-08", "fecha_actualizacion_texto": "1932-09-08", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8256295}, {"n": "Artículo 1", "i": 8256296, "t": 6}, {"n": "Artículo 2", "i": 8256297, "t": 6}, {"n": "Artículo 3", "i": 8256298, "t": 6}, {"n": "Promulgación", "i": 8256299}]}