{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6522557}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.007, de 6 de abril de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a COMPA&#xD1;IA PESQUERA CAMANCHACA S.A. para ampliar las actividades pesqueras de transformaci&#xF3;n en orden a incorporar a la planta ubicada en Isla Rocuant, sitio N&#xBA; 10, Talcahuano, VIII Regi&#xF3;n, en las l&#xED;neas de proceso de Harina y Aceite, el recurso hidrobiol&#xF3;gico indicado en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6522558}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6522559}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1007 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1007 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-04-06", "doble_articulado": false, "id_norma": "237206", "numero_fuente": "38140", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-04-20", "vigencias": [{"desde": "2005-04-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-04-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-04-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-04-20", "fecha_version": "2005-04-20", "fecha_actual