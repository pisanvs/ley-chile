{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 348, DE 1985 </div><br><br></div>", "i": 8643068}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 348, de 29 de Octubre de 1985, la Subsecretar&#xED;a de Telecomunicaciones estableci&#xF3; los canales radioel&#xE9;ctricos y los requisitos t&#xE9;cnicos m&#xED;nimos para la operaci&#xF3;n de las estaciones del Sistema de Radiocomunicaciones Personal, en la banda de frecuencias 903 a 905 MHz. La citada Resoluci&#xF3;n entrar&#xE1; en vigor el 01 de Enero de 1986.</div><div class=\"p\">&nbsp; &nbsp;  La Subsecretar&#xED;a de Telecomunicaciones proporcionar&#xE1; ejemplares de dicha Resoluci&#xF3;n a los organismos fiscales, semifiscales y particulares, que tengan relaci&#xF3;n con la citada materia.</div><br></div>", "i": 8643069}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Italo Seccatore G&#xF3;mez, Coronel de Ej&#xE9;rcito, Subsecretario de Telecomunicaciones.</div><br></div>", "i": 8643070}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "348 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-348 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TELECOMUNICACIONES"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA NO. 348, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["WEBSUBTEL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1985-10-29", "fecha_derogacion": "1986-06-10", "doble_articulado": false, "id_norma": "165722", "numero_fuente": "32312", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1985-11-04", "vigencias": [{"desde": "1986-06-10", "hasta": "", "tipo_versio