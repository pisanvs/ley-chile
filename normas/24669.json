{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Deroga el art&#xED;culo 2.o de la ley 4,113 Por cuanto el Congreso Nacional ha dadado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 7168695}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Der&#xF3;gase, a contar desde el 1.o de Enero del presente a&#xF1;o, el art&#xED;culo 2.o de la ley n&#xFA;mero 4,113, de 25 de Enero de 1927.</div><br></div>", "i": 7168696}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, dieciocho de Junio de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- Pablo Ram&#xED;rez. </div></div>", "i": 7168697}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4334", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4334"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DEROGA EL ARTÍCULO 2° DE LA LEY 4,113", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DIETA PARLAMENTARIA", "REAJUSTE", "IMPUESTO QUINTA", "CATEGORIA", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-06-18", "doble_articulado": false, "id_norma": "24669", "numero_fuente": "15104", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-06-21", "vigencias": [{"desde": "1928-06-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-06-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1928-06-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes"