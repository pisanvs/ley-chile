{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6279009}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;742, de 29 de febrero de 2000, y en base a la facultad otorgada por el art&#xED;culo 105 del DFL N&#xBA;850, de 1997, que fij&#xF3; texto actualizado de la ley N&#xBA;15.840, se expropi&#xF3; el lote de terreno N&#xBA;5-A, para la ejecuci&#xF3;n de la obra Camino Ruta M-24-K con Ruta M-50, Sector Accesos Puente Maule en Constituci&#xF3;n, Tramo Km.</div><div class=\"p\">47.920 - Km. 53.820, que figura a nombre de Forestal Celco S.A., Rol de aval&#xFA;o N&#xBA;315-7, de la comuna de Constituci&#xF3;n, VII Regi&#xF3;n, superficie 5.516,2 m2. La indemnizaci&#xF3;n indicada en dicho decreto se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA;2.186, de 1978.-</div><br></div>", "i": 6279010}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6279011}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "742", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-742"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-29", "doble_articulado": false, "id_norma": "169759", "numero_fuente": "36678", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-01", "vigencias": [{"desde": "2000-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-01", "fin_vigencia": ""}, "vigencias_ve