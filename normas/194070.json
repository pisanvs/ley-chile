{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 16.250 EXENTA, DE 2001 </div><br></div>", "i": 6367121}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 16.250, de 28 de diciembre de 2001, se ha aprobado al Instituto Alonso de Ercilla de Santiago, el siguiente plan de estudio para 1&#xBA; y 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2002.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en la presente resoluci&#xF3;n.- </div></div>", "i": 6367122}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Ruz Ruz, Jefe Divisi&#xF3;n Educaci&#xF3;n General. </div></div>", "i": 6367123}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "16250 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-16250 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 16.250 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-28", "doble_articulado": false, "id_norma": "194070", "numero_fuente": "37168", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-24", "vigencias": [{"desde": "2002-01-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2002-01-24", "fecha_version": "2002-