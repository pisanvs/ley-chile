{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8308815}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 550 de 05 de Junio de 1992, de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n, prorr&#xF3;gase por 30 d&#xED;as a contar de la fecha</div><div class=\"p\">de la presente resoluci&#xF3;n, el plazo otorgado a don IGNACIO</div><div class=\"p\">ARTURO PRADO BENITEZ, R.U.T. No. 486.911-7, domiciliado en Avda. Holanda No. 548, Depto. 1, Santiago, en el numeral 3&#xB0; de la resoluci&#xF3;n No. 204, de 1992, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de fuerza mayor. </div></div>", "i": 8308816}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 05 de Junio de 1992.- Jorge Marshall Rivera, Subsecretario de Pesca subrogante.</div><br></div>", "i": 8308817}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "550", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-550"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-06-05", "doble_articulado": false, "id_norma": "78438", "numero_fuente": "34302", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-06-27", "vigencias": [{"desde": "1992-06-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-06-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-06-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pend