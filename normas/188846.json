{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xBA; 929</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 929, celebrada el 23 de agosto de 2001, adopt&#xF3; los siguientes Acuerdos:</div><br><br></div>", "i": 6347380}, {"t": "<div><div class=\"p\">929-01-010823&nbsp; Modifica el Cap&#xED;tulo IV.B.10 del Compendio de Normas Financieras.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; modificar el Cap&#xED;tulo IV.B.10 del Compendio de Normas Financieras, reemplazando el N&#xBA; 2.- por el siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;El plazo de vencimiento de estos t&#xED;tulos ser&#xE1; de un m&#xED;nimo de 2 a&#xF1;os contado desde su fecha de emisi&#xF3;n&quot;. </div></div>", "i": 6347381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de agosto de 2001.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6347382}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "929", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-929"}, {"tipo": "5", "numero": "929-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-929-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION Nº 929", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-08-23", "doble_articulado": false, "id_norma": "188846", "numero_fuente": "37046", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-08-25", "vigencias": [{"desde": "2001-08-25", "hasta": "", "