{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6204753}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 459 de 23 de Abril de 1987, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a parcelas N&#xB0;s. 1 a la 7 y sitios 1 al 4 del Proyecto de Parcelaci&#xF3;n &quot;Qui&#xF1;antu&quot; formado por predio Qui&#xF1;antu de la comuna de Maule, S&#xE9;ptima Regi&#xF3;n. Los Derechos de Agua se extraen del canal Qui&#xF1;antu, derivado del R&#xED;o Maule. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.- </div></div>", "i": 6204754}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6204755}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "459 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-459 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-04-23", "doble_articulado": false, "id_norma": "147534", "numero_fuente": "32760", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-05-02", "vigencias": [{"desde": "1987-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "