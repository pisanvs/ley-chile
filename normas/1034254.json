{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACI&#xD3;N DE INMUEBLES QUE SE&#xD1;ALA</div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9215534}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n (ex.) N&#xBA; 4.645 del 07/12/2011, conforme al art&#xED;culo 51 ley 16.391, DL 2.186/1978 y DS 68/1991 de Vivienda y Urbanismo, para cumplir con los programas de construcci&#xF3;n de viviendas, Serviu Regi&#xF3;n de la Araucan&#xED;a, orden&#xF3; modificaci&#xF3;n de resoluci&#xF3;n (ex) N&#xBA; 4.147 de fecha 07/11/2011, en el sentido que el monto que se ordena pagar al expropiado es la suma de $196.780.000. En todo lo dem&#xE1;s se mantiene plenamente vigente la resoluci&#xF3;n modificada. </div></div>", "i": 9215535}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director (S) Serviu Regi&#xF3;n de la Araucan&#xED;a.</div></div>", "i": 9215536}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4645 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4645 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "ORDENA EXPROPIACIÓN DE INMUEBLES QUE SEÑALA; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-12-07", "doble_articulado": false, "id_norma": "1034254", "numero_fuente": "40135", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-12-15", "vigencias": [{"desde": "2011-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio