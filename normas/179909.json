{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6315641}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.706 de 26 de diciembre de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA SURIBERICA S.A., para realizar operaciones pesqueras, a contar del 1 de enero del a&#xF1;o 2001 y hasta el 31 de diciembre del mismo a&#xF1;o, ambas fechas inclusive, con el barco f&#xE1;brica denominado &apos;&apos;Isla Camila&apos;&apos;, en aguas interiores, al Sur del paralelo 47&#xB0; L.S., respecto de los recursos y con las obligaciones establecidas en sus respectivas resoluciones.</div><br></div>", "i": 6315642}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de diciembre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca. </div></div>", "i": 6315643}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2706", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2706"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-12-26", "doble_articulado": false, "id_norma": "179909", "numero_fuente": "36856", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-08", "vigencias": [{"desde": "2001-01-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-01-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso