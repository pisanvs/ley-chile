{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 631.- Santiago, 17 de octubre de 1925.- Con acuerdo del Consejo de Ministros del Despacho, dicto el siguiente DECRETO-LEI:</div><br></div>", "i": 8256468}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Suplem&#xE9;ntase en la cantidad de cinco mil pesos ($ 5,000) el &#xED;tem 85, partida 2.a del Presupuesto del Interior vijente.</div><br></div>", "i": 8256469}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese razon, rej&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Boletin de las Leyes y Decretos del Gobierno.- Luis Barros Borgo&#xF1;o.- Manuel E. V&#xE9;lis. </div></div>", "i": 8256470}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "631", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-631"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GASTOS NACION", "A O", "1925", "MODIFICACION", "MINISTERIO INTERIOR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1925-10-17", "doble_articulado": false, "id_norma": "6239", "numero_fuente": "14302", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1925-10-21", "vigencias": [{"desde": "1925-10-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1925-10-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1925-10-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1925-10-21", "fecha_actualizacion_texto": "1925-10-21", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura":