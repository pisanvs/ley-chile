{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 81, DE 2003 </div></div>", "i": 6441220}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 81, de 25 de agosto de 2003, del Ministerio de Transportes y Telecomunicaciones, se revoc&#xF3; la resoluci&#xF3;n N&#xBA; 11/03, del mismo Ministerio, y se dej&#xF3; sin efecto el proceso de licitaci&#xF3;n p&#xFA;blica de Uso de V&#xED;as de la Ciudad de Santiago para la Prestaci&#xF3;n de Servicios Urbanos de Transporte P&#xFA;blico Remunerado de Pasajeros Mediante Buses Correspondiente a Servicios Vacantes Proceso 1998. Se comunicar&#xE1; lo resuelto a los adquirentes de bases mediante carta certificada y se proceder&#xE1; a la devoluci&#xF3;n del valor de las bases a quienes acrediten la compra de las mismas.-</div><br></div>", "i": 6441221}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Guillermo D&#xED;az Silva, Subsecretario de Transportes. </div></div>", "i": 6441222}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "81", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-81"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 81, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-25", "doble_articulado": false, "id_norma": "215113", "numero_fuente": "37671", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-29", "vigencias": [{"desde": "2003-09-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-29", "fin_vigencia": ""}, "vigencias_versio