{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xBA; 39, DE 1965:</div><br><div class=\"p\">(Extracto) </div></div>", "i": 7260782}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 743, de 7 de Octubre de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n N&#xBA; 39, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a don Jos&#xE9; Fern&#xE1;ndez S&#xE1;ez, RUT N&#xBA; 1.038.401-K, domiciliado en Antofagasta, calle Juan Glasinovic N&#xBA; 650, para operar las embarcaciones &quot;Genoveva III&quot; y &quot;Sta. Mercedes&quot;, en el litoral de las Regiones I y II, en orden a sustituir en el numeral 2 de dicha resoluci&#xF3;n las caracter&#xED;sticas n&#xE1;uticas de la embarcaci&#xF3;n &quot;Sta. Mercedes&quot;, por las que se indican: Eslora 17,3 mts.; Manga 4,8 mts.; Puntal 1,8 mts.; Toneladas de Registro Grueso 42,13 tons.; Toneladas de Registro Neto 18,96 tons.; Capacidad de Bodega 33 m3.</div><br></div>", "i": 7260783}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de octubre de 1986.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 7260784}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "743", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-743"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION Nº 39, DE 1965:", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-10-07", "doble_articulado": false, "id_norma": "154869", "numero_fuente": "32612", "tipo_version": "3", "ti