{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,516.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6172170}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios del ex-juez letrado de Tocopilla, don Emilio Salas B&#xF3;rquez, muerto en el cumplimiento de su deber, se concede, por gracia, a su viuda una pension de tres mil pesos anuales, de la que disfrutar&#xE1; con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6172171}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiseis de julio de mil novecientos once.- Ramon Barros Luco.- An&#xED;bal Letelier.</div><br></div>", "i": 6172172}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2516", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2516"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-07-26", "doble_articulado": false, "id_norma": "137457", "numero_fuente": "10045", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-08-01", "vigencias": [{"desde": "1911-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-08-01", "fin_vigencia": "", "tipo_version": "