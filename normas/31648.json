{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTOS DE RESOLUCIONES </div></div>", "i": 8288958}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 748, de 27 de Junio de 1991 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se declara la caducidad de la Resoluci&#xF3;n N&#xB0; 2055, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a do&#xF1;a ADELINA VITALIA RAIMILLA RAIMILLA, R.U.T. N&#xB0; 9.654.351-4, domiciliada en la ciudad de Maull&#xED;n, La Chile, para desarrollar actividades pesqueras de cultivo, de conformidad a lo dispuesto en el art&#xED;culo 6&#xB0; del Decreto Supremo N&#xB0; 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8288959}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 27 de Junio de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8288960}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "748", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-748"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "EXTRACTOS DE RESOLUCIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ADELINA VITALIA RAIMILLA RAIMILLA", "PESCA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-06-27", "doble_articulado": false, "id_norma": "31648", "numero_fuente": "34013", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-07-10", "vigencias": [{"desde": "1991-07-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-07-10", "fin_vigencia": ""}, "vigencias_version