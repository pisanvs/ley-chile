{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6444361}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP N&#xBA; 594. de 30 de noviembre de 1994, se expropiaron los lotes de terreno N&#xBA;s 22, 29, 55 y 61, superficies 1.220 m2., 946 m2., 50.000 m2. y 5.440 m2., roles de aval&#xFA;o 846-68, 846-67, 849-24 y 849-018, comuna de Vallenar, para la obra Embalse Santa Juana, sector La Laja, Etapa II, y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Eloi Huanchicay Zuleta, Magdalena Cort&#xE9;s Huanchicay, Teresa Gonz&#xE1;lez Villalobos y Ulda Cort&#xE9;s Varas, ascendente a las cantidades de $1.699.306.- para el lote 22; $1.419.613.- para el lote 29; $14.067.219.- para el lote 55, y $3.955.064.- para el lote 61, respectivamente.</div><br></div>", "i": 6444362}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6444363}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "594", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-594"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-11-30", "doble_articulado": false, "id_norma": "216082", "numero_fuente": "35068", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-01-16", "vigencias": [{"desde": "1995-01-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-01-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-01-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes":