{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6218618}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.044, de fecha 23 de Junio de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la. V Regi&#xF3;n, se autoriza al se&#xF1;or Jos&#xE9; Rolando Rodr&#xED;guez Rodr&#xED;guez para efectuar todo tipo de servicios de transportes de pasajeros por calle y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6218619}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de Junio de 1987.- H&#xE9;ctor Soto Miranda, Secretario Regional Ministerial de Transportes y Telecomunicaciones subrogante V Regi&#xF3;n.</div><br></div>", "i": 6218620}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1044 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1044 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL V REGIÓN DE VALPARAÍSO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-23", "doble_articulado": false, "id_norma": "151117", "numero_fuente": "32811", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-04", "vigencias": [{"desde": "1987-07-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-07-04