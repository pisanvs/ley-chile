{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 167, DE 1987 </div></div>", "i": 6294387}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 167, de 17 de julio de 1987, se ha aprobado para el Liceo Nacional de Computaci&#xF3;n, en sus sedes de las Comunas de Santiago y Providencia, Provincia de Santiago, Regi&#xF3;n Metropolitana, un plan y programa especial de estudio para la Educaci&#xF3;n Media, modalidad T&#xE9;cnico-Profesional, que se aplicar&#xE1; gradualmente a contar del a&#xF1;o escolar 1988 y hasta el a&#xF1;o escolar de 1993, en la Especialidad de Programaci&#xF3;n en Computaci&#xF3;n. </div></div>", "i": 6294388}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de Julio de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6294389}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "167 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-167 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 167, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-17", "doble_articulado": false, "id_norma": "173641", "numero_fuente": "32846", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-14", "vigencias": [{"desde": "1987-08-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-08-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-08-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [],