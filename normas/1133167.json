{"html": [{"t": "<div><div class=\"p\">TAQUIGRAFO.</div><br><div class=\"p\">&nbsp; &nbsp;  EL DIRECTOR SUPREMO DEL ESTADO &amp;a.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto de acuerdo con el Senado Conservador he decretado:</div></div>", "i": 10035971}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Que se nombre un taqu&#xED;grafo para el pr&#xF3;ximo Congreso, con la asignacion de doscientos pesos mensuales, y mil de premio por una vez.</div></div>", "i": 10035972}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por tanto, ordeno que se publique por lei insert&#xE1;ndose en el Boletin. Dado en el Palacio Directorial de Santiago a 30 de Mayo de 1823.</div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Pedro Nolasco Mena.</div></div>", "i": 10035973}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["DEPARTAMENTO DE HACIENDA"], "titulo_norma": "TAQUIGRAFO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-05-30", "doble_articulado": false, "id_norma": "1133167", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-05-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-05-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-05-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2019-07-08", "fecha_version": "1823-05-30", "fecha