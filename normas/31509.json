{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTOS DE RESOLUCIONES </div></div>", "i": 8288625}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 509 de 10 de Mayo de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por 6 meses a contar de esta fecha, el plazo otorgado a do&#xF1;a NANCY ISABEL HERNANDEZ MARDONEZ; R.U.T. N&#xB0; 8.155.830-2, domiciliada en Vi&#xF1;a del Mar, para empezar a operar el establecimiento de cultivo autorizado por la resoluci&#xF3;n N&#xB0; 485, de 1989, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la existencia de una fuerza mayor. </div></div>", "i": 8288626}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 10 de Mayo de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8288627}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "540", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-540"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "EXTRACTOS DE RESOLUCIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NANCY ISABEL HERNANDEZ MARDONES", "PESCA", "PLAZO", "PRORROGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-05-10", "doble_articulado": false, "id_norma": "31509", "numero_fuente": "33972", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-05-20", "vigencias": [{"desde": "1991-05-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-05-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-05-20", "fin_vigencia": "", "tipo_ve