{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AUMENTA LA PLANTA DE OFICIALES DE LA ARMADA Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5964772}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1&#xB0;.- Aum&#xE9;ntase la planta de Oficiales de la Armada en las siguientes plazas:</div><div class=\"p\">&nbsp; &nbsp; Oficiales ejecutivos:</div><div class=\"p\">&nbsp; &nbsp; 6 Capitanes de Fragata.</div><div class=\"p\">&nbsp; &nbsp; 6 Capitanes de Corbeta.</div><div class=\"p\">&nbsp; &nbsp; Oficiales de Administraci&#xF3;n:</div><div class=\"p\">&nbsp; &nbsp; 1 Capit&#xE1;n de Nav&#xED;o.</div><div class=\"p\">&nbsp; &nbsp; 2 Capitanes de Corbeta.</div><br></div>", "i": 5964773}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2&#xB0;.- El gasto que demande esta ley se imputar&#xE1; a la mayor entrada que produzca la Cuenta C-36, &quot;Impuesto sobre Alcoholes, licores, vinos y cervezas&quot;. </div></div>", "i": 5964774}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 3&#xB0;.- La presente ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial&quot;.</div><br></div>", "i": 5964775}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, diecisiete de Junio de mil novecientos cuarenta y tres.- JUAN ANTONIO RIOS M.- O. Escudero O. </div></div>", "i": 5964776}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "7423", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-7423"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL"], "titulo_norma": "AUMENTA LA PLANTA DE OFICIALES DE LA ARMADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "PLANTA DE OFICIALES", "ARMADA DE CHILE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "