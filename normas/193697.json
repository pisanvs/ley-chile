{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6365680}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;2.549 de 20 de diciembre de 2001 de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD COMERCIAL ALIOTH LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en Camino Lechagua Km. 5 s/n, Ancud, Chilo&#xE9;, X Regi&#xF3;n, donde podr&#xE1; procesar en la l&#xED;nea de elaboraci&#xF3;n que se indica, los siguientes recursos hidrobiol&#xF3;gicos: Alga Seca: Carola, Cochayuyo, Cot&#xF3;n, Chasca, Chasc&#xF3;n, Chicorea de mar, Huiro, Luche, Luga Luga, Pelillo, Lamilla.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA;746 de 1995, de esta Subsecretar&#xED;a, conforme lo dispuesto en la presente resoluci&#xF3;n.</div><br></div>", "i": 6365681}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de diciembre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6365682}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2549", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2549"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-20", "doble_articulado": false, "id_norma": "193697", "numero_fuente": "37161", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-16", "vigencias": [{"desde": "2002-01-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-