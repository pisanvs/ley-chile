{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6236801}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta N&#xB0; 173 de 14 de Febrero de 1985, conforme Art. 5&#xB0; transitorio C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento de aguas proporcionales que corresponden a sector excluido y sector expropiado predio &quot;resto de la Hacienda La Candelaria y parte de la Hacienda La Punta&quot; de la comuna de San Francisco de Mostazal, Sexta Regi&#xF3;n; y derechos aprovechamiento de aguas que corresponden a las parcelas N&#xB0;s. 1 a la 14, sitios N&#xB0;s. 1 al 13 y reserva CORA N&#xB0; 1 del proyecto de parcelaci&#xF3;n &quot;La Candelaria&quot; formado por predio se&#xF1;alado. Los derechos de Aguas se extraen del Estero Codegua. Publicaci&#xF3;n hecha conforme Art. 13 Ley N&#xB0; 18.377.- </div></div>", "i": 6236802}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6236803}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "173 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-173 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-02-14", "doble_articulado": false, "id_norma": "156820", "numero_fuente": "32110", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-01", "vigencias": [{"desde": "1985-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-01", "fin_vigencia": ""}, "vigenci