{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aumenta los sueldos del Presidente de la Rep&#xFA;blica i de los Ministros de Estado</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,434.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275250}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo primero.- As&#xED;gnase al Presidente de la Rep&#xFA;blica el sueldo anuales de sesenta mil pesos ($ 60,000)</div><div class=\"p\">&nbsp; &nbsp; Der&#xF3;ganse las leyes de 17 de Setiembre de 1861 i de 21 de Noviembre de 1891.</div><br></div>", "i": 8275251}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ART. 2.&#xB0;- Los Ministros de Estado gozar&#xE1;n de un sueldo de veinticuatro mil pesos anuales ($ 24,000). </div></div>", "i": 8275252}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 22 de Diciembre de 1910.- EMILIANO FIGUEROA.- Enrique A. Rodr&#xED;guez.</div><br></div>", "i": 8275253}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2434", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2434"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUMENTA LOS SUELDOS DEL PRESIDENTE DE LA REPÚBLICA I DE LOS MINISTROS DE ESTADO", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTE DE LA REPUBLICA", "REMUNERACION", "FIJACION", "MINISTROS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1910-12-22", "fecha_derogacion": "1920-12-22", "