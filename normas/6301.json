{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 715.- Santiago, 11 de noviembre de 1925.- Vistos estos antecedentes y de acuerdo con el Consejo de Ministros del Despacho,</div><div class=\"p\">&nbsp; &nbsp; dicto el siguiente DECRETO-LEI:</div><br></div>", "i": 8256528}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Conc&#xE9;dese un suplemento de cincuenta mil pesos ($ 50,000) al &#xED;tem 1685, partida 6.o del Presupuesto del Interior en vijencia, para atender a la alimentacion del personal y del ganado y su movilizacion, con motivo de las concentraciones de tropa de Carabineros que se ordenen por el Gobierno.</div><br></div>", "i": 8256529}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese razon, rej&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Boletin de las Leyes y Decretos del Gobierno.- Luis Barros Borgo&#xF1;o.- Manuel E. V&#xE9;lis. </div></div>", "i": 8256530}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "715", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-715"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GASTOS NACION", "A O", "1925", "SUPLEMENTO", "MINISTERIO INTERIOR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1925-11-11", "doble_articulado": false, "id_norma": "6301", "numero_fuente": "14320", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1925-11-12", "vigencias": [{"desde": "1925-11-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1925-11-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1925-11-12", "fin_vigencia": "", "t