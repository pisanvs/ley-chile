{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6426825}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 391 de fecha 30 de abril de 2003, se expropi&#xF3; el lote de terreno N&#xBA;7, superficie 89,2 m2, Rol N&#xBA;137-587, comuna de Paine, Regi&#xF3;n Metropolitana para la obra &quot;Camino Sin Rol, Sector Peralillo-Abrantes, tramo Km. 0,00000 a Km.</div><div class=\"p\">6,03921&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Alamiro Salinas Z&#xFA;&#xF1;iga, ascendente a la cantidad de $869.677.-</div><br></div>", "i": 6426826}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6426827}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "391 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-391 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-04-30", "doble_articulado": false, "id_norma": "211223", "numero_fuente": "37585", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-17", "vigencias": [{"desde": "2003-06-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-06-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-06-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2003-06-17", "fecha_version": "2003-06-17", "fecha_actualizacion_texto": "2003-06-17", "tipo_tratado": ""}, "alertas": [], "al