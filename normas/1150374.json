{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10164823}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xBA; 3.853, de 14 de septiembre de 2020, establece requisitos para las actividades de notificaci&#xF3;n y ejecuci&#xF3;n de retiro de mercado para los titulares de registro sanitario y participantes de la cadena de distribuci&#xF3;n de productos farmac&#xE9;uticos.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10164824}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  www.ispch.cl.- Heriberto Garc&#xED;a Escorza, Director (S), Instituto de Salud P&#xFA;blica de Chile.</div><div class=\"p\"> </div><br></div>", "i": 10164825}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3853 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3853 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1826268", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-09-14", "doble_articulado": false, "id_norma": "1150374", "numero_fuente": "42773", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-10-06", "vigencias": [{"desde": "2020-10-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2020-10-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2020-10-06", "fin_vigencia": "", "tipo_version": "3"}], "ev