{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PENSION Lei n&#xFA;m. 207.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente PROYECTO DE LEI:</div><br></div>", "i": 5947150}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese a do&#xF1;a Emilia Kuntsmann, viuda de Landberck, i a su hija soltera, una pension de gracia de trescientos pesos anuales; la que disfrutar&#xE1;n con arreglo a la lei de montep&#xED;o militar.</div><br><br></div>", "i": 5947151}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 6 de Setiembre de 1894.- JORGE MONTT.-</div><div class=\"p\">C&#xE1;rlos Riesco.</div><br></div>", "i": 5947152}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "207", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-207"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EMILIA KUNTSMANN", "HIJA SOLTERA", "MONTEPIO MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-09-06", "doble_articulado": false, "id_norma": "22065", "numero_fuente": "4914", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-09-12", "vigencias": [{"desde": "1894-09-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-09-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-09-12", "fin_vigencia": "", "tip