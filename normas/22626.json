{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Congreso M&#xE9;dico Latino-Americano.- Inversion de 12,000 pesos</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,407.- Santiago, a 16 de Enero de 1901.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274311}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de doce mil pesos en ayudar a los gastos del Congreso M&#xE9;dico Latino-Americano i de la Esposicion de Hijiene. </div></div>", "i": 8274312}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ E.- Juan Antonio Orrego.</div><br></div>", "i": 8274313}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1407", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1407"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONGRESO MEDICO LATINO-AMERICANO.- INVERSION DE 12,000 PESOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONGRESO MEDICO LATINO AMERICANO", "INVERSION", "AUTORIZACION", "EXPOSICION HIGIENE", "PRESIDENTE REPUBLICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-01-16", "doble_articulado": false, "id_norma": "22626", "numero_fuente": "6793", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-01-16", "vigencias": [{"desde": "1901-01-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig