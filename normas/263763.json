{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 8,920</div><br><div class=\"p\">PRORROGA POR DOS A&#xD1;OS LOS EFECTOS DE LA LEY 8,404, QUE PRORROGO POR IGUAL PERIODO DIVERSAS DISPOSICIONES DE LA LEY N.o 7,750</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de Ley:</div><br></div>", "i": 7350838}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico. Prorr&#xF3;ganse los efectos de la ley N.o 8,404, por el plazo de dos a&#xF1;os.</div><div class=\"p\">&nbsp; &nbsp;  Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial&quot;.</div><br></div>", "i": 7350839, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuando he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a once de Noviembre&nbsp; de&nbsp; mil novecientos cuarenta y siete.- GABRIEL GONZALEZ V.- Jorge Alessandri R.</div><br></div>", "i": 7350840}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "8920", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-8920"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "PRORROGA POR DOS AÑOS LOS EFECTOS DE LA LEY 8,404, QUE PRORROGO POR IGUAL PERIODO DIVERSAS DISPOSICIONES DE LA LEY N.o 7,750", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1947-11-11", "doble_articulado": false, "id_norma": "263763", "numero_fuente": "20911", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1947-11-25", "vigencia