{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MEDIDAS HIJIENICAS Lei n&#xFA;m. 223.- Santiago, a 26 de Diciembre de 1894.- Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273848}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de treinta mil pesos ($ 30,000) en la adopcion de medidas hiji&#xE9;nicas que tiendan a prevenir la propagacion de enfermedades infecciosas.</div><br><br></div>", "i": 8273849}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo; por tanto, prom&#xFA;lguese como lei de la Rep&#xFA;blica.-JORJE MONTT.- R. Barros Luco.</div><br></div>", "i": 8273850}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "223", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-223"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MEDIDAS HIJIENICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTE REPUBLICA", "MEDIDAS HIGIENICAS", "FONDOS", "INVERSION", "AUTORIZACION", "ENFERMEDADES INFECCIOSAS", "PREVENCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-12-26", "doble_articulado": false, "id_norma": "22079", "numero_fuente": "4998", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-12-26", "vigencias": [{"desde": "1894-12-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-12-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-12-26", "fin_vigencia": "", "tipo_version": "3"}], "evento