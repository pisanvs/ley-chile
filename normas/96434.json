{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA;. 272, DE 1990</div><br><br><br></div>", "i": 7230836}, {"t": "<div><div class=\"p\">Por Decreto Exento No. 272 de fecha 25 de octubre de 1990 del Ministerio de Educaci&#xF3;n, se insert&#xF3; en la Resoluci&#xF3;n Exenta de Educaci&#xF3;n No. 1746 de 1988 y No. 3430 de 1986 del Centro de Formaci&#xF3;n T&#xE9;cnica CREP de Quilpu&#xE9;, las adecuaciones introducidas a las carreras de Contabilidad General con menci&#xF3;n en computaci&#xF3;n, Programaci&#xF3;n de Computadores y Asistente del Educador de P&#xE1;rvulos, las que podr&#xE1;n aplicarse a contar del a&#xF1;o 1990.</div><br></div>", "i": 7230837}, {"t": "<div><div class=\"p\">Santiago, 07 de Enero de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7230838}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "272 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-272 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº. 272, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1990-10-25", "fecha_derogacion": "2002-08-03", "doble_articulado": false, "id_norma": "96434", "numero_fuente": "33886", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-02-05", "vigencias": [{"desde": "2002-08-03", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1991-02-05", "hasta": "2002-08-02", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2002-08-03", "fin_vigencia": ""}