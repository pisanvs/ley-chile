{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292513}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 445, de 25 de Junio de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2&#xB0; de la Resoluci&#xF3;n N&#xB0;221, de 1993, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don PATRICIO ELIAS PAVLOVIC MORRISON, R.U.T.</div><div class=\"p\">N&#xB0;6.584.344-7, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a eximir al interesado de la obligaci&#xF3;n de adquirir el recurso Osti&#xF3;n del sur, Chlamys patagonica, de centros de cultivo autorizados, debiendo &#xE9;ste ser abastecido por pescadores artesanales. </div></div>", "i": 8292514}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 25 de Junio de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8292515}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "445", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-445"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "PESCA", "AUTORIZACION", "PATRICIO ELIAS", "PAVLOVIC MORRISON"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-06-25", "doble_articulado": false, "id_norma": "34821", "numero_fuente": "34616", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-07-16", "vigencias": [{"desde": "1993-07-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-07-16", "fin_vigencia": ""}, "v