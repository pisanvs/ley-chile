{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6399340}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA;1.351 de 16 de septiembre de 2002, se dej&#xF3; sin efecto el decreto supremo exento MOP N&#xBA;653 de 31 de mayo de 2001, que orden&#xF3; la expropiaci&#xF3;n del lote N&#xBA;18, para la obra Concesi&#xF3;n Internacional Interconexi&#xF3;n Vial Santiago-Valpara&#xED;so-Vi&#xF1;a del Mar Tramo 16: Km. 97.400,00 a Km. 99.500,00, por no ser necesario para la ejecuci&#xF3;n de &#xE9;sta. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA;2.186, de 1978.</div><br></div>", "i": 6399341}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6399342}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1351 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1351 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-09-16", "doble_articulado": false, "id_norma": "203455", "numero_fuente": "37383", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-10-15", "vigencias": [{"desde": "2002-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-10-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "MA