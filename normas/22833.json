{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que segrega la comuna de Rio Negro del departamento de Llanquihue i la agrega al de Osorno</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1672.- Santiago, a 2 de Setiembre de 1904.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274589}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Segr&#xE9;gase del departamento de Llanquihue la comuna de Rio Negro i se anexa su territorio al departamento de Osorno.</div><br></div>", "i": 8274590}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- M. E. Ballesteros.</div><br></div>", "i": 8274591}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1672", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1672"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "QUE SEGREGA LA COMUNA DE RIO NEGRO DEL DEPARTAMENTO DE LLANQUIHUE I LA AGREGA AL DE OSORNO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DEPARTAMENTO OSORNO", "COMUNA RIO NEGRO", "ANEXION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-09-02", "doble_articulado": false, "id_norma": "22833", "numero_fuente": "7996", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1904-09-02", "vigencias": [{"desde": "1904-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1904-09-02", "fin_vigencia": ""}, "vigencias_version_n