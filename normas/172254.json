{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6286951}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.135 de 21 de junio de 2000 de esta Subsecretar&#xED;a, autor&#xED;zase a RODRIGO ALONSO MANOSALVA REYES, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en Angel Parra N&#xBA; 628, Chill&#xE1;n Viejo, comuna de Chill&#xE1;n, VIII Regi&#xF3;n, donde podr&#xE1; procesar en la l&#xED;nea de elaboraci&#xF3;n que se indica, los siguientes recursos hidrobiol&#xF3;gicos: Ahumado: Salm&#xF3;n del Atl&#xE1;ntico, Salm&#xF3;n plateado, Salm&#xF3;n rey, Trucha arcoiris, Trucha caf&#xE9;. </div></div>", "i": 6286952}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de junio de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6286953}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1135", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1135"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-06-21", "doble_articulado": false, "id_norma": "172254", "numero_fuente": "36711", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-12", "vigencias": [{"desde": "2000-07-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-07-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincula