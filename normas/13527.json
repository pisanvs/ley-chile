{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; NOMBRA CONSERVADOR DE ANGOL Santiago, 22 de Abril de 1993.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 455.- Vistos: Estos antecedentes, lo dispuesto en los art&#xED;culos 446, 447 y 450 del C&#xF3;digo Org&#xE1;nico de Tribunales; en los decretos N&#xB0; 924, de 1981 y N&#xB0; 1.748, de 1992 y lo informado por la Ilma. Corte de Apelaciones de Temuco, mediante oficio N&#xB0; 1.456 de 15 de Abril de 1993.</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 5913337}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xF3;mbrase a don Carlos Paluz Rivas, como Conservador de Angol.</div><br></div>", "i": 5913338}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- Por orden del Presidente de la Rep&#xFA;blica, Francisco Cumplido Cereceda, Ministro de Justicia.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Le saluda atentamente.- Bernardo Espinosa Bancalari, Subsecretario de Justicia Subrogante.</div><br></div>", "i": 5913339}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "455", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-455"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "NOMBRA CONSERVADOR DE ANGOL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONSERVADOR", "CARGOS JUDICIALES", "NOMBRAMIENTO", "ANGOL", "NOVENA REGION", "CARLOS PALUZ RIVAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-04-22", "doble_articulado": false, "id_norma": "13527", "numero_fuente": "34568", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-05-18", "vigencias": [