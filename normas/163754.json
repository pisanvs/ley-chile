{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 2.747, DE 1985 </div></div>", "i": 6259381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 2.747 de fecha 26 de Septiembre de 1985, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se modific&#xF3; la Resoluci&#xF3;n Exenta de Educaci&#xF3;n No. 1.474 de 1982, ampliada por Resoluci&#xF3;n Exenta de Educaci&#xF3;n No. 770 de 1983, en su art&#xED;culo 2&#xB0;, en lo que respecta a las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica Escuela Superior de Administraci&#xF3;n de Negocios ESANE, a partir de Agosto de 1985.</div><br></div>", "i": 6259382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6259383}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2747 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2747 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 2.746, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-09-26", "doble_articulado": false, "id_norma": "163754", "numero_fuente": "32329", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-11-23", "vigencias": [{"desde": "1985-11-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-11-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-11-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie