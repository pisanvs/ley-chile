{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO</div></div>", "i": 9845065}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP Exento N&#xB0; 1318 de 20 de octubre de 2017, se rectific&#xF3; los numerales 2&#xB0; y 3&#xB0; de los Decretos MOP Exento <a href=\"https://www.leychile.cl/Navegar?idNorma=1105391&amp;idParte=&amp;idVersion=\">N&#xB0; 573</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1105413&amp;idParte=&amp;idVersion=\">N&#xB0; 612</a> ambos de 23 de junio de 2017, que ordenaron la expropiaci&#xF3;n de los lotes 97 y 90 en el siguiente aspecto: donde dice CARMEN ROSA BARAHONA CARRASCO, debe decir CARMEN ROSA BARAHONA CARRASCO Y PEDRO ENRIQUE GARC&#xCD;A FLORES. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xB0; del Decreto Ley N&#xB0; 2186, de 1978. </div></div>", "i": 9845066}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP. </div></div>", "i": 9845067}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1318 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1318 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1295650", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-10-20", "doble_articulado": false, "id_norma": "1109928", "numero_fuente": "41897", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-11-02", "vigencias": [{"desde": "2017-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-11-02", "fin_vigen