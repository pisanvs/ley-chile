{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8350278}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.771, de 9 de septiembre de 1999 de esta Subsecretar&#xED;a, modif&#xED;case el numeral 6 de la resoluci&#xF3;n N&#xBA; 163 de 1997, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA LA PENINSULA S.A. para operar la nave &apos;&apos;Loa 1&apos;&apos;, en el sentido de se&#xF1;alar que el plazo para iniciar operaciones con dicha nave en el litoral de la X Regi&#xF3;n es de dos a&#xF1;os contados desde la fecha de publicaci&#xF3;n del extracto de dicha resoluci&#xF3;n, esto es, el 26 de febrero de 1997.</div><br></div>", "i": 8350279}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de septiembre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8350280}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1771", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1771"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-09-09", "fecha_derogacion": "2002-11-07", "doble_articulado": false, "id_norma": "143720", "numero_fuente": "36469", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-09-21", "vigencias": [{"desde": "2002-11-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-09-21", "hasta": "2002-11-06", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2002-11-07", "fin_vigencia": ""},