{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6425365}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 326 de fecha 31 de marzo del 2003, se expropiaron los lotes de terrenos N&#xBA;s. 106 y 106-A, superficie 147 y 168 m2 respectivamente, Rol de Aval&#xFA;o N&#xBA; 126-12, comuna de Ranquil, VIII Regi&#xF3;n para la obra &quot;Camino Ruta O-66-N, Sector Nueva Aldea - &#xD1;ipas, Tramo II Km.</div><div class=\"p\">5,57900 a Km. 10,19480&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Ema Delfina Osorio Osorio y Otros, ascendente a la cantidad de $17.973.585. </div></div>", "i": 6425366}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6425367}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "326", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-326"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-03-31", "doble_articulado": false, "id_norma": "210787", "numero_fuente": "37573", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-02", "vigencias": [{"desde": "2003-06-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-06-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-06-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2003-06-02", "fecha_version": "2003-06-02", "fecha_actualizacion_texto": "2003-06-02", "t