{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6264769}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. No. 373, de 29 de noviembre de 1985, se expropiaron los lotes N&#xB0;s. 1, 2 y 3 y se constituy&#xF3; servidumbres perpetuas subterr&#xE1;neas sobre los lotes N&#xB0;s. 4, 5 y 6, cuyas superficies son 300 m2., 345 m2., 300 m2., 2.160 m2., 1.260 m2. y 1.020 m2., respectivamente, rol de aval&#xFA;o 102-18, Comuna de Machal&#xED;, VI Regi&#xF3;n, para Agua Potable de Rancagua en sector recinto Sendos Sanchina y se acord&#xF3; el precio de indemnizaci&#xF3;n con su propietario Club de Polo Cachapoal, ascendente a $ 1.528.286.</div><br><br></div>", "i": 6264770}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. (16) </div></div>", "i": 6264771}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "373", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-373"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-11-29", "doble_articulado": false, "id_norma": "165472", "numero_fuente": "32348", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-16", "vigencias": [{"desde": "1985-12-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-12-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-12-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2000-04-14", "fecha_version": "1985-12-1