{"html": [{"t": "<div><br><div class=\"p\">DERECHO DE PONTAZGO</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, octubre 22 de 1853.</div></div>", "i": 9844068}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Para evitar las dudas que pudieran tener los empleados de los resguardos de cordillera i en virtud de la autorizaci&#xF3;n que me confiere la lei de 22 de agosto &#xFA;ltimo para declarar libre de derechos la internaci&#xF3;n de todos los animales, cuya introducci&#xF3;n es permitida en el pa&#xED;s.</div><div class=\"p\">&nbsp; &nbsp;  Se declara: que conforme a lo dispuesto por el decreto de 15 de Setiembre pr&#xF3;ximo pasado no debe cobrarse derecho de pontazgo por los animales que se internen al pa&#xED;s.</div></div>", "i": 9844069}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, comun&#xED;quese i publ&#xED;quese</div><br><div class=\"p\">&nbsp; &nbsp;  MONTT </div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Jos&#xE9; Guillermo Waddington.</div></div>", "i": 9844070}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DERECHO DE PONTAZGO", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1853-10-22", "doble_articulado": false, "id_norma": "1109860", "numero_fuente": "1853", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1853-10-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1853-10-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"ini