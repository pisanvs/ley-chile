{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8666578}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.699, de 14 de mayo de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a PR&#xD3;SPERO SEGUNDO ESPINOZA BARRAZA, para iniciar actividades pesqueras de transformaci&#xF3;n, para instalar y operar planta ubicada en Parcela Tres-B, Fundo Mostazal, Santo Domingo, V Regi&#xF3;n, en las l&#xED;neas de proceso Secado y Picado de Algas, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 364 de 2009, de esta Subsecretar&#xED;a.</div></div>", "i": 8666579}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de mayo de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8666580}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1699 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-1699 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-05-14", "doble_articulado": false, "id_norma": "1002808", "numero_fuente": "39374", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-05-30", "vigencias": [{"desde": "2009-05-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-05-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-05-30", "fin_vigencia": "", "tipo_version": "3"}], "ev