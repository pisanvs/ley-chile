{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  CAUSAS DE HACIENDA.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Setiembre 6 de 1825. </div></div>", "i": 10182586}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  A fin de afianzar la administracion de justicia de las causas de Hacienda, se ordena que para verlas no han de faltar en la Corte de Apelaciones tres miembros letrados conforme al esp&#xED;ritu del art. 58 y 68 del Reglamento de Justicia, y que en caso de necesitarse auxiliares han de concurrir por el orden de sus nombramientos o llamamiento legal.</div></div>", "i": 10182587}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, comun&#xED;quese e impr&#xED;mase. </div><br><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Correa de Saa.</div><br></div>", "i": 10182588}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "CAUSAS DE HACIENDA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-09-06", "doble_articulado": false, "id_norma": "1151483", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-09-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-09-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2020-12-07", "fecha_version": "1825-09-06