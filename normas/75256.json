{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xBA; 1.214, DE 1988 </div></div>", "i": 8868000}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.273, de 23 de Noviembre de 1988, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA; 1.214, de 3 de noviembre de 1988, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Sociedad Pesquera Coloso S.A., en el sentido de sustituir los recursos hidrobiol&#xF3;gicos: &quot;Merluza com&#xFA;n y merluza espa&#xF1;ola&quot; por Sardina com&#xFA;n y sardina espa&#xF1;ola, respectivamente.</div><br></div>", "i": 8868001}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de Noviembre de 1988.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8868002}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1273", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1273"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION Nº 1.214, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "AUTORIZACION", "SOCIEDAD PESQUERA COLOSO S.A.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1988-11-23", "fecha_derogacion": "2000-02-01", "doble_articulado": false, "id_norma": "75256", "numero_fuente": "33244", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1988-12-13", "vigencias": [{"desde": "2000-02-01", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1988-12-13", "hasta": "2000-01-31", "tipo_version": "0", "