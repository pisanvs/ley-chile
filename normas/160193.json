{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 348, DE 1990 </div></div>", "i": 6247760}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 348 de</div><div class=\"p\">21 de diciembre de 1990 se han aprobado programas</div><div class=\"p\">especiales de estudio de orientaci&#xF3;n laboral a la</div><div class=\"p\">Escuela Especial Particular No. 215, CEDIF, de Santiago,</div><div class=\"p\">Regi&#xF3;n Metropolitana, por un per&#xED;odo de 4 a&#xF1;os, a contar</div><div class=\"p\">de marzo de 1991, para talleres de: Alimentaci&#xF3;n,</div><div class=\"p\">artesan&#xED;a, horticultura y plantas ornamentales, y sellado y estampado en g&#xE9;nero.</div><br></div>", "i": 6247761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 08 de Enero de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6247762}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "348 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-348 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 348, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-21", "doble_articulado": false, "id_norma": "160193", "numero_fuente": "33876", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-01-24", "vigencias": [{"desde": "1991-01-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-01-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-01-24", "fin_v