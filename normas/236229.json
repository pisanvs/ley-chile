{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 785 EXENTA, DE 2005 </div><br></div>", "i": 6518551}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 785, de fecha 4 de marzo de 2005, de Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se aprueba el programa de ense&#xF1;anza de la Escuela de Conductores clase B &quot;Autoescuela Santiago&quot;, cuya propietaria es la se&#xF1;ora Claudia Carolina Andrade Olivares, para impartir cursos conducentes a la obtenci&#xF3;n de licencia de conducir no profesional clase B, la que tendr&#xE1; su lugar de funcionamiento en Almirante Gotuzzo N&#xBA; 096, oficina 24, comuna de Santiago.- </div></div>", "i": 6518552}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Silvio Albarr&#xE1;n Alb&#xE1;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6518553}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "785 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-785 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 785 EXENTA, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-03-04", "fecha_derogacion": "2022-08-26", "doble_articulado": false, "id_norma": "236229", "numero_fuente": "38108", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-03-11", "vigencias": [{"desde": "2022-08-26", "hasta": "", "tip