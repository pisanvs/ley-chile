{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Gastos del Congreso Nacional Lei n&#xFA;m. 1,000.- Santiago, a 21 de Enero de 1898.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274037}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase la inversion de veinte mil pesos para atender a diversos gastos jenerales de la Secretar&#xED;a de la C&#xE1;mara de Diputados ocurridos en el a&#xF1;o 1897, i la de cuatro mil pesos para fomento de la Biblioteca del Congreso.</div><br><br></div>", "i": 8274038}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Antonio Valdes C.</div><br></div>", "i": 8274039}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1000", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1000"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Gastos del Congreso Nacional", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONGRESO NACIONAL", "INVERSION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-01-21", "doble_articulado": false, "id_norma": "22335", "numero_fuente": "5909", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-01-22", "vigencias": [{"desde": "1898-01-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-01-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-01-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p