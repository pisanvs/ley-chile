{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8580952}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.382 de 09 de Noviembre de 1990 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por treinta d&#xED;as a contar de esta fecha, el plazo otorgado a PESQUERA ARIES LIMITADA, R.U.T.</div><div class=\"p\">No. 89.450.900-7, domiciliada en Iquique, en el numeral 4&#xB0; de la Resoluci&#xF3;n No. 401, de 1990, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8580953}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 09 de Noviembre de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8580954}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1382", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1382"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-11-09", "doble_articulado": false, "id_norma": "81927", "numero_fuente": "33838", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-12-07", "vigencias": [{"desde": "1990-12-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-12-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-12-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMZ", "fecha_ingreso": "1997-12-30", "fecha_version": "1990-12-07",