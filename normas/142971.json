{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 320, DE 1999</div><br><br></div>", "i": 6189979}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA; 320, de 9 de agosto de 1999, se ha aprobado el Convenio de fecha 30 de abril de 1999, celebrado entre el Ministerio de Educaci&#xF3;n y la I. Municipalidad de Calle Larga, que rectifica el Convenio de Traspaso de la Escuela B&#xE1;sica F N&#xBA; 139, de Calle Larga traspasada a dicha Corporaci&#xF3;n, por Convenio aprobado por decreto supremo de Educaci&#xF3;n N&#xBA; 367, de 2 de junio de 1986.</div><br></div>", "i": 6189980}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de septiembre de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6189981}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "320 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-320 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO Nº 320, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-08-09", "doble_articulado": false, "id_norma": "142971", "numero_fuente": "36461", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-10", "vigencias": [{"desde": "1999-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-09-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_in