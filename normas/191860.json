{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6358110}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.316, de 8 de noviembre de 2001, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 5&#xBA; de la resoluci&#xF3;n N&#xBA; 2.255 de 2001, de esta Subsecretar&#xED;a que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO, para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Prospecci&#xF3;n de &#xE1;reas de reclutamiento del Jurel entre la III y X Regiones&quot;, en el sentido de reemplazar la nave &quot;Paniahue&quot; por la nave &quot;Quilpolemu&quot;, ambas de propiedad de Alimentos Marinos S.A., de la n&#xF3;mina de naves participantes en la se&#xF1;alada pesca de investigaci&#xF3;n.</div><br></div>", "i": 6358111}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de noviembre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6358112}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2316", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2316"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-08", "doble_articulado": false, "id_norma": "191860", "numero_fuente": "37115", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-20", "vigencias": [{"desde": "2001-11-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-11-20", "fin_vigencia":