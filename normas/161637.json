{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6252824}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto N&#xBA; 129, de 30 de Abril de 1985, se expropi&#xF3; el lote N&#xBA; 11 y mejora 11-a, cuya superficie es 1.673,96 m&#xB2;., rol de aval&#xFA;o 294-1, comuna de Santiago, Regi&#xF3;n Metropolitana, para prolongaci&#xF3;n L&#xED;nea N&#xBA; 2, del Metro, sector Mapocho con Avenida Manuel Rodr&#xED;guez y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios Esso Chile S.A. Petrolera y otro y Guillermo Hormaz&#xE1;bal e Hijos y Compa&#xF1;&#xED;a Limitada, ascendente a las cantidades de $ 20.793.392. y $ 3.097.520.-</div><br></div>", "i": 6252825}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6252826}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "129", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-129"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-04-30", "doble_articulado": false, "id_norma": "161637", "numero_fuente": "32185", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-01", "vigencias": [{"desde": "1985-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2000-03-20", "fecha_version": "1985-06-01", "fecha_actualizac