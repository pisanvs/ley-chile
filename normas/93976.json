{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 208, DE 1988 </div></div>", "i": 6095803}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 208 de 29 de diciembre de 1988 se ha aprobado al Colegio Academia de Humanidades, de Santiago, un plan especial de estudio de Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica, que se aplicar&#xE1; a contar de 1989 de 1&#xB0; a 3er. a&#xF1;o y en 1990 en 4&#xB0; a&#xF1;o. </div></div>", "i": 6095804}, {"t": "<div><div class=\"p\">Santiago, 20 de Enero de 1989.- Paulina Dittborn Cordua, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6095805}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "208 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-208 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 208, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-29", "doble_articulado": false, "id_norma": "93976", "numero_fuente": "33288", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-02-02", "vigencias": [{"desde": "1989-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-02-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-02-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CQA", "fecha_ingreso": "1998-03-05", "fecha_version": "1989-02-02", "fecha_actualizacion_texto": "1989-02-02", "tipo_tratado": ""}, "alertas": [], "alert