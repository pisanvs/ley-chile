{"html": [{"t": "<div><br><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESI&#xD3;N ORDINARIA N&#xBA; 1615</div></div>", "i": 9149194}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile, en su Sesi&#xF3;n Ordinaria N&#xBA; 1615, celebrada el 9 de junio de 2011, adopt&#xF3; el siguiente Acuerdo:</div><br><div class=\"p\">1615-02-110609 &#x2013; Tasa de inter&#xE9;s para pago diferido de derechos de aduana.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3;, en conformidad con lo establecido en la letra c) del art&#xED;culo 10 de la Ley N&#xB0;18.634, la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de derechos de aduana durante el semestre que concluye el 31 de diciembre de 2011, ser&#xE1; de 5,1% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.</div><br></div>", "i": 9149195}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de junio de 2011.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div></div>", "i": 9149196}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1615", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1615"}, {"tipo": "5", "numero": "1615-02", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1615-02"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESIÓN ORDINARIA Nº 1615", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-06-09", "doble_articulado": false, "id_norma": "1026396", "numero_fuente": "39984", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-06-13", "vigencias": [{"desde": "2011-