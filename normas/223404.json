{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 201.- Santiago, 11 de marzo de 2004.- Vistos: Lo dispuesto en el Art. 11 del decreto ley N&#xBA; 2.974 de 1979.</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br></div>", "i": 6472439}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del decreto ley citado, X Regi&#xF3;n, al siguiente funcionario:</div><br><div class=\"p\">- Aram Amable Fuentes Ulloa - RUT 12.307.780-6 </div></div>", "i": 6472440}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Arturo S&#xE1;ez Chatterton, Director Nacional (S).</div><br></div>", "i": 6472441}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "201", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-201"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-11", "doble_articulado": false, "id_norma": "223404", "numero_fuente": "37830", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-06", "vigencias": [{"desde": "2004-04-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-04-06", "fin_vi