{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8910409}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.235, de 12 de octubre de 2000, d&#xE9;jase sin efecto la letra d) del numeral 1 de la resoluci&#xF3;n N&#xBA; 107, del a&#xF1;o 2000, que declar&#xF3; la caducidad de la resoluci&#xF3;n N&#xBA; 1.146, de 1988, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; a Frigor&#xED;fico Arica S.A. hoy AGROPESCA S.A., para desarrollar actividades pesqueras de transformaci&#xF3;n, por haberse dictado con error de hecho.</div><div class=\"p\">Decl&#xE1;rase, en consecuencia, plenamente vigente la resoluci&#xF3;n N&#xBA; 1.146, de 1988, de esta Subsecretar&#xED;a, conforme lo se&#xF1;alado precedentemente.</div><br></div>", "i": 8910410}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de octubre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 8910411}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2235", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2235"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-12", "doble_articulado": false, "id_norma": "176632", "numero_fuente": "36788", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-16", "vigencias": [{"desde": "2000-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-10-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-10-16", "