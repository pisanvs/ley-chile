{"html": [{"t": "<div><div class=\"p\">FIJA LISTA DE VALORES DE VEH&#xCD;CULOS MOTORIZADOS PARA LOS FINES QUE SE&#xD1;ALA</div></div>", "i": 10093116}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 3, del 10 de enero de 2020.</div><div class=\"p\">&nbsp; &nbsp;  Para los fines de lo dispuesto en el <a href=\"https://www.leychile.cl/Navegar?idNorma=7054&amp;idParte=8739641&amp;idVersion=\">art&#xED;culo 12</a>, letra a), <a href=\"https://www.leychile.cl/Navegar?idNorma=7054&amp;idParte=&amp;idVersion=\">DL N&#xBA; 3.063, de 1979</a>, sobre Rentas Municipales, se fija la lista de valores de autom&#xF3;viles y otros veh&#xED;culos motorizados usados para el a&#xF1;o 2020. Publ&#xED;quese el listado anexo de esta resoluci&#xF3;n en la p&#xE1;gina web de la empresa El Mercurio S.A.P., Emol.com.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl).</div><br></div>", "i": 10093117}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "FIJA LISTA DE VALORES DE VEHÍCULOS MOTORIZADOS PARA LOS FINES QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1711046; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-01-10", "doble_articulado": false, "id_norma": "1141127", "numero_fuente": "42553", "