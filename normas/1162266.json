{"html": [{"t": "<div><div class=\"p\">MODIFICA EL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10248204}, {"t": "<div><br><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 1.547, de 25 de junio de 2021, del Director Nacional de Aduanas, se modific&#xF3; el Cap&#xED;tulo IV del Compendio de Normas Aduaneras, en orden a incorporar el Ap&#xE9;ndice VIII, que establece el &quot;Procedimiento para examen f&#xED;sico en origen de las mercanc&#xED;as amparadas en Declaraciones &#xDA;nicas de Salida&quot;.</div><div class=\"p\">&nbsp; &nbsp;  Esta resoluci&#xF3;n entrar&#xE1; en vigencia a partir de su publicaci&#xF3;n en el Diario Oficial.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10248205}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de junio de 2021.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><br></div>", "i": 10248206}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1547 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-1547 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA EL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1971967", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-06-25", "doble_articulado": false, "id_norma": "1162266", "numero_fuente": "42995", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "20