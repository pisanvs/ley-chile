{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Asignacion para casa al Administrador de la Aduana Lei n&#xFA;m. 1,431.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949149}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. As&#xED;gnase al Administrador de la Aduana de Valparaiso la suma de mil ochocientos pesos anuales para arriendo de casa.</div><br></div>", "i": 5949150}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 16 de Enero de 1901.- FEDERICO ERRAZURIZ E.- Nicolas Gonz&#xE1;lez E.</div><br></div>", "i": 5949151}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1431", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1431"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ASIGNACION PARA CASA AL ADMINISTRADOR DE LA ADUANA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ADUANA VALPARAISO", "ADMINISTRADOR", "ASIGNACION CASA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-01-16", "doble_articulado": false, "id_norma": "22642", "numero_fuente": "6794", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-01-17", "vigencias": [{"desde": "1901-01-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1901-01-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1901-01-17", "fin_vigencia": "", "tipo_version": "3"}