{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8308326}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n N&#xBA;698 de 31 de Julio de 1992 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xBA;1066, de 1988, que autoriz&#xF3; a don MAURICIO BRINER BILLARD, R.U.T.</div><div class=\"p\">N&#xBA;6.433.465-4, domiciliado en Jos&#xE9; Domingo Ca&#xF1;as N&#xBA;1988, Depto. 42, Santiago, para operar un establecimiento de cultivo en Caleta Huentalauqu&#xE9;n, Provincia de Choapa, IV Regi&#xF3;n, en virtud de lo dispuesto en el Decreto N&#xBA;263, de 1992, del Ministerio de Defensa Nacional.</div><br></div>", "i": 8308327}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 31 de Julio de 1992. Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8308328}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "698", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-698"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-07-31", "doble_articulado": false, "id_norma": "77903", "numero_fuente": "34339", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-08-11", "vigencias": [{"desde": "1992-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-08-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-08-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac