{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA EL NOMBRE DE LA POBLACION LAS REJAS DE LA COMUNA DE MAIPU, POR EL DE VILLA BERNARDO O&apos;HIGGINS.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 8282128}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Sustit&#xFA;yese el nombre de la actual Poblaci&#xF3;n Las Rejas de la comuna de Maip&#xFA;, por el de &quot;Villa Bernardo O&apos;Higgins&quot;.&quot;.</div><br></div>", "i": 8282129}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veinte de agosto de mil novecientos sesenta y tres.- JORGE ALESSANDRI RODRIGUEZ.- S&#xF3;tero del R&#xED;o.</div><br></div>", "i": 8282130}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "15244", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-15244"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA EL NOMBRE DE LA POBLACION LAS REJAS DE LA\nCOMUNA DE MAIPU, POR EL DE VILLA BERNARDO O'HIGGINS.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "VILLA BERNARDO O'HIGGINS", "SANTIAGO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1963-08-20", "doble_articulado": false, "id_norma": "28112", "numero_fuente": "25634", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1963-09-05", "vigencias": [{"desde": "1963-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio