{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA A SOCIEDAD CHAPARRAL S A. PARA AMPLIAR ACTIVIDADES PESQUERAS</div><br></div>", "i": 8357499}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 892 de 10 de Agosto de 1987, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Sociedad Chaparral S.A., domiciliada en Santiago, para ampliar actividades pesqueras autorizadas por resoluci&#xF3;n No. 657, de 01 de Septiembre de 1986, de esta Subsecretar&#xED;a de Pesca, en orden a incorporar 200.000 ovas de trucha caf&#xE9; al cultivo autorizado en dicha resoluci&#xF3;n.</div><br></div>", "i": 8357500}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de Agosto de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8357501}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "892", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-892"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A SOCIEDAD CHAPARRAL S A. PARA AMPLIAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1987-08-10", "fecha_derogacion": "1997-08-13", "doble_articulado": false, "id_norma": "152338", "numero_fuente": "32858", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1987-08-29", "vigencias": [{"desde": "1997-08-13", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1987-08-29", "hasta": "1997-08-12", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio