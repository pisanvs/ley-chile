{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,423.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6163496}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- En atencion a los importantes servicios prestados al pais por el Ministro de la Corte Suprema de Justicia, se&#xF1;or don Jos&#xE9; Alejo Valenzuela, conc&#xE9;dese a su viuda e hijas solteras una pension anual de tres mil pesos la que gozar&#xE1;n con arreglo a la lei de montep&#xED;o militar.&quot; </div></div>", "i": 6163497}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago a 3 de enero de 1901.- FEDERICO ERRAZURIZ E.- Francisco J. Herboso.</div><br></div>", "i": 6163498}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1423", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1423"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-01-03", "doble_articulado": false, "id_norma": "134805", "numero_fuente": "6788", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-01-10", "vigencias": [{"desde": "1901-01-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1901-01-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1901-01-10", "fin_vigencia": "", "tipo_version": "3"}