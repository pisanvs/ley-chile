{"html": [{"t": "<div><br><div class=\"p\">MODIFICA CONCESI&#xD3;N DE ACUICULTURA</div><br></div>", "i": 8934406}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n 839, de fecha 1 de abril de 2010, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div><br><div class=\"p\">&nbsp; &nbsp;  I.- Modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=259954&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n 95, de fecha 19 de enero de 2007</a>, del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina, en el sentido de reemplazar el p&#xE1;rrafo 4.- por el siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;4.- El concesionario deber&#xE1; dar cabal cumplimiento al Proyecto T&#xE9;cnico y Cronograma de Actividades, aprobado por resoluci&#xF3;n exenta 2.149, de fecha 26 de julio de 2006, modificada por la resoluci&#xF3;n exenta 3.299, de fecha 5 de octubre de 2009, ambas del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, Subsecretar&#xED;a de Pesca.&quot;.</div><br></div>", "i": 8934407, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 1 de junio de 2010.- Por el Sr. Subsecretario, Felipe Garc&#xED;a-Huidobro Correa, Subjefe (M).</div><br></div>", "i": 8934408}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "839", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-839"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS"], "titulo_norma": "MODIFICA CONCESIÓN DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-04-01", "doble_articulado