{"html": [{"t": "<div><br><br><div class=\"p\">MODIFICA COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10116074}, {"t": "<div><br><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 1.416, de fecha 3 de abril de 2020, rectificada por la N&#xBA;1.492, de fecha 13 de abril de 2020, ambas del Director Nacional de Aduanas, se modifica el Cap&#xED;tulo VII del &quot;Manual de Procedimientos para Subastas Aduaneras&quot;, aprobado por <a href=\"https://www.leychile.cl/Navegar?idNorma=1116090&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA;854/27.02.2018</a>, en lo siguiente:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Se agregan nuevos p&#xE1;rrafos a los numerales 5 y 10.</div><div class=\"p\">&nbsp; &nbsp;  Se sustituyen los numerales 11 y 12.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de las resoluciones se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).- </div><div class=\"p\">&nbsp; &nbsp;  </div><br></div>", "i": 10116075}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><br></div>", "i": 10116076}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1416 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1416 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1752989; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-04-03",