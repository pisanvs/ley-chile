{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DERECHOS DE APROVECHAMIENTO DE AGUAS EN COMUNA DE SAN CLEMENTE </div></div>", "i": 6021828}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta N&#xB0; 290 de 18 Febrero de 1993, conforme Art&#xED;culo 5&#xB0; Transitorio C&#xF3;digo Aguas, determin&#xF3; Derechos Aprovechamiento Aguas Proporcionales que corresponden a los Sitios N&#xB0;s 234 al 263; Reservas CORA N&#xB0;s. 32 y 48 y Reserva ODENA N&#xB0; 6 del Proyecto de Parcelaci&#xF3;n &quot;Colonia Mariposas&quot; de la Comuna de San Clemente, S&#xE9;ptima Regi&#xF3;n, formado por el predio &quot;Hacienda Mariposas&quot;.</div><div class=\"p\">&nbsp; &nbsp; Los derechos de aguas se extraen de las quebradas Los Leones, El Ventarr&#xF3;n y Los Treiles, afluentes del Estero Corel.</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n hecha conforme Art&#xED;culo 13 Ley N&#xB0; 18.377.-</div><br></div>", "i": 6021829}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director Nacional.</div><br></div>", "i": 6021830}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "290 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-290 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DERECHOS DE APROVECHAMIENTO DE AGUAS EN COMUNA DE SAN CLEMENTE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHO APROVECHAMIENTO AGUAS", "SAN CLEMENTE", "SEPTIMA", "REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-02-18", "doble_articulado": false, "id_norma": "38721", "numero_fuente": "34504-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "19