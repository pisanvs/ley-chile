{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6167826}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP No. 382, de 26 de febrero de 1999, se expropiaron los lotes de terreno No. s. 3, 18, 19 y 20, superficies 3275, 20.783,88, 14.058,48 y 3.562,55 m2. respectivamente, roles de aval&#xFA;o 516-56, 511-18, 511-96 y 511-19, comuna de Carahue, para la obra camino Costero Tir&#xFA;a - Carahue, sector Puyanhue Tranapuente y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Abel Morales Salas, Carlos Cofr&#xE9; Cuminao, Domiciano Sep&#xFA;lveda Riquelme y Manuel Jara Huentemilla, ascendente a las cantidades de $ 460.478.- para el lote 3, $ 2.074.498.- para el lote 18, $ 1.709.281.- para el lote 19 y $ 397.763.- para el lote 20.-</div><br></div>", "i": 6167827}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6167828}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "382", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-382"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-02-26", "doble_articulado": false, "id_norma": "136165", "numero_fuente": "36353", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-05-03", "vigencias": [{"desde": "1999-05-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-05-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-05-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v