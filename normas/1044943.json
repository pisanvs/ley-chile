{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9308373}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.691, de 9 de octubre de 2012, de esta Subsecretar&#xED;a, modif&#xED;quese la <a href=\"https://www.leychile.cl/Navegar?idNorma=1043186&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 2.249, de 2012</a>, de esta Subsecretar&#xED;a, en el sentido de se&#xF1;alar que el descuento a efectuar en la cuota del armador SOCIEDAD PESQUERA QUINTERO LIMITADA, es de 24 kilos y no 24 toneladas.</div></div>", "i": 9308374}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de octubre de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9308375}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2691 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2691 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-10-09", "doble_articulado": false, "id_norma": "1044943", "numero_fuente": "40388", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-10-18", "vigencias": [{"desde": "2012-10-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-10-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-10-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "16291", "fecha_ingreso": "2012-1