{"html": [{"t": "<div><div class=\"p\">DELEGA FACULTAD PARA AUTORIZAR A CONTRIBUYENTES COMO EMISORES ELECTRONICOS</div><br><br></div>", "i": 6461399}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 8 del 23 de enero de 2004. Delega en el Subdirector de Fiscalizaci&#xF3;n, la facultad para autorizar como emisores electr&#xF3;nicos a los contribuyentes que cumplan en forma satisfactoria el proceso de postulaci&#xF3;n y certificaci&#xF3;n obligatorio, a que se hace menci&#xF3;n en el resolutivo segundo de la Res.</div><div class=\"p\">Ex. SII N&#xBA;45 de septiembre de 2003.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en enero, de 2004.</div><br></div>", "i": 6461400}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DELEGA FACULTAD PARA AUTORIZAR A CONTRIBUYENTES COMO\nEMISORES ELECTRONICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FACULTAD", "SUBDIRECTOR DE FISCALIZACION", "EMISORES ELECTRONICOS", "DOCUMENTOS TRIBUTARIOS ELECTRONICOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO, NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-23", "doble_articulado": false, "id_norma": "220637", "numero_fuente": "37772", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-01-29", "vigencias": [{"desde": "2004-01-29", "hasta":