{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6374011}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA;2.075, de 31 de diciembre</div><div class=\"p\">de 2001, y en base a la facultad otorgada por el</div><div class=\"p\">art&#xED;culo 105 del D.F.L. MOP N&#xBA;850, de 1997, que fij&#xF3; el texto actualizado de la ley N&#xBA;15.840, se expropi&#xF3; el lote de terreno N&#xBA;16-A, para la obra Camino Fresia Parga-Llico-Las Ca&#xF1;itas, Rol V-46, Kms. 14.835 al 48.580,, que figura a nombre de Gonz&#xE1;lez Fehring Cervando Eloy, rol de aval&#xFA;o 164-1, superficie 90 m2., comuna de Fresia. La Comisi&#xF3;n de Peritos, con fecha 30 de abril de 2001, fij&#xF3; la indemnizaci&#xF3;n provisional en la cantidad de $598.500, la que se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA;2.186, de 1978.-</div><br></div>", "i": 6374012}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas </div></div>", "i": 6374013}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2075 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2075 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-31", "doble_articulado": false, "id_norma": "195915", "numero_fuente": "37211", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-03-15", "vigencias": [{"desde": "2002-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"ini