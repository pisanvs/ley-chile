{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Prorroga los efectos de la lei n&#xFA;m. 2,912 sobre emision de Vales de Tesorer&#xED;a</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,025.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7166228}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Prorr&#xF3;ganse, por el t&#xE9;rmino de un a&#xF1;o, los efectos de la lei n&#xFA;mero 2,912, de 3 de Agosto de 1914, sobre emision de Vales de Tesorer&#xED;a.</div><br><br></div>", "i": 7166229, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 4 de Setiembre de 1915.- RAMON BARROS LUCO.- Alberto Edwards.</div><br></div>", "i": 7166230}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3025", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3025"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "PRORROGA LOS EFECTOS DE LA LEI NUM. 2.912 SOBRE EMISION DE VALES DE TESORERIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VALES TESORERIA", "EMISION", "PLAZO", "PRORROGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1915-09-04", "doble_articulado": false, "id_norma": "23674", "numero_fuente": "11261", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1915-09-04", "vigencias": [{"desde": "1915-09-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"i