{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8355234}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.408, de 15 de diciembre de 1999, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 997, de 1996, de esta Subsecretar&#xED;a, en cuanto autoriz&#xF3; a LUIS FRANCISCO TORRES CARVAJAL, para ampliar actividades con la nave &apos;&apos;Guayac&#xE1;n&apos;&apos; respecto de los recursos Anchoveta, Sardina Espa&#xF1;ola, Jurel, Bonito, Caballa y Cojinoba del norte en la III y IV Regiones, de conformidad con la letra B) del art&#xED;culo 143 del D.S. N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8355235}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de diciembre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8355236}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2408", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2408"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "LUIS FRANCISCO TORRES CARVAJAL", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-15", "doble_articulado": false, "id_norma": "149855", "numero_fuente": "36547", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-12-24", "vigencias": [{"desde": "1999-12-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-12-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci