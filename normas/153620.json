{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6226536}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 653, de 10 de Agosto de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n se autoriza a Luis Jaramillo Piasencio, Neftal&#xED; Alvarado Arriagada, Javier Pardo Briones y Hugo L&#xF3;pez Ch&#xE1;vez para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 10 &quot;- CORVI - Regional Centro&quot; de Valdivia, cuyo trazado fue autorizado por resoluci&#xF3;n exenta No. 12, de 04 de Enero de 1985 y modificado por resoluci&#xF3;n exenta No. 486, de 04 de Noviembre de 1985, de esta Secretar&#xED;a Regional.-</div><br></div>", "i": 6226537}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6226538}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "653 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-653 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-10", "doble_articulado": false, "id_norma": "153620", "numero_fuente": "32868", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-10", "vigencias": [{"desde": "1987-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09