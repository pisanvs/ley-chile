{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO RECEPTOR JUDICIAL FUNCIONARIO QUE INDICA </div><div class=\"p\">N&#xFA;m. 103.- Santiago, 09 de Julio de 1990.- Vistos: Lo dispuesto en el Art. 11 del Decreto Ley No. 2.974.</div><br><div class=\"p\">Resuelvo:</div><br></div>", "i": 9001393}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase, como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del Decreto Ley No. 2.974, en la VIII Regi&#xF3;n, Area de Concepci&#xF3;n, al se&#xF1;or Juan Villa<div class=\"n rnp\" id=\"rnp0\"><a href=\"#np0\">NOTA:</a></div> Baglietto.</div><br><div class=\"np\" id=\"np0\"><a href=\"#rnp0\">NOTA:</a> <br>&nbsp; &nbsp; &nbsp; La RES RES 70, Agricultura, publicada el 30.04.2005, elimin&#xF3; a don Juan Villa Baglietto como Receptor Judicial.<br></div></div>", "i": 9001394}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hugo Ortega Tello, Director Nacional.</div><br><br></div>", "i": 9001395}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "3", "numero": "103", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-103"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL FUNCIONARIO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-07-09", "doble_articulado": false, "id_norma": "89203", "numero_fuente": "33747", "tipo_version": "2", "tipo_version_s": "Última Versión