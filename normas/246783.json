{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6559115}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 63, de 4 de enero de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a GASTON PATRICIO VARGAS VARGAS para instalar, por el per&#xED;odo de seis meses contados desde la fecha de la presente resoluci&#xF3;n, colectores de semillas de mit&#xED;lidos en Punta Queil&#xE9;n, X Regi&#xF3;n, en una superficie de 2,27 hect&#xE1;reas, cuyas coordenadas geogr&#xE1;ficas, referidas a la carta SHOA N&#xBA; 714 son las siguientes:</div><br><div class=\"p\">&nbsp; V&#xE9;rtice&nbsp;  Latitud (S)&nbsp;  Longitud (W)</div><div class=\"p\">&nbsp; A&nbsp;  42&#xB0;54&apos;29,00&quot;&nbsp;  73&#xB0;29&apos;44,00&quot;</div><div class=\"p\">&nbsp; B&nbsp;  42&#xB0;54&apos;34,00&quot;&nbsp;  73&#xB0;29&apos;40,50&quot;</div><div class=\"p\">&nbsp; C&nbsp;  42&#xB0;54&apos;39,00&quot;&nbsp;  73&#xB0;29&apos;42,50&quot;</div><div class=\"p\">&nbsp; D&nbsp;  42&#xB0;54&apos;34,00&quot;&nbsp;  73&#xB0;29&apos;47,00&quot;</div><br><br></div>", "i": 6559116}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de enero de 2006.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6559117}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "63 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-63 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-04", "doble_articulado": false, "id_norma": "246783", "numero_fuente": "38373", "tipo_ver