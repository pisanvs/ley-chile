{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA;8.731 EXENTA, DE 2014</div><div class=\"p\">&nbsp; </div></div>", "i": 9543473}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta se han complementado las resoluciones exentas N&#xBA;s. <a href=\"https://www.leychile.cl/Navegar?idNorma=179892&amp;idParte=0&amp;idVersion=\">11.357, de 2000</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=198671&amp;idParte=0&amp;idVersion=\">16.281, de 2001</a>, ambas del Ministerio de Educaci&#xF3;n, que aprobaron planes y programas especiales de estudio de 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Colegio St. Margaret&apos;s British School, comuna de Conc&#xF3;n, provincia de Valpara&#xED;so, Regi&#xF3;n de Valpara&#xED;so, en el sentido de agregar en el &#xC1;rea de Artes y Otros del Plan de Formaci&#xF3;n Diferenciada, el Sector de Franc&#xE9;s con 5 horas semanales.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio del sector se&#xF1;alado anteriormente.</div><br></div>", "i": 9543474}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de dicienbre de 2014.- Gonzalo Mu&#xF1;oz Stuardo, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 9543475}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8731 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-8731 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº8.731 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-12-12", "doble_articulado