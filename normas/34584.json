{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292210}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 392, de 7 de Abril de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a SOCIEDAD AGRICOLA Y COMERCIAL AGRYCOM LTDA., R.U.T. N&#xB0; 88.370.200-K, para iniciar actividades pesqueras, en orden a instalar y operar una planta ubicada en Parcela 1, Ritoque, Quintero, en la l&#xED;nea de elaboraci&#xF3;n de harina de crust&#xE1;ceos, los siguientes recursos hidrobiol&#xF3;gicos: Camar&#xF3;n nailon, Centolla, Jaiba, Krill, Langosta de J. Fern&#xE1;ndez, Langostino amarillo, Langostino colorado. </div></div>", "i": 8292211}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 7 de Abril de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292212}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "392", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-392"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "SOCIEDAD AGRICOLA Y COMERCIAL", "AGRYCOM LTDA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-04-07", "doble_articulado": false, "id_norma": "34584", "numero_fuente": "35155", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-04-29", "vigencias": [{"desde": "1995-04-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-04-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "19