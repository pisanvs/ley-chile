{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6425794}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;1.130 de 30 de mayo de 2003, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1045499&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA;257 de 1989</a>, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA AMANECER DE IQUIQUE S.A. para operar la nave en construcci&#xF3;n &quot;Spica&quot;, en virtud de lo dispuesto en los art&#xED;culos 7&#xBA; del D.S. N&#xBA;175 de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n y 143 letra b) de la Ley General de Pesca y Acuicultura. </div><br></div>", "i": 6425795, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de mayo de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6425796}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1130", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1130"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-05-30", "doble_articulado": false, "id_norma": "210899", "numero_fuente": "37576", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-05", "vigencias": [{"desde": "2003-06-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-06-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-06-05", "fin_vigencia": "", "tipo_ve