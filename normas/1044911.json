{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9306520}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.677, de 9 de octubre de 2012, de esta Subsecretar&#xED;a, autor&#xED;zase a MARCELINO GONZ&#xC1;LEZ SILVA, para ampliar actividades pesqueras extractivas con la nave &quot;Berta&quot; en las &#xE1;reas mar&#xED;timas que a continuaci&#xF3;n se indican, donde podr&#xE1; capturar los siguientes recursos hidrobiol&#xF3;gicos: a) En el &#xE1;rea mar&#xED;tima de la IV a IX Regiones, por fuera del &#xE1;rea de reserva artesanal, con arrastre: Pejerrata y Vinciguerria. b) En el &#xE1;rea mar&#xED;tima correspondiente a la IV Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, con arrastre: Cachurreta o Barrilete.</div></div>", "i": 9306521}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de octubre de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9306522}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2677 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2677 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-10-09", "doble_articulado": false, "id_norma": "1044911", "numero_fuente": "40387", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-10-17", "vigencias": [{"desde": "2012-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-10-17", "fin_vigencia": ""}, "vigen