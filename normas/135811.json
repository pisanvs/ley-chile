{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,020.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6166670}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se autoriza a la Empresa de los Ferrocarriles del Estado para abonar, por una sola vez, a do&#xF1;a Irene Zelada, viuda de Estivil, una cantidad igual al sueldo anual de que disfrutaba su esposo, don Miguel Estivil.</div><br></div>", "i": 6166671}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, dos de setiembre de mil novecientos siete.- Pedro Montt.- Gonzalo Urrejola.</div><br></div>", "i": 6166672}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2020", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2020"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-09-02", "doble_articulado": false, "id_norma": "135811", "numero_fuente": "8902", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-09-16", "vigencias": [{"desde": "1907-09-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-09-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1907-09-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingr