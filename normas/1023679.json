{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 1.989 EXENTA, DE 2011</div><br></div>", "i": 9120988}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 1.989, de 2 de marzo de 2011, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la sociedad &quot;Sociedad D&#xED;az Limitada&quot; (Preuc) RUT 77.971.980-4, contenida en la resoluci&#xF3;n exenta N&#xBA; 2.539, de 29 de septiembre de 2006, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 3, del art. 21 de la ley 19.518.</div><br></div>", "i": 9120989}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Miguel Bergu&#xF1;o Ca&#xF1;as, Director Nacional.</div></div>", "i": 9120990}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1989 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1989 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 1.989 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-03-02", "doble_articulado": false, "id_norma": "1023679", "numero_fuente": "39909", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-03-14", "vigencias": [{"desde": "2011-03-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-03-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-03-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu