{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8290174}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 95, de 16 de enero de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por don CLAUDIO</div><div class=\"p\">AGUSTIN BENAVENTE VIO, para operar un centro de cultivo</div><div class=\"p\">ubicado en Bah&#xED;a Guanaqueros, Comuna de Coquimbo,</div><div class=\"p\">Provincia de Elqui, IV Regi&#xF3;n, por no dar cumplimiento</div><div class=\"p\">el respectivo proyecto t&#xE9;cnico a lo dispuesto en los</div><div class=\"p\">art&#xED;culos 77&#xB0; y 78&#xB0; de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8290175}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 16 de enero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8290176}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "95", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-95"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "CLAUDIO AGUSTIN BENAVENTE VIO", "COQUIMBO", "CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-01-16", "doble_articulado": false, "id_norma": "33040", "numero_fuente": "35373", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-01-23", "vigencias": [{"desde": "1996-01-23", "hasta": "", "tipo_version": "3