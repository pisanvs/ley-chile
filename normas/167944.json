{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6272988}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 164, de 08 de Mayo de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se autoriza a Jorge H. R&#xED;os Castro, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro de territorio nacional a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6272989}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco Navarro Ruiz, Secretario Regional Ministerial Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6272990}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "164 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-164 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-08", "doble_articulado": false, "id_norma": "167944", "numero_fuente": "32173", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-05-17", "vigencias": [{"desde": "1985-05-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-05-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-05-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pend