{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA N&#xB0; 1.005, DE 1987 </div><br><br></div>", "i": 6276280}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.005 de fecha 13 de Mayo de 1987, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se aprob&#xF3; el siguiente plan com&#xFA;n y modificaciones introducidas a los programas de estudios del Centro de Formaci&#xF3;n T&#xE9;cnica La Frontera de Temuco, de la carrera y t&#xED;tulo t&#xE9;cnico que se indica, para impartirse a contar del a&#xF1;o 1987: Carrera: Secretariado Ejecutivo</div><div class=\"p\">T&#xED;tulo: Secretario(a) Ejecutivo(a) Secretario(a) Ejecutivo(a) especialidad Jur&#xED;dico Secretario(a) Ejecutivo(a) menci&#xF3;n en Comunicaci&#xF3;n Social Secretario(a) Ejecutivo(a) con menci&#xF3;n en Bancos Secretario(a) Ejecutivo(a) Biling&#xFC;e.</div><br></div>", "i": 6276281}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6276282}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1005 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1005 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N° 1.005, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1987-05-13", "fecha_derogacion": "2000-12-04", "doble_articulado": false, "id_norma": "168996", "numero_fuente": "32909", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1987-11-02", "vigencias": [{"desde": "2000-12-04", "hasta": "", "tip