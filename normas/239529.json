{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6531005}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.763, de 8 de junio de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a PRODUCTORA Y EXPORTADORA ACUICOLA S.A., para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Avenida Parque Fundici&#xF3;n Sur N&#xBA; 546, Tongoy, Coquimbo, IV Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Fresco refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1.702 de 2000, de esta Subsecretar&#xED;a; en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6531006}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de junio de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6531007}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1763 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1763 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-08", "doble_articulado": false, "id_norma": "239529", "numero_fuente": "38197", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-06-29", "vigencias": [{"desde": "2005-06-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-06-29", "fin_vigencia": ""