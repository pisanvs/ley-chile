{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6447009}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.509, de 15 de octubre de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1.- de la resoluci&#xF3;n N&#xBA; 877 de 1998, el numeral 2.- de la resoluci&#xF3;n N&#xBA; 227 de 1999, y el numeral 1.- de la resoluci&#xF3;n N&#xBA; 2.557 de 2002, todas de esta Subsecretar&#xED;a, y que autorizaron a PESQUERA EL GOLFO S.A. para realizar actividades pesqueras extractivas con la nave &quot;Polaris II&quot;, en el sentido de actualizar e incorporar en &#xE9;sta las siguientes caracter&#xED;sticas n&#xE1;uticas:</div><br><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp;  48,14 m.</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 10,50 m.</div><br></div>", "i": 6447010}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de octubre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6447011}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2509 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2509 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-10-15", "fecha_derogacion": "2016-11-21", "doble_articulado": false, "id_norma": "216853", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-11-05", "vigencias": [{"desde": "2016-11-21", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-11-05", "hasta