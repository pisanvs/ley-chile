{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  EXTRACTO DE DECRETO EXENTO No. 255, DE 1987 </div></div>", "i": 6168211}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 255 de 29 de diciembre de 1987 se ha aprobado para el Instituto del Mar &quot;Capit&#xE1;n Williams&quot;, de la comuna de Chonchi, provincia de Chilo&#xE9;, X Regi&#xF3;n de Los Lagos, planes y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico - Profesional, que se aplicar&#xE1;n gradualmente para las promociones que ingresen a 3er.</div><div class=\"p\">a&#xF1;o durante los a&#xF1;os 1988 y 1989, en las Especialidades que se indican:</div><br><div class=\"p\">Extracci&#xF3;n Pesquera.</div><div class=\"p\">Mec&#xE1;nica Naval.</div><div class=\"p\">Elaboraci&#xF3;n de Productos Pesqueros.</div><div class=\"p\">Acuicultura.</div><br></div>", "i": 6168212}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de Mayo de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6168213}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "255 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-255 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 255, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-12-29", "doble_articulado": false, "id_norma": "136275", "numero_fuente": "33075", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-05-19", "vigencias": [{"desde": "1988-05-19", "hasta": "",