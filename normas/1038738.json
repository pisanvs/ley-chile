{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9247006}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 739, de 29 de marzo de 2012, de esta Subsecretar&#xED;a, ac&#xF3;gense las reclamaciones de los armadores artesanales que se individualizan a continuaci&#xF3;n, interpuestas contra la resoluci&#xF3;n exenta N&#xBA; 2.005, de 2011, del Servicio Nacional de Pesca.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;janse sin efecto las caducidades declaradas por la <a href=\"https://www.leychile.cl/Navegar?idNorma=1030854&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.005, de 2011, del Servicio Nacional de Pesca</a>, &#xFA;nicamente respecto de las inscripciones en el Registro Pesquero Artesanal de las embarcaciones artesanales que a continuaci&#xF3;n se indican:</div><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/25298.jpg\"></div></div>", "i": 9247007}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de marzo de 2012.- Pablo Galilea Carillo, Subsecretario de Pesca.</div></div>", "i": 9247008}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "739 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-739 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-03-29", "doble_articulado": false, "id_norma": "1038738", "numero_fuente": "40230", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-04-04", "vigencias": [{"desde": "2012-04-04", "has