{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 279 EXENTO, DE 2005 </div></div>", "i": 6521792}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 279, de fecha 24 de marzo de 2005, del Ministerio de Educaci&#xF3;n, se reemplazan a contar del a&#xF1;o 2004 las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica de la Industria Gr&#xE1;fica o C.F.T. Ingraf, que fueran aprobadas por decreto exento de Educaci&#xF3;n N&#xBA; 176 del 24 de marzo de 2003.</div><br><br></div>", "i": 6521793}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Santiago, 6 de abril de 2005.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6521794}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "279 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-279 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 279 EXENTO, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-03-24", "doble_articulado": false, "id_norma": "236996", "numero_fuente": "38134", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-04-13", "vigencias": [{"desde": "2005-04-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-04-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-04-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "DVG", "fecha_ingreso": "2005-04-13", "fe