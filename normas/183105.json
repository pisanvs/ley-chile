{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 949 EXENTA, DE&nbsp; 2001 </div></div>", "i": 6327365}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 949, de 14 de febrero del a&#xF1;o 2001, se ha aprobado al Colegio &apos;&apos;Patrocinio de San Jos&#xE9;&apos;&apos;, comuna de Providencia, provincia de Santiago, un plan de estudio para 3&#xBA; a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores de Filosof&#xED;a en la Formaci&#xF3;n General y de Educaci&#xF3;n Tecnol&#xF3;gica en la Formaci&#xF3;n Diferenciada en la presente resoluci&#xF3;n.</div><br></div>", "i": 6327366}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de febrero de 2001.- Gabriel Ar&#xE1;nguiz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General (S). </div></div>", "i": 6327367}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "949 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-949 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 949 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-14", "doble_articulado": false, "id_norma": "183105", "numero_fuente": "36919", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-22", "vigencias": [{"desde": "2001-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"in