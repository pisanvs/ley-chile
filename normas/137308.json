{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 2,314.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6171521}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese a do&#xF1;a Mercedes Venegas v. de Nogueira derecho a gozar del montep&#xED;o a que habr&#xED;a tenido opcion si hubiera estado viuda cuando falleci&#xF3; su hijo el teniente segundo de la Armada Nacional, don Neftal&#xED; Nogueira.&quot; </div></div>", "i": 6171522}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto ordeno se promulgue i lleve a efocto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintiocho de junio de mil novecientos diez.- Pedro Montt.- C&#xE1;rlos Larrain Claro.</div><br></div>", "i": 6171523}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2314", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2314"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-06-28", "doble_articulado": false, "id_norma": "137308", "numero_fuente": "9738", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-07-09", "vigencias": [{"desde": "1910-07-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-07-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1910-07-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "