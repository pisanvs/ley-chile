{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7341046}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.067, de 4 de abril de 2007, de esta Subsecretar&#xED;a, autoriza a la SUCESION DE MARIO FLORINDO GAJARDO VENEGAS para sustituir la nave &quot;Noel I&quot; por una nave en construcci&#xF3;n, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Eslora total&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 16,95 m.</div><div class=\"p\">T.R.G. (Nacional)&nbsp; &nbsp;  85,64 t.</div><div class=\"p\">Capacidad de Bodega&nbsp;  81,10 m3</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 6,20 m.</div><div class=\"p\">Artes de pesca&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Cerco</div><br><div class=\"p\">&nbsp; &nbsp;  F&#xED;jase como zona de operaci&#xF3;n de la nave reemplazante, individualizada precedentemente, el &#xE1;rea mar&#xED;tima comprendida entre la III y IV Regiones, donde podr&#xE1; capturar, por fuera del &#xE1;rea de reserva artesanal, con red de cerco, los recursos hidrobiol&#xF3;gicos Jurel, Anchoveta y Sardina espa&#xF1;ola.</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;janse sin efecto las resoluciones N&#xBA; 1.064 de 1992, N&#xBA; 1.141 de 1998, N&#xBA; 1.862 y N&#xBA; 2.384, ambas de 2000, N&#xBA; 1.146 de 2001, N&#xBA; 3.236 de 2006, todas de esta Subsecretar&#xED;a.</div><br></div>", "i": 7341047}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de abril de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7341048}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1067 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1067 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2007-04-04", "fecha_derogacion": "2007-09-28", "doble_articulado": false, "id_norma": "260460", "numero_fuente": "38750", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2007-04-28", "vigencias": [{"desde": "2007-09-28", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2007-04-28", "hasta": "2007-09-27", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2007-09-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-04-28", "fin_vigencia": "2007-09-27", "tipo_version": "0"}, {"inicio_vigencia": "2007-09-28", "fin_vigencia": "", "tipo_version": "2"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "CMV", "fecha_ingreso": "2007-10-04", "fecha_version": "2007-09-28", "actualizado_por": "JRC", "fecha_actualizacion_texto": "2007-09-28", "tipo_tratado": ""}, "alertas": [{"clase": "derogado", "texto": "Derogado", "mensaje": "Esta norma ha sido derogada el 28-SEP-2007"}], "alerta_global": {"m": ["Esta norma ha sido derogada el 28-SEP-2007"], "e": {"i": "", "p": "", "f": "", "t": ""}}, "estructura": [{"n": "Encabezado", "i": 7341046}, {"n": "Artículo", "i": 7341047, "t": 6}, {"n": "Promulgación", "i": 7341048}]}