{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION QUE INDICA </div></div>", "i": 8326208}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No.1.176, de 29 de Agosto de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deroga la resoluci&#xF3;n No.1.439, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Sociedad Matilde L&#xF3;pez Mu&#xF1;oz y Compa&#xF1;&#xED;a, domiciliada en calle Loa No.45, Comuna de Mar&#xED;a Elena, II Regi&#xF3;n, para desarrollar actividades de cultivo de camar&#xF3;n de r&#xED;o en un sector de la localidad La Parte, Valle de Quillagua, R&#xED;o Loa, II Regi&#xF3;n, por renuncia de su titular.</div><br></div>", "i": 8326209}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 29 de Agosto de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8326210}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1176", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1176"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "DEROGA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-08-29", "doble_articulado": false, "id_norma": "95483", "numero_fuente": "33471", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-09-12", "vigencias": [{"desde": "1989-09-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-09-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-09-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe