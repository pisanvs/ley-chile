{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8318645}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.827, de 31 de diciembre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a PESQUERA PACIFIC STAR S.A., para continuar desarrollando las actividades de transformaci&#xF3;n autorizadas por resoluciones N&#xBA; 484, de 1995 y N&#xBA; 848 de 1997, ambas de esta Subsecretar&#xED;a, a Salmones Pacific Star Ltda., en virtud de las Escrituras P&#xFA;blicas de fecha 15 de abril de 1997 y de fecha 12 de junio de 1997, otorgadas ante la Notario P&#xFA;blico de Santiago, do&#xF1;a Antonieta Mendoza Escalas, de transformaci&#xF3;n y divisi&#xF3;n de sociedad. </div></div>", "i": 8318646}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de diciembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8318647}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1827", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1827"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA PACIFIC STAR S.A.", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-31", "doble_articulado": false, "id_norma": "88024", "numero_fuente": "35966", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-16", "vigencias": [{"desde": "1998-01-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-16", "fin_vigenc