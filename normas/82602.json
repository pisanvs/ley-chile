{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUA EN COMUNA DE CURICO </div></div>", "i": 6062681}, {"t": "<div><div class=\"p\">Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No.</div><div class=\"p\">1.021 de 10 de Julio de 1990, conforme Art. 5&#xB0; transitorio C&#xF3;digo Aguas, modific&#xF3; resoluci&#xF3;n exenta No. 156 de 31 de Enero de 1986, en el sentido de establecer que los derechos del Sitio No. 5 del Proyecto de Parcelaci&#xF3;n &quot;Santa Olga&quot; de la comuna de Curic&#xF3; se distribuyen entre el Sitio No. 5 y el Sitio No. 27.</div><div class=\"p\">Los derechos de aguas se extraen del r&#xED;o Teno por el Canal Quete - Quete.</div><div class=\"p\">Publicaci&#xF3;n hecha conforme art&#xED;culo 13 de la Ley No. 18.377. </div></div>", "i": 6062682}, {"t": "<div><div class=\"p\">Director Nacional.</div><br></div>", "i": 6062683}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1021 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1021 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DERECHOS DE AGUA EN COMUNA DE CURICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-07-10", "doble_articulado": false, "id_norma": "82602", "numero_fuente": "33734", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-08-01", "vigencias": [{"desde": "1990-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eve