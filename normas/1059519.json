{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9408128}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 440, de 31 de enero de 2014, de esta Subsecretar&#xED;a, ampl&#xED;ese por un a&#xF1;o, a contar del 10 de agosto de 2014, el plazo otorgado en los numerales 4&#xBA; de las resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=1035620&amp;idParte=0&amp;idVersion=\">N&#xBA; 3.316, de 2011</a>; <a href=\"https://www.leychile.cl/Navegar?idNorma=1050061&amp;idParte=0&amp;idVersion=\">N&#xBA; 800</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1051598&amp;idParte=0&amp;idVersion=\">N&#xBA; 1.222</a>, ambas de 2013, de esta Subsecretar&#xED;a, a Pesquera B&#xED;o B&#xED;o S.A., para iniciar actividades pesqueras extractivas con la nave en construcci&#xF3;n denominada &quot;BEC256407&quot;, con excepci&#xF3;n de aquellas especies cuya caducidad haya sido declarada mediante resoluci&#xF3;n, en virtud de haberse acreditado una circunstancia de fuerza mayor.</div></div>", "i": 9408129}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de enero de 2014.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9408130}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "440 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-440 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2014-01-31", "fecha_derogacion": "2017-11-29", "doble_articulado": false, "id_norma": "1059519", "tipo_version