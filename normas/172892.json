{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6288648}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.086 de 29 de mayo de 2000, se expropiaron los lotes de terreno N&#xBA;s. 70, 74, 75 y 76, superficies 165, 290, 178 y 198 m2, roles de aval&#xFA;o 1011-12, 1012-6, 1008-2 y 1008-25, comuna de Puerto Natales, para la obra Habilitaci&#xF3;n y Construcci&#xF3;n Regad&#xED;o Huertos Familiares Puerto Natales II Etapa Complementarias y se acord&#xF3; precio de la indemnizaci&#xF3;n con sus propietarios Wenceslao C&#xE1;rcamo Barr&#xED;a, Eladio Alvarez Z&#xFA;&#xF1;iga, Sigifredo Segundo Barrientos Vivar y Jorge Eris D&#xED;az B&#xF3;rquez, ascendentes a las cantidades de $238.392, lote N&#xBA;70; $478.848, lote N&#xBA;74; $110.218, lote N&#xBA;75 y $122.602, lote N&#xBA;76.</div><br></div>", "i": 6288649}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6288650}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2086", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2086"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-29", "doble_articulado": false, "id_norma": "172892", "numero_fuente": "36714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-15", "vigencias": [{"desde": "2000-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-07-15", "fin_vigencia": "", "tip