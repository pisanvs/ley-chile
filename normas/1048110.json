{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9327867}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xBA;3247 de 27 de diciembre de 2012, de conformidad a lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropiaron los lotes de terrenos N&#xB0;s. 94 y 97, superficies 74 y 577 m2, rol de Aval&#xFA;o N&#xBA;178-45, comuna de Calbuco, para la obra &quot;MEJORAMIENTO RUTA V-815, TRAMO: BIF. ILQUE &#x2013; CRUCE RUTA V-85&quot;. La Comisi&#xF3;n de peritos, integrada por NELSON BERNARDO TURRA TURRA, CHRISTIAN EMIL RAUCH Y&#xC1;&#xD1;EZ Y NELSON FABI&#xC1;N IGOR FLORES, fij&#xF3; el valor de tasaci&#xF3;n con fecha 5 de febrero de 2012, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario JUAN CARLOS MANCILLA BUSTAMANTE, en la cantidad de $1.370.409.-, suma que se pagar&#xE1; al contado. </div></div>", "i": 9327868}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9327869}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3247 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-3247 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-12-27", "doble_articulado": false, "id_norma": "1048110", "numero_fuente": "40459", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-01-15", "vigencias": [{"desde": "2013-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [