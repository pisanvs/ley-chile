{"html": [{"t": "<div><div class=\"p\">INFORMA NOMBRAMIENTO DE SECRETARIO GENERAL DEL PARTIDO RENOVACION NACIONAL </div></div>", "i": 6042998}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alberto Espina Otero, Presidente, en representaci&#xF3;n del partido &quot;Renovaci&#xF3;n Nacional&quot;, y Bruno Baranda Ferr&#xE1;n, Secretario del Tribunal Supremo de la colectividad, han informado el nombramiento como Secretario General del Se&#xF1;or Juan Antonio Peribonio Poduje para el per&#xED;odo 1997-1999 en reemplazo de don Rodrigo Ubilla Mackenney.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada en virtud del Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por Resoluci&#xF3;n O-N&#xBA; 0709 de fecha 28 de julio de 1997.-</div><br></div>", "i": 6042999}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director. </div></div>", "i": 6043000}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "709", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-709"}, {"tipo": "3", "numero": "O-0709", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-0709"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "INFORMA NOMBRAMIENTO DE SECRETARIO GENERAL DEL PARTIDO RENOVACION NACIONAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMBRAMIENTO", "JUAN ANTONIO PERIBONIO PODUJE", "PARTIDO RENOVACION NACIONAL", "SECRETARIO GENERAL", "PARTIDOS POLITICOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-28", "doble_articulado": false, "id_norma": "74821", "numero_fuente": "35840", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-08-12", "vigen