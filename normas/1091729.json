{"html": [{"t": "<div><br><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA</div></div>", "i": 9710107}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional de Temuco del SII, por resoluci&#xF3;n ex N&#xB0; 77316058909 de fecha 07/06/2016, deja sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=224983&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n Ex N&#xB0; 161 del 28/04/2004</a>, que otorga la calidad de agente retenedor de cambio de sujeto de derecho del Impuesto al Valor Agregado en las operaciones de contrato de instalaci&#xF3;n o confecci&#xF3;n de especialidades que contraten, a contar de la fecha de esta publicaci&#xF3;n, al contribuyente Constructora e Inmobiliaria Constanzo Limitada, RUT N&#xB0; 78.809.460-4, conforme a lo establecido en la resoluci&#xF3;n Ex. N&#xB0; 142 de fecha 26/12/2005, de la Direcci&#xF3;n Nacional del Servicio, publicada en el Diario Oficial de fecha 29/12/2005.- </div><br></div>", "i": 9710108, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Carlos Fuentes Salvo, Director Regional (S).</div></div>", "i": 9710109}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "77316058909 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-77316058909 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SUBSECRETARÍA DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1035246", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-06-07", "doble_articulado": false, "id_norma": "1091729", "numero_fuente": "41488", "ti