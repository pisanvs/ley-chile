{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 247 EXENTO, DE 1995 </div></div>", "i": 7161342}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 247 de fecha 21 de Abril de 1995 del Ministerio de Educaci&#xF3;n, se modific&#xF3; el Decreto Exento N&#xB0; 551 del 15 de Noviembre de 1994, correspondiente al Instituto Profesional Instituto de Formaci&#xF3;n Empresarial (ex Instituto Profesional EPSON), en el sentido de se&#xF1;alar que la carrera de T&#xE9;cnico de Nivel Superior en Administraci&#xF3;n de Empresas con menci&#xF3;n en inform&#xE1;tica conducente al t&#xED;tulo de T&#xE9;cnico de Nivel Superior en Administraci&#xF3;n de Empresas con menci&#xF3;n en Inform&#xE1;tica, es salida intermedia de la carrera de Ingenier&#xED;a de Ejecuci&#xF3;n en Administraci&#xF3;n de Empresas.</div><br><br></div>", "i": 7161343}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 9 de Mayo de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161344}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "247 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-247 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 247 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "INSTITUTO FORMACION EMPRESARIAL", "CARRERA PROFESIONAL", "TECNICO NIVEL SUPERIOR", "ADMINISTRACION EMPRESAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-04-21", "doble_articulado": false, "id_norma": "20798", "numero_fuente": "35177", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-05-26", "vigencias":