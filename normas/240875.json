{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 66/2005</div><br><br></div>", "i": 6535732}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 66, de 27 de mayo de 2005, se declar&#xF3; desierta la Licitaci&#xF3;n P&#xFA;blica Internacional para la &quot;Adquisici&#xF3;n e Instalaci&#xF3;n de Equipamiento para Pruebas de Emisiones de Veh&#xED;culos Livianos y Medianos&quot;, en el Centro de Control y Certificaci&#xF3;n Vehicular (3CV) de la Subsecretar&#xED;a de Transportes, por haber sido descalificados los proponentes conforme a lo expuesto en la evaluaci&#xF3;n de la propuesta t&#xE9;cnica de las ofertas presentadas, de fecha 16 de mayo de 2005, y en el &quot;Acta de Apertura de las Propuestas Financieras&quot;, de fecha 17 de mayo de 2005, respectivamente, y se orden&#xF3; llamar a propuesta privada y publicar en extracto esta &#xFA;ltima resoluci&#xF3;n una vez totalmente tramitada.-</div><br></div>", "i": 6535733}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jaime Est&#xE9;vez Valencia, Ministro de Transportes y Telecomunicaciones.</div><br></div>", "i": 6535734}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "66", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-66"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 66/2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VEHICULOS MOTORIZADOS", "VEHICULOS LIVIANOS", "VEHICULOS MEDIANOS", "PRUEBAS DE EMISION DE CONTAMINANTES", "EQUIPAMIENTO PARA PRUEBAS", "LICITACION PUBLICA INTERNACIONAL", "CONTAMINACION AMBIENTAL", "DECLARA DESIERTA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fech