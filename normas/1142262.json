{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 678 EXENTA, DE 3 DE FEBRERO DE 2020</div></div>", "i": 10099770}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por la presente, se ha modificado, a contar del a&#xF1;o escolar 2020, la <a href=\"https://www.leychile.cl/Navegar?idNorma=1088478&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 232, de 2016, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, a los establecimientos educacionales declarados de especial singularidad, dependientes de la Corporaci&#xF3;n Educacional de la Sociedad Nacional de Agricultura FG-SNA Educa, en el sentido de sustituir los planes y programas de estudio de 3&#xBA; a&#xF1;o de Educaci&#xF3;n Media.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10099771}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de febrero de 2020.- Le&#xF3;n Paul Castro, Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 10099772}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "678 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-678 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 678 EXENTA, DE 3 DE FEBRERO DE 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1724034", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-02-03", "doble_articulado": false, "id_norma": "1142262", "numero_fuente": "42576", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-02-11", "vigencias": [{"desde": "2