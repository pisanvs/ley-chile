{"html": [{"t": "<div><br><div class=\"p\">DEROGA AUTORIZACI&#xD3;N DE AGENTE RETENEDOR DE IVA A SUPERMERCADOS EL PILAR S.A.</div></div>", "i": 8741800}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La VII Direcci&#xF3;n Regional Talca del S.I.I., por Res/Dre07/Ex. N&#xB0; 3.505, de fecha 30 de junio de 2009, deroga a la contribuyente Supermercados El Pilar S.A., RUT N&#xB0; 96.570.790-5, a contar de la fecha de esta publicaci&#xF3;n, la calidad de agente retenedor del Impuesto al Valor Agregado, en las ventas de ganado, carnes y harina, de acuerdo a lo establecido en las resoluciones Ex. N&#xB0; 3.721, del 28.07.2000; N&#xB0; 3.722, del 28.07.2000, y N&#xB0; 5.282, del 30.11.2000, todas de la Direcci&#xF3;n Nacional.</div></div>", "i": 8741801}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Talca, 30 de junio de 2009.- Luis Aguirre P&#xE9;rez, Director Regional.</div></div>", "i": 8741802}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3505 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolucion-3505 EXENTA"}, {"tipo": "3", "numero": "DRE07/Nº 3505 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolucion-DRE07/Nº 3505 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VII DIRECCIÓN REGIONAL DE TALCA"], "titulo_norma": "DEROGA AUTORIZACIÓN DE AGENTE RETENEDOR DE IVA A SUPERMERCADOS EL PILAR S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-06-30", "doble_articulado": false, "id_norma": "1004198", "numero_fuente": "39411", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-07-14", "vigencias": [{"desde": "2009-