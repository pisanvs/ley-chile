{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 296 EXENTO, DE 1995 </div></div>", "i": 8969064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Supremo exento de Educaci&#xF3;n N&#xB0; 296 de 11 de Mayo de 1995, se ha suprimido en el plan de estudio que aplica el Colegio &quot;Kingston College&quot; de Concepci&#xF3;n, en 7&#xB0; y 8&#xB0; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica, la asignatura de Idioma Extranjero 2, Franc&#xE9;s, a contar del a&#xF1;o escolar 1996.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio de las asignaturas de: Laboratorio de F&#xED;sica y Laboratorio de Qu&#xED;mica, para los cursos de 7&#xB0; y 8&#xB0; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica.</div><br><br></div>", "i": 8969065}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 24 de Mayo de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8969066}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "296 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-296 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 296 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIO", "MODIFICACION", "COLEGIO KINGSTON", "COLLEGE", "CONCEPCION", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-11", "doble_articulado": false, "id_norma": "20927", "numero_fuente": "35185", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-06-05", "vigencias": [{"desde": "1995-06-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-06