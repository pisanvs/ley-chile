{"html": [{"t": "<div><div class=\"p\">MODIFICA COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10248348}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 1.549, de fecha 25.06.2021, del Director Nacional de Aduanas, se modifica el Compendio de Normas Aduaneras, en sus Anexos 51-7 y 51-15, en el sentido de incorporar a la EEER Blue Express S.A. a las tablas de Correo r&#xE1;pido (Couriers) y Almacenistas, respectivamente.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10248349}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de junio de 2021.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><div class=\"p\"> </div><br></div>", "i": 10248350}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1549 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1549 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1971966", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-06-25", "doble_articulado": false, "id_norma": "1162287", "numero_fuente": "42995", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-07-06", "vigencias": [{"desde": "2021-07-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2021-07-06", "fin_vigencia": ""}, "vigenc