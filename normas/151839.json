{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6220928}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 294 del 28 de Julio de 1987, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la I Regi&#xF3;n se autoriza a Luis Alberto S. D&#xED;az Rodr&#xED;guez para efectuar todo tipo de servicio de transportes de pasajeros por calles y caminos, dentro del territorio nacional a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6220929}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Eliecer Aedo Rivera, Secretario Regional Ministerial Transportes y Telecomunicaciones I Regi&#xF3;n Tarapac&#xE1;. </div></div>", "i": 6220930}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "294 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-294 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-28", "doble_articulado": false, "id_norma": "151839", "numero_fuente": "32840", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-07", "vigencias": [{"desde": "1987-08-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-08-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-08-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion