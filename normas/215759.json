{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6443294}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 822 de fecha 31 de julio de 2003, se expropi&#xF3; el lote de terreno N&#xBA; 340, superficie 308,0 m&#xB2;, rol N&#xBA; 559-67, comuna de Linares, VII Regi&#xF3;n, para la obra &quot;Camino Ruta L-45, Sector Linares - Llepo, tramo Km. 2,750 a Km. 13,147&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Luis Arturo Bravo Gonz&#xE1;lez, ascendente a la cantidad de $3.251.357. </div></div>", "i": 6443295}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6443296}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "822", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-822"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-07-31", "doble_articulado": false, "id_norma": "215759", "numero_fuente": "37685", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-10-15", "vigencias": [{"desde": "2003-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-10-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2003-10-15", "fecha_version": "2003-10-15", "fecha_actualizacion_texto": "2003-10-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabez