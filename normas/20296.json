{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 124 EXENTO, DE 1994</div><br><br></div>", "i": 5941545}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 124 de 21 de marzo de 1994 se ha aprobado un plan especial de estudio para la Educaci&#xF3;n B&#xE1;sica y Media Humanistico-Cient&#xED;fica, para el Colegio Ingl&#xE9;s San Patricio de Vi&#xF1;a del Mar, que se aplicar&#xE1; simult&#xE1;neamente en todos los cursos, a partir del a&#xF1;o escolar 1994.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban objetivos generales y espec&#xED;ficos de la actividad se&#xF1;alada en el plan de estudio con el nombre de &quot;Orientaci&#xF3;n Vocacional&quot;. </div></div>", "i": 5941546}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 29 de Marzo de 1994.- Gonzalo Undurraga Mackenna, Subsecaretario de Educaci&#xF3;n.</div><br></div>", "i": 5941547}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "124 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-124 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 124 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "COLEGIO INGLES SAN PATRICIO", "VI A", "MAR", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-21", "doble_articulado": false, "id_norma": "20296", "numero_fuente": "34837", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-04-12", "vigencias": [{"desde": "1994-04-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-04-12", "fin_vigencia": ""}, "vig