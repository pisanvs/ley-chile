{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8813999}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.041, de 7 de diciembre de 2009, de esta Subsecretar&#xED;a, rech&#xE1;zase la solicitud de modificaci&#xF3;n de concesi&#xF3;n de acuicultura N&#xBA; 207031026, presentada por TOM&#xC1;S RODRIGO VILLAVICENCIO PIZARRO, para el centro cultivo ubicado en Punta San Francisco, III Regi&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Dej&#xE1;nse sin efecto las resoluciones <a href=\"https://www.leychile.cl/Navegar?idNorma=84427&amp;idParte=&amp;idVersion=2009-12-12\">N&#xBA; 289 de 1990</a> y N&#xBA; 1.049 de 1994, ambas de esta Subsecretar&#xED;a.</div><br></div>", "i": 8814000, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de diciembre de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 8814001}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4041 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4041 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-12-07", "doble_articulado": false, "id_norma": "1008942", "numero_fuente": "39534", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-12-12", "vigencias": [{"desde": "2009-12-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-12-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-12-12", "fin_