{"html": [{"t": "<div><div class=\"p\">MODIFICA COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 9989532}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 5.528, de 13 de diciembre de 2018, del Director Nacional de Aduanas (S), se modifica el <a href=\"https://www.leychile.cl/Navegar?idNorma=248540&amp;idParte=&amp;idVersion=\">Compendio de Normas Aduaneras</a> en lo siguiente:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Se reemplaza el segundo p&#xE1;rrafo del numeral 15.7 del Cap&#xED;tulo III.</div><div class=\"p\">&nbsp; &nbsp;  La modificaci&#xF3;n entrar&#xE1; en vigencia a contar de la publicaci&#xF3;n en el Diario Oficial del presente extracto.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div></div>", "i": 9989533}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de diciembre de 2018.- Pablo Ib&#xE1;&#xF1;ez Beltrami, Director Nacional de Aduanas (S).</div></div>", "i": 9989534}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5528 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5528 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1528734", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-12-13", "doble_articulado": false, "id_norma": "1127894", "numero_fuente": "42255", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-01-16", "vigencias": [{"de