{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 131, DE 1987 </div></div>", "i": 6214564}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado planes y programas especiales de estudio para Segundo Ciclo de Educaci&#xF3;n Media T&#xE9;cnicoProfesional, a contar del a&#xF1;o escolar 1987 y hasta el a&#xF1;o escolar 1992, inclusive, para el Liceo T&#xE9;cnico Particular Nuestra Se&#xF1;ora del Carmen, Papudo, provincia de Petorca, V Regi&#xF3;n de Valpara&#xED;so.</div><div class=\"p\"> ESPECIALIDADES:</div><div class=\"p\"> - Atenci&#xF3;n de P&#xE1;rvulos con menci&#xF3;n en Nivel Medio.</div><div class=\"p\"> - Atenci&#xF3;n Social Administrativa.</div><div class=\"p\"> - Tejido Industrial.</div><div class=\"p\"> - Vestuario Industrial.</div><br></div>", "i": 6214565}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Junio de 1987.- Ren&#xE9; Salam&#xE9; Mart&#xED;n, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6214566}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "131 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-131 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 131, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-26", "doble_articulado": false, "id_norma": "150015", "numero_fuente": "32807", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-30", "vigencias": [{"desde": "1987-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-30", "fin_vigencia": ""