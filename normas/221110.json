{"html": [{"t": "<div><div class=\"p\">APRUEBA ORDENANZA SOBRE SUBVENCIONES MUNICIPALES </div></div>", "i": 6464061}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Municipalidad de Pinto pone en conocimiento de la comunidad que por Decreto Alcaldicio N&#xBA; 165 de fecha 2 de febrero de 2004, fue aprobada la Ordenanza que norma sobre el procedimiento a observar para el otorgamiento de las subvenciones municipales.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de la citada Ordenanza se informa que est&#xE1; a disposici&#xF3;n de quien lo solicite en la Secretar&#xED;a Municipal, cuya oficina se ubica en calle Ernesto Riquelme N&#xBA; 269, 1&#xBA; piso, de Pinto. </div></div>", "i": 6464062}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Sandra Valentin Merino, Alcaldesa.</div><br></div>", "i": 6464063}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "165", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-165"}], "organismos": ["MUNICIPALIDAD DE PINTO"], "titulo_norma": "APRUEBA ORDENANZA SOBRE SUBVENCIONES MUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-02", "doble_articulado": false, "id_norma": "221110", "numero_fuente": "37784", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-12", "vigencias": [{"desde": "2004-02-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-02-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-02-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2004-02-12", "fecha_versio