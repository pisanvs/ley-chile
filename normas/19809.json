{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 33 EXENTO, DE 1994 </div></div>", "i": 5939982}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto exento N&#xB0; 33, de fecha 27 de Enero de 1994, del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a la sede N&#xB0; 18 de Temuco del Centro de Formaci&#xF3;n T&#xE9;cnica INACAP, para impartir el plan y programa de estudio aprobado, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se se&#xF1;ala, a contar del a&#xF1;o 1994:</div><div class=\"p\">Carrera: Secretariado Ejecutivo Computacional</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; (Decreto Exento N&#xB0; 311 de 1991)</div><div class=\"p\"> T&#xED;tulo : Secretario (a) Ejecutivo (a) Computacional.</div><br></div>", "i": 5939983}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 08 de Abril de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5939984}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "33 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-33 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 33 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA", "TEMUCO", "NOVENA REGION", "SECRETARIADO EJECUTIVO COMPUTACIONAL", "INACAP", "INSTITUTO", "NACIONAL CAPACITACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-01-27", "doble_articulado": false, "id_norma": "19809", "numero_fuente": "34848", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-04-25", "vigencias": [{"desde": "1994-04-25", "hasta": "", "tipo_version": "3", "tipo_versio