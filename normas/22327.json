{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Exencion de Derechos de Importacion de ciertos Art&#xED;culos</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 990.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948100}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Decl&#xE1;rase exentos de derechos de importacion, hasta el a&#xF1;o 1920, los hilados de algodon i las maquinarias que las f&#xE1;bricas de tejidos de algodon internen al pais para el servicio i uso de esa industria.</div><br><br></div>", "i": 5948101}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno que se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 3 de Enero de 1898.- FEDERICO ERRAZURIZ.- Alberto Gonz&#xE1;lez E.</div><br></div>", "i": 5948102}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "990", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-990"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "EXENCION DE DERECHOS DE IMPORTACION DE CIERTOS ARTICULOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ALGODON", "DERECHOS IMPORTACION", "EXENCION", "INDUSTRIA", "MAQUINARIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-01-03", "doble_articulado": false, "id_norma": "22327", "numero_fuente": "5894", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-01-04", "vigencias": [{"desde": "1898-01-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-01-0