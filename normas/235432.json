{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A COMERCIAL SAN VALENTIN S.A.</div><br></div>", "i": 6515726}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional Santiago Poniente del SII, por resoluci&#xF3;n exenta N&#xBA;82 de 25 de enero de 2005, revoca la calidad de Agente Retenedor en las operaciones de Ventas de Harina, autorizada mediante resoluci&#xF3;n N&#xBA; 5.282 de 30/11/2000, a don Valent&#xED;n Cantergiani Cassanelli N&#xBA; 3.442.028-9, en representaci&#xF3;n de Comercial San Valent&#xED;n S.A., RUT N&#xBA; 96.523.990-1, la que entrar&#xE1; en vigencia a partir del d&#xED;a 1&#xBA; del mes siguiente al de dicha publicaci&#xF3;n en el Diario Oficial, por cuenta y costo del peticionario.</div><br></div>", "i": 6515727}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jorge A. de Calisto Bravo, Director Regional. </div></div>", "i": 6515728}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "82 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-82 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO PONIENTE"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A COMERCIAL\nSAN VALENTIN S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-01-25", "doble_articulado": false, "id_norma": "235432", "numero_fuente": "38084", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-02-11", "vigencias": [{"desde": "2005-02-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-02-11", "fin_vige