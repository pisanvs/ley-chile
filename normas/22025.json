{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; POLICIA URBANA DE SEGURIDAD DE SANTIAGO Lei n&#xFA;m. 164.- Santiago, a 19 de Enero de 1894.-Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273792}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese para el presente a&#xF1;o un ausilio de trescientos mil pesos a la Municipalidad de Santiago para elevar a mil quinientos hombres la dotacion de la polic&#xED;a urbana de seguridad.</div><br><br></div>", "i": 8273793}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORGE MONTT.-Pedro Montt.</div><br></div>", "i": 8273794}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "164", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-164"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "POLICIA URBANA DE SEGURIDAD DE SANTIAGO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDAD", "SANTIAGO", "POLICIA URBANA SEGURIDAD", "DOTACION", "FONDOS", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-01-19", "doble_articulado": false, "id_norma": "22025", "numero_fuente": "4721", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-01-19", "vigencias": [{"desde": "1894-01-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-01-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-01-19", "fin_vigencia": "", "tipo_version": "3"}],