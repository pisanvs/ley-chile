{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6153684}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1 del Compendio de Normas Financieras, certifica que la Tasa de Inter&#x201A;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables de 90 a 365 d&#xED;as, correspondiente a la primera quincena de octubre de 1988, fue de 5.13 % anual. </div></div>", "i": 6153685}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de octubre de 1988.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6153686}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE HACIENDA", "BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-10-20", "doble_articulado": false, "id_norma": "131559", "numero_fuente": "33201", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-10-21", "vigencias": [{"desde": "1988-10-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-10-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-10-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAS", "fecha_ingreso": "1999-02-09", "fecha_version": "1988-10-21", "fecha_actualizacion_texto": "1988-10-21", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabez