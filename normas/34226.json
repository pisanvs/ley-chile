{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 298.- Santiago, 5 de diciembre de 1996.- Vistos: Lo dispuesto en el Art. 11 del Decreto Ley N&#xB0; 2.974 de 1979.</div><div class=\"p\">&nbsp; &nbsp; R e s u e l v o:</div><br></div>", "i": 6009055}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del Decreto Ley N&#xB0; 2.974, en la VIII Regi&#xF3;n, al se&#xF1;or Rigoberto P&#xE9;rez Lara.</div><br></div>", "i": 6009056}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Liliana Barr&#xED;a Iroume, Directora Nacional (S).</div><br></div>", "i": 6009057}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "298", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-298"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMBRAMIENTO", "RECEPTOR JUDICIAL", "JUZGADOS DE POLICIA LOCAL", "OCTAVA REGION", "RIGOBERTO PEREZ LARA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-12-05", "doble_articulado": false, "id_norma": "34226", "numero_fuente": "35651", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-12-27", "vigencias": [{"desde": "1996-12-27", "hasta": "", "tipo_version": "3", "tipo_ve