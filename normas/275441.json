{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7376757}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.852, de 18 de julio de 2008, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3.- de la resoluci&#xF3;n exenta N&#xBA; 1.447 de 2008 de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a la SOCIEDAD DE DESARROLLO DE LA PESCA ARTESANAL S.A., para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;An&#xE1;lisis de recursos pel&#xE1;gicos y de la flota artesanal de cerco que opera en la Regi&#xF3;n del B&#xED;o-B&#xED;o&quot;, en el sentido de extender el per&#xED;odo de ejecuci&#xF3;n de la pesca de investigaci&#xF3;n hasta el 9 de diciembre de 2008. </div></div>", "i": 7376758}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de julio de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7376759}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1852 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1852 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-07-18", "doble_articulado": false, "id_norma": "275441", "numero_fuente": "39132", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-08-07", "vigencias": [{"desde": "2008-08-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-08-07", "fin_vigencia": ""}