{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 6, DE 1989 </div></div>", "i": 6114467}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 6 de 13 de enero de 1989 se ha aprobado al Centro de Capacitaci&#xF3;n Laboral de Concepci&#xF3;n, VIII Regi&#xF3;n del B&#xED;o B&#xED;o, un plan de estudio especial de orientaci&#xF3;n laboral para alumnos con deficiencia mental, que se desarrollar&#xE1; por un per&#xED;odo de 4 a&#xF1;os, a contar desde el a&#xF1;o escolar 1989.</div><div class=\"p\">Adem&#xE1;s, se aprueban programas de estudio correspondientes al plan que aprueba el presente decreto.-</div><br></div>", "i": 6114468}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Adelchi Colombo Breschi, Subsecretario de Educaci&#xF3;n P&#xFA;blica Subrogante.</div><br></div>", "i": 6114469}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "6 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-6 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 6, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-01-13", "doble_articulado": false, "id_norma": "100976", "numero_fuente": "33308", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-02-25", "vigencias": [{"desde": "1989-02-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-02-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-02-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingre