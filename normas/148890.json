{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6210190}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 3.026, del 30 de septiembre de 1999, se expropiaron los lotes de terreno N&#xBA;s 107 y 107-A, superficies 31.115 y 6.090 M2, respectivamente, rol de aval&#xFA;o 155-1, comuna de Pemuco, para la obra Proyecto Laja Diguill&#xED;n, Faja de expropiaci&#xF3;n Canal Matr&#xED;z, sector Pemuco-Diguill&#xED;n y se acord&#xF3; precio de la indemnizaci&#xF3;n con sus propietarios In&#xE9;s Elvira Sep&#xFA;lveda Cabezas y Otros, ascendente a la cantidad de</div><div class=\"p\">$9.673.343.- para los lotes N&#xBA;s 107 y 107-A. </div></div>", "i": 6210191}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6210192}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3026", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3026"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-09-30", "doble_articulado": false, "id_norma": "148890", "numero_fuente": "36528", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-12-01", "vigencias": [{"desde": "1999-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1999-12-06", "fecha_version": "1999-12-01", "fecha