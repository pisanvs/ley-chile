{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 2.843 EXENTA, DE 2014</div></div>", "i": 9485542}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.843, de 5 de junio de 2014, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Sociedad V y K Capacitaci&#xF3;n Limitada (Visi&#xF3;n Futuro Capacitaci&#xF3;n Limitada)&quot;, RUT 76.135.345-4 contenida en la resoluci&#xF3;n exenta N&#xBA; 5.097 de fecha 13 de junio de 2011, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.</div></div>", "i": 9485543}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Marcia Pardo Gonz&#xE1;lez, Jefe del Departamento de Evaluaci&#xF3;n y Organismos (PT).</div></div>", "i": 9485544}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2843 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2843 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-06-05", "doble_articulado": false, "id_norma": "1063968", "numero_fuente": "40899", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-07-04", "vigencias": [{"desde": "2014-07-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-07-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014-07-04", "fin_vigencia": "", "tipo_version": "3"}],