{"html": [{"t": "<div><div class=\"p\">CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A VI&#xD1;A SAN RAFAEL S.A.</div><br></div>", "i": 6424914}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VII Direcci&#xF3;n Regional Talca del S.I.I., por resoluci&#xF3;n DRE07/exenta N&#xBA;423 de fecha 15 de mayo de 2003, concede&nbsp; a la contribuyente Vi&#xF1;a San Rafael S.A. RUT N&#xBA;96.822.190-6, a contar del d&#xED;a primero del mes siguiente, de la fecha de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de Sujeto en las adquisiciones de Ganado Vivo, de acuerdo a la facultad establecida en el dispositivo N&#xBA;16&#xBA; de la resoluci&#xF3;n Ex. N&#xBA;3.721/2000, de la Direcci&#xF3;n Nacional.</div><br></div>", "i": 6424915}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Talca, 15 de mayo de 2003.- Mirtha Barra Paredes, Directora Regional.</div><br></div>", "i": 6424916}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "423 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-423 EXENTA"}, {"tipo": "3", "numero": "DRE-07-423 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-07-423 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VII DIRECCIÓN REGIONAL DE TALCA"], "titulo_norma": "CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A VIÑA SAN RAFAEL S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-05-15", "doble_articulado": false, "id_norma": "210670", "numero_fuente": "37569", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-05-28", "vigencias": [{"desde": "2003-05-2