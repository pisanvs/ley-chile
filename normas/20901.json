{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8969061}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto exento N&#xB0; 289 de fecha 11 de Junio de 1993 del Ministerio de Educaci&#xF3;n, se sustituy&#xF3; el inciso 1&#xB0; del art&#xED;culo 1&#xB0; del decreto exento N&#xB0; 94 de 05.03.90 correspondiente al Instituto Profesional Juan Bohon, por el siguiente nuevo:</div><div class=\"p\">&nbsp; &nbsp; &quot;Autor&#xED;zase el funcionamiento del Instituto Profesional que se indica, organizado por la persona jur&#xED;dica que se se&#xF1;ala:</div><div class=\"p\"> Nombre de la Instituci&#xF3;n : Instituto Profesional</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Juan Bohon</div><div class=\"p\"> Domicilio&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : La Serena</div><br><div class=\"p\"> Organizador&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Sociedad Educacional Vargas</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; y Compa&#xF1;&#xED;a Limitada.&quot;</div><br></div>", "i": 8969062}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n. + </div></div>", "i": 8969063}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "289 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-289 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXTRACTO DE DECRETO EXENTO N 289", "DE 1993 INSTITUTO PROFESIONAL JUAN BOHON", "SERENA", "CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado