{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6458555}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.367, de 16 de diciembre de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a JUAN DOMINGO RIVERA ITURRA, para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Estero Quell&#xF3;n s/n, Quell&#xF3;n, X Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Cocido, Fresco-Enfriado, Fresco-Refrigerado, Congelado y Conserva, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2.381 de 2003, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6458556}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de diciembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6458557}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3367 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3367 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-16", "doble_articulado": false, "id_norma": "220016", "numero_fuente": "37757", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-01-12", "vigencias": [{"desde": "2004-01-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"