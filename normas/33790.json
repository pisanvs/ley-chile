{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291133}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 214, de 5 de febrero de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, cad&#xFA;case la Resoluci&#xF3;n N&#xB0; 1305, de 1988, de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a RODRIGO ANTONIO JESUS MANDIOLA MORENO, para operar dos centros de cultivo ubicados en Hueld&#xE9;n, Comuna de Ancud, Provincia de Chilo&#xE9;, X Regi&#xF3;n, conforme lo dispuesto en el art&#xED;culo 7&#xB0; del D.S. N&#xB0; 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; D&#xE9;jase sin efecto las Resoluciones N&#xB0; 705 y N&#xB0; 712, de 1995, ambas de esta Subsecretar&#xED;a, en virtud de lo dispuesto precedentemente.</div><br></div>", "i": 8291134}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 5 de febrero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8291135}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "214", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-214"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RODRIGO MANDIOLA MORENO", "ANCUD", "DECIMA REGION", "CADUCIDAD", "CENTROS CULTIVOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-02-05", "doble_articulado": false, "id_norma": "33790", "numero_fuente": "35390", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-02-12", "vigencias": [{"desde": "1996-02-12", "hasta"