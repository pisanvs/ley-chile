{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 14, DE 1990 </div></div>", "i": 6069114}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 14, de 16 de enero de 1990, se ha aprobado, a contar del a&#xF1;o escolar 1990, al Liceo A No. 119 de la Corporaci&#xF3;n Municipal de Educaci&#xF3;n de Talagante, un plan de estudio especial de Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica de Adultos, que se desarrollar&#xE1; en dos a&#xF1;os lectivos, equivalentes al primer y segundo ciclo de Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica, respectivamente.</div><br></div>", "i": 6069115}, {"t": "<div><div class=\"p\">Santiago, 23 de Enero de 1990.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6069116}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "14 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-14 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 14, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-16", "doble_articulado": false, "id_norma": "84910", "numero_fuente": "33600", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-19", "vigencias": [{"desde": "1990-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "i