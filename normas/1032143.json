{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO ALCALDICIO N&#xB0; 1.701, DE 2011</div></div>", "i": 9202043}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto alcaldicio N&#xBA; 1.701 (19.10.2011), la I. Municipalidad de Macul otorg&#xF3; un plazo de 10 d&#xED;as corridos, al Sr. Jorge Zapata Fuenzalida, para hacer retiro de su Kiosco ubicado en calle Peatonal 36, frente al N&#xBA; 1739, por infringir la Ordenanza sobre Actividad Comercial, Industrial y Servicios, facultando a la Direcci&#xF3;n de Aseo y Ornato para su retiro, si no se diere cumplimiento.</div></div>", "i": 9202044}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1701", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1701"}], "organismos": ["MUNICIPALIDAD DE MACUL"], "titulo_norma": "EXTRACTO DE DECRETO ALCALDICIO N° 1.701, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-10-19", "doble_articulado": false, "id_norma": "1032143", "numero_fuente": "40106", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-11-10", "vigencias": [{"desde": "2011-11-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-11-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-11-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "20652", "fecha_ingreso": "2011-11-10", "fecha_version": "2011-11-10", "fecha_actualizacion_texto": "2011-11-10", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 92020