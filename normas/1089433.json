{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACIONES</div></div>", "i": 9696301}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Res. Ex. N&#xBA; 162 de 29/02/16. Exp. N&#xBA;1501822. Vistos: Ley N&#xB0;18.755; Ley N&#xBA;18.575, resoluci&#xF3;n N&#xBA;1.600/2008 de la CGR. Considerando: 1.- ADC N&#xB0;97081, que se&#xF1;ala que la infractora porta en su equipaje 0,88 kgs, de Tamarindo, dichos productos no fueron declarados. 2.- La infractora pidi&#xF3; a otra persona que llenara la declaraci&#xF3;n, ya que no puede leer ni escribir. 3.- La infractora no registra denuncias anteriores. Resuelvo: Absu&#xE9;lvase por esta &#xFA;nica vez a do&#xF1;a Mirtha Butr&#xF3;n Bonilla, documento de identificaci&#xF3;n N&#xB0; 5833893, nacionalidad boliviana, domicilio indeterminado. </div></div>", "i": 9696302}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Firma: C&#xE9;sar Cardozo Rojas, Director Regional Regi&#xF3;n de Tarapac&#xE1; SAG.</div></div>", "i": 9696303}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "162 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-162 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO REGIÓN DE TARAPACÁ"], "titulo_norma": "NOTIFICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1012765; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-02-29", "doble_articulado": false, "id_norma": "1089433", "numero_fuente": "41433", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-04-15", "vigencias": [{"desde": "2016-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2016-04-15", "fin_vigencia": "