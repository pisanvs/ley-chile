{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 2.258 EXENTO, DE 2005 </div></div>", "i": 6563794}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 2.258, de 30 de diciembre de 2005, se han modificado los decretos exentos de Educaci&#xF3;n N&#xBA;s. 416, de 2002 y 295, de 2003, que aprobaron planes y programas de estudio biling&#xFC;e para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica a la Escuela &quot;San Antonio de Padua&quot;, comuna de Ollag&#xFC;e, Regi&#xF3;n de Antofagasta.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores de Lenguaje y Comunicaci&#xF3;n y Matem&#xE1;tica para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica.</div><br></div>", "i": 6563795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de marzo de 2006.- Pedro Montt Leiva, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6563796}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2258 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2258 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 2.258 EXENTO, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-30", "doble_articulado": false, "id_norma": "247954", "numero_fuente": "38413", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-14", "vigencias": [{"desde": "2006-03-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-03-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006