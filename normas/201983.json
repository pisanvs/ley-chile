{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;678 EXENTO DE 2002 </div></div>", "i": 7293839}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;678 de fecha 26 de julio de 2002 del Ministerio de Educaci&#xF3;n, se aprueban las adecuaciones al plan y programas de estudios de la carrera de Programaci&#xF3;n en Computaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Intec, que se encuentran anexas y forman parte del presente decreto. Modif&#xED;case, en consecuencia, la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;744 del 12 de abril de 1983, en el sentido de incorporar las actuales adecuaciones.</div><div class=\"p\">&nbsp; &nbsp;  Las adecuaciones que se aprueban mediante este decreto, podr&#xE1;n aplicarse a contar del a&#xF1;o 2002. </div></div>", "i": 7293840}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de agosto de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7293841}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "678 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-678 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº678 EXENTO DE 2002", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-07-26", "fecha_derogacion": "2012-12-31", "doble_articulado": false, "id_norma": "201983", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-08-28", "vigencias": [{"desde": "2012-12-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2002-08-28", "hasta": "2012-12-30", "tipo_version": "0", "tipo_version_s": "Text