{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6134041}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 1228 de 27 de septiembre de 1988, del Ministerio de Transportes y Telecomunicaciones Subsecretar&#xED;a de Transportes se autoriza a la Sociedad Gonz&#xE1;lez y Compa&#xF1;&#xED;a Limitada (Transporte Aconcagua Santiago T.A.S. Choapa Limitada o T.A.S. Choapa Limitada), para efectuar servicio de transporte terrestre de pasajeros entre Osorno y Punta Arenas, en tr&#xE1;nsito por territorio argentino, por el Portezuelo de Pu yehue y Paso Monte Aymond, el que se atender&#xE1; con tres frecuencias semanales (1 diaria) las que se efectuar&#xE1;n en los siguientes d&#xED;as:</div><div class=\"p\">Osorno- Punta Arenas: mi&#xE9;rcoles - viernes - domingo Punta Arenas - Osorno: martes - viernes - domingo. </div></div>", "i": 6134042}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Manuel G&#xE1;rate Meneses, Coronel Subsecretario de Transportes.</div><br></div>", "i": 6134043}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1228 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1228 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-09-27", "doble_articulado": false, "id_norma": "125552", "numero_fuente": "33197", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-10-17", "vigencias": [{"desde": "1988-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenc