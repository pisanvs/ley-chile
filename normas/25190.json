{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; TRASPASA LA SUMA DE $ 60,000 DE UN ITEM A OTRO Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7170723}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.o Trasp&#xE1;sase la suma de $ 60,000 del &#xED;tem 12|06|11-a)25 del Presupuesto del Ministerio de Fomento, al &#xED;tem 06|05|04L)1, del Presupuesto del Ministerio de Hacienda.</div><br></div>", "i": 7170724, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2.o Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 7170725}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y, por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veinte de Diciembre de mil novecientos treinta y cinco.- ARTURO ALESSANDRI.- Mat&#xED;as Silva S.- Gustavo Ross.</div><br></div>", "i": 7170726}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "5768", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-5768"}], "organismos": ["MINISTERIO DE FOMENTO"], "titulo_norma": "TRASPASA LA SUMA DE $ 60,000 DE UN ITEM A OTRO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1935", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1935-12-20", "doble_articulado": false, "id_norma": "25190", "numero_fuente": "17348", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1935-12-21", "vigencias": [{"desde": "1935-12-21", "hasta": "", "tipo_versio