{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6423538}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 909, de 30 de abril de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a ANTARFOOD S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluciones citadas precedentemente, en orden a incorporar a la planta ubicada en Camino a Huicha S/N&#xBA;, Chonchi, Chilo&#xE9;, X Regi&#xF3;n, en la l&#xED;nea de elaboraci&#xF3;n que se indica, los siguientes recursos hidrobiol&#xF3;gicos: Congelado: Camar&#xF3;n ecuatoriano, Camar&#xF3;n nailon, Langostino amarillo, Langostino colorado, Camar&#xF3;n de r&#xED;o y Camar&#xF3;n tigre.</div><br></div>", "i": 6423539}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de abril de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6423540}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "909", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-909"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-04-30", "doble_articulado": false, "id_norma": "210186", "numero_fuente": "37557", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-05-13", "vigencias": [{"desde": "2003-05-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-05-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-05-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente