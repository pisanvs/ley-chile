{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7215184}, {"t": "<div><br><div class=\"p\">Por Resoluci&#xF3;n No. 900 Octubre 31 de 1991, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriza a la empresa chilena Transportes G&#xE9;minis Limitada (G&#xE9;minis Limitada), para efectuar una (1) frecuencia semanal adicional a las otorgadas por Resoluci&#xF3;n No. 77 de 28 de Enero de 1985, en la realizaci&#xF3;n del servicio Antofagasta (Chile) y Salta (Argentina), durante el per&#xED;odo comprendido entre el 15.11 y el 15.03 de cada a&#xF1;o.-</div><br></div>", "i": 7215185}, {"t": "<div><br><div class=\"p\">Sergio Gonz&#xE1;lez Tagle, Subsecretario de Transportes.</div><br></div>", "i": 7215186}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "900", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-900"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-10-31", "doble_articulado": false, "id_norma": "80333", "numero_fuente": "34118", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-16", "vigencias": [{"desde": "1991-11-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-11-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-11-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "ALV", "fecha_ingreso": "1997-12-19