{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede derecho a jubilar al Ministro de la Corte Suprema don Luis Barriga</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,950.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5954516}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Conc&#xE9;dese, por gracia, al Ministro de la Corte Suprema, don Luis Barriga, derecho de jubilar con una pension igual al sueldo &#xED;ntegro asignado a su empleo.</div><br></div>", "i": 5954517}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 18 de Noviembre de 1914.- RAMON BARROS LUCO.- Absalon Valencia.</div><br></div>", "i": 5954518}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2950", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2950"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDE DERECHO A JUBILAR AL MINISTRO DE LA CORTE SUPREMA DON LUIS BARRIGA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LUIS BARRIGA", "CORTE SUPREMA", "MINISTRO", "JUBILACION", "POR GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1914-11-18", "doble_articulado": false, "id_norma": "23620", "numero_fuente": "11025", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1914-11-20", "vigencias": [{"desde": "1914-11-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia"