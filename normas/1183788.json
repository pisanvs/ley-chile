{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10377059}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de circular del Servicio de Impuestos Internos N&#xB0; 50, del 27 de octubre de 2022, que &quot;Imparte instrucciones sobre las modificaciones introducidas por los n&#xFA;meros 1 y 2 del <a href=\"https://www.leychile.cl/Navegar?idNorma=1172303&amp;idParte=10307435&amp;idVersion=\">art&#xED;culo 6</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1172303&amp;idParte=&amp;idVersion=\">Ley N&#xB0; 21.420</a>, a los art&#xED;culos <a href=\"https://www.leychile.cl/Navegar?idNorma=6369&amp;idParte=8675259&amp;idVersion=\">2&#xB0;</a> N&#xB0; 2&#xB0;) y <a href=\"https://www.leychile.cl/Navegar?idNorma=6369&amp;idParte=8675397&amp;idVersion=\">12</a> letra E de la <a href=\"https://www.leychile.cl/Navegar?idNorma=6369&amp;idParte=&amp;idVersion=\">Ley sobre Impuesto a las Ventas y Servicios</a>.&quot;.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta circular est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl).- </div><br></div>", "i": 10377060}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Hern&#xE1;n Frigolett C&#xF3;rdova, Director.</div><div class=\"p\"> </div><br></div>", "i": 10377061}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "50", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-50"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2210824", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-10-27", "doble_articulado": false,