{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6260526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 349, de 23 de Agosto de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Jos&#xE9; Gonz&#xE1;lez Jim&#xE9;nez, Jos&#xE9; Aguinaga Sandoval, Jos&#xE9; Barrientos. C&#xE1;rdenas, Patricio Leichtle Werner, Belarmino Ch&#xE1;vez Hern&#xE1;ndez, Arnoldo Vera Vera, Mario Gonz&#xE1;lez Ampuero y Hugo Chaura C&#xE1;rdenas para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea N&#xB0; 1 &quot;Bellavista-Techo para Todos&quot; de Puerto Montt, cuyo trazado fue autorizado por resoluci&#xF3;n N&#xB0; 082 de 07 de Junio de 1984, de esta Secretar&#xED;a Regional. </div></div>", "i": 6260527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Luis Boldt Quezada, Secretario Regional Ministerial, Transportes y Telecomunicaciones, X Regi&#xF3;n. </div></div>", "i": 6260528}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "349 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-349 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-08-23", "doble_articulado": false, "id_norma": "164103", "numero_fuente": "32262", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-08-31", "vigencias": [{"desde": "1985-08-31", "hasta": "", "tipo_version": "3", "tipo_v