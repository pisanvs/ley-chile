{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.791 EXENTO, DE 2005 </div></div>", "i": 6559902}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.791 de fecha 25 de noviembre de 2005 del Ministerio de Educaci&#xF3;n, se deja sin efecto la aprobaci&#xF3;n del plan y programas de estudio de la carrera de Programaci&#xF3;n Computacional y An&#xE1;lisis Microgr&#xE1;fico, aprobada para el Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Superior Aspro, mediante resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 1.406 del 11 de mayo de 1989, a petici&#xF3;n de la propia entidad, por no estar imparti&#xE9;ndose desde el a&#xF1;o 1993.</div><br></div>", "i": 6559903}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de Diciembre de 2005.- Pedro Montt Leiva, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6559904}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1791 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1791 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.791 EXENTO, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-25", "doble_articulado": false, "id_norma": "246968", "numero_fuente": "38379", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-02-02", "vigencias": [{"desde": "2006-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-02-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-02-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion