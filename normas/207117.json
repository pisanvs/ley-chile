{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 14.124 EXENTA, DE 2002 </div></div>", "i": 7297113}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 14.124 de 27 de noviembre del a&#xF1;o 2002, se ha aprobado al Colegio The Mayflower School, comuna de Las Condes, de Santiago, un plan de estudio para 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, que se aplicar&#xE1; a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en la presente resoluci&#xF3;n para 3&#xBA; y 4&#xBA; a&#xF1;o medio.</div><br></div>", "i": 7297114}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de enero de 2003.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 7297115}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "14124 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-14124 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 14.124 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-11-27", "doble_articulado": false, "id_norma": "207117", "numero_fuente": "37471", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-01-29", "vigencias": [{"desde": "2003-01-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-01-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-01-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vin