{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6424325}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 493, de 2 de Mayo de 1995, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por JUAN ANDRES</div><div class=\"p\">HIDALGO ALVAREZ, para un sector ubicado en Islote</div><div class=\"p\">Quemado, Comuna y Provincia de Ays&#xE9;n, XI Regi&#xF3;n, por no</div><div class=\"p\">dar cumplimiento el respectivo proyecto t&#xE9;cnico al</div><div class=\"p\">art&#xED;culo 87&#xBA; de la Ley General de Pesca y Acuicultura. </div></div>", "i": 6424326}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de Mayo de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 6424327}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "493", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-493"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-02", "doble_articulado": false, "id_norma": "210484", "numero_fuente": "35165", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-05-12", "vigencias": [{"desde": "1995-05-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-05-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-05-12", "fin_vigencia": "",