{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6390680}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;943 de fecha 31 de mayo de 2002, se expropi&#xF3; el lote de terreno N&#xBA;8-B, superficie 2.748 m&#xB2;, rol de aval&#xFA;o N&#xBA;225-94, comuna de Olmu&#xE9;, para la obra &apos;&apos;Ruta F-10-G, Cuesta La Dormida, Etapa 2, Km. 10,984 al Km.</div><div class=\"p\">34,500, comuna de Olmu&#xE9;, Provincia de Quillota&apos;&apos;, V Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Cecilia Eugenia Tapia Lizana, ascendente a la cantidad de $8.374.807.-</div><br></div>", "i": 6390681}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6390682}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "943", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-943"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-31", "doble_articulado": false, "id_norma": "200966", "numero_fuente": "37323", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-08-01", "vigencias": [{"desde": "2002-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PSO", "fecha_ingreso": "2002-08-01", "fecha_version": "2002-08-01", "fecha_actualizacion_texto": "2002-08-01", "t