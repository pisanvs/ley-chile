{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N EXENTA QUE INDICA</div></div>", "i": 9837744}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xB0; 3.058, de 15 de Sept. de 2017, Serviu Regi&#xF3;n del Libertador Gral. Bernardo O&apos;Higgins, orden&#xF3; la rectificaci&#xF3;n de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1105246&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.016</a>, de fecha 28 de junio de 2017, en este sentido: Rectif&#xED;quese la resoluci&#xF3;n exenta N&#xBA; 2.016, de fecha 28 de junio de 2017, en el sentido de modificar la superficie a expropiar y el monto de la indemnizaci&#xF3;n provisoria por la expropiaci&#xF3;n parcial del inmueble ubicado en Avenida Err&#xE1;zuriz S/N, comuna de Santa Cruz, Rol de aval&#xFA;o es 526-03 de la comuna ya indicada, de aparente dominio de la Sucesi&#xF3;n de Antonio Oyarz&#xFA;n Lorca, quedando de la siguiente manera:</div><br><div class=\"p\"> <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/70697.jpg\"></div></div>", "i": 9837745}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n del Libertador Gral. Bernardo O&apos;Higgins.</div></div>", "i": 9837746}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3058 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3058 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O'HIGGINS"], "titulo_norma": "RECTIFICA RESOLUCIÓN EXENTA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1277245", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2