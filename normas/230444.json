{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7314725}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.615, de 10 de septiembre de 2004, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las resoluciones N&#xBA; 765 de 1985, N&#xBA; 896 de 1986, N&#xBA; 729 de 1988, N&#xBA; 1.710 de 1999 y N&#xBA; 2.884 de 2002, todas de esta Subsecretar&#xED;a, que autorizaron a SOCIEDAD PESCA MARINA LIMITADA para realizar actividades pesqueras extractivas con la nave &quot;Polux&quot;, en virtud de lo dispuesto en el art&#xED;culo 143 letra d) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7314726}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de septiembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7314727}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2615 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2615 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-09-10", "fecha_derogacion": "2005-03-04", "doble_articulado": false, "id_norma": "230444", "numero_fuente": "37965", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-09-20", "vigencias": [{"desde": "2005-03-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-11-09", "hasta": "2005-03-03", "tipo_version": "1", "tipo_version_s": "Intermedio"}, {"desde": "2004-09-20", "hasta": "2004-11-08", "tipo_version": "0", "tipo_version_s"