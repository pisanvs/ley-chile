{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6255350}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 38, de 21 de agosto de 1985 de la Secreter&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se autoriza a Empresa de Pullman Chile S.A., para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del territorio Nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos Urbanos de Locomoci&#xF3;n Colectiva de pasajeros.</div><br></div>", "i": 6255351}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Rigoberto G&#xF3;mez Lav&#xED;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones, VI Regi&#xF3;n.</div><br></div>", "i": 6255352}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "38 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-38 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-08-21", "doble_articulado": false, "id_norma": "162439", "numero_fuente": "32282", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-09-27", "vigencias": [{"desde": "1985-09-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-09-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-09-27", "fin_vigencia": "", "tipo_version": "3"}], "e