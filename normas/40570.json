{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA RESOLUCION N&#xB0; 5.077 EXENTA, de 1992 </div></div>", "i": 7203028}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Mediante Resoluci&#xF3;n Ex. N&#xB0; 15709, de 7 de Septiembre de 1992, el Director Regional de la V Direcci&#xF3;n Regional Valpara&#xED;so, modific&#xF3; la Resoluci&#xF3;n N&#xB0; Ex 5077 de 26 de Marzo de 1992, sobre Delegaci&#xF3;n de Facultades, en la forma siguiente:</div><div class=\"p\">&nbsp; &nbsp; 1) Interc&#xE1;lese en la parte resolutiva N&#xB0; 1 letra a), entre los guarismos &quot;10&quot; y &quot;17&quot;, el n&#xFA;mero &quot;16&quot; seguido de una coma.</div><div class=\"p\">&nbsp; &nbsp; 2) Agr&#xE9;gase a continuaci&#xF3;n de la parte resolutiva N&#xB0; 1 letra a) el siguiente inciso: &quot;Respecto de las infracciones contempladas en el art&#xED;culo 97 N&#xB0; 16, la presente delegaci&#xF3;n no abarca los casos que el Director Regional califique de graves&quot;.</div><br><br></div>", "i": 7203029}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Luis Contreras Villegas, Director Regional. </div></div>", "i": 7203030}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "15709 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-15709 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA RESOLUCION N° 5.077 EXENTA, de 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "DELEGACION", "FACULTAD", "FUNCIONARIOS", "SERVICIO IMPUESTOS INTERNOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-09-07", "doble_articulado": false, "id_norma": "40570", "numero_fuente": "34443", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacio