{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA </div></div>", "i": 6383593}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n ministerial N&#xBA; 47, de fecha 10 de</div><div class=\"p\">mayo de 2002, del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n, se cancel&#xF3; la personalidad jur&#xED;dica</div><div class=\"p\">de la &quot;Asociaci&#xF3;n de Peque&#xF1;os y Medianos Empresarios</div><div class=\"p\">de Alto Acha A.G.&quot; o &quot;Apemach A.G.&quot;, inscrita bajo el</div><div class=\"p\">N&#xBA; 271-1 del Registro que para tal efecto lleva esta</div><div class=\"p\">Secretar&#xED;a de Estado, por haberse configurado respecto</div><div class=\"p\">de ella, la causal de cancelaci&#xF3;n establecida en el</div><div class=\"p\">art&#xED;culo 18 N&#xBA; 2, letra a) del decreto ley N&#xBA; 2.757, de 1979.-</div><br></div>", "i": 6383594}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Enrique Sep&#xFA;lveda Rodr&#xED;guez, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n (S).</div><br></div>", "i": 6383595}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "47", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-47"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-10", "doble_articulado": false, "id_norma": "198725", "numero_fuente": "37272", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "20