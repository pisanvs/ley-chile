{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6743145}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. N&#xBA; 633, de 30 de Octubre de 1995, se expropiaron los lotes de terreno N&#xBA;s 93 y 111, superficie 105,00 m2 y 84,60 roles de aval&#xFA;o 650-21 y 668-5, comuna de Rancagua, para la obra Mejoramiento Ruta 5 Sur, sector Pasada por Rancagua Camino Ruta 5 Sur y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Jos&#xE9; Ortiz Lara y otros Juan Latife Saadi y otros, ascendente a las cantidades de $1.520.400, para el lote N&#xB0; 93, $2.968.125, para el lote N&#xB0; 111.</div><br></div>", "i": 6743146}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obra P&#xFA;blicas. </div></div>", "i": 6743147}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "633", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-633"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-10-30", "doble_articulado": false, "id_norma": "218626", "numero_fuente": "35331", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-12-01", "vigencias": [{"desde": "1995-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2003-12-15", "fecha_version": "1995-12-01", "fecha_actualizacion_texto": "1995-12-01", "ti