{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento al Presupuesto de Justicia Lei n&#xFA;m. 1,268.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948738}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Conc&#xE9;dese un suplemento de doce mil pesos al &#xED;tem 3 de la partida 26 del Presupuesto de Justicia, para la publicacion de la Gaceta de los Tribunales.</div><br><br></div>", "i": 5948739}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 3 de Noviembre de 1899.- FEDERICO ERRAZURIZ.- Francisco J. Herboso </div></div>", "i": 5948740}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1268", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1268"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "SUPLEMENTO AL PRESUPUESTO DE JUSTICIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1899", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-11-03", "doble_articulado": false, "id_norma": "22518", "numero_fuente": "6440", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-11-06", "vigencias": [{"desde": "1899-11-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-11-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-11-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendien