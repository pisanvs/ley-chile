{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 183, DE 1992 </div></div>", "i": 6050781}, {"t": "<div><div class=\"p\">Por Decreto Exento No. 183 de fecha 30 de junio de 1992 del Ministerio de Educaci&#xF3;n, se derog&#xF3; el Decreto Exento de Educaci&#xF3;n No. 48 de 09 de febrero de 1990, que autoriz&#xF3; el funcionamiento al Instituto Profesional CORPRIDE de la ciudad de Curic&#xF3; y Sede en la comuna de Romeral, organizado por la Corporaci&#xF3;n Privada de Desarrollo de Curic&#xF3;, y se elimin&#xF3; del Libro de Registro de Institutos Profesionales el No. 63 correspondiente a la instituci&#xF3;n antes se&#xF1;alada. </div></div>", "i": 6050782}, {"t": "<div><div class=\"p\">Santiago, 26 de Agosto de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6050783}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "183 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-183 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 183, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-06-30", "doble_articulado": false, "id_norma": "77571", "numero_fuente": "34359", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-09-04", "vigencias": [{"desde": "1992-09-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-09-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-09-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFI