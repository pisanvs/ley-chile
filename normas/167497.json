{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6271484}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.479, de fecha 10 de noviembre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a &quot;Ram&#xED;rez, Allendes y Compa&#xF1;&#xED;a Limitada&quot;, para efectuar las Revisiones T&#xE9;cnicas de los veh&#xED;culos de transporte de personas de m&#xE1;s de nueve (9) asientos, incluido el del conductor; de veh&#xED;culos motorizados de carga con capacidad para transportar m&#xE1;s de 1.750 kilos, sus remolques y semirremolques y los taxis, en el establecimiento ubicado en Avenida Departamental No. 2025, Comuna de San Miguel.</div><br></div>", "i": 6271485}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana. </div></div>", "i": 6271486}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1479 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1479 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-10", "doble_articulado": false, "id_norma": "167497", "numero_fuente": "32939", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-07", "vigencias": [{"desde": "1987-12-07", "hasta": "", "tipo_version": "3", "tipo_version_s":