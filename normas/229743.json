{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUAS EN COMUNA DE COPIAPO</div><br><br></div>", "i": 7314261}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n</div><div class=\"p\">exenta N&#xBA;2.738 del 16 de agosto de 2004, conforme</div><div class=\"p\">art&#xED;culo 5&#xBA; transitorio C&#xF3;digo de Aguas, complement&#xF3; resoluci&#xF3;n exenta N&#xBA;1.907, de 9 de septiembre de 1987, que aprob&#xF3; distribuci&#xF3;n de derechos de aprovechamiento de aguas del Proyecto de Parcelaci&#xF3;n &quot;Piedra Colgada&quot;, de la comuna de Copiap&#xF3;, provincia de Copiap&#xF3;, III Regi&#xF3;n, en el sentido de establecer que los derechos de aprovechamiento de aguas subterr&#xE1;neas que se extraen del pozo profundo identificado como Pozo Corfo 534 coordenadas 27&#xB0;10&apos; - 70&#xB0;20&apos; Sector C 4, son de car&#xE1;cter consuntivo, de ejercicio permanente y continuos. Publicaci&#xF3;n hecha conforme art&#xED;culo 13 ley N&#xBA;18.377. </div></div>", "i": 7314262}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Nacional.</div><br></div>", "i": 7314263}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2738 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2738 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUAS EN COMUNA DE COPIAPO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-08-16", "doble_articulado": false, "id_norma": "229743", "numero_fuente": "37951", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "20