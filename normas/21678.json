{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 678 EXENTO, DE 1995 </div></div>", "i": 5945836}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 678 de 15 de diciembre de 1995, se ha aprobado un plan especial de estudio al Colegio &quot;Mater Admirabilis&quot; de la comuna de Las Condes, para el 7&#xB0; y 8&#xB0; a&#xF1;o b&#xE1;sico que se aplicar&#xE1; en los a&#xF1;os escolares 1995 y 1996.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio para las asignaturas que se indican en el presente decreto para 7&#xB0; y 8&#xB0; a&#xF1;o b&#xE1;sico.</div><br></div>", "i": 5945837}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 27 de Diciembre de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5945838}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "678 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-678 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 678 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO MATER ADMIRABILIS", "LAS CONDES", "REGION", "METROPOLITANA", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-12-15", "doble_articulado": false, "id_norma": "21678", "numero_fuente": "35365", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-01-13", "vigencias": [{"desde": "1996-01-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-01-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia"