{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCIONES QUE INDICA </div></div>", "i": 8319463}, {"t": "<div><br><div class=\"p\">Por Resoluci&#xF3;n No. 1.389, de 06 de Octubre de 1989, de esta Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifican las Resoluciones No. 121, de 1986 y No. 392, de 1987, ambas de esta Subsecretar&#xED;a, que autorizaron a Pesquera Expogamar Limitada, R.U.T. No.</div><div class=\"p\">79.537.270-9, domiciliada en Santiago, para desarrollar y ampliar, respectivamente, actividades pesqueras de transformaci&#xF3;n, en el sentido de sustituir en sus numerales 2&#xB0; la expresi&#xF3;n &quot;calle Baquedano No. 16&quot; por &quot;calle Santa Ester de la Poblaci&#xF3;n Baquedano, No. 1370&quot;.</div><br></div>", "i": 8319464}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 06 de Octubre de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8319465}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1389", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1389"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-10-06", "doble_articulado": false, "id_norma": "90476", "numero_fuente": "33512", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-11-03", "vigencias": [{"desde": "1989-11-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-11-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"in