{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9314644}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.976, de 15 de noviembre de 2012, de esta Subsecretar&#xED;a, ampl&#xED;ese por doce meses, a contar del 30 de septiembre de 2012, el plazo otorgado en el numeral 4&#xBA;, inciso 2&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=222669&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 542 de 2004</a>, a CORPESCA S.A., para continuar desarrollando las actividades pesqueras extractivas con la nave &quot;Eperva 51&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre la XV a II Regiones, sobre Jibia en virtud de haberse acreditado una circunstancia de fuerza mayor.</div></div>", "i": 9314645}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de noviembre de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9314646}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2976 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2976 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-11-15", "doble_articulado": false, "id_norma": "1046005", "numero_fuente": "40417", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-11-23", "vigencias": [{"desde": "2012-11-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-11-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic