{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA EMISOR ELECTR&#xD3;NICO</div><br></div>", "i": 9109234}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA;19, de 4 de febrero de 2011, que autoriza a contribuyentes como emisor electr&#xF3;nico.</div><br><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de documentos tributarios electr&#xF3;nicos al contribuyente RUT 89.807.200-2, a contar del mes de febrero de 2011. En la Oficina Virtual del SII en Internet se podr&#xE1; consultar los documentos que el contribuyente est&#xE1; autorizado a emitir en forma electr&#xF3;nica.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de febrero de 2011.</div></div>", "i": 9109235}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "19 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-19 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISOR ELECTRÓNICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-02-04", "doble_articulado": false, "id_norma": "1022884", "numero_fuente": "39882", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-02-10", "vigencias": [{"desde": "2011-02-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-02-10", "fin_vigen