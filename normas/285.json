{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SESION N&#xB0; 559 </div></div>", "i": 5843817}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Certifico que el Consejo del Banco Central de Chile, en su Sesi&#xF3;n N&#xB0; 559 celebrada el 24 de octubre de 1996, adopt&#xF3; el siguiente Acuerdo:</div><div class=\"p\">&nbsp; &nbsp; 559-04-961024 - Deroga Cap&#xED;tulo IV.E.3 del Compendio de Normas Financieras.</div><div class=\"p\">&nbsp; &nbsp; Se acord&#xF3; derogar, a contar de la fecha del presente Acuerdo, el Cap&#xED;tulo IV.E.3 &quot;Operaciones de compra de d&#xF3;lares de los Estados Unidos de Am&#xE9;rica con recursos correspondientes a aportes de capital, con pacto de recompra&quot;, del Compendio de Normas Financieras.- </div></div>", "i": 5843818}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Jorge Carrasco V&#xE1;squez, Ministro de Fe.</div><br></div>", "i": 5843819}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "559", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-559"}, {"tipo": "5", "numero": "559-04", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-559-04"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE\nCHILE EN SESION N° 559", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DEROGACION", "COMPENDIO DE NORMAS FINANCIERAS", "OPERACIONES DE COMPRA DE DOLARES", "APORTE DE CAPITAL", "PACTO DE RECOMPRA", "BANCO CENTRAL DE CHILE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-10-24", "doble_articulado": false, "id_norma": "285", "numero_fuente": "35601", "tipo_version": "3", "tipo_version_s": "Única", "fech