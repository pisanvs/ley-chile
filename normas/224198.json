{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6743523}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xB0;392, de 31 de mayo de 1996, se expropiaron los lotes de terreno N&#xB0;s. l8-B, 19-A, l9-B, 19-C y 24, superficies 700 m2, 158 m2, 940 m2, 920 m2 y 143 m2, respectivamente, roles de aval&#xFA;os en tr&#xE1;mite y 26-10, comuna de Lolol, para la obra Camino Santa Cruz-Lolol, sector Puente Naval 1 y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Ferm&#xED;n Allendes Herrera, Mar&#xED;a Emilia Ihnen Curtze y Armando Z&#xFA;&#xF1;iga Gaete, ascendente a las cantidades de $7.886.862, $2.159.012 y $542.754.</div><br></div>", "i": 6743524}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6743525}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "392", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-392"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-31", "doble_articulado": false, "id_norma": "224198", "numero_fuente": "35516", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-07-15", "vigencias": [{"desde": "1996-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2004-04-23", "fecha_version": "1996-07-15", "fe