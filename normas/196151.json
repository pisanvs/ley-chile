{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6374770}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA; 111, de fecha 25 de febrero de 2002, se expropi&#xF3; el lote de terreno N&#xBA; 111, superficie 318 m2, rol de aval&#xFA;o 205-89, comuna de Coelemu, para la obra &quot;Camino Ruta O-170, O-176, Acceso a Guarilihue, Km. 0,00000 a Km. 8,28000&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Hayd&#xE9;e Guzm&#xE1;n Fuentes, ascendente a la cantidad de $850.648. </div></div>", "i": 6374771}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6374772}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "111 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-111 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-25", "doble_articulado": false, "id_norma": "196151", "numero_fuente": "37223", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-01", "vigencias": [{"desde": "2002-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2002-04-01", "fecha_version": "2002-04-01", "fecha_actualizacion_texto": "2002-04-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n":