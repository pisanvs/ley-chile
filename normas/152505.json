{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 106, DE 1986</div><br><br></div>", "i": 6223377}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 106 de 11 de junio de 1986, se han aprobado para el Liceo Industrial C No. 15, de Rengo, VI Regi&#xF3;n del Libertador General Bernardo O&apos;Higgins, planes y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico-Profesional, que se aplicar n gradualmente a contar del a&#xF1;o escolar 1986 y hasta el a&#xF1;o escolar de 1991, en las Especialidades de:</div><br><div class=\"p\">1.- Electromec&#xE1;nica.</div><div class=\"p\">2.- Mec&#xE1;nica de M quinas Herramientas.</div><div class=\"p\">3.- Refrigeraci&#xF3;n y Aire Acondicionado.</div><br></div>", "i": 6223378}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de Junio de 1986.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6223379}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "106 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-106 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 106, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-11", "doble_articulado": false, "id_norma": "152505", "numero_fuente": "32511", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-07-02", "vigencias": [{"desde": "1986-07-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-07-02", "fin_vigenci