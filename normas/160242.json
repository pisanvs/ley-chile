{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 189 EXENTO, DE 1999</div><br><br></div>", "i": 7085660}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 189, de fecha 12 de julio de 1999, del Ministerio de Educaci&#xF3;n, se declar&#xF3; aprobado al Instituto Profesional Diego Barros Arana el plan y programas de estudios de la carrera de Ingenier&#xED;a de Educaci&#xF3;n en Gesti&#xF3;n Empresarial, conducente al t&#xED;tulo profesional de Ingeniero de Ejecuci&#xF3;n en Gesti&#xF3;n Empresarial, para ser impartida en jornada vespertina en su sede de la ciudad de Concepci&#xF3;n, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 7085661}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de agosto de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7085662}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "189 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-189 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 189 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-07-12", "doble_articulado": false, "id_norma": "160242", "numero_fuente": "36609", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-09", "vigencias": [{"desde": "2000-03-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-09", "fin_vigencia": "", "tip