{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6187593}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.401, de 31 de mayo de 1999, se expropiaron los lotes de terreno N&#xBA;s. 7-A, 7-B, 7-C, 15, 60 y 60-A, superficies 3.895,81; 289,62; 6.685,59; 522; 424 y 816 m&#xB2;, respectivamente roles de aval&#xFA;o 9317-1, 9317-47, 9309-10 y 9309-8, comuna de Valpara&#xED;so, para la obra Habilitaci&#xF3;n Nuevo Camino La P&#xF3;lvora, Tramo I, Sector Placilla-Puertas Negras y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Ildefonso P&#xE9;rez Zujovic, Sergio N&#xFA;&#xF1;ez Aguilera y Luz Parraguez Biggio y otros, ascendente a las cantidades de $46.273.452, $13.293.000 y $3.982.000.</div><br></div>", "i": 6187594}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6187595}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1401", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1401"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-05-31", "doble_articulado": false, "id_norma": "142192", "numero_fuente": "36454", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-01", "vigencias": [{"desde": "1999-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_