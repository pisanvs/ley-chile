{"html": [{"t": "<div><div class=\"p\">MODIFICA CONCESION DE ACUICULTURA </div></div>", "i": 6590280}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n (M) 991, de fecha 21 de septiembre de 2006, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, resolvi&#xF3; lo siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  1.- Modif&#xED;case el DS. (M) N&#xBA;449, de fecha 24 de julio de 1992, en el sentido de reemplazar la raz&#xF3;n social de la siguiente forma:</div><div class=\"p\">&nbsp; &nbsp;  Reempl&#xE1;zase en su texto &#xED;ntegro lo siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  Donde dice: &quot;Pesquera Trans Antartic Limitada&quot;.</div><div class=\"p\">&nbsp; &nbsp;  Debe decir: &quot;Cultivos Acu&#xED;colas El Volc&#xE1;n Limitada&quot;.</div><br></div>", "i": 6590281}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de octubre de 2006.- Por la Subsecretaria, Carlos Vizcaya Salinas, Subjefe Subsecretar&#xED;a de Marina.</div><br></div>", "i": 6590282}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "991", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-991"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "MODIFICA CONCESION DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-09-21", "doble_articulado": false, "id_norma": "255408", "numero_fuente": "38619", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-11-21", "vigencias": [{"desde": "2006-11-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-11-21", "fin_vigen