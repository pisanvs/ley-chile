{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6338989}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 703, de 30 de abril de 2001, se expropi&#xF3; el lote de terreno N&#xBA; 36, superficie 4.893 m2., Rol de aval&#xFA;o 152-436, comuna de Graneros, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: Santiago-Talca y acceso Sur a Santiago. By Pass Rancagua, Sexta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Orlando de Jes&#xFA;s Gajardo Vargas, ascendente a la cantidad de $4.411.400.-.</div><br></div>", "i": 6338990}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6338991}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "703", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-703"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-30", "doble_articulado": false, "id_norma": "186529", "numero_fuente": "36987", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-06-15", "vigencias": [{"desde": "2001-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2001-06-15", "fecha_version": "2001-06-15", "fecha_actualizacion_texto": "2001-06-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura":