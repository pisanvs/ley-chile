{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,668.- Santiago, 12 de agosto de 1904.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6164974}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Julia Morel Zegers, hermana del aspirante de la Armada Nacional don Juan Antonio Morel Zegers, muerto en accion de guerra, la pension asignada a dicho empleo en el art&#xED;culo 11 de la lei de recompensas de 22 de diciembre de 1881&quot;. </div></div>", "i": 6164975}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.-</div><div class=\"p\">A. Bascu&#xF1;an S. M.</div><br></div>", "i": 6164976}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1668", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1668"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-08-12", "doble_articulado": false, "id_norma": "135299", "numero_fuente": "7978", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1904-08-12", "vigencias": [{"desde": "1904-08-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1904-08-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1904-08-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [],