{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DERECHOS DE AGUAS EN COMUNA DE PELARCO </div></div>", "i": 6026246}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta N&#xB0; 2669 del 2 de Octubre de 1995, complement&#xF3; la Resoluci&#xF3;n Exenta N&#xB0; 76 del 25 de Enero de 1988, que aprob&#xF3; distribuci&#xF3;n de derechos de aguas de parte del Proyecto de Parcelaci&#xF3;n de la &quot;Colonia Panguilemito&quot;, de la comuna de Pelarco, VII Regi&#xF3;n, en el sentido de aprobar conforme art&#xED;culo 5&#xB0; transitorio C&#xF3;digo Aguas, la distribuci&#xF3;n de derechos aprovechamiento aguas de la parte del sector parcelado del predio &quot;Panguilemito&quot; regado con el canal San Rafael.</div><div class=\"p\">&nbsp; &nbsp; Los derechos de aguas se extraen del R&#xED;o Claro por el Canal San Rafael.</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n hecha conforme art&#xED;culo 13 Ley N&#xB0; 18.377.</div><br></div>", "i": 6026247}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director Nacional.</div><br></div>", "i": 6026248}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2669", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2669"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "DERECHOS DE AGUAS EN COMUNA DE PELARCO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHO APROVECHAMIENTO AGUAS", "PROYECTO PARCELACION COLONIA PANGUILEMITO", "PELARCO", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-10-02", "doble_articulado": false, "id_norma": "40227", "numero_fuente": "35292-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995