{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8310732}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.574, de 18 de noviembre de 1997, de esta Subsecretar&#xED;a de Pesca, autor&#xED;zase a CULTIVOS MARINOS CHILOE LIMITADA, para continuar desarrollando las actividades de acuicultura autorizadas a Cultivos Marinos Chilo&#xE9; S.A., de mismos R.U.T. y domicilio, en virtud de la Escritura P&#xFA;blica de fecha 11 de diciembre de 1995, otorgada ante la Notario P&#xFA;blico de Santiago Nancy de la Fuente Hern&#xE1;ndez, que transform&#xF3; la Sociedad &quot;Cultivos Marinos Chilo&#xE9; S.A.&quot; en &quot;Cultivos Marinos Chilo&#xE9; Limitada&quot;.</div><br></div>", "i": 8310733}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de noviembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8310734}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1574", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1574"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "CULTIVOS MARINOS CHILOE LIMITADA", "PESCA", "ACUICULTURA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-11-18", "doble_articulado": false, "id_norma": "80217", "numero_fuente": "35931", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-12-02", "vigencias": [{"desde": "1997-12-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-12-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci