{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.254 EXENTO, DE 1997 </div></div>", "i": 7230445}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento N&#xBA; 1.254 de fecha 31 de diciembre de 1997 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica INSES, las adecuaciones al plan y programas de estudios de la carrera de Asistente de Educaci&#xF3;n Parvularia que se indican, modific&#xE1;ndose en consecuencia, la Resoluci&#xF3;n Exenta del Ministerio de Educaci&#xF3;n N&#xBA; 3.355 del 17 de diciembre de 1994. Dichas adecuaciones podr&#xE1;n aplicarse a contar de agosto de 1997.</div><br></div>", "i": 7230446}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de enero de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7230447}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1254 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1254 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.254 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "CENTRO DE FORMACION TECNICA INSES", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-31", "doble_articulado": false, "id_norma": "96121", "numero_fuente": "35988", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-02-11", "vigencias": [{"desde": "1998-02-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-02-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-02-11", "fin