{"html": [{"t": "<div><br><div class=\"p\">DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 36 exenta.- Santiago, 13 de enero de 2010.- Vistos: Lo dispuesto en el Art. 11 del decreto ley N&#xBA; 2.974 de 1979,</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div></div>", "i": 8847849}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del decreto ley citado, en la Regi&#xF3;n del Libertador Bernardo O&#x2019;Higgins, al siguiente funcionario:</div><br><div class=\"p\">&nbsp; &nbsp;  Mario Arturo Gajardo Soto</div></div>", "i": 8847850}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hern&#xE1;n Rojas Olavarr&#xED;a, Director Nacional.</div></div>", "i": 8847851}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "36 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-36 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2010-01-13", "fecha_derogacion": "2012-06-25", "doble_articulado": false, "id_norma": "1010438", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2010-01-25", "vigencias": [{"desde": "2012-06-25", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"