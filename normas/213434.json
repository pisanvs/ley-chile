{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 4.165 EXENTA, DE 2003 </div></div>", "i": 6434986}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.165 de fecha 19 de marzo de 2003 se declara que no se concedi&#xF3; el reconocimiento oficial al Centro de Formaci&#xF3;n T&#xE9;cnica Colchagua, organizado por la Sociedad Educacional Colchagua S.A. o C.F.T. Colchagua S.A., ubicado en calle Barreales N&#xBA; 771 de la ciudad de Santa Cruz.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, se elimina del Libro de Registro de Centros de Formaci&#xF3;n T&#xE9;cnica el N&#xBA; 319 de fecha 22 de octubre de 2002, correspondiente al Centro de Formaci&#xF3;n T&#xE9;cnica Colchagua (en formaci&#xF3;n) de Santa Cruz.</div><br></div>", "i": 6434987}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de abril de 2003.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 6434988}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4165 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4165 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 4.165 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-03-19", "doble_articulado": false, "id_norma": "213434", "numero_fuente": "376314", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-08-09", "vigencias": [{"desde": "2003-08-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-08-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_