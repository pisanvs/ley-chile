{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 1.996.- Santiago, 27 de Julio de 1927.- Vistos estos antecedentes,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 9050522}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.&#xBA; Conc&#xE9;dese personalidad jur&#xED;dica a la corporaci&#xF3;n denominada &quot;Club de Profesoras Gabriela Mistral&quot;, con domicilio en Santiago; y</div><div class=\"p\">&nbsp; &nbsp;  2.&#xBA; Apru&#xE9;banse los estatutos por que ha de regirse dicha corporaci&#xF3;n, en los t&#xE9;rminos de que da testimonio la escritura p&#xFA;blica adjunta, otorgada ante el notario de Santiago, don Manuel Gaete Fagalde, el 31 de Marzo &#xFA;ltimo. </div></div>", "i": 9050523}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- C. Ib&#xE1;&#xF1;ez C.- </div></div>", "i": 9050524}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1996", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1996"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1927-07-27", "doble_articulado": false, "id_norma": "125939", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1927-07-29", "vigencias": [{"desde": "1927-07-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1927-07-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1927-07-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacione