{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6210251}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 5,44% anual durante el mes de noviembre de 1999. Asimismo, en conformidad con lo dispuesto en el N&#xBA;5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de noviembre de 1999, fue de 5,43% anual. </div></div>", "i": 6210252}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 1&#xBA; de diciembre de 1999.- Jorge Carrasco V&#xE1;squez, Ministro de Fe (S).</div><br></div>", "i": 6210253}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-11-26", "doble_articulado": false, "id_norma": "148911", "numero_fuente": "36531", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-12-04", "vigencias": [{"desde": "1999-12-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-12-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-12-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-12-06", "fecha_ve