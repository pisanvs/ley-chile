{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,679.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6172820}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atenci&#xF3;n a los servicios prestados durante la guerra contra el Per&#xFA; i Bolivia por don Juan Sep&#xFA;lveda Villarroel, conc&#xE9;dese, por gracia, el derecho a disfrutar de una pension mensual de cien pesos ($ 100), que gozar&#xE1; con arreglo a la lei de montep&#xED;o militar. </div></div>", "i": 6172821}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiocho de agosto de mil novecientos doce.- Ramon Barros Luco.- Claudio Vicu&#xF1;a S. </div></div>", "i": 6172822}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2679", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2679"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-08-28", "doble_articulado": false, "id_norma": "137661", "numero_fuente": "10365", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-08-29", "vigencias": [{"desde": "1912-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-08-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-08-29", "fin_vigencia": "", "tipo_version": "3"}],