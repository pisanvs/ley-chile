{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6141334}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.853, de 30 de septiembre de 1998, se expropiaron los lotes de terreno N&#xBA; s 2 y 3, superficies 852 y 2.296 m&#xB2; respectivamente, roles de aval&#xFA;o 136-381 y 136-73, comuna de San Francisco de Mostazal, para la obra Camino Ruta 5 Sur, Sector Atravieso La Punta y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Semillas Limagrain de Chile Ltda. y Galvarino Jorquera Garc&#xED;a, ascendentes a las cantidades de $ 13.648.429.- para el lote 2 y $ 83.601.908.- para el lote 3.-</div><br></div>", "i": 6141335}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6141336}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1853", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1853"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SAN FRANCISCO DE MOSTAZAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-09-30", "doble_articulado": false, "id_norma": "127799", "numero_fuente": "36228", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-12-01", "vigencias": [{"desde": "1998-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1998-12-02", "fecha