{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  CIRCULAR INFORMATIVA N&#xB0; 11</div><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de junio de 2005 </div><div class=\"p\">&nbsp; &nbsp;  Plazo de vigencia de la sociedad solicitante del permiso de operaci&#xF3;n </div><br></div>", "i": 10206547}, {"t": "<div><br><br><div class=\"p\">El art&#xED;culo 17, letra f) de la <a href=\"https://www.leychile.cl/Navegar?idNorma=234426&amp;idParte=&amp;idVersion=\">Ley N&#xB0; 19.995</a> y la la letra e) del art&#xED;culo 9 del <a href=\"https://www.leychile.cl/Navegar?idNorma=237711&amp;idParte=&amp;idVersion=\">Decreto Supremo N&#xB0; 211</a> estipulan que &quot;La vigencia de la sociedad no podr&#xE1; ser inferior al tiempo por el cual se otorga el permiso de operaci&#xF3;n&quot;. Por tanto, en la escritura de constituci&#xF3;n de la sociedad se debe contemplar un plazo, no siendo suficiente el t&#xE9;rmino &quot;indefinido&quot; para cumplir con la exigencia antes indicada.</div><br><br></div>", "i": 10206548}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Francisco Javier Leiva Vega</div><div class=\"p\">&nbsp; &nbsp;  Superintendente de Casinos de Juego&nbsp; </div><br><br></div>", "i": 10206549}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "11", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-11"}], "organismos": ["MINISTERIO HACIENDA", "SUPERINTENDENCIA DE CASINOS DE JUEGO"], "titulo_norma": "Plazo de vigencia de la sociedad solicitante del permiso de operación", "fuente": "Otro", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-15", "doble_articulado": false, "id_norma": "1149114", "numero_fuente": "0", "tipo_version": "3", "