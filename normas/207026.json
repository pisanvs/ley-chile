{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6411327}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 39, de 8 de enero de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA LEUCOTON LIMITADA para ampliar las actividades pesqueras extractivas con la nave &quot;Leucot&#xF3;n&quot;, por fuera del &#xE1;rea de reserva artesanal, con los artes de pesca y en las &#xE1;reas mar&#xED;timas que en cada caso se indican, sobre los siguientes recursos hidrobiol&#xF3;gicos: a) Entre la I a III Regiones, con espinel: Reineta, Raya; b) Entre los paralelos 33&#xB0; L.S. y 40&#xB0; L.S., con espinel: Reineta; c) Entre el paralelo 33&#xB0; L.S. y la VII Regi&#xF3;n, con espinel y arrastre: Raya.</div><br></div>", "i": 6411328}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de enero de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6411329}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "39", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-39"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-01-08", "fecha_derogacion": "2020-12-24", "doble_articulado": false, "id_norma": "207026", "numero_fuente": "37467", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-01-24", "vigencias": [{"desde": "2020-12-24", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-01-24", "hasta": "2020-12-23", "tipo_version": "0", "tipo_version_s": "Texto Ori