{"html": [{"t": "<div><br><div class=\"p\">Pensiones</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Marzo 2 de 1814.</div></div>", "i": 10223841}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Las atenciones de la guerra agotan al Tesoro P&#xFA;blico: i no siendo justo que &#xE9;l padezca por otra parte exacciones en favor de aquellos que sin hallarse en estrema necesidad, no hacen un servicio a la Patria, se declara que solo el que no ocupase un empleo en la Rep&#xFA;blica, presentar&#xE1; al Gobierno los t&#xED;tulos por los cuales goce cualquiera pension, dentro de tercero dia de la publicacion de este decrete en El Monitor, los que residiesen en la Capital, dentro de veinte los que est&#xE9;n fuera de ella. Pasado el t&#xE9;rmino quedar&#xE1; sin goce el que no hubiese cumplido por el mismo hecho.</div></div>", "i": 10223842}, {"t": "<div><div class=\"p\"> - Irisarri. - Dr. Lazo. secretario.</div></div>", "i": 10223843}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Pensiones", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1814-03-02", "doble_articulado": false, "id_norma": "1154706", "numero_fuente": "1814", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1814-03-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1814-03-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1814-03-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "