{"html": [{"t": "<div><br><div class=\"p\">DISPONE EXPROPIACIONES QUE SE&#xD1;ALA</div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9531278}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 6.065 del 22 de octubre de 2014, Serviu Regi&#xF3;n de Valpara&#xED;so&nbsp; ha dispuesto la expropiaci&#xF3;n, conforme al art&#xED;culo 51 ley 16.391 y decreto ley 2.186 de 1978, de los inmuebles que m&#xE1;s abajo se individualizan, de presunto dominio de las personas que se indican, cuyos valores de indemnizaci&#xF3;n provisional que ser&#xE1; pagado de contado, fueron fijados por informes de septiembre de 2014 de la Comisi&#xF3;n de Peritos integrada por Enrique Ramos Guzm&#xE1;n (arquitecto), Irma D&#xED;az Riveros (constructor civil) y Hugo Fuentes Jara (constructor civil):</div><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/44972.jpg\">.</div></div>", "i": 9531279}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n de Valpara&#xED;so.</div></div>", "i": 9531280}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6065", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6065"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAÍSO"], "titulo_norma": "DISPONE EXPROPIACIONES QUE SEÑALA; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-10-22", "doble_articulado": false, "id_norma": "1070682", "numero_fuente": "41008", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-11-15", "vigencias": [{"desde": "2014-11-