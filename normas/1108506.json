{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO</div></div>", "i": 9837994}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP Exento N&#xB0; 1085 de 08 de septiembre de 2017, se rectific&#xF3; el numeral 2&#xB0; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1102830&amp;idParte=&amp;idVersion=\">Decreto MOP Exento N&#xB0; 227</a> de 25 de abril de 2017, que orden&#xF3; la expropiaci&#xF3;n del lote 6, en el siguiente aspecto: donde dice Comuna de Yerbas Buenas, debe decir Comuna de Colb&#xFA;n. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xB0; del Decreto Ley N&#xB0; 2186, de 1978.- </div></div>", "i": 9837995}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 9837996}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1085 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1085 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1278346", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-09-08", "doble_articulado": false, "id_norma": "1108506", "numero_fuente": "41873", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-10-02", "vigencias": [{"desde": "2017-10-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-10-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2017-10-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION