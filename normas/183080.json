{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6327278}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 172 de fecha 24 de Febrero de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a los se&#xF1;ores Francisco Antonio Maira D&#xED;az y Rafael Antonio Maira Benavides, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6327279}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Febrero de 1986.- Ramiro Camero Weir, Secretario Regional Ministerial Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana subrogante. </div></div>", "i": 6327280}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "172 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-172 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-02-24", "doble_articulado": false, "id_norma": "183080", "numero_fuente": "32414", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-03-05", "vigencias": [{"desde": "1986-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-03-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vi