{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede fondos para combatir la epidemia de tracoma Lei n&#xFA;m. 3,112.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275955}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir con cargo al &#xED;tem 3,765 del Presupuesto del Interior, vijente, hasta la suma de cincuenta mil pesos ($ 50,000.) en combatir la epidemia de tracoma en el territorio de la Rep&#xFA;blica. </div></div>", "i": 8275956}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 4 de Setiembre de 1916.- JUAN LUIS SANFUENTES.- Luis Izquierdo.</div><br></div>", "i": 8275957}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3112", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3112"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Concede fondos para combatir la epidemia de tracoma", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EPIDEMIA TRACOMA", "PREVENCION", "FONDOS", "INVERSION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-09-04", "doble_articulado": false, "id_norma": "23746", "numero_fuente": "11568", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-09-07", "vigencias": [{"desde": "1916-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1916-0