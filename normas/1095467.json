{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 4.796 EXENTA, DE 3 DE OCTUBRE DE 2016</div></div>", "i": 9738969}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=1074303&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 484, de 2015, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; plan y programas especiales de estudio de 1&#xBA; a 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media, al Colegio The Grange School, comuna de La Reina, provincia de Santiago, Regi&#xF3;n Metropolitana y deroga resoluciones exentas que indica.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio de las asignaturas de Econom&#xED;a A2 y Dise&#xF1;o y Tecnolog&#xED;a AS de 2&#xBA;, 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media que se acompa&#xF1;an en la presente resoluci&#xF3;n exenta.</div></div>", "i": 9738970}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de octubre de 2016.- Valentina Karina Quiroga Canahuate, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 9738971}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4796 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4796 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 4.796 EXENTA, DE 3 DE OCTUBRE DE 2016", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1121635; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-10-03", "doble_articulado": false, "id_norma": "1095467", "numero_fuente": "41581", "tipo_version": "3", "tipo_versio