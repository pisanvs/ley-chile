{"html": [{"t": "<div><div class=\"p\">APRUEBA REFORMA DE ESTATUTOS DE &quot;UAP SEGUROS DE VIDA /CHILE/ S.A.&quot; </div></div>", "i": 6075867}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico: Que por Resoluci&#xF3;n exenta N&#xBA; 368, de 12 de diciembre de 1997, se aprob&#xF3; reforma de estatutos de la sociedad an&#xF3;nima &quot;UAP Seguros de Vida /Chile/ S.A.&quot;, acordada en junta extrordinaria de accionistas de 2 de diciembre de 1997, cuya acta consta de la escritura p&#xFA;blica de igual fecha otorgada ante el Notario de Santiago don Iv&#xE1;n Torrealba Acevedo.</div><div class=\"p\">&nbsp; &nbsp;  La reforma consiste en cambiar el nombre por el de &quot;AXA Seguros Vida S.A.&quot;.</div><br></div>", "i": 6075868}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de diciembre de 1997.- Rodrigo O. Costa Aranda, Secretario General.</div><br></div>", "i": 6075869}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "368 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-368 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "APRUEBA REFORMA DE ESTATUTOS DE UAP SEGUROS DE VIDA/CHILE/S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REFORMA ESTATUTARIA", "ESTATUTOS", "UAP SEGUROS DE VIDA CHILE S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-12", "doble_articulado": false, "id_norma": "87309", "numero_fuente": "35951", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-12-29", "vigencias": [{"desde": "1997-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-12-29", "fin_vigencia": ""}, "vi