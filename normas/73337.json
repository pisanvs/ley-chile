{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6038598}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. N&#xBA; 379, de 21 de abril de 1997, se expropiaron los lotes de terreno N&#xBA;s 14, 16, 24-C y 54, superficies 274 m2., 289 m2., 516 m2. y 418 m2., roles de aval&#xFA;o 3330-10, 3330-12, 1065-12 y 2598-1, comuna de San Bernardo, para la obra Estudio de Anteproyecto e Ingenier&#xED;a para el Sistema Norte-Sur, sector Las Acacias-R&#xED;o Maipo, y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Mar&#xED;a Bernarda Soto Gonz&#xE1;lez, Iris N&#xFA;&#xF1;ez Chamorro, Luis Salinas Maul&#xE9;n, y Jorge Mestre Barrera y otro, ascendente a las cantidades de $22.738.900.-, $29.445.600.-, $26.681.200.- y $24.154.660.</div><br></div>", "i": 6038599}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6038600}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "379", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-379"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SAN BERNARDO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-21", "doble_articulado": false, "id_norma": "73337", "numero_fuente": "35779", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-06-02", "vigencias": [{"desde": "1997-06-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-06-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-06-02", "fin_vig