{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6467137}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA; 291, de 2 de febrero de 2004, se dejaron sin efecto los decretos exentos MOP N&#xBA; 1.338, de 31 de octubre, y N&#xBA; 1.573, de 28 de noviembre, ambos de 2003, por cuanto los lotes N&#xBA;s. 12, 15, 16, 33, 35, 39, 42 y 43 fueron expropiados por decreto exento MOP N&#xBA; 1.417, de 31 de octubre de 2003 y consignados en la cuenta corriente del Primer Juzgado Civil de Valpara&#xED;so. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.-</div><br></div>", "i": 6467138}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6467139}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "291 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-291 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-02", "doble_articulado": false, "id_norma": "221897", "numero_fuente": "37799", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-01", "vigencias": [{"desde": "2004-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-03-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "