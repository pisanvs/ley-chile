{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIA QUE INDICA </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 294.- Santiago, 23 de noviembre de 2005.- Vistos: Lo dispuesto en el art. 11 del decreto ley N&#xBA; 2.974 de 1979,</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 6553895}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del decreto ley citado, X Regi&#xF3;n, a la siguiente funcionaria:</div><br><div class=\"p\">- Sonia Edita Casanova Vargas, RUT 10.306.583-6 </div></div>", "i": 6553896}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Arturo S&#xE1;ez Chatterton, Director Nacional.</div><br></div>", "i": 6553897}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "294", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-294"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO DE DESARROLLO AGROPECUARIO", "DECIMA REGION", "RECEPTOR JUDICIAL", "DESIGNACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-23", "doble_articulado": false, "id_norma": "245362", "numero_fuente": "38342", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-12-21", "vigencias": [{"desde": "2005-12-21", "hasta"