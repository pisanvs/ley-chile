{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6599722}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 62, de 12 de enero de 2007, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 5&#xBA; de la resoluci&#xF3;n exenta N&#xBA; 103, modificada por resoluci&#xF3;n N&#xBA; 813, ambas de 2006, de esta Subsecretar&#xED;a, que autorizaron a CONSULTORA PUPELDE LIMITADA para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto denominado &quot;Bases para el Plan de Manejo Pesquer&#xED;as Bent&#xF3;nicas Zona Contigua Regiones X y XI, per&#xED;odo 2006&quot;, en el sentido de extender las actividades de investigaci&#xF3;n relacionadas con el recurso Luga roja hasta el d&#xED;a 31 de mayo de 2007, inclusive.</div><br></div>", "i": 6599723}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de enero de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6599724}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "62 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-62 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-12", "doble_articulado": false, "id_norma": "257991", "numero_fuente": "38677", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-01-31", "vigencias": [{"desde": "2007-01-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-01-31", "fi