{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 313 EXENTO, DE 2006 </div></div>", "i": 6567708}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 313, de fecha 22 de marzo de 2006, se declara aprobada a la Universidad Regional San Marcos, la siguiente carrera y grado acad&#xE9;mico que se indica:</div><br><div class=\"p\">Carrera: Kinesiolog&#xED;a Grado Acad&#xE9;mico: Licenciado en Kinesiolog&#xED;a T&#xED;tulo Profesional: Kinesi&#xF3;logo</div><div class=\"p\">&nbsp; &nbsp;  Dicha carrera ser&#xE1; impartida en jornada diurna en la ciudad de Concepci&#xF3;n, a contar el primer semestre del a&#xF1;o 2006.</div><br></div>", "i": 6567709}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de abril de 2006.- Pilar Romaguera Gracia, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 6567710}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "313 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-313 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2006-03-22", "fecha_derogacion": "2012-02-10", "doble_articulado": false, "id_norma": "249117", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2006-04-24", "vigencias": [{"desde": "2012-02-10", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2006-04-24", "hasta": "2012-02-09", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2012-02-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-04-24", "fin_vigencia": "2012-02-09", "tipo_version