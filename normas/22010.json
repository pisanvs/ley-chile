{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplementos Lei n&#xFA;m. 148.- Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946919}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dense los siguientes suplementos al presupuesto de Instruccion P&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; A la partida 38, Liceo de Talca, ocho mil pesos; i A la partida 43, Liceo de Concepcion, once mil pesos.</div><br><br><br></div>", "i": 5946920}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 30 de Diciembre de 1893.- JORJE MONTT.- Francisco A. Pinto.</div><br></div>", "i": 5946921}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "148", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-148"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "SUPLEMENTOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1893", "MODIFICACION MINISTERIO", "INSTRUCCION PUBLICA", "LICEO TALCA", "LICEO CONCEPCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-12-30", "doble_articulado": false, "id_norma": "22010", "numero_fuente": "4711", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-01-08", "vigencias": [{"desde": "1894-01-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-01-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "189