{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede 10 000 pesos a la Municipalidad de Talca para ensanchar el cementerio</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1674.- Santiago, a 2 de Setiembre de 1904.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274595}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese un ausilio estraordinario de diez mil pesos ($ 10 000) a la Junta de Beneficencia de Talca, destinado al ensanche del cementerio de esa ciudad.</div><br></div>", "i": 8274596}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- M. E. Ballesteros.</div><br></div>", "i": 8274597}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1674", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1674"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Concede 10 000 pesos a la Municipalidad de Talca;para ensanchar el cementerio", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUNTA BENEFICENCIA TALCA", "CEMENTERIO", "ENSANCHE", "FONDOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-09-02", "doble_articulado": false, "id_norma": "22835", "numero_fuente": "7996", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1904-09-02", "vigencias": [{"desde": "1904-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1904-09-02", "fin_vigencia": ""}