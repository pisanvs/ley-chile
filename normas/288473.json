{"html": [{"t": "<div><br><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A PESQUERA AMANECER S.A.</div><br></div>", "i": 8463316}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/N&#xBA;2.879 Ex., de fecha 20-03-09, otorga a Pesquera Amanecer S.A., RUT N&#xBA; 76.308.850-2, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de Sujeto en las ventas de productos hidrobiol&#xF3;gicos, establecido en la resoluci&#xF3;n N&#xBA; 3.311 Ex., de 30-06-2000 de la Direcci&#xF3;n Nacional. La presente autorizaci&#xF3;n surtir&#xE1; efecto a partir del d&#xED;a primero del mes siguiente a la fecha de publicaci&#xF3;n de este extracto, en el Diario Oficial y tendr&#xE1; vigencia indefinida.</div><br></div>", "i": 8463317}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 20 de marzo de 2009.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div></div>", "i": 8463318}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2879 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolucion-2879 EXENTA"}, {"tipo": "3", "numero": "DRE08/Nº 2879 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolucion-DRE08/Nº 2879 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A PESQUERA AMANECER S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-03-20", "doble_articulado": false, "id_norma": "288473", "numero_fuente": "39326", "tipo_versi