{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO RESOLUCI&#xD3;N N&#xB0; 414 EXENTA, DE 25 DE ENERO DE 2018</div></div>", "i": 9899398}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por el presente acto administrativo, se ha autorizado, a contar del a&#xF1;o escolar 2018, la readecuaci&#xF3;n del plan y programas especiales de estudio de 1&#xB0; y 2&#xB0; a&#xF1;o de Educaci&#xF3;n Media, al Colegio Saint John&apos;s Villa Academy, de la comuna de La Reina, provincia de Santiago, Regi&#xF3;n Metropolitana.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio de la asignatura de Cultura Religiosa para 1&#xB0; y 2&#xB0; a&#xF1;o medio.</div></div>", "i": 9899399}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de enero de 2018.- Valentina Karina Quiroga Canahuate, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 9899400}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "414 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-414 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO RESOLUCIÓN N° 414 EXENTA, DE 25 DE ENERO DE 2018", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1371017", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-01-25", "doble_articulado": false, "id_norma": "1116475", "numero_fuente": "42017", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-03-26", "vigencias": [{"desde": "2018-03-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2018-03-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2018-03-26", "fin_vige