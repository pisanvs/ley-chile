{"html": [{"t": "<div><div class=\"p\">NOMBRAMIENTO.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Febrero 20 de 1830.</div><br><br></div>", "i": 10247086}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Hall&#xE1;ndome plenamente satisfecho del m&#xE9;rito y aptitud del Dr. D. Juan F. Meneses, vengo en nombrarle Ministro de Estado en los departamentos de Relaciones Exteriores y del Interior.</div><br><br></div>", "i": 10247087}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Comun&#xED;quese a quienes corresponda y t&#xF3;mese razon. </div><div class=\"p\">&nbsp; &nbsp;  TAGLE.&nbsp; &nbsp;  Palacios Lopez. </div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Pro-secretario.</div></div>", "i": 10247088}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "NOMBRAMIENTO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1830-02-20", "doble_articulado": false, "id_norma": "1159406", "numero_fuente": "1830", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1830-02-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1830-02-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1830-02-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-06-30", "fecha_version": "1830-02-20", "fecha_actualizacion_texto": "2021-06-30", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructur