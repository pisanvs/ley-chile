{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO RECEPTORES JUDICIALES A FUNCIONARIOS QUE INDICA</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m.1.546 exenta.- Santiago, 12 de diciembre de 2008.- Vistos: Lo dispuesto en el art. 11 del decreto ley N&#xBA; 2.974 de 1979.</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 6911205}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Receptores Judiciales para que permanentemente practiquen las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del decreto ley citado, en la Regi&#xF3;n de Arica y Parinacota, a los siguientes funcionarios:</div><br><div class=\"p\">- Julio Ram&#xF3;n Olivares Vargas - Carmen Marcela Vicencio Contreras </div></div>", "i": 6911206}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese, publ&#xED;quese en el Diario Oficial y arch&#xED;vese.- Juan Rusque Alca&#xED;no, Director Nacional (S).</div><br></div>", "i": 6911207}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1546 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1546 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESIGNA COMO RECEPTORES JUDICIALES A FUNCIONARIOS QUE INDICA", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2008-12-12", "fecha_derogacion": "2011-02-17", "doble_articulado": false, "id_norma": "284144", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2008-12-27", "vigencias": [{"desde": "2011-02-17", "hasta": "",