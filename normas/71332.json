{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6036691}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 257, de 31 de marzo de 1997, se expropiaron a los lotes de terreno N&#xBA;s. 3, 8-A, 8-B, 11 y 17, superficies 12.425, 3.070, 2.443, 4,615 y 5,449 m2. respectivamente, roles de aval&#xFA;os 597-74, sin rol, 597-107, 597-109 y 597-108, comuna de San Ignacio, para la obra Proyecto Laja - Diguill&#xED;n, Canal Matriz, Sector Bulnes y se acord&#xF3; precio de la indemnizaci&#xF3;n con sus propietarios, Olga Lubertina Mart&#xED;nez Rivas, Hern&#xE1;n Henr&#xED;quez Jim&#xE9;nez y Jos&#xE9; R&#xF3;mulo Henr&#xED;quez Jim&#xE9;nez, ascendente a las cantidades de $5.607.852 para el lote N&#xBA; 3, $753.619 para el lote N&#xBA; 8-A y $6.296.047 para los lotes N&#xBA;s. 8-B, 11 y 17.</div><br></div>", "i": 6036692}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6036693}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "257", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-257"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SAN IGNACIO", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-31", "doble_articulado": false, "id_norma": "71332", "numero_fuente": "35766", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-15", "vigencias": [{"desde": "1997-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-15", "fin_vigencia": ""}, "vigencias_versi