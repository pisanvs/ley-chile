{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6342383}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;679 de fecha 31 de mayo de 2001, se expropi&#xF3; el lote de terreno N&#xBA;103-A, superficie 595,00 m2., rol de aval&#xFA;o 68-90, comuna de Teno, para la obra &quot;Camino Ruta J-25, Sector Cruce Longitudinal- La Monta&#xF1;a, Km. 0,22000 a Km. 25,00000&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Hern&#xE1;n Sebasti&#xE1;n Mu&#xF1;oz Basai, ascendente a la cantidad de $789.144.-</div><br></div>", "i": 6342384}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6342385}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "679", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-679"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-31", "doble_articulado": false, "id_norma": "187551", "numero_fuente": "37012", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-07-16", "vigencias": [{"desde": "2001-07-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-07-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-07-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2001-07-16", "fecha_version": "2001-07-16", "fecha_actualizacion_texto": "2001-07-16", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n