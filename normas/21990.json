{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Residencia del Ej&#xE9;rcito en el lugar de las Sesiones del Congreso</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 125.- Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946851}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Perm&#xED;tese la residencia de los cuerpos del Ej&#xE9;rcito permanente en el lugar de las sesiones del Congreso i diez leguas a su circunferencia por el t&#xE9;rmino de un a&#xF1;o.</div><div class=\"p\">&nbsp; &nbsp; Esta lei comenzar&#xE1; a rejir desde el 26 de Noviembre de 1893.</div><br><br></div>", "i": 5946852}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 25 de Noviembre de 1893.- JORJE MONTT.- Juan Antonio Orrego.</div><br></div>", "i": 5946853}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "125", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-125"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "Residencia del Ejército en el lugar de las Sesiones;del Congreso", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EJERCITO", "RESIDENCIA", "SESIONES", "CONGRESO", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-11-25", "doble_articulado": false, "id_norma": "21990", "numero_fuente": "4678", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-11-25", "vigencias": [{"desde": "1893-11-25", "hasta": "", "tipo_version": "3", "tipo_version