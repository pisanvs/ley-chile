{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO RESOLUCI&#xD3;N EXENTA QUE INDICA</div></div>", "i": 10243791}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.746, de 9 de junio de 2021, de esta Subsecretar&#xED;a, se deja sin efecto la <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=1138141&amp;idVersion=2021-06-16\">resoluci&#xF3;n exenta N&#xBA; 3.305, de 2019</a>, de esta Subsecretar&#xED;a, que estableci&#xF3; los criterios de distribuci&#xF3;n y ponderaciones de las pesquer&#xED;as artesanales de Anchoveta y Jurel en la Regi&#xF3;n de Antofagasta.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n extractada se publicar&#xE1; en el sitio de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><br></div>", "i": 10243792, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de junio de 2021.- Alicia Gallardo Lagno, Subsecretaria de Pesca y Acuicultura.</div><div class=\"p\"> </div><br></div>", "i": 10243793}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1746 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1746 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DEJA SIN EFECTO RESOLUCIÓN EXENTA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1961112", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-06-09", "doble_articulado": false, "id_norma": "1161490", "numero_fuente": "42980", "tipo