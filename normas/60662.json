{"html": [{"t": "<div><br><div class=\"p\">PRORROGA AUTORIZACION QUE INDICA </div></div>", "i": 9047770}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 777 de 18 de Junio de 1990 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por el plazo de un a&#xF1;o, a contar de la fecha de publicaci&#xF3;n del presente extracto, el plazo otorgado a Pesquera Colomba S.A., R.U.T. N&#xBA; 96.530.830-K, domiciliada en la ciudad de Santiago, para empezar a operar las dos embarcaciones y la planta, autorizadas por Resoluci&#xF3;n N&#xBA; 547, de 1988, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor. </div></div>", "i": 9047771}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de Junio de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca </div></div>", "i": 9047772}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "777", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-777"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA COLOMBA S.A.", "PLAZO", "PRORROGA", "PESCA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-06-18", "doble_articulado": false, "id_norma": "60662", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-07-16", "vigencias": [{"desde": "1990-07-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-07-16", "fin_vigencia": ""}, "vigencias_version_norma":