{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO MINISTRO DE FE A FUNCIONARIO QUE INDICA </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 25.- Santiago, 10 de Marzo de 1987.- Vistos: Lo dispuesto en el art&#xED;culo 4&#xB0; del Decreto Ley No. 2.974 de 1979,</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 6195503}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Designase como Ministro de Fe para actuar en las localidades de la IX Regi&#xF3;n en que no haya Notario ni Oficiales del Registro Civil, al funcionario del Instituto de Desarrollo Agropecuario don Hip&#xF3;lito Huircap&#xE1;n Dumuihual, T&#xE9;cnico Agr&#xED;cola, grado 20 EUR., Rol&#xED;n No. 05403200-5, con residencia en la IX Regi&#xF3;n. </div></div>", "i": 6195504}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Arturo Venegas Palacios, Vicepresidente Ejecutivo.</div><br></div>", "i": 6195505}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "25", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-25"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO MINISTRO DE FE A FUNCIONARIO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-03-10", "doble_articulado": false, "id_norma": "144809", "numero_fuente": "32758", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-04-29", "vigencias": [{"desde": "1987-04-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-04-29", "fin_vigencia": ""}, "vige