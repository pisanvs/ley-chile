{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8331341}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 878, de 12 de junio de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 1 de la resoluci&#xF3;n N&#xBA; 606, de 1998, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA IQUIQUE GUANAYE S.A., para ampliar por un a&#xF1;o el plazo realizar operaciones pesqueras con la nave &apos;&apos;Kansas&apos;&apos;, en el sentido de agregar en su inciso segundo entre los recursos autorizados al Jurel, en el litoral de la I, II y III Regiones en los plazos que all&#xED; se se&#xF1;alan.</div><br></div>", "i": 8331342}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de junio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8331343}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "878", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-878"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA IQUIQUE GUANAYE S.A.", "AMPLIACION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-06-12", "doble_articulado": false, "id_norma": "120438", "numero_fuente": "36097", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-06-24", "vigencias": [{"desde": "1998-06-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-06-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vi