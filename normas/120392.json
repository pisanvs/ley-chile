{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8331294}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 884, de 12 de junio de 1998, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura N&#xBA;95101067, presentada por</div><div class=\"p\">ANTONIETA LAGOS ZARATE, para operar un centro de cultivo</div><div class=\"p\">en Sector Panitao Bajo, Bah&#xED;a Chincui, comuna de Puerto</div><div class=\"p\">Montt, provincia de Llanquihue, X Regi&#xF3;n, conforme lo</div><div class=\"p\">dispuesto en el art&#xED;culo 14, en concordancia con el</div><div class=\"p\">art&#xED;culo 10, letra c) del D.S. N&#xBA; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8331295}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de junio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8331296}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "884", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-884"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "PUERTO MONTT", "ANTONIETA LAGOS ZARATE", "DECIMA REGION", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-06-12", "doble_articulado": false, "id_norma": "120392", "numero_fuente": "36096", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-06