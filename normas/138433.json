{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,897.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 8346140}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados al pais por el se&#xF1;or don Jos&#xE9; Domingo Amun&#xE1;tegui Rivera, conc&#xE9;dese, por gracia, a su viuda e hija soltera una pension de cuatro mil pesos ($ 4,000) anuales, de que gozar&#xE1;n por el t&#xE9;rmino de diez a&#xF1;os con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 8346141}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a ocho de julio de mil novecientos catorce.- Ramon Barros Luco.- Rafael Orrego.</div><br></div>", "i": 8346142}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2897", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2897"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1914-07-08", "doble_articulado": false, "id_norma": "138433", "numero_fuente": "10915", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1914-07-09", "vigencias": [{"desde": "1914-07-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1914-07-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1914-07-09", "fin_vigencia": ""