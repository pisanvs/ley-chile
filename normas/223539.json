{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7310510}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 885, de 30 de marzo de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a SOUTHPACIFIC KORP S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Vinga&quot;, en las &#xE1;reas mar&#xED;timas que a continuaci&#xF3;n se indican, donde podr&#xE1; capturar el recurso Jibia: a) En el &#xE1;rea mar&#xED;tima de la VI a la IX Regi&#xF3;n y la X Regi&#xF3;n, con cerco, y b) En el &#xE1;rea mar&#xED;tima de la IV a la IX Regi&#xF3;n y la X Regi&#xF3;n, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua.</div><br></div>", "i": 7310511}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de marzo de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7310512}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "885", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-885"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-03-30", "fecha_derogacion": "2007-12-21", "doble_articulado": false, "id_norma": "223539", "numero_fuente": "37834", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-04-13", "vigencias": [{"desde": "2007-12-21", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-04-13", "hasta": "2007-12-20", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2007-12-21", "fin_vigen