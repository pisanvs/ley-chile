{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8301231}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 139, de 31 de enero de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case la Resoluci&#xF3;n N&#xBA; 2.205 de 1996, de esta Subsecretar&#xED;a, que fij&#xF3; la n&#xF3;mina de armadores y embarcaciones habilitados para operar en la unidad de pesquer&#xED;a de Anchoveta y Sardina espa&#xF1;ola, se&#xF1;alada en el art&#xED;culo primero del D.S. N&#xBA; 493 de 1996, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, en el sentido de se&#xF1;alar que el armador de la nave &quot;Zonace I&quot; es Pesquera Tarapac&#xE1; S.A., y no Empresa Pesquera Zona Central S.A. como all&#xED; se indica.</div><br><br></div>", "i": 8301232}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de enero de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br><br></div>", "i": 8301233}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "139", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-139"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ARMADORES INDUSTRIALES", "NOMINA", "ANCHOVETA", "SARDINA ESPA OLA", "UNIDAD DE PESQUERIA", "EMBARCACIONES", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-01-31", "fecha_derogacion": "1997-07-17", "doble_articulado": false, "id_norma": "60885", "numero_fuente": "35687", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-02-