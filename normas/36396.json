{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8296104}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.162, 07 de Diciembre de 1994 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case la Resoluci&#xF3;n N&#xB0; 1070, de 1994, que autoriz&#xF3; a la SOCIEDAD LUNA Y GALAZ LTDA., para realizar faenas de captura, en el sentido de reemplazar el inciso primero del numeral 2&#xB0; por el siguiente &quot;La captura del Ping&#xFC;ino rey se efectuar&#xE1; en el &#xE1;rea de Bah&#xED;a In&#xFA;til, Isla Grande de Tierra del Fuego, XII Regi&#xF3;n, durante el mes de diciembre de 1994&quot;. </div></div>", "i": 8296105, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 7 de diciembre de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8296106}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1162", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1162"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD LUNA GALAZ LTDA", "PESCA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-12-07", "doble_articulado": false, "id_norma": "36396", "numero_fuente": "35046", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-12-21", "vigencias": [{"desde": "1994-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-12-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-12-21", "fin_vigencia": "", "tipo_version":