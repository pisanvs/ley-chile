{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 5.193 EXENTA, DE 2007 </div></div>", "i": 6621185}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 5.193, de 26 de junio del 2007, se han modificado las resoluciones exentas de Educaci&#xF3;n N&#xBA;s. 835, de 2001, 443, de 2002 y 6.750, de 2004, que aprobaron planes y programas especiales de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media al Colegio de los Sagrados Corazones del Arzobispado de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los cursos de 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media del Subsector &quot;Desarrollo del Pensamiento Cristiano&quot;.</div><br></div>", "i": 6621186}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de agosto de 2007.- M&#xF3;nica Luna Gonz&#xE1;lez, Jefa Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6621187}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5193 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5193 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 5.193 EXENTA, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-26", "doble_articulado": false, "id_norma": "264007", "numero_fuente": "38844", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-08-22", "vigencias": [{"desde": "2007-08-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-08-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_