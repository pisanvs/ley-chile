{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ESCUELA NORMAL DE PRECEPTORAS DE SANTIAGO Lei n&#xFA;m. 226.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de doscientos cincuentas mil pesos ($ 250,000) en la reconstruccion de un edificio destinado a la Escuela Normal de Preceptoras de Santiago.</div><br></div>", "i": 5947219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 26 de Diciembre de 1894.- JORJE MONTT.-O. Renjifo.</div><br></div>", "i": 5947220}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "226", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-226"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "ESCUELA NORMAL DE PRECEPTORAS DE SANTIAGO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ESCUELA NORMAL PRECEPTORAS", "SANTIAGO", "EDIFICIO", "RECONSTRUCCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-12-26", "doble_articulado": false, "id_norma": "22082", "numero_fuente": "4998", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-12-26", "vigencias": [{"desde": "1894-12-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-12-26", "fin_vigencia": ""},