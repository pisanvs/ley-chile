{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 1.571 EXENTA, DE 2011</div><br></div>", "i": 9163957}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Res ex. N&#xBA; 1.571, de 2011, autoriza al siguiente taller para adecuar veh&#xED;culos al uso de gas licuado de petr&#xF3;leo como combustible:</div><br><br><div class=\"p\">&nbsp; Empresa&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Nombre del Taller&nbsp; &nbsp; &nbsp;  Direcci&#xF3;n del&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Ciudad</div><div class=\"p\">&nbsp; Habilitada&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Taller</div><div class=\"p\">&nbsp; Emaserv S.A.&nbsp; &nbsp; &nbsp;  Bosch Car Service&nbsp; &nbsp; &nbsp;  Caupolic&#xE1;n&nbsp; N&#xB0; 648&nbsp; &nbsp;  Temuco</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  esquina Lauraro</div><br><div class=\"p\">&nbsp; &nbsp;  Autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.-</div></div>", "i": 9163958}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Gloria Hutt Hesse, Subsecretaria de Transportes</div><br></div>", "i": 9163959}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1571 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1571 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 1.571 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN FECHA DE PROMULGAC