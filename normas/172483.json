{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 115, DE 1987 </div></div>", "i": 6287674}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 115 de 10 de junio de 1987 se ha aprobado, a contar del presente a&#xF1;o escolar, Plan Experimental de Estudio de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica para Adultos el que se desarrollar&#xE1; a trav&#xE9;s de la metodolog&#xED;a de Educaci&#xF3;n Abierta.</div><div class=\"p\">&nbsp; &nbsp;  El plan de estudio aprobado se impartir&#xE1; experimentalmente en establecimientos educacionales de las Regiones Quinta y Metropolitana.</div><br></div>", "i": 6287675}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de Junio de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6287676}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "115 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-115 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 115, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-10", "doble_articulado": false, "id_norma": "172483", "numero_fuente": "32808", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-01", "vigencias": [{"desde": "1987-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion