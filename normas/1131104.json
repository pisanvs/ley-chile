{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10019354}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (Exento) N&#xB0; 177 de 03 de abril de 2019, se dej&#xF3; sin efecto parcialmente el <a href=\"https://www.leychile.cl/Navegar?idNorma=1106513&amp;idParte=&amp;idVersion=\">Decreto MOP (Exento) N&#xB0; 807 de 21 de julio de 2017</a>, s&#xF3;lo en lo relativo a la expropiaci&#xF3;n del lote N&#xB0; 12, en el resto permanece plenamente vigente el Decreto MOP (Exento) N&#xB0; 807 21 de julio de 2017, en lo que respecta a la expropiaci&#xF3;n del lote N&#xB0; 15, necesario para la obra REPOSICION RUTA 148 SECTOR: CRUCE RUTA 5 - PUENTE QUEIME, COMUNA DE BULNES, PROVINCIA DE DIGUILLIN, REGI&#xD3;N DE &#xD1;UBLE. (ANTES PROVINCIA DE &#xD1;UBLE, REGION DEL BIO BIO). La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xB0; del Decreto Ley N&#xB0; 2186, de 1978. </div></div>", "i": 10019355}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10019356}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "177 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-177 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1582917", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-04-03", "doble_articulado": false, "id_norma": "1131104", "numero_fuente": "42343", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-05-02", "vigencias": [{"desde": "2019-05-02",