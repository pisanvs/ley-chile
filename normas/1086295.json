{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 7.955 EXENTA, DE 17 DE DICIEMBRE DE 2015, QUE MODIFICA PLANES Y PROGRAMAS QUE INDICA</div></div>", "i": 9664664}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=197457&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.561, de 2002, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; plan y programas especiales de estudio de 1&#xBA; y 2&#xBA; a&#xF1;o de Educaci&#xF3;n Media al Colegio Francisco de Miranda, comuna de Pe&#xF1;alol&#xE9;n, provincia de Santiago, Regi&#xF3;n Metropolitana.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para 3er a&#xF1;o de Educaci&#xF3;n Media de los sectores que se indican en la presente resoluci&#xF3;n exenta.</div></div>", "i": 9664665}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de diciembre de 2015.- Gonzalo Mu&#xF1;oz Stuardo, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 9664666}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7955 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-7955 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 7.955 EXENTA, DE 17 DE DICIEMBRE DE 2015, QUE MODIFICA PLANES Y PROGRAMAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 984760", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-12-22", "doble_articulado": false, "id_norma": "1086295", "numero_fuente": "4