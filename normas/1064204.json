{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 1 EXENTA, DE 2014</div></div>", "i": 9486746}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.702, de 2 de julio de 2014, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1060528&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1</a> de 2014 en el sentido de se&#xF1;alar que la cuota del segundo semestre correspondiente a la flota constituida por embarcaciones de eslora menor o igual a 12 metros se distribuir&#xE1; mensualmente de la siguiente manera:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/41154.jpg\">.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9486747}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de julio de 2014.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9486748}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1702 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1702 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 1 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacio