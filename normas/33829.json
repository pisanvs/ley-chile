{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291196}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 224, de 7 de Marzo de 1995, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, se deneg&#xF3; la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por don EDUARDO</div><div class=\"p\">ALFREDO FRENE HAUSDORF, para un sector ubicado en San</div><div class=\"p\">Jos&#xE9;, Canal Quihua, Comuna de Calbuco, Provincia de</div><div class=\"p\">Llanquihue, X Regi&#xF3;n, en virtud de lo dispuesto en los</div><div class=\"p\">art&#xED;culos 76&#xB0;, 77&#xB0;, 78&#xB0; y 5&#xB0; transitorio inciso 6&#xB0;, de la Ley General de Pesca y Acuicultura y el art&#xED;culo 14&#xB0; del D.S. N&#xB0; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. Asimismo, se dej&#xF3; sin efecto la Resoluci&#xF3;n N&#xB0; 88, de 1991, de esta Subsecretar&#xED;a. </div></div>", "i": 8291197}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 7 de Marzo de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8291198}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "224", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-224"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "ACUICULTURA", "EDUARDO ALFREDO FRENE", "HAUSDORF"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-03-07", "doble_articulado": false, "id_norma": "33829", "numero_fuente": "35117", "tipo_version