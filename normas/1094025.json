{"html": [{"t": "<div><br><div class=\"p\">HABILITA PROVISORIAMENTE LA RAMPA PUNTA MALDONADO, EN EL LAGO TAGUA TAGUA, COMUNA DE COCHAM&#xD3;</div></div>", "i": 9724926}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n C.P. Cocham&#xF3; Ord. N&#xBA; 12.600/08, del 11 de agosto de 2016, se habilita provisoriamente la rampa Punta Maldonado, en el Lago Tagua Tagua, comuna de Cocham&#xF3;.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta Circular Mar&#xED;tima Local, se encuentra publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl) Usuario Mar&#xED;timo - Resoluciones Locales.</div></div>", "i": 9724927}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Cocham&#xF3;, 17 de agosto de 2016.- V&#xED;ctor Turra Gonz&#xE1;lez, Sargento Primero L (SEG.M), Capit&#xE1;n de Puerto de Cocham&#xF3;. </div></div>", "i": 9724928}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-8"}, {"tipo": "3", "numero": "12600/08", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-12600/08"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y MARINA MERCANTE", "GOBERNACIÓN MARÍTIMA DE PUERTO MONTT", "CAPITANÍA DE PUERTO DE COCHAMÓ"], "titulo_norma": "HABILITA PROVISORIAMENTE LA RAMPA PUNTA MALDONADO, EN EL LAGO TAGUA TAGUA, COMUNA DE COCHAMÓ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1103049; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-08-11", "doble_articulado": fal