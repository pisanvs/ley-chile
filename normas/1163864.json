{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div><br></div>", "i": 10260806}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 463, del 31 de marzo de 2021, Serviu Regi&#xF3;n del Libertador General Bernardo O&apos;Higgins orden&#xF3; la Rectificaci&#xF3;n de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1139268&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 2.565, de fecha 20 de noviembre de 2019</a>, en el sentido de modificar la superficie a expropiar en el inmueble de aparente dominio de Massai Agricultural Services S.A., ubicado en Avda. Pdte. S. Allende G. N&#xB0; 1101 LT3, comuna de Rancagua, rol de aval&#xFA;o 96-3, individualizado como el lote 96-3 en plano de expropiaciones del proyecto &quot;Ampliaci&#xF3;n Avenida Baquedano&quot; en la comuna de Rancagua. Quedando el inmueble individualizado con una superficie expropiada de 1.069,86 m&#xB2; y un monto de indemnizaci&#xF3;n provisoria de $115.690.000.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10260807}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n del Libertador General Bernardo O&apos;Higgins.</div><br></div>", "i": 10260808}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "463 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-463 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DEL LIBERTADOR GENERAL BERNARDO O'HIGGINS"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1988328", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-03-31", "doble_artic