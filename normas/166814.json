{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7268288}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 147 de 31 de Enero de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a don ULISES ROMERO BORNE, R.U.T. No. 5.482.009-7, domiciliado en Constituci&#xF3;n, Ega&#xF1;a No. 368, para ampliar actividades pesqueras que tiene autorizadas por resoluci&#xF3;n No. 1165, de 1989, de esta Subsecretar&#xED;a, podr&#xE1; extraer con la embarcaci&#xF3;n &quot;Punta del Este&quot; autorizada por la resoluci&#xF3;n citada, el recurso pez espada, en el litoral de las Regiones I a X.</div><div class=\"p\">&nbsp; &nbsp;  La presente autorizaci&#xF3;n es sin perjuicio de las que corresponda conferir a otras autoridades, de acuerdo a las disposiciones legales o reglamentarias vigentes o que se establezcan.</div><br></div>", "i": 7268289}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de Enero de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 7268290}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "147", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-147"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-01-31", "fecha_derogacion": "2000-10-04", "doble_articulado": false, "id_norma": "166814", "numero_fuente": "33908", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-03-02", "vigencias": [{"desde": "2000-10-04", "hast