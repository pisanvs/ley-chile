{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 78, DE 1992 </div></div>", "i": 6053690}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 78 de 31 de marzo de 1992 se ha aprobado al Colegio Rancagua College, de Rancagua, VI Regi&#xF3;n, un plan especial de estudio para los cursos de educaci&#xF3;n b&#xE1;sica y educaci&#xF3;n media human&#xED;stico-cient&#xED;fica, a partir del a&#xF1;o escolar 1992, que se aplicar&#xE1; en todos los cursos simult&#xE1;neamente, a excepci&#xF3;n del 4&#xB0; a&#xF1;o medio que se aplicar&#xE1; en el a&#xF1;o 1993. </div></div>", "i": 6053691}, {"t": "<div><div class=\"p\">Santiago, 30 de Abril de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6053692}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "78 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-78 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 78, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-03-31", "doble_articulado": false, "id_norma": "78929", "numero_fuente": "34269", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-05-18", "vigencias": [{"desde": "1992-05-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-05-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-05-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "ALV", "fecha_ingreso": "1997-12-05", "fe