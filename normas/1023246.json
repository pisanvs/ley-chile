{"html": [{"t": "<div><br><div class=\"p\">SUPRIME DEPARTAMENTO TRIBUNAL TRIBUTARIO Y CREA DEPARTAMENTO QUE INDICA</div><br></div>", "i": 9114412}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 24, de 17 de febrero de 2011, que se&#xF1;ala:</div><div class=\"p\">&nbsp; &nbsp;  Suprime Departamento Tribunal Tributario y crea Departamento de Procedimientos Administrativos Tributarios en la VII Direcci&#xF3;n Regional Talca; deja sin efecto autorizaci&#xF3;n para delegar facultades y autoriza delegaci&#xF3;n de facultades que indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en febrero de 2011.</div></div>", "i": 9114413}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "24 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-24 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "SUPRIME DEPARTAMENTO TRIBUNAL TRIBUTARIO Y CREA DEPARTAMENTO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-02-17", "doble_articulado": false, "id_norma": "1023246", "numero_fuente": "39892", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-02-22", "vigencias": [{"desde": "2011-02-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-02-22", "fin_vigencia": ""}, "vigencias_version_no