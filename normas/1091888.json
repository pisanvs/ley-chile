{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETO&nbsp; N&#xBA; 1.184 EXENTO, DE 2015, DEL MINISTERIO DE ECONOM&#xCD;A, FOMENTO Y TURISMO</div></div>", "i": 9711013}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 474, de 17 de junio de 2016, de este Ministerio, modif&#xED;case el <a href=\"https://www.leychile.cl/Navegar?idNorma=1085835&amp;idParte=0&amp;idVersion=\">decreto exento N&#xBA; 1.184, de 2015</a>, en el sentido de se&#xF1;alar que la cuota anual de captura de la unidad de pesquer&#xED;a de Anchoveta a&#xF1;o 2016, ascender&#xE1; a 34.600 toneladas, fraccionadas de la siguiente manera:</div><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/58751.jpg\">.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9711014}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de junio de 2016.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9711015}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "474 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-474 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA DECRETO Nº 1.184 EXENTO, DE 2015, DEL MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1036871; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-06-17", "doble_articulado": f