{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DISPONE EXPROPIACIONES PARCIALES QUE SE&#xD1;ALA </div></div>", "i": 5853086}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Decreto 601, 26 abril 1996, Alcalde Municipalidad Puc&#xF3;n, dispone expropiaci&#xF3;n parcial conforme D.F.L. 458 de 1976, Ley 18.695 y D.L. 2.186 de 1978, inmueble dominio aparente de Rafael Aburto Paillalef, inscrito fojas 240 N&#xB0; 226 Registro Propiedad Puc&#xF3;n 1992, Rol aval&#xFA;o 114-9, superficie aproximada 2.184 m2. Deslindes: Norte: en 91 metros con el mismo propietario; Sur: el mismo propietario en 91 metros; Oriente: en 24 metros con propiedad de Luis Alberto Colipe Aburto; Poniente: en 24 metros con propiedad de Felipe Aburto Paillalef. Indemnizaci&#xF3;n provisional $4.149.600.- Pagadera contado. </div></div>", "i": 5853087}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Carlos Barra Matamala, Alcalde de Puc&#xF3;n. </div></div>", "i": 5853088}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "601", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-601"}], "organismos": ["MUNICIPALIDAD DE PUCÓN"], "titulo_norma": "DISPONE EXPROPIACIONES PARCIALES QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "PUCON", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-04-26", "doble_articulado": false, "id_norma": "2544", "numero_fuente": "35481-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-06-01", "vigencias": [{"desde": "1996-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc