{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 279.- Santiago, 5 de Noviembre de 1993.- Vistos: Lo dispuesto en el art&#xED;culo 11 del Decreto Ley N&#xB0;2.974 de 1979.</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 6008837}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del Decreto Ley citado, en la VI Regi&#xF3;n al se&#xF1;or:</div><div class=\"p\">&nbsp; &nbsp; Juan Fernando V&#xE9;liz Melo.</div><br></div>", "i": 6008838}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hugo Ortega Tello, Director Nacional. Lo que transcribo a Ud. para su conocimiento.- Oficial de Partes.</div><br></div>", "i": 6008839}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "279", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-279"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECEPTOR JUDICIAL", "CARGOS JUDICIALES", "NOMBRAMIENTO", "JUAN FERNANDO VELIZ MELO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-11-05", "doble_articulado": false, "id_norma": "34132", "numero_fuente": "34734", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-12-06", "vigencias": [{"desde": "1993-12-06", "hasta": "", "tipo_