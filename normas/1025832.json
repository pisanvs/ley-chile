{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 978 EXENTO, DE 20 DE MAYO DE 2011</div></div>", "i": 9144420}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta que se indica del Ministerio de Educaci&#xF3;n, se aprueban las modificaciones introducidas al plan y programas de estudio del Centro de Formaci&#xF3;n T&#xE9;cnica Centro de Ense&#xF1;anza de Alta Costura Paulina Diard, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, las que podr&#xE1;n impartirse a contar del a&#xF1;o 2011, en la Sede Central de Santiago.</div><br><div class=\"p\">Carrera&nbsp;  :&nbsp; &nbsp; Dise&#xF1;o de vestuario, moldaje y confecci&#xF3;n</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; :&nbsp; &nbsp; T&#xE9;cnico de Nivel Superior en Dise&#xF1;o de </div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Vestuario, Moldaje y Confecci&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  (<a href=\"https://www.leychile.cl/Navegar?idNorma=259779&amp;idParte=0&amp;idVersion=\">Dex. N&#xBA; 334 de 18.01.07</a>)</div></div>", "i": 9144421}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de mayo de 2011.- Fernando Rojas Ochagav&#xED;a, Subsecretario de Educaci&#xF3;n.</div></div>", "i": 9144422}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "978 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-978 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 978 EXENTO, DE 20 DE MAYO DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2011-05-20", "fecha_derogacion": "202