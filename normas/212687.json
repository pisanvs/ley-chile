{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7301737}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.597, de 11 de julio de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 511 de 1996, de esta Subsecretar&#xED;a, y que autoriz&#xF3; a PESQUERA YELCHO S.A. para realizar actividades pesqueras con la nave &quot;Gualas&quot;, s&#xF3;lo en cuanto se rectifican las siguientes caracter&#xED;sticas n&#xE1;uticas de &#xE9;sta:</div><br><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp;  81,70 m</div><div class=\"p\">TRG (Internacional)&nbsp; &nbsp; 2574,00</div><div class=\"p\">Potencia principal&nbsp; &nbsp;  4500,00 hp</div><div class=\"p\">Potencia auxiliar&nbsp; &nbsp; &nbsp; 1630,00 hp.</div><br></div>", "i": 7301738}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de julio de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7301739}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1597 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1597 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-07-11", "fecha_derogacion": "2004-04-30", "doble_articulado": false, "id_norma": "212687", "numero_fuente": "37612", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-07-18", "vigencias": [{"desde": "2004-04-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-07-18", "has