{"html": [{"t": "<div><div class=\"p\">EXTRACTO&nbsp; DE&nbsp; DECRETO&nbsp; N&#xBA;361&nbsp; EXENTO,&nbsp; DE 1998</div><br></div>", "i": 6293933}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 361 de fecha 3 de marzo de 1998 del Ministerio de Educaci&#xF3;n, se rectific&#xF3; el decreto exento N&#xBA; 397 del 15 de abril de 1997, del Ministerio de Educaci&#xF3;n, correspondiente al Instituto Profesional Cepech, en el sentido de se&#xF1;alar que la carrera de Auditor&#xED;a, aprobada por Acuerdo del Consejo Superior de Educaci&#xF3;n, en enero de 1997, es impartida en jornada diurna.</div><br></div>", "i": 6293934}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de marzo de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6293935}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "361 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-361 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº361 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-03-03", "doble_articulado": false, "id_norma": "173548", "numero_fuente": "36727", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-31", "vigencias": [{"desde": "2000-07-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-07-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2000-07-