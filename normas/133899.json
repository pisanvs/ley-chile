{"html": [{"t": "<div><div class=\"p\">APRUEBA ORDENANZA MUNICIPAL QUE INDICA </div></div>", "i": 6160462}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante decreto exento No. 1 de fecha 29.02.88, de la Ilustre Municipalidad de Parral se aprob&#xF3; la Ordenanza Municipal sobre Funcionamiento del Terminal de Buses de Locomoci&#xF3;n Colectiva no Urbana de la Comuna de Parral, dictada en cumplimiento a las disposiciones del Decreto Supremo No. 94 de fecha 10.04.85, del Ministerio de Transportes y Telecomunicaciones y Circular No. L-52 de fecha 19.08.85, del Ministerio del Interior. Dicha Ordenanza consta de 32 art&#xED;culos y empez&#xF3; a regir con fecha 22 de Marzo de 1988.-</div><br></div>", "i": 6160463}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alfonso Rodr&#xED;guez del R&#xED;o, Alcalde de Parral.- Juan Carlos Alvarez Maigret, Secretario Municipal. </div></div>", "i": 6160464}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1 EXENTO"}], "organismos": ["MUNICIPALIDAD DE PARRAL"], "titulo_norma": "APRUEBA ORDENANZA MUNICIPAL QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-02-29", "doble_articulado": false, "id_norma": "133899", "numero_fuente": "33048", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-04-18", "vigencias": [{"desde": "1988-04-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-04-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-04-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [