{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUA EN COMUNA DE LOS</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; ANGELES</div><br></div>", "i": 6538275}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xBA; 2.070 del 5 de mayo de 2005, modificada por resoluci&#xF3;n exenta N&#xBA; 4.440 de 19 de agosto de 2005, conforme art&#xED;culo 5&#xBA; transitorio C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento de aguas del predio &quot;Santa Juana de Huaqui, hoy Santa Elcira&quot;, de la comuna de Los Angeles, provincia de B&#xED;o B&#xED;o, VIII Regi&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Los derechos de aprovechamiento de aguas son 279 lts/seg. del Estero Paso Cerrado, conducidos por el canal Santa Elcira Norte o canal Paso Cerrado, y son consuntivos y de ejercicio permanente y continuo. Publicaci&#xF3;n hecha conforme art&#xED;culo 13&#xBA; ley N&#xBA; 18.377.- </div></div>", "i": 6538276}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Nacional.</div><br></div>", "i": 6538277}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2070 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2070 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUA EN COMUNA DE LOS ANGELES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-05-05", "doble_articulado": false, "id_norma": "241462", "numero_fuente": "38251", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-09-01", "vigencias": [{"desde": "2005-09-01