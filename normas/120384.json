{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xBA; 1.929</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Comit&#xE9; Ejecutivo de este Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 1.929, celebrada el 26 de abril de 1989, adopt&#xF3; el siguiente acuerdo:</div><br></div>", "i": 6116054}, {"t": "<div><div class=\"p\">1929-05-880426- Modifica Cap&#xED;tulo III.C.2 del Compendio de Normas Financieras.</div><br><div class=\"p\">Se acord&#xF3; sustituir en el n&#xFA;mero 2 del Cap&#xED;tulo III.C.2 &quot;Normas que rigen a las Cooperativas de Ahorro y Cr&#xE9;dito&quot; del Compendio de Normas Financieras, la expresi&#xF3;n &quot;1,25 veces&quot; por &quot;1,5 veces&quot;.</div><br></div>", "i": 6116055}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de abril de 1989.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6116056}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1929", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1929"}, {"tipo": "5", "numero": "1929-05", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1929-05"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDO ADOPTADO POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION Nº 1.929", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-04-26", "doble_articulado": false, "id_norma": "120384", "numero_fuente": "33358", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-04-27", "vigencias": [{"desde": "1989-04-27", "hasta": "", "tipo_version": "3", "tipo_