{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8296122}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.167, de 7 de Diciembre de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2&#xB0; de la Resoluci&#xF3;n N&#xB0; 1.408, de 1992, modificada por Resoluci&#xF3;n N&#xB0; 255, de 1994, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA SANTA BERNARDITA LIMITADA, R.U.T. N&#xB0; 79.577.700-8, para operar la nave &quot;Mar&#xED;a Bernardita&quot;, matr&#xED;cula N&#xB0; 2869, en el sentido de incluir, adem&#xE1;s del recurso objetivo all&#xED; autorizado, las especies que constituyen su fauna acompa&#xF1;ante y que son las siguientes: Agujilla, Anchoveta, Caballa, Merluza de cola, Sardina y Sardina com&#xFA;n.</div><br></div>", "i": 8296123}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 7 de Diciembre de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8296124}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1167", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1167"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA SANTA BERNARDITA LIMITADA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-12-07", "fecha_derogacion": "1995-05-27", "doble_articulado": false, "id_norma": "36402", "numero_fuente": "35047", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-12-22", "vigencias": [{"desde": "1995-05-27",