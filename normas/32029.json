{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m 10.- Santiago, 19 de Enero de 1994.- Vistos: Lo dispuesto en el Art. 11 del Decreto Ley N&#xB0; 2.974 de 1979.</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 6002677}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del Decreto Ley citado, en la IV Regi&#xF3;n al se&#xF1;or:</div><div class=\"p\">&nbsp; &nbsp; - Rafael Verdugo Verdugo </div></div>", "i": 6002678}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Alfonso Jasmen Correa, Director Nacional (S).</div><br></div>", "i": 6002679}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-10"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECEPTOR JUDICIAL", "CARGOS JUDICIALES", "NOMBRAMIENTO", "RAFAEL VERDUGO VERDUGO", "CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-01-19", "doble_articulado": false, "id_norma": "32029", "numero_fuente": "34795", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-02-19", "vigencias": [{"desde": "1994-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vi