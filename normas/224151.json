{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6475030}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 994, de 13 de abril de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a CORPESCA S.A. para realizar actividades extractivas en aguas internacionales, en orden a operar la nave &quot;Pica&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; CB-2945</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  2395</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; 22,25 m.</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  6,65 m.</div><div class=\"p\">Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 3,00 m.</div><div class=\"p\">T.R.G.</div><div class=\"p\">(Internacional)&nbsp; &nbsp; &nbsp;  98,94</div><div class=\"p\">Capacidad de bodega&nbsp;  140,50 m3</div><br><br></div>", "i": 6475031}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de abril de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6475032}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "994", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-994"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-13", "doble_articulado": false, "id_norma": "224151", "numero_fuente": "37843", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-23", "vigencias": [{"desde"