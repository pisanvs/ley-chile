{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6276829}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.353 de fecha 09 de Octubre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a la Sociedad de la Fuente Hermanos Limitada, Juan de la Fuente Mart&#xED;nez y a don F&#xE9;lix Marcelo de la Fuente Mart&#xED;nez, para efectuar todo tipo de servicios de transporte de pasajeros, por calles y caminos, dentro del territorio nacional a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6276830}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Octubre de 1987.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6276831}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1353 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1353 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-10-09", "doble_articulado": false, "id_norma": "169174", "numero_fuente": "32914", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-07", "vigencias": [{"desde": "1987-11-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-07", "fin_vigen