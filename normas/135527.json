{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,514.- Santiago, 3 de enero de 1902.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6165692}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- El montep&#xED;o de que disfrutar&#xE1;n la viuda e hijos del capitan de nav&#xED;o de la Armada don Ramon Vidal Gormaz, ser&#xE1; el que corresponde al empleo de contra-almirante, del cual gozar&#xE1;n con arreglo a la lei de 6 de agosto de 1855, i con esclusion de toda otra asignacion fiscal.</div><br></div>", "i": 6165693}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Beltran Mathieu.</div><br></div>", "i": 6165694}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1514", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1514"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1902-01-03", "doble_articulado": false, "id_norma": "135527", "numero_fuente": "7113", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1902-01-04", "vigencias": [{"desde": "1902-01-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1902-01-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1902-01-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "