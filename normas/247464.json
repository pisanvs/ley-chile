{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6562013}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 406, de 6 de febrero de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BIO BIO S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Gardar&quot;, en el &#xE1;rea mar&#xED;tima correspondiente al Archipi&#xE9;lago de Juan Fern&#xE1;ndez, Isla de Pascua, Isla Sala y G&#xF3;mez e Islas Desventuradas, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar, con cerco, el recurso hidrobiol&#xF3;gico Jurelillo de Juan Fern&#xE1;ndez.</div><br></div>", "i": 6562014}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de febrero de 2006.- Edith Saa Collantes, Subsecretario de Pesca (S).</div><br></div>", "i": 6562015}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "406 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-406 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2006-02-06", "fecha_derogacion": "2006-08-07", "doble_articulado": false, "id_norma": "247464", "numero_fuente": "38395", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2006-02-21", "vigencias": [{"desde": "2006-08-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2006-02-21", "hasta": "2006-08-06", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2006-08-07", "fin_vigencia": ""}, "vigencias_version_nor