{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 295 EXENTO, DE 1996 </div></div>", "i": 5943566}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 295, de fecha 27 de mayo de 1996, del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a la Sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica Inacap, para impartir planes y programas de estudios aprobados para la instituci&#xF3;n, de las carreras y t&#xED;tulos t&#xE9;cnicos de nivel superior que se se&#xF1;alan, a partir del a&#xF1;o 1996:</div><div class=\"p\"> Sede N&#xB0; 9 - Renca</div><div class=\"p\"> Carrera&nbsp; &nbsp; : Programaci&#xF3;n de Computadores</div><div class=\"p\"> T&#xED;tulo&nbsp; &nbsp;  : T&#xE9;cnico en Programaci&#xF3;n de Computadores</div><div class=\"p\"> Carrera&nbsp; &nbsp; : Administraci&#xF3;n de Empresas</div><div class=\"p\"> T&#xED;tulo&nbsp; &nbsp;  : T&#xE9;cnico en Administraci&#xF3;n de Empresas</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; con menci&#xF3;n en Marketing, Finanzas o</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Personal</div><br></div>", "i": 5943567}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 13 de junio de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943568}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "295", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-295"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 295 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA INACAP", "PROGRAMAS ESTUDIO", "PLANES ESTUDIO", "RENCA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observ