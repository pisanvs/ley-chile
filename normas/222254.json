{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br></div>", "i": 6468261}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 15, de fecha 14 de Marzo de 1983, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se ha autoriza al Sr. Dagoberto Soto Gonz&#xE1;lez para efectuar todo tipo de servicios de transportes de pasajeros por las calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros, de acuerdo al D.S. N&#xBA; 100-82.</div><br></div>", "i": 6468262}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Puerto Montt, 14 de Marzo de 1983.- Enrique Brintrup Barrera, Secretario Regional Ministerial, Transp. y Telec. X Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6468263}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "15 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-15 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1983-03-14", "doble_articulado": false, "id_norma": "222254", "numero_fuente": "31563", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1983-05-10", "vigencias": [{"desde": "1983-05-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1983-05-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1983