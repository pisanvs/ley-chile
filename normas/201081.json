{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 541 EXENTO, DE 2002 </div></div>", "i": 6391047}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 541 de fecha 24 de junio de 2002, de Educaci&#xF3;n, se declara aprobada a la Universidad de Ciencias de la Inform&#xE1;tica la modificaci&#xF3;n al Plan y a los Programas de estudio de la carrera de Ingenier&#xED;a Civil en Inform&#xE1;tica, la que se imparte en jornada diurna en su sede de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, dicha modificaci&#xF3;n rige a contar del segundo semestre del a&#xF1;o 2002.</div><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase presente para todos los efectos legales y administrativos.</div><br></div>", "i": 6391048}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de julio de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6391049}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "541 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-541 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 541 EXENTO, DE 2002", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-06-24", "fecha_derogacion": "2020-01-01", "doble_articulado": false, "id_norma": "201081", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-08-02", "vigencias": [{"desde": "2020-01-01", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2002-08-02", "hasta": "2019-12-31", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2020-01-01", "fin_vigenc