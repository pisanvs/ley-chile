{"html": [{"t": "<div><div class=\"p\">REMATES</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Enero 24 de 1826. </div><br><div class=\"p\">&nbsp; &nbsp;  El Consejo Directorial ha sido instruido, que la Junta de almonedas hace publicar las propuestas antes de tiempo, y que de otras aun sin publicarse, se sabe su contenido, por cuanto quedan abiertas y sin custodiarse. En su consecuencia ha acordado y decreta lo siguiente:</div></div>", "i": 10196931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Prev&#xE9;ngase a la Junta de almonedas que no publique las propuestas hasta despues de apercibir de remate, y que las que queden abiertas por no haber alguna ventajosa se guarden bajo de llave. Trascribase a la Junta para su cumplimiento, y t&#xF3;mese razon en la Contadur&#xED;a mayor.</div></div>", "i": 10196932}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  INFANTE.</div><div class=\"p\">&nbsp; &nbsp;  Gandarillas.</div></div>", "i": 10196933}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "REMATES", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1826-01-24", "doble_articulado": false, "id_norma": "1152010", "numero_fuente": "1826", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1826-01-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1826-01-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1826-01-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-01-28", "fecha_version": "1826-01-24", "fecha_actualizacion_texto": "2021-01-28", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10196931}, {"n": "Artículo", "i": 10196932, "t": 6}, {"n": "Promulgación", "i": 10196933}]}