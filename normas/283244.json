{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N EXENTA N&#xBA; 7.747, DE 2008 </div></div>", "i": 7382063}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 7.747, de 28 de octubre del 2008, se ha modificado la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 14.124, de 2002, modificada por la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 10.833, de 2005, que aprob&#xF3; planes y programas especiales de estudio de 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media al Colegio &quot;The Mayflower School&quot;, de la comuna de Las Condes, de Santiago, en el sentido de sustituir el plan de estudio para 3&#xBA; y 4&#xBA; a&#xF1;o medio por el que se indica en la presente resoluci&#xF3;n.</div><br></div>", "i": 7382064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de noviembre de 2008.- Rosita Puga Hamilton, Jefa Divisi&#xF3;n de Educacion General. </div></div>", "i": 7382065}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7747 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7747 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN EXENTA Nº 7.747, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-10-28", "doble_articulado": false, "id_norma": "283244", "numero_fuente": "39235", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-12-12", "vigencias": [{"desde": "2008-12-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-12-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia":