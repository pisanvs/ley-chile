{"html": [{"t": "<div><div class=\"p\">INFORMA SOBRE NUEVA COMPOSICION DE LA DIRECTIVA CENTRAL DEL PARTIDO DEMOCRATA CRISTIANO </div></div>", "i": 6522580}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Adolfo Zald&#xED;var Larra&#xED;n y Jaime Mulet Mart&#xED;nez, Presidente y Secretario General de la Directiva Central y Jos&#xE9; Ar&#xE9;valo Medina, Presidente del Tribunal Supremo, del Partido Dem&#xF3;crata Cristiano, respectivamente, han informado el nombramiento de don Waldo Mora Longa, como Tesorero de la Directiva Central del partido, en reemplazo de don Carlos Conejeros Moroni.</div><div class=\"p\">Publicaci&#xF3;n ordenada en virtud de lo establecido en el Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por resoluci&#xF3;n O-N&#xBA; 7.196 de fecha 18 de abril de 2005.</div><br></div>", "i": 6522581}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Elizabeth Cabrera Burgos, Director (S). </div></div>", "i": 6522582}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7196", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-7196"}, {"tipo": "3", "numero": "O-7196", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-7196"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "INFORMA SOBRE NUEVA COMPOSICION DE LA DIRECTIVA CENTRAL\nDEL PARTIDO DEMOCRATA CRISTIANO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO DEMOCRATA CRISTIANO", "DIRECTIVA CENTRAL", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-04-18", "doble_articulado": false, "id_norma": "237212", "numero_fuente": "38141", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "