{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6486789}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.535, de 4 de junio de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; SALMONES PACIFIC STAR&nbsp;  S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Camino a San Antonio s/n, Quell&#xF3;n, Chilo&#xE9;, X Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n Cocido, Fresco-Refrigerado, Congelado, Seco-Salado, Ahumado, Conserva y Embutido, los recursos hidrobiol&#xF3;gicos individualizados en la resoluci&#xF3;n extractada. </div></div>", "i": 6486790}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de junio de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6486791}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1535 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1535 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-06-04", "fecha_derogacion": "2004-08-11", "doble_articulado": false, "id_norma": "227364", "numero_fuente": "37904", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-07-08", "vigencias": [{"desde": "2004-08-11", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-07-08", "hasta": "2004-08-10", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2004-08-11", "fin_vigencia": ""}, "vigencias_