{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACION DE AGENTE RETENEDOR DEL IVA A SUPERMERCADOS EL PILAR CUATRO S.A.</div><br></div>", "i": 6530251}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VII Direcci&#xF3;n Regional Talca del SII, por Res/Dre07/Ex. N&#xBA;478 de fecha 1&#xBA; junio 2005, deroga a la contribuyente Supermercados El Pilar Cuatro S.A., RUT.</div><div class=\"p\">N&#xBA;96.951.270-K, a contar del d&#xED;a 1&#xBA; del mes siguiente al de su publicaci&#xF3;n en el Diario Oficial, la Calidad de Agente Retenedor del Impuesto al Valor Agregado, en las adquisiciones de ganado vivo, de acuerdo a la facultad establecida en el dispositivo N&#xBA;18&#xBA; de la resoluci&#xF3;n exenta N&#xBA;3.721 de 28.07.2000, de la Direcci&#xF3;n Nacional. </div></div>", "i": 6530252}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Talca, 1 de junio de 2005.- Mirtha Barra Paredes, Directora Regional.</div><br></div>", "i": 6530253}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "478 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-478 EXENTA"}, {"tipo": "3", "numero": "DRE-07-478 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-07-478 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VII DIRECCIÓN REGIONAL DE TALCA"], "titulo_norma": "DEROGA AUTORIZACION DE AGENTE RETENEDOR DEL IVA A\nSUPERMERCADOS EL PILAR CUATRO S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-01", "doble_articulado": false, "id_norma": "239317", "numero_fuente": "38190", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-06-20