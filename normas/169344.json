{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6277402}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.354, de fecha 09.10.87, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a la Asociaci&#xF3;n Gremial de Transporte de Pasajeros Intercomunal 16-A, para efectuar servicio p&#xFA;blico urbano de locomoci&#xF3;n colectiva de pasajeros en el recorrido Troncal N&#xB0; 16 &quot;Vitacura - Departamental - Lo Espinoza&quot;, y la Variante N&#xB0; 16-A &quot;Vitacura Am&#xE9;rico Vespucio - Lo Espinoza&quot;, de la L&#xED;nea de Taxibuses N&#xB0; 16 &quot;Intercomunal 16&quot;, cuyo trazado se encuentra autorizado por resoluci&#xF3;n exenta N&#xB0; 403, de 14 de Mayo de 1986, de esta Secretar&#xED;a Regional.</div><br></div>", "i": 6277403}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29.10.87.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6277404}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1354 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1354 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-10-09", "doble_articulado": false, "id_norma": "169344", "numero_fuente": "32923", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "198