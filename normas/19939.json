{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 57 EXENTO, DE 1995 </div></div>", "i": 7160265}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 57 de fecha 17 de Enero de</div><div class=\"p\">1995 del Ministerio de Educaci&#xF3;n, se modific&#xF3; el</div><div class=\"p\">art&#xED;culo &#xFA;nico del Decreto Exento de Educaci&#xF3;n N&#xB0; 69 de 1988, modificado por Decreto Exento de Educaci&#xF3;n N&#xB0; 269 de 1993 que autoriz&#xF3; el funcionamiento del Instituto Profesional del Maule, en el sentido que el Instituto Profesional autorizado a funcionar en dicho Decreto pasa a denominarse, a contar de esta fecha, Instituto Profesional del Valle Central.</div><br></div>", "i": 7160266}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 26 de Enero de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160267}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "57 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-57 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 57 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO PROFESIONAL MAULE", "CAMBIO NOMBRE", "INSTITUTO PROFESIONAL VALLE CENTRAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-01-17", "doble_articulado": false, "id_norma": "19939", "numero_fuente": "35087", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-02-07", "vigencias": [{"desde": "1995-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-02-07", "fin_vigencia": ""}, "vigencias_versio