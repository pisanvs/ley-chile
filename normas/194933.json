{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div><br><br></div>", "i": 6370734}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA; 122, de 28 de diciembre del a&#xF1;o 2001, se autoriz&#xF3; la existencia y aprob&#xF3; el estatuto de la &quot;Cooperativa de Trabajo Diamantina Limitada&quot; de Tierra Amarilla; en los t&#xE9;rminos que da testimonio el Acta Constitutiva reducida a escritura p&#xFA;blica con fecha 1 de agosto de 2001, ante el Notario de Copiap&#xF3;, Luis Contreras Fuentes, Repertorio N&#xBA; 1.302-2001, complementada por acta protocolizada ante el mismo Notario con fecha 19 de noviembre de&nbsp; 2001 bajo el N&#xBA; 1.948-2001.</div><br></div>", "i": 6370735}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6370736}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "122", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-122"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-28", "doble_articulado": false, "id_norma": "194933", "numero_fuente": "37198", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-02-28", "vigencias": [{"desde": "2002-02-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"