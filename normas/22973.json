{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,872 que rehabilita a do&#xF1;a Juana Silva Lei n&#xFA;m. 1,872.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5952299}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Rehabil&#xED;tase a do&#xF1;a Juana Silva, madre del soldado Manuel Jesus Lazo, fallecido a consecuencias de heridas que recibi&#xF3; en la batalla de Miraflores, para que pueda tramitar su espediente de pension i acojerse a los beneficios de la lei de 22 de diciembre de 1881.</div><br></div>", "i": 5952300}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 31 de julio de 1906.- JERMAN RIESCO.- Salvador Vergara A.</div><br></div>", "i": 5952301}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1872", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1872"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "LEI NUM. 1,872 QUE REHABILITA A DOÑA JUANA SILVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUANA SILVA", "REHABILITACION POR GRACIA", "EXPEDIENTE", "PENSION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-07-31", "doble_articulado": false, "id_norma": "22973", "numero_fuente": "8827", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-06-18", "vigencias": [{"desde": "1907-06-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}]