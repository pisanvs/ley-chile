{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.864 EXENTA, DE 2005 </div></div>", "i": 6544827}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.864, de 29 de abril de 2005, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se dispuso el inicio de la puesta en marcha definitiva de la Concesi&#xF3;n Cuatro, adjudicada a &quot;Sociedad T&#xFC;v Rheinland-Acchi Limitada&quot;, para operar en la comuna de Quilicura, una Planta Revisora Clase A2, con tres (3) l&#xED;neas de revisi&#xF3;n livianas y tres (3) l&#xED;neas de revisi&#xF3;n pesadas, a contar del 30 de abril de 2005.</div><br></div>", "i": 6544828}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Silvio Albarr&#xE1;n Alb&#xE1;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6544829}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1864 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1864 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.864 EXENTA, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-04-29", "doble_articulado": false, "id_norma": "243145", "numero_fuente": "38291", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-10-20", "vigencias": [{"desde": "2005-10-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vige