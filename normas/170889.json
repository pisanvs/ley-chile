{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6281976}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.159, de 30 de marzo del 2000, se expropiaron los lotes de terreno N&#xBA;18 y 19, superficies 83.330,6 y 8.326,5 m2., roles de aval&#xFA;os en tr&#xE1;mite, comuna de Constituci&#xF3;n, para la obra Camino M-24-K Quivolgo-Puente Lautaro, Sector B, La Trinchera-Put&#xFA; (variante costera), Km. 13,240 a Km.</div><div class=\"p\">30,000, y se acord&#xF3; precio de la indemnizaci&#xF3;n con su propietario Jos&#xE9; Mar&#xED;a Urz&#xFA;a Avenda&#xF1;o, ascendente a la cantidad de $100.144.615 para los lotes N&#xBA;s 18 y 19.- </div></div>", "i": 6281977}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6281978}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1159", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1159"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-03-30", "doble_articulado": false, "id_norma": "170889", "numero_fuente": "36690", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-15", "vigencias": [{"desde": "2000-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2000-06-16", "fecha_version": "2000-06-15", "f