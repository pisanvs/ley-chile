{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 71, DE 1982</div><br><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 53.- Santiago, 17 de Mayo de 1988.- Vistos: Lo dispuesto en el Art. 11 del Decreto Ley No. 2.974, de 1979, y lo informado por el se&#xA4;or Director de la XI Regi&#xF3;n.</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 6158500}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case la resoluci&#xF3;n No. 71 de 17 de Mayo de 1982, sobre la designaci&#xF3;n de Receptores Judiciales, en la siguiente forma:</div><div class=\"p\">Se elimina a don Luis Astorga Gonz&#xE1;lez.</div><div class=\"p\">Se designan como Receptores Judiciales a los se&#xF1;ores: Mois&#xE9;s Espinoza Arriagada y Eugenio Pellon Castilla, para que act&#xA3;en en la XI Regi&#xF3;n.</div><br></div>", "i": 6158501}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Sergio Retamal Iglesias, Vicepresidente Ejecutivo.</div><br></div>", "i": 6158502}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "53", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-53"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "MODIFICA RESOLUCION No. 71, DE 1982", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-05-17", "doble_articulado": false, "id_norma": "133246", "numero_fuente": "33110", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-07-02", "vigencias": [{"desde": "1988-07-02", "hasta": "", "tipo_version":