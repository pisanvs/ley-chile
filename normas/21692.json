{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 686 EXENTO, DE 1994 </div></div>", "i": 7162217}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 686 de 30 de Diciembre de 1994, se ha modificado, a partir del presente a&#xF1;o escolar, el art&#xED;culo 1&#xB0; del Decreto Supremo Exento de Educaci&#xF3;n N&#xB0; 716 de 1993, que aprob&#xF3; planes especiales de estudio al Instituto Alem&#xE1;n de Osorno, en la forma que indica el presente decreto.</div><br></div>", "i": 7162218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 18 de Enero de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7162219}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "686 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-686 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 686 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIO", "INTITUTO ALEMAN", "OSORNO", "DECIMA", "REGION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-12-30", "doble_articulado": false, "id_norma": "21692", "numero_fuente": "35125", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-03-23", "vigencias": [{"desde": "1995-03-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-03-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-03-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "fecha_versi