{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6239006}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 38, de fecha 04 de Marzo de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la II Regi&#xF3;n, se autoriza a don Benjam&#xED;n Armando Barrios Ardiles para efectuar todo tipo de servicio de transporte de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6239007}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Guido M. Ram&#xED;rez Maturana, Secretario Regional Ministerial de transportes y Telecomunicaciones II Regi&#xF3;n.</div><br></div>", "i": 6239008}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "38 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-38 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL II REGIÓN DE ANTOFAGASTA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-03-04", "doble_articulado": false, "id_norma": "157619", "numero_fuente": "32124", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-18", "vigencias": [{"desde": "1985-03-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-03-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes"