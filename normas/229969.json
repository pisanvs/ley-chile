{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6495713}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.366, de 27 de agosto de 2004, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 639 de 2000, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a SOCIEDAD PESQUERA PACIFICO SUR S.A. para operar la nave &quot;Don Enrique&quot;, respecto del recurso hidrobiol&#xF3;gico Reineta, en el &#xE1;rea mar&#xED;tima comprendida entre la IV Regi&#xF3;n y el paralelo 41&#xBA; 28,6&apos;L.S., ello en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura. </div></div>", "i": 6495714}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de agosto de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6495715}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2366", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2366"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-08-27", "doble_articulado": false, "id_norma": "229969", "numero_fuente": "37954", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-09-04", "vigencias": [{"desde": "2004-09-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-09-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-09-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc