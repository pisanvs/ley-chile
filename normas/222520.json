{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA A TRANSPORTE AGRICOLA Y FORESTAL EL ALAMO LTDA.</div><br></div>", "i": 6469181}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del SII, por resoluci&#xF3;n DRE08/N&#xBA; Ex-216, de fecha 28 de enero de 2004, revoca a Transporte Agr&#xED;cola y Forestal El Alamo Ltda., RUT N&#xBA; 78.640.950-0, a partir del d&#xED;a 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las prestaciones de Servicios de Faenamiento de Ganado, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 16 de la resoluci&#xF3;n 3.722 del 28-07-2000, de la Direcci&#xF3;n Nacional.</div><br></div>", "i": 6469182}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Flores Guti&#xE9;rrez, Director Regional. </div></div>", "i": 6469183}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "216 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-216 EXENTA"}, {"tipo": "3", "numero": "DRE-08-216 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-216 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA A TRANSPORTE\nAGRICOLA Y FORESTAL EL ALAMO LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-28", "doble_articulado": false, "id_norma": "222520", "numero_fuente": "37812", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03