{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 241 EXENTO, DE 1996 </div></div>", "i": 8944874}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 241, de fecha 24 de abril de 1996 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Instituto AIEP, las adecuaciones a los planes y programas de estudios de las carreras de Secretariado Ejecutivo Biling&#xFC;e, de Dise&#xF1;o Gr&#xE1;fico y de Sonido, modific&#xE1;ndose, en consecuencia, la Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xB0; 1.027, de 1989, los Decretos Exentos N&#xB0; 400, de 1990, y N&#xB0; 226, de 1991, respectivamente. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1996.</div><br></div>", "i": 8944875}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 24 de mayo de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8944876}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "241 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-241 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 241 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA", "INSTITUTO AIEP", "PLANES", "ESTUDIO", "PROGRAMAS ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-04-24", "doble_articulado": false, "id_norma": "20780", "numero_fuente": "35490", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-06-13", "vigencias": [{"desde": "1996-06-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-