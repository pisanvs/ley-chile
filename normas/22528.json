{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Rehabilitacion del Teniente de Ej&#xE9;rcito don Jos&#xE9; Manuel Espiga</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,283.- Santiago, a 22 de Noviembre de 1899.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948772}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Rehabil&#xED;tase al ex-teniente de Ej&#xE9;rcito don Jos&#xE9; Manuel Espiga, para tramitar su espediente de invalidez, en conformidad a lo dispuesto en las leyes de 22 de diciembre de 1881 i 9 de Enero de 1892.</div><br><br></div>", "i": 5948773}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C&#xE1;rlos Concha.</div><br></div>", "i": 5948774}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1283", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1283"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "Rehabilitacion del Teniente de Ejército don José;Manuel Espiga", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JOSE MANUEL ESPIGA", "EXPEDIENTE", "INVALIDEZ", "REHABILITACION", "TRAMITACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-11-22", "doble_articulado": false, "id_norma": "22528", "numero_fuente": "6456", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-11-24", "vigencias": [{"desde": "1899-11-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-11-24", "fin_vige