{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION QUE INDICA</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 2.- Santiago, 14 de enero de 2004.- Visto: Lo dispuesto en el art&#xED;culo 61 de la ley N&#xBA; 19.880; la resoluci&#xF3;n Ministerial T.R. N&#xBA; 60, de 2003, y la resoluci&#xF3;n N&#xBA; 520, de 1996 de la Contralor&#xED;a General de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 6464166}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Der&#xF3;gase la resoluci&#xF3;n Ministerial T.R. N&#xBA; 60, de fecha 16 de septiembre de 2003.</div><br></div>", "i": 6464167}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, t&#xF3;mese raz&#xF3;n y notif&#xED;quese.- Jorge Rodr&#xED;guez Grossi, Ministro de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribe para su conocimiento.- Saluda atentamente a usted, Alvaro D&#xED;az P&#xE9;rez, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6464168}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "DEROGA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-14", "doble_articulado": false, "id_norma": "221144", "numero_fuente": "37785", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-13", "vigencias": [{"desde": "2004-02-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni