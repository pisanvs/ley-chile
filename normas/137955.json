{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,725.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6173702}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados al pais por don Vicente Aguirre V&#xE1;rgas, se concede a su viuda e hijas solteras una pension anual de seis mil pesos ($ 6,000).</div><br></div>", "i": 6173703}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiseis de diciembre de mil novecientos doce.- Ramon Barros Luco.- E. Villegas E.</div><br></div>", "i": 6173704}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2725", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2725"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-12-26", "doble_articulado": false, "id_norma": "137955", "numero_fuente": "10468", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1913-01-03", "vigencias": [{"desde": "1913-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1913-01-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1913-01-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-06-21", "fech