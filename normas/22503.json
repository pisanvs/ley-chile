{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Adquisicion de una propiedad en Antofagasta Lei n&#xFA;m. 1,250.- Santiago, a 28 de Agosto de 1899.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274216}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se autoriza al Presidente de la Rep&#xFA;blica para que de fondos fiscales invierta hasta la suma de treinta mil pesos en la adquisicion para el Fisco del cuartel construido por la Municipalidad de Antofagasta i que actualmente ocupa la polic&#xED;a de dicha ciudad.</div><br><br></div>", "i": 8274217}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- Federico Err&#xE1;zuriz.- R. Silva Cruz, </div></div>", "i": 8274218}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1250", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1250"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Adquisicion de una propiedad en Antofagasta", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ANTOFAGASTA", "CUARTEL POLICIA", "FISCO", "EDIFICIO", "ADQUISICION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-08-28", "doble_articulado": false, "id_norma": "22503", "numero_fuente": "6385", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-08-28", "vigencias": [{"desde": "1899-08-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-08-28", "fin_vig