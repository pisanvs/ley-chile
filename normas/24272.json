{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;mero 3,822.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7167351}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese un suplemento de tres millones setecientos treinta y cuatro mil quinientos veintiun pesos ($ 3.734,521) al &#xED;tem 84 de la partida 3.a del Presupuesto de Guerra vijente.</div><div class=\"p\">&nbsp; &nbsp; El gasto que importe esta lei, se imputar&#xE1; a la mayor entrada que la calculada proveniente del premio del oro.</div><br></div>", "i": 7167352}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintisiete de diciembre de mil novecientos veintiuno.- Arturo Alessandri.- Samuel Claro Lastarria.</div><br></div>", "i": 7167353}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3822", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3822"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GASTOS ADMINISTRACION PUBLICA", "A O", "1921", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1921-12-27", "doble_articulado": false, "id_norma": "24272", "numero_fuente": "13161", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1921-12-28", "vigencias": [{"desde": "1921-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ú