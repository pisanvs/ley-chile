{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9057678}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.288, de 29 de octubre de 2010, de esta Subsecretar&#xED;a, autor&#xED;zase a JAIME ROM&#xC1;N &#xC1;LVAREZ ARMIJO para ampliar actividades pesqueras extractivas con la nave &quot;Cazador&quot;, en el &#xE1;rea mar&#xED;tima de la V Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, con espinel, sobre el recurso hidrobiol&#xF3;gico Raya volant&#xED;n.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n exenta N&#xBA; 446 de 2010, de esta Subsecretar&#xED;a de Pesca en virtud del contenido de la presente resoluci&#xF3;n.</div></div>", "i": 9057679}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de octubre de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9057680}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3288 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3288 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2010-10-29", "fecha_derogacion": "2015-05-12", "doble_articulado": false, "id_norma": "1019366", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2010-11-15", "vigencias": [{"desde": "2015-05-12", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2010-11-15", "hasta": "2015-05-11", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2015-05-12", "fin_vigen