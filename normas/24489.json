{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Modifica decreto-ley 755 sobre Impuesto a la Renta Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 7168211}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Agr&#xE9;gase despu&#xE9;s del inciso primero del art&#xED;culo 82, reformado, del decreto ley n&#xFA;mero 755, sobre Impuesto a la Renta, el siguiente inciso:</div><div class=\"p\">&nbsp; &nbsp; El impuesto sobre herencia se comprobar&#xE1; en los casos y en la forma establecida por la ley respectiva&quot;.</div><div class=\"p\">&nbsp; &nbsp; La presente ley comenzar&#xE1; a regir desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br><br></div>", "i": 7168212, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica. Santiago, a 20 de Junio de mil novecientos veintisiete.-Carlos Ib&#xE1;&#xF1;ez C.- Pablo Ram&#xED;rez.</div><br></div>", "i": 7168213}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4123", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4123"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA DECRETO-LEY 755 SOBRE IMPUESTO A LA RENTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["IMPUESTO RENTA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1927-06-20", "doble_articulado": false, "id_norma": "24489", "numero_fuente": "14809", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1927-07-01", "vigencias": [{"desde": "1927-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1927-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1927-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "IMH", "fecha_ingreso": "1999-03-03", "fecha_version": "1927-07-01", "fecha_actualizacion_texto": "1927-07-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 7168211}, {"n": "Artículo UNICO", "i": 7168212, "t": 6}, {"n": "Promulgación", "i": 7168213}]}