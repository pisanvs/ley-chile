{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 68, DE 1987 </div></div>", "i": 6211114}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 68 de 10 de abril de 1987 se ha aprobado la aplicaci&#xF3;n de los programas de Religi&#xF3;n Cat&#xF3;lica para la asignatura de Religi&#xF3;n de la Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, aprobados por decreto supremo exento de Educaci&#xF3;n No. 158 de 1983, en la asignatura de Religi&#xF3;n de la Educaci&#xF3;n Media T&#xE9;cnico-Profesional.</div><br></div>", "i": 6211115}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 05 de Mayo de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6211116}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "68 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-68 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 68, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-04-10", "doble_articulado": false, "id_norma": "149101", "numero_fuente": "32769", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-05-13", "vigencias": [{"desde": "1987-05-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-05-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-05-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-12-09", "fecha_version": "1987-05-13", "fech