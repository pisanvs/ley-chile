{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 229, DE 1986 </div></div>", "i": 7260930}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 229, de 19 de junio de 1986, se ha modificado el Decreto Supremo Exento de Educaci&#xF3;n N&#xB0; 187, de 17 de junio de 1985 que aprob&#xF3; planes y programas especiales de estudio de segundo ciclo de Educaci&#xF3;n Media, Modalidad T&#xE9;cnico - Profesional, para el Liceo Agr&#xED;cola &quot;La Providencia&quot;, de Traigu&#xE9;n, en el sentido de agregar asignaturas electivas que se indican, y que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar 1986 y hasta el a&#xF1;o escolar 1990. </div></div>", "i": 7260931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Junio de 1986.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7260932}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "229 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-229 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 229, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-19", "doble_articulado": false, "id_norma": "155036", "numero_fuente": "32508", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-06-28", "vigencias": [{"desde": "1986-06-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-06-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-06-28"