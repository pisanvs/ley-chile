{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DENOMINA &quot;JORGE MU&#xD1;OZ SILVA&quot; LA ESCUELA SUPERIOR DE HOMBRES N&#xB0; 1 DE SAN FERNANDO</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha tenido a bien prestar su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 5978788}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Denom&#xED;nase &quot;Jorge Mu&#xF1;oz Silva&quot;, a la Escuela Superior de Hombres N&#xB0; 1 de San Fernando. </div></div>", "i": 5978789}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintinueve de septiembre de mil novecientos sesenta y siete.- EDUARDO FREI MONTALVA.- Juan G&#xF3;mez.</div><br></div>", "i": 5978790}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "16684", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-16684"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "DENOMINA \"JORGE MUÑOZ SILVA\" LA ESCUELA SUPERIOR DE\nHOMBRES N° 1 DE SAN FERNANDO", "fuente": "Recopilación de leyes de la Contraloría", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "ESCUELA SUPERIOR N 1", "SAN FERNANDO", "JORGE MU OZ SILVA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1967-09-29", "doble_articulado": false, "id_norma": "28626", "numero_fuente": "TOMO 53", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1967-10-10", "vigencias": [{"desde": "1967-10-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig