{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9299421}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. (Exento) N&#xBA;1958, de fecha 31 de agosto de 2012, y de conformidad a lo dispuesto en el art&#xED;culo 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;1-A, superficie 124,00 m2., Rol N&#xBA;644-25, para la obra &quot;REPOSICI&#xD3;N Y CONSTRUCCI&#xD3;N DE PUENTES VARIAS PROVINCIAS, REGI&#xD3;N METROPOLITANA&apos;, comuna de Paine. La comisi&#xF3;n de peritos, integrada por N&#xE9;stor Abello Rodr&#xED;guez, Douglas Herrera Flores y Marcela Redard Ayala, fij&#xF3; el valor de tasaci&#xF3;n con fecha 31 de agosto de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario SEGUNDO DEL CARMEN FERRADA ARENAS, en la cantidad de $2.680.768, suma que se pagar&#xE1; al contado. </div></div>", "i": 9299422}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9299423}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1958 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1958 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-08-31", "doble_articulado": false, "id_norma": "1044346", "numero_fuente": "40374", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-10-01", "vigencias": [{"desde": "2012-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"i