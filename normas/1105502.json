{"html": [{"t": "<div><br><div class=\"p\">CREA REGISTRO DE COMPRAS Y VENTAS COMO SE SE&#xD1;ALA Y DEROGA RESOLUCIONES QUE INDICA</div></div>", "i": 9815210}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta SII N&#xBA; 61 del 12 de julio de 2017, que establece:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Crea Registro de Compras y Ventas; exime a contribuyentes que se indican de la obligaci&#xF3;n de llevar libro de compras y ventas, o solamente de compras; y deroga resoluciones que se indican.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de julio de 2017.</div><div class=\"p\"> </div></div>", "i": 9815211}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "61 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-61 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CREA REGISTRO DE COMPRAS Y VENTAS COMO SE SEÑALA Y DEROGA RESOLUCIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1242749; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-07-12", "doble_articulado": false, "id_norma": "1105502", "numero_fuente": "41812", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-07-19", "vigencias": [{"desde": "2017-07-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-07-19", "fin_vigenci