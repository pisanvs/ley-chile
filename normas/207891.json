{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 14.120 EXENTA, DE 2002 </div><br></div>", "i": 6415232}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 14.120 de 27 de noviembre del a&#xF1;o 2002, se ha aprobado al Liceo &quot;San Agust&#xED;n&quot;, comuna de &#xD1;u&#xF1;oa, de Santiago, un plan de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de ense&#xF1;anza media, que se aplicar&#xE1; a partir del a&#xF1;o escolar 2003.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores de Educaci&#xF3;n de la Fe (1&#xBA; y 2&#xBA; a&#xF1;o) y Antropolog&#xED;a Cristiana (3&#xBA; y 4&#xBA; a&#xF1;o).</div><br></div>", "i": 6415233}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de enero de 2003.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6415234}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "14120 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-14120 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 14.120 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-11-27", "doble_articulado": false, "id_norma": "207891", "numero_fuente": "37492", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-02-22", "vigencias": [{"desde": "2003-02-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-02-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-02-22", "fin_vigencia": "", "ti