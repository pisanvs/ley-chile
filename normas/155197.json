{"html": [{"t": "<div><div class=\"p\">EXPROPIA TERRENO QUE INDICA </div></div>", "i": 6231485}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Proc&#xE9;dase a expropiar de acuerdo al Decreto Alcaldicio N&#xB0; 311 del 29.10.85 el terreno en que funciona la Escuela B&#xE1;sica G-186 &quot;Pe&#xF1;a Santa Rosa&quot; y cuyos deslindes son: Norte: En 166 mts. con camino p&#xFA;blico a Piedra Lisa; Sur en 100 mts. con propiedad de don Carlos Furet; Oriente en 59 mts. con camino p&#xFA;blico a Piedra Lisa; Poniente en 166 mts. con propiedad de Carlos Furet. El citado terreno forma parte de uno de mayor extensi&#xF3;n y rola inscrito a fojas 865 N&#xB0; 1.054 del Registro de Propiedades del Conservador de Bienes Ra&#xED;ces de San Carlos, a nombre de la Sociedad Agr&#xED;cola Carlos Furet y C&#xED;a. Ltda., la cual es representada por don Carlos Furet Torres.</div><br></div>", "i": 6231486}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "311", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-311"}], "organismos": ["MUNICIPALIDAD DE SAN NICOLÁS"], "titulo_norma": "EXPROPIA TERRENO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-10-29", "doble_articulado": false, "id_norma": "155197", "numero_fuente": "32287", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-02-01", "vigencias": [{"desde": "1986-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes":