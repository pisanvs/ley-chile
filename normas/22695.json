{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que concede un suplemento de 230,000 pesos para atender al cumplimiento de la lei de Reclutas i Reemplazos</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 1| de Diciembre de 1901.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7163115}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de doscientos treinta mil pesos para que el Presidente de la Rep&#xFA;blica atienda al cumplimiento de la lei de Reclutas i Reemplazos del Ej&#xE9;rcito i Armada. </div></div>", "i": 7163116}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de Rep&#xFA;blica.- JERMAN RIESCO.- Beltran Mathieu.</div><br></div>", "i": 7163117}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1497", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1497"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "QUE CONCEDE UN SUPLEMENTO DE 230,000 PESOS PARA ATENDER AL CUMPLIMIENTO DE LA LEI DE RECLUTAS I REEMPLAZOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EJERCITO CHILE", "ARMADA NACIONAL", "RECLUTAMIENTO", "REEMPLAZO", "PRESIDENTE REPUBLICA", "FONDOS", "DESTINACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-12-11", "doble_articulado": false, "id_norma": "22695", "numero_fuente": "7095", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-12-12", "vigencias": [{"desde": "1901-12-12", "hasta": "", "tipo_version": "3