{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DISPONE EXPROPIACION PARCIAL DE INMUEBLE </div></div>", "i": 6004829}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 61, de 14 de mayo 1996, del SERVIU V Regi&#xF3;n Valpara&#xED;so, se dispuso, conforme art&#xED;culo 87 Ley 8946, expropiaci&#xF3;n parcial de inmueble ubicado Avenida Ram&#xF3;n Barros Luco, San Antonio, de presunto dominio del Sindicato Profesional de Estibadores Mar&#xED;timos San Antonio, en una superficie aproximada de 204,72 m2, rol de aval&#xFA;o 1022-5. Comisi&#xF3;n Tasadora integrada por Sres. Osvaldo Mu&#xF1;oz Quintana, arquitecto, y Pablo Caria Giurici y Alvaro Verdejo Vidal, constructores civiles, seg&#xFA;n informe de 2 febrero de 1996, fij&#xF3; monto provisional indemnizaci&#xF3;n en $7.641.600.-, que se pagar&#xE1;n de contado.- Gerardo Gonz&#xE1;lez L&#xF3;pez, </div></div>", "i": 6004830}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director SERVIU V Regi&#xF3;n (S).</div><br></div>", "i": 6004831}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "61", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-61"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAISO"], "titulo_norma": "DISPONE EXPROPIACION PARCIAL DE INMUEBLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SAN ANTONIO", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-14", "doble_articulado": false, "id_norma": "32730", "numero_fuente": "35504-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-07-01", "vigencias": [{"desde": "1996-07-01", "hasta": "", "tipo