{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6089324}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 184, de 02 de mayo de 1989, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriza al se&#xF1;or Aquilino Silva Obando, para efectuar transporte terrestre de pasajeros entre Puerto Natales (Chile) y Villa Minera R&#xED;o Turbio 28 de Noviembre (Argentina), por los pasos fronterizos de Dorotea y Laurita (Casas Viejas), con dos frecuencias diarias de lunes a viernes y una frecuencia diaria, los s&#xE1;bados, domingos y feriados, de ida y vuelta. </div></div>", "i": 6089325}, {"t": "<div><div class=\"p\">- Manuel G&#xE1;rate Meneses, Coronel, Subsecretario de Transportes.</div><br></div>", "i": 6089326}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "184", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-184"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-02", "doble_articulado": false, "id_norma": "91569", "numero_fuente": "33388", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-06-03", "vigencias": [{"desde": "1989-06-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-06-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-06-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1998-02-25