{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autorizacion al Presidente de la Rep&#xFA;blica para que numere los incisos de la lei n&#xFA;m. 980</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m.1,167.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948479}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza al Presidente de la Rep&#xFA;blica para que numere los incisos de la lei n&#xFA;mero 980 de 23 de Diciembre de 1897, sobre derechos de Aduana.</div><br><br></div>", "i": 5948480}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 9 de Enero de 1899.- FEDERICO ERRAZURIZ.- R. Sotomayor.</div><br></div>", "i": 5948481}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1167", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1167"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "Autorizacion al Presidente de la República para que;numere los incisos de la lei núm. 980", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTE REPUBLICA", "LEY DERECHOS ADUANA", "INCISOS", "NUMERACION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-01-09", "doble_articulado": false, "id_norma": "22443", "numero_fuente": "6196", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-01-09", "vigencias": [{"desde": "1899-01-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ún