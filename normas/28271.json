{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; REHABILITA EN SU NACIONALIDAD CHILENA A DON CARLOS MIRA GOMEZ</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 8282396}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Rehabil&#xED;tase en su nacionalidad chilena a don Carlos Mira G&#xF3;mez, que la perdiera con motivo de su nacionalizaci&#xF3;n en Venezuela&quot;.</div><br></div>", "i": 8282397}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veinticuatro de septiembre de mil novecientos sesenta y cuatro.- JORGE ALESSANDRI RODRIGUEZ.- S&#xF3;tero del R&#xED;o.</div><br></div>", "i": 8282398}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "15710", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-15710"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "REHABILITA EN SU NACIONALIDAD CHILENA A DON CARLOS\nMIRA GOMEZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REHABILITACION", "NACIONALIDAD CHILENA", "CARLOS MIRA GOMEZ"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1964-09-24", "doble_articulado": false, "id_norma": "28271", "numero_fuente": "25957", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1964-10-06", "vigencias": [{"desde": "1964-10-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1964-10-06", "fin_vigencia": ""}, "vigencias_version_n