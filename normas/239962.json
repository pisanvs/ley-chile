{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6532596}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.017, de 1 de julio de 2005, de esta Subsecretar&#xED;a, decl&#xE1;rase vigente la resoluci&#xF3;n N&#xBA; 1.029 de 2005, de esta Subsecretar&#xED;a, que autoriza a CONSERVAS Y CONGELADOS DE PUERTO MONTT S.A., para desarrollar actividades pesqueras de transformaci&#xF3;n en una planta ubicada en camino Chinquihue, Kil&#xF3;metro 12, Puerto Montt, X Regi&#xF3;n.</div><div class=\"p\">D&#xE9;jense sin efecto las resoluciones N&#xBA; 1.607 de 2005, N&#xBA;2.723 de 2002, N&#xBA; 1.238 de 2003, N&#xBA; 245 y N&#xBA; 2.787, ambas de 2004, todas de esta Subsecretar&#xED;a, en virtud de la carta de renuncia se&#xF1;alada en la parte considerativa de la resoluci&#xF3;n extractada.</div><br></div>", "i": 6532597}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de julio de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6532598}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2017 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2017 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-07-01", "doble_articulado": false, "id_norma": "239962", "numero_fuente": "38206", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-09", "vigencias": [{"desde": "2005-07-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-09"