{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 7300662}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico. Autorizase al Presidente de la Rep&#xFA;blica para enajenar en remate p&#xFA;blico la Escampavia &quot;Porvenir&quot;, de la Armada Nacional.</div><br></div>", "i": 7300663}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto ha tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiuno de Agosto de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Edgardo von Schroeders. </div></div>", "i": 7300664}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4875", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4875"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "AUTORIZA ENAJENACION ESCAMPAVIA PORVENIR DE LA ARMADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-08-21", "doble_articulado": false, "id_norma": "211588", "numero_fuente": "15761", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-08-29", "vigencias": [{"desde": "1930-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1930-08-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1930-08-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2003-06-24", "fecha_vers