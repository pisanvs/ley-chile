{"html": [{"t": "<div><div class=\"p\">APRUEBA LA DISOLUCION VOLUNTARIA DE LA COOPERATIVA DE SERVICIOS DE VERANEO CAMPO Y MAR LIMITADA </div></div>", "i": 6321841}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA;3, de fecha 10 de enero del a&#xF1;o 2001, se aprob&#xF3; la disoluci&#xF3;n voluntaria de la Cooperativa de Servicios de Veraneo Campo y Mar Limitada, que consta en la escritura p&#xFA;blica suscrita con fecha 13 de diciembre del a&#xF1;o 2000, ante el Notario P&#xFA;blico de Santiago, don Claudio Hern&#xE1;n Mesina Schulz. </div></div>", "i": 6321842}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas.</div><br></div>", "i": 6321843}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "APRUEBA LA DISOLUCION VOLUNTARIA DE LA COOPERATIVA DE SERVICIOS DE VERANEO CAMPO Y MAR LIMITADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-01-10", "doble_articulado": false, "id_norma": "181658", "numero_fuente": "36885", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-02-10", "vigencias": [{"desde": "2001-02-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-02-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v