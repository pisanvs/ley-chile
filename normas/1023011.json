{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, febrero 26 de 1877</div><br><div class=\"p\">&nbsp; &nbsp;  Visto lo dispuesto por el art. 6&#xBA; del C&#xF3;digo Civil, i por el decreto de 16 de setiembre de 1830, decreto;</div></div>", "i": 9109861}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Las leyes, los decretos i demas resoluciones del Gobierno que se publiquen en el Diario Oficial de la Rep&#xFA;blica de Chile se tendr&#xE1;n como aut&#xE9;nticas i oficialmente comunicadas, para que obliguen a las personas i corporaciones a quienes correspondan.</div><br></div>", "i": 9109862}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese i comun&#xED;quese.</div><div class=\"p\">&nbsp; &nbsp;  PINTO.</div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Victorino Lastarria.</div><br></div>", "i": 9109863}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1877-02-26", "doble_articulado": false, "id_norma": "1023011", "numero_fuente": "2", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1877-03-02", "vigencias": [{"desde": "1877-03-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1877-03-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1877-03-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "362", "fecha_ingreso": "2011-02-14", "fecha_version": "1877-03-02", "actuali