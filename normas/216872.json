{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 210, DE 1987 </div></div>", "i": 6447063}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 210 de 22 de octubre de 1987 se ha prorrogado, a contar del a&#xF1;o escolar 1987, la vigencia del decreto supremo exento de Educaci&#xF3;n N&#xB0; 168 de 1983, que aprob&#xF3; un plan de estudio experimental para 1&#xB0; y 2&#xB0; a&#xF1;o de Educaci&#xF3;n Media al Colegio Francisco de Miranda, de Santiago.</div><br></div>", "i": 6447064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6447065}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "210 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-210 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 210, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-10-22", "doble_articulado": false, "id_norma": "216872", "numero_fuente": "32916", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-10", "vigencias": [{"desde": "1987-11-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-11-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2003-11-05", "fecha_version": "1987-11-10", "fecha_actualizacion_texto": "1987-11-10", "tipo_tratado": ""}, "ale