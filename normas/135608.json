{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,965.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165983}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese a la viuda e hijos del injeniero tercero de la Armada don Augusto Marzarez, muerto a causa de la esplosion de uno de los calderos del Hu&#xE1;scar, ocurrida el 1.&#xBA; de abril de 1896, el montep&#xED;o correspondiente al empleo de teniente primero de la Armada&quot;.</div><br></div>", "i": 6165984}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, diecinueve de julio de mil novecientos siete.- Pedro Montt.- Alejandro Lira.</div><br></div>", "i": 6165985}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1965", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1965"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-07-19", "doble_articulado": false, "id_norma": "135608", "numero_fuente": "8857", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-07-24", "vigencias": [{"desde": "1907-07-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-07-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1907-07-24", "fin_vigencia": "", "tipo_version":