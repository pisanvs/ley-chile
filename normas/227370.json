{"html": [{"t": "<div><div class=\"p\">BANCO DE CHILE</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, octubre 17 de 1860.</div><br></div>", "i": 9053073}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  (129). En vista de la precedente solicitud del Director Jeneral del Banco de Chile i atendiendo a que el art. 20 de la lei sobre Bancos de 23 de julio &#xFA;ltimo se refiere clara i terminantemente a las obligaciones al portador, se declara con arreglo al mismo art&#xED;culo que no deben aplicarse a los recibos ni a las cuentas corrientes las disposiciones que el citado art&#xED;culo contiene.</div><br></div>", "i": 9053074}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, comun&#xED;quese i publ&#xED;quese.</div><br><div class=\"p\">&nbsp; &nbsp;  MONTT Jovino Novoa.</div><br></div>", "i": 9053075}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "BANCO DE CHILE", "fuente": "Boletin de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1860-10-17", "doble_articulado": false, "id_norma": "227370", "numero_fuente": "28; PAGINA 280", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1860-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1860-10-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1860-10-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresado_por": "CMV", "fecha_ingreso": "2004-07-