{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede al Senador don Guillermo Barros Jara, permiso para ausentarse del pa&#xED;s por m&#xE1;s de un a&#xF1;o.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br><br></div>", "i": 8277540}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese al senador don Guillermo Barros Jara, el permiso requerido por el art&#xED;culo 31 de la Constituci&#xF3;n Pol&#xED;tica, para poder permanecer ausente del pa&#xED;s por m&#xE1;s de un a&#xF1;o.</div><br></div>", "i": 8277541}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; prom&#xFA;lguese y ll&#xE9;vese a efecto como ley la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecisiete de Junio de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Guillermo Edwards Matte. </div></div>", "i": 8277542}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4599", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4599"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE AL SENADOR DON GUILLERMO BARROS JARA, PERMISO PARA AUSENTARSE DEL PAÍS POR MÁS DE UN AÑO.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["GUILLERMO BARROS JARA", "PERMISO", "CONCESION", "VIAJE", "EXTRANJERO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-06-17", "doble_articulado": false, "id_norma": "24764", "numero_fuente": "15400", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-06-18", "vigencias": [{"desde": "1929-06-18", "hasta": "", "tipo_version": "3", "t