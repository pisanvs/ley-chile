{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO N&#xBA; 1.251 EXENTO, DE 2011</div></div>", "i": 9314754}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento N&#xBA; 1.132, de 15 de noviembre de 2012, de este Ministerio, modif&#xED;case el art&#xED;culo 3&#xBA; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1035605&amp;idParte=&amp;idVersion=\">Decreto Exento N&#xBA; 1.251 de 2011, del Ministerio de Econom&#xED;a, Fomento y Turismo</a>, que estableci&#xF3; la cuota global anual de captura de la unidad de pesquer&#xED;a de Anchoveta de la XV a II Regiones, en sentido de reemplazar la tabla ah&#xED; indicada por la siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/29237.jpg\"> </div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y del Servicio Nacional de Pesca.</div><br><br></div>", "i": 9314755, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de noviembre de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9314756}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1132 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1132 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA DECRETO Nº 1.251 EXENTO, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-11-15", "doble_articulado": false, "id_norma": "1045990", "numero_fuente": "4