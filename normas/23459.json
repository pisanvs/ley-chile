{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede una asignaci&#xF3;n anual al Profesor don Miguel Luis Amun&#xE1;tegui Reyes.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,738.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5954001}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados a la instruccion p&#xFA;blica por don Miguel Luis Amun&#xE1;tegui Reyes, conc&#xE9;desele, por gracia, una asignacion de tres mil quinientos pesos anuales, que gozar&#xE1; sin perjuicio de la pension que le corresponde por su jubilacion.</div><br></div>", "i": 5954002}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 10 de Enero de 1913.- RAMON BARROS LUCO.-</div><div class=\"p\">E. Villegas E.</div><br></div>", "i": 5954003}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2738", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2738"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "Concede una asignación anual al Profesor don Miguel;Luis Amunátegui Reyes.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MIGUEL LUIS AMUNATEGUI REYES", "ASIGNACION ANUAL", "INSTRUCCION PUBLICA", "SERVICIOS PRESTADOS", "CONCESION POR", "GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1913-01-10", "doble_articulado": false, "id_norma": "23459", "numero_fuente": "10476", "tipo_v