{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,297, que prohibe la esportacion de los metales viejos o usados, que se indican.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,297.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 7166518}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica por exijirlo as&#xED; el interes nacional, para que pueda prohibir la esportacion de los siguientes metales viejos o usados: hierro, cobre, plomo i zinc o sus aleaciones.</div><br></div>", "i": 7166519}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado he tenido a bien aprobarlo i sancionarlo; por tanto prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago a veintiuno de Setiembre de mil novecientos diecisiete.- JUAN LUIS SANFUENTES.- Armando Quezada A. </div></div>", "i": 7166520}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "https://tramitacion.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=18188-07", "informacion": "Deroga la ley N° 3.297, que prohíbe la exportación de los metales viejos o usados, que se indica", "nroBoletin": "18188-07"}, {"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3297", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3297"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LEI NÚM. 3.297, QUE PROHIBE LA ESPORTACIÓN DE LOS METALES VIEJOS O USADOS, QUE SE INDICAN", "fuente": "Diario Oficial", "resu