{"html": [{"t": "<div><br><div class=\"p\">ESTABLECE CUOTA ANUAL DE CAPTURA PARA EL RECURSO JIBIA XV-XII REGIONES, A&#xD1;O 2015.</div></div>", "i": 9544501}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 960 de 22 de diciembre de 2014, de este Ministerio, f&#xED;jase para el a&#xF1;o 2015, la siguiente cuota anual de captura para el recurso Jibia a ser extra&#xED;da en el &#xE1;rea mar&#xED;tima comprendida entre la XV a la XII Regiones, seg&#xFA;n se indica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/46299.jpg\">.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9544502}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valparaiso, 22 de diciembre de 2014.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9544503}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "960 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-960 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "ESTABLECE CUOTA ANUAL DE CAPTURA PARA EL RECURSO JIBIA XV-XII REGIONES, AÑO 2015.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-12-22", "doble_articulado": false, "id_norma": "1072939", "numero_fuente": "41042", "ti