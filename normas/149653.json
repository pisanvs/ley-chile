{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 201 EXENTO, DE 1999</div><br><br></div>", "i": 7257671}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;201, de fecha 20 de julio de 1999, del Ministerio de Educaci&#xF3;n, se aprobaron las adecuaciones a los planes y programas de estudios de las carreras Comunicaci&#xF3;n Social y Dise&#xF1;o de Vestuario del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Aiep, modific&#xE1;ndose, en consecuencia, el decreto exento N&#xBA;136 del 29 de marzo de 1994 y la resoluci&#xF3;n exenta N&#xBA;1.027 del 4 de abril de 1998, respectivamente, en el sentido de incorporar dichas adecuaciones, las que podr&#xE1;n aplicarse a contar del a&#xF1;o 1999.</div><br></div>", "i": 7257672}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de agosto de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7257673}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "201 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-201 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 201 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-07-20", "doble_articulado": false, "id_norma": "149653", "numero_fuente": "36539", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-12-20", "vigencias": [{"desde": "1999-12-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-12-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-12-20", "fin_vigencia": "", "tipo_vers