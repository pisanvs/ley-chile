{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10223767}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;57, de 26 de marzo de 2021, se desisti&#xF3; de la expropiaci&#xF3;n del lote N&#xBA;1, realizada por <a href=\"https://www.leychile.cl/Navegar?idNorma=1097813&amp;idVersion=2021-05-03\">Decreto Exento MOP. N&#xBA;1347, de 16 de noviembre de 2016</a>, debido a que no se requiere para la ejecuci&#xF3;n de la obra: Sistema de Regad&#xED;o Cuncumen Botadero 2, Comuna de San Antonio, Regi&#xF3;n de Valpara&#xED;so. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en los art&#xED;culos 7&#xBA; y 32&#xBA; del Decreto Ley N&#xBA;2186, de 1978. </div><br></div>", "i": 10223768, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10223769}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "57 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-57 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1934024", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-03-26", "doble_articulado": false, "id_norma": "1159057", "numero_fuente": "42944", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-05-03", "vigencias": [{"desde": "2021-05-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2021-05-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2021-05-03", "fin_vigencia": "", "tipo_versi