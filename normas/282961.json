{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Minuta</div></div>", "i": 7032022}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  644 Nombra a las siguientes personas para que desempe&#xF1;en en la Escuela Pr&#xE1;ctica de Agricultura de San Felipe, los cargos que se indican:</div><div class=\"p\">&nbsp; &nbsp;  A don Alfonso Labb&#xE9; Mart&#xED;nez, que desempe&#xF1;aba el cargo de Inspector del grado 20.o, de la Escuela Agr&#xED;cola de Chill&#xE1;n, como Ec&#xF3;nomo de la Escuela Agr&#xED;cola de San Felipe, con el sueldo de $ 6,600 anuales.</div><div class=\"p\">&nbsp; &nbsp;  A don Joaqu&#xED;n del Fierro Mardones, actual Inspector de la Escuela Agr&#xED;cola de Ancud, contratado del grado 19.o como Inspector del grado 20.o de la planta de la Escuela Agr&#xED;cola de San Felipe y con el sueldo de $ 6.200 anuales.</div><br></div>", "i": 10515183}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "644", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-644"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "MINUTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA PUBLICADA SIN PROMULGACIÓN NI FECHA DE PROMULGACIÓN", "PF"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "282961", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1936-11-07", "vigencias": [{"desde": "1937-11-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1937-11-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1937-11-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "GGV", "fecha_ingreso": "2008-12-10", "fe