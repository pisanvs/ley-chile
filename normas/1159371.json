{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Pagos a los militares</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Setiembre 28 de 1814</div></div>", "i": 10227856}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Los Ministros del Tesoro P&#xFA;blico no har&#xE1;n pago alguno a individuo militar que no se halle con plaza activa en el Ej&#xE9;rcito empleado por el Estado, i en actual ejercicio; tomando en caso de duda conocimiento del Jefe del Departamento Militar, a quien deben dirijir sus pretensiones los que no se hallen en aquel caso, para que por su conducto lleguen a nuestra intelijencia, i esperen su decision: t&#xF3;mese razon y comun&#xED;quese en el Monitor. - </div></div>", "i": 10227857}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Carrera. - Uribe. - Mu&#xF1;oz.</div></div>", "i": 10227858}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Pagos a los militares", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1814-09-28", "doble_articulado": false, "id_norma": "1159371", "numero_fuente": "1814", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1814-09-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1814-09-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1814-09-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2021-05-17", "fecha_version": "1814-09-28", "fecha_actualiz