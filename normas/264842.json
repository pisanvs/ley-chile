{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7353848}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA;404 de fecha 31 de julio del 2007, se expropi&#xF3; el lote de terreno N&#xBA;4, superficie 6.160 m&#xB2;, Rol N&#xBA;204-42, comuna de Chait&#xE9;n, X Regi&#xF3;n para la obra &quot;Mejoramiento Ruta 7 Longitudinal Austral, Sector Ex Pozos de Empr&#xE9;stitos - El Amarillo, tramo Km.</div><div class=\"p\">13,000 al Km. 26,700&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Emelina del Carmen Mayorga Navarro, ascendente a la cantidad de</div><div class=\"p\">$1.666.711.- para el lote N&#xBA;4.</div><br></div>", "i": 7353849}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 7353850}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "404 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-404 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-07-31", "doble_articulado": false, "id_norma": "264842", "numero_fuente": "38865", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-09-15", "vigencias": [{"desde": "2007-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2007-09-20", "fecha_versio