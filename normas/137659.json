{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,677.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6172814}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atenci&#xF3;n a que el subteniente de Ej&#xE9;rcito don Arturo P&#xE9;rez Canto fue muerto en el Combate de la Concepcion, conc&#xE9;dese, por gracia, a cada una de sus hermanas do&#xF1;a Amelia i do&#xF1;a Corina P&#xE9;rez Canto, una pension anual de mil pesos ($ 1,000) de que disfrutar&#xE1;n con arreglo a la lei de montep&#xED;o militar i sin derecho de acrecer. </div></div>", "i": 6172815}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiocho de agosto de mil novecientos doce.- Ramon Barros Luco.- Claudio Vicu&#xF1;a S. </div></div>", "i": 6172816}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2677", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2677"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-08-28", "doble_articulado": false, "id_norma": "137659", "numero_fuente": "10365", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-08-29", "vigencias": [{"desde": "1912-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-08-29", "fin_vigencia": ""}, "vigencias_version_norm