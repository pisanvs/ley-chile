{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8592676}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.588, de 29 de abril de 2009, de esta Subsecretar&#xED;a, modif&#xED;quese resoluci&#xF3;n N&#xBA; 1.228, de 2009, de esta Subsecretar&#xED;a, que autoriz&#xF3; a UNIVERSIDAD ANDR&#xC9;S BELLO para efectuar una pesca de investigaci&#xF3;n, T.T.R. Proyecto &quot;Determinaci&#xF3;n de interacciones interespec&#xED;ficas entre el Vis&#xF3;n Americano (Mustela vison) y el Huill&#xED;n (Lontra provocax) en ambientes marinos de la XI Regi&#xF3;n, Chile&quot;, en el sentido de extender su per&#xED;odo de vigencia hasta el 30 de abril de 2010.</div></div>", "i": 8592677}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de abril de 2009.- Mar&#xED;a &#xC1;ngela Barbieri Bellolio, Subsecretaria de Pesca (S).</div></div>", "i": 8592678}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1588 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-1588 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-04-29", "doble_articulado": false, "id_norma": "1002041", "numero_fuente": "39359", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-05-12", "vigencias": [{"desde": "2009-05-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-05-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-05-12", "fin_vigencia": "", "tipo