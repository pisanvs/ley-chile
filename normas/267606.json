{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6745795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA;722, de 8 de noviembre de 2007, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA; del decreto exento MOP N&#xBA;302, de 28 de marzo de 2002, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n, del lote de terreno N&#xBA;85, expropiado a N&#xE9;stor P&#xE9;rez Matus, con motivo de la obra Camino R&#xED;o Bueno - Crucero, Rol T-90-U y T-933, Km. 0,00 a Km. 20,900 (II Parte). Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n, fijada por la Comisi&#xF3;n de Peritos con fecha 12 de julio de 2000, ascendente a la cantidad de $864.960 para lote N&#xBA; 85.</div><br></div>", "i": 6745796}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6745797}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "722 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-722 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-11-08", "doble_articulado": false, "id_norma": "267606", "numero_fuente": "38937", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-15", "vigencias": [{"desde": "2007-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-12-15", "fin_vigencia": ""}, "vigencias