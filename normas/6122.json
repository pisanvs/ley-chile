{"html": [{"t": "<div><div class=\"p\">Agregado al art&#xED;culo 6.o de la ley N.o 5,005 </div><br><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 482.- Santiago, 24 de Agosto de 1932.- El Presidente provisional de la Rep&#xFA;blica de Chile, de acuerdo con el Consejo de Ministros, dicta el siguiente, </div><br><div class=\"p\">&nbsp; &nbsp; Decreto-ley:</div><br></div>", "i": 7124173}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.o Agr&#xE9;guese al art&#xED;culo 6.o de la ley n&#xFA;mero 5,005, de 24 de Noviembre ppdo., lo siguiente:</div><div class=\"p\">&quot;La de los empleados de la Subsecretar&#xED;a de Marina y la de los empleados del Departamento de Obras Mar&#xED;timas&quot;. </div></div>", "i": 7124174, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 2.o Este decreto-ley comenzar&#xE1; a regir desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 7124175}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- CARLOS DAVILA.- J. M. Montalva B.</div><br></div>", "i": 7124176}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "482", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-482"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "Agregado al artículo 6.o de la ley N.o 5,005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SUBSECRETARIA MARINA", "DEPARTAMENTO OBRAS MARITIMAS", "PERSONAL", "NOMBRAMIENTOS", "VACANTES", "PROVEIMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-08-24", "doble_articulado": false, "id_norma"