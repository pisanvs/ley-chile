{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE RESOLUCION </div></div>", "i": 6003308}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 21 de fecha 14 de Junio de 1995, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se adjudic&#xF3; a don Jorge Abraham Arellano D&#xED;az, la concesi&#xF3;n para operar, hasta el 7 de Septiembre de 1997, a contar de la fecha de publicaci&#xF3;n del presente extracto, un establecimiento ubicado en calle Montt N&#xB0; 608, de la Comuna de Mulch&#xE9;n, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de emisi&#xF3;n de contaminantes de los veh&#xED;culos motorizados, remolques y semirremolques, seg&#xFA;n el inciso Segundo del Art. 7&#xB0; del D.S. N&#xB0; 156/90, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.</div><br></div>", "i": 6003309}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Miguel Reyes N&#xFA;&#xF1;ez, Secretario Regional Ministerial Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6003310}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "21", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-21"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION REVISION TECNICA", "PLANTA REVISION TECNICA", "MULCHEN", "OCTAVA REGION", "JORGE ARELLANO DIAZ"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-06-14", "doble_articulado": false, "id_norma": "32225", "numero_fuente": "35220", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publ