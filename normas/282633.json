{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A JULIO H. MOSSO DINEN </div></div>", "i": 6666187}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE 08/N&#xBA; Ex. 10.382, de fecha 17.11.08, revoca a don Julio H. Mosso Dinen, RUT N&#xBA; 7.528.998-7, a partir del d&#xED;a 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las ventas de harina, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 17 de la resoluci&#xF3;n Ex. N&#xBA;5.282, del 30.11.2000, de la Direcci&#xF3;n Nacional. Concepci&#xF3;n, 17 de noviembre de 2008.-</div><br></div>", "i": 6666188}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Flores Guti&#xE9;rrez, Director Regional. </div></div>", "i": 6666189}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10382 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-10382 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A JULIO H. MOSSO DINEN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-11-17", "doble_articulado": false, "id_norma": "282633", "numero_fuente": "39225", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-11-29", "vigencias": [{"desde": "2008-11-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-11-29", "fin_vigencia": ""}, "vigencias_version