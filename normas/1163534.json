{"html": [{"t": "<div><div class=\"p\">RECTIFICACI&#xD3;N</div></div>", "i": 10258378}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Rectif&#xED;case el &quot;<a href=\"https://www.bcn.cl/leychile/navegar?idNorma=1163432&amp;idVersion=2021-08-11\">Acuerdo N&#xBA; 56</a> que modifica los Procedimientos de Aprobaci&#xF3;n de Fondos Mutuos Extranjeros y de Gestores de Activos Alternativos Extranjeros&quot;, publicado con fecha 7 de agosto de 2021 en el Diario Oficial, en el siguiente sentido:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Agregar la siguiente oraci&#xF3;n al final del segundo p&#xE1;rrafo del Art&#xED;culo 20.-:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  &quot;Para efectos de la evaluaci&#xF3;n, los fondos administrados por una misma sociedad administradora se considerar&#xE1;n como un solo aportante.&quot;</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><br></div>", "i": 10258379, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de julio de 2021.- Alejandro Mu&#xF1;oz Vald&#xE9;s, Secretario.</div><div class=\"p\"> </div><br></div>", "i": 10258380}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "Aviso-S/N"}], "organismos": ["COMISIÓN CLASIFICADORA DE RIESGO", "SECRETARÍA ADMINISTRATIVA"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1992018"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-07-29", "doble_articulado": false, "id_norma": "1163534", "numero_fuente": "43025", "tipo_version": "3", "tipo_version_s": "Únic