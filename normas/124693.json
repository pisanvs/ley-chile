{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6131460}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.219 de 16 de septiembre de 1988, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriza a la Sociedad Gonz&#xE1;lez y Compa&#xF1;&#xED;a Limitada (Transporte Aconcagua Santiago T.A.S. Choapa Limitada o T.A.S. Choapa Limitada), para efectuar servicio internacional de transporte terrestre de pasajeros entre Puerto Montt-Osorno (Chile) y San Carlos de Bariloche (Argentina), por el Paso de Portezuelo de Puyehue, el que se atender&#xE1; con dos (2) frecuencias semanales.- </div></div>", "i": 6131461}, {"t": "<div><div class=\"p\">Manuel G&#xE1;rate Meneses, Coronel, Subsecretario de Transportes.</div><br></div>", "i": 6131462}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1219 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1219 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-09-16", "doble_articulado": false, "id_norma": "124693", "numero_fuente": "33192", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-10-10", "vigencias": [{"desde": "1988-10-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-10-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-10-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAS", "fec