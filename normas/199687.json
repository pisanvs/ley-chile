{"html": [{"t": "<div><div class=\"p\">CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD PESQUERA QUINTERO LIMITADA </div></div>", "i": 6386600}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La V Direcci&#xF3;n Regional del Servicio de Impuestos Internos, por Res. Ex. N&#xBA; 086 del 10 de junio de 2002 concede la calidad de Agente Retenedor del IVA, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n en el Diario Oficial, a la Sociedad Pesquera Quintero Limitada, RUT N&#xBA; 78.577.670-4, en las adquisiciones de especies hidrobiol&#xF3;gicas, conforme a lo establecido en la resoluci&#xF3;n Ex. N&#xBA; 3.311, del 30.06.2000, la cual entr&#xF3; en vigencia el 01 de julio del 2000.-</div><br></div>", "i": 6386601}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco C&#xE1;rcamo Avenda&#xF1;o, Director Regional. </div></div>", "i": 6386602}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "86 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-86 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL DE VALPARAÍSO"], "titulo_norma": "CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD PESQUERA QUINTERO LIMITADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-10", "doble_articulado": false, "id_norma": "199687", "numero_fuente": "37292", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-25", "vigencias": [{"desde": "2002-06-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-06-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vige