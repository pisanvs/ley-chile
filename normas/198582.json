{"html": [{"t": "<div><div class=\"p\">CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A SUPERMERCADOS UNIMARC S.A.</div><br></div>", "i": 6383053}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional Santiago Poniente del SII, por resoluci&#xF3;n N&#xBA; Ex. 463, de 10 de mayo de 2002, concede la calidad de Agente Retenedor del Impuesto al Valor Agregado en las compras de especies hidrobiol&#xF3;gicas a la empresa Supermercados Unimarc S.A., RUT.: 96.621.750-2, con vigencia a contar del d&#xED;a 1&#xBA; del mes siguiente al de su publicaci&#xF3;n en el Diario Oficial, y en forma indefinida, mientras se mantenga el fiel cumplimiento de la resoluci&#xF3;n N&#xBA; Ex. 3.311, de 30.06.2000, (D.O. 03.07.2000).-</div><br></div>", "i": 6383054}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jorge A. de Calisto Bravo, Director Regional. </div></div>", "i": 6383055}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "463 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-463 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO PONIENTE"], "titulo_norma": "CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A SUPERMERCADOS UNIMARC S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-10", "doble_articulado": false, "id_norma": "198582", "numero_fuente": "37270", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-30", "vigencias": [{"desde": "2002-05-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-30", "fin_vigencia": ""}, "vigencias_version_n