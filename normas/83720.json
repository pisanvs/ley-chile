{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6066104}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta No. 135, de 20 de Febrero de 1990, se adjudica a Soc. Touring Club Ltda., la concesi&#xF3;n para operar, por un plazo de cinco a&#xF1;os a contar del 05 de marzo de 1990, un establecimiento ubicado en calle Avda. Vitacura No. 8620, Las Condes destinado a la Revisi&#xF3;n T&#xE9;cnica y Verificaci&#xF3;n de Emisi&#xF3;n de Contaminantes de Autom&#xF3;viles, Station Wagons, Motocicletas, Veh&#xED;culos de carga de menos de 1.750 Kg. de capacidad de carga &#xFA;til y sus remolques ubicadas en la Regi&#xF3;n Metropolitana, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.- </div></div>", "i": 6066105}, {"t": "<div><div class=\"p\">Carlos Silva Echiburu, Ministro de Transportes y Telecomunicaciones.</div><br></div>", "i": 6066106}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "135 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-135 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-02-20", "doble_articulado": false, "id_norma": "83720", "numero_fuente": "33611", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-03", "vigencias": [{"desde": "1990-03-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-03-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-03-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p