{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,238.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6162802}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se autoriza al Presidente de la Rep&#xFA;blica para que invierta la suma de cuatro mil francos o su equivalente en moneda chilena en pagar al maestro relojero de la Escuela de Artes i Oficios don Pablo Lebas, el sueldo correspondiente al presente a&#xF1;o.</div><br></div>", "i": 6162803}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, a treinta i uno de julio de mil ochocientos noventa i nueve.- FEDERICO ERRAZURIZ.- Daniel Rioseco. </div></div>", "i": 6162804}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1238", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1238"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-07-31", "doble_articulado": false, "id_norma": "134572", "numero_fuente": "6362", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-07-31", "vigencias": [{"desde": "1899-07-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-07-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-07-31", "fin_vigencia": "", "tipo_version": "3"}]