{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8296383}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 1.214, de 22 de Diciembre de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por un a&#xF1;o, a contar del 30 de enero de 1995, el plazo otorgado a PESQUERA QUINTERO UNO S.A., R.U.T. N&#xB0; 96.596.570-K, en el numeral 5 de la Resoluci&#xF3;n N&#xB0; 1.432, de 1992, de esta Subsecretar&#xED;a, para desarrollar actividades pesqueras extractivas con una nave en construcci&#xF3;n, en ejercicio del derecho conferido en virtud de lo dispuesto en los incisos 3&#xB0; y 4&#xB0; del art&#xED;culo 3&#xB0; transitorio de la Ley General de Pesca y Acuicultura, en virtud de haberse acreditado la existencia de una fuerza mayor. </div></div>", "i": 8296384}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 22 de Diciembre de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8296385}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1214", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1214"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA QUINTERO UNO S.A.", "PESCA", "PLAZO", "PRORROGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-12-22", "fecha_derogacion": "1997-10-22", "doble_articulado": false, "id_norma": "36507", "numero_fuente": "35055", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-12-31", "vigencias": [{"desde": "1997-10-22", "hasta": "", "tipo_v