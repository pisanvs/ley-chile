{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6440495}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.022, de 21 de agosto de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; DISTRIBUIDORA MARES DEL SUR LIMITADA para ampliar actividades pesqueras extractivas con la nave &quot;Tahiti&quot;, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar los recursos hidrobiol&#xF3;gicos que a continuaci&#xF3;n se se&#xF1;alan: a) Entre la III a VIII Regiones, con arrastre: Besugo, Cojinova moteada, Congrio dorado, Palometa, Calamar, Jibia; b) Entre la III a VII Regiones, con arrastre: Raya. </div></div>", "i": 6440496}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6440497}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2022", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2022"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-21", "doble_articulado": false, "id_norma": "214895", "numero_fuente": "37663", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-17", "vigencias": [{"desde": "2003-09-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-09-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICA