{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6440079}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;103 de 21 de agosto 2003, Serviu Regi&#xF3;n Tarapac&#xE1;, conforme D.L. N&#xBA;1.523/1976, N&#xBA;2.186/1978 y D.S. N&#xBA;355/76, 131 de 2002, y 71/2003, todos de Vivienda y Urbanismo, dispuso expropiaci&#xF3;n del inmueble ubicado en Iquique, calle Las Cabras N&#xBA;1107, Rol de Aval&#xFA;o 103/014, de presunto dominio de Ernesto Nina. Comisi&#xF3;n integrada por peritos H&#xE9;ctor Ruiz Le-Beuffe, arquitecto y se&#xF1;ores Gast&#xF3;n Gonz&#xE1;lez Kemnis y Oscar Esc&#xE1;rate Arancibia, Constructores Civiles, seg&#xFA;n informe tasaci&#xF3;n de 24 julio 2003, fij&#xF3; monto provisional de indemnizaci&#xF3;n en $17.000.000 pagadera al contado.</div><br></div>", "i": 6440080}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Dina Tarraza Lovazzano, Directora Serviu Regi&#xF3;n de Tarapac&#xE1;.</div><br></div>", "i": 6440081}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "103", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-103"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "I REGIÓN DE TARAPACÁ"], "titulo_norma": "DISPONE EXPROPIACIONES DE INMUEBLES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-21", "doble_articulado": false, "id_norma": "214737", "numero_fuente": "37661", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-15", "vigencias": [{"desde": "2003-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09