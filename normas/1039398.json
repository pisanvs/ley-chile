{"html": [{"t": "<div><br><div class=\"p\">CERTIFICADO</div></div>", "i": 9252407}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1 del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de Mayo de 1989, fue de 5,73% anual.</div></div>", "i": 9252408}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de Mayo de 1989.- Carmen Hermosilla Valencia, Secretario General.</div></div>", "i": 9252409}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "Certificado-S/N"}], "organismos": ["MINISTERIO DE HACIENDA", "BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-19", "doble_articulado": false, "id_norma": "1039398", "numero_fuente": "33377", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-05-20", "vigencias": [{"desde": "1989-05-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-05-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-05-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2012-04-26", "fecha_version": "1989-05-20", "fecha_actualizacion_texto": "2012-04-26", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n"