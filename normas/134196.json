{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,131.- Santiago, 16 de diciembre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 8342805}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atenci&#xF3;n a los servicios prestados a la Naci&#xF3;n por el se&#xF1;or don Antonio Garc&#xED;a Reyes, conc&#xE9;dese a sus nietas solteras, do&#xF1;a Mar&#xED;a Amelia, do&#xF1;a In&#xE9;s, do&#xF1;a Carolina i do&#xF1;a Filomena Garc&#xED;a i Cordovez, una pensi&#xF3;n anual de mil doscientos pesos, de la cual gozar&#xE1;n con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 8342806, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo;&nbsp; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C. Walker Mart&#xED;nez.</div><br></div>", "i": 8342807}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1131", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1131"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-12-16", "doble_articulado": false, "id_norma": "134196", "numero_fuente": "6177", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-12-16", "vigencias": [{"desde": "1898-12-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-12-16", "fin_vigencia": ""}, "vigencias_version_norma": 