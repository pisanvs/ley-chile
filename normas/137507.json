{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,533.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6172305}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Susana Sep&#xFA;lveda, viuda del ayudante mayor de Ej&#xE9;rcito, don Marco Aurelio Guti&#xE9;rrez, derecho a disfrutar de la pension de montep&#xED;o militar correspondiente al empleo de ayudante mayor.</div><br></div>", "i": 6172306}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto,&nbsp; prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, cinco de agosto de mil novecientos once.- Ramon Barros Luco.- An&#xED;bal Rodr&#xED;guez H.</div><br></div>", "i": 6172307}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2533", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2533"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-08-05", "doble_articulado": false, "id_norma": "137507", "numero_fuente": "10097", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-10-05", "vigencias": [{"desde": "1911-10-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-10-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-10-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes":