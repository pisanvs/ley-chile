{"html": [{"t": "<div><div class=\"p\">OBSERVANCIA DEL ARTICULO 243 DE LA CONSTITUCION.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Febrero 16 de 1824.</div><br><div class=\"p\">&nbsp; &nbsp;  El Gobierno ha acordado y decreta:</div></div>", "i": 10069353}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Que en cumplimiento del art. 243 de la Constitucion no se pase al Ministro de Hacienda para su aprobacion ningun auto o sentencia que contenga pago, o liberacion fiscal, sin que preceda el competente rejistro que deber&#xE1; hacerse por los Inspectores fiscales en virtud del citado art&#xED;culo. Trascr&#xED;base a quienes corresponda, e impr&#xED;mase en el Boletin.</div></div>", "i": 10069354}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  ERRAZURIZ.</div><div class=\"p\">&nbsp; &nbsp;  Benavente.</div></div>", "i": 10069355}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["DEPARTAMENTO DE HACIENDA"], "titulo_norma": "DEPARTAMENTO DE HACIENDA.; OBSERVANCIA DEL ARTICULO 243 DE LA CONSTITUCION.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-02-16", "doble_articulado": false, "id_norma": "1138339", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-02-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-02-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-02-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "