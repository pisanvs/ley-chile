{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 7250275}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 133, de 26 de Enero de 1988, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se modifica la resoluci&#xF3;n No. 210/86, en el sentido de sustituir los ciento treinta cupos diarios con que la empresa de origen chileno &quot;Sociedad de Transporte Cordillera Nevada Limitada&quot;, efect&#xFA;a el servicio regular de transporte terrestre de pasajeros entre Santiago - Valpara&#xED;so -</div><div class=\"p\">Vi&#xF1;a del Mar - Mendoza, por nueve frecuencias diarias de ida y vuelta.</div><div class=\"p\">La empresa antes individualizada est&#xE1; autorizada para reforzar las frecuencias en un cincuenta por ciento (50%).</div><br></div>", "i": 7250276}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Patricio Figueroa Cruz, Subsecretario de Transportes subrogante.</div><br></div>", "i": 7250277}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "133", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-133"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-26", "doble_articulado": false, "id_norma": "138558", "numero_fuente": "33000", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-19", "vigencias": [{"desde": "1988-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-19", "fin_vigencia": ""}, "vig