{"html": [{"t": "<div><div class=\"p\">DISPONE EXPROPIACION PARCIAL DE INMUEBLE</div><br><br><br><br></div>", "i": 6116773}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Decreto Secc. 2da. N&#xBA;460, junio 15 1998, Alcalde Municipalidad Santiago dispone expropiaci&#xF3;n parcial, conforme art. 85 decreto 458 Ministerio Vivienda y Urbanismo inmueble 21 de Mayo 767, Rol N&#xBA; 227-003, comuna Santiago, dominio aparente Sociedad de Rentas 21 de Mayo S.A., superficie aproximada 185 metros cuadrados. Deslindes: Norte, 5,80 mts. ensanche 21 de Mayo; Sur, 6,50 mts. calle Esmeralda; Oriente, 30 mts. resto predio, y Poniente, 30 mts. calle 21 de Mayo. Indemnizaci&#xF3;n $79.550.000.- pagadera contado.</div><br></div>", "i": 6116774}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jaime Ravinet de la Fuente, Alcalde Santiago. </div></div>", "i": 6116775}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "460", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-460"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "DISPONE EXPROPIACION PARCIAL DE INMUEBLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SANTIAGO", "REGION MEROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-06-15", "doble_articulado": false, "id_norma": "120622", "numero_fuente": "36102", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-07-01", "vigencias": [{"desde": "1998-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen