{"html": [{"t": "<div><div class=\"p\">&#xFEFF;DECLARACION SOBRE PATENTES.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Setiembre 5 de 1825.</div></div>", "i": 10182598}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Los extranjeros que tengan carta de ciudadan&#xED;a, y los que no teni&#xE9;ndola, obran como si la tuviesen, manteniendo tiendas o despachos por menor, cuyo jiro es solamente permitido a los ciudadanos, son obligados por ahora &#xE0; tomar patente de la clase, que por la lei de 5 de Agosto de 1824 corresponda a los hijos del pais por igual jiro, sin perjuicio de lo que la pr&#xF3;xima Legislatura tuviese a bien disponer sobre el particular. T&#xF3;mese razon, trascr&#xED;base e impr&#xED;mase.</div></div>", "i": 10182599}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Correa de Saa.</div></div>", "i": 10182600}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "DECLARACION SOBRE PATENTES", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-09-05", "doble_articulado": false, "id_norma": "1151487", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-09-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-09-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_