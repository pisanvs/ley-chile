{"html": [{"t": "<div><br><div class=\"p\"> </div><div class=\"p\">EXTRACTO </div></div>", "i": 9972699}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA; 1559, de 13 de noviembre de 2018, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA;, del Decreto Exento MOP. N&#xBA;290, de 28 de abril de 2017, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote de terreno N&#xBA;43-A, expropiado con motivo de la obra: &#x201C;Mejoramiento Ruta 7, Sector Lenca - La Arena Tramo: Chaicas - La Arena, Km. 37,47600 a Km. 44,60900&#x201D;, Comuna de Puerto Montt, Regi&#xF3;n de Los Lagos. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n fijada mediante tasaci&#xF3;n de 22 de mayo de 2015, ascendente a la cantidad $1.171.000, para el lote N&#xB0;43-A. </div></div>", "i": 9972700}, {"t": "<div><div class=\"p\">.</div></div>", "i": 9972701}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1559 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1559 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1503004", "NORMA SIN PROMULGACIÓN", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-11-13", "doble_articulado": false, "id_norma": "1126115", "numero_fuente": "42219", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-12-01", "vigencias": [{"desde": "2018-12-01", "hasta": "