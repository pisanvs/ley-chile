{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 10,807</div><br><div class=\"p\">REHABILITA EN LA NACIONALIDAD CHILENA A DON NICOLAS LOLAS CAFATE</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6600215}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Rehabil&#xED;tase en la nacionalidad chilena a don Nicol&#xE1;s Lolas Cafate.</div><br></div>", "i": 6600216}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, once de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- C. Torres H. </div></div>", "i": 6600217}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10807", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10807"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "REHABILITA EN LA NACIONALIDAD CHILENA A DON NICOLAS\nLOLAS CAFATE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-11", "doble_articulado": false, "id_norma": "258083", "numero_fuente": "22386", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-10-25", "vigencias": [{"desde": "1952-10-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1952-10-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1952-10-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac