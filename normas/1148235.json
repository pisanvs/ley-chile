{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 1.550 EXENTA, DE 2020, DE ESTA SUBSECRETAR&#xCD;A</div></div>", "i": 10149311}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.752, de 6 de agosto de 2020 de esta Subsecretar&#xED;a, modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1147577&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.550, de 2020</a>, de esta Subsecretar&#xED;a, ampliando el plazo de postulaci&#xF3;n hasta el lunes 17 de agosto de 2020 y efectuando los dem&#xE1;s cambios que se indican en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><br></div>", "i": 10149312}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de agosto de 2020.- Rom&#xE1;n Zelaya R&#xED;os, Subsecretario de Pesca y Acuicultura.</div><br></div>", "i": 10149313}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1752 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-1752 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 1.550 EXENTA, DE 2020, DE ESTA SUBSECRETARÍA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1798188", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-08-06", "doble_articulado": false, "id_norma": "1148235", "numero_fuente": "42730", "tipo_version"