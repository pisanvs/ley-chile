{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5903624}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto MOP. N&#xB0;254, de 26 de Agosto de 1993, se expropiaron los lotes de terreno N&#xB0;s. 4, 23, 29, 30, 31 y 47, superficies 53 m2., 60m2., 4.490m2., 1.080m2., 8.740 m2. y 240 m2., roles de aval&#xFA;o, uno en tr&#xE1;mite, 34-34, 34-31, 34-19 y 34-32, Comunas de Nancagua y Ch&#xE9;pica, para la obra Camino Nancagua-Puquillay-Ch&#xE9;pica y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Flor del Carmen Duarte Olgu&#xED;n, Luis Patricio Crespo Ureta y Gabriela de las M. Meneses Videla, ascendente a las cantidades de $350.695.- para el lote 4; $5.428.189.- para los lotes 23, 29, 30 y 31, y $216.576.- para el lote 47, respectivamente.- </div></div>", "i": 5903625}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 5903626}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "254", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-254"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DECRETO EXPROPIATORIO", "EXPROPIACION", "BIEN RAIZ", "BIEN INMUEBLE", "NANCAGUA", "CHEPICA", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-08-26", "doble_articulado": false, "id_norma": "11561", "numero_fuente": "34680-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-10-01", "vigencias": [{"desde": "1993-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v