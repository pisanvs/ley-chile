{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8309169}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.580, de 18 de noviembre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud presentada por la SOCIEDAD PESQUERA MC HUGH Y CIA. LTDA. para sustituir la nave &quot;Timonel 8&quot;, por no dar cumplimiento a lo dispuesto en los art&#xED;culos 2, 3 y 4 del D.S. N&#xBA; 64 de 1992, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n y por encontrarse caducada. </div></div>", "i": 8309170}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de noviembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8309171}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1580", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1580"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "SOCIEDAD PESQUERA MC HUGH Y CIA. LTDA.", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-11-18", "doble_articulado": false, "id_norma": "78694", "numero_fuente": "35927", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-11-27", "vigencias": [{"desde": "1997-11-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-11-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-11-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "in