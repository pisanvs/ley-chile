{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL CONSEJO EN SU SESION N&#xBA; 811 </div><br></div>", "i": 6214345}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 811, celebrada el 23 de diciembre de 1999, adopt&#xF3; los siguientes Acuerdos:</div><br><div class=\"p\">811-06-991223 - Tasa de inter&#xE9;s para pago diferido de derechos de Aduana.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3;, en conformidad con lo establecido en la letra c) del Art. N&#xBA; 10 de la ley N&#xBA; 18.634, que la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de derechos de aduana durante el semestre que expira el 30 de junio del 2000, ser&#xE1; de 13,90% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.</div><br></div>", "i": 6214346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de diciembre de 1999.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6214347}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "811", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-811"}, {"tipo": "5", "numero": "811-06-991223", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-811-06-991223"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL CONSEJO EN SU SESION Nº 811", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-23", "doble_articulado": false, "id_norma": "149941", "numero_fuente": "36549", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-12-28", "vigencias": [{"desde": "1999-12-28", "hasta": "", "tipo_version":