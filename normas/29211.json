{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CONCEDE NACIONALIDAD CHILENA AL PADRE GUSTAVO LE PAIGE</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8284417}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese al Padre Gustavo Le Paige la nacionalidad chilena, en reconocimiento de la gran obra realizada en beneficio de Chile.</div><br></div>", "i": 8284418}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, tres de Julio de mil novecientos setenta y dos.- SALVADOR ALLENDE GOSSENS.- Hern&#xE1;n del Canto R.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud.- para su conocimiento.- Saluda atentamente a Ud.- Daniel Vergara Bustos, Subsecretario del Interior.</div><br></div>", "i": 8284419}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "17684", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-17684"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE NACIONALIDAD CHILENA AL PADRE GUSTAVO LE\nPAIGE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NACIONALIDAD CHILENA GRACIA", "PADRE GUSTAVO LE PAIGE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1972-07-03", "doble_articulado": false, "id_norma": "29211", "numero_fuente": "28302", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1972-07-14", "vigencias": [{"desde": "1972-07-14", "hasta": "", "tipo_version": "3", "tipo_version_s