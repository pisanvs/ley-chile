{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6221017}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 120 de fecha 25 de Junio de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la II Regi&#xF3;n se autoriza a Soc. Buses Antofagasta Mantos Blancos Ltda., para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.- </div></div>", "i": 6221018}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Guido M. Ram&#xED;rez Maturana, SEREMI de Transportes y Telecomunicaciones II Regi&#xF3;n.</div><br></div>", "i": 6221019}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "120", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-120"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL II REGIÓN DE ANTOFAGASTA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-25", "doble_articulado": false, "id_norma": "151868", "numero_fuente": "32841", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-08", "vigencias": [{"desde": "1987-08-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-08-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-08-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JA