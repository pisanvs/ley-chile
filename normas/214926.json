{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6440579}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.136, de 1 de septiembre de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 11&#xBA; de la resoluci&#xF3;n N&#xBA; 220 de 2002, modificada por resoluci&#xF3;n N&#xBA; 2.184 de 2002, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; a la UNIVERSIDAD CATOLICA DEL NORTE para realizar actividades experimentales sobre la especie Abal&#xF3;n japon&#xE9;s, en conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del proyecto &quot;Cultivos de Abal&#xF3;n japon&#xE9;s Haliotis discus hannai en estanques y en el mar&quot;, en el sentido de se&#xF1;alar que la autorizaci&#xF3;n rige hasta el 31 de diciembre de 2003. </div></div>", "i": 6440580}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de septiembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6440581}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2136 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2136 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-09-01", "doble_articulado": false, "id_norma": "214926", "numero_fuente": "37664", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-20", "vigencias": [{"desde": "2003-09-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-20", "fin_vigencia": ""}, "vigencias_version_