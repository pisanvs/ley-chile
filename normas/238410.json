{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6527612}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA;361, de fecha 29 de abril de 2005, se expropiaron los lotes de terreno N&#xBA;s.</div><div class=\"p\">81-A y 82-A, superficies 158 y 96 m&#xB2;, Roles N&#xBA;s. 518-426 y 518-427, comuna de Antuco, VIII Regi&#xF3;n, para la obra &quot;Camino Ruta Q-45, Sector Antuco - Abanico, Tramo II Km.</div><div class=\"p\">3,95000 a Km. 12,40150&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Edith Mar&#xED;a Bobadilla Cea, ascendente a la cantidad de $338.416.</div><br></div>", "i": 6527613}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6527614}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "361 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-361 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-04-29", "doble_articulado": false, "id_norma": "238410", "numero_fuente": "38174", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-06-01", "vigencias": [{"desde": "2005-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-06-01", "fecha_version": "2005-06-01", "fecha_actualizacion_texto