{"html": [{"t": "<div><div class=\"p\">PRORROGA AUTORIZACION QUE INDICA </div></div>", "i": 8344085}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 249, de 04 de Marzo de 1988, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por el plazo de 6 meses a contar del 04 de Marzo de 1988, la autorizaci&#xF3;n conferida a Empresa Pesquera Mar del Sur S.A., domiciliada en Santiago, para desarrollar faenas de pesca exploratoria en el &#xE1;rea comprendida entre los paralelos 47&#xB0; y 56&#xB0; L.S., en aguas interiores y exteriores con sus barcos f&#xE1;brica &quot;Mar del Sur I&quot; y &quot;Mar del Sur II&quot;, en los t&#xE9;rminos y condiciones establecidos en la resoluci&#xF3;n No. 570, de 1987, de esta Subsecretaria.</div><br></div>", "i": 8344086}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 04 de Marzo de 1988.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8344087}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "249", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-249"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-04", "doble_articulado": false, "id_norma": "135423", "numero_fuente": "33022", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-03-16", "vigencias": [{"desde": "1988-03-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-03-16", "fin_v