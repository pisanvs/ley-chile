{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6077940}, {"t": "<div><div class=\"p\">El Banco Central de Chile, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de marzo de 1991, fue de 5,82% anual.</div><br></div>", "i": 6077941}, {"t": "<div><div class=\"p\">Santiago, 20 de marzo de 1991.- V&#xED;ctor Vial del R&#xED;o, Secretario General.</div><br></div>", "i": 6077942}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["ESTA NORMA NO TIENE TITULO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-03-20", "doble_articulado": false, "id_norma": "88051", "numero_fuente": "33924", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-03-21", "vigencias": [{"desde": "1991-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-03-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-03-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1998-02-05", "fecha_version": "1991-03-21", "fecha_actualizacion_texto": "1991-03-21", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6077940}, {"n": "Artículo", "i":