{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 3,974.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6192699}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se concede, por gracia, al ex-conscripto Gabriel Morales Dom&#xED;nguez, una pension de retiro equivalente al sueldo &#xED;ntegro que a un soldado se&#xF1;alan las leyes vijentes.</div><br></div>", "i": 6192700}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a once de agosto de mil novecientos veintitres.- Arturo Alessandri.- Luis Altamirano. </div></div>", "i": 6192701}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3974", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3974"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1923-08-11", "doble_articulado": false, "id_norma": "143922", "numero_fuente": "13650", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1923-08-11", "vigencias": [{"desde": "1923-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1923-08-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1923-08-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-09-2