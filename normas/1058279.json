{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">NOTIFICACIONES</div></div>", "i": 9400091}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Res. Ex. N&#xBA; 368 de 01/04/13: Vistos: Acta de Denuncia y Citaci&#xF3;n N&#xBA; 3327 de 18/03/13, cursada a Beatriz Betty Molina Conde, C.I. N&#xBA; 48.278.458-1, nacionalidad peruana, domicilio desconocido, que indica: portar 0,5 Kg. de duraznos y 0,6 Kg. de granadina, sin declararlo. Considerando: 1.- Que se ha infringido el decreto ley N&#xBA; 3.557; 2.- Declaraci&#xF3;n del denunciado, quien reconoce los hechos, pero que no lo declar&#xF3; por olvido; 3.- El informe de la Encargada Regional de Controles Fronterizos quien pondera el perjuicio de la infracci&#xF3;n al DL 3.557. Resuelvo: 1.- Absu&#xE9;lvase de los cargos.</div></div>", "i": 9400092}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Firma: Andr&#xE9;s Puiggros Vogel, Director SAG, Regi&#xF3;n de Arica y Parinacota</div></div>", "i": 9400093}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "368 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-368 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO XV REGIÓN DE ARICA Y PARINACOTA"], "titulo_norma": "NOTIFICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-04-01", "doble_articulado": false, "id_norma": "1058279", "numero_fuente": "40757", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-01-15", "vigencias": [{"desde": "2014-01-15", "hasta": "", "tipo_version": "3", "tipo_