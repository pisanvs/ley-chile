{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8318693}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 29, de 13 de enero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud presentada por SOCIEDAD PESQUERA COLOSO S.A., para prorrogar la vigencia de las Resoluciones de la Subsecretar&#xED;a de Pesca que autorizaron la realizaci&#xF3;n de actividades pesqueras extractivas para naves de su flota, por no haberse acreditado una causal de fuerza mayor.</div><br></div>", "i": 8318694}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de enero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8318695}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "29", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-29"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "SOLICITUD DE REPOSICION", "SOCIEDAD PESQUERA COLOSO S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-01-13", "doble_articulado": false, "id_norma": "88374", "numero_fuente": "35970", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-21", "vigencias": [{"desde": "1998-01-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-01-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "GMR