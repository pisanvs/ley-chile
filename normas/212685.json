{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6432393}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.584, de 9 de julio de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a ALIMENTOS MARINOS S.A., para realizar actividades extractivas en aguas internacionales en orden a operar la nave &quot;Vichuqu&#xE9;n II&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2934 - Valpara&#xED;so</div><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp;  CBVH</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp;  64,32 m.</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 12,6 m.</div><div class=\"p\">TRG (Internacional)&nbsp; 1.694,00</div><div class=\"p\">Potencia principal&nbsp;  5320,00 hp</div><div class=\"p\">Potencia auxiliar&nbsp; &nbsp; 1038,00 hp</div><div class=\"p\">Arte de pesca&nbsp; &nbsp; &nbsp; &nbsp; Cerco,&nbsp; arrastre de media agua.</div><br></div>", "i": 6432394}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de julio de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6432395}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1584 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1584 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-07-09", "doble_articulado": false, "id_norma": "212685", "numero_fuente": "37612", "tipo_version": "3", "tipo_v