{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 447 EXENTO, DE 1999 </div></div>", "i": 6297598}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 447 de 29 de diciembre de 1999, se ha aprobado al &apos;&apos;British Royal School&apos;&apos; de Concepci&#xF3;n, de la comuna de San Pedro de la Paz, VIII Regi&#xF3;n del B&#xED;o-B&#xED;o, un plan de estudio para los cursos de 1&#xBA;, 2&#xBA;, 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA; a&#xF1;o (NB.1, NB.2, NB.3 y NB.4) de Ense&#xF1;anza B&#xE1;sica, el que se aplicar&#xE1; simult&#xE1;neamente en todos los cursos a contar del a&#xF1;o escolar 2000.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores de los cursos que se indican en el presente decreto.</div><br></div>", "i": 6297599}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de enero de 2000.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6297600}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "447 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-447 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 447 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-29", "doble_articulado": false, "id_norma": "174581", "numero_fuente": "36746", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-23", "vigencias": [{"desde": "2000-08-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-23", "fin_vigencia": "