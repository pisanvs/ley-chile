{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,546.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6172311}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Isabel Walch, viuda del capitan de fragata de la Armada Nacional don Domingo Salamanca, derecho a percibir la pension de montep&#xED;o militar correspondiente al empleo de capitan de nav&#xED;o, en vez de la que actualmente disfruta. </div></div>", "i": 6172312}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, treinta de agosto de mil novecientos once.- Ramon Barros Luco.- Alejandro Huneeus G. H. </div></div>", "i": 6172313}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2546", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2546"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-08-30", "doble_articulado": false, "id_norma": "137510", "numero_fuente": "10107", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-10-17", "vigencias": [{"desde": "1911-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-10-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-10-17", "fin_vigencia": "", "tipo_version": "3"}], "evento