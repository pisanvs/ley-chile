{"html": [{"t": "<div><div class=\"p\">NOTIFICACI&#xD3;N </div></div>", "i": 7375678}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;4.003 de 27 de junio de 2008 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme D.L. N&#xBA;2.186 de 1978, del Lote N&#xBA;42-B, correspondiente a parte del inmueble ubicado en Ca&#xF1;ete Interior 1765, Rol de Aval&#xFA;o N&#xBA;2233-57, de la comuna de Conchal&#xED;, aparente dominio de Posch Fern&#xE1;ndez Gottlieb. Comisi&#xF3;n integrada por peritos se&#xF1;ores Mar&#xED;a Ang&#xE9;lica Hurtado Arranz, Arquitecto, Alfredo Irizarri Valderrama, Arquitecto y Carmen Pilar R&#xED;os Marcuello, ingeniero civil. Seg&#xFA;n informe de 19 de mayo de 2008, fij&#xF3; monto provisional indemnizaci&#xF3;n en $902.040, pagadera al contado. </div></div>", "i": 7375679}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director (S) Serviu Metropolitano.</div><br></div>", "i": 7375680}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4003 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4003 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "DISPONE EXPROPIACIÓN PARCIAL Y TOTAL DE INMUEBLES QUE INDICAN; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-06-27", "doble_articulado": false, "id_norma": "274315", "numero_fuente": "39113", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-07-15", "vigencias": [{"desde": "2008-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vige