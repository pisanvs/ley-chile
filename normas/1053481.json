{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 5.688 EXENTA, DE 2013</div></div>", "i": 9368744}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 5.688, de 29 de julio de 2013, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Araneda Montaner Sociedad Limitada (Mqm Capacitaciones)&quot;, RUT 76.168.943-6 contenida en la resoluci&#xF3;n exenta N&#xBA; 2.739 de 21 de marzo de 2012, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2 del Art. 21 de la ley 19.518.- </div></div>", "i": 9368745}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (S).</div></div>", "i": 9368746}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5688 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5688 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 5.688 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-07-29", "doble_articulado": false, "id_norma": "1053481", "numero_fuente": "40627", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-08-06", "vigencias": [{"desde": "2013-08-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-08-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-08-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincula