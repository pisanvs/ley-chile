{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;mero 4,372</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6211881}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- En atenci&#xF3;n a los servicios prestados a la Instrucci&#xF3;n P&#xFA;blica por la educacionista do&#xF1;a Concepci&#xF3;n Urbina v. de Villal&#xF3;n, conc&#xE9;desele, por gracia, una pensi&#xF3;n de mil doscientos pesos ($ 1,200) anuales.&quot; </div></div>", "i": 6211882}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a diez de Agosto de mil novecientos veintiocho.- Carlos Ib&#xE1;&#xF1;ez del Campo.- J. Eduardo Barrios. </div></div>", "i": 6211883}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4372", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4372"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-08-10", "doble_articulado": false, "id_norma": "149316", "numero_fuente": "15162", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-08-30", "vigencias": [{"desde": "1928-08-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-08-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1928-08-30", "fin_vigencia": "", "tipo_version": "