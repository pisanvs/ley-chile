{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 8.342 EXENTA, DE 1999 </div></div>", "i": 6260523}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 8.342 de 8 de septiembre de 1999, se ha aprobado al Colegio &apos;&apos;The British School&apos;&apos;, de Punta Arenas, XII Regi&#xF3;n de Magallanes y la Ant&#xE1;rtica Chilena, un plan especial de estudio para segundo a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2000.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para segundo a&#xF1;o de ense&#xF1;anza media de los subsectores que se indican en la presente resoluci&#xF3;n exenta.</div><br></div>", "i": 6260524}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de septiembre de 1999.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6260525}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8342 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8342 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 8.342 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-09-08", "doble_articulado": false, "id_norma": "164102", "numero_fuente": "36632", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-05", "vigencias": [{"desde": "2000-04-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-04-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "20