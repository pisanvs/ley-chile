{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0;483, DE 1993 </div></div>", "i": 7161934}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0;483 de 21 de septiembre de 1993 se ha modificado y complementado el plan especial de estudio del Colegio Craighouse de Santiago, aprobado por decreto supremo exento de Educaci&#xF3;n N&#xB0;318 de 1986.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa de estudio para la asignatura de Computaci&#xF3;n que se imparte en 7&#xB0; y 8&#xB0; a&#xF1;o b&#xE1;sico.</div><br></div>", "i": 7161935}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 5 de Octubre de 1993.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161936}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "483", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-483"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N°483, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "COLEGIO CRAIGHOUSE SANTIAGO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-09-21", "doble_articulado": false, "id_norma": "21333", "numero_fuente": "34693", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-10-18", "vigencias": [{"desde": "1993-10-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-10-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-10-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url