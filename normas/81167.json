{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8311946}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xBA;1.129, de 3 de Septiembre de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA;1.295, de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA HUALPEN S.A., R.U.T. N&#xBA;95.504.000-7, domiciliada en Talcahuano, que modific&#xF3; la resoluci&#xF3;n N&#xBA;1062, de 1988, en el sentido de se&#xF1;alar que el litoral autorizado para operar la nave &quot;Licant&#xE9;n&quot;, comprende las Regiones VI a X. </div></div>", "i": 8311947}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 3 de Septiembre de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8311948}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1129", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1129"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-09-03", "fecha_derogacion": "2001-05-14", "doble_articulado": false, "id_norma": "81167", "numero_fuente": "34081", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-10-02", "vigencias": [{"desde": "2001-05-14", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1991-10-02", "hasta": "2001-05-13", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2001-05-14", "fin_vigencia": ""}, "vigencias_version_