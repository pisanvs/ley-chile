{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,606.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6172510}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Mercedes Novoa, viuda del soldado de la Independencia don Diego Toro, una pension mensual de veinticinco pesos ($ 25), de la que disfrutar&#xE1; con arreglo a la lei de montep&#xED;o militar i con esclusion de toda otra asignacion fiscal.</div><br></div>", "i": 6172511}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, once de enero de mil novecientos doce.- Ramon Barros Luco.- Alejandro Huneeus.</div><br></div>", "i": 6172512}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2606", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2606"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-01-11", "doble_articulado": false, "id_norma": "137589", "numero_fuente": "10177", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-01-12", "vigencias": [{"desde": "1912-01-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-01-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-01-12", "fin_vigencia": "", "tipo_version": "3"}], "even