{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6005877}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 0100 de 2 de Abril de 1993, del Serviu V. Regi&#xF3;n de Valpara&#xED;so, se dispuso la expropiaci&#xF3;n conforme Art&#xED;culo 87 Ley 8.946 de Pavimentaci&#xF3;n Comunal y Decreto Ley N&#xB0; 2.186 de 1978, de parte de lote N&#xB0; 205 de calle Pedro de Valdivia, comuna de Vi&#xF1;a del Mar, rol de aval&#xFA;o N&#xB0; 1594-205, en 29 M2, de aparente dominio de Silvia Gonz&#xE1;lez P&#xE9;rez.</div><div class=\"p\">&nbsp; &nbsp; Comisi&#xF3;n Tasadora integrada por arquitecto Osvaldo Mu&#xF1;oz Quintana y constructores civiles Alvaro Verdejo Vidal y Pablo Caria Giurici, seg&#xFA;n informe de fecha 8 de Marzo de 1993, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 101.500.-, la que se pagar&#xE1; de contado.-</div><br></div>", "i": 6005878}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director Serviu V Regi&#xF3;n.</div><br></div>", "i": 6005879}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "100", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-100"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BIEN RAIZ", "BIEN INMUEBLE", "EXPROPIACION", "DECRETO EXPROPIATORIO", "VI A DEL MAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-04-02", "doble_articulado": false, "id_norma": "33077", "numero_fuente": "34555", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-05-03", "vigencias": [{"desde": "1993-05-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-05-03", "fin