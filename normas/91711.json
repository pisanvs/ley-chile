{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 105, DE 1989 </div></div>", "i": 8929991}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n Exenta de la referencia se han aprobado Planes y Programas de Estudio para la Educaci&#xF3;n Media T&#xE9;cnico Profesional, a contar del a&#xF1;o escolar 1989 y hasta el a&#xF1;o escolar 1993 inclusive, para el Liceo A-8 &quot;Instituto del Mar Carlos Condell&quot; de Iquique.</div><br><div class=\"p\">ESPECIALIDADES:</div><br><div class=\"p\">1.- Extracci&#xF3;n Pesquera.</div><div class=\"p\">2.- Mec&#xE1;nica Naval.</div><div class=\"p\">3.- Elaboraci&#xF3;n Productos Pesqueros.</div><div class=\"p\">4.- Acuicultura.</div><br></div>", "i": 8929992}, {"t": "<div><div class=\"p\">Iquique.- Benigna Barrios Herrera, Secretario Ministerial Educaci&#xF3;n I Regi&#xF3;n Tarapac&#xE1;.</div><br></div>", "i": 8929993}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "105 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-105 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA NO. 105, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "91711", "numero_fuente": "33361", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-05-02", "vigencias": [{"desde": "1989-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-05-02", "fin_vigencia": "", "tipo_version": "3"}], "e