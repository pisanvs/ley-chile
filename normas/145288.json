{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8351453}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.982, de 6 de octubre de 1999, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 1.442 de 1999, de esta Subsecretar&#xED;a, que fij&#xF3; la n&#xF3;mina de armadores y embarcaciones que cumplen con los requisitos legales para operar en las unidades de pesquer&#xED;a de Sardina espa&#xF1;ola Sardinops sagax y Anchoveta Engraulis ringens, declaradas en estado de plena explotaci&#xF3;n y sometidas a dicho r&#xE9;gimen de administraci&#xF3;n, en el litoral de la I y II Regiones, se&#xF1;alada en el DS N&#xBA; 354 de 1993, en el &#xE1;rea se&#xF1;alada en sus respectivas autorizaciones, en orden a incorporar lo siguiente:</div><br><div class=\"p\">EPERVA S.A. PESQUERA: Eperva 66.</div><br></div>", "i": 8351454}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de octubre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8351455}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1982", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1982"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-10-06", "fecha_derogacion": "2000-01-22", "doble_articulado": false, "id_norma": "145288", "numero_fuente": "36488", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-10-14", "vigencias": [{"desde": "2000-01-22", "hasta": "", "tipo_version": "2",