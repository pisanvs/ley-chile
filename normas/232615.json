{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6505420}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA; 1.446, de 21 de octubre</div><div class=\"p\">de 2004, y en base a la facultad otorgada por el</div><div class=\"p\">art&#xED;culo 105 del DFL MOP N&#xBA; 850 de 1997, que fij&#xF3; el texto actualizado de la ley N&#xBA; 15.840, se expropi&#xF3; el lote de terreno N&#xBA; 4, para la obra: Mejoramiento Ruta 11CH, sector Arica - Tambo Quemado, sectores Bif. Putre - Bif. Choquelimpie, Km. 124,500 a Km. 147,76212, I Regi&#xF3;n, que figura a nombre de Medina Alberto Primitivo, rol de aval&#xFA;o 3810-14, superficie 2.252 m2. La Comisi&#xF3;n de Peritos, fij&#xF3; con fecha 11 de septiembre de 2004, en la cantidad de $225.200. La indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.</div><br></div>", "i": 6505421}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6505422}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1446 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1446 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-21", "doble_articulado": false, "id_norma": "232615", "numero_fuente": "38010", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-11-15", "vigencias": [{"desde": "2004-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}]