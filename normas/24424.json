{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; LEI NUM. 4,038, QUE CONCEDE DERECHO A JUBILAR A DON URBANO VERGARA</div><div class=\"p\">&nbsp; &nbsp; LEI NUM. 4,038.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5957784}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al sub-director de la Direcci&#xF3;n Jeneral de Impuestos Internos, don Urbano Vergara, el derecho a jubilar con una pension anual equivalente al sueldo de que goza en el ejercicio de su cargo.</div><br></div>", "i": 5957785}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 27 de Agosto de 1924.- Arturo Alessandri.- Enrique Za&#xF1;artu P.</div><br></div>", "i": 5957786}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4038", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4038"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LEI NUM. 4,038, QUE CONCEDE DERECHO A JUBILAR A DON;URBANO VERGARA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["URBANO VERGARA", "JUBILACION", "CONCESION", "BENEFICIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1924-08-27", "doble_articulado": false, "id_norma": "24424", "numero_fuente": "13967", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1924-09-01", "vigencias": [{"desde": "1924-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni