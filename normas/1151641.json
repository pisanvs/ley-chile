{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10175010}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xBA; 4.580 de 2 de noviembre de 2020, rectifica la <a href=\"https://www.leychile.cl/Navegar?idNorma=1149877&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.422, de fecha 25 de agosto de 2020</a>, que instruye a titulares de registros sanitarios, y a los solicitantes de dichos registros, a declarar la especie vegetal del almid&#xF3;n utilizado como excipiente en los productos farmac&#xE9;uticos que lo contienen en su formulaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10175011}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Heriberto Garc&#xED;a Escorza, Director (S), Instituto de Salud P&#xFA;blica de Chile.</div><div class=\"p\"> </div><br></div>", "i": 10175012}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4580 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4580 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1847378", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-11-02", "doble_articulado": false, "id_norma": "1151641", "numero_fuente": "42806", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-11-16", "vigencias": [{"desde": "2020-11-16", "hasta": "", "tipo_version": "3", "tipo_version_s"