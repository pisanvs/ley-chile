{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 305 EXENTO, DE 1996 </div></div>", "i": 5943688}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 305, de fecha 28 de mayo de 1996 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a las Sedes que se indican del Centro de Formaci&#xF3;n T&#xE9;cnica INACAP, para impartir planes y programas de estudios aprobados para la instituci&#xF3;n, de las carreras y t&#xED;tulos t&#xE9;cnicos de nivel superior que se se&#xF1;alan, a partir del a&#xF1;o 1996.</div><div class=\"p\"> Sede N&#xB0; 15.- Rancagua</div><div class=\"p\"> Carrera&nbsp; &nbsp; &nbsp; : Dise&#xF1;o y Producci&#xF3;n de Areas Verdes.</div><div class=\"p\"> T&#xED;tulo&nbsp; &nbsp; &nbsp;  : T&#xE9;cnico en Dise&#xF1;o y Producci&#xF3;n de</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Areas Verdes.</div><div class=\"p\"> Sede N&#xB0; 28.- Concepci&#xF3;n.</div><div class=\"p\"> Carrera&nbsp; &nbsp; &nbsp; : Cocina Internacional.</div><div class=\"p\"> T&#xED;tulo&nbsp; &nbsp; &nbsp;  : T&#xE9;cnico en Cocina Internacional.</div><br></div>", "i": 5943689}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 14 de junio de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943690}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "305", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-305"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 305 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA INACAP", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "AUTORIZACION", "RANCAGUA", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observacione