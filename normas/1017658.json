{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9015711}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.026, de 30 de septiembre de 2010, de esta Subsecretar&#xED;a, ac&#xF3;gense los descargos formulados y ampl&#xED;ese por 12 meses, a contar del 1&#xBA; de abril de 2010, el plazo otorgado por el numeral 5.- inciso 2&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=216692&amp;idParte=0&amp;idVersion=\">Resoluci&#xF3;n Exenta N&#xBA; 2.548, de 2003</a>, modificada por las resoluciones N&#xBA; 1.517 y N&#xBA; 2.643, ambas de 2004, y N&#xBA; 2.859, de 2008, todas de esta Subsecretar&#xED;a, a FRIOSUR X S.A., para reiniciar actividades pesqueras extractivas con la nave &quot;Don Enrique&quot; respecto del recurso hidrobiol&#xF3;gico Alfonsino Beryx splendens, en el &#xE1;rea mar&#xED;tima correspondiente al Archipi&#xE9;lago Juan Fern&#xE1;ndez, Isla de Pascua, Isla Sala y G&#xF3;mez e Islas Desventuradas.</div></div>", "i": 9015712}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de septiembre de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9015713}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3026 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3026 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2010-09-30", "fecha_derogacion": "2015-12-31", "doble_articulado": false, "id_norma": "1017658", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2010-10-08", "v