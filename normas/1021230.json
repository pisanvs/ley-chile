{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9077122}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA;2984, de 19 de noviembre de 2010, se dej&#xF3; sin efecto el decreto exento MOP N&#xBA;1159, de 27 de agosto de 2001, que ordenaba la expropiaci&#xF3;n del lote de terreno N&#xBA;14, para la obra &quot;Concesi&#xF3;n Internacional Interconexi&#xF3;n Vial Santiago - Valpara&#xED;so - Vi&#xF1;a del Mar. Tramo 18C. Km. 105.989,95 a Km. 109.300,40 &quot;, debido a que la expropiaci&#xF3;n se determin&#xF3; como improcedente, por tratarse el lote N&#xBA;14 expropiado de un bien nacional de uso p&#xFA;blico.</div></div>", "i": 9077123, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9077124}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2984 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2984 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO."], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-11-19", "doble_articulado": false, "id_norma": "1021230", "numero_fuente": "39835", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-12-15", "vigencias": [{"desde": "2010-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-12-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "i