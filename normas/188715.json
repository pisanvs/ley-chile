{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA DE ASOCIACION GREMIAL QUE INDICA </div></div>", "i": 6346826}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 18, de 10 de Febrero de 1986, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la personalidad jur&#xED;dica de la &quot;Asociaci&#xF3;n Gremial de Due&#xF1;os de Camiones de Villa Alemana&quot;, inscrita bajo el No. 211 del Registro de Asociaciones Gremiales que lleva este Ministerio, por haberse configurado respecto de ella las causales de cancelaci&#xF3;n contempladas en el art&#xED;culo 18 No. 2, letras b) y d) del DL 2.757.</div><br></div>", "i": 6346827}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jorge Valenzuela Dur&#xE1;n, Coronel de Ej&#xE9;rcito, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 6346828}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "18", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-18"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA DE ASOCIACION GREMIAL QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-02-10", "doble_articulado": false, "id_norma": "188715", "numero_fuente": "32416", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-03-07", "vigencias": [{"desde": "1986-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-03-07", "fin_vigencia": ""}, "vige