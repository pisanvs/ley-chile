{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6222894}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 47, de 27 de Agosto de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se autoriza al Sr. Juan Emilio Vald&#xE9;s Reyes para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva.</div><br></div>", "i": 6222895}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rancagua, 27 de Agosto de 1987.- Rigoberto G&#xF3;mez Lav&#xED;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n </div></div>", "i": 6222896}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "47 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-47 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-27", "doble_articulado": false, "id_norma": "152353", "numero_fuente": "32859", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-31", "vigencias": [{"desde": "1987-08-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-08-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-08-31", "fin_vigencia": "", "tipo_v