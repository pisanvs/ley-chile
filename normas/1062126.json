{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA;30 EXENTA, DE 2014</div></div>", "i": 9444470}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.175, de 30 de abril de 2014, de esta Subsecretar&#xED;a, modif&#xED;quese la <a href=\"https://www.leychile.cl/Navegar?idNorma=1058357&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 30, de 2014</a>, modificada mediante resoluciones exentas N&#xBA; 628, N&#xBA; 995, N&#xBA; 996, N&#xBA; 1.024 y N&#xBA; 1.045, todas de 2014, de esta Subsecretar&#xED;a, que estableci&#xF3; la distribuci&#xF3;n de la fracci&#xF3;n artesanal de la pesquer&#xED;a artesanal Merluza com&#xFA;n de la IV, V, VI, VII y VIII Regiones, en el sentido de se&#xF1;alar que la distribuci&#xF3;n enero-diciembre de 2014, en el &#xC1;rea Sur de la VIII Regi&#xF3;n, expresada en toneladas, se efectuar&#xE1; de la siguiente manera:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/39725.jpg\">.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><br></div>", "i": 9444471, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de abril de 2014.- Paolo Trejo Carmona, Subsecretario de Pesca y&nbsp; Acuicultura (S).</div></div>", "i": 9444472}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1175 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1175 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº30 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-04-30", "doble_articulado": false, "id_norma": "1062126", "numero_fuente": "40852", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-05-09", "vigencias": [{"desde": "2014-05-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-05-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014-05-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "1289", "fecha_ingreso": "2014-05-09", "fecha_version": "2014-05-09", "fecha_actualizacion_texto": "2014-05-09", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9444470}, {"n": "Artículo", "i": 9444471, "t": 6}, {"n": "Promulgación", "i": 9444472}]}