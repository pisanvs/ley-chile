{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.752 EXENTA, DE 2014</div></div>", "i": 9495165}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 3.752 de 15 de julio de 2014, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Servicios de Capacitaci&#xF3;n Impacto Limitada (Impacto Limitada)&quot;, RUT 76.091.253-0 contenida en la resoluci&#xF3;n exenta N&#xBA; 5.778 de 16 de junio de 2010, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 3, del Art. 21 de la Ley 19.518.</div></div>", "i": 9495166}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Marcia Pardo Gonz&#xE1;lez, Jefa del Departamento de Desarrollo y Regulaci&#xF3;n de Mercado (PT).</div></div>", "i": 9495167}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3752 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3752 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.752 EXENTA, DE 2014", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2014-07-15", "fecha_derogacion": "2014-08-19", "doble_articulado": false, "id_norma": "1065261", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2014-08-09", "vigencias": [{"desde": "2014-08-19", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2014-08-09", "hasta": "2014-08-18", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "v