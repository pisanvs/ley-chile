{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION No. 251 DE 17 DE JUNIO DE 1985 </div></div>", "i": 6265138}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado Planes y Programas Especiales de Estudio para Segundo Ciclo de la Educaci&#xF3;n Media T&#xE9;cnico Profesional, a contar del a&#xF1;o escolar 1985 y hasta el a&#xF1;o escolar 1990, inclusive, para el Liceo Industrial &quot;C&quot; No. 12, de Curacaut&#xED;n.</div><br><div class=\"p\">&nbsp; &nbsp;  ESPECIALIDADES:</div><div class=\"p\">&nbsp; &nbsp;  1.- Mec&#xE1;nica de M&#xE1;quinas Herramientas.</div><div class=\"p\">&nbsp; &nbsp;  2.- Electricidad Industrial: Menci&#xF3;n:</div><div class=\"p\">Electromec&#xE1;nica.</div><div class=\"p\">&nbsp; &nbsp;  3.- Electricidad Industrial: Menci&#xF3;n: Instalaciones El&#xE9;ctricas.</div><div class=\"p\">&nbsp; &nbsp;  4.- Alimentaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  5.- Atenci&#xF3;n de P&#xE1;rvulos.</div><br></div>", "i": 6265139}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  28 de junio de 1985.- Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica, subrogante.</div><br></div>", "i": 6265140}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "251 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-251 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION No. 251\nDE 17 DE JUNIO DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-17", "doble_articulado": false, "id_norma": "165603", "numero_fuente":