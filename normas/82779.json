{"html": [{"t": "<div><div class=\"p\">CADUCA RESOLUCION QUE INDICA </div></div>", "i": 8314165}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.060 de 30 de Agosto de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad conforme al art&#xED;culo 7&#xB0;, del decreto No. 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, de la resoluci&#xF3;n No.</div><div class=\"p\">1.045, de 1988, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Pesquera y Cultivos de Recursos Marinos Limitada, RUT No.</div><div class=\"p\">88.547.300-8, domiciliada en Caleta Prado Mejillones, para desarrollar actividades pesqueras de transformaci&#xF3;n. </div></div>", "i": 8314166}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 30 de Agosto de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8314167}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1060", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1060"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "CADUCA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-08-30", "doble_articulado": false, "id_norma": "82779", "numero_fuente": "33771", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-09-15", "vigencias": [{"desde": "1990-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-09-15", "fin_