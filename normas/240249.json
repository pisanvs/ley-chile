{"html": [{"t": "<div><div class=\"p\">EXTRACTO de DECRETO N&#xBA;807 EXENTO, DE 2005 </div></div>", "i": 6533567}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;807, de fecha 20 de junio de 2005, del Ministerio de Educaci&#xF3;n, se reemplaza a contar del a&#xF1;o 2005, las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto de Formaci&#xF3;n Empresarial IFE, Escuela de Negocios, que fueran aprobadas por decreto exento de Educaci&#xF3;n N&#xBA;183, del 12 de marzo de 2002.</div><br></div>", "i": 6533568}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de julio de 2005.- Pedro Montt Leiva, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6533569}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "807 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-807 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº807 EXENTO, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-20", "doble_articulado": false, "id_norma": "240249", "numero_fuente": "38215", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-20", "vigencias": [{"desde": "2005-07-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-07-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JRC", "fecha_ingreso": "2005-07-20", "fecha_ver