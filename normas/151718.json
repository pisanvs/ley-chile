{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6220575}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 1.085, de fecha 30 de Septiembre de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la V Regi&#xF3;n, se autoriza a Cristi&#xE1;n Romero Mu&#xF1;oz para efectuar las revisiones t&#xE9;cnicas de los veh&#xED;culos de transporte de personas de m&#xE1;s de nueve (9) asientos, incluido el del conductor; de veh&#xED;culos motorizados de carga con capacidad para transportar m&#xE1;s de 1.750 kilos, sus remolques y semirremolques y los taxis, en el establecimiento ubicado en Parcela N&#xB0; 2 Quebradilla, Km. 147,3 Ruta 5, de la Comuna de La Ligua.</div><br></div>", "i": 6220576}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de Septiembre de 1986.- Hern&#xE1;n V&#xE1;squez Wacquez, Capit&#xE1;n de Nav&#xED;o, Secretario Regional Ministerial de Transportes y Telecomunicaciones V Regi&#xF3;n. </div></div>", "i": 6220577}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1085", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1085"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-09-30", "doble_articulado": false, "id_norma": "151718", "numero_fuente": "32.589", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-10-06", "vigencias": [{"desde": "1986-10-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"ini