{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6298749}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.701, de 30 de junio de 2000, se expropiaron los lotes de terreno N&#xBA;s. 1 y 2, superficies 78 m&#xB2; y 352 m&#xB2;, rol de aval&#xFA;o 3983-61, comuna de Talca, para la obra Concesi&#xF3;n Internacional Ruta 5, tramo: Talca - Chill&#xE1;n, S&#xE9;ptima Regi&#xF3;n, y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Arnoldo Ramiro Villaseca Varela y Otros, ascendente a la cantidad total de $1.585.129.</div><br></div>", "i": 6298750}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6298751}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2701", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2701"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-06-30", "doble_articulado": false, "id_norma": "174877", "numero_fuente": "36754", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-01", "vigencias": [{"desde": "2000-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-09-06", "fecha_version": "2000-09-01", "fecha_actualizacion_texto": "2000-09-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "