{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10275994}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xBA; 990, de 21 septiembre 2021, prohibi&#xF3; circulaci&#xF3;n de veh&#xED;culos que indica en condiciones que se&#xF1;ala, relativas a Semana de la Movilidad en la ciudad de Coyhaique, y autoriz&#xF3; a Direcci&#xF3;n de Tr&#xE1;nsito Municipal de Coyhaique para realizar siguiente intervenci&#xF3;n en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - corte total de v&#xED;a en calle Condell entre Plaza de Armas y Av. Baquedano, entre los d&#xED;as lunes 20 y viernes 24 de septiembre de 2021.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10275995}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andrea Mac&#xED;as Palma, Gobernadora Regional, Gobierno Regional de Ays&#xE9;n.- Ximena Guti&#xE9;rrez Jaramillo, Asesora Jur&#xED;dica, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10275996}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "990 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-990 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2024051", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-09-21", "doble_articulado": false, "id_norma": "1166419", "numero_fuente": "43077", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-10-14", "vigencias": [{"desde": "2021-10-14", "hasta": "", "tipo_version": "3", "tipo_version_s"