{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,520.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br></div>", "i": 7165821}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Agr&#xE9;gase el promotor fiscal de Llanquihue a los indicados en el inciso 5&#xB0; del art&#xED;culo 2&#xB0; de la lei n&#xFA;mero 2,446, de 14 de enero de 1911, que fij&#xF3; los sueldos de los empleados del &#xF3;rden judicial. </div></div>", "i": 7165822}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, cuatro de agosto de mil novecientos once.- Ramon Barros Luco.- An&#xED;bal Letelier.</div><br></div>", "i": 7165823}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2520", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2520"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PODER JUDICIAL", "EMPLEADOS", "SUELDOS", "PROMOTORES FISCALES", "MODIFICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-08-04", "doble_articulado": false, "id_norma": "23345", "numero_fuente": "10053", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-08-10", "vigencias": [{"desde": "1911-08-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-08-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-08-10", "fin_vigencia": "", "t