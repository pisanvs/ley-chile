{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 2.902, DE 1989 </div></div>", "i": 6068143}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n Exenta No. 2.902 de fecha 09 de Noviembre de 1989 de la Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica, se aprobaron las adecuaciones introducidas a la carrera de Turismo y Hoteler&#xED;a del Centro de Formaci&#xF3;n T&#xE9;cnica Sim&#xF3;n Bol&#xED;var de Santiago, las que podr&#xE1;n aplicarse a contar de agosto de 1989.</div><br></div>", "i": 6068144}, {"t": "<div><div class=\"p\">Santiago, 09 de Marzo de 1990.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6068145}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2902 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2902 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 2.902, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-11-09", "doble_articulado": false, "id_norma": "84558", "numero_fuente": "33629", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-24", "vigencias": [{"desde": "1990-03-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-03-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-03-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MNV", "fecha_ingreso": "1998-01-13", "fecha_version": "1990-03-24", "fecha_actualizacion_texto": "1990-03