{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO AUTORIZACION QUE INDICA </div></div>", "i": 7270204}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 1.282 de 30 de Octubre de 1987 de esta Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deja sin efecto la autorizaci&#xF3;n conferida a Pesquera Trinidad S.A. por resoluci&#xF3;n N&#xB0; 972, de 1987, de esta Subsecretar&#xED;a de Pesca, para operar la embarcaci&#xF3;n denominada &quot;Maria Isabel&quot;. Se sustituye frase en el numeral 11&#xB0; y se declara que mantiene plena vigencia la resoluci&#xF3;n N&#xB0; 19, de 08 de enero de 1986, que autoriza a Soc. Comercial Mirna Ly y C&#xED;a. Ltda. para operar la embarcaci&#xF3;n &quot;Mar&#xED;a Isabel&quot;.</div><br></div>", "i": 7270205}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de Octubre de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 7270206}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1282", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1282"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "DEJA SIN EFECTO AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-10-30", "doble_articulado": false, "id_norma": "169262", "numero_fuente": "32921", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-16", "vigencias": [{"desde": "1987-11-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-16", "fin_vigencia": ""}