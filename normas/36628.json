{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8296713}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.279, de 29 de Diciembre de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a FUNDACION CHINQUIHUE, R.U.T. N&#xB0; 71.554.600-0, para iniciar actividades pesqueras, en orden a operar la planta ubicada en Camino a Chinquihue, Km. 12, Puerto Montt, donde podr&#xE1; procesar, en la l&#xED;nea de elaboraci&#xF3;n de Congelado, los siguientes recursos hidrobiol&#xF3;gicos: Salm&#xF3;n cereza, Salm&#xF3;n del Atl&#xE1;ntico, Salm&#xF3;n plateado, Salm&#xF3;n rey, Trucha arcoiris.</div><br><br></div>", "i": 8296714}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 29 de Diciembre de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8296715}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1279", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1279"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FUNDACION CHINQUIHUE", "INDUSTRIA PESQUERA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-12-29", "doble_articulado": false, "id_norma": "36628", "numero_fuente": "35072", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-01-20", "vigencias": [{"desde": "1995-01-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-01-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-01-20", "