{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xB0; 575, DE 1985</div><div class=\"p\">(Extracto) </div></div>", "i": 7259833}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xB0; 404, de 14 de Mayo de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n 575, de 12 de Septiembre de 1985, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a don Jos&#xE9; Albino Fern&#xE1;ndez Salas, para operar la embarcaci&#xF3;n &quot;Don Rufino&quot;, en orden a reemplazar en el inciso tercero del numeral 5&#xB0;, la frase &quot;a la industrializaci&#xF3;n en forma de conserva y congelado&quot;, por &quot;a consumo humano directo&quot;.</div><br></div>", "i": 7259834}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de Mayo de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7259835}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "404", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-404"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION N° 575, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-05-14", "doble_articulado": false, "id_norma": "153376", "numero_fuente": "32486", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-06-03", "vigencias": [{"desde": "1986-06-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-06-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia