{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 2, DE 1996 </div></div>", "i": 5939084}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 2 de fecha 9 de enero de 1996 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica CEDECOM, las adecuaciones introducidas al plan y programas de estudio de la carrera Secretariado Ejecutivo con menci&#xF3;n en Computaci&#xF3;n, las que se insertaron en el Decreto Exento del Ministerio de Educaci&#xF3;n N&#xB0; 402 de 1990. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1996.</div><br></div>", "i": 5939085}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 25 de enero de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5939086}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 2, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA CEDECOM", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-01-09", "doble_articulado": false, "id_norma": "19512", "numero_fuente": "35386", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-02-07", "vigencias": [{"desde": "1996-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-02-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes