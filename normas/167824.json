{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6272644}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 924, de 16 de Noviembre de 1987, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Jorge Quidiante Viveros para efectuar el servicio de taxi colectivo de la L&#xED;nea No. 1 &quot;Hospital Mait&#xE9;n&quot; de La Uni&#xF3;n, cuyo trazado fue autorizado por resoluci&#xF3;n No. 124, de 28 de Junio de 1984, y modificado por resoluci&#xF3;n No. 374, de 04 de Septiembre de 1985, de esta Secretar&#xED;a Regional.</div><br></div>", "i": 6272645}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n. </div></div>", "i": 6272646}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "924 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-924 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-16", "doble_articulado": false, "id_norma": "167824", "numero_fuente": "32946", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-16", "vigencias": [{"desde": "1987-12-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-16", "fin_vigencia": "", "