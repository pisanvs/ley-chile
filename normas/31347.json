{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA RESOLUCION N&#xB0; 157, DE 1990</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 122.- Santiago, 20 de Diciembre de 1991.- Visto: La resoluci&#xF3;n N&#xB0; 157, de 1990, del Ministerio de Transportes y Telecomunicaciones y lo dispuesto por los art&#xED;culo 56, 88, 89 y 98 de la Ley N&#xB0; 18.290, Resuelvo:</div><br></div>", "i": 7193112}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Sustit&#xFA;yese en la letra b) del numeral 2&#xB0; de la resoluci&#xF3;n N&#xB0; 157/90, en la columna &quot;fecha de retiro&quot; fijada para el modelo 1965 o anteriores, la frase &quot;desde el 1&#xB0; de enero de 1992&quot; por &quot;desde el 1&#xB0; de abril de 1992&quot;.</div><br></div>", "i": 7193113}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- V&#xED;ctor Germ&#xE1;n Correa D&#xED;az, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Saluda a Ud.- Sergio Gonz&#xE1;lez Tagle, Subsecretario de Transportes.</div><br></div>", "i": 7193114}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "122", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-122"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "MODIFICA RESOLUCION N° 157, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VEHICULOS MOTORIZADOS", "RETIRO", "PLAZO", "AMPLIACION", "LOCOMOCION COLECTIVA", "BUSES", "TAXIBUSES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-12-20", "doble_articulado": false, "id_norma": "31347", "numero_fuente": "34159", "tipo_version": "3", "tipo_version_s": "Única", "fec