{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8306647}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.240, de 15 de septiembre de</div><div class=\"p\">1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de</div><div class=\"p\">Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la</div><div class=\"p\">solicitud presentada por PESQUERA SUR LIMITADA, para</div><div class=\"p\">ampliar actividades pesqueras extractivas con la nave &quot;</div><div class=\"p\">Pesur II&quot;, por no haberse acreditado la obtenci&#xF3;n de su</div><div class=\"p\">matr&#xED;cula, contraviniendo lo dispuesto en el art&#xED;culo</div><div class=\"p\">14&#xBA; inciso 2&#xBA;, de la Ley N&#xBA; 18.892 y sus modificaciones,</div><div class=\"p\">verific&#xE1;ndose la causal denegatoria prevista en el</div><div class=\"p\">art&#xED;culo 19 letra e) del mismo cuerpo legal. </div></div>", "i": 8306648}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de septiembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8306649}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1240", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1240"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "AUTORIZACION", "PESCA", "PESQUERA SUR LIMITADA", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-09-15", "doble_articulado": false, "id_norma": "75852", "numero_fuente": "35876", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997