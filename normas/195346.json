{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6372061}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 424, de 20 de febrero de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; CORPESCA S.A., para ampliar las actividades pesqueras extractivas con la nave Am&#xE9;rica 2, en el &#xE1;rea mar&#xED;tima de la I y II Regiones, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar con cerco los siguientes recursos: Agujilla, Anchoa blanca Engraulis nasus, Bacaladillo, Bonito, Dorado, Jurel fino Decapterus sp., Machuelo, Palometa, Sardina redonda Etrumeus teres y Vinciguerria. </div></div>", "i": 6372062}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de febrero de 2002.- Jessica Fuentes Olmos, Subsecretario de Pesca (S).</div><br></div>", "i": 6372063}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "424", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-424"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-02-20", "fecha_derogacion": "2011-01-20", "doble_articulado": false, "id_norma": "195346", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-03-11", "vigencias": [{"desde": "2011-01-20", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2002-03-11", "hasta": "2011-01-19", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2011-01-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-03-11", "fin_vigen