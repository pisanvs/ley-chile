{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 10 EXENTA,DE 1998 </div></div>", "i": 8326945}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta N&#xBA; 10 de fecha 21 de Enero de 1998, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se ha rechazado el Recurso de Reclamaci&#xF3;n interpuesto por Pesquera Nacional S.A., Rut:</div><div class=\"p\">88.627.400-9 y confirmada la Resoluci&#xF3;n N&#xBA; 1.029, de 1997, de la Subsecretar&#xED;a de Pesca, que declar&#xF3; la caducidad parcial de la Resoluci&#xF3;n N&#xBA; 1.718, de 1989 de esa Subsecretar&#xED;a, que autoriz&#xF3; a dicha empresa para desarrollar actividades pesqueras con la nave &quot;Macarena IV&quot;.-</div><br></div>", "i": 8326946}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis S&#xE1;nchez Castell&#xF3;n, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n (S).</div><br></div>", "i": 8326947}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-10 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 10 EXENTA DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECURSO DE RECLAMACION", "PESQUERA NACIONAL S.A.", "PESCA", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-01-21", "doble_articulado": false, "id_norma": "96012", "numero_fuente": "35987", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-02-10", "vigencias": [{"desde": "1998-02-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"