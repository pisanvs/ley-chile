{"html": [{"t": "<div><div class=\"p\">SUSPENDE CALIDAD DE AGENTE RETENEDOR</div></div>", "i": 10002891}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n Ex. del Servicio de Impuestos Internos, N&#xBA; 28 de 19 de febrero de 2019 suspende calidad de agente retenedor a Aguas Andinas S.A., RUT N&#xBA; 61.808.000-5, conforme a <a href=\"https://www.leychile.cl/Navegar?idNorma=1118264&amp;idParte=9911323&amp;idVersion=\">resoluci&#xF3;n Ex. SII N&#xBA; 42 de 30 de abril de 2018</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1127442&amp;idParte=9985779&amp;idVersion=\">resoluci&#xF3;n Ex. SII N&#xBA; 150 de 28 de diciembre de 2018</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de febrero de 2019.</div></div>", "i": 10002892}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "28 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-28 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "SUSPENDE CALIDAD DE AGENTE RETENEDOR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1550338", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-02-19", "doble_articulado": false, "id_norma": "1129215", "numero_fuente": "42287", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-02-22", "vigencias": [{"desde": "2019-02-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"