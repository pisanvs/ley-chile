{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 306.- Santiago, 20 de Mayo de 1931.-Vistas las facultades que me confiere la ley N.o 4,945 de 6 de Febrero de 1931 y lo informado por la Contralor&#xED;a General de la Rep&#xFA;blica en el oficio que se acompa&#xF1;a, Decreto:</div><br></div>", "i": 8255419}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Efect&#xFA;ense los siguientes traspasos entre los &#xED;tem que se indican del Presupuesto Extraordinario del presente a&#xF1;o, para la Aviaci&#xF3;n Nacional:</div><div class=\"p\">&nbsp; &nbsp; Partida IV-E-0401-a- a Partida XVI-E 1602-C, $ 900,000.00.</div><div class=\"p\">&nbsp; &nbsp; Partida IV-E-0401-b- a Partida XVI-E 1602-C, $ 1.900,000.00.</div><div class=\"p\">&nbsp; &nbsp; Partida XVI-E-1602-A- a Partida XVI-E 1602-C, $ 800,000,00.</div><br></div>", "i": 8255420}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese en la Contralor&#xED;a General de la Rep&#xFA;blica, t&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Bolet&#xED;n Oficial.-C. IBA&#xD1;EZ C.-C. O. Froedden.- R. Jaramillo B.</div><br></div>", "i": 8255421}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "306", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-306"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1931", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-05-20", "doble_articulado": false, "id_norma": "5376", "numero_fuente": "15985", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-05-30", "vigencias": [{"desde": "1931-05-30", "hasta": "", "tipo_version":