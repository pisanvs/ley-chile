{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8331595}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 910,&nbsp; de 30 de junio de 1998, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud presentada por PESQUERA SAN FRANCISCO S.A., para ampliar el plazo para realizar actividades pesqueras extractivas con las naves &apos;&apos;Santa Adriana&apos;&apos;, &apos;&apos;Tocaril&apos;&apos;, &apos;&apos;Cristi&#xE1;n Claudio&apos;&apos;, &apos;&apos;San Andr&#xE9;s&apos;&apos;, &apos;&apos;Gabrielita&apos;&apos; y &apos;&apos;Adelita&apos;&apos;, autorizadas por las resoluciones N&#xBA; 1.514, N&#xBA; 1.515, N&#xBA; 1.516, N&#xBA; 1.517, N&#xBA; 1.518 y N&#xBA; 1.519 todas del a&#xF1;o 1996 y de esta Subsecretar&#xED;a, en virtud de no haberse acreditado una circunstancia de fuerza mayor o caso fortuito.</div><br></div>", "i": 8331596}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de junio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8331597}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "910", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-910"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA SAN FRANCISCO S.A.", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-06-30", "doble_articulado": false, "id_norma": "120896", "numero_fuente": "36108", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-07-08", "vigenc