{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 132 EXENTO, DE 2001 </div></div>", "i": 7282713}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 132 de fecha 5 de abril de 2001 del Ministerio de Educaci&#xF3;n, se aprueban las adecuaciones al plan y programas de estudios de la carrera de T&#xE9;cnico en Enfermer&#xED;a del Centro de Formaci&#xF3;n T&#xE9;cnica DE ENAC, que se encuentran anexas y forman parte del presente decreto. Modif&#xED;case, en consecuencia, el decreto exento del Ministerio de Educaci&#xF3;n N&#xBA;412 del 16 de abril de 1997, en el sentido de incorporar dichas adecuaciones.</div><div class=\"p\">&nbsp; &nbsp;  Las adecuaciones que se aprueban, podr&#xE1;n aplicarse a contar del a&#xF1;o 2001.</div><br></div>", "i": 7282714}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de abril de 2001.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7282715}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "132 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-132 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 132 EXENTO, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-05", "doble_articulado": false, "id_norma": "184895", "numero_fuente": "36955", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-07", "vigencias": [{"desde": "2001-05-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-05-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001