{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DERECHO APROVECHAMIENTO DE AGUAS </div></div>", "i": 6026103}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n</div><div class=\"p\">Exenta N&#xB0; 2.417 del 6 de Agosto de 1996, conforme</div><div class=\"p\">art&#xED;culo 5&#xB0; transitorio C&#xF3;digo Aguas, determin&#xF3; Derechos Aprovechamiento de Aguas proporcionales que corresponden a las parcelas N&#xB0;s. 2 a 6, 11, 22, 24 y 32 a 49, sitios N&#xB0;s. 1 al 43 y 45 al 72; Reservas Cooperativas N&#xB0;s. 1, 3, 4 y 7 y Bien Com&#xFA;n General N&#xB0; 1 del Proyecto de Divisi&#xF3;n de los Terrenos de la Cooperativa de Reforma Agraria &quot;Pupilla Limitada&quot;, formada por predio &quot;Hijuela Segunda o Pupilla de los Fundos San Jos&#xE9; del Carmen y Pupilla&quot;, de la comuna de Palmilla, VI Regi&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Los derechos de aguas se extraen del Canal Colchagua y del r&#xED;o Tinguiririca.</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n hecha conforme art&#xED;culo 13 Ley N&#xB0; 18.377.-</div><br></div>", "i": 6026104}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director Nacional.</div><br></div>", "i": 6026105}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2417", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2417"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHO APROVECHAMIENTO DE AGUAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHO APROVECHAMIENTO AGUAS", "PALMILLA", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-08-06", "doble_articulado": false, "i