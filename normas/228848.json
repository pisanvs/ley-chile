{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6491526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.031, de 3 de agosto de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a SALMONES PACIFIC STAR S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Camino a San Antonio s/n, Quell&#xF3;n, Chilo&#xE9;, X Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n Cocido, Fresco-Refrigerado, Congelado, Seco-Salado, Ahumado, Conserva y Embutido, los recursos hidrobiol&#xF3;gicos individualizados en la resoluci&#xF3;n extractada. Deja sin efecto la resoluci&#xF3;n N&#xBA; 1.535 de 2004, de esta Subsecretar&#xED;a.</div><br></div>", "i": 6491527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de agosto de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6491528}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2031 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2031 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-08-03", "doble_articulado": false, "id_norma": "228848", "numero_fuente": "37933", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-08-11", "vigencias": [{"desde": "2004-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-08-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-08-11", "fin_vigencia": "", "tipo_version"