{"html": [{"t": "<div><div class=\"p\">DESIGNA SUBSECRETARIO DE TELECOMUNICACIONES</div><br><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 187.- Santiago, 24 de Mayo de 1995.- Vistos: Lo dispuesto por el Art&#xED;culo 32&#xB0;, N&#xB0; 9, de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp; D e c r e t o:</div><br><br></div>", "i": 5899279}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico: Des&#xED;gnase, a contar del 01 de junio de 1995, a don Gregorio San Mart&#xED;n Ricci, Rut.:</div><div class=\"p\">7.259.977-2, en el cargo de Subsecretario de Telecomunicaciones, quien por razones impostergables de buen servicio deber&#xE1; asumir de inmediato sus funciones. </div></div>", "i": 5899280}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- EDUARDO FREI RUIZ-TAGLE, Presidente de la Rep&#xFA;blica.- Narciso Irureta Aburto, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Saluda atentamente a Ud., Gregorio San Mart&#xED;n Ricci, Subsecretario de Telecomunicaciones.</div><br></div>", "i": 5899281}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "187", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-187"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TELECOMUNICACIONES"], "titulo_norma": "DESIGNA SUBSECRETARIO DE TELECOMUNICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["GREGORIO SAN MARTIN RICCI", "MINISTERIO TRANSPORTES TELECOMUNICACIONES", "SUBSECRETARIA", "NOMBRAMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-24", "doble_arti