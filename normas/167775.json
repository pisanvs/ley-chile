{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 95 EXENTO, DE 2000</div><br><br></div>", "i": 7268967}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 95, de fecha 22 de marzo de 2000, del Ministerio de Educaci&#xF3;n, se aprobaron las adecuaciones a los planes y programas de estudios de las carreras de Administraci&#xF3;n de Empresas y de Secretariado Ejecutivo Computacional del Centro de Formaci&#xF3;n T&#xE9;cnica Centro Interamericano de Educaci&#xF3;n y Cultura Cidec, modific&#xE1;ndose, en consecuencia, el decreto exento N&#xBA; 91 del 4 de marzo de 1994 y el decreto exento N&#xBA; 240 del 25 de mayo de 1993, respectivamente, en el sentido de incorporar dichas adecuaciones.</div><br></div>", "i": 7268968}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de abril de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7268969}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "95 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-95 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 95 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-03-22", "doble_articulado": false, "id_norma": "167775", "numero_fuente": "36654", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-04", "vigencias": [{"desde": "2000-05-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-04", "fin_vigencia": "", "tipo_vers