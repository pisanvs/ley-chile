{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6244176}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 496, de Julio 9 de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana, se autoriza a don Jos&#xE9; Antonio Estruga Soler para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6244177}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 10 de 1985.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6244178}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "496 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-496 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-07-09", "doble_articulado": false, "id_norma": "159135", "numero_fuente": "32227", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-07-20", "vigencias": [{"desde": "1985-07-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-07-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-07-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": []