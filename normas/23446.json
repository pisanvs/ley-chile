{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Permite la residencia de los cuerpos del Ej&#xE9;rcito en el lugar de las sesiones del Congreso Nacional Lei n&#xFA;m. 2,718.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5953958}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Perm&#xED;tese, por el t&#xE9;rmino de un a&#xF1;o, la residencia de los cuerpos del Ej&#xE9;rcito permanente en el lugar de las sesiones del Congreso Nacional i diez leguas a su circunferencia.</div><br></div>", "i": 5953959}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 13 de Diciembre de 1912.- RAMON BARROS LUCO.- Claudio Vicu&#xF1;a S.</div><br></div>", "i": 5953960}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2718", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2718"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PERMITE LA RESIDENCIA DE LOS CUERPOS DEL EJERCITO EN EL LUGAR DE LAS SESIONES DEL CONGRESO NACIONAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EJERCITO CHILE", "RESIDENCIA", "CONGRESO NACIONAL", "LUGAR", "SESIONES", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-12-13", "doble_articulado": false, "id_norma": "23446", "numero_fuente": "10453", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-12-14", "vigencias": [{"desde": "1912-12-14", "hasta": "", "ti