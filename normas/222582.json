{"html": [{"t": "<div><div class=\"p\">REAJUSTE DE CUANTIAS</div><br><br></div>", "i": 7309938}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Para los fines previstos en el art&#xED;culo 6&#xBA; del decreto ley N&#xBA;1.417 de 1916, modificado por el decreto ley N&#xBA; 2.416 de 1978, en relaci&#xF3;n con lo establecido en el art&#xED;culo 198 del C&#xF3;digo Org&#xE1;nico de Tribunales y en raz&#xF3;n de que, en el per&#xED;odo considerado, no se produjo variaci&#xF3;n del Indice de Precios al Consumidor que permita modificar los montos actualmente vigentes para los efectos de recusaci&#xF3;n de los Abogados Integrantes de Cortes de Apelaciones y Corte Suprema, se mantienen las cuant&#xED;as determinadas en el Acuerdo del Pleno de 7 de marzo de 2003.</div><br><br></div>", "i": 7309939, "v": ["CONCORDANCIA"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Publ&#xED;quese en el Diario Oficial.</div><br></div>", "i": 7309940}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "S/N", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-S/N"}], "organismos": ["CORTE SUPREMA"], "titulo_norma": "REAJUSTE DE CUANTIAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CODIGO ORGANICO DE TRIBUNALES", "CUANTIAS", "REAJUSTE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "222582", "numero_fuente": "37814", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-18", "vigencias": [{"desde": "2004-03-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-03-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-03-18", "fin_vigencia": "", "tipo_ver