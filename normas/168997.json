{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA N&#xB0; 1.968, DE 1987 </div></div>", "i": 6276283}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.908 de fecha 26 de Agosto de</div><div class=\"p\">1987, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se ampli&#xF3; el</div><div class=\"p\">art&#xED;culo &#xFA;nico de la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xB0; 2.351 de 1985, correspondiente al Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Andr&#xE9;s Bello de Temuco, en el sentido de incluir en la denominaci&#xF3;n del t&#xED;tulo lo siguiente:</div><br><div class=\"p\">Dice:</div><div class=\"p\">Carrera: Electr&#xF3;nica Titulo: T&#xE9;cnico en Electr&#xF3;nica Debe decir:</div><div class=\"p\">Carrera: Electr&#xF3;nica Titulo: T&#xE9;cnico en Electr&#xF3;nica con menci&#xF3;n Electr&#xF3;nica Industrial.</div><br></div>", "i": 6276284}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6276285}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1908 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1908 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N° 1.908, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-26", "doble_articulado": false, "id_norma": "168997", "numero_fuente": "32909", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-02", "vigencias": [{"desde": "1987-11-02", "hasta": "", "tipo_version": "3", "tipo_vers