{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6568915}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 983, de 3 de abril de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD COMERCIAL IMPORTADORA Y EXPORTADORA ROXANA LIMITADA para ampliar las actividades pesqueras de transformaci&#xF3;n autorizadas por las resoluciones citadas en Visto, en orden a incorporar a la planta ubicada en Cardonal Bajo Km. 2,7, Puerto Montt, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco-enfriado, Fresco refrigerado, Congelado, Seco salado, Ahumado, Conserva y Deshidra-tado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6568916}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 3 de abril de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6568917}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "983 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-983 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-04-03", "doble_articulado": false, "id_norma": "249340", "numero_fuente": "38454", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-05-04", "vigencias": [{"desde": "2006-05-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-05-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-05-04", "fin_vige