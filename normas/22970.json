{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,869 que eleva a puertos mayores terrestres los menores de Ollag&#xFC;e i La Portada Lei n&#xFA;m. 1,869.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5952290}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- El&#xE9;vanse a puertos mayores terretres los puertos menores de Ollag&#xFC;e i La Portada, ubicados en las provincias de Antofagasta i Tacna, respectivamente.</div><br></div>", "i": 5952291}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 23 de julio de 1906.- JERMAN RIESCO.- Joaquin Prieto.</div><br></div>", "i": 5952292}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1869", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1869"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LEI NUM. 1,869 QUE ELEVA A PUERTOS MAYORES TERRESTRES LOS MENORES DE OLLAGÜE I LA PORTADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PUERTOS MAYORES TERRESTRES", "PUERTOS MENORES", "OLLAGUE", "LA PORTADA", "CATEGORIA", "CAMBIO", "ANTOFAGASTA", "TACNA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-07-23", "doble_articulado": false, "id_norma": "22970", "numero_fuente": "8819", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-06-08", "vigencias": [{"desde": "1907-06-08", "hasta": "", "tipo_version": "3", "tipo_version