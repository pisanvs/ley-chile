{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA DE ASOCIACION GREMIAL </div></div>", "i": 6262873}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 95, de 25 de Septiembre de 1985, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la personalidad jur&#xED;dica de la &quot;Asociaci&#xF3;n Gremial de Productores de Seguros de Chile&quot;, inscrita bajo el N&#xB0; 2 del Registro de Asociaciones Gremiales, por haberse configurado respecto de ella la causal establecida en el art&#xED;culo 18&#xB0; N&#xB0; 2, letra d), del DL 2.757. Los bienes quedados una vez liquidada la asociaci&#xF3;n gremial sancionada deber&#xE1;n entregarse al Cuerpo de Bomberos de Santiago.-</div><br></div>", "i": 6262874}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jorge Valenzuela Dur&#xE1;n, Coronel de Ej&#xE9;rcito, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 6262875}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "95", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-95"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-09-25", "doble_articulado": false, "id_norma": "164861", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-10-17", "vigencias": [{"desde": "1985-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-10-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-10-1