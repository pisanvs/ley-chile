{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 3.521 EXENTA, DE 2011</div></div>", "i": 9270370}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.705, de 22 de junio de 2012, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1035607&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.521, de 2011</a>, modificada mediante resoluci&#xF3;n exenta N&#xBA; 893, de 2012, ambas de esta Subsecretar&#xED;a de Pesca, que estableci&#xF3; la distribuci&#xF3;n de la fracci&#xF3;n artesanal de las pesquer&#xED;as de Merluza com&#xFA;n de la IV, V, VI, VII y VIII Regiones, en el sentido de se&#xF1;alar que la distribuci&#xF3;n enero-diciembre de 2012, en las &#xC1;reas Centro y Sur de la VII Regi&#xF3;n y &#xC1;rea Norte de la VIII Regi&#xF3;n, expresada en toneladas, se efectuar&#xE1; de la siguiente manera:</div><br><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/26830.jpg\"></div><br></div>", "i": 9270371, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de junio de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9270372}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1705 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1705 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 3.521 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-22", "doble_articulado": false, "id