{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 21, DE 1989 </div><br></div>", "i": 6091329}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 21 de fecha 28.02.89, la Secretar&#xED;a Ministerial de Educaci&#xF3;n de la Regi&#xF3;n de Antofagasta ha aprobado Planes y Programas de Estudio de 1&#xB0; a 4&#xB0; a&#xF1;o de la Educaci&#xF3;n Media T&#xE9;cnico Profesional, para el Liceo Polit&#xE9;cnico C - 20 de Taltal.</div><div class=\"p\">En las Especialidades de:- Mec&#xE1;nica de Mantenci&#xF3;n - Mec&#xE1;nica de M&#xE1;quinas Herramientas Los Planes y Programas aprobados tendr&#xE1;n vigencia a contar del a&#xF1;o escolar 1989 y hasta el a&#xF1;o 1996.-</div><br></div>", "i": 6091330}, {"t": "<div><div class=\"p\">Luis Humberto Alvear L&#xF3;pez, Secretario Ministerial de Educaci&#xF3;n Regi&#xF3;n de Antofagasta.</div><br></div>", "i": 6091331}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "21 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-21 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 21, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-02-28", "doble_articulado": false, "id_norma": "92361", "numero_fuente": "33357", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-04-26", "vigencias": [{"desde": "1989-04-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-04-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-04-26", "fin_vigencia": "", "tipo_version": "3"}], "even