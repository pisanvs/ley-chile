{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DEROGA LA LEY 6.694, DE 11 DE OCTUBRE DE 1940, QUE DECLARO DE UTILIDAD PUBLICA Y AUTORIZO LA EXPROPIACION DE TERRENOS EN LA ISLA DE HUAPE O HUAPI, UBICADA EN EL LAGO RANCO.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5974346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Der&#xF3;gase la ley 6.694, de 11 octubre de 1940.&quot; </div></div>", "i": 5974347}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veiticuatro de agosto de mil novecientos sesenta y uno.- JORGE ALESSANDRI RODRIGUEZ.- Enrique Bahamonde.</div><br></div>", "i": 5974348}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14612", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14612"}], "organismos": ["MINISTERIO DE TIERRAS Y COLONIZACIÓN"], "titulo_norma": "DEROGA LA LEY 6.694, DE 11 DE OCTUBRE DE 1940, QUE\nDECLARO DE UTILIDAD PUBLICA Y AUTORIZO LA EXPROPIACION\nDE TERRENOS EN LA ISLA DE HUAPE O HUAPI, UBICADA EN EL\nLAGO RANCO.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DEROGACION", "LEY 6694", "EXPROPIACION", "ISLA HUAPE", "ISLA HUAPI", "LAGO RANCO", "VALDIVIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1961-08-24", "doble_articulado": false, "id_norma": "27805", "numero_fuente": "25034", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1961-08-31", "vigencias": [{"desde": "1961