{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7351057}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA; 359, de fecha 29 de junio del 2007, se expropiaron los lotes de terreno N&#xBA;s. 5 y 5-A, superficies 446 y 110 m&#xB2;, Rol N&#xBA; 293-3, comuna de Frutillar, X Regi&#xF3;n para la obra &quot;Reposici&#xF3;n Construcci&#xF3;n y Habilitaci&#xF3;n de Caminos para Vialidad Complementaria Concesi&#xF3;n Internacional Ruta 5 Sur, tramo Temuco-R&#xED;o Bueno-Puerto Montt, camino La Vega (Sector La Huacha Norte), Comuna de Frutillar, Provincia de Llanquihue, X Regi&#xF3;n&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Mois&#xE9;s Aguila Gonz&#xE1;lez, ascendente a la cantidad de $553.356, para los lotes N&#xBA;s. 5 y 5-A.</div><br></div>", "i": 7351058}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 7351059}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "359 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-359 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-29", "doble_articulado": false, "id_norma": "263872", "numero_fuente": "38839", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-08-16", "vigencias": [{"desde": "2007-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-08-16", "fin_vigencia": "", "tipo_versi