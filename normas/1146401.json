{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10127831}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 436, de 13 de abril de 2020, de la Gobernaci&#xF3;n Provincial de Isla de Pascua, se ha establecido Modalidad Excepcional para el Ingreso de Solicitudes de Particulares de Forma Telem&#xE1;tica, Ampl&#xED;a, de Oficio, los Plazos que Indica, y Se&#xF1;ala Otras Medidas con Ocasi&#xF3;n de Brote de Covid-19.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de dicho acto administrativo se encuentra publicado en la p&#xE1;gina web de la Gobernaci&#xF3;n Provincial de Isla de Pascua (http://www.gobernacionisladepascua.gov.cl/).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10127832}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Isla de Pascua, 28 de mayo de 2020.- Laura Tarita Rapu Alarc&#xF3;n, Gobernadora Provincial de Isla de Pascua.</div><div class=\"p\"> </div><br></div>", "i": 10127833}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "436 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-436 EXENTA"}], "organismos": ["MINISTERIO DEL INTERIOR Y SEGURIDAD PÚBLICA", "GOBERNACIÓN DE ISLA DE PASCUA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": ["CORONAVIRUS", "CORONAVIRUS COVID-19", "COVID-19"], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1770745; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-04-13", "doble_articulado": false, "id_norma": "1146401", "numero_fuente": "42677", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-06-10", "vigencias": [{"desde": "2020-06-10", "hasta": "", "tipo_version": "3", "tipo_version_s":