{"html": [{"t": "<div><div class=\"p\">CADUCA RESOLUCION QUE INDICA </div></div>", "i": 8314498}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 797, de 27 de Junio de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad conforme al art&#xED;culo 7&#xB0;, del decreto No. 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, de la resoluci&#xF3;n No. 458, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la Sociedad de Algas San Juan S.A., domiciliada en la ciudad de Valdivia, para desarrollar actividades pesqueras de cultivo. </div></div>", "i": 8314499}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 27 de Junio de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8314500}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "797", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-797"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "CADUCA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-06-27", "doble_articulado": false, "id_norma": "82958", "numero_fuente": "33711", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-07-05", "vigencias": [{"desde": "1990-07-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-07-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-07-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICAC