{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10301002}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xB0; 1.684, de 27 diciembre de 2021, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos relativas a Actividad denominada &quot;Acto Entrega de Maquinaria&quot;, en la ciudad de Coyhaique, y autoriz&#xF3; a I. Municipalidad de Coyhaique para realizar siguientes intervenciones en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  &#x2013;Corte total de v&#xED;a en calle Francisco Bilbao, entre calles Lord Cochrane y Arturo Prat, el d&#xED;a jueves 30 de diciembre entre las 11:00 y las 13:00 hrs.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10301003}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andrea Mac&#xED;as Palma, Gobernadora Regional, Gobierno Regional de Ays&#xE9;n.- Ximena Guti&#xE9;rrez Jaramillo, Asesor Jur&#xED;dico, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10301004}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1684 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1684 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2070545", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-12-27", "doble_articulado": false, "id_norma": "1171279", "numero_fuente": "43151", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-01-13", "vigencias": [{"desde": "2022-01-13", "hasta": "", "tipo_version": "3", "ti