{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA N&#xBA;1.742 DE 1991 </div></div>", "i": 6057227}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n Exenta N&#xBA;1742 de fecha 07 de Junio de 1991 del Ministerio de Educaci&#xF3;n, se declar&#xF3; que no se concede el reconocimiento oficial al Centro de Formaci&#xF3;n T&#xE9;cnica Salvatierra, organizado por la Sociedad Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Superior Salvatierra de Quillota Ltda., ubicado en calle Freire N&#xBA;1171 de Quillota.</div><div class=\"p\">Por este mismo cuerpo legal, se elimin&#xF3; del Libro de Registros de Centros de Formaci&#xF3;n T&#xE9;cnica el N&#xBA;213 de fecha 02 de Noviembre de 1990 correspondiente a la mencionada instituci&#xF3;n.</div><br></div>", "i": 6057228}, {"t": "<div><div class=\"p\">Santiago, 8 de Noviembre de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6057229}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1742 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1742 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA Nº1.742 DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-06-07", "doble_articulado": false, "id_norma": "80390", "numero_fuente": "34120", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-19", "vigencias": [{"desde": "1991-11-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-11-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vige