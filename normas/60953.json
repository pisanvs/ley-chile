{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8301297}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 224 de 31 de enero de 1997, de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de</div><div class=\"p\">acuicultura N&#xBA; 93103135, presentada por GONZALO ALEJANDRO</div><div class=\"p\">CAMACHO SANTIBA&#xD1;EZ, para un sector ubicado al Weste del Morro</div><div class=\"p\">Quinterguen, Isla Caucahue, Estero Castro, Comuna de Castro,</div><div class=\"p\">Provincia de Chilo&#xE9;, X Regi&#xF3;n, conforme lo dispuesto en el</div><div class=\"p\">Art&#xED;culo 14 del D.S. N&#xBA; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8301298}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de enero de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8301299}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "224", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-224"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["GONZALO ALEJANDRO CAMACHO SANTIBA EZ", "CONCESION DE ACUICULTURA", "DENEGACION", "CASTRO", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-01-31", "doble_articulado": false, "id_norma": "60953", "numero_fuente": "35691", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-02-13", "vigencias": [{"desde": "1997-02-13