{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; FIJA PORCENTAJE DE VARIACION QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 33.- Valpara&#xED;so, 23 de Octubre de 1991.- Visto: El art&#xED;culo 3&#xB0; de la Ley N&#xB0; 18.696, el art&#xED;culo 10&#xB0; de la Ley N&#xB0; 19.040 y las facultades que me confiere el D.S. N&#xB0; 72 de 1991, del Ministerio de Transportes y Telecomunicaciones</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 7193073}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Determ&#xED;nase, para los efectos del D.S. N&#xB0; 72/91, del Ministerio de Transportes y Telecomunicaciones, en todas las ciudades de la Quinta Regi&#xF3;n, que las variantes de los trazados troncales deben coincidir con &#xE9;stos en un porcentaje de un 60%.</div><br></div>", "i": 7193074}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese y publ&#xED;quese.- Adolfo Tannenbaum Ram&#xED;rez, Secretario Regional Ministerial de Transportes y Telecomunicaciones V Regi&#xF3;n.</div><br></div>", "i": 7193075}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "33", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-33"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "FIJA PORCENTAJE DE VARIACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LOCOMOCION COLECTIVA", "V REGION", "VEHICULOS MOTORIZADOS", "TRAZADOS TRONCALES", "VARIANTES", "PORCENTAJE VARIACION", "FIJACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-10-23", "doble_articulado": false, "id_norma": "31268", "numero_fuente": "34112", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-09", "vigencias": [{"desd