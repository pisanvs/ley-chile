{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 7264557}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 3 de Enero 07 de 1991, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriza a la Empresa Chilena Juan Gonzalo Alcoholado Castillo, para efectuar una (1) frecuencia semanal adicional a las otorgadas por resoluci&#xF3;n No. 167 de 21 de Febrero de 1986, en la realizaci&#xF3;n del Servicio Temuco (Chile) y San Mart&#xED;n de Los Andes (Argentina), durante el per&#xED;odo comprendido entre el 15 de noviembre y 15 de marzo de cada a&#xF1;o. </div></div>", "i": 7264558}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Sergio Gonz&#xE1;lez Tagle, Subsecretario de Transportes.</div><br></div>", "i": 7264559}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-07", "doble_articulado": false, "id_norma": "160202", "numero_fuente": "33877", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-01-25", "vigencias": [{"desde": "1991-01-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-01-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-01-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part":