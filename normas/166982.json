{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6269761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n que suscribe, certifica que el Instituto Profesional del B&#xED;o-B&#xED;o, autorizado a funcionar por Decreto Exento de Educaci&#xF3;n No. 65 de 1990, podr&#xE1; impartir a contar del a&#xF1;o 1991 la carrera de &quot;Dise&#xF1;o Gr&#xE1;fico Publicitario&quot;.</div><div class=\"p\">&nbsp; &nbsp;  Dicha instituci&#xF3;n se encuentra liberada de la obligaci&#xF3;n de someter sus planes y programas de estudios de la mencionada carrera a una entidad examinadora y de rendir ex&#xE1;menes finales ante comisiones mixtas paritarias en virtud de lo dispuesto en el art&#xED;culo 14&#xB0; y 15&#xB0; del DFL No. 5/81 y DS 1.118 de 1986.</div><br><br></div>", "i": 6269762}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de Enero de 1991.</div><div class=\"p\">&nbsp; &nbsp;  RAUL ALLARD NEUMANN Subsecretario de Educaci&#xF3;n </div></div>", "i": 6269763}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "DIVISIÓN DE EDUCACION SUPERIOR"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-31", "doble_articulado": false, "id_norma": "166982", "numero_fuente": "33910", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-03-05", "vigencias": [{"desde": "1991-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-03-05", "fin_vigencia": ""}, "vigencias_vers