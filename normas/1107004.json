{"html": [{"t": "<div><br><div class=\"p\">CRITERIOS DE SEGMENTACI&#xD3;N DE CONTRIBUYENTES</div></div>", "i": 9828069}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta SII N&#xBA; 76, de 23 de agosto de 2017, para clasificar a los contribuyentes, este Servicio atiende a su naturaleza jur&#xED;dica (persona natural o jur&#xED;dica), vigencia, categor&#xED;a tributaria, patrimonio, capital, montos de compras, ingresos, resultado anual y actividades econ&#xF3;micas; en base a estos criterios los segmentos en que se clasifican los contribuyentes son: Persona, Micro, Peque&#xF1;a, Mediana y Gran Empresa.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII de agosto de 2017.</div></div>", "i": 9828070}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "76 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-76 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CRITERIOS DE SEGMENTACIÓN DE CONTRIBUYENTES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1264141", "EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-08-23", "doble_articulado": false, "id_norma": "1107004", "numero_fuente": "41847", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-08-30", "vigencias": [{"desde": "2017-08-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-08-30", "fin_vig