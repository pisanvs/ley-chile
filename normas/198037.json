{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6381214}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;389, de 25 de febrero del 2002, se expropi&#xF3; el lote de terreno N&#xBA;123-15, superficie 943, rol de aval&#xFA;o 233-109, comuna de Rengo, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo Santiago-Talca Sector F: Kms.</div><div class=\"p\">92.000,00 al 110.200,00. Sexta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Misael del Carmen Gonz&#xE1;lez Tarife&#xF1;o y otros, ascendente a la cantidad de $13.983.337.- para el lote N&#xBA;123-15.</div><br></div>", "i": 6381215}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6381216}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "389", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-389"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-25", "doble_articulado": false, "id_norma": "198037", "numero_fuente": "37259", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-15", "vigencias": [{"desde": "2002-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MAS", "fecha_ingreso": "2002-05-15", "fecha_version": "2002-05-15", "fecha_actualizacion_texto": "2002-05-