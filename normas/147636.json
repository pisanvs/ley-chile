{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6205036}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 355, de 22 de Abril de 1987, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Ricardo Jalabert Rodr&#xED;guez, Carlos Arias Rodr&#xED;guez y Jos&#xE9; Catal&#xE1;n Arancibia para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 20 &quot;Las Animas - Centro&quot; de Valdivia, cuyo trazado fue autorizado por resoluci&#xF3;n exenta No. 35, de 16 de enero de 1986, de esta Secretar&#xED;a Regional.</div><br></div>", "i": 6205037}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Enrique Brintrup Barrera, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n subrogante.</div><br></div>", "i": 6205038}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "355 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-355 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-04-22", "doble_articulado": false, "id_norma": "147636", "numero_fuente": "32768", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-05-12", "vigencias": [{"desde": "1987-05-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-05-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-05-1