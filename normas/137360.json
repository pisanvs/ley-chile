{"html": [{"t": "<div><div class=\"p\">MODIFICA LA LEY N&#xBA; 15.378</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6171755}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Reempl&#xE1;zanse en el art&#xED;culo 3&#xBA; de la ley N&#xBA; 15.378, de 18 de Diciembre de 1963, las palabras &quot;por el DFL. N&#xBA; 81, de 1960, de la escala de grados y sueldos del Cuerpo de Carabineros de Chile&quot; por estas otras: &quot;en el art&#xED;culo 1&#xBA;, letra a), de la ley N&#xBA; 11.852, de 29 de Agosto de 1955.&quot;.&quot; </div></div>", "i": 6171756}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a dos de Septiembre de mil novecientos sesenta y ocho.- EDUARDO FREI MONTALVA.- Andr&#xE9;s Zald&#xED;var L.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a U. para su conocimiento.- Dios guarde a U. Jos&#xE9; F. Guzm&#xE1;n C., Subsecretario de Hacienda.</div><br></div>", "i": 6171757}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "16931", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-16931"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA LA LEY Nº 15.378", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1968-09-02", "doble_articulado": false, "id_norma": "137360", "numero_fuente": "27141", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1968-09-10", "vigencias": [{"desde": "1968-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1968-09-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1968-09-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "1999-06-07", "fecha_version": "1968-09-10", "fecha_actualizacion_texto": "1968-09-10", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6171755}, {"n": "Artículo UNICO", "i": 6171756, "t": 6}, {"n": "Promulgación", "i": 6171757}]}