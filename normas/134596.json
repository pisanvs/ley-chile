{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,310.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6162867}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese por gracia a don Agustin Eyzaguirre, para los efectos de su jubilacion los ocho a&#xF1;os, dos meses i diez dias que sirvi&#xF3; el cargo de contador de la Caja de Cr&#xE9;dito Hipotecario sin nombramiento del Presidente de la Rep&#xFA;blica.</div><br></div>", "i": 6162868}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de diciembre de 1899.- FEDERICO ERRAZURIZ.- Manuel Salinas.</div><br></div>", "i": 6162869}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1310", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1310"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-12-27", "doble_articulado": false, "id_norma": "134596", "numero_fuente": "6484", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-12-29", "vigencias": [{"desde": "1899-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-12-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-12-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingr