{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6417983}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 492, de 18 de febrero de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a NATALIO DEL CARMEN GODOY GONZALEZ para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Rengo N&#xBA; 440, Los Vilos, IV Regi&#xF3;n, en la l&#xED;nea de elaboraci&#xF3;n de congelado y fresco-enfriado, el recurso hidrobiol&#xF3;gico Langosta de agua dulce. El recurso Langosta de agua dulce deber&#xE1; provenir de centros de cultivo debidamente autorizados.</div><br></div>", "i": 6417984}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de febrero de 2003.- Jessica Fuentes Olmos, Subsecretario de Pesca (S).</div><br></div>", "i": 6417985}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "492", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-492"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-02-18", "doble_articulado": false, "id_norma": "208630", "numero_fuente": "37514", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-03-20", "vigencias": [{"desde": "2003-03-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-03-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-03-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingres