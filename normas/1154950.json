{"html": [{"t": "<div><div class=\"p\">Donativos</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago i 14 de Abril de 1814.</div></div>", "i": 10209219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Deseando el Gobierno dar a los buenos Ciudadanos la prueba de su gratitud por la obligacion que han hecho de camisas i ropas para nuestros dignos defensores, public&#xE1;ndose en El Monitor se previene que a este efecto se oficie al Se&#xF1;or Juez Mayor de Alta Polic&#xED;a pase a la Secretar&#xED;a una razon de los sujetos que han donado ropas para la tropa, con toda especificacion i que se ejecute lo mismo por el comisionado D. Jos&#xE9; Jim&#xE9;nez de Guzman, i not&#xED;ciese a los Ministros de la Tesorer&#xED;a Jeneral e imprimase.-</div></div>", "i": 10209220}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lastra.-Villarreal, secretario.</div></div>", "i": 10209221}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Donativos", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1814-04-14", "doble_articulado": false, "id_norma": "1154950", "numero_fuente": "1814", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1814-04-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1814-04-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1814-04-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-03-15", "fecha_version":