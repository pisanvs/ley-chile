{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 590.- Santiago, 7 de setiembre de 1925.-</div><div class=\"p\">&nbsp; &nbsp; El Vice-Presidente de la Rep&#xFA;blica, de acuerdo con el Consejo de Ministros del Despacho, dicta el siguiente DECRETO-LEI:</div><br></div>", "i": 8256459}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- La Junta Electoral de Santiago, que, en conformidad a lo dispuesto en el art&#xED;culo 26 del decreto-lei n&#xFA;mero 542, de 19 de setiembre &#xFA;ltimo, debe reunirse en la Oficina del Conservador de Bienes Raices, podr&#xE1; instalarse en cualquiera sala del edificio del Congreso Nacional.</div><div class=\"p\">&nbsp; &nbsp; El presente decreto-lei empezar&#xE1; a rejir desde la fecha de su publicacion en el Diario Oficial. </div></div>", "i": 8256460, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese razon, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Boletin de las Leyes y Decretos del Gobierno.- L. Barros Borgo&#xF1;o.- Manuel E. V&#xE9;liz.</div><br></div>", "i": 8256461}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "590", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-590"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUNTA ELECTORAL SANTIAGO", "LUGAR REUNION", "EDIFICIO CONGRESO NACIONAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1925-09-07", "doble_articulado": false, "id_norma": "6216", "numero_fuente": "14294", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1925-10-10", "vigencias": [{"desde": "1925-10-10", "hasta": "", "tipo_version": "3", "tipo_version_