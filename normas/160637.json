{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 7264967}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 210, de 12 de marzo de 1986, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se renueva la concesi&#xF3;n otorgada a la Sociedad de Transporte Cordillera Nevada Limitada (Nevada Limitada) por Resoluciones N&#xB0;s 883/71 y 579/83, ambas del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, para efectuar servicio regular de transporte terrestre de pasajeros entre &quot;Santiago - Valpara&#xED;so - Vi&#xF1;a del Mar - Mendoza&quot;, por Paso Caracoles (T&#xFA;nel Cristo Redentor), utilizando una capacidad portante de 130 cupos (asientos/pasajeros) diarios.</div><br></div>", "i": 7264968}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago de Chile, 18.03.86.- Enrique Y&#xE1;var Martin, Coronel de Ej&#xE9;rcito, Subsecretario de Transportes. </div></div>", "i": 7264969}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "210 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-210 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-03-12", "doble_articulado": false, "id_norma": "160637", "numero_fuente": "32437", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-04-03", "vigencias": [{"desde": "1986-04-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1