{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; APRUEBA REFORMA DE ESTATUTOS DE &quot;ISE COMPA&#xD1;IA DE SEGUROS DE VIDA S.A.&quot; </div></div>", "i": 7201351}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Certifico: Que por resoluci&#xF3;n exenta N&#xB0; 273 de 29 de octubre de 1996, se aprob&#xF3; reforma de estatutos de la sociedad an&#xF3;nima &quot;ISE Compa&#xF1;&#xED;a de Seguros de Vida S.A.&quot;, que consta de la escritura p&#xFA;blica de 8 de octubre de 1996, otorgada ante el Notario de Santiago don Patricio Raby Benavente.</div><div class=\"p\">&nbsp; &nbsp; La reforma consiste en cambiar el nombre de la sociedad por el de &quot;ISE - Las Am&#xE9;ricas Compa&#xF1;&#xED;a de Seguros de Vida S.A.&quot;.</div><br></div>", "i": 7201352}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 29 de octubre de 1996.- Rodrigo O. Costa Aranda, Secretario General.</div><br></div>", "i": 7201353}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "273", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-273"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "APRUEBA REFORMA DE ESTATUTOS DE ISE COMPAÑIA DE SEGUROS DE VIDA S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REFORMA ESTATUTARIA", "ESTATUTOS", "ISE COMPA IA DE SEGUROS DE VIDA S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-10-29", "doble_articulado": false, "id_norma": "38695", "numero_fuente": "35621", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-11-21", "vigencias": [{"desde": "1996-11-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-11-21", "fin_vigenc