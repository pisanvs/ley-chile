{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 2.451 EXENTO, DE 2010</div></div>", "i": 9091954}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por el presente decreto exento se han aprobado planes y programas especiales de estudio biling&#xFC;es para 1&#xBA; a 8&#xBA; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica, al Colegio Inmaculada Concepci&#xF3;n, comuna de Talcahuano, Regi&#xF3;n del B&#xED;o-B&#xED;o, los que se aplicar&#xE1;n a partir del a&#xF1;o 2011 seg&#xFA;n gradualidad establecida en el presente decreto.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio especiales biling&#xFC;es para 1&#xBA; a 8&#xBA; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica para los Sectores que se indican en el respectivo decreto.</div></div>", "i": 9091955}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de diciembre de 2010.- Fernando Rojas Ochagav&#xED;a, Subsecretario de Educaci&#xF3;n.</div></div>", "i": 9091956}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2451 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2451 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "XTRACTO DE DECRETO Nº 2.451 EXENTO, DE 2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-28", "doble_articulado": false, "id_norma": "1021713", "numero_fuente": "39849", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-01-03", "vigencias": [{"desde": "2011-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-01-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_