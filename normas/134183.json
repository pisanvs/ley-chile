{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,113.- Santiago, 26 de octubre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6161565}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados durante la guerra de la Independencia, por el sarjento-mayor graduado don Felipe Salazar, conc&#xE9;dese, por gracia, a su hija do&#xF1;a Jenoveva Salazar, v. de Z&#xFA;&#xF1;iga, derecho a gozar de la pension correspondiente al empleo de sarjento-mayor, en vez de la que actualmente disfruta.</div><br></div>", "i": 6161566}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Ventura Blanco.</div><br></div>", "i": 6161567}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1113", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1113"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-10-26", "doble_articulado": false, "id_norma": "134183", "numero_fuente": "6140", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-11-02", "vigencias": [{"desde": "1898-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-11-02", "fin_vigencia": "", "tipo_version": "3"}], "ev