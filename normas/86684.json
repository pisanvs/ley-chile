{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION No 53, DE 1992</div><br><div class=\"p\">N&#xFA;m. 85.- Santiago, 14 de Septiembre de 1992.- Vistos: Lo dispuesto en el art&#xED;culo 56&#xBA; de la ley No.18.290 </div><div class=\"p\">Resuelvo:</div><br></div>", "i": 7221297}, {"t": "<div><div class=\"p\">Der&#xF3;gase la resoluci&#xF3;n No.53 de este Ministerio, de fecha 17 de Julio de 1992.</div><br></div>", "i": 7221298}, {"t": "<div><div class=\"p\">An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- V&#xED;ctor Germ&#xE1;n Correa D&#xED;az, Ministro de Transportes y Telecomunicaciones. Lo que transcribo para su conocimiento.- Saluda a Ud.- Patricia Mu&#xF1;oz Villela, Jefe Depto. Administrativo. </div></div>", "i": 7221299}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "85", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-85"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "DEROGA RESOLUCION No 53, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-09-14", "doble_articulado": false, "id_norma": "86684", "numero_fuente": "34388", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-10-13", "vigencias": [{"desde": "1992-10-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-10-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-10-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "IMH", "fecha_ingreso": "1998-