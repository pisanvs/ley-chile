{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8298573}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.910 de 11 de noviembre de 1996 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a MIGUEL JORGE KRSTULOVIC SINOVCIC, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Camino Fertilizante/N&#xB0; 510, Mejillones, II Regi&#xF3;n, donde podr&#xE1; procesar en la l&#xED;nea de elaboraci&#xF3;n de Secado y Molienda de Algas, el recurso hidrobiol&#xF3;gico Pelillo Gracilaria spp.</div><br><br></div>", "i": 8298574}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 11 de noviembre de 1996.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8298575}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1910", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1910"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MIGUEL JORGE KRSTULOVIC SINOVCIC", "AUTORIZACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-11-11", "fecha_derogacion": "2001-11-20", "doble_articulado": false, "id_norma": "37549", "numero_fuente": "35633", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-12-05", "vigencias": [{"desde": "2001-11-20", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1996-12-05", "hasta": "2001-11-19", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"in