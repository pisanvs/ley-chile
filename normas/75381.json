{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8306055}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.104, de 1 de agosto de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a PESQUERA NACIONAL S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Mat&#xED;as&quot;, matr&#xED;cula 2820, en orden a capturar con la nave &quot;Mat&#xED;as&quot;, con red de cerco, en el Litoral de la X Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, los siguientes recursos hidrobiol&#xF3;gicos: Anchoveta, Caballa, Jurel, Merluza de cola y Sardina com&#xFA;n.</div><div class=\"p\">&nbsp; &nbsp;  Deni&#xE9;gase la autorizaci&#xF3;n solicitada respecto de los recursos y &#xE1;reas no mencionados en la presente Resoluci&#xF3;n, en virtud de los informes y normas legales se&#xF1;aladas en Visto.</div><br></div>", "i": 8306056}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de agosto de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8306057}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1104", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1104"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA NACIONAL S.A.", "PESCA", "AUTORIZACION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-08-01", "fecha_derogacion": "2002-07-02", "doble_articulado": false, "id_norma": "75381", "numero_fuente": "35853", "tipo_version": "2", "tipo_version_s": "Última Versión",