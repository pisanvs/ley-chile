{"html": [{"t": "<div><div class=\"p\">RECTIFICA DECRETO ALCALDICIO N&#xBA;1.596, DE 1991 </div><div class=\"p\">Por Decreto Secc. 1a N&#xBA;54 de Fecha 14 de Enero de 1992, Rectif&#xED;case el Decreto Alcaldicio Secc. 1a N&#xBA;1.596 de 24 de Octubre de 1991 que modific&#xF3; la Ordenanza Local de Publicidad y Propaganda que se realice en la V&#xED;a P&#xFA;blica en la comuna de Las Condes, aprobada por Decreto Alcaldicio Secc. la N&#xBA;619 de 22 de Mayo de 1981, en el sentido que en el punto 1&#xBA;, 11 Tipolog&#xED;as Permitidas, letra a. Letreros adosados a la edificaci&#xF3;n, el p&#xE1;rrafo a.1. debe quedar de la siguiente manera:</div><br></div>", "i": 8669798}, {"t": "<div><div class=\"p\">a. 1.- No podr&#xE1;n colocarse a menos de 2.50 mts. de altura medidos desde el plano de la acera adyacente, en tanto que su altura m&#xE1;xima no ser&#xE1; superior a 60.00 mts., medidos de igual forma.</div><br></div>", "i": 8669799}, {"t": "<div><div class=\"p\">El Alcalde.</div><br></div>", "i": 8669800}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "54", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-54"}], "organismos": ["MUNICIPALIDAD DE LAS CONDES"], "titulo_norma": "RECTIFICA DECRETO ALCALDICIO Nº1.596, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-01-14", "doble_articulado": false, "id_norma": "86072", "numero_fuente": "34171", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-01-20", "vigencias": [{"desde": "1992-01-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-01-20", "fin_vigencia": ""}, "vigencias_version_norma"