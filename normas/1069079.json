{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9524412}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.725, de 15 de octubre de 2014,de esta Subsecretar&#xED;a, autor&#xED;zase al SINDICATO DE TRABAJADORES INDEPENDIENTES, PESCADORES ARTESANALES DE ESTERO ROLECHA, para realizar actividades experimentales de acuicultura, cuyo objetivo es transferir tecnolog&#xED;as para cultivo de luga en &#xE1;reas de manejo.</div><div class=\"p\">&nbsp; &nbsp;  Las actividades se desarrollar&#xE1;n por 2 a&#xF1;os, en destinaci&#xF3;n mar&#xED;tima otorgada por D. Ex. N&#xBA; 449, de 2008, del Ministerio de Defensa Nacional, cumpliendo con la normativa vigente y en la forma indicada en el Informe T&#xE9;cnico y resoluci&#xF3;n extractada.</div></div>", "i": 9524413}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de octubre de 2014.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9524414}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2725 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2725 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-10-15", "doble_articulado": false, "id_norma": "1069079", "numero_fuente": "40999", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-11-05", "vigencias": [{"desde": "2014-11-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-11-05", "fin_vigencia": ""}, 