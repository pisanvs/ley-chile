{"html": [{"t": "<div><div class=\"p\">AUTORIZA A PESQUERA ITATA S.A. PARA AMPLIAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 6347743}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 247 de 13 de Marzo de 1986 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, pronunci&#xE1;ndose sobre solicitud del 03 de Enero de 1986, se autoriza a Pesquera Itata S.A., domiciliada en Santiago, para operar la embarcaci&#xF3;n denominada &quot;Petrohu&#xE9; I&quot;, en el litoral de las Regiones VIII, IX y X, en labores extractivas de los siguientes recursos: sardina com&#xFA;n, sardina espa&#xF1;ola, anchoveta, caballa, jurel y agujilla.</div><br></div>", "i": 6347744}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de Marzo de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6347745}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "247", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-247"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA ITATA S.A. PARA AMPLIAR ACTIVIDADES\nPESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-03-13", "fecha_derogacion": "1986-12-29", "doble_articulado": false, "id_norma": "188954", "numero_fuente": "32430", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-03-24", "vigencias": [{"desde": "1986-12-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1986-03-24", "hasta": "1986-12-28", "tipo_version": "0", "tipo_v