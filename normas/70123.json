{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8301988}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 360, de 11 de marzo de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xBA; 466, de 1994, de esta Subsecretar&#xED;a, que autoriz&#xF3; a&nbsp; PESQUERA IQUIQUE-GUANAYE S.A., para desarrollar actividades pesqueras extractivas con la nave &quot;Sokol&quot;, por haberse configurado la causal prevista en el art&#xED;culo 143 letra b) de la Ley N&#xBA; 18.892 y sus modificaciones.</div><br></div>", "i": 8301989}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de marzo de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8301990}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "360", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-360"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA IQUIQUE-GUANAYE S.A.", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-11", "doble_articulado": false, "id_norma": "70123", "numero_fuente": "35721", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-03-20", "vigencias": [{"desde": "1997-03-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-03-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-03-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "