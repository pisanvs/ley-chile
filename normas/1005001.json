{"html": [{"t": "<div><br><div class=\"p\">ESTABLECE MECANISMO DE COBRO Y REGISTRO DE COSTOS DIRECTOS DE REPRODUCCI&#xD3;N PARA EFECTOS QUE INDICA</div></div>", "i": 8768425}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta N&#xBA;115, de 7 de agosto de 2009, del Director del Servicio de Impuestos Internos, que establece mecanismo de cobro y registro de costos directos de reproducci&#xF3;n para efectos de las solicitudes de acceso a la informaci&#xF3;n, conforme con lo se&#xF1;alado en el <a href=\"https://www.leychile.cl/Navegar?idNorma=276363&amp;idParte=8564044&amp;idVersion=\">art&#xED;culo 18 de la ley N&#xBA;20.285</a>.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en agosto de 2009.</div><br></div>", "i": 8768426}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "115 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-115 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ESTABLECE MECANISMO DE COBRO Y REGISTRO DE COSTOS DIRECTOS DE REPRODUCCIÓN PARA EFECTOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-08-07", "doble_articulado": false, "id_norma": "1005001", "numero_fuente": "39436", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-08-13", "vigencias": [{"desde": "2009-08-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio