{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 323, DE 1993 </div></div>", "i": 5943803}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 323 de 25</div><div class=\"p\">de junio de 1993, se ha aprobado para la Escuela</div><div class=\"p\">Especial N&#xB0; 973 &quot;Santa Juliana&quot;, de la comuna de</div><div class=\"p\">Santiago, Regi&#xF3;n Metropolitana, un plan y programas</div><div class=\"p\">especiales de estudio para impartir ense&#xF1;anza orientada</div><div class=\"p\">a la vida del trabajo, a trav&#xE9;s de Talleres de</div><div class=\"p\">Artesan&#xED;a, Jardiner&#xED;a y Alimentaci&#xF3;n, por un per&#xED;odo de cuatro a&#xF1;os, a contar de Marzo de 1993.</div><br></div>", "i": 5943804}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 28 de junio de 1993.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943805}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "323", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-323"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 323, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ESTABLECIMIENTOS EDUCACIONALES", "SANTIAGO", "REGION METROPOLITANA", "ESCUELA ESPECIAL N 973 SANTA JULIANA", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-06-25", "doble_articulado": false, "id_norma": "20995", "numero_fuente": "34602", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-06-30", "vigencias": [{"desde": "1993-06-30", "hasta": "", "tipo_version": "3",