{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><br></div>", "i": 8781728}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1&#xB0;.- Der&#xF3;ganse los dos &#xFA;ltimos incisos del</div><div class=\"p\">art&#xED;culo 6&#xB0; de la ley n&#xFA;mero 4,601, de 18 de Junio de 1929, que gravan la exportaci&#xF3;n de los cueros de liebres y conejos.</div><br></div>", "i": 8781729}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 2&#xB0;.- Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial.&quot; </div></div>", "i": 8781730}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y, por cunto he tenido bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto com ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a treinta de Agosto de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Edecio Torreblanca. </div></div>", "i": 8781731}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4874", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4874"}], "organismos": ["MINISTERIO DE LA PROPIEDAD AUSTRAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LIEBRES", "CONEJOS", "CUEROS", "IMPUESTO", "EXPORTACION", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-08-30", "doble_articulado": false, "id_norma": "24956", "numero_fuente": "15672", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-08-30", "vigencias": [{"desde": "1930-08-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vige