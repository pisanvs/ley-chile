{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6472981}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 901, de 31 de marzo de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a SOUTHPACIFIC KORP S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Guanaye 5&quot;, en las &#xE1;reas mar&#xED;timas que a continuaci&#xF3;n se indican, donde podr&#xE1; capturar el recurso Jibia: a) En el &#xE1;rea mar&#xED;tima de la I a la IV Regi&#xF3;n, de la VII Regi&#xF3;n y de la IX a X Regi&#xF3;n, con cerco; b) En el &#xE1;rea mar&#xED;tima de la I a III Regi&#xF3;n, con arrastre de media agua, y c) En el &#xE1;rea mar&#xED;tima de las IV, VII, IX y X Regiones, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua.</div><br></div>", "i": 6472982}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de marzo de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6472983}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "901", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-901"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-31", "doble_articulado": false, "id_norma": "223541", "numero_fuente": "37834", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-13", "vigencias": [{"desde": "2004-04-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-04-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vi