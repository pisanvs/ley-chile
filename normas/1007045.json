{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.406 EXENTA, DE 2009</div></div>", "i": 8789386}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.406, de fecha 13 de abril de 2009, del Ministerio de Educaci&#xF3;n, se aprueban los planes y programas de estudios al Centro de Formaci&#xF3;n T&#xE9;cnica MAGNOS, de las carreras y t&#xED;tulos t&#xE9;cnicos de nivel superior que se indican, para ser impartidos en la Sede Central de Santiago, a contar del a&#xF1;o 2009:</div><br><div class=\"p\">Carrera: Asistente Gerencial</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico de Nivel Superior Asistente Gerencial</div><div class=\"p\">Carrera: T&#xE9;cnico en Contabilidad General</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico de Nivel Superior en Contabilidad General.</div></div>", "i": 8789387}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de junio de 2009.- Cristi&#xE1;n Mart&#xED;nez Ahumada, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8789388}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3406 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3406 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.406 EXENTA, DE 2009", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2009-04-13", "fecha_derogacion": "2017-08-31", "doble_articulado": false, "id_norma": "1007045", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2009-10-10", "vigencias": [{"desde": "2017-08-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Vers