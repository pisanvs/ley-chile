{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7294503}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.038 de 26 de septiembre de</div><div class=\"p\">2002, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto la</div><div class=\"p\">resoluci&#xF3;n N&#xBA; 638 de 1987, de esta Subsecretar&#xED;a, en</div><div class=\"p\">cuanto autoriz&#xF3; a&nbsp; SABROPESCA LIMITADA a operar una</div><div class=\"p\">planta de transformaci&#xF3;n en Caleta Hornos, comuna de</div><div class=\"p\">La Higuera, IV Regi&#xF3;n, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 7&#xBA; del D.S. N&#xBA; 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, y de lo informado por el Servicio Nacional de Pesca en oficios citados en Visto.</div><br></div>", "i": 7294504}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de septiembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7294505}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2038", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2038"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-09-26", "doble_articulado": false, "id_norma": "203200", "numero_fuente": "37376", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-10-05", "vigencias": [{"desde": "2002-10-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-10-05", "fin_vigencia": ""}, "vigenc