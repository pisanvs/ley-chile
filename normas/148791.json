{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6209895}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 3.160, de 22 de octubre de 1999, se modific&#xF3; el decreto MOP N&#xBA; 1.785, de 30 de junio de 1999, que autoriz&#xF3; la expropiaci&#xF3;n del lote N&#xBA; 36 para la obra Mejoramiento Autopista, Concepci&#xF3;n - Talcahuano, Sector Rotonda Bonilla y Campus San Andr&#xE9;s, en la parte que se refiere a la indemnizaci&#xF3;n definitiva de la expropiaci&#xF3;n m&#xE1;s su correspondiente reajuste asciende a la cantidad de $70.482.720.-</div><br></div>", "i": 6209896}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6209897}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3160", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3160"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-22", "doble_articulado": false, "id_norma": "148791", "numero_fuente": "36528", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-12-01", "vigencias": [{"desde": "1999-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "1999-12-03", "fecha_version": "1999-12-01", "fecha_actualizacion_texto": "1999-12-01", "tipo_tratado": ""}, "alertas": [], "alerta