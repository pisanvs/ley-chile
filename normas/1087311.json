{"html": [{"t": "<div><br><div class=\"p\">PARTIDO REGIONALISTA INDEPENDIENTE</div></div>", "i": 9673573}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Alejandra Bravo Hidalgo y Eduardo Salas Cerda, Presidente Nacional y Secretario General, respectivamente, del Partido Regionalista Independiente, han solicitado la constituci&#xF3;n legal del partido en las Regiones III de Atacama, IV de Coquimbo, VII del Maule, XIV de Los R&#xED;os, XI de Ais&#xE9;n del General Carlos Ib&#xE1;&#xF1;ez del Campo y XII de Magallanes y de la Ant&#xE1;rtica Chilena, acompa&#xF1;ando 369, 775, 1.500, 674, 113 y 214 fichas de afiliaci&#xF3;n, respectivamente.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xBA; de la ley N&#xBA; 18.603, por resoluci&#xF3;n O-N&#xBA; 24 de fecha 29 de enero de 2016.- </div><div class=\"p\">&nbsp; </div></div>", "i": 9673574}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Elizabeth Cabrera Burgos, Directora (S).</div></div>", "i": 9673575}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "24", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-24"}, {"tipo": "3", "numero": "O-24", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-24"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO REGIONALISTA INDEPENDIENTE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 993962; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-01-29", "doble_articulado": false, "id_norma": "1087311", "numero_fuente": "41374", "tipo_version": "3", "tipo_version_s": "Única", "fec