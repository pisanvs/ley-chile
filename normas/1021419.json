{"html": [{"t": "<div><br><div class=\"p\">CERTIFICADO</div></div>", "i": 9083061}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) de captaci&#xF3;n para operaciones reajustables de entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de diciembre de 2010, fue de 3,34% anual.</div></div>", "i": 9083062}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de diciembre de 2010.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div></div>", "i": 9083063}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "Certificado-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-17", "doble_articulado": false, "id_norma": "1021419", "numero_fuente": "39840", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-12-21", "vigencias": [{"desde": "2010-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-12-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-12-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2010-12-21", "fecha_version": "2010-12-21", "actualizado_por": "1289", "fecha_actualizacion_texto": "2010-12-21", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabez