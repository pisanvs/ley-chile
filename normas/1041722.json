{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9273059}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.870, de 6 de julio de 2012, de esta Subsecretar&#xED;a de Pesca, modif&#xED;case el numeral 4&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1041123&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 1.393, de 2012</a>, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Determinaci&#xF3;n de la distribuci&#xF3;n espacial de Jurel entre la V y X Regiones, desde las 5 a 600 mn de la costa, a&#xF1;o 2012&quot;, en el sentido de reemplazar su primer p&#xE1;rrafo por el se&#xF1;alado en la resoluci&#xF3;n extractada.</div></div>", "i": 9273060}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de julio de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9273061}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1870 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1870 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-06", "doble_articulado": false, "id_norma": "1041722", "numero_fuente": "40310", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-07-12", "vigencias": [{"desde": "2012-07-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-07