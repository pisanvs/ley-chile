{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295687}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.100, de 12 de junio de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la</div><div class=\"p\">Resoluci&#xF3;n N&#xB0; 1.127, de 1992, de esta Subsecretar&#xED;a, que</div><div class=\"p\">autoriz&#xF3; a SOCIEDAD PESQUERA TIBURON LIMITADA, para</div><div class=\"p\">desarrollar actividades pesqueras extractivas con la</div><div class=\"p\">nave &quot;Tibur&#xF3;n II&quot;, en virtud de lo se&#xF1;alado en el</div><div class=\"p\">art&#xED;culo 143, letras b) y d) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8295688}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 12 de junio de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295689}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1100", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1100"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "SOCIEDAD PESQUERA TIBURON", "LIMITADA", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-06-12", "doble_articulado": false, "id_norma": "36222", "numero_fuente": "35495", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-06-19", "vigencias": [{"desde": "1996-06-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci