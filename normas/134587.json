{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 1,281.- Santiago, 22 de noviembre de 1899.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6162843}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atenci&#xF3;n a los servicios prestados por el jeneral de brigada don Juan de Dios Rivera, durante la guerra de la independencia, conc&#xE9;dese a su hija do&#xF1;a Elena Rivera, viuda de Correas, una pensi&#xF3;n mensual de ciento cincuenta pesos, que gozar&#xE1; con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6162844}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C&#xE1;rlos Concha.</div><br></div>", "i": 6162845}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1281", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1281"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-11-22", "doble_articulado": false, "id_norma": "134587", "numero_fuente": "6456", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-11-24", "vigencias": [{"desde": "1899-11-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-11-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-11-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": 