{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9341142}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. Exento N&#xBA;307, de 28 de febrero de 2013, y de conformidad a lo dispuesto en el art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;20, superficie 1.506 m2., Rol N&#xBA;210-2, Comuna de Lebu, para la obra &quot;MEJORAMIENTO RUTA P-40, SECTOR QUIAPO - MILLONHUE, PROV. DE ARAUCO&quot;, REGI&#xD3;N DEL BIOB&#xCD;O, integrada por Roxana Cecilia Abarz&#xFA;a Gajardo, Adriana Katherina Fasce Casanueva y Valeska Carolina Ale Go&#xF1;i, fij&#xF3; el valor de tasaci&#xF3;n con fecha 09 de enero de 2012, acord&#xE1;ndose la indemnizaci&#xF3;n con sus propietarios JORGE ALEJANDRO GALINDO FULGERI Y OTROS, en la cantidad de $1.579.646.- suma que se pagar&#xE1; al contado.- </div></div>", "i": 9341143}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9341144}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "307 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-307 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-02-28", "doble_articulado": false, "id_norma": "1049772", "numero_fuente": "40522", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-04-01", "vigencias": [{"desde": "2013-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc