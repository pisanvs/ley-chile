{"html": [{"t": "<div><div class=\"p\">INFORMA NUEVA COMPOSICI&#xD3;N DEL PARTIDO SOCIALISTA DE CHILE </div></div>", "i": 7374618}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Camilo Escalona Medina y Marcelo Schilling Rodr&#xED;guez, Presidente y Secretario General del Partido Socialista de Chile, y Mar&#xED;a Cristina Gim&#xE9;nez Peralta y Reinaldo Flores Aguilera, Presidenta y Secretario del Tribunal Supremo de la colectividad, respectivamente, han informado la nueva composici&#xF3;n de su Directiva Central, la que est&#xE1; integrada por:</div><br><div class=\"p\">Directiva Central:</div><br><div class=\"p\">Presidente&nbsp; &nbsp; &nbsp; &nbsp;  : Camilo Escalona Medina</div><div class=\"p\">Secretario General : Marcelo Schilling Rodr&#xED;guez</div><div class=\"p\">Tesorero&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  : Ricardo Solari Saavedra</div><br><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada en virtud de lo establecido en el Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por resoluci&#xF3;n O-N&#xBA; 983, de fecha 13 de junio de 2008.-</div><br><br></div>", "i": 7374619}, {"t": "<div><div class=\"p\">Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 7374620}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "983", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-983"}, {"tipo": "3", "numero": "O-983", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-983"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "INFORMA NUEVA COMPOSICIÓN DEL PARTIDO SOCIALISTA DE\nCHILE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO SOCIALISTA DE CHILE", "DIRECTIVA CENTRAL", "CAMILO ESCALONA MEDINA", "PRESIDENTE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_