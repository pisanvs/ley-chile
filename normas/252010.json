{"html": [{"t": "<div><div class=\"p\">ACTUALIZA NOMINA GRANDES CONTRIBUYENTES </div></div>", "i": 6578580}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 92, de 1 de agosto de 2006. Se Incorpora a N&#xF3;mina Grandes Contribuyentes a quienes a la fecha de la publicaci&#xF3;n de esta resoluci&#xF3;n cumplan con los criterios establecidos en los resolutivos 2 y 6 de la Res. Ex. N&#xBA; 45 de 19.11.01 y resolutivos 2&#xBA;, 3 y 5&#xBA; de la Res. Ex. N&#xBA; 68 de 02.12.03. Se incluye &quot;Anexo A&quot;, el cual fija N&#xF3;mina Grandes Contribuyentes y &quot;Anexo B&quot; que individualiza aquellos que han dejado de pertenecer a dicha n&#xF3;mina de acuerdo a los par&#xE1;metros ya indicados.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de agosto de 2006.</div><br></div>", "i": 6578581}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "92 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-92 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ACTUALIZA NOMINA GRANDES CONTRIBUYENTES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-08-01", "doble_articulado": false, "id_norma": "252010", "numero_fuente": "38532", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-08-05", "vigencias": [{"desde": "2006-08-