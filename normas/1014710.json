{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div></div>", "i": 8935051}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA; 39.577 de 03 de febrero del 2010, se public&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1010730&amp;idParte=0&amp;idVersion=\">INSTRUCCI&#xD3;N GENERAL N&#xB0; 4 SOBRE TRANSPARENCIA ACTIVA</a> con el error que se salva a continuaci&#xF3;n: p&#xE1;gina treinta y siete, primera columna, en el punto 1.9. , en el p&#xE1;rrafo segundo, donde dice &quot;... . Dicha n&#xF3;mina incluir&#xE1; datos como, por ejemplo, domicilio, tel&#xE9;fono y correo electr&#xF3;nico del beneficiario, ...&quot; debe decir &quot;... . Dicha n&#xF3;mina excluir&#xE1; datos como, por ejemplo, domicilio, tel&#xE9;fono y correo electr&#xF3;nico del beneficiario, ...&quot;.</div><br></div>", "i": 8935052, "v": ["RECTIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "134", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-134"}], "organismos": ["CONSEJO PARA LA TRANSPARENCIA"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1014710", "numero_fuente": "39692", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-06-22", "vigencias": [{"desde": "2010-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-06-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-06-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "RECTIFICACION", "url_part