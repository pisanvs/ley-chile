{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8300918}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 63, de 17 de enero de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n; modif&#xED;case el numeral 1&#xBA; de la Resoluci&#xF3;n N&#xBA; 1.421, de 1996, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; para ampliar actividades pesqueras a PESQUERA TARAPACA S.A., en el sentido de cambiar el nombre de la nave &quot;Loa 23&quot; por el de &quot;Valdivia IV&quot;; como asimismo la matr&#xED;cula de &#xE9;sta, actualmente, n&#xFA;mero &quot;2799&quot; por la n&#xFA;mero &quot;2895&quot;.</div><br><br></div>", "i": 8300919}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de enero de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br><br></div>", "i": 8300920}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "63", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-63"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA TARAPACA S.A.", "PESCA", "AUTORIZACION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-01-17", "fecha_derogacion": "2001-08-09", "doble_articulado": false, "id_norma": "60498", "numero_fuente": "35678", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-01-29", "vigencias": [{"desde": "2001-08-09", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1997-01-29", "hasta": "2001-08-08", "tipo_version": "0", "tipo_