{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8323893}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 55, de 19 de enero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por un a&#xF1;o, a contar del 5 de junio de 1997, el plazo para reiniciar operaciones con la nave &quot;Don Peter&quot;, autorizada por la resoluci&#xF3;n N&#xBA; 600 de 1995, de esta Subsecretar&#xED;a, a SOCIEDAD PESQUERA HORIZONTE LTDA., en virtud de haberse acreditado una circunstancia de fuerza mayor. </div></div>", "i": 8323894}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de enero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8323895}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "55", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-55"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AMPLIACION", "AUTORIZACION", "PESCA", "SOCIEDAD PESQUERA HORIZONTE LTDA."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-01-19", "fecha_derogacion": "2001-06-02", "doble_articulado": false, "id_norma": "93914", "numero_fuente": "35982", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-02-04", "vigencias": [{"desde": "2001-06-02", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-02-04", "hasta": "2001-06-01", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2001-06-02", "fin_vigencia": ""}, "v