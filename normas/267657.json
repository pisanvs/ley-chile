{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6745948}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;784, de 29 de octubre de 2007, se expropi&#xF3; el lote de terreno N&#xBA; 29, superficie 10.689,17 m2, Rol N&#xBA;1420-17, comuna de Rancagua, VI Regi&#xF3;n, para la obra &quot;Proyecto Modificaci&#xF3;n Dise&#xF1;o Definitivo Interceptor de Aguas Lluvias Alameda Rancagua&quot;, obra &quot;Colector Interceptor Alameda&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Alfonso M&#xE1;rquez de la Plata Cort&#xE9;s y Otra, ascendente a la cantidad de $19.810.269.</div><br></div>", "i": 6745949}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6745950}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "784", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-784"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-10-29", "doble_articulado": false, "id_norma": "267657", "numero_fuente": "38937", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-15", "vigencias": [{"desde": "2007-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-12-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2007-12-17", "fecha_version": "2007-12-15", "fecha_actualizacion_texto": "2007-12-15