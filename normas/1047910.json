{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9325273}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.249, de 11 de diciembre de 2012, de esta Subsecretar&#xED;a, autor&#xED;zase a PELANTARO BASILIO INOSTROZA CONCHA, para ampliar actividades pesqueras extractivas con la nave &quot;Rodrigo Alejandro&quot;, en el &#xE1;rea mar&#xED;tima correspondiente a la VIII Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, con red de arrastre, donde podr&#xE1; capturar los siguientes recursos hidrobiol&#xF3;gicos: Bacaladillo o mote, Vinciguerria, Agujilla, Pampanito, Caballa, Cachurreta, Cojinoba del sur, Cojinoba moteada y Pejerrata.</div></div>", "i": 9325274}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de diciembre de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9325275}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3249 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3249 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-12-11", "doble_articulado": false, "id_norma": "1047910", "numero_fuente": "40455", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-01-10", "vigencias": [{"desde": "2013-01-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-01-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-01-10", "fin_vigencia": "", "tipo_vers