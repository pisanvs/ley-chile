{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292558}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 453, de 13 de marzo de 1996, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n; deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por INVERSIONES PACIFICO SUR LTDA., para un centro de cultivo ubicado en Auque, Punta Abtao, Canal Abtao, comuna de Calbuco, provincia de Llanquihue, X Regi&#xF3;n, por no dar cumplimiento el respectivo proyecto t&#xE9;cnico a lo dispuesto en el art&#xED;culo 12&#xB0; del D.S. N&#xB0; 175, de 1980, modificado por el D.S. N&#xB0; 427, de 1989, todos del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8292559}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, de 13 de marzo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292560}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "453", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-453"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "INVERSIONES PACIFICO SUR LTDA.", "CALBUCO", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-03-13", "doble_articulado": false, "id_norma": "34852", "numero_fuente": "35423", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-03-21", "vigencias": [{"desde": "1996-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-03-21", "f