{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9144549}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, doce de mayo de dos mil once.- Habi&#xE9;ndose incurrido en error en la publicaci&#xF3;n en el Diario Oficial de la tabla de emplazamiento a que se refiere el <a href=\"https://www.leychile.cl/Navegar?idNorma=22740&amp;idParte=8767507&amp;idVersion=\">art&#xED;culo 259 del C&#xF3;digo de Procedimiento Civil</a>, correspondiente al quinquenio 2009-2014, rectif&#xED;casela en aquella parte que se refiere a los t&#xE9;rminos que han de computarse desde cualquier punto de la Rep&#xFA;blica, reemplaz&#xE1;ndose la expresi&#xF3;n &quot;Bolivia&quot; que se lee junto a &quot;Ecuador, Colombia, Venezuela, Brasil, Paraguay y&quot;, por &quot;Guayanas&quot;.- </div></div>", "i": 9144550, "v": ["CONCORDANCIA"]}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Milton Juica Arancibia, Presidente Corte Suprema.</div></div>", "i": 9144551}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  TABLA DE EMPLAZAMIENTO</div><br><div class=\"p\">&nbsp; &nbsp;  VER DIARIO OFICIAL DE 27.05.2011, P&#xC1;GINA 4-5, CUERPO I.</div></div>", "i": 9144552}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "Aviso-S/N"}], "organismos": ["CORTE SUPREMA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-05-12", "doble_articulado": false, "id_norma": "1025819", "numero_fuente": "39970", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-05-27", "vigencias": [{"desde": "2011-05-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "