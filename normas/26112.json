{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PRORROGA POR EL PLAZO QUE INDICA LA CONCESION OTORGADA POR LA LEY 6,389 AL CLUB DEPORTIVO Y SOCIAL DE PUTAENDO</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5967290}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1&#xB0;.- Prorr&#xF3;gase por el plazo de veinte a&#xF1;os la concesi&#xF3;n otorgada por la ley N&#xB0; 6,389, de 14 de Agosto de 1939, al Club Deportivo y Social de Putaendo. </div></div>", "i": 5967291}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2&#xB0;.- Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial&quot;.</div><br></div>", "i": 5967292}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, doce de Noviembre de mil novecientos cuarenta y nueve.- GABRIEL GONZALEZ VIDELA.- Fidel Estay Cort&#xE9;s.</div><br></div>", "i": 5967293}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "9495", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-9495"}], "organismos": ["MINISTERIO DE TIERRAS Y COLONIZACIÓN"], "titulo_norma": "PRORROGA POR EL PLAZO QUE INDICA LA CONCESION\nOTORGADA POR LA LEY 6,389 AL CLUB DEPORTIVO Y SOCIAL DE\nPUTAENDO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRORROGA PLAZO", "CONCESION", "LEY 6389", "CLUB DEPORTIVO Y SOCIAL", "PUTAENDO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1949-11-12", "doble_articulado": false, "