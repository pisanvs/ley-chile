{"html": [{"t": "<div><div class=\"p\">&#xFEFF;EXCEPCION AL ART. 2.&#xB0; DE LA LEI DE 25 DE SETIEMBRE</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso nacional con fecha 11 de este mes ha decretado lo siguiente:</div></div>", "i": 10208839}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Las obligaciones o pagar&#xE9;s firmados a vales antes de la promulgacion de la lei de 25 de setiembre no son comprendidos en la determinacion que se hace en el art. 2.&#xB0; de&nbsp; dicha lei.</div></div>", "i": 10208840}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por tanto ordeno que se publique por lei insert&#xE1;ndose en el Boletin. Dado en el Palacio de Gobierno en Santiago de Chile a 11 de Noviembre de 826.</div><br><div class=\"p\">&nbsp; &nbsp;  EIZAGUIERRE.\t</div><br><div class=\"p\">&nbsp; &nbsp;  Vial.</div></div>", "i": 10208841}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "33", "numero": "S/N", "abreviacion": "LEI", "descripcion": "Lei", "compuesto": "Lei-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "EXCEPCION AL ART. 2.° DE LA LEI DE 25 DE SETIEMBRE", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1826-11-11", "doble_articulado": false, "id_norma": "1152905", "numero_fuente": "1826", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1826-11-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1826-11-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1826-11-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "2932", "fecha_ing