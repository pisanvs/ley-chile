{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 1.659</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Comit&#xE9; Ejecutivo de este Banco Central de Chile en su Sesi&#xF3;n No. 1.659, celebrada el 1&#xBA; de Julio de 1985, adopt&#xF3; los siguientes acuerdos: </div></div>", "i": 6258791}, {"t": "<div><div class=\"p\">1659-05-850701 - Modifica Cap&#xED;tulo III.B.1 del Compendio de Normas Financieras.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; derogar la Disposici&#xF3;n Transitoria del Cap&#xED;tulo III.B.1. &quot;Normas sobre Captaci&#xF3;n e Intermediaci&#xF3;n&quot; del Compendio de Normas Financieras. </div></div>", "i": 6258792}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 2 de Julio de 1985.- Carmen Hermosilla Valencia. Secretario General.</div><br></div>", "i": 6258793}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1659", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1659"}, {"tipo": "5", "numero": "1659-05", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1659-05"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 1.659", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-07-01", "doble_articulado": false, "id_norma": "163563", "numero_fuente": "32212", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-07-03", "vigencias": [{"desde": "1985-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia":