{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 56 EXENTO, DE 2004 </div></div>", "i": 6464706}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La I. Municipalidad de Loncoche, pone en conocimiento de la comunidad que por decreto alcaldicio exento N&#xBA; 056 de fecha 29 de enero de 2004, fue aprobado el reglamento sobre la regulaci&#xF3;n al acceso a la informaci&#xF3;n municipal y establece el secreto o reserva sobre documentos y actos administrativos que indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo del citado reglamento se informa que estar&#xE1; a disposici&#xF3;n del p&#xFA;blico en la Oficina de Partes.</div><br></div>", "i": 6464707}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Carlos Fernando Espejo Z&#xFA;&#xF1;iga, Alcalde de Loncoche.</div><br></div>", "i": 6464708}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "56 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-56 EXENTO"}], "organismos": ["MUNICIPALIDAD DE LONCOCHE"], "titulo_norma": "EXTRACTO DE DECRETO Nº 56 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-29", "doble_articulado": false, "id_norma": "221294", "numero_fuente": "37788", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-17", "vigencias": [{"desde": "2004-02-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-02-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-02-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2004-02