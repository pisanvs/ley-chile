{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6270631}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 2.492, de 27 de Noviembre de 1987, conforme Art. 5&#xB0; Transitorio del C&#xF3;digo de Aguas, determin&#xF3; Derechos de Aprovechamiento de Aguas proporcionales que corresponden a Sector Excluido y Sector Expropiado predio &quot;La Chipana&quot; de las comunas de Chimbarongo y Teno, VI y VII Regiones. Los Derechos de Aprovechamiento de Aguas se extraen del R&#xED;o Teno por el Canal Huemul; Toma El Casta&#xF1;o del Estero de Chimbarongo y derrames de la antigua Hacienda Casas de Huemul. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377. </div></div>", "i": 6270632}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6270633}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2492 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2492 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-27", "doble_articulado": false, "id_norma": "167218", "numero_fuente": "32934", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-01", "vigencias": [{"desde": "1987-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-01", "fin_vigencia": "", "t