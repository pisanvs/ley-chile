{"html": [{"t": "<div><br><div class=\"p\">DERECHOS DE AGUA EN COMUNA DE SAN ANTONIO</div></div>", "i": 9399986}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero, mediante resoluci&#xF3;n exenta N&#xBA; 7.770, de 9 de diciembre de 2013, aprob&#xF3; la distribuci&#xF3;n de los derechos de aprovechamiento de aguas del predio denominado &quot;El Asilo&quot;, ubicados en la comuna de San Antonio, Regi&#xF3;n de Valpara&#xED;so, en el sentido de establecer, en unidad de volumen por unidad de tiempo, los derechos de aprovechamiento de aguas conducidos por el canal El Asilo, derivados del r&#xED;o Maipo, estableciendo que dichos derechos son consuntivos, de ejercicio permanente y continuo.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13&#xBA; de la ley N&#xBA; 18.377.</div></div>", "i": 9399987}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director Nacional.</div></div>", "i": 9399988}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7770 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-7770 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUA EN COMUNA DE SAN ANTONIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-12-09", "doble_articulado": false, "id_norma": "1058247", "numero_fuente": "40757", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-01-15", "vigencias": [{"desde": "2014-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia