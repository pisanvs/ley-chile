{"html": [{"t": "<div><div class=\"p\">&#xFEFF;ECEPCION DEL RATEO AL RESGUARDO DE LA CORDILLERA</div><br><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso nacional con fecha 3 de este mes ha decretado lo siguiente: </div></div>", "i": 10225324}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Se declara que el resguardo de la cordillera es comprendido en las excepciones de la ley del rateo.</div><br><div class=\"p\">&nbsp; &nbsp;  Por tanto ordeno que se ejecute y publique en el bolet&#xED;n. Dado en la Sala de Gobierno en Santiago de Chile a 5 de marzo de 1827.</div></div>", "i": 10225325}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE</div><br><div class=\"p\">&nbsp; &nbsp;  Rio.</div></div>", "i": 10225326}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "﻿ECEPCION DEL RATEO AL RESGUARDO DE LA CORDILLERA", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1827-03-05", "doble_articulado": false, "id_norma": "1156571", "numero_fuente": "1827", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1827-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1827-03-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1827-03-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2021-05-10", "fecha_version": "1827-03-05", "fecha_actualizacion_texto": "2021-05-10", "tipo_tratado": ""}, "alerta