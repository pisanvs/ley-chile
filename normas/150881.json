{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6217641}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 503 de 04 de junio de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Claudio D&#xED;az Aros para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 1 &quot;Francke - Centro Rahue Alto&quot; de Osorno, cuyo trazado fue autorizado por resoluci&#xF3;n No. 90 de fecha 12 de junio de 1984 y modificado por resoluci&#xF3;n No. 464 de 16 de septiembre de 1986, de esta Secretar&#xED;a Regional.- </div></div>", "i": 6217642}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6217643}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "503 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-503 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-04", "doble_articulado": false, "id_norma": "150881", "numero_fuente": "32800", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-20", "vigencias": [{"desde": "1987-06-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-06-20", "fin_vigencia":