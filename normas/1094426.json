{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 28 A</div></div>", "i": 9726906}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.603, de 25 de agosto de 2016, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1088434&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 726 de 2016</a>, de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 28 A, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo, para los centros de cultivo que se indican en la resoluci&#xF3;n extractada.</div></div>", "i": 9726907}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de agosto de 2016.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura. </div></div>", "i": 9726908}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2603 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2603 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 28 A", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1106616; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-08-25", "doble_articulado": false, "id_norma": "1094426", "numero_fuente": "41549", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-09-02", "vigencias": [{"desde": "2016-09-02", "hasta": "", "tipo_version": "3", "tipo_version