{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 7270056}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.386, de fecha 22 de Octubre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a los se&#xF1;ores Orlando Patricio Pi&#xF1;a Boselli y don Ricardo Aguayo Riveros para efectuar servicio p&#xFA;blico urbano de locomoci&#xF3;n colectiva de pasajeros en el recorrido de la Variante N&#xB0; 100-6 &quot;Pablo de Rocka-Quilicura&quot;, de la L&#xED;nea de Buses N&#xB0; 100 &quot;Pe&#xF1;alol&#xE9;n -Mapocho-Quilicura&quot;, cuyo trazado se encuentra autorizado por la resoluci&#xF3;n N&#xB0; 2.286, 30 de Noviembre de 1979, de esta Secretar&#xED;a Regional. </div></div>", "i": 7270057}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de Octubre de 1987.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 7270058}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1386 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1386 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-10-22", "doble_articulado": false, "id_norma": "169176", "numero_fuente": "32914", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-07", "vigencias": [{"desde": "1987-1