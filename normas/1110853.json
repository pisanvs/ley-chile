{"html": [{"t": "<div><br><br><div class=\"p\">EXTRACTO</div></div>", "i": 9849916}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA; 1375, de 02 de noviembre de 2017, se modific&#xF3; el numeral segundo del <a href=\"https://www.leychile.cl/Navegar?idNorma=1109080&amp;idParte=&amp;idVersion=\">Decreto (Exento) MOP. N&#xBA; 1101</a>, de 08 de septiembre de 2017, en lo que respecta al nombre del propietario del lote N&#xBA; 117, donde dice &quot;Fortestal&quot;, debe decir &quot;Forestal&quot;. </div><br></div>", "i": 9849917, "v": ["MODIFICACION"]}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div><br></div>", "i": 9849918}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1375 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1375 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1301219", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-11-02", "doble_articulado": false, "id_norma": "1110853", "numero_fuente": "41908", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-11-15", "vigencias": [{"desde": "2017-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2017-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "906", "fecha_ingr