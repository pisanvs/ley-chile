{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6511003}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.632, de 23 de diciembre de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA FRIOSUR VIII S.A., para realizar actividades extractivas en aguas internacionales con la nave &quot;Friosur VIII&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><div class=\"p\"> Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; CB-5643</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  2861</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 47,80 m.</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  10,50 m.</div><div class=\"p\">Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 7,65 m.</div><div class=\"p\">T.R.G. (Internacional)&nbsp; &nbsp; &nbsp; 930,00</div><div class=\"p\">Potencia motor principal&nbsp; &nbsp; 2193,80 HP</div><div class=\"p\">Potencia motor auxiliar&nbsp; &nbsp;  676,30 HP</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp;  537,22 m3</div><br><br></div>", "i": 6511004}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de diciembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6511005}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3632 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3632 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observa