{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6498902}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 513 de 23 de septiembre de 2004, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme D.L. N&#xBA;2.186, de 1978, del lote N&#xBA;20 correspondiente al inmueble ubicado en calle Suiza N&#xBA;344, presunto rol de aval&#xFA;o N&#xBA;543-8, comuna de Cerrillos, de dominio de Mario Andr&#xE9;s Mart&#xED;nez. Comisi&#xF3;n integrada por peritos Rodrigo Mella Ascar, constructor civil; Mauricio Encina Aguilera, ingeniero civil; y Mar&#xED;a Quiroga Gonz&#xE1;lez, arquitecto. Seg&#xFA;n informe de fecha 12 de abril de 2004 fij&#xF3; monto provisional indemnizaci&#xF3;n en $33.714.380.- pagadera al contado. Monto definitivo de la indemnizaci&#xF3;n fue fijado de com&#xFA;n acuerdo en $38.000.000.-</div><br></div>", "i": 6498903}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Director Serviu Metropolitano.</div><br></div>", "i": 6498904}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "513", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-513"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-09-23", "doble_articulado": false, "id_norma": "230811", "numero_fuente": "37975", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-10-01", "vigencias": [{"desde": "2004-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}