{"html": [{"t": "<div><div class=\"p\">APRUEBA ORDENANZA SOBRE SUBVENCIONES MUNICIPALES </div></div>", "i": 6455980}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Municipalidad de Panquehue pone en conocimiento de la comunidad que, por decreto alcaldicio N&#xBA; 1.786 de fecha 22 de diciembre de 2003, fue aprobada la ordenanza que norma sobre el procedimiento a observar para el otorgamiento de las Subvenciones Municipales.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de la citada ordenanza est&#xE1; a disposici&#xF3;n de quien lo solicite en la Direcci&#xF3;n de Desarrollo Comunitario, cuyas oficinas se ubican en calle Troncal N&#xBA; 1166, Panquehue.</div><br></div>", "i": 6455981}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Ren&#xE9; Ahumada Ortega, Alcalde.</div><br></div>", "i": 6455982}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1786", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1786"}], "organismos": ["MUNICIPALIDAD DE PANQUEHUE"], "titulo_norma": "APRUEBA ORDENANZA SOBRE SUBVENCIONES MUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-22", "doble_articulado": false, "id_norma": "219425", "numero_fuente": "37746", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-29", "vigencias": [{"desde": "2003-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-12-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-12-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2003-12-29", "f