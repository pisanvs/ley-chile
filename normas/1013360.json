{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8918456}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.420, de 21 de abril de 2010, de esta Subsecretar&#xED;a, autor&#xED;zase a H&#xC9;CTOR ABEL Z&#xDA;&#xD1;IGA GALLARDO, para instalar, por el per&#xED;odo de seis meses contados desde la fecha de la presente resoluci&#xF3;n, colectores de semillas de choritos en Punta Iglesia, Estero Reloncav&#xED;, X Regi&#xF3;n, en una superficie de 3,9 hect&#xE1;reas, cuyas coordenadas geogr&#xE1;ficas, referidas al plano DPC-210, son:</div><br><div class=\"p\">V&#xE9;rtice&nbsp;  Latitud (S)&nbsp;  Longitud (W)</div><br><div class=\"p\">&nbsp;  A&nbsp; &nbsp;  41&#xBA;40&apos;22.85&quot;&nbsp;  72&#xBA;22&apos;35.68&quot;</div><div class=\"p\">&nbsp;  B&nbsp; &nbsp;  41&#xBA;40&apos;18.07&quot;&nbsp;  72&#xBA;22&apos;27.92&quot;</div><div class=\"p\">&nbsp;  C&nbsp; &nbsp;  41&#xBA;40&apos;22.28&quot;&nbsp;  72&#xBA;22&apos;23.31&quot;</div><div class=\"p\">&nbsp;  D&nbsp; &nbsp;  41&#xBA;40&apos;27.06&quot;&nbsp;  72&#xBA;22&apos;31.07&quot;</div></div>", "i": 8918457}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de abril de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 8918458}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1420", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1420"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-04-21", "doble_articulado": false, "id_norma": "1013360", "numero_fuen