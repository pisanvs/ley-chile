{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6404040}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 63, de 18 de noviembre de 2002, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, rech&#xE1;zase el recurso de reclamaci&#xF3;n interpuesto por PESQUERA FRIOSUR S.A., en contra de la resoluci&#xF3;n N&#xBA;2.278 de 2001 de la Subsecretar&#xED;a de Pesca, en virtud de no haberse acreditado fehacientemente la improcedencia de la declaraci&#xF3;n de caducidad parcial de la autorizaci&#xF3;n con la que contaba la nave &quot;Friosur IX&quot; dispuesta por la resoluci&#xF3;n recurrida, de conformidad con lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 6404041}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de noviembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6404042}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "63 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-63 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-11-18", "doble_articulado": false, "id_norma": "204988", "numero_fuente": "37418", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-11-26", "vigencias": [{"desde": "2002-11-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-11-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "200