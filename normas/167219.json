{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6270634}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 2.493, de 27 de Noviembre de 1987, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a Sector Excluido y Sector Expropiado predio &quot;Resto del Predio R&#xFA;stico Denominado Hacienda El Colorado&quot; de la comuna de San Clemente, VII Regi&#xF3;n; y Derechos Aprovechamiento Aguas que corresponden a parcelas N&#xB0;s. 1 a la 47, sitios N&#xB0;s. 1 al 70 y Reservas Cora N&#xB0;s. 1, 2 y 3 del Proyecto de Parcelaci&#xF3;n &quot;El Colorado&quot; formado por predio se&#xF1;alado. Los Derechos de Aguas se extraen del Canal Maule Norte. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.</div><br></div>", "i": 6270635}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Director Ejecutivo.</div><br></div>", "i": 6270636}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2493 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2493 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-27", "doble_articulado": false, "id_norma": "167219", "numero_fuente": "32934", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-01", "vigencias": [{"desde": "1987-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}