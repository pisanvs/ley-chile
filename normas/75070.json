{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8305751}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.144, de 8 de agosto de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de las Resoluciones N&#xBA; 111, de 1982 y N&#xBA; 335, de 1997, de esta Subsecretar&#xED;a, que autorizaron a PESQUERA TEL LIMITADA, para operar la nave &quot;Venus&quot;; en virtud de configurarse la causal prevista en el art&#xED;culo 143 letra b) de la Ley N&#xBA; 18.892 y sus modificaciones, citada en Visto.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xBA; 855, de 1997, de esta Subsecretar&#xED;a en virtud de no haberse publicado oportunamente en el Diario Oficial.</div><br></div>", "i": 8305752}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de agosto de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8305753}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1144", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1144"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA TEL LIMITADA", "AUTORIZACION", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-08-08", "doble_articulado": false, "id_norma": "75070", "numero_fuente": "35845", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-08-19", "vigencias": [{"desde": "1997-08-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia