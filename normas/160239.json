{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 8, DE 2000</div><br><br><br></div>", "i": 6247974}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA; 8, de fecha 20 de enero del a&#xF1;o 2000, se aprob&#xF3; la reforma parcial al estatuto de la Cooperativa Nacional Due&#xF1;os de Camiones Limitada, en los t&#xE9;rminos que da testimonio la escritura p&#xFA;blica suscrita con fecha 4 de noviembre de 1999, ante el notario de Santiago, Eduardo Pinto Peralta. </div></div>", "i": 6247975}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Sr. Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas.</div><br></div>", "i": 6247976}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 8, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COOPERATIVA NACIONAL DUEÑOS DE CAMIONES", "ESTATUTOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-20", "doble_articulado": false, "id_norma": "160239", "numero_fuente": "36609", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-09", "vigencias": [{"desde": "2000-03-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresa