{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AUTORIZA LA ERECCION EN SANTIAGO DE UN MONUMENTO PUBLICO A JUAN SEBASTIAN BASH.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8278374}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.&#xB0; Autor&#xED;zase la erecci&#xF3;n en Santiago de un monumento p&#xFA;blico a Juan Sebasti&#xE1;n Bach. </div></div>", "i": 8278375}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2.&#xB0; Esta ley regir&#xE1; desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 8278376}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecis&#xE9;is de Agosto de mil novecientos cuarenta y cuatro.- JUAN ANTONIO RIOS M.- Osvaldo Hiriart.</div><br></div>", "i": 8278377}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "7822", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-7822"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA LA ERECCION EN SANTIAGO DE UN MONUMENTO\nPUBLICO A JUAN SEBASTIAN BASH.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1944-08-16", "doble_articulado": false, "id_norma": "25657", "numero_fuente": "19947", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1944-08-31", "vigencias": [{"desde": "1944-08-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vige