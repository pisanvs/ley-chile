{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xB0; 1.782</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Comit&#xE9; Ejecutivo de este Banco Central de Chile en su Sesi&#xF3;n N&#xB0; 1.782, celebrada el 18 de febrero de 1987, adopt&#xF3; el siguiente acuerdo: </div></div>", "i": 6184917}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; 1782-03-870218 - Modifica Cap&#xED;tulo III.C.2 del Compendio de Normas Financieras.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; reemplazar en el n&#xFA;mero 2 del Cap&#xED;tulo III.C.2 &quot;Normas que rigen a las Cooperativas de Ahorro y Cr&#xE9;dito&quot; del Compendio de Normas Financieras, las palabras &quot;una vez&quot; por la expresi&#xF3;n &quot;1,25 veces&quot;. </div></div>", "i": 6184918}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de febrero de 1987.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6184919}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1782", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1782"}, {"tipo": "5", "numero": "1782-03", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1782-03"}], "organismos": ["MINISTERIO DE HACIENDA", "BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDO ADOPTADO POR EL COMITE EJECUTIVO DEL BANCO\nCENTRAL DE CHILE EN SU SESION N° 1.782", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-18", "doble_articulado": false, "id_norma": "141275", "numero_fuente": "32703", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-02-20", "vigencias"