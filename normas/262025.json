{"html": [{"t": "<div><div class=\"p\">Decreto con fuerza de Ley N.o 78</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 78.- Santiago, 2 de Abril de 1931.- Vistos estos antecedentes, y en uso de las facultades que me confiere la ley n&#xFA;mero 4,945, de 6 de Febrero &#xFA;ltimo, </div><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 9054025}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ratif&#xED;canse las disposiciones contenidas en los</div><div class=\"p\">art&#xED;culos 7.o y 8.o del decreto supremo n&#xFA;mero 950, del Ministerio de Hacienda, de fecha 22 de Marzo de 1928. </div></div>", "i": 9054026}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- C.IBA&#xD1;EZ C.- Carlos Castro Ruiz.</div><br></div>", "i": 9054027}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "78", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-78"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DECRETO CON FUERZA DE LEY N.º 78", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-04-02", "doble_articulado": false, "id_norma": "262025", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-05-28", "vigencias": [{"desde": "1931-05-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1931-05-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1931-05-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2007-06-21", "fecha_version": "1931-05-28", "fecha_actualizacion_texto": "1931-05-28", "