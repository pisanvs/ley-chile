{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,542, que suplementa el Presupuesto de Marina.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,542.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 7166769}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.-Conc&#xE9;dese un suplemento de setecientos mil pesos ($ 700,000) al &#xED;tem 133 del Presupuesto de Marina vijente.</div><div class=\"p\">&nbsp; &nbsp; D&#xE9;jase sin invertir igual cantidad del &#xED;tem 778 del indicado Presupuesto.</div><br></div>", "i": 7166770, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintinueve de Agosto de mil novecientos diecinueve.- JUAN LUIS SANFUENTES.- Enrique Berm&#xFA;dez. </div></div>", "i": 7166771}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3542", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3542"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "Lei núm. 3,542, que suplementa el Presupuesto de;Marina.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1919", "MODIFICACION", "MINISTERIO", "MARINA", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1919-08-29", "doble_articulado": false, "id_norma": "24053", "numero_fuente": "12464", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1919-09-03", "vigencias": [{"desde": "1919-09-03", "hasta": "", "tipo_