{"html": [{"t": "<div><div class=\"p\">EXTRACTO RESOLUCI&#xD3;N N&#xB0; 6.287 EXENTA, DE 27 DE NOVIEMBRE DE 2017</div></div>", "i": 9865066}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por el presente acto administrativo se han modificado, a contar del A&#xF1;o Escolar 2018, las resoluciones exentas Nos <a href=\"https://www.leychile.cl/Navegar?idNorma=180790&amp;idParte=0&amp;idVersion=\">12.993, de 2000</a>; <a href=\"https://www.leychile.cl/Navegar?idNorma=196619&amp;idParte=0&amp;idVersion=\">16.288, de 2001</a>, y <a href=\"https://www.leychile.cl/Navegar?idNorma=206149&amp;idParte=0&amp;idVersion=\">14.116, de 2002</a>, todas del Ministerio de Educaci&#xF3;n, que aprobaron Planes y Programas Especiales de Estudio de 1&#xBA; a 4&#xBA; A&#xF1;o de Educaci&#xF3;n Media, al Colegio Craighouse School, de la comuna de Lo Barnechea, provincia de Santiago, Regi&#xF3;n Metropolitana, en el sentido de sustituir sus Planes de Estudio de 1&#xBA; a 4&#xBA; A&#xF1;o de Educaci&#xF3;n Media, por los que se indican en la presente resoluci&#xF3;n exenta.</div></div>", "i": 9865067}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de noviembre de 2017.- Valentina Karina Quiroga Canahuate, Subsecretaria de Educaci&#xF3;n.</div></div>", "i": 9865068}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6287 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6287 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO RESOLUCIÓN N° 6.287 EXENTA, DE 27 DE NOVIEMBRE DE 2017", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1316892; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-11-27", "doble_