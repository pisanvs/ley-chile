{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8346045}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.191, de 18 de junio de 1999, de esta Subsecretar&#xED;a, modif&#xED;case la resoluci&#xF3;n N&#xBA; 1.211 de 1998, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA CORONEL S.A., para operar la nave &apos;&apos;Antartic&apos;&apos;, de la siguiente manera: Agregar en el numeral 1, en las caracter&#xED;sticas n&#xE1;uticas, lo siguiente: &apos;&apos;Potencia total instalada 3.127 Hp&apos;&apos;. Establecer que los recursos hidrobiol&#xF3;gicos se&#xF1;alados en las letras b) y c) del numeral 2 y letras c) y d) del numeral 3 podr&#xE1;n ser capturados con red de arrastre de media agua, solamente por fuera de las 60 millas n&#xE1;uticas medidas desde las l&#xED;neas de base normal.</div><br></div>", "i": 8346046}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de junio de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8346047}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1191", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1191"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-06-18", "fecha_derogacion": "2011-10-19", "doble_articulado": false, "id_norma": "138254", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-06-30", "vigencias": [{"desde": "2011-10-19", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-06-30", "hasta": "2011-10-18