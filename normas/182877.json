{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;01111 EXENTA, DE 2001 </div></div>", "i": 6326586}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;0111, de 23 de febrero de 2001, se ha aprobado al Colegio &apos;&apos;Colegio Compa&#xF1;&#xED;a de Mar&#xED;a Seminario&apos;&apos; de la comuna de Providencia, Santiago, Planes y Programas Especiales de Estudio para tercer a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban Programas de Estudio para los Subsectores de la Formaci&#xF3;n Diferenciada que se se&#xF1;alan en la presente resoluci&#xF3;n.</div><br></div>", "i": 6326587}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de marzo de 2001.- Rafael Andaur Troncoso, Jefe Divisi&#xF3;n Educaci&#xF3;n General (S). </div></div>", "i": 6326588}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "111 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-111 EXENTA"}, {"tipo": "3", "numero": "0111 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-0111 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº01111 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-23", "doble_articulado": false, "id_norma": "182877", "numero_fuente": "36916", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-19", "vigencias": [{"desde": "2001-03-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigen