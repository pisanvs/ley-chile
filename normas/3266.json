{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AGREGA ARTICULO QUE INDICA A ORDENANZA QUE SE&#xD1;ALA N&#xFA;m. 1.005 exento.- Ovalle, Noviembre 20 de 1991.- Vistos: Lo dispuesto en el Art. 43 del D.L. 3.063 de 1979 Rentas Municipales y las facultades que me confiere la Ley 18.695 de 1988 Org&#xE1;nico de Municipalidades.</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 7111655}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Agr&#xE9;gase al Art. 7&#xB0; del Decreto Exento N&#xB0; 80 del 30 de Enero de 1987, Ordenanza de Derechos Municipales, el siguiente N&#xB0; 22:</div><div class=\"p\">&nbsp; &nbsp; &quot;22.- Hora de Estacionamiento en lugares sometidos a restricci&#xF3;n por tiempo limitado, controlado por Tarjetas Parqu&#xED;metro&quot; $80.-</div><br></div>", "i": 7111656}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, comun&#xED;quese, publ&#xED;quese, d&#xE9;se cumplimiento y arch&#xED;vese.- Eugenio Darrigrande Pizarro, Alcalde.- Ester Guti&#xE9;rrez Zepeda, Secretaria Municipal. </div></div>", "i": 7111657}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1005 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1005 EXENTO"}], "organismos": ["MUNICIPALIDAD DE OVALLE"], "titulo_norma": "AGREGA ARTICULO QUE INDICA A ORDENANZA QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDAD OVALLE", "ORDENANZA DERECHOS", "MUNICIPALES", "TARJETAS PARQUIMETRO", "MODIFICACION."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-11-20", "doble_articulado": false, "id_norma": "3266", "numero_fuente": "34129", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-29", "vigencias": [{"desde": "199