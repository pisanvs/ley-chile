{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6526813}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.376, de 5 de mayo de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a AQUAFISH S.A. para iniciar actividades pesqueras extractivas con la nave &quot;Altar 10&quot;, en el &#xE1;rea mar&#xED;tima correspondiente a Isla de Pascua, Isla Sala y G&#xF3;mez, Islas Desventuradas y Archipi&#xE9;lago de Juan Fern&#xE1;ndez, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar, con palangre, los siguientes recursos hidrobiol&#xF3;gicos: At&#xFA;n aleta amarilla, At&#xFA;n aleta larga, At&#xFA;n ojos grandes, Bonito, Tibur&#xF3;n o marrajo, Tollo, Fume, At&#xFA;n de escamas o at&#xFA;n chauchera, Marl&#xED;n rayado, At&#xFA;n aleta azul, Azulejo, Marl&#xED;n trompa corta, Marl&#xED;n negro, Marl&#xED;n azul o zuncho y Cachurreta o Barrilete.</div><br></div>", "i": 6526814}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de mayo de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6526815}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1376 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1376 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-05-05", "fecha_derogacion": "2009-08-28", "doble_articulado": false, "id_norma": "238183", "numero_fuente": "38166", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-05-20", "vigencias": [{"desde": "2009-08-28