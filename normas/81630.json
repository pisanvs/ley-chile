{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 247, DE 1990 </div></div>", "i": 6060286}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 247, de 01 de octubre de 1990, se ha modificado el decreto supremo exento de Educaci&#xF3;n No. 209, de 1988, en el sentido de sustituir los planes de estudio aprobados en su art&#xED;culo 1&#xB0; para la Escuela T&#xE9;cnica &quot;Sagrada Familia&quot;, de Punta Arenas. </div></div>", "i": 6060287}, {"t": "<div><div class=\"p\">Santiago, 17 de Octubre de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6060288}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "247 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-247 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 247, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-10-01", "doble_articulado": false, "id_norma": "81630", "numero_fuente": "33800", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-10-23", "vigencias": [{"desde": "1990-10-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-10-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-10-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1997-12-29", "fecha_version": "1990-10-23", "fecha_actualizacion_texto": "1990-10-23", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructu