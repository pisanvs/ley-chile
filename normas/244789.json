{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 704 EXENTO, DE 2002 </div></div>", "i": 7326006}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 704 de fecha 5 de agosto de 2002, del Ministerio de Educaci&#xF3;n, se deja sin efecto la aprobaci&#xF3;n del plan y programas de estudios de la carrera de Programaci&#xF3;n en Computaci&#xF3;n y An&#xE1;lisis de Sistemas concedida mediante decreto exento de Educaci&#xF3;n N&#xBA; 315 del 26 de noviembre de 1991, para el Centro de Formaci&#xF3;n T&#xE9;cnica Instituto de Capacitaci&#xF3;n Luis Alberto Vera, a petici&#xF3;n de la propia entidad, dado que no registra matr&#xED;cula de alumnos en los &#xFA;ltimos a&#xF1;os. </div></div>", "i": 7326007}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de agosto de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7326008}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "704 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-704 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 704 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-08-05", "doble_articulado": false, "id_norma": "244789", "numero_fuente": "38330", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-12-06", "vigencias": [{"desde": "2005-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-12-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-12-06", "fin_vigencia": "", "tipo_version": "3"}], "ev