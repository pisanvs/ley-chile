{"html": [{"t": "<div><div class=\"p\">APRUEBA REFORMA DE ESTATUTOS DE BOLSA ELECTRONICA DE CHILE, BOLSA DE VALORES </div></div>", "i": 6075882}, {"t": "<div><div class=\"p\">Certifico: Que por Resoluci&#xF3;n Exenta No. 104, de fecha 26 de</div><div class=\"p\">Mayo de 1992, se aprob&#xF3; la reforma de estatutos de la</div><div class=\"p\">entidad denominada Bolsa Electr&#xF3;nica de Chile, Bolsa de</div><div class=\"p\">Valores, que consta de la escritura p&#xFA;blica de 05 de mayo de</div><div class=\"p\">1992, otorgada en la Quinta Notar&#xED;a de Santiago de don</div><div class=\"p\">Patricio Raby Benavente.</div><div class=\"p\">La reforma consiste en aumentar el plazo de duraci&#xF3;n del</div><div class=\"p\">cargo de director de 1 a 2 a&#xF1;os, sustituyendo al efecto el</div><div class=\"p\">art&#xED;culo 29 de los estatutos sociales.</div><br></div>", "i": 6075883}, {"t": "<div><div class=\"p\">Santiago, 26 de mayo de 1992.- Rodrigo O. Costa Aranda, Secretario General.</div><br></div>", "i": 6075884}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "104 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-104 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "APRUEBA REFORMA DE ESTATUTOS DE BOLSA ELECTRONICA DE CHILE,\nBOLSA DE VALORES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-05-26", "doble_articulado": false, "id_norma": "87315", "numero_fuente": "34287", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-06-09", "vigencias": [{"desde": "1992-06-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-06-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-06-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1998-01-30", "fecha_version": "1992-06-09", "fecha_actualizacion_texto": "1992-06-09", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6075882}, {"n": "Artículo", "i": 6075883, "t": 6}, {"n": "Promulgación", "i": 6075884}]}