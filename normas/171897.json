{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 47 EXENTO, DE&nbsp; 2000</div><br><br></div>", "i": 6285697}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 47 de fecha 31 de enero de 2000 del Ministerio de Educaci&#xF3;n, se registran las modificaciones introducidas a los planes y programas de estudios de las carreras de Derecho y de Pedagog&#xED;a en Educaci&#xF3;n Parvularia de la Universidad Mar&#xED;tima de Chile, que fueran aprobadas por las Universidades de Talca y del B&#xED;o-B&#xED;o, en calidad de entidades examinadoras, a contar del per&#xED;odo acad&#xE9;mico 1999 y 2000, respectivamente.</div><br></div>", "i": 6285698}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de febrero de 2000.- Claudio di Gir&#xF3;lamo Carlini, Subsecretario de Educaci&#xF3;n (S). </div></div>", "i": 6285699}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "47 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-47 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 47 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-31", "doble_articulado": false, "id_norma": "171897", "numero_fuente": "36704", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-04", "vigencias": [{"desde": "2000-07-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-07-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_po