{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10128044}, {"t": "<div><div class=\"p\"> </div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta n&#xFA;mero 1.153, de 5 de junio de 2020 de este Servicio, se aprueba resoluci&#xF3;n que modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1146416&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 1.115 de 2 de junio de 2020</a> del Servicio Nacional de Pesca y Acuicultura, que resuelve solicitudes de reemplazo de inscripci&#xF3;n vacante en el Registro Pesquero Artesanal, para la pesquer&#xED;a de Reineta (Brama australis) por motivo que indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n, se publicar&#xE1; en el sitio de dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y la Subsecretar&#xED;a de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10128045}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, a 5 de junio de 2020.- Alicia Gallardo Lagno, Directora Nacional, Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\"> </div><br></div>", "i": 10128046}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1153 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1153 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1771211; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-06-05", "doble_articulado": fals