{"html": [{"t": "<div><div class=\"p\">MODIFICA AP&#xC9;NDICE X DEL CAP&#xCD;TULO III DEL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10130808}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.066, de 11 de junio de 2020, del Director Nacional de Aduanas, se modifica el Ap&#xE9;ndice X del Cap&#xED;tulo III del <a href=\"https://www.leychile.cl/Navegar?idNorma=248540&amp;idParte=&amp;idVersion=\">Compendio de Normas Aduaneras</a> respecto a sus Anexos N&#xBA; 1A, N&#xBA; 2 y N&#xBA; 3.</div><div class=\"p\">&nbsp; &nbsp;  Esta resoluci&#xF3;n entrar&#xE1; en vigencia a partir de su publicaci&#xF3;n en el Diario Oficial.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><br></div>", "i": 10130809}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de junio de 2020.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><div class=\"p\"> </div><br></div>", "i": 10130810}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2066 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2066 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA APÉNDICE X DEL CAPÍTULO III DEL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1774372; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-06-11", "doble_articulado": false, "id_norma": "1146822", "numero_fuente": "42685", "tipo_version": "3", "tipo_version