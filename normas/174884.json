{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6298772}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.708, de 30 de junio de 2000, se expropi&#xF3; el lote de terreno N&#xBA;100-A, superficie 106 M2, rol de aval&#xFA;o 57-4, comuna de Ch&#xE9;pica, para la obra Camino Ch&#xE9;pica - Bif. Teno. Sector Cuesta El Peral -</div><div class=\"p\">Ch&#xE9;pica - Tramo Km. 5.250 a Km. 18.893.22 y se acord&#xF3; precio de la indemnizaci&#xF3;n con su propietario Manuel Mu&#xF1;oz Romero, ascendente a la cantidad de $466.400. </div></div>", "i": 6298773}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6298774}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2708", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2708"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-06-30", "doble_articulado": false, "id_norma": "174884", "numero_fuente": "36754", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-01", "vigencias": [{"desde": "2000-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-09-06", "fecha_version": "2000-09-01", "fecha_actualizacion_texto": "2000-09-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura