{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6504788}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 587 de 20 de octubre de 2004 de Serviu Metropolitano, orden&#xF3; expropiaci&#xF3;n, conforme D.L.</div><div class=\"p\">N&#xBA; 2.186 de 1978, del lote N&#xBA; 109-A correspondiente del inmueble ubicado en Arica N&#xBA; 3540, presunto rol de aval&#xFA;o N&#xBA; 935-31, comuna de Estaci&#xF3;n Central, aparente dominio de Mar&#xED;a Fr. Garc&#xED;a Schneider y otros. Comisi&#xF3;n integrada por peritos Nancy S&#xE1;nchez Sep&#xFA;lveda, Arquitecto, Teresa Sancho Pernas, Arquitecto y Ram&#xF3;n Rovira Baro, Constructor Civil. Seg&#xFA;n informe de 20 de agosto de 2004, fij&#xF3; monto provisional indemnizaci&#xF3;n en $10.580.900.- pagadera al contado.</div><br></div>", "i": 6504789}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6504790}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "587", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-587"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACION DE INMUEBLES QUE INDICA; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-20", "doble_articulado": false, "id_norma": "232434", "numero_fuente": "38011", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-11-15", "vigencias": [{"desde": "2004-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni