{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7291801}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 780, de 22 de abril de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a ENRIQUE HORACIO CABRERA SILVA, para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluci&#xF3;n N&#xBA; 725 de 1994, de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Avenida 21 de Mayo S/N, Pargua, Calbuco, X Regi&#xF3;n, en las l&#xED;neas de proceso que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Cocido: Ostra del Pac&#xED;fico; Fresco-enfriado, Fresco-refrigerado y Congelado: Turbot, Ostra del Pac&#xED;fico, Abal&#xF3;n rojo y Abal&#xF3;n japon&#xE9;s; Conserva: Ostra del Pac&#xED;fico, Abal&#xF3;n rojo y Abal&#xF3;n japon&#xE9;s; Deshidratado: Turbot, Abal&#xF3;n rojo y Abal&#xF3;n japon&#xE9;s. </div></div>", "i": 7291802}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de abril de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7291803}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "780", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-780"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-22", "doble_articulado": false, "id_norma": "198330", "numero_fuente": "37262", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-18", "vigencias": [{"desde": "2002-05-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vige