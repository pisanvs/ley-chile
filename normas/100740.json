{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO RESOLUCIONES QUE INDICA</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 2 exenta.- Talca, 13 de Enero de 1989. Visto: El Decreto Supremo No. 275t80, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes; y la Ley No. 18.696, de 1988; y Teniendo presente: Que la resoluci&#xF3;n No. 37/88 fue publicada en el Diario Oficial el 14 de Septiembre de 1988:</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 6114195}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1&#xB0;.- Dej&#xE1;nse sin efecto las resoluciones exentas N&#xB0;s. 626 de 29.03.88 y 692, de 03.08.88.</div><br></div>", "i": 6114196}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese y comun&#xED;quese.- J. Hern&#xE1;n Poblete Rodr&#xED;guez, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n del Maule.</div><br></div>", "i": 6114197}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "DEJA SIN EFECTO RESOLUCIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-01-13", "doble_articulado": false, "id_norma": "100740", "numero_fuente": "33428", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-07-21", "vigencias": [{"desde": "1989-07-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-07-21",