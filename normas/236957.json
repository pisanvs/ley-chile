{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6521665}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 701, de 16 de marzo de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD COMERCIAL DASAN LIMITADA, para ampliar actividades pesqueras de transformaci&#xF3;n en orden a incorporar a la planta ubicada en Circunvalaci&#xF3;n N&#xBA; 81, sector Cardonal, Puerto Montt, X Regi&#xF3;n, en las l&#xED;neas de proceso de Fresco Enfriado, Fresco Resfrigerado y Congelado, el recurso hidrobiol&#xF3;gico indicado en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6521666}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de marzo de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6521667}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "701 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-701 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-03-16", "doble_articulado": false, "id_norma": "236957", "numero_fuente": "38133", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-04-12", "vigencias": [{"desde": "2005-04-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-04-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-04-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2005-04-12", "fech