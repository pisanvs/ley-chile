{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><br></div>", "i": 7168354}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Modif&#xED;case la glosa del &#xED;tem 165, Cap&#xED;tulo IV del Presupuesto de Obras P&#xFA;blicas, en la siguiente forma:</div><div class=\"p\">&nbsp; &nbsp; Agregar:</div><div class=\"p\">&nbsp; &nbsp; &quot;Chill&#xE1;n (para iniciar la construcci&#xF3;n de la red de aguas lluvias de alcantarillado), $ 200,000 y reducir en igual suma la de trescientos cincuenta mil pesos ($ 350,000) consultada para Quillota.</div><br></div>", "i": 7168355}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a treinta de Diciembre de mil novecientos veintisiete.- Carlos Ib&#xE1;&#xF1;ez del Campo.- Enrique Balmaceda.</div><br></div>", "i": 7168356}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4227", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4227"}], "organismos": ["MINISTERIO DE BIENESTAR SOCIAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1927", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1927-12-30", "doble_articulado": false, "id_norma": "24584", "numero_fuente": "14960", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1927-12-30", "vigencias": [{"desde": "1927-12-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"