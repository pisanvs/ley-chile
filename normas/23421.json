{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Libera de derechos de internacion el monumento obsequiado a la ciudad de Santiago por los alemanes residentes en Chile.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,667.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8856685}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- La Aduana de Valparaiso despachar&#xE1; libre de derechos de internacion el monumento obsequiado por la Colonia Alemana a la ciudad de Santiago. </div></div>", "i": 8856686}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 31 de Julio de 1912.- RAMON BARROS LUCO.- Samule Claro Lastarria.</div><br></div>", "i": 8856687}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2667", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2667"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "Libera de derechos de internacion el monumento;obsequiado a la ciudad de Santiago por los alemanes;residentes en Chile.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHOS INTERNACION", "MONUMENTO", "SANTIAGO", "DONACION", "COLONIA ALEMANA RESIDENTE", "EXENCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-07-31", "doble_articulado": false, "id_norma": "23421", "numero_fuente": "10344", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-08-03", "vigencias": [{"desde": "1912-08-03