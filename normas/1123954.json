{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9955132}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n Ex. N&#xBA; 3.057 de fecha 27/09/2018, conforme al art&#xED;culo 48 y 62 ley 19.880, de Serviu Regi&#xF3;n de la Araucan&#xED;a, se orden&#xF3; la rectificaci&#xF3;n de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1123234&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n Ex. N&#xBA; 2.862 de fecha 6 de septiembre de 2018 de Serviu Araucan&#xED;a</a>, que dispuso la expropiaci&#xF3;n del Lote 142-0, en el sentido que por un error de digitaci&#xF3;n en su resuelvo N&#xBA; 1, se indic&#xF3; lo siguiente: &quot;Superficie aproximada total a expropiar; 259,33 metros cuadrados&quot;, correspondiendo expresar correctamente, total a expropiar; 253,39 metros cuadrados&quot;.- </div></div>", "i": 9955133}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n de la Araucan&#xED;a. </div></div>", "i": 9955134}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3057 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3057 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1476201", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-09-27", "doble_articulado": false, "id_norma": "1123954", "numero_fuente": "42181", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-10-16", "vigencias": [{"desde": "2018-10-16", "hasta": "", "tipo_version": "3", "tipo_version