{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 12, DE 2021, DEL MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES</div></div>", "i": 10291727}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 12, de 3 de marzo de 2021, tomada de raz&#xF3;n por la Contralor&#xED;a General de la Rep&#xFA;blica, se aprob&#xF3; la Modificaci&#xF3;n al Contrato de Prestaci&#xF3;n de los Servicios Complementarios de Administraci&#xF3;n Financiera de los Recursos del Sistema de Transporte P&#xFA;blico de Pasajeros de Santiago, suscrita entre el Ministerio de Transportes y Telecomunicaciones y el Administrador Financiero del Transantiago S.A. Texto &#xED;ntegro de la resoluci&#xF3;n indicada se encuentra en la p&#xE1;gina web www.dtpm.cl.-</div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10291728}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gloria Hutt Hesse, Ministra de Transportes y Telecomunicaciones.</div><br></div>", "i": 10291729}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "12", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-12"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 12, DE 2021, DEL MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2054644", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-03-03", "doble_articulado": false, "id_norma": "1169636", "numero_fuente": "43126", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-12-13", "vigencias": [{"desde": "2021-12-13", "hasta": "