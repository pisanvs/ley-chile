{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; INFORMA SOBRE DESIGNACION DE CARGOS DIRECTIVOS VACANTES </div></div>", "i": 6023436}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Erich Schnake Silva y Jorge Mario Saavedra en representaci&#xF3;n del Partido Por la Democracia, han informado la designaci&#xF3;n en los cargos directivos vacantes que se indican, a las siguientes personas:</div><div class=\"p\">&nbsp; &nbsp; DIRECTIVA CENTRAL Vicepresidentes: Adriana Mu&#xF1;oz D&#xE1;lbora, Jorge Molina Valdivieso.</div><div class=\"p\">&nbsp; &nbsp; Vocales: Octavio jara Wolff, Ricardo Brodsky Baudet, Juan Saavedra Gorriateguy.</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n que se ordena seg&#xFA;n lo dispuesto por el Tribunal Calificador de Elecciones de fecha 27 de Junio de 1988, por resoluci&#xF3;n exenta N&#xB0; 0-733 de 8 de Julio de 1991.</div><br></div>", "i": 6023437}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 8 de Julio de 1991.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director Servicio Electoral.</div><br></div>", "i": 6023438}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "733 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-733 EXENTA"}, {"tipo": "3", "numero": "0-733 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-0-733 EXENTA"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "INFORMA SOBRE DESIGNACION DE CARGOS DIRECTIVOS\nVACANTES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDO POR DEMOCRACIA", "DIRECTIVA CENTRAL", "NOMBRAMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-07-08", "doble_articulado": false, "id_norma": "39261", "numero_fuente": "34018", "tipo_version": "