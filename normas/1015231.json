{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  RECTIFICACI&#xD3;N</div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  La publicaci&#xF3;n del <a href=\"https://www.leychile.cl/Navegar?idNorma=1015230&amp;idParte=0&amp;idVersion=\">decreto N&#xB0; 165, de 1980,</a> que crea la Comisi&#xF3;n Nacional de Facilitaci&#xF3;n del Transporte A&#xE9;reo Internacional, efectuada en la edici&#xF3;n n&#xFA;mero 30.716, del d&#xED;a 16 de Julio de 1980, p&#xE1;gina cuatro, se rectifica en el sentido de que &#xE9;ste pertenece a la Subsecretar&#xED;a de Transportes y no a la Subsecretar&#xED;a de Telecomunicaciones, como equivocadamente aparece en la mencionada publicaci&#xF3;n.</div><br></div>", "i": 8945806}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "135", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-135"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1015231", "numero_fuente": "30719", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1980-07-19", "vigencias": [{"desde": "1980-07-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1980-07-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1980-07-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "RECTIFICACION", "url_part": "rectificacion"}], "ingresado_por": "362", "fecha_ingreso": "2010-07-13", "fecha_version": "1980-07-19", "actuali