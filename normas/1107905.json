{"html": [{"t": "<div><br><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9833895}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.221, de 29 de agosto de 2017, de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n parcial, conforme art&#xED;culo 51 Ley 16.391, de inmueble ubicado en Sitio 16 Santa Olga Manzana C/11, Rol Aval&#xFA;o N&#xBA; 611-17, comuna Constituci&#xF3;n, superficie 16,07 m&#xB2;, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Ver&#xF3;nica Panchilla Silva. Comisi&#xF3;n integrada por peritos Patricio Ulises Dur&#xE1;n Marcos, Arquitecto; Rodrigo Antonio Silva Lazo, Constructor Civil y Pedro Pablo Cruz Weston, Arquitecto, seg&#xFA;n informe de 12 de junio de 2017, fij&#xF3; monto provisional indemnizaci&#xF3;n en $208.910.- pagados al contado.- </div></div>", "i": 9833896}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Omar Guti&#xE9;rrez Mesina, Director Serviu Regi&#xF3;n del Maule. </div><br></div>", "i": 9833897}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3221 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3221 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN VII REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1270048", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-08-29", "doble_articulado": false, "id_norma": "1107905", "numero_fuente": "41861", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-09-15", "vigencias": [{"desde": "2017-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s":