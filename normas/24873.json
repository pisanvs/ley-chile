{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n de gracia a do&#xF1;a Mar&#xED;a Ram&#xED;rez de Avila.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 8277676}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia y por el plazo de diez a&#xF1;os, a do&#xF1;a Mar&#xED;a Ram&#xED;rez de Avila, madre del ex-oficial de la Polic&#xED;a de San Fernando, don Amador Avila, el derecho a disfrutar de una pensi&#xF3;n de dos mil cuatrocientos pesos ($ 2,400) anuales.</div><div class=\"p\">&nbsp; &nbsp; Esta ley empezar&#xE1; a regir desde el 1.o de Enero de 1930.</div><br></div>", "i": 8277677}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veinte de Diciembre de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Enrique Berm&#xFA;dez. </div></div>", "i": 8277678}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4737", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4737"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Concede pensión de gracia a doña María Ramírez de;Avila.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MARIA RAMIREZ DE AVILA", "PENSION POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-12-20", "doble_articulado": false, "id_norma": "24873", "numero_fuente": "15558", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-12-27", "v