{"html": [{"t": "<div><div class=\"p\">PRORROGA PLAZO QUE INDICA </div></div>", "i": 8315832}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 459 de 09 de Marzo de 1990 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por el t&#xE9;rmino de 30 d&#xED;as a contar del 09 de Marzo de 1990, el plazo otorgado por la resoluci&#xF3;n No. 186 de 1990 a don Patricio Javier Ampuero Jim&#xE9;nez, domiciliado en Rosas 230, Constituci&#xF3;n, para publicar el extracto a que se refiere el numeral No. 4 de la resoluci&#xF3;n citada, por haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8315833}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 09 de marzo de 1990.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8315834}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "459", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-459"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "PRORROGA PLAZO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-09", "doble_articulado": false, "id_norma": "84076", "numero_fuente": "33625", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-20", "vigencias": [{"desde": "1990-03-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-03-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-03-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "M