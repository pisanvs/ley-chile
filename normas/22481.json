{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Adquisicion del cuartel municipal de Copiap&#xF3; Lei n&#xFA;m. 1,214.-Santiago, a 1.&#xB0; de Febrero de 1899.- Por cuanto el Congreso Nacional, ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948620}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza al Presidente de la Rep&#xFA;blica para que, de fondos fiscales, invierta hasta la suma de treinta mil ciento noventa i tres pesos en la adquisicion para el Estado del cuartel municipal de Copiap&#xF3;, segun tasacion hecha por la Direccion de Obras P&#xFA;blicas.</div><br><br></div>", "i": 5948621}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C&#xE1;rlos Concha.</div><br></div>", "i": 5948622}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1214", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1214"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "ADQUISICION DEL CUARTEL MUNICIPAL DE COPIAPO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CUARTEL MUNICIPAL", "COPIAPO", "PRESIDENTE REPUBLICA", "INVERSION", "AUTORIZACION", "ADQUISICION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-02-01", "doble_articulado": false, "id_norma": "22481", "numero_fuente": "6217", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-02-02", "vigencias": [{"desde": "1899-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-02-02", 