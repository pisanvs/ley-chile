{"html": [{"t": "<div><div class=\"p\">Correspondencia libre de porte</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Octubre 17 de 1822</div></div>", "i": 10196958}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Toda correspondencia entre el vice-almirante lord Cochrane i los oficiales de la marina, es, i debe tenerse por oficial, libre por tanto de portes de correo. El administrador jeneral de la renta dispondr&#xE1; se devuelvan los portes que hasta aqu&#xED; se hayan cobrado.</div></div>", "i": 10196959}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon de este decreto en la administracion jeneral de dicha renta e ins&#xE9;rtese en la Gaceta Ministerial.-O&apos;Higgins.-Echeverr&#xED;a.</div></div>", "i": 10196960}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Correspondencia libre de porte", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1822-10-17", "doble_articulado": false, "id_norma": "1151908", "numero_fuente": "1822", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1822-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1822-10-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1822-10-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-01-28", "fecha_version": "1822-10-17", "fecha_actualizacion_texto": "2021-01-28", "tipo_tratado": ""}, "alertas": [], "alerta_glob