{"html": [{"t": "<div><div class=\"p\">MODIFICA ORDENANZA QUE INDICA </div></div>", "i": 6148368}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Con fecha 22 de agosto de 1988 la I. Municipalidad de</div><div class=\"p\">Renca dict&#xF3; el Decreto Alcaldicio No. 1.202 que modifica la</div><div class=\"p\">Ordenanza No. 001 de 27 de enero de 1988 sobre derechos</div><div class=\"p\">municipales por permisos, concesiones y servicios</div><div class=\"p\">municipales, s&#xF3;lo en el sentido de que en el T&#xED;tulo III,</div><div class=\"p\">art. 5&#xB0;, letra E), se cambia el derecho a cancelar por el servicio de &quot;0,18% UTM&quot; a &quot;0,18 UTM&quot;.</div><br></div>", "i": 6148369}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - El Alcalde.</div><br></div>", "i": 6148370}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1202", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1202"}], "organismos": ["MUNICIPALIDAD DE RENCA"], "titulo_norma": "MODIFICA ORDENANZA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-22", "doble_articulado": false, "id_norma": "129873", "numero_fuente": "33156", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-08-26", "vigencias": [{"desde": "1988-08-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-08-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-08-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-01-15", "fecha_version": "1988-08-26", "fecha_actualizacion_texto": "198