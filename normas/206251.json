{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6408218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.902, de 19 de diciembre de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA ITATA S.A., para realizar actividades extractivas en aguas internacionales con la nave &quot;Maull&#xED;n I&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2527</div><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CB-2896</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  42,08 m</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 9,02 m</div><div class=\"p\">TRG (Internacional)&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 547,75</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 736,24 m3</div><div class=\"p\">Potencia motor principal&nbsp; &nbsp;  1341,00 hp</div><div class=\"p\">Potencia motor auxiliar&nbsp; &nbsp; &nbsp; 610,00 hp</div><br></div>", "i": 6408219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de diciembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6408220}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2902", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2902"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-19", "d