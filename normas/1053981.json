{"html": [{"t": "<div><br><div class=\"p\">DECLARA &#xC1;REA DE RESTRICCI&#xD3;N DEL SECTOR HIDROGEOL&#xD3;GICO DE APROVECHAMIENTO COM&#xDA;N DENOMINADO CHOAPA BAJO, REGI&#xD3;N DE COQUIMBO</div></div>", "i": 9373116}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n DGA N&#xBA; 41, de fecha 18 de julio de 2013, se ha declarado &#xC1;rea de Restricci&#xF3;n para nuevas extracciones de aguas subterr&#xE1;neas, en el sector hidrogeol&#xF3;gico de aprovechamiento com&#xFA;n denominado Choapa Bajo, Regi&#xF3;n de Coquimbo. Los antecedentes se encuentran disponibles en oficinas de la Direcci&#xF3;n General de Aguas de la Regi&#xF3;n de Coquimbo y en la p&#xE1;gina web de la DGA.- </div></div>", "i": 9373117}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Guillermo Madariaga Meza, Director General de Aguas (S).</div></div>", "i": 9373118}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "41", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-41"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "DIRECCIÓN GENERAL DE AGUAS"], "titulo_norma": "DECLARA ÁREA DE RESTRICCIÓN DEL SECTOR HIDROGEOLÓGICO DE APROVECHAMIENTO COMÚN DENOMINADO CHOAPA BAJO, REGIÓN DE COQUIMBO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-07-18", "doble_articulado": false, "id_norma": "1053981", "numero_fuente": "40649", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-09-02", "vigencias": [{"desde": "2013-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci