{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.343 EXENTA, DE 2013</div></div>", "i": 9352282}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 3.343, de 6 de mayo de 2013, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Sociedad de Capacitaci&#xF3;n Empresarial Limitada (Procompetencias Ltda.)&quot;, RUT 76.045.193-2 contenida en la resoluci&#xF3;n exenta N&#xBA; 7.290 de 2 de agosto de 2010, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.- </div></div>", "i": 9352283}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (PT).</div></div>", "i": 9352284}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3343 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3343 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.343 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-05-06", "doble_articulado": false, "id_norma": "1050989", "numero_fuente": "40558", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-05-14", "vigencias": [{"desde": "2013-05-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-05-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-05-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie