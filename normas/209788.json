{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 4,707</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6422168}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al ex-contramaestre de m&#xE1;quinas de la Armada, don Remigio Pradenas Cisternas, el derecho a gozar de la pensi&#xF3;n de retiro que le corresponde como inv&#xE1;lido absoluto&quot;. </div></div>", "i": 6422169}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, cuatro de Diciembre de mil novecientos veintinueve.- Carlos Iba&#xF1;ez del C.- Carlos O. Fr&#xF6;dden. </div></div>", "i": 6422170}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4707", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4707"}], "organismos": ["MINISTERIO DE MARINA", "SUBSECRETARIA DE MARINA"], "titulo_norma": "LEY NUM. 4707", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-12-04", "doble_articulado": false, "id_norma": "209788", "numero_fuente": "15540", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-12-05", "vigencias": [{"desde": "1929-12-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-12-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1929-12-05", "fin_vigencia": "", "tipo_version": "3"}], 