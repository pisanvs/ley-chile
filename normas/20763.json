{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 238, DE 1992 </div></div>", "i": 5943041}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 238 de fecha 12 de Agosto de 1992 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a la Sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica Propam, para impartir plan y programas de estudio aprobado para la instituci&#xF3;n de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se se&#xF1;ala, a partir del a&#xF1;o 1991:</div><div class=\"p\">&nbsp; &nbsp; -Sede N&#xB0; 6 - Vi&#xF1;a del Mar.</div><div class=\"p\">&nbsp; &nbsp; Carrera : Prevenci&#xF3;n de Riesgos (Decreto Exento N&#xB0; 490/90).</div><div class=\"p\">&nbsp; &nbsp; T&#xED;tulo : T&#xE9;cnico en Prevenci&#xF3;n de Riesgos. </div></div>", "i": 5943042}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 18 de Diciembre de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943043}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "238", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-238"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 238, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA PROPAM", "PLAN ESTUDIOS", "PROGRAMA ESTUDIOS", "PREVENCION RIESGOS", "VI A DEL MAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-08-12", "doble_articulado": false, "id_norma": "20763", "numero_fuente": "34502", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-02-26", "vigencias": [{"desde": "1993-02-26", "hasta": "", "tipo_version": "3", "tipo_versio