{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8316819}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 92, de 23 de Enero de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n No. 1.394, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a do&#xF1;a Carlina del Carmen Pe&#xF1;afiel Lizana, R.U.T. No. 5.745.409-1, domiciliada en la ciudad de Temuco, calle Yulton No. 1450, para desarrollar actividades pesqueras de transformaci&#xF3;n, en orden a reemplazar el apellido &quot;Lizama&quot; por &quot;Lizana&quot;. </div></div>", "i": 8316820}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 23 de Enero de 1990.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8316821}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "92", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-92"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-23", "doble_articulado": false, "id_norma": "84970", "numero_fuente": "33602", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-22", "vigencias": [{"desde": "1990-02-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por":