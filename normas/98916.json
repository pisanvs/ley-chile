{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8329929}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;636, de 5 de mayo de 1998, de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura N&#xBA;95101161 presentada por MARY</div><div class=\"p\">JEANNINE BARNETCHE CRASS&nbsp; para operar un centro de</div><div class=\"p\">cultivo ubicado en Sector Sur de la Isla Tenglo, al Este</div><div class=\"p\">de Punta Codina, comuna de Puerto Montt, provincia de</div><div class=\"p\">Llanquihue,&nbsp; X Regi&#xF3;n, conforme lo dispuesto en el</div><div class=\"p\">art&#xED;culo 14 del D.S. N&#xBA;290 de 1993 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8329930}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de mayo de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8329931}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "636", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-636"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "PUERTO MONTT", "MARY JEANNINE BARNETCHE CRASS", "DECIMA REGION", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-05-05", "doble_articulado": false, "id_norma": "98916", "numero_fuente": "36063", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-05-13", "vige