{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9252214}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 488, de 24 de febrero de 2012, de esta Subsecretar&#xED;a, autor&#xED;zase al PARQUE METROPOLITANO DE SANTIAGO, para colectar, en el plazo de 1 a&#xF1;o contado desde la fecha de la presente resoluci&#xF3;n, 25 huevos de la especie Ping&#xFC;ino de Humboldt (Spheniscus humboldti), en el Santuario de la Naturaleza &quot;Islote P&#xE1;jaros Ni&#xF1;os&quot;, de Algarrobo, Regi&#xF3;n de Valpara&#xED;so, en la forma y condiciones se&#xF1;aladas en la resoluci&#xF3;n extractada.</div><br><div class=\"p\">&nbsp; &nbsp;  El solicitante designa como persona responsable de esta autorizaci&#xF3;n a Mauricio Fabry Otte.</div></div>", "i": 9252215}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de febrero de 2012.- Maximiliano Alarma Carrasco, Subsecretario de Pesca (S).</div></div>", "i": 9252216}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "488", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-488"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-02-24", "doble_articulado": false, "id_norma": "1039369", "numero_fuente": "40246", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-04-25", "vigencias": [{"desde": "2012-04-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-04-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012