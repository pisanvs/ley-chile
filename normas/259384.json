{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 735 EXENTO, DE 2003 </div></div>", "i": 7338218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 735, de fecha 22 de septiembre de 2003, de Educaci&#xF3;n, se declara aprobada a la Universidad Miguel de Cervantes la modificaci&#xF3;n al Plan y a los Programas de estudio de la carrera de Derecho, a contar del primer semestre del a&#xF1;o 2004. Dicha carrera se imparte en jornada diurna y vespertina en su sede de Santiago.</div><br></div>", "i": 7338219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de octubre de 2003.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 7338220}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "735 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-735 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 735 EXENTO, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-09-22", "doble_articulado": false, "id_norma": "259384", "numero_fuente": "38723", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-03-26", "vigencias": [{"desde": "2007-03-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-03-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-03-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2007-03-26", "fecha_version": "2007-03-26", "fecha_actualizacion_texto": "2007-03-26", "tipo_tratado": ""