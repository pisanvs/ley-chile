{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 56, DE 1986 </div></div>", "i": 7265729}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 317, de 03 de Abril de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n No. 56, de 1986, de la misma Subsecretar&#xED;a, que autoriz&#xF3; a Enpromar y Compa&#xF1;&#xED;a Limitado, para instalar y operar una planta de congelado de recursos hidrobiol&#xF3;gicos en camino Cementerio s/n, Comuna de Puerto Varas, en orden a incluir en el numeral 3&#xB0; la especie loco, para ser utilizado como materia prima en la planta se&#xF1;alada.</div><br></div>", "i": 7265730}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 03 de Abril de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7265731}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "317", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-317"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 56, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-04-03", "doble_articulado": false, "id_norma": "161823", "numero_fuente": "32449", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-04-17", "vigencias": [{"desde": "1986-04-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-04-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-04-17", "fin_vigencia": "", "tipo_version": "