{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6385269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;588, de 28 de marzo del 2002, se expropi&#xF3; el lote de terreno N&#xBA;29-3, superficie 451 m2, rol de aval&#xFA;o 36-3, comuna de Romeral, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: Santiago Talca Sector L: Km. 179.500,00 al 192.900,00, S&#xE9;ptima Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Pablo Adolfo Maturana Aspillaga, ascendente a la cantidad de $4.093.500.- para el lote N&#xBA;29-3. </div></div>", "i": 6385270}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6385271}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "588", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-588"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-28", "doble_articulado": false, "id_norma": "199284", "numero_fuente": "37284", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-15", "vigencias": [{"desde": "2002-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PSO", "fecha_ingreso": "2002-06-17", "fecha_version": "2002-06-15", "fecha_actualizacion_texto": "2002-06-15", "tipo_tratado": ""}, "alertas": [], "alerta_g