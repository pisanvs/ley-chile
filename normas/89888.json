{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A FEDERACION PROVINCIAL SOLIDARIDAD CAMPESINA &#xD1;UBLE </div></div>", "i": 6084003}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional del Servicio de Impuestos Internos, por Resoluci&#xF3;n DRE08/N&#xBA; Ex-1.016 de fecha 23 de diciembre de 1997, ha procedido a revocar a solicitud de la Federaci&#xF3;n Provincial Solidaridad Campesina &#xD1;uble, Rut. N&#xBA; 72.407.100-7, su calidad de Agente Retenedor del Impuesto al Valor Agregado por la Compra Legumbres, de acuerdo a lo dispuesto en el dispositivo N&#xBA; 14, de la Resoluci&#xF3;n N&#xBA; Ex-5380/97, la que regir&#xE1; a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n.</div><br></div>", "i": 6084004}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Saluda a Ud., Mario Ruiz Paredes, Director Regional (S).</div><br></div>", "i": 6084005}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1016 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1016 EXENTA"}, {"tipo": "3", "numero": "DRE-08-1016 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-1016 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A FEDERACION PROVINCIAL SOLIDARIDAD CAMPESINA ÑUBLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "FEDERACION PROVINCIAL SOLIDARIDAD CAMPESINA UBLE", "LEGUMBRES", "REVOCACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-23", "doble_articulado": false, "id