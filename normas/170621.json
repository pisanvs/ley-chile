{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6281131}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4 de 11 de enero de 1988, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Primera Regi&#xF3;n se autoriza a don Juan Roberto Colville Garrido, para efectuar las revisiones t&#xE9;cnicas de los veh&#xED;culos de transporte de personas de m&#xE1;s de nueve (9) asientos, incluido el del conductor; de veh&#xED;culos motorizados de carga con capacidad para transportar m&#xE1;s de 1.750 kilos, sus remolques y semirremolques y los taxis, en el establecimiento ubicado en calle Sotomayor N&#xBA; 2080 de la ciudad de Iquique.-</div><br></div>", "i": 6281132}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Eliecer Aedo Rivera, Secretario Regional Ministerial Transportes y Telecomunicaciones, I Regi&#xF3;n Tarapac&#xE1;.</div><br></div>", "i": 6281133}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-11", "doble_articulado": false, "id_norma": "170621", "numero_fuente": "32972", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-01-18", "vigencias": [{"desde": "1988-01-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-01-18", "fin_vige