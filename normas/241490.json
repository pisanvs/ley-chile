{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6538369}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 713, de fecha 29 de julio de 2005, se expropi&#xF3; el lote de terreno N&#xBA; 1, superficie 3.161 m&#xB2;, Rol N&#xBA; 608-30, comuna de San Ignacio, VIII Regi&#xF3;n para la obra &quot;Laja - Diguill&#xED;n, Canal Alimentador N&#xFA;mero 6 Km. 0,008 a Km. 0,705&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Rafael de la Cruz Aedo Aedo y otros, ascendente a la cantidad de $2.750.804 para el lote N&#xBA; 1.</div><br></div>", "i": 6538370}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6538371}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "713 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-713 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-07-29", "doble_articulado": false, "id_norma": "241490", "numero_fuente": "38251", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-09-01", "vigencias": [{"desde": "2005-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2005-09-01", "fecha_version": "2005-09-01", "fecha_actualizacion_texto": "2005-09-01", "tipo_tratado": ""}, "aler