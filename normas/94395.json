{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6096947}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 685, de 25 de Julio de 1989, de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL 2186 de 1978, parte inmueble ubicado en calle Nataniel Cox No. 541, presunto rol aval&#xFA;os 641-12 comuna Santiago, aparentemente dominio de do&#xF1;a Carmen Jaure Aguilar. Comisi&#xF3;n integrada por peritos Sres; Gabriel Urrutia Benavente y Mario Vergara Navarrete, arquitectos y Walter Soto Silva, ingeniero civil, seg&#xFA;n informe de 24 de Noviembre de 1988, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 1.953.245, pagadera al contado.</div><br></div>", "i": 6096948}, {"t": "<div><div class=\"p\">Director SERVIU Metropolitano.</div><br></div>", "i": 6096949}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "685", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-685"}], "organismos": ["SERVICIO DE VIVIENDA Y URBANIZACIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-07-25", "doble_articulado": false, "id_norma": "94395", "numero_fuente": "33449", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-08-16", "vigencias": [{"desde": "1989-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1998-03-06", "fecha_version": "1989-08-16", "fecha_actualizacion_texto": "1989-