{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6410472}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n, que suscribe, certifica que la carrera de &quot;Comunicaci&#xF3;n Social&quot; conducente al t&#xED;tulo profesional de &quot;Comunicador Social&quot; con menci&#xF3;n en &quot;Relaciones P&#xFA;blicas&quot; que ofrece el Instituto Profesional &quot;Academia de Idiomas y Estudios Profesionales AIEP&quot;, autorizada seg&#xFA;n certificado N&#xBA; 177 de fecha 22 de Febrero de 1990, ha sido modificada en lo que respecta al r&#xE9;gimen curricular de semestral a anual.</div><div class=\"p\">&nbsp; &nbsp;  La carrera en comento, podr&#xE1; impartirse a contar del a&#xF1;o 1991, con la modificaci&#xF3;n aprobada. </div></div>", "i": 6410473}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de Enero de 1991.</div><div class=\"p\">&nbsp; &nbsp;  RAUL ALLARD NEUMANN Subsecretario de Educaci&#xF3;n </div></div>", "i": 6410474}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-31", "doble_articulado": false, "id_norma": "206802", "numero_fuente": "33899", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-02-20", "vigencias": [{"desde": "1991-02-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-02-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci