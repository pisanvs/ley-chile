{"html": [{"t": "<div><br><div class=\"p\">TASACI&#xD3;N DE INMUEBLE EXPROPIADO</div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9275274}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.560 de 22 diciembre 2011 rectifico <a href=\"https://www.leychile.cl/Navegar?idNorma=1032416&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.906, de 3 de noviembre de 2011</a>, ambas de Serviu Regi&#xF3;n del Maule, en el sentido de que la tasaci&#xF3;n del inmueble expropiado ubicado en Blanco 1380, Rol Aval&#xFA;o N&#xBA; 27-6, comuna Constituci&#xF3;n, propietario aparente Quiroz Munoz Olga Alicia, fue corregida por comisi&#xF3;n de peritos con fecha 15 diciembre 2011, fijando monto provisional indemnizaci&#xF3;n en $19.300.000.- pagados al contado.- Clarisa Ayala Arenas, </div><br></div>", "i": 9275275}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Directora Serviu Regi&#xF3;n del Maule.</div></div>", "i": 9275276}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4560 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4560 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN VII REGIÓN DEL MAULE"], "titulo_norma": "TASACIÓN DE INMUEBLE EXPROPIADO; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-12-22", "doble_articulado": false, "id_norma": "1041805", "numero_fuente": "40313", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-07-17", "vigencias": [{"desde": "2012-07-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic