{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6540352}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 837 de fecha 30 de agosto de 2005, se expropi&#xF3; el lote de terreno N&#xBA; 3, superficie 341 m&#xB2;, rol N&#xBA; 142-019, comuna de Huasco, para la obra &quot;Construcci&#xF3;n Camino Costero, Tramo Huasco-Carrizal, provincia de Huasco, Regi&#xF3;n de Atacama, Etapa I&quot;, III Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Santiago Israel Rojas Gonz&#xE1;lez, ascendente a la cantidad de $878.172. </div></div>", "i": 6540353}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6540354}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "837 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-837 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-08-30", "doble_articulado": false, "id_norma": "242077", "numero_fuente": "38263", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-09-15", "vigencias": [{"desde": "2005-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-09-15", "fecha_version": "2005-09-15", "fecha_actualizacion_texto": "2005-09-15", "tipo_tratado": ""}, "a