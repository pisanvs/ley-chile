{"html": [{"t": "<div><div class=\"p\">MODIFICASE LA RESOLUCION (M) N&#xBA; 1.980 DE 1996 </div></div>", "i": 7211257}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante Resoluci&#xF3;n N&#xBA; 1.239, de fecha 25 de julio de 1997, de esta Subsecretar&#xED;a de Marina del Ministerio de Defensa Nacional, se resolvi&#xF3;:</div><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case la Resoluci&#xF3;n (M) N&#xBA; 1.980, de fecha 30 de diciembre de 1996, que otorg&#xF3; concesi&#xF3;n de acuicultura a Granja Marina Chauquear Limitada, en el sentido que se reemplaza en los vistos, numeral 1, letra f), y en el p&#xE1;rrafo 4.-, el guarismo &quot;986&quot;, por &quot;968&quot;. </div></div>", "i": 7211258}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de septiembre de 1997.- Pablo Cabrera Gaete, Subsecretario de Marina.</div><br></div>", "i": 7211259}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1239", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1239"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "MODIFICASE LA RESOLUCION (M) Nº 1.980 DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "MODIFICACION", "GRANJA MARINA CHAUQUEAR LIMITADA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-25", "doble_articulado": false, "id_norma": "76359", "numero_fuente": "35893", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-10-17", "vigencias": [{"desde": "1997-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-10-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-1