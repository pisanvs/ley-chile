{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA; 79, DE 1985 </div></div>", "i": 6258126}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 79, de 14 de Mayo de 1985, se ha procedido a aprobar los programas de estudio de las asignaturas de Dactilograf&#xED;a y de Digitaci&#xF3;n al Instituto de la Sordera.</div><div class=\"p\">&nbsp; &nbsp;  Los programas aprobados se aplicar&#xE1;n con car&#xE1;cter de experimental, por un per&#xED;odo de tres a&#xF1;os a contar del a&#xF1;o 1985.</div><div class=\"p\">&nbsp; &nbsp;  Las situaciones no previstas ser&#xE1;n resueltas por la Direcci&#xF3;n de Educaci&#xF3;n Primaria y Normal.</div><br></div>", "i": 6258127}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de Mayo de 1985.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6258128}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "79 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-79 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº 79, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-14", "doble_articulado": false, "id_norma": "163341", "numero_fuente": "32206", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-26", "vigencias": [{"desde": "1985-06-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-06-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-06-26", "fin_vigencia": "", "tipo_version": "3"}], "