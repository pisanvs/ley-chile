{"html": [{"t": "<div><div class=\"p\">EXTRACTO&nbsp; DE&nbsp; DECRETO&nbsp; N&#xBA; 451 EXENTO, DE 1999</div><br></div>", "i": 6252628}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 451 de 29 de diciembre de 1999, se ha aprobado al &apos;&apos;Campvs College&apos;&apos; comuna de Providencia, de Santiago, un plan de estudio para 6&#xBA; a&#xF1;o (NB.4) de Ense&#xF1;anza B&#xE1;sica el que se aplicar&#xE1; a contar del a&#xF1;o escolar 2000.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en el presente decreto. </div></div>", "i": 6252629}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de febrero de 2000.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6252630}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "451 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-451 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 451 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-29", "doble_articulado": false, "id_norma": "161574", "numero_fuente": "36618", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-20", "vigencias": [{"desde": "2000-03-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fe