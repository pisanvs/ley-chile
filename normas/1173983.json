{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10319786}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xB0; 132 de 2 febrero 2022, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos relativas a la actividad denominada &quot;Feria Campesina y de Artesan&#xED;a, en la ciudad de Ays&#xE9;n&quot;, y autoriz&#xF3; a la Municipalidad de Ays&#xE9;n para realizar la siguiente intervenci&#xF3;n en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - Corte total de v&#xED;a en calle Moraleda, entre calles Eusebio Ibar y Nalcayec, de la ciudad de Ays&#xE9;n, el d&#xED;a viernes 4 de febrero de 2022, desde las 08:00 hrs. hasta las 15:00 hrs.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10319787}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andrea Mac&#xED;as Palma, Gobernadora Regional.- Javier Gonz&#xE1;lez Jara, Asesor Jur&#xED;dico.</div><br></div>", "i": 10319788}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "132 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-132 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2102051"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-02-02", "doble_articulado": false, "id_norma": "1173983", "numero_fuente": "43209", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-03-22", "vigencias": [{"desde": "2022-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig