{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6083272}, {"t": "<div><div class=\"p\">El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 11,73% anual durante el mes de abril de 1990.</div><div class=\"p\">Asimismo, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de abril de 1990, fue de 10,87% anual.</div><br></div>", "i": 6083273}, {"t": "<div><div class=\"p\">Santiago, 04 de mayo de 1990.- V&#xED;ctor Vial del R&#xED;o, Secretario General Interino.</div><br></div>", "i": 6083274}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["ESTA NORMA NO TIENE TITULO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-05-04", "doble_articulado": false, "id_norma": "89634", "numero_fuente": "33662", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-05-05", "vigencias": [{"desde": "1990-05-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-05-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-05-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1998-02-1