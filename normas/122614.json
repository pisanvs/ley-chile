{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8332803}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.026, de 27 de julio de 1998, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las resoluciones N&#xBA; 1.302, N&#xBA; 1.303 y N&#xBA; 1.304, todas de 1992, N&#xBA; 1.106 y N&#xBA; 1.107, ambas de 1993, N&#xBA; 271, N&#xBA; 272, N&#xBA; 278, N&#xBA; 280, N&#xBA; 1.764, N&#xBA; 1.765, N&#xBA; 1.766, N&#xBA; 1.767, N&#xBA; 1.768, N&#xBA; 1.769, N&#xBA; 1.770, N&#xBA; 1.771, N&#xBA; 1.772, todas de 1995 y N&#xBA; 2.250 de 1996, de esta Subsecretar&#xED;a, que concedieron permisos extraordinarios de pesca sobre el recurso Bacalao de profundidad a PESQUERA MAR DEL SUR S.A.</div><br></div>", "i": 8332804}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de julio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8332805}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1026", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1026"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA MAR DEL SUR S.A.", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-27", "doble_articulado": false, "id_norma": "122614", "numero_fuente": "36130", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-08-03", "vigencias": [{"desde": "1998-08-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-08-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vi