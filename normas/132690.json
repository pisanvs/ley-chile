{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6156888}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n</div><div class=\"p\">exenta No. 2.357 de 10 de Noviembre de 1987, conforme</div><div class=\"p\">Art. 5&#xB0; Transitorio C&#xF3;digo Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a Sector Excluido y Sector Expropiado predio &quot;Parte del Fundo Las Piedras o San Jos&#xE9; de Marga Marga&quot; de la comuna de Quilpu&#xE9;, y Regi&#xF3;n. Los derechos de aguas se extraen de las aguas de la Quebrada El Carrizo que escurren al Embalse El Carrizo entre el 01 de Mayo y el 31 de Agosto de cada a&#xF1;o y Aguas del Embalse La Sepultura. Publicaci&#xF3;n hecha conforme Art. 13 Ley No.</div><div class=\"p\">18.377.-</div><br></div>", "i": 6156889}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6156890}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2357 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2357 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-10", "doble_articulado": false, "id_norma": "132690", "numero_fuente": "33036", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-04-04", "vigencias": [{"desde": "1988-04-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-04-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-04-04", "f