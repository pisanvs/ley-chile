{"html": [{"t": "<div><div class=\"p\">AUTORIZA EXCEPCION REGIMEN CAMBIO SUJETO DEL IVA </div></div>", "i": 6439822}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional Concepci&#xF3;n, del S.I.I., por resoluci&#xF3;n DRE08/N&#xBA; Ex-1710, de fecha 22 de agosto de 2003, excepciona, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, a Industria de Acero Manufacturado Ltda., RUT. N&#xBA;86.752.500-9, del r&#xE9;gimen de Cambio de Sujeto de IVA, en las ventas de Chatarra, establecido en la resoluci&#xF3;n Ex-N&#xBA; 07 de 28-01-2003 de la Direcci&#xF3;n Nacional. Consecuencialmente el (la) peticionario (a) excepcionado (a) pasa a tener la calidad de agente retenedor del Impuesto al Valor Agregado en sus operaciones de compras de Chatarra.</div><br></div>", "i": 6439823}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 22 de agosto de 2003.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6439824}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1710 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1710 EXENTA"}, {"tipo": "3", "numero": "DRE-08-1710 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-1710 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "AUTORIZA EXCEPCION REGIMEN CAMBIO SUJETO DEL IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-22", "doble_articulado": false, "id_norma": "214649", "numero_fuente": "37659", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2