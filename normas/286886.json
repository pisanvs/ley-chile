{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A SUPERMERCADOS SAN FRANCISCO S.A.</div><br></div>", "i": 6986454}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n de Grandes Contribuyentes del SII, por resoluci&#xF3;n N&#xBA; Ex. 3, de fecha 26 enero 2009, otorga a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, a Supermercados San Francisco S.A., RUT N&#xBA; 78.722.910-7, la calidad de Agente Retenedor del Impuesto al Valor Agregado en las compras de especies hidrobiol&#xF3;gicas que efect&#xFA;e, conforme lo establecido en la resoluci&#xF3;n Ex. N&#xBA; 3.311, de 30/06/2000, de la Direcci&#xF3;n Nacional del Servicio de Impuestos Internos. </div></div>", "i": 6986455}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Bernardo Marchant &#xC1;guila, Director de Grandes Contribuyentes.</div><br></div>", "i": 6986456}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN DE GRANDES CONTRIBUYENTES"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A\nSUPERMERCADOS SAN FRANCISCO S.A", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-01-26", "doble_articulado": false, "id_norma": "286886", "numero_fuente": "39278", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-02-03", "vigencias": [{"desde": "2009-02-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-02-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v