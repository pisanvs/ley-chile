{"html": [{"t": "<div><div class=\"p\"> </div><div class=\"p\">OTORGAMIENTO CONCESI&#xD3;N MAR&#xCD;TIMA MENOR</div></div>", "i": 10204712}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Decreto supremo N&#xB0; 73 de fecha 25 febrero 2020, del MINDEF, Subsecretar&#xED;a Fuerzas Armadas, otorg&#xF3; a Inmobiliaria Lomas del Alto Ltda., Rut 96.673.110-9, Concesi&#xF3;n Mar&#xED;tima menor, con vencimiento 31 diciembre 2024, sobre sector playa y fondo de lago, en sector Carmelito, km 4 camino Puc&#xF3;n Villarrica, lago Villarrica, comuna Puc&#xF3;n, provincia Caut&#xED;n, Regi&#xF3;n Araucan&#xED;a. Superficies otorgadas: Sector Playa 240.28 m&#xB2; y Sector Fondo de Lago 377.59 m&#xB2;, tramitada con SIABC 35.787. El objeto es amparar instalaci&#xF3;n de rampa de carga y descarga embarcaciones e instalaci&#xF3;n D&#xE1;rsena abrigo embarcaciones menores deportivas hasta 25 TRG. Antecedentes disponibles Capitan&#xED;a Puerto Lago Villarrica.- </div><br></div>", "i": 10204713}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  H&#xE9;ctor Rojas Mart&#xED;n, Capit&#xE1;n de Corbeta LT, Capit&#xE1;n de Puerto Lago Villarrica.</div></div>", "i": 10204714}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "73", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-73"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE"], "titulo_norma": "OTORGAMIENTO CONCESIÓN MARÍTIMA MENOR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1894215", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-02-25", "doble_articulado": false, "id_norma": "1155912", "numero_fuente":