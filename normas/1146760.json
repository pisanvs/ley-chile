{"html": [{"t": "<div><br><br><div class=\"p\">BALMACEDA</div><br><div class=\"p\">&#xFEFF;&nbsp; &nbsp;  Santiago, 15 de enero de 1887.</div><br><div class=\"p\">&nbsp; &nbsp;  Vistas las comunicaciones adjuntas, de las cuales aparece, que el c&#xF3;lera asi&#xE1;tico se ha declarado en varios puntos de los departamentos de Quillota i de los Andes, en uso de la facultad que confiere al Presidente de la Rep&#xFA;blica el art&#xED;culo 6.&#xB0; de la lei de 30 de diciembre &#xFA;ltimo i con acuerdo del Senado,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div></div>", "i": 10151399}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Decl&#xE1;ranse infestados de c&#xF3;lera asi&#xE1;tica los departamentos de Quillota i de los Andes.</div></div>", "i": 10151400}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese i publ&#xED;quese.</div><br><div class=\"p\">&nbsp; &nbsp;  BALMACEDA.</div><br><div class=\"p\">&nbsp; &nbsp;  C&#xC1;RLOS ANT&#xDA;NEZ.</div></div>", "i": 10151401}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE LO INTERIOR"], "titulo_norma": "BALMACEDA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1887-01-17", "doble_articulado": false, "id_norma": "1146760", "numero_fuente": "2009", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1887-01-15", "vigencias": [{"desde": "1887-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1887-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1887-