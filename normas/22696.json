{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que incorpora en el Ej&#xE9;rcito, en el empleo de sarjento mayor, a don Alfreso Schonnemayer</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 12 de Diciembre de 1901.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949323}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que, sin aumentar la dotacion de planta, incorpore en el Ej&#xE9;rcito, en el empleo de sarjento mayor de infanter&#xED;a, a don Alfredo Schonnemayer.</div><br></div>", "i": 5949324}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de Rep&#xFA;blica.- JERMAN RIESCO.- Beltran Mathieu.</div><br></div>", "i": 5949325}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1498", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1498"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "QUE INCORPORA EN EL EJERCITO, EN EL EMPLEO DE SARJENTO MAYOR A DON ALFRESO SCHONNEMAYER", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ALFREDO SCHONNEMAYER", "EJERCITO CHILE", "INCORPORACION", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-12-12", "doble_articulado": false, "id_norma": "22696", "numero_fuente": "7095", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-12-12", "vigencias": [{"desde": "1901-12-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}],