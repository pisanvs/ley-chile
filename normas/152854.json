{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6224451}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 81, de 14 de Julio de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la XII Regi&#xF3;n, Magallanes y Ant&#xE1;rtica Chilena, se autoriza a don Rigoberto Hern&#xE1;n Villablanca D&#xED;az para efectuar el servicio de taxi colectivo urbano, cumpliendo el siguiente recorrido:</div><br><div class=\"p\">LINEA No. 18</div><br><div class=\"p\">Ida: R&#xF3;mulo Correa frente a Edificios EMPART - Se&#xF1;oret Maip&#xFA; - Chilo&#xE9; - Paraguaya - 21 de Mayo - frente ex - Pesquera CEPREL. Regreso: Frente ex - Pesquera CEPREL - 21 de Mayo - Magallanes - Diagonal Don Bosco Avda. Bulnes - R&#xF3;mulo Correa frente Edificios EMPART Plazoleta.</div><br></div>", "i": 6224452}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jos&#xE9; Urbano Peralta, Secretario Regional Ministerial XII Regi&#xF3;n.</div><br></div>", "i": 6224453}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "81 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-81 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XII REGIÓN DE MAGALLANES Y ANTÁRTICA CHILENA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-07-14", "doble_articulado": false, "id_norma": "152854", "numero_fuente": "32527", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-07-21", "vigencias": [{"desde": "1986-07-21", "hast