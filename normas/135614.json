{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,617.- Santiago, 30 de setiembre de 1903.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6166001}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados al pais por el ex-Intendente Jeneral del Ej&#xE9;rcito i Armada, jubilado, don Juan de Dios Merino Benavente, se le declaran de abono los cuatro a&#xF1;os siete meses que necesita para jubilar con el sueldo &#xED;ntegro de su empleo.</div><br></div>", "i": 6166002}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- C&#xE1;rlos Besa.</div><br></div>", "i": 6166003}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1617", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1617"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1903-09-30", "doble_articulado": false, "id_norma": "135614", "numero_fuente": "7718", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1903-10-03", "vigencias": [{"desde": "1903-10-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1903-10-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1903-10-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fec