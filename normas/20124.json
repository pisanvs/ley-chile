{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 93 EXENTO, DE 1994 </div></div>", "i": 7160469}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 93, de fecha 4 de Marzo de 1994 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a la Sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica &quot;Centro Nacional de Estudios Param&#xE9;dicos PROPAM&quot;, para impartir plan y programa de estudios aprobado para la instituci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se se&#xF1;ala, a partir del a&#xF1;o 1994:</div><div class=\"p\">&nbsp; &nbsp; Sede N&#xB0; 11 - Temuco.</div><div class=\"p\">Carrera : T&#xE9;cnico en Farmacia (Resoluci&#xF3;n Exenta N&#xB0;</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  2871 de 1988).</div><div class=\"p\"> T&#xED;tulo&nbsp; : T&#xE9;cnico en Farmacia.</div><br></div>", "i": 7160470}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160471}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "93 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-93 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 93 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORAMACION TECNICA", "PLANES ESTUDIOS", "CENTRO", "NACIONAL ESTUDIOS PARAMEDICOS PROPAM", "PROGRAMAS", "ESTUDIOS", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-04", "doble_articulado": false, "id_norma": "20124", "numero_fuente": "34926", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-07-28",