{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,076.- Santiago, 7 de setiembre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6161517}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Filomena i do&#xF1;a Rosa Fierro Beit&#xED;a, hijas del teniente-coronel de la Independencia, don Francisco J. Fierro, el goce de la pension de montep&#xED;o correspondiente al empleo de coronel, en vez de la de teniente-coronel que actualmente perciben.</div><br></div>", "i": 6161518}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- V. Blanco </div></div>", "i": 6161519}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1076", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1076"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-09-07", "doble_articulado": false, "id_norma": "134164", "numero_fuente": "6099", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-09-12", "vigencias": [{"desde": "1898-09-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-09-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-09-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "