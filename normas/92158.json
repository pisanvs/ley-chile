{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 20, DE 1989 </div></div>", "i": 7226741}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 20 de fecha 28 de Febrero de 1989, la Secretar&#xED;a Ministerial de Educaci&#xF3;n de la Regi&#xF3;n de Antofagasta, ha aprobado Planes y Programas de Estudio de 1&#xB0; a 4&#xB0; A&#xF1;o de Educaci&#xF3;n Media T&#xE9;cnico Profesional para el Liceo Polit&#xE9;cnico C No. 3 &quot;Diego Portales Palazuelos&quot; de Tocopilla.</div><div class=\"p\">En las Especialidades de:</div><br><div class=\"p\">- Extracci&#xF3;n Pesquera.</div><div class=\"p\">- Industrializaci&#xF3;n de Productos del Mar.</div><br><div class=\"p\">Los Planes y Programas aprobados tendr&#xE1;n vigencia a contar del a&#xF1;o 1989 y hasta el a&#xF1;o 1996.-</div><br></div>", "i": 7226742}, {"t": "<div><div class=\"p\">Luis Humberto Alvear L&#xF3;pez, Secretario Ministerial de Educaci&#xF3;n II Regi&#xF3;n - Antofagasta.</div><br></div>", "i": 7226743}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "20 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-20 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N°  20, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-02-28", "doble_articulado": false, "id_norma": "92158", "numero_fuente": "33376", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-05-19", "vigencias": [{"desde": "1989-05-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-05-19", "fin_vigen