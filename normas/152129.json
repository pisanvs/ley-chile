{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6222193}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 1496 de 12 de Agosto de 1987, conforme art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas que corresponden a parcelas N&#xB0;s. 2, 4, 5 y 6, sitios N&#xB0;s. 7 al 10 del Proyecto de Parcelaci&#xF3;n &quot;Santa Adriana&quot; formado por sector efectivamente expropiado del Predio &quot;Fundo Santa Adriana antes Hijuela Segunda del Fundo Trapiche Bajo&quot;, de la Comuna de Sagrada Familia, VII Regi&#xF3;n. Los derechos de agua se extraen del Estero Pirihu&#xED;n por Canal Comunidad Trapiche.</div><div class=\"p\">Publicaci&#xF3;n hecha conforme art. 13 Ley No. 18.377.- </div></div>", "i": 6222194}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6222195}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1496 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1496 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-12", "doble_articulado": false, "id_norma": "152129", "numero_fuente": "32847", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-17", "vigencias": [{"desde": "1987-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-08-17", "fin_vigencia": ""}, "vigencias_versi