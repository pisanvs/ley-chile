{"html": [{"t": "<div><div class=\"p\">AUTORIZA A LA SOCIEDAD PESQUERA GALEB LTDA. PARA DESARROLLAR ACTIVIDADES PESQUERAS</div><br><br><br></div>", "i": 7269502}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 145, de 4 de Mayo de 1981, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a la &quot;Sociedad Pesquera Galeb Ltda.&quot;, domiciliada en Antofagasta, para desarrollar actividades pesqueras en la forma y condiciones que en dicha resoluci&#xF3;n se establecen. La interesada podr&#xE1; operar la embarcaci&#xF3;n &quot;Punta San Pedro&quot;, en el litoral comprendido entre los paralelos 22&#xBA; y 26&#xBA; de latitud sur, en la captura de anchoa, bonito, caballa, cojinova, jurel y sardina espa&#xF1;ola.- </div></div>", "i": 7269503}, {"t": "<div><div class=\"p\">Roberto Verdugo Gormaz, Subsecretario de Pesca. </div></div>", "i": 7269504}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "145", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-145"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A LA SOCIEDAD PESQUERA GALEB LTDA. PARA\nDESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1981-05-04", "fecha_derogacion": "2001-06-21", "doble_articulado": false, "id_norma": "168208", "numero_fuente": "33376", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1981-05-19", "vigencias": [{"desde": "2001-06-21", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1981-05