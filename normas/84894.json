{"html": [{"t": "<div><div class=\"p\">PRORROGA PLAZO QUE INDICA </div></div>", "i": 8316756}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 202, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por 5 meses a contar del 21 de Marzo de 1990, el plazo establecido en el numeral 5&#xB0; de la Resoluci&#xF3;n No. 291, de 1989, de esta Subsecretar&#xED;a de Pesca, para que Concar S.A., R.U.T, No. 96.514.850-7, domiciliada en Valpara&#xED;so, inicie actividades pesqueras extractivas con la embarcaci&#xF3;n &quot;Mar&#xED;a Tamara&quot;, en raz&#xF3;n de haberse acreditado la ocurrencia de una causal de fuerza mayor.</div><br></div>", "i": 8316757}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 06 de Febrero de 1990.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8316758}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "202", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-202"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA PLAZO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-02-06", "doble_articulado": false, "id_norma": "84894", "numero_fuente": "33600", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-19", "vigencias": [{"desde": "1990-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": []