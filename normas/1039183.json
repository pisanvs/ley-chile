{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9249745}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;610, de 29 de marzo de 2012, se dej&#xF3; sin efecto los numerales 3&#xB0;, 4&#xB0;, 5&#xB0; y 6&#xB0;, del <a href=\"https://www.leychile.cl/Navegar?idNorma=267170&amp;idParte=0&amp;idVersion=\">Decreto Exento MOP. N&#xB0;667, de 29 de octubre de 2007</a>, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote de terreno N&#xB0;31-B, expropiado con motivo de la obra &quot;Mejoramiento Ruta D-825, Limahuida - Almendrillo, Sector Tahuinco - Salamanca, Km. 13,14000 a Km. 23,49783, II Etapa&quot;. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n, fijado mediante tasaci&#xF3;n de 04 de septiembre de 2006, en la suma de $111.283.</div></div>", "i": 9249746}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9249747}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "610 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-610 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-03-29", "doble_articulado": false, "id_norma": "1039183", "numero_fuente": "40238", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-04-16", "vigencias": [{"desde": "2012-04-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"i