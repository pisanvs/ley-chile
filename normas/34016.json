{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291460}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 257, de 8 de abril de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por 30 d&#xED;as a contar de la fecha de la presente Resoluci&#xF3;n, el plazo otorgado a do&#xF1;a HERMOSINA DE LAS MERCEDES CRUZ OLIVARES, R.U.T.</div><div class=\"p\">N&#xB0; 8.200.379-7, domiciliada en Los Vilos, calle Michimalongo N&#xB0; 440, en el numeral 5&#xB0; de la Resoluci&#xF3;n N&#xB0; 1257, de 1992, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la peticionacia para desarrollar actividades pesqueras de transformaci&#xF3;n en la planta ubicada en la IV Regi&#xF3;n, por haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8291461, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 8 de abril de 1993. Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8291462}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "257", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-257"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRORROGA", "PESCA", "HERMOSINA DE LAS MERCEDES CRUZ", "OLIVARES", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1993-04-08", "fecha_derogacion": "2001-01-06", "doble_articulado": false, "id_norma": "34016", "numero_fuente": "34560", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1993-05-08", "vigencias": [{"desde": "2001-01-06", "hasta": "", "tipo_v