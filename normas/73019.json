{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8303272}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 676, de 9 de mayo de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 1 de la Resoluci&#xF3;n N&#xBA; 167 de 1997, de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a ALIMENTOS MARINOS S.A., para operar por sustituci&#xF3;n la nave &quot;Alimar IX&quot;, en el sentido de se&#xF1;alar que las naves sustitutas que entran a operar son once y no diez como all&#xED; se indica. </div></div>", "i": 8303273}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de mayo de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8303274}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "676", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-676"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "ALIMENTOS MARINOS S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-05-09", "fecha_derogacion": "1998-02-04", "doble_articulado": false, "id_norma": "73019", "numero_fuente": "35776", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-05-28", "vigencias": [{"desde": "1998-02-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1997-05-28", "hasta": "1998-02-03", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1998-02-04", "fin_vigencia": ""}, "vigencias_ve