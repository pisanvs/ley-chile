{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6302114}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 4.25% anual durante el mes de febrero de 1988.</div><br><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad a lo dispuesto en el N&#xBA; 5 del Cap&#xED;tulo IV.B.8.1 del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables de 90 a 365 d&#xED;as, correspondiente a la segunda quincena de febrero de 1988 fue de 4.23% anual. </div></div>", "i": 6302115}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 03 de marzo de 1988.- Loreto Moya Gonz&#xE1;lez, Secretario General subrogante.</div><br></div>", "i": 6302116}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-03", "doble_articulado": false, "id_norma": "175944", "numero_fuente": "33012", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-03-04", "vigencias": [{"desde": "1988-03-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-03-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-03-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones