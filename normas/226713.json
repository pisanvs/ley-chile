{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6484445}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.614, de 10 de junio de</div><div class=\"p\">2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA CHILE</div><div class=\"p\">S.A. para ampliar actividades pesqueras extractivas con</div><div class=\"p\">la nave &quot;Puyuguapi&quot;, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; capturar: a) Entre la I a XII Regiones, con trampas: Pulpo; b) En el Archipi&#xE9;lago de Juan Fern&#xE1;ndez, Isla de Pascua, Isla Sala y G&#xF3;mez e Islas Desventuradas, con trampas: Pulpo.</div><br></div>", "i": 6484446}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de junio de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6484447}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1614 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1614 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-06-10", "fecha_derogacion": "2005-12-29", "doble_articulado": false, "id_norma": "226713", "numero_fuente": "37893", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-06-24", "vigencias": [{"desde": "2005-12-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-06-24", "hasta": "2005-12-28", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2005-12-29", "fi