{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6526351}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP exento N&#xBA; 422 de fecha 29 de abril de 2005, se expropi&#xF3; el lote de terreno N&#xBA; 12, superficie 2.416 m2, rol de aval&#xFA;o N&#xBA; 249-40, comuna de Salamanca, para la obra &quot;Readecuaci&#xF3;n Entrega Final Canal Panguesillo, Sistema Regad&#xED;o Valle del Choapa&quot;, Obras: &quot;Primera Entrega&quot; y &quot;Segunda Entrega&quot;, comuna de Salamanca, provincia del Choapa, Regi&#xF3;n de Coquimbo&quot;, IV Regi&#xF3;n, y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Manuel de la Cruz Cepeda Carvajal, ascendente a la cantidad de $2.544.185.</div><br></div>", "i": 6526352}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6526353}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "422 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-422 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-04-29", "doble_articulado": false, "id_norma": "238027", "numero_fuente": "38162", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-05-16", "vigencias": [{"desde": "2005-05-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-05-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-05-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DV