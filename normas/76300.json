{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6047360}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. N&#xBA; 785, de 29 de agosto de 1997, se expropiaron los lotes de terreno N&#xBA;s. 8-A, 14-A, 16-A y 17-A, superficies 72, 264, 728, y 352 M2.</div><div class=\"p\">respectivamente, roles de aval&#xFA;o 12094-3, 12095-4, 12095-6 y 12095-7, comuna de Rancagua, para la obra Mejoramiento Ruta 5 Sur, Sector Pasada por Rancagua, Camino Ruta 5 Sur y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Manuel Santib&#xE1;&#xF1;ez Vergara, Samuel Berr&#xED;os Alemanis y Embotelladora Andina S.A. ascendente a las cantidades de $1.459.896, $10.533.933.- y $35.558.159.-</div><br></div>", "i": 6047361}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6047362}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "785", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-785"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "RANCAGUA", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-08-29", "doble_articulado": false, "id_norma": "76300", "numero_fuente": "35891", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-10-15", "vigencias": [{"desde": "1997-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-10-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul