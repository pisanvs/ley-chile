{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8331118}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;853, de 10 de junio de 1998, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case la resoluci&#xF3;n N&#xBA;1.862 de 1997, de esta Subsecretar&#xED;a, que fij&#xF3; la n&#xF3;mina de armadores y embarcaciones que cumplen los requisitos legales para operar en la unidad de pesquer&#xED;a de Congrio dorado declarado en estado de plena explotaci&#xF3;n y sometido a dicho r&#xE9;gimen de administraci&#xF3;n, en el litoral comprendido entre el paralelo 41&#xB0;28,6&apos; L.S. y el paralelo 47&#xB0; L.S., en el &#xE1;rea se&#xF1;alada en sus respectivas autorizaciones, en el sentido de incorporar en su numeral 1&#xBA; lo siguiente: PESCA CHILE S.A.: Puerto Ballena.</div><br></div>", "i": 8331119}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de junio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8331120}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "853", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-853"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ARMADORES INDUSTRIALES", "NOMINA", "PESCA", "CONGRIO DORADO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-06-10", "fecha_derogacion": "1998-08-10", "doble_articulado": false, "id_norma": "120222", "numero_fuente": "36093", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-06-