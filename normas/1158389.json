{"html": [{"t": "<div><br><div class=\"p\">EL DIRECTOR SUPREMO DELEGADO DE CHILE &amp;c. </div></div>", "i": 10237763}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto ha llegado a esta capital el Excmo. Se&#xF1;or D. Ramon Freire, y ha indicado al Gobierno que desde el lunes 14 del corriente vuelve a reasumir el ejercicio de la Suprema Direccion del Estado: Por tanto ordeno que se anuncie por bando especial y que se inserte en el Boletin para noticia p&#xFA;blica.</div></div>", "i": 10237764}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Junio 12 de 1824.</div><br><br><div class=\"p\">&nbsp; &nbsp;  ERRAZURIZ.</div><br><div class=\"p\">&nbsp; &nbsp;  Diego Jos&#xE9; Benavente.</div></div>", "i": 10237765}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "36", "numero": "S/N", "abreviacion": "Bando", "descripcion": "Bando", "compuesto": "Bando-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "EL DIRECTOR SUPREMO DELEGADO DE CHILE &c.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-06-12", "doble_articulado": false, "id_norma": "1158389", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-06-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-06-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-06-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2021-06-04", "fecha_version": "1824-06-12", "fecha_actualizacion_texto": "2021-06-04", "tipo_tratado": ""}, "alertas": [], "alert