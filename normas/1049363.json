{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 579 EXENTA, DE 2013</div></div>", "i": 9337081}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 579, de 25 de enero de 2013, del Servicio Nacional de Capacitaci&#xF3;n y Empleo, se fija para el a&#xF1;o 2013, la cantidad de $30.000 (treinta mil pesos), por cada Unidad de Competencia Laboral, tambi&#xE9;n denominada UCL, como valor m&#xE1;ximo a descontar por cada proceso de evaluaci&#xF3;n y certificaci&#xF3;n de competencias laborales efectuado, denominado valor proceso de evaluaci&#xF3;n y certificaci&#xF3;n de competencias laborales participante.- </div></div>", "i": 9337082}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennet Urrutia, Director Nacional (PT).</div></div>", "i": 9337083}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "579 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-579 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 579 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-01-25", "doble_articulado": false, "id_norma": "1049363", "numero_fuente": "40506", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-03-11", "vigencias": [{"desde": "2013-03-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-03-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-03-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_