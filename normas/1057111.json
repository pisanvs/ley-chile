{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 6.486 EXENTA, DE 2013</div></div>", "i": 9391857}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 6.486, de fecha 6 de diciembre de 2013, de Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se aprueba el programa de ense&#xF1;anza para la obtenci&#xF3;n de licencia de conductor Clase B a la Escuela de Conductores No Profesionales o Clase B &quot;San Osvaldo&quot;, cuyo propietario y director es el se&#xF1;or Fredy Osvaldo Sep&#xFA;lveda Grandi, RUT N&#xBA; 12.737.097-4, la que tendr&#xE1; su lugar de funcionamiento en el local ubicado en Alcalde Jorge Monckeberg N&#xBA; 2280, comuna de Macul.</div></div>", "i": 9391858}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Sergio Stephan Orellana, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana.</div></div>", "i": 9391859}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6486 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6486 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL REGIÓN METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 6.486 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-12-06", "doble_articulado": false, "id_norma": "1057111", "numero_fuente": "40731", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion":