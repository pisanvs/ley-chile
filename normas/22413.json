{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento a la partida 21 del Presupuesto de Guerra Lei n&#xFA;m. 1,109.- Santiago, a 26 de Octubre de 1898.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948380}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de quince mil pesos al &#xED;tem 6 de la partida 21 del presupuesto de Guerra, para arriendo de casas para cuarteles i oficinas militares.</div><br><br></div>", "i": 5948381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Ventura Blanco.</div><br></div>", "i": 5948382}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1109", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1109"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "Suplemento a la partida 21 del Presupuesto de Guerra", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1898", "MODIFICACION", "MINISTERIO", "GUERRA", "CUARTELES MILITARES", "OFICINAS MILITARES", "ARRIENDO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-10-26", "doble_articulado": false, "id_norma": "22413", "numero_fuente": "6143", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-11-05", "vigencias": [{"desde": "1898-11-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-11-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"