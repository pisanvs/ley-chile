{"html": [{"t": "<div><div class=\"p\">DETERMINA DERECHO DE APROVECHAMIENTO DE AGUAS QUE INDICA </div></div>", "i": 6237942}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n</div><div class=\"p\">Exenta N&#xB0; 1.684 de 18 de Diciembre de 1985, conforme</div><div class=\"p\">Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento de aguas proporcionales que corresponden a Sector Expropiado Predio &quot;Quilelto y Santa Elena&quot; de la comuna de San Carlos, VIII Regi&#xF3;n: y derechos de aprovechamiento de aguas que corresponden a las parcelas N&#xB0;s. 1 a la 7, sitios N&#xB0;s. 1 al 16 del proyecto de parcelaci&#xF3;n &quot;Quilelto&quot; formado por predio se&#xF1;alado. Los derechos de agua se extraen del canal Quilelto derivado del r&#xED;o &#xD1;uble. Publicaci&#xF3;n hecha conforme Art. 1&#xB0; Ley N&#xB0; 18.377.</div><br></div>", "i": 6237943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Ejecutivo.</div><br></div>", "i": 6237944}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1684 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1684 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHO DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-18", "doble_articulado": false, "id_norma": "157245", "numero_fuente": "32372", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-01-15", "vigencias": [{"desde": "1986-01-15", "hasta": "", "tipo_version": "3", "tipo_versio