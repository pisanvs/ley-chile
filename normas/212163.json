{"html": [{"t": "<div><div class=\"p\">EXTRACTO RESOLUCION EXENTA N&#xBA;597, DE 2003 MODIFICA RESOLUCION EXENTA N&#xBA;250 DE 2003 </div></div>", "i": 6696371}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1. Modif&#xED;quese la resoluci&#xF3;n exenta N&#xBA;250 de fecha 26.03.2003 de esta Seremi, en su Resuelvo N&#xBA;5, quedando &#xE9;ste en definitiva como se se&#xF1;ala a continuaci&#xF3;n:</div><br><div class=\"p\">&nbsp; &nbsp;  5.- Recursos disponibles 675.627 UF.</div><br><div class=\"p\">&nbsp; &nbsp;  2. En todo aquello no modificado por la presente resoluci&#xF3;n se mantiene vigente lo dispuesto por resoluci&#xF3;n exenta N&#xBA;250 del 26.03.2003 de esta Seremi de Vivienda y Urbanismo.</div><br></div>", "i": 6696372}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Secretario Regional Ministerial de Vivienda y Urbanismo (S) </div></div>", "i": 6696373}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "597 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-597 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO RESOLUCION EXENTA Nº597, DE 2003 MODIFICA\nRESOLUCION EXENTA Nº250 DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "212163", "numero_fuente": "37603", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-08", "vigencias": [{"desde": "2003-07-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-07-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigen