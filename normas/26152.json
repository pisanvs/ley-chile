{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; REEMPLAZA EL ARTICULO 3&#xB0; DE LA LEY N&#xB0; 8,103, DE 1945, POR EL QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha tenido a bien prestar su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8278817}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Reempl&#xE1;zase el art&#xED;culo 3&#xB0; de la ley N&#xB0; 8,103, de 24 de Febrero de 1945, por el siguiente:</div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 3&#xB0;.- El producto del o los empr&#xE9;stitos se invertir&#xE1; en dotar de energ&#xED;a el&#xE9;ctrica a la ciudad de Puerto Aysen y alrededores&quot;.</div><br></div>", "i": 8278818}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, dieciseis de Febrero de mil novecientos cincuenta.- GABRIEL GONZALEZ VIDELA.- I. Holger T. </div></div>", "i": 8278819}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "9573", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-9573"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "REEMPLAZA EL ARTICULO 3° DE LA LEY N° 8,103, DE\n1945, POR EL QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FACULTAD", "MUNICIPALIDAD DE AYSEN", "CONTRATACION", "PRESTAMO", "EMPRESTITO", "INVERSION", "DESTINACION", "ENERGIA ELECTRICA", "PUERTO AYSEN"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1950-02-16", "doble_articulado": false, "id_norma": "26152", "numero_fuente": "21591", "tipo_vers