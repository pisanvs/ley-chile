{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6566923}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 106, de 13 de marzo de 2006, de Serviu Metropolitano, orden&#xF3; la expropiaci&#xF3;n parcial, conforme DL N&#xBA; 2.186, de 1978, del Lote N&#xBA; 17 correspondiente del inmueble ubicado en Avda. Larra&#xED;n N&#xBA; 7123, presunto Rol de aval&#xFA;o N&#xBA; 4700-06, comuna de La Reina, aparente dominio de Uson Godoy Jacinto. Comisi&#xF3;n integrada por peritos Jaime Jurgens Bittner, ingeniero civil; Juan Alfredo D&#xED;az Velasco, arquitecto, y Miguel Ortiz Bobadilla, constructor civil. Seg&#xFA;n informe de 6 de enero de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $26.250.000, pagadera al contado.</div><br></div>", "i": 6566924}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6566925}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "106", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-106"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "DISPONEN EXPROPIACION PARCIAL DE INMUEBLES QUE INDICAN; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-03-13", "doble_articulado": false, "id_norma": "248920", "numero_fuente": "38440", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-04-17", "vigencias": [{"desde": "2006-04-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"