{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PENSION Lei n&#xFA;m. 332.-Santiago, a 14 de Enero de 1896.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947555}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se declara, por gracia, que do&#xF1;a Carmela Huppeinbauer, viuda del capitan de fragata don Manuel Antonio Riofr&#xED;o, tiene derecho a la pension de montep&#xED;o que le conceden las leyes como si su marido hubiere obtenido el permiso necesario para contraer matrimonio.</div><br><br></div>", "i": 5947556}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORJE MONTT.- Luis Barros Borgo&#xF1;o.</div><br></div>", "i": 5947557}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "332", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-332"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CARMELA HUPPEINBAUER", "BENEFICIO POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-01-14", "doble_articulado": false, "id_norma": "22183", "numero_fuente": "5309", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1896-01-15", "vigencias": [{"desde": "1896-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1896-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1896-01-15", "fin_vigencia