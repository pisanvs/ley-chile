{"html": [{"t": "<div><div class=\"p\">LEI NUM. 1,995 QUE CONCEDE UN SUPLEMENTO DE $ 81,700 AL PRESUPUESTO DE GUERRA.</div><br><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,995.-</div><br><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br></div>", "i": 5952558}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese un suplemento de ochenta i un mil setecientos pesos al &#xED;tem 193 del presupuesto del Ministerio de Guerra, para compra de materiales, pago de jornales i gastos jenerales de la Direccion del Material de Guerra.</div><br></div>", "i": 5952559}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 26 de agosto de 1907.-PEDRO MONTT.-Alejandro Lira.</div><br></div>", "i": 5952560}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1995", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1995"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "LEI NUM. 1,995 QUE CONCEDE UN SUPLEMENTO DE $ 81,700 AL PRESUPUESTO DE GUERRA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1907", "MINISTERIO GUERRA", "MODIFICACION", "DIRECCION MATERIAL GUERRA", "MATERIALES", "PAGO JORNALES", "GASTOS GENERALES", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-08-26", "doble_articulado": false, "id_norma": "23057", "numero_fuente": "8887", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacio