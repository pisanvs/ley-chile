{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9410565}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 579, de 18 de febrero de 2014, de esta Subsecretar&#xED;a, autor&#xED;zase a MARINE GEL ANTARTIC S.A. para realizar actividad experimental de acuicultura con Luga roja, cuyo objetivo es diversificar la disponibilidad de esta especie para la elaboraci&#xF3;n de carrageninas en Tierra del Fuego.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Las actividades se desarrollar&#xE1;n por un a&#xF1;o, en concesi&#xF3;n de escasa importancia, ubicada en el Cabo Boquer&#xED;n, Bah&#xED;a In&#xFA;til, comuna de Porvenir, provincia de Tierra del Fuego, XII Regi&#xF3;n, cumpliendo con la normativa vigente y en la forma indicada en el Informe T&#xE9;cnico y resoluci&#xF3;n extractada.</div></div>", "i": 9410566}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de febrero de 2014.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9410567}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "579 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-579 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-02-18", "doble_articulado": false, "id_norma": "1059983", "numero_fuente": "40798", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-03-04", "vigencias": [{"desde": "2014-03-04", "hasta": "", "tipo_version"