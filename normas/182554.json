{"html": [{"t": "<div><div class=\"p\">EXTRACTO&nbsp; DE&nbsp; RESOLUCION&nbsp; N&#xBA; 948 EXENTA, DE 2001</div><br></div>", "i": 6325348}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 948 de 14 de febrero del a&#xF1;o 2001, se ha aprobado al Colegio Instituci&#xF3;n Teresiana, comuna de Las Condes, provincia de Santiago, un plan de estudio para 3er. a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores de la Formaci&#xF3;n Diferenciada que se se&#xF1;alan en la presente resoluci&#xF3;n.</div><br></div>", "i": 6325349}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de febrero de 2001.- Gabriel Ar&#xE1;nguiz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General (S). </div></div>", "i": 6325350}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "948 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-948 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 948 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-14", "doble_articulado": false, "id_norma": "182554", "numero_fuente": "36904", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-05", "vigencias": [{"desde": "2001-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-03-05", "fin_vigencia": "", "tipo_version": "3"}], "e