{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA NOMBRE A LA CALLE CHACABUCO DEL BALNEARIO &quot;EL TABO&quot;</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8279538}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- La calle Chacabuco del balneario &quot;El Tabo&quot; de la comuna de Cartagena se denominar&#xE1;, en lo sucesivo &quot;Doctor Ernesto Prado Tagle&quot;.</div><br></div>", "i": 8279539}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecis&#xE9;is de Septiembre de mil novecientos cincuenta y cuatro.- CARLOS IBA&#xD1;EZ DEL CAMPO.- A. Parra U.</div><br></div>", "i": 8279540}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11620", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11620"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA NOMBRE A LA CALLE CHACABUCO DEL BALNEARIO EL TABO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIA NOMBRA", "CALLE CHACABUCO", "BALNEARIO", "TABO", "CARTAGENA", "DOCTOR ERNESTO PRADO TAGLE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1954-09-16", "doble_articulado": false, "id_norma": "26725", "numero_fuente": "22966", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1954-10-06", "vigencias": [{"desde": "1954-10-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1954-10-06", "fin_