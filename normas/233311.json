{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6508092}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n N&#xBA; 3.452 de 2 de diciembre de 2004, de esta Subsecretar&#xED;a, rectif&#xED;case el numeral 3&#xBA; letra b) de la resoluci&#xF3;n N&#xBA; 3.282 de 2004, que autoriz&#xF3; a PESQUERA DEL NORTE S.A. para sustituir la nave &quot;Karibib&quot; por una nave en construcci&#xF3;n, en el sentido de indicar que la peticionaria podr&#xE1; desarrollar actividades extractivas con la embarcaci&#xF3;n en construcci&#xF3;n individualizada precedentemente sobre el recurso Merluza de cola, con arrastre de media agua, por fuera de la l&#xED;nea imaginaria trazada a una distancia de 60 millas n&#xE1;uticas medidas desde las l&#xED;neas de base normales o rectas, seg&#xFA;n corresponda, s&#xF3;lo entre la V a VII Regiones y en la IX Regi&#xF3;n, y no como all&#xED; se indica. </div></div>", "i": 6508093}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de diciembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6508094}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3452", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3452"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-12-02", "fecha_derogacion": "2015-03-24", "doble_articulado": false, "id_norma": "233311", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-12-09", "vigencias": [{"desde": "2015-03-24", "hasta": "", "tipo_version": "2", "tipo_versio