{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA RESOLUCION N&#xB0; 1.129, DE 1981</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 33.- Santiago, 22 de Mayo de 1991.- Visto:</div><div class=\"p\">&nbsp; &nbsp; Lo dispuesto en los decretos leyes N&#xB0;s. 557, de 1974 y 1.762 de 1977, y en el art&#xED;culo 4&#xB0;, letra q) del decreto con fuerza de ley N&#xB0; 279, de 1960,</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br><br></div>", "i": 6000420}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo Unico.- Sustit&#xFA;yese en la letra b) del numeral 2&#xB0; de la Resoluci&#xF3;n N&#xB0; 1.129 de fecha 12 de noviembre de 1981, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, la frase &quot;0.66 m. de ancho&quot; por 0.80 m. de ancho&quot;. </div></div>", "i": 6000421}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- V&#xED;ctor Germ&#xE1;n Correa D&#xED;as, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Saluda a Ud.- Patricia Mu&#xF1;oz Villela, Jefe Depto. Administrativo. </div></div>", "i": 6000422}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "33", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-33"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "MODIFICA RESOLUCION N° 1.129, DE 1981", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LOMOCION COLECTIVA", "TAXIS", "VEHICULOS MOTORIZADOS", "AVISOS PUBLICITARIOS", "LETREROS", "DIMENSION MAXIMA", "UBICACION", "REGLAMENTO", "MODIFICACION", "PLANTAS DE REVISION TECNICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "