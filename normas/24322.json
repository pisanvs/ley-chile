{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,887, que declara feriado el dia 7 de Setiembre de 1922</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,887.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8276795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.-En homenaje a los Estados Unidos del Brasil, decl&#xE1;rase feriado el dia 7 del presente mes, fecha del Centenario de su Independencia.</div><br></div>", "i": 8276796}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 6 de Setiembre de 1922.- ARTURO ALESSANDRI.- Antonio Huneeus.</div><br></div>", "i": 8276797}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3887", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3887"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 3,887, QUE DECLARA FERIADO EL DIA 7 DE SETIEMBRE DE 1922", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ESTADOS UNIDOS DEL BRASIL", "FERIADO LEGAL", "DECLARACION", "CENTENARIO DE LA INDEPENDENCIA", "HOMENAJE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1922-09-06", "doble_articulado": false, "id_norma": "24322", "numero_fuente": "13373", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1922-09-06", "vigencias": [{"desde": "1922-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1922-09-