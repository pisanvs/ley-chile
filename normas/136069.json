{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  EXTRACTO DE DECRETO EXENTO No. 96, DE 1988 </div></div>", "i": 7248435}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 96 de 29 de abril de 1988 se ha aprobado a la Escuela D-366 de Vi&#xF1;a del Mar, provincia de Valpara&#xED;so, V Regi&#xF3;n de Valpara&#xED;so, un plan de estudio especial de orientaci&#xF3;n laboral para menores deficientes mentales que se desarrollar&#xE1; con car&#xE1;cter experimental por un per&#xED;odo de 4 a&#xF1;os, a contar de 1988.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban los programas de estudio correspondientes y se dan normas de evaluaci&#xF3;n. </div></div>", "i": 7248436}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de Mayo de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7248437}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "96 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-96 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 96, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-04-29", "doble_articulado": false, "id_norma": "136069", "numero_fuente": "33072", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-05-16", "vigencias": [{"desde": "1988-05-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-05-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-05-16", "fin_vige