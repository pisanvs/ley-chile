{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;606 EXENTO, DE 1998</div><br><br><br><br><br></div>", "i": 6114756}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA;606, de 20 de mayo de 1998, se ha aprobado a la Escuela B&#xE1;sica Particular N&#xBA;70 Farmland School de Curacav&#xED;, de Santiago, para que a partir del a&#xF1;o escolar 1998 y en concordancia con la gradualidad de aplicaci&#xF3;n que establece el decreto supremo de Educaci&#xF3;n N&#xBA;40 de 1996 y sus modificaciones, aplique un plan de estudio para los cursos de 1&#xBA; a 8&#xBA; a&#xF1;o (NB.1 a NB.6) de Ense&#xF1;anza B&#xE1;sica.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio correspondientes a todos los subsectores mencionados en el plan de estudio que se aprueba por el presente decreto.- </div></div>", "i": 6114757}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 6114758}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "606 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-606 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO de DECRETO Nº606 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "FARMLAND SCHOOL", "CURACAVI", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-05-20", "doble_articulado": false, "id_norma": "120042", "numero_fuente": "36088", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-06-13", "vigencias": [{"desde": "1998-06-13", "hasta": "", "