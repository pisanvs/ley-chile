{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 107 EXENTO, DE 1988 </div></div>", "i": 6155070}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 107 de 03 de junio de 1988 se ha aprobado para el Centro Educacional Municipal A No. 85 &quot;Los H&#xE9;roes de La Concepci&#xF3;n&quot;, comuna de Cerro Navia, Regi&#xF3;n Metropolitana, planes y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico - Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar de 1988 y hasta el a&#xF1;o escolar de 1989 en la Rama Comercial, Especialidades de Secretariado Administrativo y Programaci&#xF3;n en Computaci&#xF3;n. </div></div>", "i": 6155071}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de Junio de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6155072}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "107 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-107 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO N° 107 EXENTO, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-06-03", "doble_articulado": false, "id_norma": "132006", "numero_fuente": "33108", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-06-30", "vigencias": [{"desde": "1988-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-06-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-06-30", "f