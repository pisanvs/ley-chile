{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,443.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170725}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Laura i a do&#xF1;a Leonor Due&#xF1;as Latuz una pension mensual de ciento veinte pesos ($ 120.00) en atencion a los servicios prestados por su abuelo el Coronel de la Independencia don Manuel J. Latuz i por su hermano el Capitan don Pedro A. Due&#xF1;as.</div><br></div>", "i": 6170726}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, treinta i uno de diciembre de 1910.- Ramon Barros Luco.- A. Pinto Concha.</div><br></div>", "i": 6170727}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2443", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2443"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-12-31", "doble_articulado": false, "id_norma": "137049", "numero_fuente": "9873", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-01-05", "vigencias": [{"desde": "1911-01-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-01-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-01-05", "fin_vigencia": "", "tipo_version": "