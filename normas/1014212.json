{"html": [{"t": "<div><br><br><div class=\"p\">DECLARA AMPLIADO PLAZO PARA INICIAR ACTIVIDADES DE ACUICULTURA POR FUERZA MAYOR</div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n 2.481, de fecha 28 de diciembre de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div></div>", "i": 8928637}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Decl&#xE1;rase ampliado, entre el 21 de abril de 2006 y el 21 de abril de 2010, ambas fechas inclusive, el plazo para iniciar actividades de acuicultura por fuerza mayor, autorizadas mediante <a href=\"https://www.leychile.cl/Navegar?idNorma=234884&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 1.652, de fecha 20 de octubre de 2004, del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina</a>.</div></div>", "i": 8928638}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de abril de 2010.- Por el Sr. Subsecretario, Felipe Garc&#xED;a-Huidobro Correa, Subjefe (M).</div></div>", "i": 8928639}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2481", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2481"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "DECLARA AMPLIADO PLAZO PARA INICIAR ACTIVIDADES DE ACUICULTURA POR FUERZA MAYOR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-12-28", "doble_articulado": false, "id_norma": "1014212", "numero_fuente": "39676", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-06-03", "vigencias": [{"desde": "2010-06-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"i