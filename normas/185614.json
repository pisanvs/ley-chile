{"html": [{"t": "<div><div class=\"p\">APRUEBA MODIFICACION A ORDENANZA N&#xBA; 3</div><br><br></div>", "i": 6694361}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Apru&#xE9;base la siguiente modificaci&#xF3;n a la ordenanza comunal N&#xBA; 3 sobre: &quot;Patentes de Alcoholes y Horario de Funcionamiento de Establecimientos de Expendio de Bebidas Alcoh&#xF3;licas&quot;, sancionada por decreto alcaldicio N&#xBA; 1.996 de fecha 11.7.2000, en el sentido de reemplazar el inciso segundo del art&#xED;culo 16&#xBA; como sigue:</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;Estos establecimientos no podr&#xE1;n expender bebidas alcoh&#xF3;licas, sino a partir de las 8:00 horas AM&quot; </div><div class=\"p\">&nbsp; &nbsp;  En el actual inciso segundo del art&#xED;culo 16&#xBA; de dicha ordenanza, pasa a &#xFA;ltimo inciso del mismo art&#xED;culo.</div><br></div>", "i": 6694362}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "AVI-S/N"}], "organismos": ["MUNICIPALIDAD DE CERRO NAVIA"], "titulo_norma": "APRUEBA MODIFICACION A ORDENANZA Nº 3", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO. NO TIENE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "185614", "numero_fuente": "36969", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-24", "vigencias": [{"desde": "2001-05-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-05-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-05-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION