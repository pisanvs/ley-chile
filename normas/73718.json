{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7208399}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 313, de 31 de marzo de 1997, se expropiaron los lotes de terreno N&#xBA;s. 2, 4, 5, 6, 7, 20, 24 y 32, superficies 180, 1.617, 2.094, 4.442, 335, 88, 4.487 y 1.945 m&#xB2;, roles de aval&#xFA;os 321-43, 321-47, 319-1, 320-8 y 346-256, comuna de R&#xED;o Negro, obra Camino U-800 y U-600, R&#xED;o Negro Riachuelo y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Guillermo Paredes Coronado, Juan Carrasco C&#xE1;rdenas, Fritz Leibbrandt Harsch, Fredy Klocker Hechenleitner y Emilio Hern&#xE1;ndez Quintul, ascendente a las cantidades de $326.442, $427.183, $748.055, $556.599 y $350.033.-</div><br></div>", "i": 7208400}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 7208401}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "313", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-313"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "RIO NEGRO", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-31", "doble_articulado": false, "id_norma": "73718", "numero_fuente": "35791", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-06-16", "vigencias": [{"desde": "1997-06-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-06-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-06-16", "fin_vigencia": "", "tipo_version": "