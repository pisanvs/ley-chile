{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,021.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6175498}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al ex-subteniente del Ej&#xE9;rcito, don Agustin A. Garc&#xED;a G., para los efectos de su retiro, los cuatro a&#xF1;os diez meses i seis dias que sirvi&#xF3; como empleado de los Ferrocarriles del Estado i en la polic&#xED;a de Valparaiso.</div><br></div>", "i": 6175499}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a cuatro de setiembre de mil novecientos quince.- Ramon Barros Luco.- Guillermo Soublette. </div></div>", "i": 6175500}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3021", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3021"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1915-09-04", "doble_articulado": false, "id_norma": "138475", "numero_fuente": "11283", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1915-10-02", "vigencias": [{"desde": "1915-10-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1915-10-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1915-10-02", "fin_vigencia": "", "tipo_version": "3"}], "event