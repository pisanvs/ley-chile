{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 125 EXENTO, DE 1994 </div></div>", "i": 5941556}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 125 de fecha 23 de marzo de 1994 del Ministerio de Educaci&#xF3;n, se sustituy&#xF3; el art&#xED;culo &#xFA;nico del Decreto Exento N&#xB0; 90 de 1982 correspondiente al Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Celler, por el siguiente nuevo:</div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1&#xB0;: Autor&#xED;zase el funcionamiento del Centro de Formaci&#xF3;n T&#xE9;cnica que se indica, organizado por la persona jur&#xED;dica que se se&#xF1;ala, cuyo fin es la docencia a nivel t&#xE9;cnico para egresados de ense&#xF1;anza media:</div><div class=\"p\"> Nombre de la Instituci&#xF3;n: Centro de Formaci&#xF3;n T&#xE9;cnica</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Celler</div><br><div class=\"p\"> Domicilio&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  : Vi&#xF1;a del Mar</div><div class=\"p\"> Organizador&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  : Sociedad Centro de Formaci&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  T&#xE9;cnica Celler Limitada.</div><br></div>", "i": 5941557}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5941558}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "125", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-125"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 125 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "FUNCIONAMIENTO", "MODIFICACION", "CENTRO FORMACIO