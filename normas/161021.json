{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6250767}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;3.264, de 29 de octubre de 1999, se modific&#xF3; el decreto MOP N&#xBA;391, de 26 de febrero de 1999, que autoriz&#xF3; la expropiaci&#xF3;n entre otros del lote N&#xBA;14, rol de aval&#xFA;o N&#xBA;3198-15, comuna de Chill&#xE1;n, para la obra Camino Ruta N-545 Chill&#xE1;n Tanilvoro, sector Chill&#xE1;n - Universidad Adventista, orden&#xE1;ndose la consignaci&#xF3;n judicial del valor provisional de la indemnizaci&#xF3;n ascendente a la cantidad de $445.500, por haber quedado sin efecto el convenio directo de precio suscrito con el expropiado se&#xF1;or Juan V&#xE1;squez Medina. La indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto por el art&#xED;culo 7&#xBA; del decreto ley N&#xBA;2.186, de 1978.</div><br></div>", "i": 6250768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6250769}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3264", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3264"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-29", "doble_articulado": false, "id_norma": "161021", "numero_fuente": "36614", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-15", "vigencias": [{"desde": "2000-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-15", "fin_vigencia":