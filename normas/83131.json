{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9049179}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta N&#xB0;. 341 de 07.06.90 del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriza en forma complementaria a la empresa de origen argentino Autotransportes T.I.C.S.A.</div><div class=\"p\">(Transportes Interprovincial Cuyo Sur Argentino) S.R.L., para efectuar Servicio Internacionai de Transporte Terrestre de Pasajeros entre San Juan (Argentina) Santiago (Chile) utilizando el paso fronterizo t&#xFA;nel Cristo Redentor, realizando dos frecuencias semanales de ida y vuelta. Sergio </div></div>", "i": 9049180}, {"t": "<div><div class=\"p\">Gonz&#xE1;lez Tagle, Subsecretario de Transportes. </div></div>", "i": 9049181}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "341", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-341"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-07-07", "doble_articulado": false, "id_norma": "83131", "numero_fuente": "33711", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-07-05", "vigencias": [{"desde": "1990-07-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-07-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-07-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1998-01-07", "fecha_version": "1990