{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 103, DE 1986</div><br><br></div>", "i": 6223371}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 103 de 11 de junio de 1986, se han aprobado para el Liceo Industrial Particular &quot;General Carrera&quot;, de San Miguel; planes y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico-Profesional, que se aplicar n gradualmente a contar del a&#xF1;o escolar 1986 y hasta el a&#xF1;o escolar de 1991, en las Especialidades de:</div><br><div class=\"p\">1.- Electromec nica.</div><div class=\"p\">2.- Mec&#xE1;nica de Combusti&#xF3;n Interna y Automotriz. </div></div>", "i": 6223372}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de Junio de 1986.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6223373}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "103 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-103 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 103, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-11", "doble_articulado": false, "id_norma": "152503", "numero_fuente": "32511", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-07-02", "vigencias": [{"desde": "1986-07-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-07-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-07-02", "fin_vigencia": "