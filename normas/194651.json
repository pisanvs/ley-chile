{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6369333}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 244, de 31 de enero de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA QUINTERO S.A., para ampliar las actividades pesqueras extractivas con la nave &quot;Don Estefan&quot;, matr&#xED;cula 2945.</div><div class=\"p\">&nbsp; &nbsp;  La interesada podr&#xE1; realizar actividades pesqueras con la nave se&#xF1;alada precedentemente, con el arte de pesca y en el &#xE1;rea mar&#xED;tima que se indica, por fuera del &#xE1;rea de reserva artesanal, sobre los siguientes recursos hidrobiol&#xF3;gicos: Litoral comprendido entre la I y III Regiones con espinel sobre: Reineta Brama australis.</div><br></div>", "i": 6369334}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de enero de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6369335}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "244", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-244"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-01-31", "fecha_derogacion": "2014-06-09", "doble_articulado": false, "id_norma": "194651", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-02-16", "vigencias": [{"desde": "2014-06-09", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2002-02-16", "hasta": "2014-06-08", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2014-06-0