{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 1.530 EXENTA, DE 2014</div><div class=\"p\"> </div></div>", "i": 9428931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 1.530, de 27 de marzo de 2014, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Organismo T&#xE9;cnico de Capacitaci&#xF3;n Marcela del Carmen Pozo Becerra E.I.R.L. (Agrolog&#xED;stica E.I.R.L.)&quot;, RUT 76.067.929-1 contenida en la resoluci&#xF3;n exenta N&#xBA; 10.099 de 23 de noviembre de 2009, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.</div><div class=\"p\">&nbsp; </div></div>", "i": 9428932}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Julio Salas Guti&#xE9;rrez, Director Nacional (PT).</div></div>", "i": 9428933}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1530 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1530 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 1.530 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-03-27", "doble_articulado": false, "id_norma": "1061050", "numero_fuente": "40829", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-04-09", "vigencias": [{"desde": "2014-04-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_v