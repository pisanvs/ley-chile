{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8335905}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.456, de 8 de octubre de 1998, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xBA; 1.248, de 1991 de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD PESQUERA MAMI&#xD1;A S.A., para operar las naves &apos;&apos;Thais&apos;&apos;, &apos;&apos;Mami&#xF1;a&apos;&apos;, &apos;&apos;Octopus&apos;&apos; y &apos;&apos;Tacora&apos;&apos;, por haber suspendido actividades por m&#xE1;s de 12 meses sucesivos y encontrarse en mora del pago de la patente &#xFA;nica pesquera, configur&#xE1;ndose la causal prevista en el art&#xED;culo 143 letra b) y d) de la Ley General de Pesca y Acuicultura, respectivamente.</div><br></div>", "i": 8335906}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de octubre de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8335907}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1456", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1456"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "SOCIEDAD PESQUERA MAMI A S.A.", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-10-08", "doble_articulado": false, "id_norma": "126120", "numero_fuente": "36191", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-10-19", "vigencias": [{"desde": "1998-10-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-10-19"