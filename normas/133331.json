{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Certificado</div><br></div>", "i": 6158764}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 6,90% anual durante el mes de febrero de 1999.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad con lo dispuesto en el N&#xBA;5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de febrero de 1999, fue de 7,00% anual.</div><br></div>", "i": 6158765}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 2 de marzo de 1999.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6158766}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-03-02", "doble_articulado": false, "id_norma": "133331", "numero_fuente": "36306", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-03-05", "vigencias": [{"desde": "1999-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-03-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-03-05", "fin_vigencia": "", "tipo_ve