{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SOLICITA LA CONSTITUCION LEGAL DEL PARTIDO POR LA DEMOCRACIA </div></div>", "i": 6014232}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Jorge Schaulsohn Brodsky, Presidente, del &quot;Partido Por la Democracia&quot;, ha solicitado la constituci&#xF3;n legal del Partido, en la VI Regi&#xF3;n del Libertador General Bernardo O&apos;Higgins y en la XII Regi&#xF3;n de Magallanes y de la Ant&#xE1;rtica Chilena acompa&#xF1;ando las siguientes cantidades de afiliaciones en las regiones que se se&#xF1;alan:</div><div class=\"p\"> VI Regi&#xF3;n&nbsp; &nbsp; &nbsp; &nbsp; 2.369</div><div class=\"p\"> XII Regi&#xF3;n&nbsp; &nbsp; &nbsp; &nbsp;  517</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la Ley N&#xB0; 18.603, por Resoluci&#xF3;n O-N&#xB0; 1.045 de fecha 15 de Noviembre de 1995.-</div><br></div>", "i": 6014233}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director. </div></div>", "i": 6014234}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1045", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1045"}, {"tipo": "3", "numero": "O-1045", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-1045"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA LA CONSTITUCION LEGAL DEL PARTIDO POR LA\nDEMOCRACIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDO DEMOCRACIA", "PARTIDOS POLITICOS", "CONSTITUCION LEGAL", "SEXTA REGION", "DECIMO SEGUNDA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-11-15", "doble_articulado": false, "id_norma": "36110", "numero_fuent