{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Edificios escolares Lei n&#xFA;m. 1,203.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948584}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Los edificios construidos para escuelas o tomados en arrendamiento por el Fisco para escuelas p&#xFA;blicas, no podr&#xE1;n ser destinados a objeto alguno estra&#xF1;o a la ense&#xF1;anza.</div><br><br></div>", "i": 5948585}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 1.&#xB0; de Febrero de 1899.- FEDERICO ERRAZUIZ.- C&#xE1;rlos A. Palacios Z.</div><br></div>", "i": 5948586}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1203", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1203"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "EDIFICIOS ESCOLARES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EDIFICIOS ESCOLARES", "USO EXCLUSIVO EDUCACION", "OBLIGATORIEDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-02-01", "doble_articulado": false, "id_norma": "22470", "numero_fuente": "6217", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-02-02", "vigencias": [{"desde": "1899-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-02-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-02-02", "