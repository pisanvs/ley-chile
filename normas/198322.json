{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6382089}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;620 de 28 de marzo del 2002, se expropi&#xF3; el lote de terreno N&#xBA;26-A, superficie 1.664 m&#xB2;, rol de aval&#xFA;o 3505-2, comuna de Quilpu&#xE9;, para la obra Concesi&#xF3;n Internacional Interconexi&#xF3;n Vial Santiago - Valpara&#xED;so - Vi&#xF1;a del Mar. Troncal Sur Tramo 3. Kms.</div><div class=\"p\">98.650,00 al 99.200,00, Quinta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Alejandro Correa y Compa&#xF1;&#xED;a Limitada, ascendente a la cantidad de $7.245.184.- para el lote N&#xBA;26-A.</div><br></div>", "i": 6382090}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6382091}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "620", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-620"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-28", "doble_articulado": false, "id_norma": "198322", "numero_fuente": "37259", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-15", "vigencias": [{"desde": "2002-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PSO", "fecha_ingreso": "2002-05-20", "fecha_version