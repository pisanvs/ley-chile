{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 225 EXENTA, DE 2003 </div><br></div>", "i": 6696126}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modifica primer proceso de selecci&#xF3;n a&#xF1;o 2003, Subsidio Nueva B&#xE1;sica para Viviendas Serviu, en el sentido de aumentar el n&#xFA;mero de subsidios en la oferta N&#xBA; 3.</div><br><div class=\"p\">&nbsp; &nbsp;  Modifica la resoluci&#xF3;n N&#xBA; 186, de 18 de febrero de 2003, que define el primer proceso de postulaci&#xF3;n en la Regi&#xF3;n Metropolitana del a&#xF1;o 2003, en el sentido de aumentar a 69 el n&#xFA;mero de viviendas en la oferta N&#xBA; 3 y a un total de 9.660 UF los recursos disponibles. </div></div>", "i": 6696127}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Secretario Ministerial Metropolitano de Vivienda y Urbanismo Subrogante.</div><br></div>", "i": 6696128}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "225 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-225 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 225 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "208091", "numero_fuente": "37498", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-03-01", "vigencias": [{"desde": "2003-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_