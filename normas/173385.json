{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.049 EXENTO, DE 1998 </div></div>", "i": 6293415}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.049 de fecha 26 de noviembre de 1998 del Ministerio de Educaci&#xF3;n, se declar&#xF3; aprobada a la Universidad San Sebasti&#xE1;n, la siguiente carrera y t&#xED;tulo profesional para impartirse en jornada vespertina, en su Sede de la ciudad de Concepci&#xF3;n, de conformidad al acuerdo adoptado por el Consejo Superior de Educaci&#xF3;n, quien llevar&#xE1; a efecto la verificaci&#xF3;n progresiva de su desarrollo:</div><br><div class=\"p\">Carrera&nbsp; &nbsp;  :&nbsp; &nbsp; &nbsp; Comunicaci&#xF3;n Organizacional,</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  conducente al t&#xED;tulo profesional de</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Comunicador Organizacional.</div><br></div>", "i": 6293416}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de diciembre de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6293417}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1049 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1049 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.049 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-26", "doble_articulado": false, "id_norma": "173385", "numero_fuente": "36722", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-25", "vigencias": [{"desde"