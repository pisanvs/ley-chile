{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUA EN LA COMUNA DE TALCA </div></div>", "i": 6090365}, {"t": "<div><div class=\"p\">Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 645 de 02 de Mayo de 1989, conforme Art. 5&#xB0; transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a Sector Excluido y Sector Expropiado predio &quot;La Florida&quot; de la comuna de Talca, VII Regi&#xF3;n y Derechos de Aprovechamiento de Aguas que corresponden a las parcelas N&#xB0;s. 1 a la 9 y sitios N&#xB0;s. 1 y 2 del Proyecto de Parcelaci&#xF3;n &quot;La Florida&quot;, formado por predio se&#xF1;alado. Los derechos de aguas se extraen del Canal Duao Zapata, derivado del R&#xED;o Maule. Publicaci&#xF3;n hecha conforme Art. 13 Ley 18.377.</div><br></div>", "i": 6090366}, {"t": "<div><div class=\"p\">Director Nacional.</div><br></div>", "i": 6090367}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "645 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-645 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DERECHOS DE AGUA EN LA COMUNA DE TALCA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-02", "doble_articulado": false, "id_norma": "92005", "numero_fuente": "33372", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-05-15", "vigencias": [{"desde": "1989-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-05-15",