{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,866, que declara libre de derechos de internacion un camion-ambulancia para la Cruz Roja de Tocopilla</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,866.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5957314}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Decl&#xE1;rase libre de derechos de internacion a un camion-ambulancia perteneciente a la Cruz Roja del puerto de Tocopilla.</div><br></div>", "i": 5957315}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 28 de Junio de 1922.- ARTURO ALESSANDRI.- Samuel Claro Lastarria.</div><br></div>", "i": 5957316}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3866", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3866"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LEI NUM. 3,866, QUE DECLARA LIBRE DE DERECHOS DE INTERNACION UN CAMION-AMBULANCIA PARA LA CRUZ ROJA DE TOCOPILLA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CRUZ ROJA", "TOCOPILLA", "CAMION AMBULANCIA", "DERECHOS", "INTERNACION", "EXENCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1922-06-28", "doble_articulado": false, "id_norma": "24306", "numero_fuente": "13322", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1922-07-07", "vigencias": [{"desde": "1922-07-07", "hasta": "", "tipo_version": "3", "tipo