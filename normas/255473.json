{"html": [{"t": "<div><div class=\"p\">AUTORIZA EMISOR ELECTRONICO </div></div>", "i": 6590503}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA;139, del 23 de noviembre de 2006, que autoriza a contribuyente como emisor electr&#xF3;nico.</div><br><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de documentos tributarios electr&#xF3;nicos a RUT.96.563.570-K a contar del mes de noviembre de 2006. En la Oficina Virtual del SII en Internet se podr&#xE1;n consultar los documentos que el contribuyente est&#xE1; autorizado a emitir en forma electr&#xF3;nica.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de noviembre de 2006. </div></div>", "i": 6590504}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "139 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-139 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISOR ELECTRONICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-11-23", "doble_articulado": false, "id_norma": "255473", "numero_fuente": "38624", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-11-27", "vigencias": [{"desde": "2006-11-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-11-27", "fin_vigencia": ""}, "vigencias_