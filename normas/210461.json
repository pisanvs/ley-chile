{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CIRCULAR N&#xBA;27, DE 2003 </div></div>", "i": 6424251}, {"t": "<div><div class=\"p\">I. INTRODUCCION</div><br><div class=\"p\">&nbsp; &nbsp;  En el Diario Oficial de fecha 11 de febrero del a&#xF1;o 2003, se public&#xF3; la ley N&#xBA;19.857, texto legal que autoriza el establecimiento de empresas individuales de responsabilidad limitada, fijando las condiciones y requisitos que deben cumplir para su constituci&#xF3;n y el r&#xE9;gimen tributario a que estar&#xE1;n afectas.</div><br><div class=\"p\">II. INSTRUCCIONES SOBRE LA MATERIA</div><br><div class=\"p\">&nbsp; &nbsp;  Ahora bien, este Servicio mediante la Circular N&#xBA;27 de fecha 14 de mayo del a&#xF1;o 2003, imparti&#xF3; las instrucciones pertinentes respecto del tratamiento tributario que afecta a las empresas indicadas en el Cap&#xED;tulo anterior; instructivo que ser&#xE1; publicado &#xED;ntegramente en la p&#xE1;gina web que tiene habilitada este Servicio en Internet, cuya direcci&#xF3;n es www.sii.cl y en el Bolet&#xED;n que edita este organismo del mes de mayo del a&#xF1;o 2003.</div><br></div>", "i": 6424252}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Gina Anastasov Aguilera, Secretaria General. </div></div>", "i": 6424253}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "27", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "CIR-27"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE CIRCULAR Nº27, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EMPRESAS INDIVIDUALES DE RESPONSABILIDAD LIMITADA", "REGIMEN TRIBUTARIO", "INSTRUCCIONES", "SERVICIO DE IMPUESTOS INTERNOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-05-14", "doble_articulado": false, "id_norma": "210461", "numero_fuente": "37562", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-05-19", "vigencias": [{"desde": "2003-05-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-05-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-05-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresado_por": "JRC", "fecha_ingreso": "2003-05-19", "fecha_version": "2003-05-19", "fecha_actualizacion_texto": "2003-05-19", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6424251}, {"n": "Artículo", "i": 6424252, "t": 6}, {"n": "Promulgación", "i": 6424253}]}