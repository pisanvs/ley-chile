{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 8.440 EXENTA, DE 2004 </div></div>", "i": 6489074}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 8.440 de 21 de junio de 2004, se ha modificado la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 3.453 de 2002, que aprob&#xF3; planes y programas especiales de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media al Colegio Marista &quot;Champagnat&quot;, de Villa Alemana, en el sentido de sustituir los planes y programas de 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media por los que se indican en la presente resoluci&#xF3;n.</div><br></div>", "i": 6489075}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de julio de 2004.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6489076}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8440 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8440 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 8.440 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-06-21", "doble_articulado": false, "id_norma": "228093", "numero_fuente": "37919", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-26", "vigencias": [{"desde": "2004-07-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-07-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-07-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion