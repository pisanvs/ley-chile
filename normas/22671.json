{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que declara feriado el dia 25 de Junio de 1901 Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274358}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se declara dia feriado el dia 25 de Junio de mil novecientos uno.</div><br></div>", "i": 8274359}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 22 de Junio de 1901.- ANIBAL ZA&#xD1;ARTU.- Luis Martiniano Rodriguez.</div><br></div>", "i": 8274360}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1464", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1464"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "QUE DECLARA FERIADO EL DIA 25 DE JUNIO DE 1901", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FERIADO LEGAL", "25 JUNIO 1901", "DECLARACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-06-22", "doble_articulado": false, "id_norma": "22671", "numero_fuente": "6921", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-06-22", "vigencias": [{"desde": "1901-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1901-06-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1901-06-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-02-01", "fecha_version": "