{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xB0; 11, DE 1987 </div></div>", "i": 8548924}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 115, de 05.02.87, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n N&#xB0; 11, de 1987, en el sentido de reemplazar las coordenadas geogr&#xE1;ficas de los V&#xE9;rtices C y D por las siguientes:</div><div class=\"p\">V&#xE9;rtice C: Lat. 42&#xB0; 52&apos; 13&quot; S, Long. 73&#xB0; 41&apos; 35&quot;W;</div><div class=\"p\">V&#xE9;rtice D: Lat. 42&#xB0; 52&apos; 13&quot;S, Long. 73&#xB0; 41&apos; 12&quot;W. </div></div>", "i": 8548925}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 05.02.87.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8548926}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "115", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-115"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION N° 11, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-05", "doble_articulado": false, "id_norma": "144386", "numero_fuente": "32698", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-02-14", "vigencias": [{"desde": "1987-02-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-02-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-02-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu