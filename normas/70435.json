{"html": [{"t": "<div><div class=\"p\">Rectificaci&#xF3;n</div><div class=\"p\">(21/03/97) Decreto N&#xBA;400 </div></div>", "i": 6033845}, {"t": "<div><div class=\"p\">LA ALCALDIA DE &#xD1;U&#xD1;OA DECRETO HOY LO SIGUIENTE:</div><br><div class=\"p\">&nbsp; &nbsp;  1) Sustit&#xFA;yese la letra &quot;c&quot; del art&#xED;culo 6&#xBA; de la Ordenanza Municipal N&#xBA; 1, sobre &quot;Otorgamiento de Patentes de Alcoholes&quot;, por la siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;c) Distancia: Trat&#xE1;ndose de patentes de cantinas, bares o tabernas y cabarets, el local deber&#xE1; cumplir con la obligaci&#xF3;n de distancia se&#xF1;alada en el art&#xED;culo 153 de la Ley N&#xBA; 17.105, la que ser&#xE1; medida entre los ejes de los accesos principales de los establecimientos se&#xF1;alados en dicha norma, tomando la l&#xED;nea m&#xE1;s corta por las aceras, calles y espacios de uso p&#xFA;blico. </div></div>", "i": 6033846}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Pedro Sabat Pietracarpina, Alcalde </div></div>", "i": 6033847}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "400", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-400"}], "organismos": ["MUNICIPALIDAD DE ÑUÑOA"], "titulo_norma": "RECTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECTIFICACION", "ORDENANZA MUNICIPAL", "PATENTES DE ALCOHOLES", "MUNICIPALIDAD DE ÑUÑOA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-21", "doble_articulado": false, "id_norma": "70435", "numero_fuente": "35732", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-04", "vigencias": [{"desde": "1997-04-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}]