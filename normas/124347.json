{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6130458}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP. No. 683, de 29 de mayo de 1998, complementado por decreto MOP. No. 1.223, de 24 de agosto de 1998, se expropiaron los lotes de terreno No. s.41-B, 41-M y 41-N, superficies 5.340, 5.476 y 6.500 m&#xB2;, roles de aval&#xFA;os 402-10, comuna de Vicu&#xF1;a, para la obra Proyecto Embalse Puclaro, Sector Punta Azul, III Etapa y se acord&#xF3; precio de la indemnizaci&#xF3;n con sus propietarios, Ruperto Benjam&#xED;n Castro Oddershede y Luis Hern&#xE1;n Cort&#xE9;s Cort&#xE9;s, ascendentes a las cantidades de $ 2.226.745.- para el lote No. 41-B y $ 4.993.914.- para los lotes No. s.41-M y 41-N.- </div></div>", "i": 6130459}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6130460}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "683", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-683"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "VICU A", "CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-05-29", "doble_articulado": false, "id_norma": "124347", "numero_fuente": "36165", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-09-15", "vigencias": [{"desde": "1998-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente