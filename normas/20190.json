{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 107 EXENTO, DE 1993 </div></div>", "i": 5941206}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 107 de fecha 8 de Marzo de 1993 del Ministerio de Educaci&#xF3;n, autoriz&#xF3; a las Sedes que se indican del Centro de Formaci&#xF3;n T&#xE9;cnica CIDEC, para impartir planes y programas de estudios para la instituci&#xF3;n, de las carreras y t&#xED;tulos t&#xE9;cnicos de nivel aprobados superior que se se&#xF1;alan a partir del a&#xF1;o 1993:</div><div class=\"p\"> Sede N&#xB0; 14 - Chill&#xE1;n</div><div class=\"p\"> Carrera&nbsp; : Asistente Judicial (Decreto Exento N&#xB0; 420</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  de 1990).</div><div class=\"p\"> T&#xED;tulo&nbsp;  : T&#xE9;cnico Asistente Judicial.</div><div class=\"p\"> Carrera&nbsp; : Turismo (Resoluci&#xF3;n Exenta N&#xB0; 3.053/82).</div><div class=\"p\"> T&#xED;tulo&nbsp;  : T&#xE9;cnico en Turismo</div><br><div class=\"p\"> Sede N&#xB0; 6 - Puerto Montt</div><div class=\"p\"> Carrera&nbsp; : Turismo (Resoluci&#xF3;n Exenta N&#xB0; 3.053/82).</div><div class=\"p\"> T&#xED;tulo&nbsp;  : T&#xE9;cnico en Turismo.</div><br></div>", "i": 5941207}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 5941208}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "107", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-107"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 107 EXENTO, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA CIDEC", "CHILLAN", "PUERTO MONTT", "ASISTENTE SOCIAL", "TURISMO", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_trata