{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DEROGA DFL. N&#xB0; 6, DE 1967 Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5982556}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Der&#xF3;gase, a contar del 1&#xB0; de</div><div class=\"p\">Agosto de 1972, el DFL N&#xB0; 6, de 30 de Septiembre de</div><div class=\"p\">1967, dictado en uso de las facultades conferidas por el</div><div class=\"p\">art&#xED;culo 249 de la ley N&#xB0; 16.617.&quot;.</div><br></div>", "i": 5982557}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a catorce de de Julio de mil novecientos setenta y dos.- SALVADOR ALLENDE GOSSENS.- Orlando Millas C.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda atentamente a Ud.- Patricio Morales Salinas, Subsecretario de Hacienda.</div><br></div>", "i": 5982558}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "17692", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-17692"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DEROGA DFL. N° 6, DE 1967", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DEROGACION", "DFL-6", "MINISTERIO RELACIONES EXTERIORES", "1967", "EFECTO RETROACTIVO", "RETROACTIVIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1971-07-14", "doble_articulado": false, "id_norma": "29218", "numero_fuente": "28329", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "