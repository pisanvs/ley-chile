{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Fija la tarifa que corresponde cobrar a la Municipalidad de Chillan por los animales que se introduzcan a la Feria Municipal.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,809.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275621}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.-Se autoriza a la Municipalidad de Chillan para cobrar veinte centavos por cada animal vacuno o caballar i diez centavos por cada ovino o porcino, que se introduzcan a la feria Municipal. </div></div>", "i": 8275622}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 10 de Setiembre de 1913.- RAMON BARROS LUCO.- Manuel Rivas Vicu&#xF1;a.</div><br></div>", "i": 8275623}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2809", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2809"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "FIJA LA TARIFA QUE CORRESPONDE COBRAR A LA MUNICIPALIDAD DE CHILLAN POR LOS ANIMALES QUE SE INTRODUZCAN A LA FERIA MUNICIPAL.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDAD CHILLAN", "FERIA MUNICIPAL", "ANIMALES", "TARIFAS", "FIJACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": 