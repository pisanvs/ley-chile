{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION 351, DE 1980 </div></div>", "i": 7281571}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 332, de 2 de Junio de 1983, del Director Nacional de Pesca, se modifica la autorizaci&#xF3;n conferida a la Sociedad Pesquera Penco Ltda., por resoluci&#xF3;n 351, de 1980, del Director Nacional de Pesca, en orden a autorizarla adem&#xE1;s para secar algas de los g&#xE9;neros Gracilaria e Iridaea, en forma artificial en la localidad de Lajas Blancas, Ancud, X Regi&#xF3;n, provenientes del litoral de la IX, X y XI Regi&#xF3;n.</div><br></div>", "i": 7281572}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de Junio de 1983.- Ren&#xE9; Maturana Contreras, Subdirector Nacional de Pesca subrogante.</div><br></div>", "i": 7281573}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "332", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-332"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA", "SERVICIO NACIONAL DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION N° 351, DE 1980", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1983-06-02", "doble_articulado": false, "id_norma": "182983", "numero_fuente": "31590", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1983-06-11", "vigencias": [{"desde": "1983-06-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1983-06-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1983-06-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion