{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6231610}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta N&#xB0; 53, de 23 de Enero de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a la Sociedad Empresa de Transportes Til-Til Responsabilidad Limitada</div><div class=\"p\">(Transportes Til-Til), para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6231611}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de Enero de 1986.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6231612}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "53 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-53 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-01-23", "doble_articulado": false, "id_norma": "155241", "numero_fuente": "32389", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-02-04", "vigencias": [{"desde": "1986-02-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-02-04", "fin_vigencia": ""}, "vigencias_versi