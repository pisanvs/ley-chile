{"html": [{"t": "<div><div class=\"p\">AMPLIA PLAZO PARA INICIAR ACTIVIDADES DE ACUICULTURA </div></div>", "i": 6488157}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n (M) 935, de 31 de marzo de 2004, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div><div class=\"p\">&nbsp; &nbsp;  Ampl&#xED;ase por un a&#xF1;o, a contar de la publicaci&#xF3;n en el Diario Oficial de la presente resoluci&#xF3;n, el plazo para iniciar actividades de acuicultura autorizadas mediante resoluci&#xF3;n (M) 1.375, de 17 de julio de 2002, cuyo Proyecto T&#xE9;cnico y Cronograma de Actividades fue aprobado por la resoluci&#xF3;n 842 de 2002, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, Subsecretar&#xED;a de Pesca.</div><br></div>", "i": 6488158}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de julio de 2004.- Por el Subsecretario, Jos&#xE9; Pelayo Castro, Subjefe Subsecretar&#xED;a de Marina.</div><br></div>", "i": 6488159}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "935", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-935"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "AMPLIA PLAZO PARA INICIAR ACTIVIDADES DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-31", "doble_articulado": false, "id_norma": "227789", "numero_fuente": "37913", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-19", "vigencias": [{"desde": "2004-07-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-07-19", "fin_vigenc