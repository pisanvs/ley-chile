{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6367352}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 190, de 22 de enero de 2002, de</div><div class=\"p\">esta Subsecretar&#xED;a, ac&#xF3;gese la renuncia al &#xE1;rea de</div><div class=\"p\">manejo correspondiente al sector denominado Laguna</div><div class=\"p\">Verde, Sector B, V Regi&#xF3;n, individualizada en el</div><div class=\"p\">art&#xED;culo 1&#xBA;) N&#xBA; 2 del D.S. N&#xBA; 717 de 1998, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, presentada por el SINDICATO DE TRABAJADORES INDEPENDIENTES DE LA PESCA ARTESANAL, BUZOS MARISCADORES Y ACTIVIDADES CONEXAS DE CALETA LAGUNA VERDE.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto las resoluciones N&#xBA; 1.837 de 1999 y N&#xBA; 935 de 2000, ambas de esta Subsecretar&#xED;a, en virtud de lo dispuesto en la presente resoluci&#xF3;n.</div><br></div>", "i": 6367353}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de enero de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6367354}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "190", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-190"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-01-22", "doble_articulado": false, "id_norma": "194130", "numero_fuente": "37171", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-28", "vigencias": [{"desde": "2002-01-28", "hasta": "", "tipo_version": "3"