{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8290341}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 110, 19 de Enero de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 756, de 1992, que caduc&#xF3; la Resoluci&#xF3;n N&#xB0; 582, de 1991, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; a don JORGE PAREDES LEIVA, R.U.T. N&#xB0; 5.699.508-0, para operar un establecimiento de cultivo, en virtud de las normas legales, reglamentarias y Resoluciones citadas en Visto, por haberse dictado err&#xF3;neamente.-</div><br></div>", "i": 8290342}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 19 de Enero de 1994.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8290343}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "110", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-110"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JORGE PAREDES LEIVA", "AUTORIZACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-01-19", "doble_articulado": false, "id_norma": "33176", "numero_fuente": "34781", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-02-03", "vigencias": [{"desde": "1994-02-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-02-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-02-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi