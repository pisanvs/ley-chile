{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xBA; 432, DE 1983 </div></div>", "i": 6253177}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 273 de 14 de Mayo de 1985 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 3&#xBA; de la resoluci&#xF3;n 432, de 1983, de la Subsecretaria de Pesca, que autoriz&#xF3; a &quot;Pesquera Torres del Paine Limitada&quot;, para instalar y operar en Punta Arenas, una planta elaboradora de pescados y mariscos congelado, en conserva y fresco, en orden a incluir el recurso raya, entre los que puede utilizar como materia prima en la elaboraci&#xF3;n de los productos se&#xF1;alados.</div><br></div>", "i": 6253178}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de mayo de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6253179}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "273", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-273"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION Nº 432, DE 1983", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-14", "doble_articulado": false, "id_norma": "161755", "numero_fuente": "32191", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-08", "vigencias": [{"desde": "1985-06-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-06-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-06-08", "fin_vigencia": "",