{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6543509}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.137, de 27 de septiembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a SOLARIUM BIOTECHNOLOGY S.A., para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Km. 27.5 ruta A-665, La Huayca, comuna de Pozo Almonte, provincia de Iquique, I Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Polvo de Microalgas, el recurso hidrobiol&#xF3;gico indicado en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6543510}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de septiembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6543511}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3137 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3137 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-27", "doble_articulado": false, "id_norma": "242833", "numero_fuente": "38286", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-10-14", "vigencias": [{"desde": "2005-10-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-10-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-10-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingr