{"html": [{"t": "<div><div class=\"p\">MODIFICA EL ANEXO 51-3, RELATIVO A &quot;AGENTES DE ADUANA&quot;, DEL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10245657}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 1.469, de 15.06.2021, del Director Nacional de Aduanas, se modific&#xF3; el Anexo 51-3, relativo a &quot;Agentes de Aduana&quot;, en el siguiente sentido:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Elim&#xED;nese, de la tabla del citado Anexo al Agente de Aduana Sr. Juan Pablo Schweitzer, c&#xF3;digo F-49, en circunstancias que fue licencia y nombramiento para actuar como tal fue cancelado.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10245658}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de junio de 2021.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><div class=\"p\"> </div><br></div>", "i": 10245659}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1469 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1469 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA EL ANEXO 51-3, RELATIVO A \"AGENTES DE ADUANA\", DEL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1964182", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-06-15", "doble_articulado": false, "id_no