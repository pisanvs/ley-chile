{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6558335}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 165, de 12 de enero de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BIO BIO S.A. para continuar desarrollando actividades pesqueras con una nave en construcci&#xF3;n autorizada para operar mediante resoluci&#xF3;n N&#xBA; 3.645 de 2005, de la Subsecretar&#xED;a de Pesca, y con la nave &quot;Oce&#xE1;nica 3&quot;, las que fueran autorizadas a Pesquera San Pablo S.A., todo ello en virtud del contenido de la presente resoluci&#xF3;n. </div></div>", "i": 6558336}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de enero de 2006.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6558337}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "165 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-165 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-12", "doble_articulado": false, "id_norma": "246603", "numero_fuente": "38368", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-01-20", "vigencias": [{"desde": "2006-01-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-01-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-01-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresa