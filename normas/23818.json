{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede fondos para gastos de alimentacion de reos Lei n&#xFA;m. 3,215.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7166453}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que invierta hasta la cantidad de doscientos sesenta i cinco mil pesos ($ 265,000,) en atender al mayor gasto que se ocasione durante los meses de Noviembre i Diciembre de 1916 en el servicio de alimentacion de reos.</div><br></div>", "i": 7166454}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 29 de Enero de 1917.- JUAN LUIS SANFUENTES.- Pedro F. I&#xF1;iguez.</div><br></div>", "i": 7166455}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3215", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3215"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDE FONDOS PARA GASTOS DE ALIMENTACION DE REOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REOS", "ALIMENTACION", "GASTOS", "FONDOS", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1917-01-29", "doble_articulado": false, "id_norma": "23818", "numero_fuente": "11686", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1917-01-30", "vigencias": [{"desde": "1917-01-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic