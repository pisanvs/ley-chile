{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  MONEDAS SIN LEI.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Agosto 17 de 1832. </div><br><div class=\"p\">&nbsp; &nbsp;  Habiendo resultado del ensaye que el Gobierno mand&#xF3; hacer de siete monedas de oro y nueve de plata, acu&#xF1;adas en la Rioja en diferentes a&#xF1;os, que su lei no corresponde a la que pide la ordenanza, el Presidente de la Rep&#xFA;blica, ha acordado y decreta:</div></div>", "i": 10264980}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art. &#xFA;nico. Las tesorer&#xED;as y demas oficinas fiscales no admitir&#xE1;n en lo sucesivo monedas de oro o plata selladas en la Rioja.</div></div>", "i": 10264981}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon y comun&#xED;quese a quienes corresponda.</div><br><br><div class=\"p\">&nbsp; &nbsp;  PRIETO.</div><br><div class=\"p\">&nbsp; &nbsp;  Rengifo.</div></div>", "i": 10264982}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "MONEDAS SIN LEI.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-08-17", "doble_articulado": false, "id_norma": "1160871", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-08-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-08-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion