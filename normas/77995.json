{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8308407}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 648, de 15 de Julio de 1992, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por un a&#xF1;o a contar del 20 de marzo de 1992, el plazo otorgado a HATFIELD INTERNATIONAL S.A., R.U.T. No. 95.435.000-2, domiciliada en Santiago, en el numeral 5&#xB0; de las resoluciones No. 847 y No. 923, ambas de 1989, de esta Subsecretar&#xED;a, el que ya hab&#xED;a sido prorrogado por la resoluci&#xF3;n No. 219, de 1991, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8308408}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 15 de Julio de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8308409}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "648", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-648"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-07-15", "doble_articulado": false, "id_norma": "77995", "numero_fuente": "34330", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-07-31", "vigencias": [{"desde": "1992-07-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-07-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-07-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac