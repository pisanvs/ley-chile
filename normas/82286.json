{"html": [{"t": "<div><div class=\"p\">PRORROGA AUTORIZACION QUE INDICA</div><div class=\"p\">(Extracto) </div></div>", "i": 8313473}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 1.032 de 23 de Agosto de 1990 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por un a&#xF1;o a contar de la fecha de la presente Resoluci&#xF3;n, el plazo otorgado a don Claudio Larco Brice&#xF1;o, R.U.T. No. 8.316.496-4, domiciliado en Isla Picton No. 140, Caldera, para empezar a operar el establecimiento de cultivo autorizado por Resoluci&#xF3;n No. 321, de 1989, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor. </div></div>", "i": 8313474}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 23 de Agosto de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8313475}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1032", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1032"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "PRORROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-08-23", "doble_articulado": false, "id_norma": "82286", "numero_fuente": "33775", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-09-22", "vigencias": [{"desde": "1990-09-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-09-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-09-22", "fin_vigencia": "", "tipo