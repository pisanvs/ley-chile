{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br></div>", "i": 6263849}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 529, del 27 de Diciembre de 1984, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Coquimbo, se autoriza do&#xF1;a Ana de Lourdes Zabala Cort&#xE9;s para efectuar todo tipo de servicio de transporte de pasajeros por calles y caminos dentro del territorio nacional la excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6263850}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Serena, 27 de Diciembre de 1984.- Dante Guerra Tallar, Secretario Regional Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n de Coquimbo subrogante. </div></div>", "i": 6263851}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "529 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-529 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IV REGIÓN COQUIMBO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-12-27", "doble_articulado": false, "id_norma": "165158", "numero_fuente": "32061", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-01-03", "vigencias": [{"desde": "1985-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-01-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-01-03", "fin_v