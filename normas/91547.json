{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUAS EN COMUNA DE CHIMBARONGO</div><br><br></div>", "i": 6089254}, {"t": "<div><div class=\"p\">Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 375, de fecha 17 de Marzo de 1989, conforme art. 5&#xB0; transitorio C&#xF3;digo Aguas, determin&#xF3; derechos aprovechamiento aguas que corresponden a las Parcelas Nos 1 a la 24; Reservas Cora Nos 1 y 2 y Propiedad Escuela del Proyecto de Parcelaci&#xF3;n de la Colonia San Antonio de Chimbarongo de la comuna de Chimbarongo, VI Regi&#xF3;n, formado por predio fundo San Antonio.</div><div class=\"p\">Los derechos de aguas se extraen del Canal La Punta, derivado del r&#xED;o Tinguiririca.</div><div class=\"p\">Publicaci&#xF3;n hecha conforme art. 13, Ley No. 18.377.- </div></div>", "i": 6089255}, {"t": "<div><div class=\"p\">Director Nacional.</div><br></div>", "i": 6089256}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "375 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-375 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DERECHOS DE AGUAS EN COMUNA DE CHIMBARONGO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-03-17", "doble_articulado": false, "id_norma": "91547", "numero_fuente": "33336", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-04-01", "vigencias": [{"desde": "1989-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-04-01", "fin_vigencia": "", "tipo_version":