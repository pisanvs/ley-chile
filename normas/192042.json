{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6359143}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA;146, del 27 de diciembre del a&#xF1;o 2000, se autoriz&#xF3; la existencia y aprob&#xF3; el estatuto de la Cooperativa de Trabajo Ancud, de nombre de fantas&#xED;a Huaihuen, de la comuna de Ancud, en los t&#xE9;rminos que da testimonio el acta constitutiva protocolizada con fecha 24 de octubre del 2000, bajo el N&#xBA;1.358, y el acta rectificatoria protocolizada con fecha 27 de noviembre del mismo a&#xF1;o, bajo el N&#xBA;1.552, al final de los registros del Notario de Ancud, do&#xF1;a Martita W&#xF6;rner Tapia.</div><br></div>", "i": 6359144}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6359145}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "146", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-146"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-12-27", "doble_articulado": false, "id_norma": "192042", "numero_fuente": "37121", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-27", "vigencias": [{"desde": "2001-11-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-11-27", "fin_vigencia": ""}, "vigencias_