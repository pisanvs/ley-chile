{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Agrega un inciso al art&#xED;culo 1.o de la ley 4,230, de 22 de Diciembre de 1927</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5959570}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.o Agr&#xE9;gase al art&#xED;culo 1.o de la ley n&#xFA;mero 4,230, de 22 de Diciembre de 1927, el inciso siguiente:</div><div class=\"p\">&nbsp; &nbsp; &quot;Esta exenci&#xF3;n incluir&#xE1; el impuesto complementario a la renta que afecte al tenedor de los bonos por razon de la renta derivada de los mismos&quot;.</div><br></div>", "i": 5959571}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 2.o Esta ley empezar&#xE1; a regir desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 5959572}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.-</div><div class=\"p\">&nbsp; &nbsp; Santiago, diez de Septiembre de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- Pablo Ram&#xED;rez. </div></div>", "i": 5959573}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4410", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4410"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "AGRAGA UN INCISO AL ARTICULO 1.º DE LA LEY 4,230, DE 22 DE DICIEMBRE DE 1927", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BONOS", "EMISION", "GARANTIA ESTADO", "IMPUESTO RENTA", "COMPLEMENTARIO", "EXENCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-09