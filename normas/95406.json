{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 94, DE 1989 </div></div>", "i": 6099904}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 94 de 12 de mayo de 1989 se ha aprobado, a contar del a&#xF1;o 1989 y hasta el a&#xF1;o 1992 a los Liceos Industriales A No. 19 de Santiago y A No. 16 de La Calera, planes especiales de estudio para el primer y segundo ciclo de la Educaci&#xF3;n Media de Adultos, modalidad T&#xE9;cnico - Profesional, en las especialidades que se indican: - Liceo Industrial A No. 19 de Santiago.</div><div class=\"p\">Especialidades:</div><div class=\"p\">* Aire Acondicionado.</div><div class=\"p\">* Construcci&#xF3;n Habitacional.</div><div class=\"p\">- Liceo Industrial A No. 16 de La Calera.</div><div class=\"p\">Especialidades:</div><div class=\"p\">* Instalaciones El&#xE9;ctricas.-</div><br></div>", "i": 6099905}, {"t": "<div><div class=\"p\">Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6099906}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "94 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-94 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 94, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-12", "doble_articulado": false, "id_norma": "95406", "numero_fuente": "33404", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-06-22", "vigencias": [{"desde": "1989-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "