{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; MODIFICA RESOLUCION QUE INDICA</div><br></div>", "i": 8339967}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 851 de 17.08.88 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. Modif&#xED;case la resoluci&#xF3;n No. 630, del 22.06.87, modificatoria de la resoluci&#xF3;n No. 142, de 1986, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; a Pesquera Auro S.A. a operar la embarcaci&#xF3;n &quot;Auro&quot; en construcci&#xF3;n, en orden a sustituir el nombre por el de &quot;Claudia Alejandra&quot;. </div></div>", "i": 8339968}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17.08.88.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8339969}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "851", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-851"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-17", "doble_articulado": false, "id_norma": "130945", "numero_fuente": "33162", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-09-02", "vigencias": [{"desde": "1988-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-09-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIF