{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9074935}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.658, de 2 de diciembre de 2010, de esta Subsecretar&#xED;a, d&#xE9;jese sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=1015201&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.026 de 2010</a>, de esta Subsecretar&#xED;a, que declar&#xF3; la caducidad total de las resoluciones exentas N&#xBA; 4.030 de 2005 y N&#xBA; 820 de 2008, ambas de esta Subsecretar&#xED;a, que autorizaron don Giovanni Arancibia Fuentes para desarrollar actividades pesqueras extractivas con la nave &quot;Isla Tab&#xF3;n&quot;, en virtud de haberse acreditado el pago de la patente &#xFA;nica pesquera correspondiente al a&#xF1;o 2010.</div><br></div>", "i": 9074936, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de diciembre de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9074937}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3658 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-3658 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-02", "doble_articulado": false, "id_norma": "1020642", "numero_fuente": "39831", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-12-10", "vigencias": [{"desde": "2010-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-12-10", "fin_vigencia