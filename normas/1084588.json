{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9652605}, {"t": "<div><div class=\"p\">&nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. (Exento) N&#xBA; 1368, de 24 de noviembre de 2015, se rectific&#xF3; el numeral 6&#xBA; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1084025&amp;idParte=&amp;idVersion=\">Decreto MOP. (Exento) N&#xBA; 1084, de 23 de octubre de 2015</a>, que orden&#xF3; la expropiaci&#xF3;n del lote N&#xBA; 143, en el siguiente aspecto: donde dice: &quot;DOS MILLONES DOSCIENTOS CUARENTA Y SIETE MIL CUATROCIENTOS VEINTITR&#xC9;S PESOS ($2.247.423.-)&quot;, debe decir: DOS MILLONES CUATROCIENTOS SESENTA Y SIETE MIL CUATROCIENTOS VEINTITR&#xC9;S PESOS ($2.467.423.-). La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA; 2186, de 1978.</div></div>", "i": 9652606}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1368 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1368 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 971445", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-11-24", "doble_articulado": false, "id_norma": "1084588", "numero_fuente": "41321", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-12-01", "vigencias": [{"desde": "2015-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2015-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2015-12-01", "fin_vigencia": "", "tipo_version": "3"}], "even