{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6264760}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. No. 372, de 29 de noviembre de 1985, se expropi&#xF3; el lote No. 1 y se constituy&#xF3; servidumbre de tr&#xE1;nsito y acueducto sobre el lote No. 2, cuyas superficies son 1.716,06 m2. y 577,50 m2., respectivamente, rol de aval&#xFA;o 3207-31, Comuna de Temuco, IX Regi&#xF3;n para Alcantarillado de Temuco, Recinto Planta Elevadora de aguas servidas, sector amanecer y se acord&#xF3; el precio de indemnizaci&#xF3;n con su propietario Juan Carlos Ruiz Rodr&#xED;guez, ascendente $ 463.271. </div></div>", "i": 6264761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. (16) </div></div>", "i": 6264762}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "372", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-372"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-11-29", "doble_articulado": false, "id_norma": "165469", "numero_fuente": "32348", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-16", "vigencias": [{"desde": "1985-12-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-12-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-12-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2000-04-14", "fecha_version": "1985-12-16", "fecha_actualizacion_texto": "1985-12-1