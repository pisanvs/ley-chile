{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6423767}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;255, de fecha 28 de marzo de 2003, se expropi&#xF3; el lote de terreno N&#xBA;37, superficie 243 m2., rol de aval&#xFA;o 221-28, comuna de Coelemu, para la obra &quot;Camino Ruta O-170, O-176, Acceso a Guarilihue, Km. 0,00000 a Km. 8,28000&quot;, VIII Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Pedro Segundo G&#xF3;mez Godoy, ascendente a la cantidad de $4.801.371. </div></div>", "i": 6423768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6423769}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "255", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-255"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-03-28", "doble_articulado": false, "id_norma": "210279", "numero_fuente": "37559", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-05-15", "vigencias": [{"desde": "2003-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2003-05-15", "fecha_version": "2003-05-15", "fecha_actualizacion_texto": "2003-05-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabez