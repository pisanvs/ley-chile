{"html": [{"t": "<div><div class=\"p\">&#xFEFF;INTENDENTE DE SANTIAGO &#x2013; SE NOMBRA.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Abril 7 de 1830.</div></div>", "i": 10250263}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Careciendo esta Provincia de Santiago de Intendente y Vice-Intendente, y queriendo el Gobierno promoverla de ambos funcionarios, tan necesarios en las actuales circunstancias, en uso de la facultad de que esta investido, tiene a bien nombrar, para el primer cargo, al Coronel don Enrique Campino, y para el segundo al Teniente coronel don Pedro N. Uriondo, cuya idoneidad y distinguidos m&#xE9;ritos han impulsado este nombramiento, que ha merecido la aprobacion del Congreso nacional de plenipotenciarios.</div></div>", "i": 10250264}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Trascr&#xED;base a quienes corresponda, t&#xF3;mese razon y publ&#xED;quese.</div><br><div class=\"p\">&nbsp; &nbsp;  OVALLE.</div><div class=\"p\">&nbsp; &nbsp;  Portales.</div></div>", "i": 10250265}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "﻿INTENDENTE DE SANTIAGO – SE NOMBRA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1830-04-07", "doble_articulado": false, "id_norma": "1159516", "numero_fuente": "1830", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1830-04-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1830-04-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici