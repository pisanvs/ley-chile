{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6516362}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 339, de 9 de febrero de</div><div class=\"p\">2005, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto la</div><div class=\"p\">resoluci&#xF3;n N&#xBA; 3.376 de 2004, de esta Subsecretar&#xED;a, que</div><div class=\"p\">rechaz&#xF3; la solicitud N&#xBA; 98101053, presentada por JUAN</div><div class=\"p\">VICTOR PE&#xD1;A IMILMAQUI para un centro de cultivo ubicado</div><div class=\"p\">en estero Reloncav&#xED;, islote Barquitos, en virtud del</div><div class=\"p\">art&#xED;culo 59 de la ley N&#xBA; 19.880, y por haber sido dictada fundada en un error de hecho.</div><br></div>", "i": 6516363}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de febrero de 2005.- Jessica Fuentes Olmos, Subsecretario de Pesca (S).</div><br></div>", "i": 6516364}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "339 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-339 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-02-09", "doble_articulado": false, "id_norma": "235601", "numero_fuente": "38089", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-02-17", "vigencias": [{"desde": "2005-02-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-02-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-02-17", "fin_vigencia": "", "tipo_