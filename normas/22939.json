{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Eleva a puerto mayor el puerto menor de cordillera de Nahuelhuapi.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1817.- Santiago, a 7 de Febrero de 1906.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7164454}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se eleva a la categor&#xED;a de puerto mayor el puerto menor de cordillera de Nahuelhuapi, que en adelante se donominar&#xE1; de Casa-Pangue, i se establecer&#xE1; en el lugar de este nombre.</div><br></div>", "i": 7164455}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Belfor Fernandez.</div><br></div>", "i": 7164456}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1817", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1817"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ELEVA A PUERTO MAYOR EL PUERTO MENOR DE CORDILLERA DE NAHUELHUAPI", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NAHUELHUAPI", "PUERTO", "CASA PANGUE", "ELEVACION", "CATEGORIA", "DENOMINACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-02-07", "doble_articulado": false, "id_norma": "22939", "numero_fuente": "8426", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1906-02-09", "vigencias": [{"desde": "1906-02-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1906-02-09", "fin_vigen