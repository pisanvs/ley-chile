{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6147579}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 1.159 de 11 de agosto de 1988, de Ministerio de Transportes y Telecomunicaciones Subsecretaria de Transportes se autoriza a la Sociedad Gonz&#xE1;lez y Compa&#xF1;&#xED;a Limitada (Transporte Aconcagua Santiago T.A.S. Choapa Limitada o T.A.S. Choapa Limitada), para efectuar servicio internacional de transporte terrestre de pasajeros entre Santiago (Chile) y San Carlos de Bariloche (Argentina), por Paso Puyehue, el que se atender&#xE1; con una frecuencia semanal.-</div><br></div>", "i": 6147580}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Manuel G&#xE1;rate Meneses, Coronel, Subsecretario de Transportes.</div><br></div>", "i": 6147581}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1159 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1159 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-11", "doble_articulado": false, "id_norma": "129651", "numero_fuente": "33159", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-08-30", "vigencias": [{"desde": "1988-08-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-08-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-08-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT