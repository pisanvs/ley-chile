{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7291530}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 738, de 12 de abril de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a CONSTRUCCIONES Y CARPINTERIA NAVAL CONCAR S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluciones N&#xBA; 1.159 y N&#xBA; 1.441, ambas de 1996, N&#xBA; 701 de 1998, N&#xBA; 122 de 1999 y N&#xBA; 2.248 de 2000, todas de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Lote 5 D 5, Sector R&#xED;o Guanaco, comuna de Navarino, Puerto Williams, XII Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de Cocido, Congelado y Conserva, el recurso hidrobiol&#xF3;gico Ostra del Pac&#xED;fico.</div><br></div>", "i": 7291531}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de abril de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7291532}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "738", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-738"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-12", "doble_articulado": false, "id_norma": "197761", "numero_fuente": "37251", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-06", "vigencias": [{"desde": "2002-05-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-06"