{"html": [{"t": "<div><br><div class=\"p\">EXTRACTOS DE RESOLUCIONES EXENTAS</div><br><div class=\"p\">NOTIFICACIONES</div></div>", "i": 9682449}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Res. Ex. N&#xBA;1.022 de 21/12/15. Exp. N&#xBA;1501777. Vistos: La Ley 18.755; Ley N&#xBA;18.575, resoluci&#xF3;n N&#xBA;1.600/2008 de la CGR. Considerando: 1.- ADC N&#xBA;097061, se&#xF1;ala que se encuentra 1 manzana que no fue declarada. 2.- Que, la infractora se&#xF1;ala que olvid&#xF3; comerse la manzana y fue por ello que se no la declar&#xF3;. 3.- Que, la infractora no registra denuncias anteriores. Resuelvo: Absu&#xE9;lvase por esta &#xFA;nica vez a do&#xF1;a Romualda Rejas de Cardozo, Pasaporte N&#xBA;3274123, nacionalidad boliviana, domicilio indeterminado.- </div></div>", "i": 9682450}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  C&#xE9;sar Cardozo Rojas, Director Regional Regi&#xF3;n de Tarapac&#xE1; Servicio Agr&#xED;cola y Ganadero. </div></div>", "i": 9682451}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1022 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-1022 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTOS DE RESOLUCIONES EXENTAS; NOTIFICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1003887", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-12-21", "doble_articulado": false, "id_norma": "1088382", "numero_fuente": "41408", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-03-15", "vigencias": [{"desde": "2016-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"i