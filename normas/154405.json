{"html": [{"t": "<div><div class=\"p\">DECLARA CADUCIDAD DE RESOLUCION QUE INDICA </div></div>", "i": 6228892}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.064, de 09.09.87, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se declara la caducidad de la resoluci&#xF3;n No. 430, de 19 de Mayo de 1986, de esta entidad, que autoriz&#xF3; a operar a &quot;Pesquera Yadr&#xE1;n Sociedad Limitada&quot; un establecimiento de cultivo de Osti&#xF3;n del Norte, en Bah&#xED;a Guanaqueros, IV Regi&#xF3;n, por haber incurrido en la causal establecida en el art&#xED;culo 7&#xB0; del decreto No. 175 de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 6228893}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 09.09.87.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 6228894}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1064", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1064"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "DECLARA CADUCIDAD DE RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-09", "doble_articulado": false, "id_norma": "154405", "numero_fuente": "32881", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-29", "vigencias": [{"desde": "1987-09-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-09-29