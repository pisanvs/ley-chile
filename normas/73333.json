{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6038555}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 375, de 21 de abril de 1997, se expropiaron los lotes de terreno N&#xBA;s. 1 y 3, superficies 105.758 m2. y 1.370 m2, roles de aval&#xFA;os 191-21 y 191-25, comuna de Arauco, obra Camino Arauco Llico, sector Curaquilla-Llico y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Rodolfo Gaete Jenicek y otra y Rodolfo Gaete Jenicek, ascendente a las cantidades de $13.449.187 y $392.326.</div><br></div>", "i": 6038556}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6038557}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "375", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-375"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "ARAUCO", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-21", "doble_articulado": false, "id_norma": "73333", "numero_fuente": "35779", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-06-02", "vigencias": [{"desde": "1997-06-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-06-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-06-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "GMR", "fecha_ingreso": "1997-06-18", "fecha_version": "1997-06-02", "fecha_actualizacion_texto": "1997-06-02", "tipo_tratado": ""}, "aler