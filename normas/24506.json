{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aprueba la Convenci&#xF3;n Postal Universal, sus Convenios, Protocolos y Reglamentos, subscrita en Madrid el 30 de Noviembre de 1920.</div><br><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 8801578}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Apru&#xE9;base la Convenci&#xF3;n Postal Universal, sus Convenios, Protocolos y Reglamentos respectivos, subscrita en Madrid, el 30 de Noviembre de 1920.</div><br><br></div>", "i": 8801579}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, dieciocho de Julio de mil novecientos veintisiete.- Carlos Ib&#xE1;&#xF1;ez C.- Aquiles Vergara. </div></div>", "i": 8801580}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4141", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4141"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES"], "titulo_norma": "APRUEBA LA CONVENCIÓN POSTAL UNIVERSAL, SUS CONVENIOS, PROTOCOLOS Y REGLAMENTOS, SUBSCRITA EN MADRID EL 30 DE NOVIEMBRE DE 1920", "fuente": "", "resumenes": [], "materias": ["Convención Postal Universal"], "terminos_libres": ["CONVENCION POSTAL UNIVERSAL", "CONVENIOS", "PROTOCOLOS", "REGLAMENTOS", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1927-07-18", "doble_articulado": false, "id_norma": "24506", "numero_fuente": "14832", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1927-07-28", "vigencias": [{"de