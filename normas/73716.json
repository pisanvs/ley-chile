{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6039767}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 280 de 31 de marzo de 1997, se expropiaron los lotes de terreno N&#xBA;s 1, 9-B y 9, Canal Rinconada y lote N&#xBA; 5, Canal Rinconada Ramal N&#xBA; 3, superficies 1.668, 570, 714 y 3.054, Roles de Aval&#xFA;o 591-67, 590-37, 590-1 y 590-28, comuna de Yungay, para la obra Proyecto Laja Diguill&#xED;n, Area de Riego Yungay, Canal Rinconada y Canal Rinconada Ramal N&#xBA; 3 y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Segundo Alfredo Mu&#xF1;oz Ocampo, Alonso Arturo Panes Jara, Jos&#xE9; Santiago Mu&#xF1;oz Vallejos y Matilde Rosa Mu&#xF1;oz Gonz&#xE1;lez, ascendente a las cantidades de $383.583, $196.621, $441.177 y $951.491, respectivamente.-</div><br></div>", "i": 6039768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6039769}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "280", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-280"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "YUNGAY", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-31", "doble_articulado": false, "id_norma": "73716", "numero_fuente": "35791", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-06-16", "vigencias": [{"desde": "1997-06-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-06-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici