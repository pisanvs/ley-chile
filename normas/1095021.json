{"html": [{"t": "<div><br><div class=\"p\">Pago de la contribucion mensual</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de Mayo de 1819.</div><br></div>", "i": 9739350}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Con el objeto de aliviar al vecindario en el pago de la mensualidad, vengo en permitir que los Ministros de la Tesorer&#xED;a Jeneral reciban en plata de chafalon&#xED;a a siete pesos marco, a quienes se les prohibe el que puedan hacer ningun pago en chafalon&#xED;a, sino que la remitir&#xE1;n a la casa de Moneda: p&#xF3;ngase en noticia de los Ministros, e impr&#xED;mase.-</div></div>", "i": 9739351}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  O&apos;Higgins.- Cruz.</div></div>", "i": 9739352}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Pago de la contribucion mensual", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1819-05-27", "doble_articulado": false, "id_norma": "1095021", "numero_fuente": "0", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1819-05-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1819-05-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1819-05-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "362", "fecha_ingreso": "2016-10-13", "fecha_version": "1819-05-27", "fecha_actualizacion_texto": "2016-10-13", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estru