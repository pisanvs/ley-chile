{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 972 EXENTA, DE 2011</div></div>", "i": 9107908}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 972, de 27 de enero de 2011, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la sociedad &quot;Centro T&#xE9;cnico de Capacitaci&#xF3;n Choapa Limitada&quot; (Cetech Ltda.), RUT 76.053.421-8, contenida en la resoluci&#xF3;n exenta N&#xBA;11.677, de 11 de diciembre de 2009, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 3, del art. 21 de la ley 19.518.</div></div>", "i": 9107909}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jos&#xE9; Miguel Bergu&#xF1;o Ca&#xF1;as, Director Nacional.</div></div>", "i": 9107910}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "972 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-972 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 972 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-01-27", "doble_articulado": false, "id_norma": "1022823", "numero_fuente": "39879", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-02-07", "vigencias": [{"desde": "2011-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-02-07", "fin_vigencia": "", "tipo_version": "3"}],