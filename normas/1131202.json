{"html": [{"t": "<div><br><div class=\"p\">CREA MODELO DE CERTIFICADO QUE INDICA</div></div>", "i": 10020078}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 51, de 30 de abril de 2019, que establece:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Crea modelo de certificado N&#xBA; 62, sobre donaciones efectuadas a los &#xF3;rganos y servicios p&#xFA;blicos incluidos en la Ley de Presupuestos, que forman parte del Fisco.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de abril de 2019.</div></div>", "i": 10020079}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "51 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-51 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CREA MODELO DE CERTIFICADO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1584734; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-04-30", "doble_articulado": false, "id_norma": "1131202", "numero_fuente": "42345", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-05-04", "vigencias": [{"desde": "2019-05-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-05-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2019-05-04", "fin_vigencia": "", "tipo_