{"html": [{"t": "<div><div class=\"p\">AGREGA COMUNA DE LA LIGUA A NOMINA QUE INDICA (Resoluci&#xF3;n)</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 16.- Santiago, 05 de Mayo de 1988.- Vistos: Lo dispuesto en el Art&#xED;culo 95&#xB0; de la Ley de Tr&#xE1;nsito No.</div><div class=\"p\">18.290; en el Art&#xED;culo 2&#xB0; del Decreto Supremo No. 48 de 1985 del Ministerio de Transportes y Telecomunicaciones, </div><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 6182292}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.- Agr&#xE9;gase la comuna de La Ligua a la n&#xF3;mina establecida en el No. 1 de la resoluci&#xF3;n No. 51/85 del Ministerio de Transportes y Telecomunicaciones. </div></div>", "i": 6182293}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- Jorge Massa Armijo, General de Brigada A&#xE9;rea, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo para su conocimiento.- Saluda a Ud.- Patricia Mu&#xF1;oz Villela, Jefe Depto. Administrativo. </div></div>", "i": 6182294}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "16", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-16"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "AGREGA COMUNA DE LA LIGUA A NOMINA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-05-05", "doble_articulado": false, "id_norma": "140509", "numero_fuente": "33077", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-05-23", "vigencias": [{"desde": "1988-05-23", "hasta"