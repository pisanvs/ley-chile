{"html": [{"t": "<div><div class=\"p\">AUTORIZA EMISOR DE BOLETAS ELECTRONICAS </div></div>", "i": 6587509}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 127, de 23 de octubre de 2006, que autoriza a contribuyente como emisor de boletas electr&#xF3;nicas.</div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de boletas electr&#xF3;nicas al contribuyente RUT 96.568.740-8 a contar del mes de octubre de 2006.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de octubre de 2006.</div><br></div>", "i": 6587510}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "127 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-127 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISOR DE BOLETAS ELECTRONICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-10-23", "doble_articulado": false, "id_norma": "254612", "numero_fuente": "38598", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-10-26", "vigencias": [{"desde": "2006-10-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-10-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-10-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CM