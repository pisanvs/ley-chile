{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 927 EXENTA, DE 16.02.2018</div></div>", "i": 9890610}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por el presente acto administrativo, se ha autorizado, a contar del a&#xF1;o escolar 2018, la readecuaci&#xF3;n del plan y programas especiales de estudio de 2&#xB0; a&#xF1;o de Educaci&#xF3;n Media, al Liceo A-1 Javiera Carrera&quot;, comuna y provincia de Santiago, Regi&#xF3;n Metropolitana.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas especiales de estudio de las asignaturas de Biolog&#xED;a, Qu&#xED;mica y F&#xED;sica de 2&#xBA; a&#xF1;o de Educaci&#xF3;n Media.</div></div>", "i": 9890611}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de febrero de 2018.- Francisco Jeria Le&#xF3;n, Subsecretario de Educaci&#xF3;n (S).</div></div>", "i": 9890612}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "927 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-927 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 927 EXENTA, DE 16.02.2018", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1357654", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-02-16", "doble_articulado": false, "id_norma": "1115588", "numero_fuente": "41993", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-02-26", "vigencias": [{"desde": "2018-02-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2018-02-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2018-02-26", "fin_vigencia": "", "tipo_v