{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 197 EXENTA, DE 2016</div></div>", "i": 9717170}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La VI Direcci&#xF3;n Regional Rancagua del S.I.I., por resoluci&#xF3;n Ex. N&#xBA; 197, de fecha 18.05.2016, otorga la calidad de Agente Retenedor del Impuesto al Valor Agregado en la Carne, a Ganadera R&#xED;o Loco SpA, RUT N&#xBA; 76.280.235-K. Dicho acto de autoridad regir&#xE1; a contar del d&#xED;a primero del mes siguiente al de esta publicaci&#xF3;n, de acuerdo a lo establecido en la resoluci&#xF3;n exenta S.I.I. N&#xBA; 3.722 del 28.07.2000, de la Direcci&#xF3;n Nacional.</div></div>", "i": 9717171}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Rancagua, 15 de junio de 2016.- Claudio Ambiado Araya, Director Regional.</div><br></div>", "i": 9717172}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "197 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-197 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VI DIRECCIÓN REGIONAL RANCAGUA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 197 EXENTA, DE 2016", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1044335; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-05-18", "doble_articulado": false, "id_norma": "1092776", "numero_fuente": "41513", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-07-21", "vigencias": [{"desde": "2016-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2016-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2016-08-01", "fin_vigencia": "", "ti