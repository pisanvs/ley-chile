{"html": [{"t": "<div><br><div class=\"p\">INFORMA CONSTITUCI&#xD3;N LEGAL DEL PARTIDO PROGRESISTA</div></div>", "i": 9335011}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Marco Enr&#xED;quez-Ominami Gumucio, Presidente de la Directiva Central del Partido Progresista, ha solicitado la constituci&#xF3;n legal del partido en la VIII Regi&#xF3;n del Biob&#xED;o. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de cinco mil trescientas treinta y seis (5.336) fichas de afiliaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xBA; de la ley N&#xBA; 18.603, por resoluci&#xF3;n O-N&#xBA; 23, de fecha 12 de febrero de 2013.- </div></div>", "i": 9335012}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div></div>", "i": 9335013}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "23", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-23"}, {"tipo": "3", "numero": "O-23", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-23"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "INFORMA CONSTITUCIÓN LEGAL DEL PARTIDO PROGRESISTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-02-12", "doble_articulado": false, "id_norma": "1049076", "numero_fuente": "40493", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-02-23", "vigencias": [{"desde": "2013-02-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-02-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig