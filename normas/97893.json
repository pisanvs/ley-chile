{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8329130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;431, de 6 de abril de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto el punto 4) del numeral 1 de la resoluci&#xF3;n N&#xBA;1.081, de 1996, solamente en cuanto declar&#xF3; la caducidad de la resoluci&#xF3;n N&#xBA;179, de 1991, de esta Subsecretar&#xED;a, que autoriz&#xF3; a do&#xF1;a LITA DEL CARMEN VILLARROEL GUTIERREZ, para operar la nave &apos;&apos;Juan Antonio I&apos;&apos;, manteniendo, en este caso, la caducidad respecto de los recursos pel&#xE1;gicos en el litoral de la III y IV regiones, de conformidad con lo dispuesto en la resoluci&#xF3;n Ministerial exenta N&#xBA;20, de 1998.</div><br></div>", "i": 8329131}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8329132}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "431", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-431"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "LITA DEL CARMEN VILLARROEL GUTIERREZ", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-06", "doble_articulado": false, "id_norma": "97893", "numero_fuente": "36038", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-04-13", "vigencias": [{"desde": "1998-04-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vig