{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6275255}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;629, de 29 de febrero del 2000, se expropiaron los lotes de terreno N&#xBA;s. 1, 2, 3, 4, 5 y 6, superficies 2.083, 670, 1.036, 1.375, 1.470, 2.840 m&#xB2;, roles de aval&#xFA;os 147-154, 147-153, 147-152 y 147-150, comuna de Dalcahue, para la obra Camino Butalcura Chaquihual y otro y se acord&#xF3; precio de la indemnizaci&#xF3;n con sus propietarios Adolfo Vidal Gallardo, Manuel Ojeda Ojeda, Juan Ojeda C&#xE1;rdenas, Ferm&#xED;n Ojeda C&#xE1;rdenas y Gabriel Ojeda C&#xE1;rdenas, ascendentes a las cantidades de $603.665, lote N&#xBA;1;</div><div class=\"p\">$245.667, lote N&#xBA;2; $281.538, lote N&#xBA;3; $458.838, lotes N&#xBA;s. 4 y 5 y $551.131, lote N&#xBA;6.</div><br></div>", "i": 6275256}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6275257}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "629", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-629"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-29", "doble_articulado": false, "id_norma": "168647", "numero_fuente": "36663", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-15", "vigencias": [{"desde": "2000-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-15", "fin_vigencia": "", "tipo_version