{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6462086}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.397 de 28 de noviembre de 2003, y en base a la facultad otorgada por el art&#xED;culo 105 del DFL MOP N&#xBA; 850, de 1997, que fij&#xF3; el texto actualizado de la ley N&#xBA; 15.840, se expropi&#xF3; el lote de terreno N&#xBA; 1 para la obra: Instalaci&#xF3;n Red de Agua Potable Ampliaci&#xF3;n Valle Grande, que figura a nombre de Chacra El Carmen Pc 2, rol de aval&#xFA;o 183-18 comuna de Colina; Regi&#xF3;n Metropolitana, superficies 5.000 m2.- La comisi&#xF3;n de peritos fij&#xF3; con fecha 4 de septiembre de 2003 en la cantidad de $60.000.000.- La indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.</div><br></div>", "i": 6462087}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6462088}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1397", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1397"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-11-28", "doble_articulado": false, "id_norma": "220796", "numero_fuente": "37775", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-02", "vigencias": [{"desde": "2004-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-02-02", "fin_vigencia": ""}, "vigencias_version_norma