{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 607 EXENTO, DE 1993 </div></div>", "i": 7162110}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 607 de 16 de Noviembre de 1993 se ha modificado el decreto supremo exento de Educaci&#xF3;n N&#xB0; 235 de 1983, prorrogado por decreto supremo exento de Educaci&#xF3;n N&#xB0; 154 de 1988, que aprob&#xF3; un plan especial de estudio al Liceo Experimental Manuel de Salas, de Santiago, en el sentido de sustituir en el art&#xED;culo 1&#xB0; el plan de estudio para Educaci&#xF3;n B&#xE1;sica por el que se indica en el presente decreto.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa de estudio de Computaci&#xF3;n para los cursos de 5&#xB0; a 8&#xB0; a&#xF1;o b&#xE1;sico. </div></div>", "i": 7162111}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 31 de diciembre de 1993.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7162112}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "607 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-607 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 607 EXENTO, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "LICEO EXPERIMENTAL MANUEL SALAS", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-11-16", "doble_articulado": false, "id_norma": "21550", "numero_fuente": "34775", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-01-27", "vigencias": [{"desde": "1994-01-27", "hasta": "", "tipo_version": "3", "tipo_v