{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 537 EXENTO, DE 2005 </div></div>", "i": 6530390}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 537, de fecha 4 de mayo de 2005, del Ministerio de Educaci&#xF3;n, se aprueban el plan y programas de estudios al Centro de Formaci&#xF3;n T&#xE9;cnica Colchagua, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartido a contar del a&#xF1;o 2005.</div><br><div class=\"p\">Carrera&nbsp;  : Gesti&#xF3;n en Turismo</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; : T&#xE9;cnico de Nivel Superior en Gesti&#xF3;n en</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Turismo.</div><br><div class=\"p\">&nbsp; &nbsp;  El nuevo plan y programas de estudios que se aprueba mediante este decreto pasar&#xE1; a formar parte del proyecto institucional del Centro de Formaci&#xF3;n T&#xE9;cnica Colchagua, correspondiendo al Ministerio de Educaci&#xF3;n la verificaci&#xF3;n de su desarrollo.</div><br></div>", "i": 6530391}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de junio de 2005.- Pedro Montt Leiva, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6530392}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "537 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-537 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 537 EXENTO, DE 2005", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-05-04", "fecha_derogacion": "2009-09-05", "doble_articulado": false, "id_norma": "239365", "numero_fuente": "38193", "tipo_version": "2", "tipo_version_s": "Úl