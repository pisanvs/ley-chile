{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 130, DE 1986 </div></div>", "i": 8930259}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado Planes y Programas Especiales de Estudio para Segundo Ciclo de la Educaci&#xF3;n Media T&#xE9;cnico - Profesional, a contar del a&#xF1;o escolar 1986 y hasta el a&#xF1;o escolar 1991, inclusive, para el Liceo Industrial A-7, Jos&#xE9; Tom&#xE1;s Urmeneta, de Coquimbo.</div><div class=\"p\">Especialidades:</div><div class=\"p\">1. Mec&#xE1;nica de Combusti&#xF3;n Interna</div><div class=\"p\">2. Electromec&#xE1;nica</div><div class=\"p\">3. Electr&#xF3;nica</div><div class=\"p\">4. Mec&#xE1;nica de Mantenci&#xF3;n de M&#xE1;quinas y Equipos Industriales.-</div><br><br></div>", "i": 8930260}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 8930261}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "130 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-130 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 130, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO. NO TIENE FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "155252", "numero_fuente": "32509", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-06-30", "vigencias": [{"desde": "1986-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-06-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigen