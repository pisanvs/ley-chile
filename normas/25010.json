{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8929082}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 1.o Agr&#xE9;gase al art&#xED;culo 6.o de la ley 5,005, de 24 de Noviembre de 1931, el siguiente inciso:</div><div class=\"p\">&nbsp; &nbsp; &quot;h) Las del personal de las fuerzas armadas y del afecto a la ley 4,758&quot;.</div><br></div>", "i": 8929086}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 2.o Esta ley comenzar&#xE1; a regir desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 8929087}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.- JUAN E. MONTERO.- Marcial Mora M.- Carlos Vergara.- E. Spoerer.</div><br></div>", "i": 8929088}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "5040", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-5040"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ADMINISTRACION PUBLICA", "SERVICIOS", "VACANTES", "FUERZAS ARMADAS", "PERSONAL", "PROVEIMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "25010", "numero_fuente": "16184", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-01-27", "vigencias": [{"desde": "1932-01-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1932-01-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1932-01-27", "fin_vigencia