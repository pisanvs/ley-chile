{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8586802}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.998, de 29 de noviembre de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2&#xB0; de la Resoluci&#xF3;n N&#xB0; 402, de 1996, de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a PESQUERA PUNTA ARENAS S.A., para operar la nave &quot;Friosur III&quot;, en el sentido de se&#xF1;alar que el nombre y las actuales caracter&#xED;sticas n&#xE1;uticas de ella son las siguientes:</div><div class=\"p\"> Nombre&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &quot;Sur&quot;</div><div class=\"p\"> Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp;  2890</div><div class=\"p\"> Eslora total&nbsp; &nbsp; &nbsp; 51,0 m.</div><div class=\"p\"> Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 8,30 m.</div><div class=\"p\"> Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  3,70 m.</div><div class=\"p\"> T.R.G.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 604</div><div class=\"p\"> Arte de pesca&nbsp; &nbsp;  Palangre de fondo</div><br></div>", "i": 8586803}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 29 de noviembre de 1996.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8586804}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1998", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1998"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA PUNTA ARENAS S.A.", "PESCA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogad