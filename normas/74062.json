{"html": [{"t": "<div><div class=\"p\">INFORMA NOMBRAMIENTO DE SECRETARIO GENERAL DEL PARTIDO &quot;NUEVA ALIANZA POPULAR&quot; </div></div>", "i": 6040697}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Nicol&#xE1;s Garc&#xED;a Moreno, Presidente, en representaci&#xF3;n del partido &quot;Nueva Alianza Popular&quot;, y Cecilia Vargas Cornejo, Presidente del Tribunal Supremo de la colectividad, han informado el nombramiento como Secretario General del partido del se&#xF1;or Gustavo Adolfo Ogalde Aguirre, en reemplazo del se&#xF1;or Jaime Arnoldo Dur&#xE1;n Oportus.</div><br><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada en virtud del Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por Resoluci&#xF3;n N&#xBA; O-0679 de 25 de junio de 1997.</div><br></div>", "i": 6040698}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de junio de 1997.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6040699}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "679", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-679"}, {"tipo": "3", "numero": "O-0679", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-0679"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "INFORMA NOMBRAMIENTO DE SECRETARIO GENERAL DEL PARTIDO NUEVA ALIANZA POPULAR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMBRAMIENTO", "SECRETARIO GENERAL", "PARTIDOS POLITICOS", "NUEVA ALIANZA POPULAR", "GUSTAVO ADOLFO OGALDE AGUIRRE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-06-25", "doble_articulado": false, "id_norma": "74062", "numero_fuente": "35807", "tipo_version": "3", "tipo_version_s": "Únic