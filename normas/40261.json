{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DELEGA EN EL JEFE DEL DEPARTAMENTO DE RESOLUCIONES REGIONAL LA FACULTAD QUE INDICA </div></div>", "i": 6026344}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Mediante Resoluci&#xF3;n N&#xB0; 2.886 exenta, de 06 de Septiembre de 1994 el suscrito deleg&#xF3; en el Jefe del Departamento de Resoluciones Regional la facultad de autorizar las disminuciones de capital solicitadas por las sociedades, conforme a lo dispuesto en el inciso final del Art. 69&#xB0; del C&#xF3;digo Tributario; de acuerdo a Resoluci&#xF3;n Exenta N&#xB0; 3.830, de fecha 30.08.94, de la Direcci&#xF3;n Nacional, que autoriza delegar en los funcionarios que se&#xF1;ala dicha facultad.-</div><br></div>", "i": 6026345}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Lidia Castillo Alarc&#xF3;n, Director Regional (S). </div></div>", "i": 6026346}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2886", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2886"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DELEGA EN EL JEFE DEL DEPARTAMENTO DE RESOLUCIONES\nREGIONAL LA FACULTAD QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SERVICIO IMPUESTOS INTERNOS", "DELEGACION", "FACULTAD", "DIRECCION REGIONAL", "DECIMA REGION", "PUERTO MONTT", "DEPARTAMENTO RESOLUCIONES REGIONAL", "JEFE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-09-06", "doble_articulado": false, "id_norma": "40261", "numero_fuente": "34969", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-09-17", "vigencias": [{"desde": "1994-09-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-09-17", "