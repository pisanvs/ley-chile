{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 2.614 EXENTA, DE 2002 </div><br></div>", "i": 7290706}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 2.614, de 8 de marzo del a&#xF1;o 2002, se ha aprobado al Saint John&apos;s Villa Academy, comuna de La Reina, de Santiago, un plan de estudio para 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; en el a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 7290707}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de marzo de 2002.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 7290708}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2614 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2614 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 2.614 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-08", "doble_articulado": false, "id_norma": "196617", "numero_fuente": "37232", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-11", "vigencias": [{"desde": "2002-04-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-04-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-04-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modific