{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6137123}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 7.379, de fecha 06 de Diciembre de 1988, el Servicio Electoral dispuso publicar el siguiente extracto de la solicitud de inscripci&#xF3;n en la Regi&#xF3;n Metropolitana de Santiago, del Partido &quot;Los Verdes&quot;. Andr&#xE9;s Koryzma Zep y Rafael Edwards Aguirre en representaci&#xF3;n del Partido &quot;Los Verdes&quot;, solicitan la inscripci&#xF3;n del Partido en el Registro de Partidos Pol&#xED;ticos de la Regi&#xF3;n Metropolitana de Santiago, conforme al Art. 17 de la Ley 18.603. Declaran haber presentado m&#xE1;s de 13.000 afiliaciones.</div><br></div>", "i": 6137124}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 05 de Diciembre de 1988.- Andr&#xE9;s Merino Espi&#xF1;eira, Director Subrogante.</div><br></div>", "i": 6137125}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7379 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7379 EXENTA"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-06", "doble_articulado": false, "id_norma": "126501", "numero_fuente": "33244", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-12-13", "vigencias": [{"desde": "1988-12-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-12-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-12-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "FM