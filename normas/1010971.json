{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8870416}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 197, de 11 de enero de 2010, de esta Subsecretar&#xED;a, autor&#xED;zase a COOPERATIVA DE TRABAJO &quot;SEMILLERO CASCAJAL&quot; para instalar, por el per&#xED;odo de seis meses contados desde el 1 de febrero de 2010, colectores de semillas de Mit&#xED;lidos en Estero Reloncav&#xED;, X Regi&#xF3;n, en una superficie de 1,32 hect&#xE1;reas, cuyas coordenadas geogr&#xE1;ficas, referidas al plano DPC-211, Datum WGS-84, son:</div><br><div class=\"p\">V&#xE9;rtice&nbsp;  Latitud (S)&nbsp; &nbsp;  Longitud (W)</div><br><div class=\"p\">&nbsp;  A&nbsp; &nbsp;  41&#xBA; 35&#x2019;50,35&quot;&nbsp;  72&#xBA; 19&#x2019;35,78&quot;</div><div class=\"p\">&nbsp;  B&nbsp; &nbsp;  41&#xBA; 35&#x2019;50,94&quot;&nbsp;  72&#xBA; 19&#x2019;32,60&quot;</div><div class=\"p\">&nbsp;  C&nbsp; &nbsp;  41&#xBA; 35&#x2019;56,54&quot;&nbsp;  72&#xBA; 19&#x2019;34,45&quot;</div><div class=\"p\">&nbsp;  D&nbsp; &nbsp;  41&#xBA; 35&#x2019;56,01&quot;&nbsp;  72&#xBA; 19&#x2019;37,49&quot;</div></div>", "i": 8870417}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de enero de 2010.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8870418}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "197", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-197"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-01-11", "doble_articulad