{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 7.652 EXENTA,DE 2008 </div></div>", "i": 7382283}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 7.652, de 22 de octubre de 2008, se ha modificado la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 8.069, de 1999, que aprob&#xF3; plan y programas especiales de estudio de 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media al Colegio &quot;Andr&#xE9;e English School&quot;, de la comuna de La Reina, de Santiago, en el sentido de sustituir el plan de estudio de 2&#xBA; a&#xF1;o medio por el que se indica en la presente resoluci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio del Subsector de Filosof&#xED;a del Sector de Filosof&#xED;a y Psicolog&#xED;a del Plan de Formaci&#xF3;n General para 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media.</div><br></div>", "i": 7382284}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de noviembre de 2008.- Rosita Puga Hamilton, Jefa Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 7382285}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7652 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7652 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 7.652 EXENTA,DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-10-22", "doble_articulado": false, "id_norma": "283544", "numero_fuente": "39238", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-12-16", "vigencias": [{"desde": "2008-12-16", "hasta": "", "tipo_version": "3", "tip