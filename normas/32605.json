{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESIGNA COMO MINISTRO DE FE A FUNCIONARIO QUE INDICA N&#xFA;m. 49.- Santiago, 15 de marzo de 1993.- Vistos: Lo dispuesto en el art&#xED;culo 4&#xB0; del Decreto Ley N&#xB0; 2.974 de 1979.</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 6004454}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Des&#xED;gnase como Ministro de Fe para actuar en las localidades ubicadas en la VIII Regi&#xF3;n, en que no hayan Notarios ni Oficiales del Registro Civil, al siguiente funcionario:</div><div class=\"p\">&nbsp; &nbsp; - Juan Alberto Daig Y&#xE9;venes.</div><br></div>", "i": 6004455}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hugo Ortega Tello, Director Nacional.</div><br></div>", "i": 6004456}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "49", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-49"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "DESIGNA COMO MINISTRO DE FE A FUNCIONARIO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MINISTRO FE", "OCTAVA REGION", "INSTITUTO DESARROLLO AGROPECUARIO", "JUAN ALBERTO DAIG YEVENES", "INDAP"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-03-15", "doble_articulado": false, "id_norma": "32605", "numero_fuente": "34540", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-04-14", "vigencias": [{"desde": "1993-04-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-04-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-04-14", "fin_vig