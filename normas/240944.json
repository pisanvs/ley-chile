{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6535970}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.306, de 21 de julio de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a THOMAS CAMPBELL Y COMPA&#xD1;IA LIMITADA, para ampliar actividades pesqueras de transformaci&#xF3;n en orden a incorporar a la planta ubicada en Avenida Forestal N&#xBA; 1101, Parque Industrial, Coronel, VIII Regi&#xF3;n, en las l&#xED;neas de proceso de Cocido, fresco enfriado, fresco refrigerado y congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1.762 de 2005, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6535971}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de julio de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6535972}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2306 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2306 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-07-21", "doble_articulado": false, "id_norma": "240944", "numero_fuente": "38235", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-08-12", "vigencias": [{"desde": "2005-08-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-08-12", "fin_vigencia": ""}, "vige