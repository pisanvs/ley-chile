{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 186, DE 1991 </div></div>", "i": 7231439}, {"t": "<div><div class=\"p\">Por Decreto exento No. 186 de fecha 17 de julio de 1991 del Ministerio de Educaci&#xF3;n, se reemplazaron las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Lautaro, que fueran aprobadas por Resoluci&#xF3;n Exenta No. 2347 de 1987, las que podr&#xE1;n aplicarse a contar del a&#xF1;o 1991.</div><br></div>", "i": 7231440}, {"t": "<div><div class=\"p\">Santiago, 12 de Septiembre de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7231441}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "186", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-186"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 186, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-07-17", "doble_articulado": false, "id_norma": "96864", "numero_fuente": "34089", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-10-11", "vigencias": [{"desde": "1991-10-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-10-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-10-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JAM", "fecha_ingreso": "1998-04-02", "fecha_version": "1991-10-11", "fecha_actualizacion_texto": "1