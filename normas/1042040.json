{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  CERTIFICADO</div></div>", "i": 9276993}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) de captaci&#xF3;n para operaciones reajustables de entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de julio de 2012, fue de 5,84% anual.</div></div>", "i": 9276994}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de julio de 2012.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div></div>", "i": 9276995}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "Certificado-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-18", "doble_articulado": false, "id_norma": "1042040", "numero_fuente": "40317", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-07-21", "vigencias": [{"desde": "2012-07-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-07-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-07-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2012-07-23", "fecha_version": "2012-07-21", "fecha_actualizacion_texto": "2012-07-23", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9276993}, {"n":