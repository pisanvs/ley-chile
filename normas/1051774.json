{"html": [{"t": "<div><br><div class=\"p\">DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 166.359 exenta.- Santiago, 13 de diciembre de 2012.- Vistos: Lo dispuesto en el Art. 11 del decreto ley N&#xBA; 2.974, de 1979.</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div></div>", "i": 9358430}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del decreto ley citado, en la Regi&#xF3;n del B&#xED;ob&#xED;o, al siguiente funcionario:</div><div class=\"p\">&nbsp; &nbsp;  Hern&#xE1;n Humberto Carrillo Bilbao RUT: 6.836.791-3.</div></div>", "i": 9358431}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Ricardo Arizt&#xED;a de Castro, Director Nacional.</div></div>", "i": 9358432}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "166359 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-166359 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-12-13", "doble_articulado": false, "id_norma": "1051774", "numero_fuente": "40583", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-06-13", "vigencias": [{"desde": "2013-06-13", "hasta": "", "tipo_version": "3", "tipo_version_s