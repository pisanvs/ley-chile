{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACION DE INMUEBLES QUE INDICA</div><br><div class=\"p\">NOTIFICACION </div></div>", "i": 6483219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;267 de 19 de mayo de 2004 de Serviu Metropolitano, ordenose expropiaci&#xF3;n, conforme D.L. N&#xBA;2.186 de 1978, del Lote N&#xBA;121 correspondiente a parte del inmueble ubicado en Santa Rosa 4342, presunto rol de aval&#xFA;o N&#xBA;4138-60, comuna de San Joaqu&#xED;n, aparente dominio de Arellano Becerra Ram&#xF3;n. Comisi&#xF3;n integrada por peritos Miguel Ort&#xED;z Bobadilla, Constructor Civil; Jimena Asenjo Burgos, Arquitecto y Pedro Almonacid Colin, ingeniero civil. Seg&#xFA;n informe de 30 de septiembre de 2003, fij&#xF3; monto provisional indemnizaci&#xF3;n en $4.003.880. pagadera al contado.</div><br></div>", "i": 6483220}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director. Serviu Metropolitano.</div><br></div>", "i": 6483221}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "267", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-267"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "ORDENA EXPROPIACION DE INMUEBLES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-19", "doble_articulado": false, "id_norma": "226376", "numero_fuente": "37885", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-15", "vigencias": [{"desde": "2004-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenc