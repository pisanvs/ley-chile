{"html": [{"t": "<div><div class=\"p\">CERTIFICA CALIDAD DE AGENTE RETENEDOR DE IVA A POSTES S.A.</div><br></div>", "i": 6440650}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 7.- Certifico que Postes S.A., RUT 96.639.900-7 cumple los requisitos establecidos en la Res. N&#xBA; Ex. 4.916 del 31.10.2000 publicada en el Diario Oficial el 03.11.2000 que en consecuencia tiene la calidad de agente retenedor del Impuesto al Valor Agregado, en las ventas de madera que efect&#xFA;e durante el per&#xED;odo comprendido entre el 1&#xBA; del mes siguiente al de la publicaci&#xF3;n de este certificado en el Diario Oficial con vigencia indefinida.</div><br></div>", "i": 6440651}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rancagua, 2 de septiembre de 2003.- Luis Mu&#xF1;oz Arratia, Director Regional.</div><br></div>", "i": 6440652}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VI DIRECCIÓN REGIONAL DE RANCAGUA"], "titulo_norma": "CERTIFICA CALIDAD DE AGENTE RETENEDOR DE IVA A POSTES\nS.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-09-02", "doble_articulado": false, "id_norma": "214944", "numero_fuente": "37665", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-22", "vigencias": [{"desde": "2003-09-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-09-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos