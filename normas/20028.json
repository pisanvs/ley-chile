{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 75 EXENTO, DE 1994 </div></div>", "i": 5940696}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 75 de 28 de Febrero de 1994 se ha aprobado un plan especial de estudio para ser aplicado por el Internado Nacional Barros Arana, de Santiago, en los cursos de 7&#xB0; y 8&#xB0; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica y en todos los cursos de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, a partir del a&#xF1;o escolar 1994.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s se aprueban programas de estudio de las asignaturas de Historia y Geograf&#xED;a de Chile y de Orientaci&#xF3;n Grupal y Vocacional.</div><br></div>", "i": 5940697}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 3 de Marzo de 1994.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5940698}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "75", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-75"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 75 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "INTERNADO NACIONAL BARROS ARANA", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-02-28", "doble_articulado": false, "id_norma": "20028", "numero_fuente": "34809", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-03-08", "vigencias": [{"desde": "1994-03-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-03-08", "fin_vigencia": ""}, "vigencias_versi