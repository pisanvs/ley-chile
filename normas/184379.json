{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6331541}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 624, de 10 de abril del 2001, de esta Subsecretar&#xED;a, modif&#xED;case el considerando tercero y el numeral 2 de la resoluci&#xF3;n N&#xBA; 124 de 2001 de esta Subsecretar&#xED;a, que ampli&#xF3; el plazo a ALIMENTOS MARINOS S.A.&nbsp; para iniciar actividades pesqueras extractivas con la nave &quot;Ordinat&quot;, en el sentido de se&#xF1;alar que el recurso hidrobiol&#xF3;gico, objeto de la caducidad parcial all&#xED; declarada, es la Sardina espa&#xF1;ola y no la Sardina com&#xFA;n como all&#xED; err&#xF3;neamente se se&#xF1;ala.</div><br><br></div>", "i": 6331542}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de abril de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6331543}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "624", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-624"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-10", "doble_articulado": false, "id_norma": "184379", "numero_fuente": "36941", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-04-19", "vigencias": [{"desde": "2001-04-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-04-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-04-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes"