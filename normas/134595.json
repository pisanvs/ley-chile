{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,309.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6162864}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Ab&#xF3;nase por gracia a don&nbsp; Jos&#xE9; Mar&#xED;a V&#xE1;zquez, contador cuarto de la Direccion de Contabilidad, para los efectos de su jubilacion, el tiempo que acreditare haber servido como administrador de Estanco.</div><br></div>", "i": 6162865}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de diciembre de 1899.- FEDERICO ERRAZURIZ.- Manuel Salinas.</div><br></div>", "i": 6162866}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1309", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1309"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-12-27", "doble_articulado": false, "id_norma": "134595", "numero_fuente": "6484", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-12-29", "vigencias": [{"desde": "1899-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-12-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-12-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso