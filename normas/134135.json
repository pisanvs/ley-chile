{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 987.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6161434}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Decl&#xE1;rase de abono al teniente-coronel retirado de Ej&#xE9;rcito, don Antonio R. Gonz&#xE1;lez, los tres a&#xF1;os once meses i quince dias que estuvo temporalmente separado del Ej&#xE9;rcito, desde el 24 de marzo de 1884 hasta el 9 de marzo de 1888. </div></div>", "i": 6161435}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintinueve de diciembre de mil ochocientos noventa i siete.- FEDERICO ERRAZURIZ.- Patricio Larrain A.</div><br></div>", "i": 6161436}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "987", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-987"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-12-29", "doble_articulado": false, "id_norma": "134135", "numero_fuente": "5896", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-01-07", "vigencias": [{"desde": "1898-01-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-01-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-01-07", "fin_vigencia": "", "tipo_version": "3"}], "event