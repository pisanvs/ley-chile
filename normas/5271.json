{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 273.- Santiago, 20 de Mayo de 1931.- Vistas las facultades que me confiere la ley n&#xFA;mero 4,945 de 6 de Febrero de 1931.</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 7119967}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; 1.o El&#xE9;vase en $ 160,445 la suma consultada en el &#xED;tem 06/10/08-e del Presupuesto vigente.</div><div class=\"p\">&nbsp; &nbsp; 2.o Este aumento se deducir&#xE1; de las entradas que consultan los art&#xED;culos 26 y 42 del decreto con fuerza de ley n&#xFA;mero 94, de 11 de Abril de 1931.</div><br></div>", "i": 7119968}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- C. IBA&#xD1;EZ C.- R. Jaramillo B.</div><br></div>", "i": 7119969}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "273", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-273"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1931", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-05-20", "doble_articulado": false, "id_norma": "5271", "numero_fuente": "15983", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-05-29", "vigencias": [{"desde": "1931-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1931-05-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1931-05-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacione