{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N&nbsp; N&#xBA; 76 EXENTA, DE 2014</div></div>", "i": 9602065}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 31, de 17 de abril de 2015, se modific&#xF3; la <a href=\"https://www.leychile.cl/Navegar?idNorma=1071429&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 76, de 9 de octubre de 2014</a>, ambas de la Subsecretar&#xED;a de Energ&#xED;a, en el sentido de incorporar a do&#xF1;a Carolina G&#xF3;mez Agurto, a contar del 13 de abril de 2015, como Subrogante del Jefe de la Divisi&#xF3;n de Desarrollo Sustentable, con las mismas facultades previstas en la resoluci&#xF3;n exenta N&#xBA; 76, de 2014, de la Subsecretar&#xED;a de Energ&#xED;a.</div><br></div>", "i": 9602066, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda Atte. a Ud., Hern&#xE1;n Moya Bruzzone, Jefe Divisi&#xF3;n Jur&#xED;dica Subsecretar&#xED;a de Energ&#xED;a.</div></div>", "i": 9602067}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "31 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-31 EXENTA"}], "organismos": ["MINISTERIO DE ENERGÍA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 76 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-04-17", "doble_articulado": false, "id_norma": "1077855", "numero_fuente": "41166", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-05-26", "vigencias": [{"desde": "2015-05-26", "hasta": "", "tipo_version": "3", "tipo_versi