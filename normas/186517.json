{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6338953}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 683, de 30 de abril de 2001, se expropi&#xF3; el lote de terreno N&#xBA; 176, superficie 108 m&#xB2;, rol de aval&#xFA;o 5883-1, comuna de La Granja, para la obra Concesi&#xF3;n Internacional Ruta 5, Tramo: Santiago - Talca. Sector A: Acceso Sur a Santiago, Regi&#xF3;n Metropolitana y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Mar&#xED;a de Lourdes P&#xE9;rez Carrasco, ascendente a la cantidad de $11.407.759.-</div><br></div>", "i": 6338954}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6338955}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "683", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-683"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-30", "doble_articulado": false, "id_norma": "186517", "numero_fuente": "36987", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-06-15", "vigencias": [{"desde": "2001-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2001-06-15", "fecha_version": "2001-06-15", "fecha_actualizacion_texto": "2001-06-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "est