{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div></div>", "i": 9274844}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA; 40.311, de 13 de julio de 2012, se public&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1041745&amp;idParte=0&amp;idVersion=\">decreto N&#xBA; 44, que &quot;APRUEBA REGLAMENTO SOBRE INFORMACI&#xD3;N AL CONSUMIDOR DE TARJETAS DE CR&#xC9;DITO BANCARIAS Y NO BANCARIAS</a>&quot;, con el error de publicaci&#xF3;n que se salva a continuaci&#xF3;n: I Cuerpo, p&#xE1;gina 44, segunda columna, en DISPOSICI&#xD3;N TRANSITORIA, donde dice &quot;<a href=\"https://www.leychile.cl/Navegar?idNorma=1041745&amp;idParte=9273592&amp;idVersion=\">Art&#xED;culo &#xFA;nico transitorio</a>.- El presente reglamento entrar&#xE1; en vigencia el 1 de julio de 2012. ...&quot;, debe decir &quot;Art&#xED;culo &#xFA;nico transitorio.- El presente reglamento entrar&#xE1; en vigencia el 31 de julio de 2012. ...&quot;.</div><br><br></div>", "i": 9274845, "v": ["RECTIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "213", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-213"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE ECONOMÍA Y EMPRESAS DE MENOR TAMAÑO"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1041778", "numero_fuente": "40312", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-07-14", "vigencias": [{"desde": "2012-07-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012