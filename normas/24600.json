{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 7168410}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Apru&#xE9;banse los traspasos de fondos decretados por el Ministerio de Defensa Nacional - Departamento de Marina - por decretos n&#xFA;meros 864, de 19 de Abril &#xFA;ltimo, y 1,093, de 18 de Mayo pasado, de los Cap&#xED;tulos, &#xED;tem y sumas que se detallan:</div><div class=\"p\"> Del Cap.&nbsp; &nbsp;  Del &#xED;tem&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  La suma</div><br><div class=\"p\">&nbsp;  II&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 19&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; $&nbsp; 500,000</div><div class=\"p\">&nbsp; III&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 31&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  100,000</div><div class=\"p\">&nbsp; XVI&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  437&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  300,000</div><br><div class=\"p\">&nbsp; Al Cap.&nbsp; &nbsp; &nbsp;  Item&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; La suma</div><br><div class=\"p\">&nbsp;  II&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 26&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; $&nbsp;  82,000</div><div class=\"p\">&nbsp; VII&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  184&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 94,000</div><div class=\"p\">&nbsp;  XV&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  422&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 70,000</div><div class=\"p\">&nbsp;  XV&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  429&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  624,000</div><div class=\"p\">&nbsp;  XV&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  433&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 30,000</div><div class=\"p\">&nbsp; &nbsp; Y del Cap&#xED;tulo II del &#xED;tem 19, la suma de $ 70,000, al Cap&#xED;tulo XV, &#xED;tem 433, la suma indicada.&quot;</div><br></div>", "i": 7168411}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a treinta y uno de Diciembre de mil novecientos veintisiete.- Carlos Ib&#xE1;&#xF1;ez del Campo.- C.</div><div class=\"p\">O. Frodden.</div><br></div>", "i": 7168412}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4245", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4245"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1927", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1927-12-31", "doble_articulado": false, "id_norma": "24600", "numero_fuente": "14990", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-02-03", "vigencias": [{"desde": "1928-02-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-02-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1928-02-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}, {"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresado_por": "JAM", "fecha_ingreso": "1999-03-09", "fecha_version": "1928-02-03", "fecha_actualizacion_texto": "1928-02-03", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 7168410}, {"n": "Artículo UNICO", "i": 7168411, "t": 6}, {"n": "Promulgación", "i": 7168412}]}