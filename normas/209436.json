{"html": [{"t": "<div><div class=\"p\">ACEPTA RENUNCIA AL CARGO DE SUBSECRETARIA GENERAL DE GOBIERNO</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 29.- Santiago, 10 de marzo de 2003.- Visto: La carta renuncia adjunta y lo establecido en el art&#xED;culo 32 N&#xBA; 9 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile,</div><br><div class=\"p\">&nbsp; &nbsp;  D e c r e t o:</div><br><br></div>", "i": 7299265}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ac&#xE9;ptase, a contar del 6 de marzo de 2003, la renuncia voluntaria al cargo de Subsecretaria General de Gobierno presentada por do&#xF1;a Mar&#xED;a Eliana Arntz Bustos. </div></div>", "i": 7299266}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese y comun&#xED;quese.- RICARDO LAGOS ESCOBAR, Presidente de la Rep&#xFA;blica.- Francisco Vidal Salinas, Ministro Secretario General de Gobierno.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud., para su conocimiento.- Patricio Santamar&#xED;a Mutis, Subsecretario General de Gobierno.</div><br></div>", "i": 7299267}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "29", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-29"}], "organismos": ["MINISTERIO SECRETARÍA GENERAL DE GOBIERNO"], "titulo_norma": "ACEPTA RENUNCIA AL CARGO DE SUBSECRETARIA GENERAL DE GOBIERNO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SUBSECRETARIA GENERAL DE GOBIERNO", "MARIA ELIANA ARNTZ BUSTOS", "RENUNCIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-03-10", "doble_articulado": false, "id_norma": "209436", "numero_fuente": "37538", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-04-17", "vigencias"