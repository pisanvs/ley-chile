{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6195767}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 135, de 10 de Febrero de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Alejandro S&#xE1;nchez Cabrera para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea N&#xB0; 1, &quot;Bellavista - Techo para Todos&quot; de Puerto Montt, cuyo trazado fue autorizado por re soluci&#xF3;n N&#xB0; 82, de 07 de Junio de 1984, de esta Secretar&#xED;a Regional.</div><br></div>", "i": 6195768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n. </div></div>", "i": 6195769}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "135 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-135 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-10", "doble_articulado": false, "id_norma": "144897", "numero_fuente": "32708", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-02-26", "vigencias": [{"desde": "1987-02-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-02-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-02-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe