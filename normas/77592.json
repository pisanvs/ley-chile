{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6050820}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 26, del 20 de Marzo de 1992, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la I Regi&#xF3;n, se adjudic&#xF3; a Servicio T&#xE9;cnico del Norte Ltda., la concesi&#xF3;n para operar, por un plazo de cinco a&#xF1;os a contar de la fecha de publicaci&#xF3;n del presente extracto, un establecimiento ubicado en Calle Sotomayor 2131, de Iquique, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de emisi&#xF3;n de contaminantes de los veh&#xED;culos que se se&#xF1;alen en el inciso primero del art&#xED;culo 7&#xB0; del DS 156/90 del Ministerio, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 6050821}, {"t": "<div><div class=\"p\">Yerko Luksic Sandoval, Secretario Regional Ministerial Transportes y Telecomunicaciones I Regi&#xF3;n.</div><br></div>", "i": 6050822}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "26", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-26"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-03-20", "doble_articulado": false, "id_norma": "77592", "numero_fuente": "34362", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-09-08", "vigencias": [{"desde": "1992-09-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-09-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"