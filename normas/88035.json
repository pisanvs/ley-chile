{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO MINISTROS DE FE A FUNCIONARIOS QUE INDICA </div><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">N&#xFA;m. 178.- Santiago, 12 de Noviembre de 1990.- Vistos: Lo dispuesto en el Art&#xED;culo 4&#xB0; del Decreto Ley No. 2.974 de 1979.</div><br><div class=\"p\">Resuelvo:</div><br></div>", "i": 6077882}, {"t": "<div><div class=\"p\">Des&#xED;gnanse como Ministros de Fe para actuar en las localidades ubicadas en la I y II Regiones, en que no haya Notarios ni Oficiales del Registro Civil, a los siguientes funcionarios:</div><div class=\"p\">- Jos&#xE9; Luis Rivas Deville</div><div class=\"p\">- Gustavo Osvaldo Bravo Castillo</div><div class=\"p\">- Orlando Marcelo Miranda Ortega</div><div class=\"p\">- Mario Concha Sanhueza.</div><br></div>", "i": 6077883}, {"t": "<div><div class=\"p\">T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hugo Ortega Tello, Director Nacional. </div></div>", "i": 6077884}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "178", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-178"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO MINISTROS DE FE A FUNCIONARIOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-11-12", "doble_articulado": false, "id_norma": "88035", "numero_fuente": "33837", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-12-06", "vigencias": [{"desde": "1990-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-