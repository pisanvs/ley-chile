{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6167805}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP No. 357, de 26 de febrero de 1999, se expropiaron los lotes de terreno No. s 44 y 46, superficies 568 y 515 m2, respectivamente, roles de aval&#xFA;o en tr&#xE1;mite, comuna de Constituci&#xF3;n, para la obra Camino Ruta M-40 - Santa Olga - Empedrado, Sector Santa Olga - Los Pellines y se acord&#xF3; precio de indemnizaci&#xF3;n con su propietario Gerardo Jaque Letelier, ascendente a la cantidad de $ 315.594.- para los lotes 44 y 46.- </div></div>", "i": 6167806}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6167807}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "357", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-357"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-02-26", "doble_articulado": false, "id_norma": "136157", "numero_fuente": "36353", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-05-03", "vigencias": [{"desde": "1999-05-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-05-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-05-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-05-10", "fecha_version": "1999-05-03", "fecha_actualizacion_texto": "1999-05-03", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "e