{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  NOMBRAMIENTO DE JUEZ DE REMATADOS.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Mayo 30 de 1823.</div></div>", "i": 10042781}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Considerando la necesidad que hai de velar sobre el cumplimiento de las condenas de los reos destinados al presidio, y teniendo presente lo prevenido por las leyes, he venido en decretar que se restituya a su antiguo ejercicio el cargo de Juez de rematados que servir&#xE1; por ahora el Camarista D. Gabriel Jos&#xE9; Tocornal, turnando anualmente en lo sucesivo entre los demas camaristas como era de costumbre. Trascr&#xED;base a la C&#xE1;mara de Justicia e ins&#xE9;rtese en el Boletin.</div></div>", "i": 10042782}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Ega&#xF1;a.</div></div>", "i": 10042783}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "NOMBRAMIENTO DE JUEZ DE REMATADOS", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-05-30", "doble_articulado": false, "id_norma": "1134034", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-05-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-05-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-05-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_po