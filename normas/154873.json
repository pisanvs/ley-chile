{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 116, DE 1983</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 63.- Santiago, 18 de Agosto de 1986.- Vistos: Lo dispuesto en el art&#xED;culo 4&#xB0; del Decreto Ley 2.974 de 1979,</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 7260785}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por haber dejado de pertenecer al Servicio, d&#xE9;jese sin efecto la designaci&#xF3;n de los se&#xF1;ores Luis Miranda Concha y Luis Mu&#xF1;oz Pincheira como Ministros de Fe, efectuada en la resoluci&#xF3;n No. 116 de 16 de Diciembre de 1983.</div><br></div>", "i": 7260786}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Arturo Venegas Palacios, Vicepresidente Ejecutivo.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. Para su conocimiento.- Jos&#xE9; Manuel Rodr&#xED;guez, Secretario General.</div><br></div>", "i": 7260787}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "63", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-63"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO MINISTRO DE FE A FUNCIONARIO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-08-18", "doble_articulado": false, "id_norma": "154873", "numero_fuente": "32.570", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-09-10", "vigencias": [{"desde": "1986-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-09-10", "