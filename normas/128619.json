{"html": [{"t": "<div><div class=\"p\">REASUME MANDO DEL ESTADO</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 21 de noviembre de 1998.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 3.313.- Visto: Lo dispuesto en los art&#xED;culos 29&#xBA; y 32&#xBA;, N&#xBA; 8 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile,</div><br><div class=\"p\">&nbsp; &nbsp;  D e c r e t o:</div><br><br></div>", "i": 8337673}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Con ocasi&#xF3;n de mi regreso al pa&#xED;s a contar de esta fecha reasumo el mando del Estado.</div><br></div>", "i": 8337674}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- EDUARDO FREI RUIZ-TAGLE, Presidente de la Rep&#xFA;blica.- Ra&#xFA;l Troncoso Castillo, Ministro del Interior.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud., Belisario Velasco Baraona, Subsecretario del Interior. </div></div>", "i": 8337675}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3313", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3313"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARIA DEL INTERIOR"], "titulo_norma": "REASUME MANDO DEL ESTADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-21", "doble_articulado": false, "id_norma": "128619", "numero_fuente": "36245", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-12-22", "vigencias": [{"desde": "1998-12-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-12-22", "f