{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCIONES QUE INDICA </div></div>", "i": 8344082}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 245 de 04 de Marzo de 1988 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, der&#xF3;gase las resoluciones No. 340, de 1984 y No. 185, de 1985, ambas de esta Subsecretar&#xED;a, que autorizaron a don Alfredo Puga Mart&#xED;nez c&#xE9;dula de identidad No. 2.943.237-6, domiciliado en calle Apoquindo No. 5118, departamento No. 101, Santiago, para desarrollar y ampliar actividades pesqueras de transformaci&#xF3;n respectivamente, en las instalaciones de Frigor&#xED;fico La Granja, ubicadas en calle Santa Rosa No. 9233, Santiago, por renuncia de su titular.</div><br></div>", "i": 8344083}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 04 de Marzo de 1988.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8344084}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "245", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-245"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "DEROGA RESOLUCIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-04", "doble_articulado": false, "id_norma": "135422", "numero_fuente": "33022", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-03-16", "vigencias": [{"desde": "1988-03-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-03-16", "fin_vigencia": ""}, "vigencias_version_nor