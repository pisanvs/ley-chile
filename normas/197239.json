{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6378556}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 717, de 10 de abril de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a ALFREDO EDUARDO ROJAS VEGA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en Camino al Vertedero N&#xBA; 100, La Herradura, Coquimbo, IV Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de proceso que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Alga seca: Huiro, Huiro negro, Palo, Chasca y Pelillo; Harina, Deshidratado: Desechos de: Camar&#xF3;n nailon, Langostino amarillo y Langostino colorado.</div><br></div>", "i": 6378557}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de abril de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6378558}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "717", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-717"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-10", "doble_articulado": false, "id_norma": "197239", "numero_fuente": "37243", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-25", "vigencias": [{"desde": "2002-04-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-04-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-04-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vi