{"html": [{"t": "<div><br><div class=\"p\">MODIFICA MANUAL DE TR&#xC1;FICO TERRESTRE</div></div>", "i": 9991576}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 5.721, de fecha 27 de diciembre de 2018, del Director Nacional de Aduanas (S), se modifica la letra l, del cap&#xED;tulo II del Manual de Tr&#xE1;fico Terrestre, aprobado por la resoluci&#xF3;n N&#xB0; 748, de 13.02.1989, y reemplazada por resoluci&#xF3;n N&#xB0; 6.000, de 30.12.2004, en lo siguiente:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Se reemplaza el numeral 1.4.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  La modificaci&#xF3;n entrar&#xE1; en vigencia 90 d&#xED;as despu&#xE9;s de la publicaci&#xF3;n en el Diario Oficial del presente extracto.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\"> </div></div>", "i": 9991577}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de diciembre de 2018.- Pablo Ib&#xE1;&#xF1;ez Beltrami, Director Nacional de Aduanas (S).</div></div>", "i": 9991578}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5721 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5721 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA MANUAL DE TRÁFICO TERRESTRE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1533060; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-12-27", "doble_articulado": false, "id_norma": "1128166", "numero_fuente": "4226