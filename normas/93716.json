{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6095099}, {"t": "<div><div class=\"p\">Por Resuelvo Sendos No. 493, de 27 de Junio de 1989, se expropi&#xF3; los lotes de terrenos N&#xB0;s 5, 6-A y 6-B, Rol No. 149 - 195 de la comuna de Codegua, VI Regi&#xF3;n, de 4.095,1220 y 945 m2. de superficie respectivamente, para la ejecuci&#xF3;n de la obra A.P. de Codegua, mejoramiento del Servicio y se acord&#xF3; el monto de la indemnizaci&#xF3;n con su propietario don Julio Ernesto Russi Greene, ascendente a $ 580.000.- en los cuales se incluye la servidumbre del lote No. 7 del mismo propietario.-</div><br></div>", "i": 6095100}, {"t": "<div><div class=\"p\">Director Nacional de Obras Sanitarias.</div><br></div>", "i": 6095101}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "493", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-493"}], "organismos": ["SERVICIO NACIONAL DE OBRAS SANITARIAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-06-27", "doble_articulado": false, "id_norma": "93716", "numero_fuente": "33437", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-08-01", "vigencias": [{"desde": "1989-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1998-03-04", "fecha_version": "1989-08-01", "fecha_actualizacion_texto": "1989-08-01", "tipo_tratado": ""}, "alertas": []