{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6053341}, {"t": "<div><div class=\"p\">Por Decreto M.O.P. No. 114, de 29 de abril de 1992, se expropiaron los lotes de terreno N&#xB0;s 2, 5, 9, y 9-A, superficies 470 m2., 240 m2., y 580 m2., roles de aval&#xFA;o 23-67, 24-29 y 24-14 Comuna de Olivar, para la obra Camino Olivar - Coinco y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Jovino Gonz&#xE1;lez Ot&#xE1;rola, Juan de Dios Ram&#xED;rez Gaete, e Ignacio Per&#xE9;z Inostroza y otros , ascendente a las cantidades de $ 398.843.- para el lote 2, $ 178.920.- para el lote 5, y $ 439.845.- para los lotes 9 y 9-A, respectivamente.-</div><br></div>", "i": 6053342}, {"t": "<div><div class=\"p\">Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 6053343}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "114", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-114"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-04-29", "doble_articulado": false, "id_norma": "78788", "numero_fuente": "34280", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-06-01", "vigencias": [{"desde": "1992-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MNV", "fecha_ingreso": "1997-12-04", "fecha_version": "1992-06-01", "fecha_actual