{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6387525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA;755, de fecha 30 de mayo de 2002, se expropiaron los lotes de terreno N&#xBA;s. 14, 15, 16, 17, 18 y 19, superficies 3.127 m&#xB2;, 37 m&#xB2;, 71 m&#xB2;, 989 m&#xB2;, 535 m&#xB2; y 108 m&#xB2;, respectivamente, Rol de aval&#xFA;o 221-40, comuna de Coelemu, VIII Regi&#xF3;n, para la obra &apos;&apos;Camino Ruta O-170, O-176, Acceso a Guarilihue, Km.</div><div class=\"p\">0,00000 al 8,28000&apos;&apos;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario don Marcos Burgos Parra, ascendente a la cantidad de $4.069.926.- </div></div>", "i": 6387526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6387527}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "755 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-755 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-30", "doble_articulado": false, "id_norma": "200011", "numero_fuente": "37296", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-01", "vigencias": [{"desde": "2002-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MAS", "fecha_ingreso": "2002-07-03", "fec