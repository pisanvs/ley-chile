{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6434794}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n</div><div class=\"p\">exenta N&#xBA; 1.424 de 4 de Septiembre de 1991, conforme</div><div class=\"p\">Art. 5&#xBA; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos de Aprovechamiento Aguas proporcionales que corresponden a predio &quot;Monte Alegre&quot; de la Comuna de Maule, VII Regi&#xF3;n; y Derechos de Aprovechamiento Aguas que corresponden a Lotes&nbsp; Agr&#xED;colas N&#xBA;s. 1 al 10 y sitios N&#xBA;s. 1 al 12 y Lote Cooperativa de Proyecto de Asignaci&#xF3;n &quot;Monte Alegre&quot; formado por predio se&#xF1;alado. Los derechos de aguas se extraen de los canales Col&#xED;n, Duao Zapata, Mayo e Isla. Derrames del Fundo Las Verbenas Y Vertientes del Fundo San Jos&#xE9;.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme Art.13 Ley N&#xBA; 18.377.- </div></div>", "i": 6434795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Nacional.</div><br></div>", "i": 6434796}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1424 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1424 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-09-04", "doble_articulado": false, "id_norma": "213374", "numero_fuente": "34106", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-02", "vigencias": [{"desde": "1991-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}]