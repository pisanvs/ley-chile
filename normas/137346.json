{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m.&nbsp; 2,395.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6171696}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se declara de abono, para los efectos de su retiro, al sarjento-mayor don Antonio D. Hurtado dos a&#xF1;os cuatro meses i diecinueve dias, tiempo que permanecio fuera del Ej&#xE9;rcito con motivo de los sucesos pol&#xED;ticos del a&#xF1;o 1891.</div><br></div>", "i": 6171697}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, doce de setiembre de mil novecientos diez.- Emiliano Figueroa.- C&#xE1;rlos Larrain Claro. </div></div>", "i": 6171698}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2395", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2395"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-09-12", "doble_articulado": false, "id_norma": "137346", "numero_fuente": "9793", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-09-14", "vigencias": [{"desde": "1910-09-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-09-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1910-09-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci