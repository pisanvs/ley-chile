{"html": [{"t": "<div><div class=\"p\">AUTORIZA A DON HIPOLITO RUBEN CARCAMO SALAZAR PARA DESARROLLAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 6426381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 168, de 17 de Abril de 1984, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a don Hip&#xF3;lito Rub&#xE9;n C&#xE1;rcamo Salazar, c&#xE9;dula de identidad N&#xB0; 5.768.084-9 de Valdivia, domiciliado en Tres Espinos camino a Niebla, para instalar y operar un cultivo de choro zapato y chorito, en caleta Niebla, r&#xED;o Valdivia, comuna y provincia de Valdivia, en un &#xE1;rea de 17.300 m2 de fondos de r&#xED;o.</div><br></div>", "i": 6426382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de Abril de 1984.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6426383}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "168", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-168"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A DON HIPOLITO RUBEN CARCAMO SALAZAR PARA\nDESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1984-04-17", "fecha_derogacion": "1985-09-21", "doble_articulado": false, "id_norma": "211076", "numero_fuente": "31868", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1984-05-11", "vigencias": [{"desde": "1985-09-21", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1984-05-11", "hasta": "1985-09-20", "tipo_vers