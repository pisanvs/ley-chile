{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n de gracia a do&#xF1;a Agustina Toledo Dur&#xE1;n</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5959212}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a do&#xF1;a Agustina Toledo Dur&#xE1;n, hija del sargento 1.o de la &#xE9;poca de la Independencia, don Jos&#xE9; Ignacio Toledo, una pensi&#xF3;n mensual de treinta pesos.</div><div class=\"p\">&nbsp; &nbsp; La pensi&#xF3;n otorgada por la presente ley se disfrutar&#xE1; por el plazo de diez a&#xF1;os.</div><br></div>", "i": 5959213}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecisiete de Febrero de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- Bartolom&#xE9; Blanche E. </div></div>", "i": 5959214}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4318", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4318"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "CONCEDE PENSION DE GRACIAS A DOÑA AGUSTINA TOLEDO DURAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGUSTINA TOLEDO DURAN", "PENSION DE GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-02-17", "doble_articulado": false, "id_norma": "24657", "numero_fuente": "15011", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-02-28", "vigencias": [{"desde": "1928-02-28", "h