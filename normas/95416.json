{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 101, DE 1989 </div></div>", "i": 6099925}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n N&#xB0;101, de 12 de mayo de 1989 se ha facultado, a contar del presente a&#xF1;o escolar, a la direcci&#xF3;n del Instituto del Mar &quot;Capit&#xE1;n Williams&quot; de Chonchi, provincia de Chilo&#xE9;, X Regi&#xF3;n de Los Lagos, para conformar anualmente el Area de Asignaturas Electivas de las Especialidades que imparte, aprobadas por decreto supremo exento de Educaci&#xF3;n No. 255, de 1987.</div><br></div>", "i": 6099926}, {"t": "<div><div class=\"p\">- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6099927}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "101", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-101"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 101, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-12", "doble_articulado": false, "id_norma": "95416", "numero_fuente": "33404", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-06-22", "vigencias": [{"desde": "1989-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-06-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-06-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1998-03-13", "fecha_version":