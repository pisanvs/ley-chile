{"html": [{"t": "<div><div class=\"p\">MODIFICA ORDENANZA MUNICIPAL</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 403 exento.- Illapel, 24 de julio de 2001.- Vistos: El acuerdo del Concejo Municipal de fecha 17 de julio de 2001 y las atribuciones que me confiere la ley N&#xBA; 18.695, ley Org&#xE1;nica Constitucional de Municipalidades.</div><br><div class=\"p\">&nbsp; &nbsp;  D e c r e t o:</div><br><br></div>", "i": 6348497}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.- Modif&#xED;quese la ordenanza municipal eliminando el concepto de arriendo por compra, de nichos municipales en 10,7 UTM.</div><br><div class=\"p\">&nbsp; &nbsp;  2.- Publ&#xED;quese en el Diario Oficial.</div><br></div>", "i": 6348498}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y arch&#xED;vese.- Luis Lemus Aracena, Alcalde.- Mar&#xED;a Jorquera Valencia, Secretaria Municipal.</div><br></div>", "i": 6348499}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "403 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-403 EXENTO"}], "organismos": ["MUNICIPALIDAD DE ILLAPEL"], "titulo_norma": "MODIFICA ORDENANZA MUNICIPAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-07-24", "doble_articulado": false, "id_norma": "189155", "numero_fuente": "37055", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-09-06", "vigencias": [{"desde": "2001-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-09-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-09-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe