{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aumenta a $ 12,000 la pensi&#xF3;n de que disfruta don Francisco Ortega Mu&#xF1;oz</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 7169705}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- El&#xE9;vase, por gracia y a contar desde el 1.o de Enero de 1930, a la cantidad de doce mil pesos ($ 12,000) anuales, la pensi&#xF3;n de jubilaci&#xF3;n que disfruta don Francisco Ortega Mu&#xF1;oz.</div><br></div>", "i": 7169706}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diez de Enero de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Rodolfo Jaramillo B.</div><br></div>", "i": 7169707}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4778", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4778"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "AUMENTA A $ 12,000 LA PENSIÓN DE QUE DISFRUTA DON FRANCISCO ORTEGA MUÑOZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FRANCISCO ORTEGA MU OZ", "PENSION GRACIA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-01-10", "doble_articulado": false, "id_norma": "24905", "numero_fuente": "15572", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-01-14", "vigencias": [{"desde": "1930-01-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1930-01-14", "fin_