{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,964.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5957598}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Ab&#xF3;nase, por gracia, cinco a&#xF1;os de servicios a don Alberto Obrecht, Director del Observatorio Astron&#xF3;mico i Profesor de la Universidad de Chile, a fin de que pueda jubilar con el sueldo &#xED;ntegro asignado a sus empleos, en conformidad a las reglas jenerales establecidas para la jubilacion de los empleados p&#xFA;blicos.</div><br></div>", "i": 5957599}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 12 de Julio de 1923.- ARTURO ALESSANDRI.- Alcibiades Roldan.</div><br></div>", "i": 5957600}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3964", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3964"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ALBERTO OBRECHT", "JUBILACION", "ABONO POR GRACIA", "CONESION", "BENEFICIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1923-07-12", "doble_articulado": false, "id_norma": "24370", "numero_fuente": "13631", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1923-07-20", "vigencias": [{"desde": "1923-07-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigen