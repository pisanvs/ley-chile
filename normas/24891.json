{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede abono de tiempio de servicios a don Guillermo Chamorro</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional a dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5960695}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Ab&#xF3;nase, por gracia y para los efectos de su jubilaci&#xF3;n, al Secretario de la Corte de Apelaciones de Talca don Guillermo Chamorro Morales, el tiempo durante el cual sirvi&#xF3;, sin sueldo del Estado, el cargo de Secretario del Juzgado de Letras de Constituci&#xF3;n.</div><br></div>", "i": 5960696}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta y uno de Diciembre de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Rodolfo Jaramillo B.</div><br></div>", "i": 5960697}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4759", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4759"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE ABONO DE TIEMPO DE SERVICIOS A DON GUILLERMO CHAMORRO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["GUILLERMO CHAMORRO MORALES", "TIEMPO SERVIDO", "ABONO", "CONCESION", "JUBILACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-12-31", "doble_articulado": false, "id_norma": "24891", "numero_fuente": "15568", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-01-09", "vigencias": [{"desde": "1930-01-09", "hasta": "", "tipo_version":