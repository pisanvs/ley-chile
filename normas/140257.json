{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xBA;10, DE 1995</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 221.- Santiago, 16 de julio de 1999.- Vistos: Lo dispuesto en el Art. 4&#xBA; del decreto ley N&#xBA;2.974 de 1979.</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br><br></div>", "i": 6181338}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case la resoluci&#xF3;n N&#xBA; 10, de 20 de enero de 1995, que designa Ministros de Fe en la forma que se indica:</div><br><br><div class=\"p\">V REGION</div><br><div class=\"p\">Se eliminan a los se&#xF1;ores: Jos&#xE9; Bustos Quiroz y Eric Jofr&#xE9; Villalobos.</div><br><br><div class=\"p\">VII REGION</div><br><div class=\"p\">Se eliminan a los se&#xF1;ores: Jaime Rodr&#xED;guez Torres y Alberto Gonz&#xE1;lez Bravo.</div><br></div>", "i": 6181339}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Luis Marambio Canales, Director Nacional.</div><br></div>", "i": 6181340}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "221", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-221"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "MODIFICA RESOLUCION Nº10, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-07-16", "doble_articulado": false, "id_norma": "140257", "numero_fuente": "36433", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-08-07", "vigencias": [{"desde": "1999-08-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"