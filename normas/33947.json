{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6008385}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0;245, de 30 Agosto 1993, del SERVIU V. Regi&#xF3;n de Valpara&#xED;so, se dispuso expropiaci&#xF3;n conforme art. 87 Ley 8.946 y D.L. 2.186, de 1978, que afecta parcialmente inmueble rol aval&#xFA;o 5001-712, ubicado Sector Con-Con, Comuna Vi&#xF1;a del Mar, entre calles Manantiales y Diez, de presunto dominio del Cuerpo de Bomberos de Vi&#xF1;a del Mar, en superficie aproximada de 367 m2 Comisi&#xF3;n Tasadora integrada por arquitectos Osvaldo Mu&#xF1;oz Quintana y Edmundo Bravo Ubilla, y Constructor Civil Sr. Pablo Caria Giurici, seg&#xFA;n informe de 23 Agosto 1993, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 1.101.000.-, la que ser&#xE1; pagada de contado.-</div><br></div>", "i": 6008386}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director SERVIU V Regi&#xF3;n.</div><br></div>", "i": 6008387}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "245", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-245"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DECRETO EXPROPIATORIO", "EXPROPIACION", "BIEN RAIZ", "BIEN INMUEBLE", "VI A DEL MAR", "V REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-08-30", "doble_articulado": false, "id_norma": "33947", "numero_fuente": "34680-3", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-10-01", "vigencias": [{"desde": "1993-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-10-01", "fin_vigencia": ""}, "vigencias_versio