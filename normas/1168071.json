{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10282981}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xB0; 1.236, de 29 octubre 2021, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos relativas a realizaci&#xF3;n del Raid D&#xE9;cimo Aniversario Club Coyhaique Raid&apos;s en la Ciudad de Balmaceda, el d&#xED;a s&#xE1;bado 30 de octubre de 2021 entre las 09:00 y las 16:00 hrs., y autoriz&#xF3; a Club Coyhaique Raid&apos;s de Coyhaique para realizar intervenciones en v&#xED;a p&#xFA;blica por siguiente recorrido:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  -Fundo El Sauce (al suroeste de Balmaceda), direcci&#xF3;n sur por Ruta X-699; ingreso a Estancia La Frontera, y retorno a Fundo El Sauce.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10282982}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &#xD3;scar del Solar Navarrete, Gobernador Regional (S), Gobierno Regional de Ays&#xE9;n.- Ximena Guti&#xE9;rrez Jaramillo, Asesora Jur&#xED;dica, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10282983}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1236 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1236 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2038019", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-10-29", "doble_articulado": false, "id_norma": "1168071", "numero_fuente": "43099", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-11-10", "