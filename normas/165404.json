{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br></div>", "i": 6264559}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 803, de 18.11.85, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, renu&#xE9;vase la autorizaci&#xF3;n complementaria otorgada a la empresa de origen uruguayo &quot;General Artigas&quot;. por resoluci&#xF3;n No. 1.298, de Octubre 24 de 1984, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, para efectuar servicio internacional de transporte terrestre de pasajeros entre Montevideo (Uruguay) y Santiago (Chile), en tr&#xE1;nsito por territorio argentino, utilizando el paso Caracoles (T&#xFA;nel Cristo Redentor), con dos (2) frecuencias semanales.</div><br></div>", "i": 6264560}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Carlos Villegas Lorca, Subsecretario de Transportes Subrogante.</div><br></div>", "i": 6264561}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "803 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-803 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-04", "doble_articulado": false, "id_norma": "165404", "numero_fuente": "32347", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-14", "vigencias": [{"desde": "1985-12-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-12-14", "fin_vigencia": ""}, "vigencias_v