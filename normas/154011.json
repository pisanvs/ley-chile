{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6227628}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 325, de 04 de junio de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Nelva Mundaca para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 1 &quot;Hospital - Mait&#xE9;n&quot; de La Uni&#xF3;n, cuyo trazado fue autorizado por resoluci&#xF3;n No. 124 de 28 de junio de 1984 y modificado por resoluci&#xF3;n exenta No. 374 de 04 de septiembre de 1985, de esta Secretar&#xED;a Regional.</div><br></div>", "i": 6227629}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Enrique Brintrup Barrera, Secretario Regional Ministerial Transp. y Telec. X Regi&#xF3;n subrogante. </div></div>", "i": 6227630}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "325 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-325 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-04", "doble_articulado": false, "id_norma": "154011", "numero_fuente": "32553", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-08-21", "vigencias": [{"desde": "1986-08-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-08-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-08-21", "fin_vigencia": "