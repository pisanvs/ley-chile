{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6216328}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 673 de 27.05.87, conforme a Art. 229, 231, 239, y 234 de la Ley 16.640 y Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, revoc&#xF3; Resoluci&#xF3;n Exenta No. 348 de fecha 25.03.87 del mismo Servicio y determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a parcelas N&#xB0;s. 1 a la 20, sitios 1 al 18 y Reserva COBA No. 1 del Proyecto de Parcelaci&#xF3;n &quot;Las Coles&quot;, de la comuna de Chill&#xE1;n, formado por predios &quot;Las Coles o Cato o La Concepci&#xF3;n&quot;, &quot;Venecia&quot; y &quot;Santa Clara&quot;. Los Derechos de Agua se extraen del r&#xED;o Chill&#xE1;n y los canales Cato y &#xD1;uble o de La Luz.- Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.</div><br></div>", "i": 6216329}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6216330}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "673 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-673 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-05-27", "doble_articulado": false, "id_norma": "150514", "numero_fuente": "32784", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-01", "vigencias": [{"desde": "1987-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia