{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 7265892}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 560, de Agosto 16 de 1985, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se renueva la concesi&#xF3;n otorgada al se&#xF1;or Francisco Vera C&#xE1;rdenas por resoluciones Nos. 1.672/74 y 579/83, ambas del Ministerio de Transportes y Telecomunicaciones, para efectuar servicio regular de transporte internacional terrestre de pasajeros entre Punta Arenas (Chile) y R&#xED;o Gallegos (Argentina) por Paso Monte Aymond, efectuando dos frecuencias semanales.</div><br><br></div>", "i": 7265893}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Enrique Y&#xE1;var Mart&#xED;n, Coronel de Ej&#xE9;rcito, Subsecretario de Transportes.</div><br></div>", "i": 7265894}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "560", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-560"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-08-16", "doble_articulado": false, "id_norma": "161978", "numero_fuente": "32263", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-09-02", "vigencias": [{"desde": "1985-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-09-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci