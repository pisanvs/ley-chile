{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 69, DE 1987 </div></div>", "i": 7253116}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 69 de 13 de abril de 1987 se ha agregado a contar del presente a&#xF1;o escolar al plan de estudio aprobado por decreto supremo exento de Educaci&#xF3;n No. 189 de 1985, a la Escuela Agr&#xED;cola Femenina &quot;&#xD1;ielol&quot;, de Temuco, provincia de Caut&#xED;n; IX Regi&#xF3;n de La Araucan&#xED;a, la asignatura electiva &quot;El Arte Culinario&quot;, en 5&#xB0; a&#xF1;o, con 2 clases semanales.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se ha aprobado el programa de estudio correspondiente a dicha asignatura.</div><br></div>", "i": 7253117}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de Abril de 1987.- Ren&#xE9; Salam&#xE9; Mart&#xED;n, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7253118}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "69 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-69 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 69, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-04-13", "doble_articulado": false, "id_norma": "142549", "numero_fuente": "32754", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-04-24", "vigencias": [{"desde": "1987-04-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-04-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vige