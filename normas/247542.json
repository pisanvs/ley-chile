{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A PESQUERA ALTAMAR LTDA.</div><br></div>", "i": 6562255}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/N&#xBA;ex-995, de fecha 15 de febrero de 2006, otorga a Pesquera Altamar Ltda., RUT N&#xBA; 78.752.120-7, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de Sujeto en las ventas de Productos Hidrobiol&#xF3;gicos, establecido en la resoluci&#xF3;n N&#xBA; ex-3311, de 30-06-2000, de la Direcci&#xF3;n Nacional. La presente autorizaci&#xF3;n surtir&#xE1; efecto a partir del d&#xED;a primero del mes siguiente a la fecha de publicaci&#xF3;n de este extracto en el Diario Oficial y tendr&#xE1; vigencia indefinida.</div><br></div>", "i": 6562256}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 15 de febrero de 2006.- Ram&#xF3;n Concha Velis, Director Regional (S).</div><br></div>", "i": 6562257}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "995 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-995 EXENTA"}, {"tipo": "3", "numero": "DRE-08-995 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-995 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A PESQUERA ALTAMAR LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-02-15", "doble_articulado": false, "id_norma": "247542", "numero_fuente": "38398", "tipo_version": "3", "tipo_versi