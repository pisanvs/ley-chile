{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Rehabilita para su jubilaci&#xF3;n a don Faustino Lorca, ex-portero de la C&#xE1;mara de Senadores.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 8277361}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Se rehabilita al ex-portero de la C&#xE1;mara de Senadores, Faustino Lorca, en los derechos que ten&#xED;a adquiridos para los efectos de su jubilaci&#xF3;n y que perdi&#xF3; por haber sido separado de su empleo el 15 de Julio de 1907.</div><br></div>", "i": 8277362}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintitr&#xE9;s de Enero de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- Enrique Balmaceda. </div></div>", "i": 8277363}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4263", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4263"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "REHABILITA PARA SU JUBILACIÓN A DON FAUSTINO LORCA, EX-PORTERO DE LA CÁMARA DE SENADORES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FAUSTINO LORCA", "JUBILACION", "DERECHOS ADQUIRIDOS", "REHABILITACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-01-23", "doble_articulado": false, "id_norma": "24614", "numero_fuente": "14991", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-02-04", "vigencias": [{"desde": "1928-02-04", "hasta": "", "tipo_ver