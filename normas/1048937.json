{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 887 EXENTA, DE 2013</div></div>", "i": 9334028}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 887, de 8 de febrero de 2013, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Gamma Capacitaci&#xF3;n Limitada (Gamma Limitada)&quot;, RUT 76.609.500-3, contenida en la resoluci&#xF3;n exenta N&#xBA; 3.922, de 16 de noviembre de 2006, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.- </div></div>", "i": 9334029}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (PT).</div></div>", "i": 9334030}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "887 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-887 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 887 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-02-08", "doble_articulado": false, "id_norma": "1048937", "numero_fuente": "40489", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-02-19", "vigencias": [{"desde": "2013-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-02-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-02-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacione