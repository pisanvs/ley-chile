{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;672 EXENTO, DE 1995 </div></div>", "i": 6283073}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;672 de fecha 14 de diciembre de 1995 del Ministerio de Educaci&#xF3;n, se declar&#xF3; aprobado a la Universidad Academia de Humanismo Cristiano inscrita en el Registro de Universidades bajo el Folio C-N&#xBA;14 del a&#xF1;o 1988, el programa de Maestr&#xED;a en Investigaci&#xF3;n Educativa, conducente al grado acad&#xE9;mico de Magister en Investigaci&#xF3;n Educativa, para ser impartido a contar del 1er. semestre 1996, de conformidad al acuerdo adoptado por el Consejo Superior de Educaci&#xF3;n.</div><br></div>", "i": 6283074}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de diciembre de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6283075}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "672 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-672 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº672 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-12-14", "doble_articulado": false, "id_norma": "171243", "numero_fuente": "36692", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-17", "vigencias": [{"desde": "2000-06-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-06-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient