{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 441 EXENTO, DE 2000</div><br><br></div>", "i": 6307561}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 441, de 11 de octubre del 2000, se ha aprobado, a partir del a&#xF1;o escolar 2001, un programa de Religi&#xF3;n de la Comunidad Religiosa Testigos de Jehov&#xE1; de Chile, para los cursos de 1&#xBA; a 8&#xBA; a&#xF1;o de ense&#xF1;anza b&#xE1;sica, el que podr&#xE1; aplicarse conforme a la gradualidad establecida en el decreto supremo de Educaci&#xF3;n N&#xBA; 40 de 1996 y sus modificaciones y seg&#xFA;n lo establecido en el decreto supremo de Educaci&#xF3;n N&#xBA; 924 de 1983.</div><br></div>", "i": 6307562}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de octubre de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6307563}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "441 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-441 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 441 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-11", "doble_articulado": false, "id_norma": "177504", "numero_fuente": "36805", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-11-06", "vigencias": [{"desde": "2000-11-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-11-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-11-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos