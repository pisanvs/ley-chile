{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8328595}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 264, de 19 de febrero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de las resoluciones N&#xBA; 1143 de 1992 y N&#xBA; 747 de 1993, ambas de esta Subsecretar&#xED;a, que autorizaron a Pesquera Santa Lucia S.A., para ampliar actividades pesqueras con la nave &quot;Luc&#xED;a&quot;, Matr&#xED;cula 2647, por haber cesado sus operaciones por m&#xE1;s de un a&#xF1;o respecto de las pesquer&#xED;as autorizadas, en virtud de lo dispuesto en el Art&#xED;culo 143 letra b) del D.S. N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8328596}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de febrero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8328597}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "264", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-264"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA SANTA LUCIA S.A.", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-02-19", "doble_articulado": false, "id_norma": "97314", "numero_fuente": "36001", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-02-26", "vigencias": [{"desde": "1998-02-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-02