{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291244}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 232 de 8 de Marzo de 1995, de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, se deneg&#xF3; la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por la SOCIEDAD</div><div class=\"p\">PRODUCTORA LOS FIORDOS PATAGONICOS LTDA., para un sector</div><div class=\"p\">ubicado en el Estero Queulat, comuna de Cisnes,</div><div class=\"p\">Provincia de Ays&#xE9;n, XI Regi&#xF3;n, en virtud de lo dispuesto</div><div class=\"p\">en los art&#xED;culos 76&#xB0;, 77&#xB0;, 78&#xB0; y 5&#xB0; transitorio inciso</div><div class=\"p\">6&#xB0;, de la Ley General de Pesca y Acuicultura y el</div><div class=\"p\">art&#xED;culo 14&#xB0; del D.S. N&#xB0; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. Asimismo, se dej&#xF3; sin efecto la Resoluci&#xF3;n N&#xB0; 162 de 1991, de esta Subsecretar&#xED;a.</div><br></div>", "i": 8291245}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 8 de Marzo de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8291246}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "232", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-232"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION ACUICULTURA", "DENEGACION", "DECIMA REGION", "SOCIEDAD PRODUCTORA FIORDOS PATAGONICOS LTDA."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha