{"html": [{"t": "<div><div class=\"p\">AUTORIZA A RECEPTOR ELECTR&#xD3;NICO </div></div>", "i": 7354123}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 108 de 12 de septiembre de 2007, que autoriza a Organismo P&#xFA;blico como receptor electr&#xF3;nico.</div><br><div class=\"p\">&nbsp; &nbsp;  Se autoriza como receptor de documentos tributarios electr&#xF3;nicos, a contar del mes de septiembre de 2007, al Organismo P&#xFA;blico RUT 61.114.000-2.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de septiembre de 2007. </div></div>", "i": 7354124}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "108 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-108 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A RECEPTOR ELECTRÓNICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-09-12", "doble_articulado": false, "id_norma": "264937", "numero_fuente": "38867", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-09-21", "vigencias": [{"desde": "2007-09-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-09-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-09-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen