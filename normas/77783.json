{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9048915}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 168 de fecha 28 de Octubre de 1991 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n se cancel&#xF3; la personalidad jur&#xED;dica de la Asociaci&#xF3;n de Funcionarios Universitarios No Acad&#xE9;micos de Talca A.G. inscrita bajo el No. 48-7 del Registro que para tal efecto lleva este Ministerio por haberse configurado respecto de ella, la causal de cancelaci&#xF3;n contemplada en el art&#xED;culo 5&#xB0; inciso 3&#xB0; en relaci&#xF3;n con el art&#xED;culo 18 No. 2 letra a) del decreto ley No. 2.757, de 1979.-</div><br></div>", "i": 9048916}, {"t": "<div><div class=\"p\">Jorge Marshall Rivera, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 9048917}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "168", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-168"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-10-28", "doble_articulado": false, "id_norma": "77783", "numero_fuente": "34344", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-08-18", "vigencias": [{"desde": "1992-08-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-08-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-08-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "