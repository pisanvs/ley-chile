{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 530 EXENTO, DE 2002 </div></div>", "i": 6389306}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 530 de fecha 18 de junio de 2002 del Ministerio de Educaci&#xF3;n, se aprueban las modificaciones introducidas al plan y programas de estudios del Centro de Formaci&#xF3;n T&#xE9;cnica Osorno, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar de agosto del a&#xF1;o 2002, en la Casa Central de Osorno, con la siguiente denominaci&#xF3;n:</div><br><br><div class=\"p\">Carrera&nbsp; : Secretariado Ejecutivo con especialidad</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  en Automatizaci&#xF3;n de Oficinas, cambia por:</div><br><div class=\"p\"> Carrera&nbsp; : Secretariado Ejecutivo Jur&#xED;dico Computacional.</div><div class=\"p\"> T&#xED;tulo&nbsp;  : Secretario(a) Ejecutivo(a) Jur&#xED;dico Computacional.</div><br></div>", "i": 6389307}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de julio de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6389308}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "530 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-530 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 530 EXENTO, DE 2002", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-06-18", "fecha_derogacion": "2015-06-25", "doble_articulado": false, "id_norma": "200571", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-07-17", "vigencias": [{"desde": "2015-06-