{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8945593}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.016, de 5 de julio de 2010, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la <a href=\"https://www.leychile.cl/Navegar?idNorma=194701&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 307 de 2002</a> de esta Subsecretar&#xED;a, que autoriz&#xF3; a MAR&#xCD;A BAYCIC BAYCIC para ampliar actividades pesqueras extractivas con la nave &quot;Don Mario&quot;, respecto del recurso hidrobiol&#xF3;gico Reineta, en el &#xE1;rea mar&#xED;tima comprendida entre la XV a III Regiones, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8945594, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de julio de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div><br></div>", "i": 8945595}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2016 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2016 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-07-05", "doble_articulado": false, "id_norma": "1015184", "numero_fuente": "39707", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-07-10", "vigencias": [{"desde": "2010-07-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-07-10", "fin_vigencia": ""}, "vigencias_version_norma":