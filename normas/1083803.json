{"html": [{"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">SE APRUEBA INSTRUCTIVO INSTITUCIONAL &quot;PROCEDIMIENTO PARA ALUMNOS EN PR&#xC1;CTICA&quot;</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 9648712}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 556, de 16 de octubre de 2015, se aprueba para el Instituto de Previsi&#xF3;n Social el Instructivo Institucional &quot;Procedimiento para Alumnos en Pr&#xE1;ctica&quot;, que describe el procedimiento de selecci&#xF3;n, inserci&#xF3;n, participaci&#xF3;n, aprendizaje y egreso de alumnos en pr&#xE1;ctica de estudio en el IPS, adem&#xE1;s de los procedimientos asociados a la generaci&#xF3;n de convenios con establecimientos educacionales.</div><br></div>", "i": 9648713}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 6 de noviembre de 2015.- Patricio Coronado Rojo, Director Nacional.</div></div>", "i": 9648714}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "556 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-556 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARÍA DE PREVISIÓN SOCIAL", "INSTITUTO DE PREVISIÓN SOCIAL"], "titulo_norma": "SE APRUEBA INSTRUCTIVO INSTITUCIONAL \"PROCEDIMIENTO PARA ALUMNOS EN PRÁCTICA\"", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-10-16", "doble_articulado": false, "id_norma": "1083803", "numero_fuente": "41306", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-11-13", "vigencias": [{"desde": "2015-11-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia