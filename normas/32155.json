{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; REQUERIMIENTO A SECRETARIOS MUNICIPALES </div></div>", "i": 6003099}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Director del Servicio Electoral requiere a los Secretarios Municipales de todas las municipalidades del pa&#xED;s, para que le informen si se han constituido los Concejos de sus respectivos municipios, dentro del plazo de quinto d&#xED;a contado desde la fecha de esta publicaci&#xF3;n en conformidad con lo establecido en la disposici&#xF3;n d&#xE9;cima transitoria de la ley N&#xB0; 19.175, modificada por ley N&#xB0; 19.194, y para los efectos de la disposici&#xF3;n trig&#xE9;sima tercera transitoria de la Constituci&#xF3;n Pol&#xED;tica.</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n que se efect&#xFA;a en virtud de la Resoluci&#xF3;n 0-N&#xB0; 0017, de 22 de Enero de 1993, del Servicio Electoral.</div><br></div>", "i": 6003100}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director Servicio Electoral.</div><br></div>", "i": 6003101}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "17", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-17"}, {"tipo": "3", "numero": "O-0017", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-0017"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "REQUERIMIENTO A SECRETARIOS MUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REQUERIMIENTO", "CONCEJO MUNICIPAL", "SECRETARIO MUNICIPAL", "MUNICIPALIDADES", "SERVICIO ELECTORAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-01-22", "doble_articulado": false, "id_norma": "32155", "numero_fuente": "34480-2", "tipo_version": "3", "tipo_vers