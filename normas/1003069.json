{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.306 EXENTA, DE 2009</div></div>", "i": 8669504}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 3.306, de 6 de abril de 2009, se ha aprobado plan y programas especiales de estudio de 1&#xBA; y 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media, al Liceo Experimental Art&#xED;stico de Santiago administrado por la Corporaci&#xF3;n Educacional de Desarrollo Art&#xED;stico.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio de los Subsectores del Plan de Formaci&#xF3;n Complementaria para los cursos de 1&#xBA; y 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media que se indican en la presente resoluci&#xF3;n.</div></div>", "i": 8669505}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de mayo de 2009.- Rosita Puga Hamilton, Jefa Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 8669506}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3306 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-3306 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.306 EXENTA, DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-04-06", "doble_articulado": false, "id_norma": "1003069", "numero_fuente": "39378", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-06-04", "vigencias": [{"desde": "2009-06-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-06-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009