{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6267489}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 523 de 14 de diciembre de 1984, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se autoriza a do&#xF1;a, Mercedes Lara Henr&#xED;quez, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro de territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6267490}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco Navarro Ruiz, Secretario Regional Ministerial de Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6267491}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "523 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-523 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-12-14", "doble_articulado": false, "id_norma": "166273", "numero_fuente": "32081", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-01-26", "vigencias": [{"desde": "1985-01-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-01-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-01-26", "fin_vigencia": "", "tip