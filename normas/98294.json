{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 360 EXENTO, DE 1998</div><br><br></div>", "i": 6108583}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;360 de fecha 3 de marzo de 1998, del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a las sedes que se indican del Centro de Formaci&#xF3;n T&#xE9;cnica Diego Portales, para impartir plan y programas de estudios aprobados para la instituci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se se&#xF1;ala, a partir del a&#xF1;o 1998:</div><br><div class=\"p\">Sedes N&#xBA; 2 de Vi&#xF1;a del Mar y N&#xBA; 3 de Chill&#xE1;n.</div><br><div class=\"p\">Carrera&nbsp; &nbsp;  : Topograf&#xED;a.</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; &nbsp; : T&#xE9;cnico en Topograf&#xED;a.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; (Decreto exento N&#xBA;312 del 26.11.91).</div><br></div>", "i": 6108584}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de abril de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6108585}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "360 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-360 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 360 EXENTO, DE 1998", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "CENTRO DE FORMACION TECNICA DIEGO PORTALES", "VI A DEL MAR", "QUINTA REGION", "CHILLAN", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-03-03", "fecha_derogacion": "2015-06-25", "doble_articulado": false, "id_norma": "98294", "tipo_version": "2", "tipo_v