{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Seccion 1.a, n&#xFA;m. 1,632.-Santiago, 25 de noviembre de 1901.-He acordado i decreto:</div></div>", "i": 9377961}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Sobre la base de la actual oficina de Embarques i Trasportes del Estado Mayor Jeneral, Organ&#xED;zase una seccion que se compondr&#xE1; de tres departamentos.</div><br><div class=\"p\">&nbsp; &nbsp;  Primer Departamento:</div><br><div class=\"p\">&nbsp; &nbsp;  Estudios del servicio de comunicaciones.</div><br><div class=\"p\">&nbsp; &nbsp;  Segundo Departamento:</div><br><div class=\"p\">&nbsp; &nbsp;  a) Asuntos relativos a la academia de guerra;</div><div class=\"p\">&nbsp; &nbsp;  b) Historia militar.</div><br><div class=\"p\">&nbsp; &nbsp;  Tercer Departamento:</div><br><div class=\"p\">&nbsp; &nbsp;  c) Grandes maniobras;</div><div class=\"p\">&nbsp; &nbsp;  d) Viajes de instruccion de oficiales del Estado Mayor Jeneral i de los Estados Mayores de Zonas.</div><div class=\"p\">&nbsp; &nbsp;  El Estado Mayor Jeneral propondr&#xE1; al Gobierno el personal correspondiente.</div></div>", "i": 9377962}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese i publ&#xED;quese. - RIESCO.- B. Mathieu.</div></div>", "i": 9377963}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1632", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1632"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-11-25", "doble_articulado": false, "id_norma": "1055055", "numero_fuente": "7082", "tipo_version": "3", "tipo_version_s":