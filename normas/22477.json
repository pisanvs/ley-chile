{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Construccion, conservacion i reparacion de puentes Lei n&#xFA;m. 1,210._ Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948607}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza al Presidente de la Republica para que invierta, durante el a&#xF1;o en curso, hasta la suma de trescientos mil pesos en atender a la construccion, conservacion i reparacion de puentes.</div><br><br></div>", "i": 5948608}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 2 de Febrero de 1899.- FEDERICO ERRAZURIZ.- Arturo Alessandri.</div><br></div>", "i": 5948609}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1210", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1210"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "CONSTRUCCION, COSERVACION I REPARACION DE PUENTES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTE REPUBLICA", "PUENTES", "FONDOS", "DESTINACION", "CONSTRUCCION", "REPARACION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-02-02", "doble_articulado": false, "id_norma": "22477", "numero_fuente": "6220", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-02-03", "vigencias": [{"desde": "1899-02-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-02-03", "fin_vigencia": ""},