{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9207343}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.087, de 21 de noviembre de 2011, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la <a href=\"https://www.leychile.cl/Navegar?idNorma=249823&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.285 de 2006</a>, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a Pesquera del Norte S.A, hoy FOODCORP S.A. para realizar actividades pesqueras extractivas con la nave &quot;Cazador&quot;, respecto de los recursos hidrobiol&#xF3;gicos autorizados en la letra f) de la mencionada resoluci&#xF3;n, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum citado en Visto de la resoluci&#xF3;n extractada.</div></div>", "i": 9207344}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de noviembre de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9207345}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3087 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3087 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-11-21", "doble_articulado": false, "id_norma": "1033169", "numero_fuente": "40120", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-11-26", "vigencias": [{"desde": "2011-11-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única