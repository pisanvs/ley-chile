{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8953692}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.255, de 5 de Julio de 1996, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto el Numeral 2&#xB0; de la Resoluci&#xF3;n N&#xB0; 213 de 1996, que declar&#xF3; la<span class=\"n\" id=\"n_0\">RECTIFICACION<br>D.O. 09.10.1996</span> caducidad parcial de la Resoluci&#xF3;n N&#xB0; 260, de 1983, ambas de esta Subsecretar&#xED;a, que autorizaba a INVERSIONES DELFINES SOCIEDAD ANONIMA CERRADA, para realizar actividades pesqueras extractivas con la nave &quot;Punta Arenas&quot;, en virtud de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor, respecto de la paralizaci&#xF3;n de actividades en el litoral de I y II Regi&#xF3;n. En consecuencia, la Resoluci&#xF3;n N&#xB0; 260 de 1983 contin&#xFA;a plenamente v&#xE1;lida en el litoral de la I a IV Regi&#xF3;n. </div></div>", "i": 8953693}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 5 de Julio de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8953694}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "3", "numero": "1255", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1255"}], "organismos": ["MINISTERIO DE ECONOMÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INVERSIONES DELFINES SOCIEDAD ANONIMA CERRADA", "MODIFICACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-07-05", "fecha_derogacion": "1997-03-06", "doble_articulado": false, "id_norma": "36592", "numero_fuente": "35533", "tipo_version": "2", "tipo_version_