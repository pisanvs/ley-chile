{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0;3.223 EXENTA, DE 2013</div></div>", "i": 9351943}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 3.223, de 30 de abril de 2013, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Organismo T&#xE9;cnico Capacitador Prodetec Limitada (Prodetec Ltda.)&quot;, RUT 76.090.368-K, contenida en la resoluci&#xF3;n exenta N&#xB0; 4.381, de 4 de mayo de 2010, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xB0; 2, del Art. 21 de la ley 19.518.- </div><br></div>", "i": 9351944}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (S).</div></div>", "i": 9351945}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3223 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3223 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N°3.223 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-04-30", "doble_articulado": false, "id_norma": "1050964", "numero_fuente": "40556", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-05-11", "vigencias": [{"desde": "2013-05-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-05-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-05-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient