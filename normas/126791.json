{"html": [{"t": "<div><div class=\"p\">TASA DE INTERES PROMEDIO</div><br><br><br></div>", "i": 6138081}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 11,62% anual durante el mes de octubre de 1998.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad con lo dispuesto en el N&#xBA;5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de octubre de 1998, fue de 9,44% anual. </div></div>", "i": 6138082}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 2 de noviembre de 1998.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6138083}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "TASA DE INTERES PROMEDIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA DE INTERES PROMEDIO", "OPERACIONES DE CREDITO DE DINERO", "CAPTACION", "TIP"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-02", "doble_articulado": false, "id_norma": "126791", "numero_fuente": "36206", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-11-05", "vigencias": [{"desde": "1998-11-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-11-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998