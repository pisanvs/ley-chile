{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACION PARCIAL DE INMUEBLE QUE SE&#xD1;ALA </div><br><br></div>", "i": 6130150}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 439 de 27 de agosto de 1998 de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xBA; 2.186 de 1978, parte del inmueble ubicado en Pasaje Jovino Novoa N&#xBA; 275, presunto rol de aval&#xFA;os&nbsp; N&#xBA;1-28, comuna de Lampa, de aparente dominio de Sucesi&#xF3;n Espinosa Munita. Comisi&#xF3;n integrada por peritos Ren&#xE9; Ureta K&#xF6;ster, arquitecto, Jos&#xE9; Miguel Haltenhoff Aenishanslin y M&#xE1;ximo Cort&#xE9;s Evaristi, constructores civiles, seg&#xFA;n informe de 6 de octubre de 1997, fij&#xF3; monto provisional de indemnizaci&#xF3;n en $441.825.- pagadera al contado.</div><br></div>", "i": 6130151}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; - Director Serviu Metropolitano.</div><br></div>", "i": 6130152}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "439", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-439"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACION PARCIAL DE INMUEBLE QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "LAMPA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NOTIFICACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-27", "doble_articulado": false, "id_norma": "124248", "numero_fuente": "36165", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-09-15", "vigencias": [{"desde": "1998-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ú