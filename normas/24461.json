{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Deroga decreto-ley 670, sobre censura de publicidad y noticias en tiempo de guerro o de conmoci&#xF3;n interior.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 5958263}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.&#xB0; Der&#xF3;gase el decreto-ley n&#xFA;mero 670, de 17 de Octubre de 1925, sobre censura de publicidad y noticias en tiempo de guerra o de conmoci&#xF3;n interior. </div></div>", "i": 5958264}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 2.&#xB0; Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 5958265}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a quince de Septiembre de mil novecientos veintis&#xE9;is.- Emiliano Figueroa.- Carlos Iba&#xF1;ez C. </div></div>", "i": 5958266}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4089", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4089"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "DEROGA DECRETO-LEY 670, SOBRE CENSURA DE PUBLICIDAD Y NOTICIAS EN TIEMPO DE GUERRO O DE CONMOCION INTERIOR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PUBLICIDAD", "NOTICIAS", "CENSURA", "TIEMPO DE GUERRA", "CONMOCION INTERIOR", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1926-09-15", "doble_articulado": false, "id_norma": "24461", "numero_fuente": "14585", "ti