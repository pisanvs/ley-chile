{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobacion a los siguientes</div><br><div class=\"p\">PROYECTO DE LEI:</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;mero 3,135:</div><br></div>", "i": 6177134}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Prudencia Avila v. de Rodr&#xED;guez, una pension mensual de setenta pesos ($ 70), en vez de la que disfruta actualmente&quot;.</div><br></div>", "i": 6177135}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlos i sancionarlos; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como leyes de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintitres de setiembre de mil novecientos dieciseis.- Juan Luis Sanfuentes.- J. Boonen Rivera. </div></div>", "i": 6177136}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3135", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3135"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-09-23", "doble_articulado": false, "id_norma": "138966", "numero_fuente": "11583", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-09-27", "vigencias": [{"desde": "1916-09-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1916-09-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1916-09-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por":