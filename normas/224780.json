{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6477480}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.124, de 27 de abril de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a GLOBALPESCA S.A. para realizar actividades extractivas en aguas internacionales con la nave &quot;Globalpesca I&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; CB-7961</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  3086</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 55,37 m.</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  10,00 m.</div><div class=\"p\">Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 4,20 m.</div><div class=\"p\">T.R.G. (Internacional)&nbsp; &nbsp; &nbsp; 878,00</div><br></div>", "i": 6477481}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de abril de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6477482}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1124", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1124"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTARCTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-27", "doble_articulado": false, "id_norma": "224780", "numero_fuente": "37852", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-05-05", "vig