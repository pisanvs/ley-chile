{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><br></div>", "i": 7170038}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Agr&#xE9;gase a continuaci&#xF3;n de la palabra &quot;Hipotecario:, que figura en el art&#xED;culo 5.o de la ley n&#xFA;mero 4,885, de 6 de Septiembre de 1930, la siguiente frase: &quot;o dem&#xE1;s instituciones de cr&#xE9;dito regidas por las disposiciones de la ley de 29 de Agosto de 1855, modificada por por el decreto ley N.o 743 y promulgadas refundidas en el decreto N.o 2,829, de 21 de Diciembre de 1925&quot;.</div><div class=\"p\">&nbsp; &nbsp; Esta ley comenzar&#xE1; a regir desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 7170039, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintinueve de Septiembre de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Bartolom&#xE9; Blanche E.</div><br></div>", "i": 7170040}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4899", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4899"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LOTERIA BENEFICENCIA PUBLICA", "FONDOS RESERVA", "INVERSION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-09-29", "doble_articulado": false, "id_norma": "24963", "numero_fuente": "15787", "t