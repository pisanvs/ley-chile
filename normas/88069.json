{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6077990}, {"t": "<div><div class=\"p\">Certifico que por Resoluci&#xF3;n No. E-056, de 25 de marzo de 1991, se ha revocado la autorizaci&#xF3;n de existencia y dispuesto la liquidaci&#xF3;n de la Administradora de Fondos de Pensiones Bannuestra S.A., por infracci&#xF3;n a lo dispuesto en el art&#xED;culo 24 del D.L.3.500 de 1980.</div><br><div class=\"p\">La autorizaci&#xF3;n de existencia de esta Administradora fue concedida por Resoluci&#xF3;n No.E-054 de 27 de octubre de 1989, cuyo certificado se encuentra inscrito a fs.29.328 No.15.843 de noviembre de 1980, en el Registro de Comercio de Santiago.</div><br></div>", "i": 6077991}, {"t": "<div><div class=\"p\">Santiago, 25 de Marzo de 1991.- Julio Bustamante Jeraldo, Superintendente.</div><br></div>", "i": 6077992}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "56", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-56"}, {"tipo": "3", "numero": "E-056", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-E-056"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARIA DE PREVISION SOCIAL", "SUPERINTENDENCIA DE ADMINISTRADORAS DE FONDOS DE PENSIONES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-03-25", "doble_articulado": false, "id_norma": "88069", "numero_fuente": "33931", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-01", "vigencias": [{"desde": "1991-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-04-01", "fin_vigencia": ""}, "vigencias_version_n