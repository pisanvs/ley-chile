{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 5.715 EXENTA DE 2001 </div></div>", "i": 6337381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 5.715 de 17 de mayo del a&#xF1;o 2001, se ha aprobado a los Colegios Administrados por la Corporaci&#xF3;n Iglesia Adventista del S&#xE9;ptimo D&#xED;a, de Santiago, el siguiente plan de estudio para todos los cursos de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban los siguientes programas de estudio para 1&#xBA;, 2&#xBA;, 3&#xBA;, 4&#xBA;, a&#xF1;o de Ense&#xF1;anza Media, para los Subsectores que a continuaci&#xF3;n se indican. </div></div>", "i": 6337382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de mayo de 2001.- Juan Ruz Ruz, Jefe Divisi&#xF3;n Educaci&#xF3;n General </div></div>", "i": 6337383}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5715 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5715 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 5.715 EXENTA DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-17", "doble_articulado": false, "id_norma": "186088", "numero_fuente": "36978", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-06-04", "vigencias": [{"desde": "2001-06-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-06-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-06-04", "fin_vigencia