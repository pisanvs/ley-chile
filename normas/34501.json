{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292075}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 373, de 21 de febrero de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, cad&#xFA;case parcialmente la Resoluci&#xF3;n N&#xB0; 245, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don PEDRO AVILEZ SEPULVEDA, en cuanto a la autorizaci&#xF3;n para operar la nave &quot;Punta Galant&quot;, en virtud de lo dispuesto en el art&#xED;culo 143&#xB0; letras b) y d) del D.S. N&#xB0; 430, de 1991 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, que fij&#xF3; el texto refundido de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8292076}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 21 de febrero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292077}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "373", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-373"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "PEDRO AVILEZ SEPULVEDA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-02-21", "doble_articulado": false, "id_norma": "34501", "numero_fuente": "35405", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-02-29", "vigencias": [{"desde": "1996-02-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-02-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "199