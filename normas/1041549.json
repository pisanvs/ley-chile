{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 5.821 EXENTA, DE 2012</div></div>", "i": 9271861}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 5.821, de 25 de junio de 2012, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Capacitaci&#xF3;n y Asesor&#xED;as Buchholz Limitada (Azor Ltda. o Azor Asesor&#xED;as Ltda.)&quot;, RUT 77.584.130-3 contenida en la resoluci&#xF3;n exenta N&#xBA; 1.978, de 4 de septiembre de 2006, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del art. 21 de la ley 19.518.-</div></div>", "i": 9271862}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (PT).</div></div>", "i": 9271863}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5821 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5821 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 5.821 EXENTA, DE 2012", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2012-06-25", "fecha_derogacion": "2012-07-30", "doble_articulado": false, "id_norma": "1041549", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2012-07-05", "vigencias": [{"desde": "2012-07-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2012-07-05", "hasta": "2012-07-29", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2012-07-30", "fin_vige