{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 90, DE 2005 </div></div>", "i": 6520802}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 90, del 3 de marzo de 2005, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la III Regi&#xF3;n de Atacama, se dispuso el cierre de la Planta de Revisi&#xF3;n T&#xE9;cnica Clase AB 0306, que practica revisi&#xF3;n t&#xE9;cnica de veh&#xED;culos Clase AB, en la comuna de Vallenar, Tercera Regi&#xF3;n de Atacama, concesionada a do&#xF1;a Mirza Cort&#xE9;s Acosta, a contar del 3 de marzo de 2005, y se declara la extinci&#xF3;n de la Pr&#xF3;rroga del Contrato de Concesi&#xF3;n de la misma Planta Revisora.-</div><br></div>", "i": 6520803}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Mois&#xE9;s Illanes Rojas, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Tercera Regi&#xF3;n de Atacama.</div><br></div>", "i": 6520804}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "90", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-90"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES", "SECRETARíA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 90, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-03-03", "doble_articulado": false, "id_norma": "236796", "numero_fuente": "38125", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-04-02", "vigencias": [{"desde": "2005-04-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig