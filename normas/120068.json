{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6114860}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Decreto Secc. 2&#xAA; N&#xBA; 439, 05/06/1998, Alcalde Municipalidad Santiago dispone expropiaci&#xF3;n parcial, conforme art. 85 decreto 458 Ministerio de Vivienda y Urbanismo inmueble Almirante Barroso 633 esquina Nororiente Santo Domingo Rol N&#xBA; 220-010-011-012, comuna Santiago, dominio aparente Inmobiliaria e Inversiones Maksimir Limitada, superficie aproximada 158 metros cuadrados. Deslindes. Norte, 28,25 mts. l&#xED;nea quebrada resto predio; Sur, 28,25 mts. calle Santo Domingo; Oriente, 4,90 mts. otro propietario y 7,27 mts. resto predio, incluyendo ochavo 4 mts. y Poniente, 11,97 mts. calle Almirante Barroso. Indemnizaci&#xF3;n $27.075.670.- pagadera contado. </div></div>", "i": 6114861}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jaime Ravinet de la Fuente, Alcalde Santiago. </div></div>", "i": 6114862}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "439", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-439"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-06-05", "doble_articulado": false, "id_norma": "120068", "numero_fuente": "36089", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-06-15", "vigencias": [{"desde": "1998-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-06-15", "fin_vigenc