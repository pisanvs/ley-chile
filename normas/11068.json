{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DEROGA DECRETO QUE SE&#xD1;ALA</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 214.- Santiago, 20 de Octubre de 1992.- Visto: El DL. N&#xB0; 557 de 1974 y las facultades que me confiere el N&#xB0; 8 del art&#xED;culo 32 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 7141756}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Der&#xF3;gase el decreto supremo N&#xB0; 145, de 19 de Julio de 1991, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes. </div></div>", "i": 7141757}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Germ&#xE1;n Molina Valdivieso, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Saluda a Ud. Patricia Mu&#xF1;oz Villela, Jefe Depto. Administrativo. </div></div>", "i": 7141758}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "214", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-214"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "DEROGA DECRETO QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DEROGACION", "CIRCULACION VEHICULAR", "RESTRICCION VEHICULAR", "LOCOMOCION COLECTIVA", "VEHICULO MOTORIZADO", "SANTIAGO", "ZONA RESTRICCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-10-20", "doble_articulado": false, "id_norma": "11068", "numero_fuente": "34421", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-11-20", "vigencias": [{"desd