{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6412611}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n, que suscribe, certifica que la Universidad Bolivariana inscrita bajo el n&#xFA;mero C-10 del Registro del Ministerio de Educaci&#xF3;n, ha presentado los programas de estudio de la carrera de &quot;Periodismo&quot; conducente al t&#xED;tulo de &quot;Periodista&quot;, a la Universidad Cat&#xF3;lica del Norte, como entidad examinadora y revisados por &#xE9;sta han sido aprobados.</div><div class=\"p\">&nbsp; &nbsp;  La carrera mencionada podr&#xE1; impartirse a contar de 1990.</div><br></div>", "i": 6412612}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de Enero de 1991.</div><div class=\"p\">&nbsp; &nbsp;  RAUL ALLARD NEUMANN Subsecretario de Educaci&#xF3;n </div></div>", "i": 6412613}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-31", "doble_articulado": false, "id_norma": "207318", "numero_fuente": "33908", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-03-02", "vigencias": [{"desde": "1991-03-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-03-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-03-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "f