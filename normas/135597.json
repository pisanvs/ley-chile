{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,955.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165949}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados al pais por el sarjento-mayor graduado, don Jos&#xE9; Agustin Campos, conc&#xE9;dese a su viuda do&#xF1;a Octavia Potts v. de Campos, el goce de la pension de sarjento-mayor en vez de la de capitan que actualmente disfruta.</div><br></div>", "i": 6165950}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, diez de julio de mil novecientos siete.- Pedro Montt.- Alejandro Lira.</div><br></div>", "i": 6165951}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1955", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1955"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-07-10", "doble_articulado": false, "id_norma": "135597", "numero_fuente": "8845", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-07-10", "vigencias": [{"desde": "1907-07-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-07-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1907-07-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "