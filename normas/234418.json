{"html": [{"t": "<div><div class=\"p\">LEY NUM. 9.709</div><br><div class=\"p\">CONCEDE AMNISTIA AL EX CARABINERO DON LUIS ARMANDO VERGARA TORRES</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6512235}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Conc&#xE9;dese amnist&#xED;a al ex carabinero don Luis Armando Vergara Torres por el delito de primera deserci&#xF3;n simple en tiempo de paz, cometido en Junio de 1942, a que fu&#xE9; condenado por los Tribunales Militares. </div></div>", "i": 6512236}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, seis de Octubre de mil novecientos cincuenta.- GABRIEL GONZALEZ VIDELA.- Humberto Parada. </div></div>", "i": 6512237}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "9709", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-9709"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDE AMNISTIA AL EX CARABINERO DON LUIS ARMANDO\nVERGARA TORRES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1950-10-06", "doble_articulado": false, "id_norma": "234418", "numero_fuente": "21784", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1950-10-23", "vigencias": [{"desde": "1950-10-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1950-10-23", "fin_vigencia": ""}, "vigencias_vers