{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">Comercio de Chile con el Per&#xFA;</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Mayo 11 de 1822.</div></div>", "i": 9922213}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Con lo informado por la Junta Gubernativa i Econ&#xF3;mica de Hacienda, se declara que estando mandado por decreto de 8 de Febrero del a&#xF1;o pr&#xF3;ximo pasado, impreso en la Ministerial, n&#xFA;mero 79, tomo 2&#xB0;, contin&#xFA;e el comercio de Chile con las provincias libres del Per&#xFA; en el estado que tenia &#xE1;ntes de nuestra emancipacion pol&#xED;tica, sujet&#xE1;ndose los introductores a la presentacion de rejistros, segun reglamentos; no hai arbitrios para alterar por ahora una disposicion tan interesante a dos potencias amigas, i tan precautoria del fraude.</div><br></div>", "i": 9922214}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, impr&#xED;mase i circ&#xFA;lese.-O&apos;Higgins.-Rodr&#xED;guez.</div></div>", "i": 9922215}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTRO", "descripcion": "Otro", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Comercio de Chile con el Perú", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1822-05-11", "doble_articulado": false, "id_norma": "1117151", "numero_fuente": "1822", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1822-05-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1822-05-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "