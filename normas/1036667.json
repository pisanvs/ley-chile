{"html": [{"t": "<div><br><div class=\"p\">SOLICITA INSCRIPCI&#xD3;N EN REGISTRO DE PARTIDOS POL&#xCD;TICOS A PARTIDO AIRE</div></div>", "i": 9229180}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Enrique Hern&#xE1;n Jim&#xE9;nez Valenzuela y Javier Andre Soto Fuentes, Presidente y Secretario General, respectivamente, de la entidad pol&#xED;tica en formaci&#xF3;n denominada Aire, han solicitado con fecha 11 de enero de 2012, la inscripci&#xF3;n de la entidad en el Registro de Partidos Pol&#xED;ticos, en la Regiones X, XI y XII. La solicitud de inscripci&#xF3;n se&#xF1;ala acompa&#xF1;ar, la cantidad de afiliados que se indican:</div><br><div class=\"p\">X Regi&#xF3;n:&nbsp; &nbsp; &nbsp;  1.951</div><div class=\"p\">XI Regi&#xF3;n:&nbsp; &nbsp; &nbsp; 307</div><div class=\"p\">XII Regi&#xF3;n:&nbsp; &nbsp;  447</div><br><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en los art&#xED;culos 9&#xBA; y 11&#xBA; de la ley N&#xBA; 18.603, por resoluci&#xF3;n O-N&#xBA; 233, de fecha 12 de enero de 2012.</div></div>", "i": 9229181}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div></div>", "i": 9229182}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "233", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-233"}, {"tipo": "3", "numero": "O-233", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-O-233"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA INSCRIPCIÓN EN REGISTRO DE PARTIDOS POLÍTICOS A PARTIDO AIRE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-01-12"