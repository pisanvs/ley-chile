{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente.</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6428330}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para enajenar en remate p&#xFA;blico, el destructor &quot;Lientur&quot; y el escampav&#xED;a &quot;Colo Colo&quot;, de la Armada Nacional&quot;.</div><br></div>", "i": 6428331}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veinticinco de Julio de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Carlos O. Frodden. </div></div>", "i": 6428332}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4867", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4867"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "PROYECTO DE LEY:", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-07-25", "doble_articulado": false, "id_norma": "211586", "numero_fuente": "15742", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-08-06", "vigencias": [{"desde": "1930-08-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1930-08-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1930-08-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2003-06-24"