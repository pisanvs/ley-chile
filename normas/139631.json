{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8347102}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;1.263, de 8 de julio de 1999,&nbsp; de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA EL GOLFO S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluciones N&#xBA;355 de 1993 y N&#xBA;1.324 de 1998, ambas de esta Subsecretar&#xED;a, en la forma y bajo las condiciones que a continuaci&#xF3;n se expresan.</div><div class=\"p\">&nbsp; &nbsp;  La peticionaria podr&#xE1; incorporar a la planta ubicada en calle Col&#xF3;n N&#xBA;2400, Talcahuano, en la l&#xED;nea de elaboraci&#xF3;n de Congelado, el recurso hidrobiol&#xF3;gico: Orange roughy.</div><br></div>", "i": 8347103}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de julio de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8347104}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1263", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1263"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-07-08", "doble_articulado": false, "id_norma": "139631", "numero_fuente": "36421", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-07-24", "vigencias": [{"desde": "1999-07-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-07-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-07-24", "fin_vigencia": "", "tipo_version