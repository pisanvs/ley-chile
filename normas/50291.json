{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8300330}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 2.177, de 27 de diciembre de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase parcialmente sin efecto la Resoluci&#xF3;n N&#xBA; 912, de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA LOS FIORDOS LTDA. para realizar actividades de acuicultura, s&#xF3;lo en cuanto se refiere a la autorizaci&#xF3;n para operar un centro de cultivo correspondiente al sector 3, ubicado en Isla Za&#xF1;artu, Canal Jacaf, Comuna de Cisnes, Provincia de Ays&#xE9;n, XI Regi&#xF3;n, en virtud de la renuncia formulada por su titular. </div></div>", "i": 8300331}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de diciembre de 1996.-</div><div class=\"p\">&nbsp; &nbsp;  Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca. </div></div>", "i": 8300332}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2177", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2177"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "ACUICULTURA", "AUTORIZACION", "MODDIFICACION", "PESQUERA LOS FIORDOS LTDA."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-12-27", "doble_articulado": false, "id_norma": "50291", "numero_fuente": "35660", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-01-08", "vigencias": [{"desde": "1997-01-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig