{"html": [{"t": "<div><div class=\"p\">MODIFICA LA LEY N.o 12,719</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6430252}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Agr&#xE9;gase al final del inciso primero del art&#xED;culo &#xFA;nico de la ley N.o 12,719, suprimiendo el punto, la siguiente frase: &quot;y en conformidad a lo dispuesto en el art&#xED;culo 18 de la ley n&#xFA;mero 11,986&quot;.</div><br></div>", "i": 6430253}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a catorce de Octubre de mil novecientos cincuenta y ocho.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Eduardo Urz&#xFA;a Merino.</div><br></div>", "i": 6430254}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "12719", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-12719"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA LA LEY N.o 12,719", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1958-10-14", "doble_articulado": false, "id_norma": "212116", "numero_fuente": "24177", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1958-10-24", "vigencias": [{"desde": "1958-10-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1958-10-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1958-10-24", "fin_vigencia": "", "