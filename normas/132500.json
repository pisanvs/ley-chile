{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO No. 52 EXENTO, DE 1988 </div></div>", "i": 6156428}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 52, de 23 de marzo de 1988, se ha aprobado para el Liceo Regional T&#xE9;cnico-Profesional, de la Comuna de Temuco, Provincia de Caut&#xED;n, IX Regi&#xF3;n de La Araucan&#xED;a, un plan y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico-Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar de 1988 y hasta el a&#xF1;o escolar de 1989, en la Rama T&#xE9;cnica, Especialidad Atenci&#xF3;n de Menores en Situaci&#xF3;n Irregular. </div></div>", "i": 6156429}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de Marzo de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6156430}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "52 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-52 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO No. 52 EXENTO, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-23", "doble_articulado": false, "id_norma": "132500", "numero_fuente": "33046", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-04-15", "vigencias": [{"desde": "1988-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-04-15", "fin_vigencia": "", "tipo_