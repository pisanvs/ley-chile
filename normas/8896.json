{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO </div></div>", "i": 5891964}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto M.O.P. N&#xB0; 83, de 29 Abril de 1991, se expropiaron los Lotes N&#xB0;s 1, 3, 4 y 5, superficies 750 m2., 780 m2., 110 m2. y 125 m2 roles de aval&#xFA;o 177-028, 182-003, 181-007 y 180-31, Comuna de San Vicente, para la obra Camino San Vicente. El Tambo-Angostura, sector San Vicente - El Tambo Rol H-80-I y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios do&#xF1;a Hilda Sep&#xFA;lveda Ernst y los se&#xF1;ores Hem&#xE1;n Valencia Ortiz, Rafael Dinamarca Gonz&#xE1;lez y Ram&#xF3;n Lizana Donoso, ascendentes a las cantidades de $ 475.541.- $ 356.834.- $ 643.277.- y $ 239.042.- respectivamente, </div></div>", "i": 5891965}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 5891966}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "83", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-83"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "EXTRACTO DE DECRETO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "INMUEBLE", "SAN VICENTE", "CAMINO PUBLICO", "CAMINO SAN VICENTE", "CAMINO EL TAMBO-ANGOSTURA", "SECTOR SAN VICENTE-EL TAMBO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-04-29", "doble_articulado": false, "id_norma": "8896", "numero_fuente": "33981", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-06-01", "vigencias": [{"desde": "1991-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-06-01", "fin_vigencia": ""}, "vigenc