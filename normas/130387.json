{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6149805}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 1140 de 6 de Julio de 1988, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas que corresponden a Reserva y Sector Expropiado Predio &quot;Santa Sara&quot; de la comuna de Yumbel, VIII Regi&#xF3;n, y Derechos Aprovechamiento Aguas que corresponden a parcelas N&#xB0;s. 1 a la 12 y sitios N&#xB0;s. 1 al 17 del Proyecto de Parcelaci&#xF3;n &quot;Los Aromos&quot; formado por predio se&#xF1;alado.- Los Derechos de Agua se extraen de los canales Batuco y la Mancha derivados del r&#xED;o Laja y derrames del predio Curanilahue. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.</div><br></div>", "i": 6149806}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Ejecutivo.</div><br></div>", "i": 6149807}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1140", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1140"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVEGHAMIENTO DE AGUAS QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-07-06", "doble_articulado": false, "id_norma": "130387", "numero_fuente": "33121", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-07-15", "vigencias": [{"desde": "1988-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vige