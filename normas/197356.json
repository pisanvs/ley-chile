{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6378919}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 740, de 12 de abril de 2002, de esta Subsecretar&#xED;a, modif&#xED;case la resoluci&#xF3;n N&#xBA;687 de 2002, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO, para efectuar una pesca de investigaci&#xF3;n de conformidad&nbsp; con los t&#xE9;rminos t&#xE9;cnicos de referencia del proyecto denominado &quot;Prospecci&#xF3;n de &#xE1;reas de reclutamiento del Jurel entre la III y X Regiones&quot;, en el sentido de sustituir su numeral 3&#xBA; por el siguiente:</div><div class=\"p\">&nbsp; &nbsp;  &quot;3.- La pesca de investigaci&#xF3;n se efectuar&#xE1; en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 26&#xB0; a 41&#xB0; L.S., desde la 5 hasta las 510 millas n&#xE1;uticas de la costa de Chile&quot;.</div><br></div>", "i": 6378920}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de abril de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6378921}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "740", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-740"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-12", "doble_articulado": false, "id_norma": "197356", "numero_fuente": "37246", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-29", "vigencias": [{"desde": "2002-04-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"