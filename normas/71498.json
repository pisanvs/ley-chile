{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 336 EXENTO, DE 1997 </div></div>", "i": 7207490}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento N&#xBA; 336 de fecha 20 de marzo de 1997 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; al Centro de Formaci&#xF3;n T&#xE9;cnica Centro Interamericano de Educaci&#xF3;n y Cultura Cidec, el plan y programas de estudios de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida en la Sede que se se&#xF1;ala, a contar del a&#xF1;o 1997:</div><br><br><br><div class=\"p\">Sede N&#xBA; 10 : Concepci&#xF3;n</div><div class=\"p\">Carrera&nbsp; &nbsp; :&nbsp; T&#xE9;cnico en Sonido.</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp;  :&nbsp; T&#xE9;cnico de nivel superior en Sonido.</div><br></div>", "i": 7207491}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de abril de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7207492}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "336 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-336 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 336 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "CENTRO DE FORMACION TECNICA", "CENTRO INTERAMERICANO DE EDUCACION Y CULTURA CIDEC", "CONCEPCION", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-20", "doble_articulado": false, "id_norma": "71498", "numero_fuente": "35770", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-20", "vigencias": [{"desde": "1997-05-20