{"html": [{"t": "<div><br><div class=\"p\">OFICIO DEL TRIBUNAL DEL CONSULADO</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Setiembre 24 de 1825.</div></div>", "i": 10247223}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Este tribunal como todo el comercio ha visto con placer la &#xFA;ltima ampliacion del decreto de seis de Julio &#xFA;ltimo, y mirando desde luego en ella una prueba del decidido empe&#xF1;o, con que procura el Gobierno el fomento del comercio no puede menos, que tributarles su mas cordial gratitud, por s&#xED; y a nombre del comercio en jeneral.</div></div>", "i": 10247224}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Admita U. S. con este motivo nuestros mejores sentimientos de aprecio y consideracion. - Felipe Santiago del Solar. - Pedro de Salas. - Onofre Bunster. - Sr. Ministro de Hacienda. </div><br><div class=\"p\">&nbsp; &nbsp;  DECRETO.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Setiembre 28 de 1825.</div><br><div class=\"p\">&nbsp; &nbsp;  Por recibido, impr&#xED;mase.</div><br><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Correa de Saa.</div></div>", "i": 10247225}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "OFICIO DEL TRIBUNAL DEL CONSULADO", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-09-28", "doble_articulado": false, "id_norma": "1162014", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-09-28", "hasta": "", "tipo_version": "