{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aprueba los contratos celebrados entre el Gobierno y la Chile Telephone Company Limited.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 8277708}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Apru&#xE9;base el contrato y el contrato suplementario celebrado entre el Gobierno y la Chile Telephone Company Ltd. y que consta de las escrituras extendidas ante el notario don Pedro N. Cruz, con fecha 7 de Diciembre de 1929.</div><br></div>", "i": 8277709}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veinte de Enero de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Enrique Berm&#xFA;dez. </div></div>", "i": 8277710}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4791", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4791"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "APRUEBA LOS CONTRATOS CELEBRADOS ENTRE EL GOBIERNO Y LA CHILE TELEPHONE COMPANY LIMITED.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CHILE TELEPHONE COMPANY LIMITED", "GOBIERNO CHILE", "CONTRATOS", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-01-20", "doble_articulado": false, "id_norma": "24915", "numero_fuente": "15579", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-01-23", "vigencias": [{"desde": "1930-01-23", "hasta": "", "tipo_version": "3", "tipo_ver