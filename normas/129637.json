{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6147531}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.160, de 11 de agosto de 1988, del Ministerio de Transportes y Telecomunicaci&#xF3;n, Subsecretar&#xED;a de Transportes, se autoriza a la Sociedad Transportes Cruz del Sur Limitada para efectuar servicio internacional de transporte terrestre de pasajeros entre Santiago (Chile) y San Carlos de Bariloche (Argentina), por Paso Puyehue, el que se atender&#xE1; con una frecuencia semanal.-</div><br></div>", "i": 6147532}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Manuel G&#xE1;rate Meneses, Coronel, Subsecretario de Transportes.</div><br></div>", "i": 6147533}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1160 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1160 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-11", "doble_articulado": false, "id_norma": "129637", "numero_fuente": "33157", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-08-27", "vigencias": [{"desde": "1988-08-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-08-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-08-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-01-13", "fecha_version": "1988-08-27", "fecha_actuali