{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10240493}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n Exenta N&#xB0;988, de 28 de mayo de 2021, determina el listado de prestaciones del Instituto de Salud P&#xFA;blica de Chile que se mantendr&#xE1;n suspendidas mientras dure la alerta sanitaria decretada por la pandemia del virus SARS-CoV-2.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10240494}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Heriberto Garc&#xED;a Escorza, Director (S), Instituto de Salud P&#xFA;blica de Chile.</div><div class=\"p\"> </div><br></div>", "i": 10240495}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "988 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-988 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": ["CORONAVIRUS COVID-19", "CORONAVIRUS", "COVID-19"], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1957079", "EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2021-05-28", "fecha_derogacion": "2022-04-26", "doble_articulado": false, "id_norma": "1160858", "numero_fuente": "42974", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2021-06-09", "vigencias": [{"desde": "2022-04-26", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2021-06-09", "hasta": "2022-04-25", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigenc