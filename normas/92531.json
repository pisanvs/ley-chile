{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION No. 185, DE 1989 </div></div>", "i": 7227047}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 185, de 02.05.89 del Ministerio de Transportes y Telecomunicaciones Subsecretaria de Transportes, se autoriza a la Sociedad de Transportes y Servicios Lagoper Limitada (Transportes Lagoper Limitada), para efectuar transporte terrestre de pasajeros entre Puerto Natales (Chile) y Villa Minera - Rio Turbio - 28 de Noviembre (Argentina) por los pasos fronterizos de Dorotea y Laurita (Casas Viejas), con dos frecuencias diarias de lunes a viernes y una frecuencia diaria los s&#xE1;bados, domingos y feriados, de ida y vuelta.-</div><br></div>", "i": 7227048}, {"t": "<div><div class=\"p\">Manuel G&#xE1;rate Meneses, Coronel, Subsecretario de Transportes.</div><br></div>", "i": 7227049}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "185", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-185"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION N° 185, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-02", "doble_articulado": false, "id_norma": "92531", "numero_fuente": "33383", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-05-29", "vigencias": [{"desde": "1989-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-05-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-05-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc