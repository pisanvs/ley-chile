{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Modifica el art&#xED;culo 6&#xB0; de la ley N&#xB0; 5,005 N&#xFA;m. 443.- Santiago, 18 de Agosto de 1932.- Vistos estos antecedentes, el Presidente Provisional de la Rep&#xFA;blica ha acordado y dicta el siguiente,</div><div class=\"p\">&nbsp; &nbsp; Decreto-ley:</div><br></div>", "i": 8256106}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Modif&#xED;case la letra f) del art&#xED;culo 6.o de la ley N.o 5,005, de 24 de Noviembre del a&#xF1;o pr&#xF3;ximo pasado, en la siguiente forma:</div><div class=\"p\">&nbsp; &nbsp; &quot;Las de los empleados del Servicio de Correos y Tel&#xE9;grafos&quot;.</div><br></div>", "i": 8256107}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de Leyes y Decretos del Gobierno.- CARLOS DAVILA.- Joaqu&#xED;n Fern&#xE1;ndez F.</div><br></div>", "i": 8256108}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "443", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-443"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA EL ARTÍCULO 6° DE LA LEY N° 5,005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SERVICIO CORREOS TELEGRAFOS", "PERSONAL", "NOMBRAMIENTOS", "VACANTES", "PROVEIMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-08-18", "doble_articulado": false, "id_norma": "6086", "numero_fuente": "16358", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-08-25", "vigencias": [{"desde": "1932-08-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1932-08-25", "fin_vigencia": ""}, "vigencias_version_norma"