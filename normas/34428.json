{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291976}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 353, de 30 de Marzo de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;canse los vistos y el numeral 1&#xB0; de la Resoluci&#xF3;n N&#xB0; 964, de 1994, de esta Subsecretar&#xED;a, en el sentido de se&#xF1;alar que las Resoluciones que all&#xED; se mencionan son la N&#xB0; 58, de 1984 y N&#xB0; 146, de 1986, ambas de esta Subsecretar&#xED;a, y no las que all&#xED; se indican.</div><br></div>", "i": 8291977}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 30 de Marzo de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8291978}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "353", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-353"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "RECTIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-03-30", "doble_articulado": false, "id_norma": "34428", "numero_fuente": "35139", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-04-08", "vigencias": [{"desde": "1995-04-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-04-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-04-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "fecha_version": "199