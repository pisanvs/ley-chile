{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292945}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 527, de 19 de marzo de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por GONZALO</div><div class=\"p\">ALEJANDRO CAMACHO SANTIBA&#xD1;EZ, para un centro de cultivo</div><div class=\"p\">ubicado en Isla Linlinao, comuna de Chonchi, provincia</div><div class=\"p\">de Chilo&#xE9;, X Regi&#xF3;n, conforme lo dispuesto en los</div><div class=\"p\">art&#xED;culos 78&#xB0; y 87&#xB0;, de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8292946}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 19 de marzo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292947}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "527", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-527"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "GONZALO ALEJANDRO CAMACHO SANTIBA EZ", "CHONCHI", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-03-19", "doble_articulado": false, "id_norma": "35033", "numero_fuente": "35428", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-03-27", "vigencias": [{"desde": "1996-03-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-