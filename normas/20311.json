{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 127 EXENTO, DE 1996 </div></div>", "i": 7160688}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Supremo Exento de Educaci&#xF3;n N&#xB0; 127 de 29 de Febrero de 1996, se ha modificado el Decreto Supremo Exento de Educaci&#xF3;n N&#xB0; 579, de 1995, que aprob&#xF3; plan especial de estudio al Colegio &quot;Verbo Divino&quot;. Se suprime la letra d) del art&#xED;culo 2&#xB0; y se menciona que lo estipulado en las letras a), b) y c) del mismo art&#xED;culo se aplicar&#xE1; progresivamente: 5&#xB0; A&#xF1;o B&#xE1;sico a 1er. A&#xF1;o Medio a contar de 1996 y 2&#xB0; A&#xF1;o Medio a contar de 1997. </div></div>", "i": 7160689, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 29 de Febrero de 1996.- Juan Eduardo Garc&#xED;a-Huidobro S., Subsecretario de Educaci&#xF3;n (S). </div></div>", "i": 7160690}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "127 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-127 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 127 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO VERBO DIVINO", "PLANES ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-02-29", "doble_articulado": false, "id_norma": "20311", "numero_fuente": "35421", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-03-19", "vigencias": [{"desde": "1996-03-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-03-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc