{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DECLARA FERIADOS LOS DIAS QUE INDICA EN LA COMUNA DE ILLAPEL</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8279654}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Decl&#xE1;ranse feriados, para todos los efectos legales, los d&#xED;as 12 y 13 de Noviembre de 1954, en la comuna de Illapel, departamento del mismo nombre, en la provincia de Coquimbo&quot;.</div><br></div>", "i": 8279655}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diez de Noviembre de mil novecientos cincuenta y cuatro.- CARLOS IBA&#xD1;EZ DEL CAMPO.- A. Parra U.</div><br></div>", "i": 8279656}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11742", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11742"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DECLARA FERIADOS LOS DIAS QUE INDICA EN LA COMUNA DE\nILLAPEL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FERIADO LEGAL", "ILLAPEL", "COQUIMBO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1954-11-10", "doble_articulado": false, "id_norma": "26775", "numero_fuente": "22996", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1954-11-12", "vigencias": [{"desde": "1954-11-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1954-11-12", "fin_vigencia": ""}, "vigencias_version_