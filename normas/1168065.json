{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10282952}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xB0;1.182, de 21 de octubre de 2021, prohibi&#xF3; circulaci&#xF3;n de veh&#xED;culos relativa a Feria Artesanal en el Marco del Aniversario de la Localidad de Puerto Chacabuco, comuna de Ays&#xE9;n, y autoriz&#xF3; a &#xC1;rea de Cultura de la I. Municipalidad de Ays&#xE9;n para realizar siguiente intervenci&#xF3;n en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - corte total de v&#xED;a en calle Ram&#xF3;n Carnicer, entre calle Ignacio Carrera Pinto y Ruta 240 de Puerto Chacabuco, desde las 08:00 hrs. del d&#xED;a viernes 22 hasta las 18:00 hrs. del d&#xED;a lunes 25 de octubre de 2021.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10282953}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &#xD3;scar del Solar Navarrete, Gobernador Regional (S), Gobierno Regional de Ays&#xE9;n.- Ximena Guti&#xE9;rrez Jaramillo, Asesora Jur&#xED;dica, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10282954}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1182 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1182 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2038025", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-10-21", "doble_articulado": false, "id_norma": "1168065", "numero_fuente": "43099", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publi