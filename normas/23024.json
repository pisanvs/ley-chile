{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,936 que ampl&#xED;a el plazo del Reglamento de Minas i fija la patente de los yacimientos de arenas aur&#xED;feras.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,936.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5952448}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO PRIMERO. Ampl&#xED;ase a quinientos dias el plazo establecido por el art. 10 del Reglamento de Minas de 5 de Julio de 1895.</div><br></div>", "i": 5952449}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ART. 2.&#xB0; Los yacimientos de arenas aur&#xED;feras pagar&#xE1;n una patente anual de un peso por hect&#xE1;rea.</div><br></div>", "i": 5952450}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 8 de febrero de 1907.- PEDRO MONTT.- R. Sotomayor.</div><br></div>", "i": 5952451}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1936", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1936"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LEI NUM. 1,936 QUE AMPLIA EL PLAZO DEL REGLAMENTO DE MINAS I FIJA LA PATENTE DE LOS YACIMIENTOS DE ARENAS AURIFERAS.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REGLAMENTO MINAS", "PERTENENCIAS MINERAS", "CONSTITUCION", "PLAZO", "SOLICITUD", "REGISTRO", "PUBLICACION", "YACIMIENTOS ARENAS", "PATENTE ANUAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion"