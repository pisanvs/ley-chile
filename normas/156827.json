{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6236819}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. N&#xB0; 25, de 31 de Enero de 1985, se expropi&#xF3; el lote de terreno N&#xB0; 11, para Variante Nuevo Puente sobre el r&#xED;o Andali&#xE9;n, camino Concepci&#xF3;n-Tom&#xE9;, que figura a nombre de do&#xF1;a Elba del C. Candia Novoa, rol de aval&#xFA;o 204 m2., comuna de Concepci&#xF3;n, VIII Regi&#xF3;n. La Comisi&#xF3;n de Peritos compuesta por los se&#xF1;ores Teodoro Medina R., Ram&#xF3;n Jofr&#xE9; J. y Gerardo Valverde V., fij&#xF3; con fecha 07 de Septiembre de 1984, el valor provisional de la indemnizaci&#xF3;n en la cantidad de $ 225.300. La indemnizaei&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xB0; del decreto ley N&#xB0; 2. 186, de 1978.-</div><br></div>", "i": 6236820}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal subrogante del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6236821}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "25", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-25"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-31", "doble_articulado": false, "id_norma": "156827", "numero_fuente": "32110", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-01", "vigencias": [{"desde": "1985-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-01", "fin_vigencia": ""}, "vigencias_version_no