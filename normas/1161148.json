{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10242575}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.933 de 25 de mayo de 2021, Serviu Regi&#xF3;n de Valpara&#xED;so, dispuesto expropiaci&#xF3;n conforme al art&#xED;culo 51 Ley 16.391 y decreto ley 2.186 de 1978, del lote signado con el n&#xFA;mero 401b, ubicado en Marga Marga 1808, de la comuna de Quilpu&#xE9;, en el plano DRS-P Exp. 21-A, Exp. 23-A y Exp. 22-A &quot;Proyecto Mejoramiento Eje Marga-Marga de la comuna de Quilpu&#xE9;&quot; de presunto dominio de Leiva Reyes Elsa, rol aval&#xFA;o 3502-8. Comisi&#xF3;n Tasadora integrada por Guillermo Parra Silva, Julia Venegas Escalante y Jaime Jurgens Bittner, seg&#xFA;n informe de tasaci&#xF3;n se fij&#xF3; monto indemnizaci&#xF3;n provisional en $32.539.801, que ser&#xE1; pagada al contado. </div></div>", "i": 10242576}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director Serviu.</div><div class=\"p\"> </div><br></div>", "i": 10242577}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1933 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1933 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DE VALPARAÍSO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1959174", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-05-25", "doble_articulado": false, "id_norma": "1161148", "numero_fuente": "42979", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-06-15", "vigencias": [{"desde": "2