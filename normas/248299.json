{"html": [{"t": "<div><div class=\"p\">INFORMA SOBRE NUEVA COMPOSICION DE LA DIRECTIVA CENTRAL DEL PARTIDO POR LA DEMOCRACIA </div></div>", "i": 6564862}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Jofr&#xE9; Delgado, Presidente de la Directiva Central del Partido Por la Democracia y Zoran Spasitelj Ostoic Marroqu&#xED;n, Secretario del Tribunal Supremo de la colectividad, han informado el nombramiento de don Ren&#xE9; Jofr&#xE9; Delgado como Presidente de la Directiva Central del partido, por la renuncia al cargo de don V&#xED;ctor Jeame Barrueto.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada en virtud de lo establecido en el Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por resoluci&#xF3;n O-N&#xBA;648, de fecha 10 de marzo de 2006.</div><br></div>", "i": 6564863}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director. </div></div>", "i": 6564864}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "648", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-648"}, {"tipo": "3", "numero": "O-648", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-648"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "INFORMA SOBRE NUEVA COMPOSICION DE LA DIRECTIVA CENTRAL\nDEL PARTIDO POR LA DEMOCRACIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDO POR LA DEMOCRACIA", "DIRECTIVA CENTRAL", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-03-10", "doble_articulado": false, "id_norma": "248299", "numero_fuente": "38419", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-21", "vigencias": [{"des