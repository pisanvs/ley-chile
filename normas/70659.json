{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6034396}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decretos M.O.P. N&#xBA;s 185 y 179, ambos de 28 de febrero de 1997, se expropiaron los lotes de terreno N&#xBA;s. 2, 4, 6, 6-D, 7 y 16, superficies 1.910, 660, 1.220, 40, 135,5 y 250 M2., roles de aval&#xFA;os 220-45, 220-48, 220-53, en tr&#xE1;mite, 220-23 y en tr&#xE1;mite, comuna de Rengo, para la obra Camino H-65, sector Rengo - Popeta y se acord&#xF3; precio de la indemnizaci&#xF3;n con sus propietarios Sociedad Vi&#xF1;edos Torre&#xF3;n de Paredes S.A., Mar&#xED;a del Tr&#xE1;nsito Arriaza Labra, Jos&#xE9; Lorenzoni Iturbe y la Sucesi&#xF3;n Manuel Jes&#xFA;s Romero Saavedra, ascendente a las cantidades de $18.571.742, para los lotes 2, 4 y 6;</div><div class=\"p\">$765.600, para el lote 6-D; 1.075.480, para el lote 7 y $890.832, para el lote 16.</div><br></div>", "i": 6034397}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6034398}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "179", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-179"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "RENGO", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-02-28", "doble_articulado": false, "id_norma": "70659", "numero_fuente": "35741", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-15", "vigencias": [{"desde": "1997-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997