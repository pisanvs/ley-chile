{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8289672}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 48, de 22 de Enero de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a PESQUERA CHIVILINGO DOS S.A., R.U.T. N&#xB0; 96.649.170-1, domiciliada en la ciudad de Santiago, para continuar desarrollando las actividades pesqueras autorizadas a Pesquera Chivilingo S.A., R.U.T. N&#xB0; 95.508.710-9, del mismo domicilio, por resoluciones N&#xB0; 910, de 1989, N&#xB0; 1369, de 1990 y N&#xB0; 1416, de 1991, en lo relativo a la operaci&#xF3;n de la nave en construcci&#xF3;n denominada &quot;Chivilingo 2&quot;, en las &#xE1;reas y sobre las especies que en dichas resoluciones se indica.</div><br><br></div>", "i": 8289673}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 22 de Enero de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8289674}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "48", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-48"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "PESQUERA CHIVILINGO DOS S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1993-01-22", "fecha_derogacion": "1995-12-21", "doble_articulado": false, "id_norma": "32595", "numero_fuente": "34486", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1993-02-08", "vigencias": [{"desde": "1995-12-21", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}