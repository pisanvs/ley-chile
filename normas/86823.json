{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xB0; 250, DE 1982</div><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">N&#xFA;m. 37.- Santiago, 08 de Mayo de 1992.</div><div class=\"p\">Visto: Lo dispuesto por el art&#xED;culo 56 de la Ley No. 18.290, de Tr&#xE1;nsito,</div><br><div class=\"p\">Resuelvo:</div><br></div>", "i": 7221474}, {"t": "<div><div class=\"p\">1.- Modif&#xED;case el art&#xED;culo 2&#xB0; de la Resoluci&#xF3;n No. 250 de 1982, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, en el sentido de agregar en el inciso primero, a continuaci&#xF3;n del punto aparte, que pasa a ser coma, lo siguiente: &quot;salvo en el caso de minibuses que presten servicios de locomoci&#xF3;n colectiva al interior de la XI Regi&#xF3;n y en la Provincia de Palena de la X regi&#xF3;n&quot;.</div><br><br></div>", "i": 7221475}, {"t": "<div><div class=\"p\">An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- V&#xED;ctor Germ&#xE1;n Correa D&#xED;az, Ministro de Transportes y Telecomunicaciones. Lo que transcribo para su conocimiento.- Saluda a Ud.- Patricia Mu&#xF1;oz Villela, Jefe Depto. Administrativo. </div></div>", "i": 7221476}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "37", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-37"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "MODIFICA RESOLUCION N° 250, DE 1982", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-05-08", "doble_articulado": false, "id_norma": "86823", "numero_fuente": "34296", "tipo_version": "3", "tipo_version_s":