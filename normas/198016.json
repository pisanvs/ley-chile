{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6381151}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;589, de 28 de marzo del 2002, se expropi&#xF3; el lote de terreno N&#xBA;8-1, superficie 285, rol de aval&#xFA;o 300-13, comuna de Malloa, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo Santiago-Talca Sector G: Kms. 110.200,00 al 128.400,00. Sexta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria M&#xF3;nica Isabel Tobar Lizama, ascendente a la cantidad de $10.267.500.- para el lote N&#xBA;8-1.</div><br></div>", "i": 6381152}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6381153}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "589", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-589"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-28", "doble_articulado": false, "id_norma": "198016", "numero_fuente": "37259", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-15", "vigencias": [{"desde": "2002-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PSO", "fecha_ingreso": "2002-05-15", "fecha_version": "2002-05-15", "fecha_actualizacion_texto": "2002-05-15", "tipo_tratado": ""}, "alertas": [], "alert