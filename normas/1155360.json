{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10197647}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xBA; 787, del 23 de diciembre de 2020, Serviu Regi&#xF3;n de &#xD1;uble orden&#xF3; expropiaci&#xF3;n parcial de inmueble ubicado en Vicu&#xF1;a Mackenna N&#xBA; 315, comuna de Chill&#xE1;n, rol de aval&#xFA;o N&#xBA; 00525-00047, de aparente dominio de Millar Arias Claudio. La parte afecta a expropiaci&#xF3;n parcial de terreno es de 215,94 m2 (Lote 49) y cuyos linderos particulares, enmarcados en el plano S16R-052, para el proyecto &quot;Mejoramiento Avenida Diagonal Las Termas, Chill&#xE1;n&quot;, conforme art&#xED;culo 51 ley 16.391 y DL 2.186. Comisi&#xF3;n Peritos integrada por la arquitecto Priscila Andrea Encalada Rueda, arquitecto Cecilia Mar&#xED;a Carrasco Verdugo y por el Constructor Civil Fernando Iv&#xE1;n Cerda Espinosa, que fij&#xF3; el monto de la indemnizaci&#xF3;n provisional por la expropiaci&#xF3;n, en la suma de $21.735.370.- </div></div>", "i": 10197648}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n de &#xD1;uble.</div><br></div>", "i": 10197649}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "787 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-787 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "XVI REGIÓN DE ÑUBLE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1887751", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-12-23", "doble_articulado": false, "id_norma": "