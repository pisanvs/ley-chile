{"html": [{"t": "<div><div class=\"p\">EXTRACTO&nbsp; DE&nbsp; DECRETO N&#xBA; 264&nbsp; EXENTO,&nbsp; DE 1997</div><br></div>", "i": 6040323}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 264 de 5</div><div class=\"p\">de marzo de 1997, se ha aprobado, a partir del a&#xF1;o</div><div class=\"p\">escolar 1997, un programa de Religi&#xF3;n de las Iglesias y</div><div class=\"p\">Corporaciones Evang&#xE9;licas de Chile para los cursos de 1&#xBA;</div><div class=\"p\">a 8&#xBA; a&#xF1;o (NB.1 a NB.6) de ense&#xF1;anza b&#xE1;sica, el que podr&#xE1;</div><div class=\"p\">aplicarse conforme a la gradualidad establecida en el</div><div class=\"p\">art&#xED;culo 4&#xBA; del Decreto Supremo de Educaci&#xF3;n N&#xBA; 40 de 1996; 1&#xBA; y 2&#xBA; a&#xF1;o en 1997; 3&#xBA;, 4&#xBA; y 5&#xBA; a&#xF1;o en 1998; 6&#xBA; a&#xF1;o en 1999; 7&#xBA; a&#xF1;o en 2000; y 8&#xBA; a&#xF1;o en 2001. </div></div>", "i": 6040324}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de marzo de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6040325}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "264 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-264 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 264 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RELIGION", "IGLESIAS Y CORPORACIONES EVANGELICAS DE CHILE", "PROGRAMAS DE ESTUDIOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-05", "doble_articulado": false, "id_norma": "73889", "numero_fuente": "35801", "tipo_version": "3", "tipo_version_s": "Única"