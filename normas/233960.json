{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6510221}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.352, de 25 de noviembre de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA PACIFICO AUSTRAL LIMITADA, para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar una planta ubicada en La Ribera Sur N&#xBA; 300, Ancud, Chilo&#xE9;, X Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n Cocido y congelado, el recurso hidrobiol&#xF3;gico individualizado en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6510222}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de noviembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6510223}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3352 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3352 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-25", "doble_articulado": false, "id_norma": "233960", "numero_fuente": "38044", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-24", "vigencias": [{"desde": "2004-12-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-12-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-12-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "200