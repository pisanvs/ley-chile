{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A MOLINO EL TREBOL LTDA.</div><br></div>", "i": 6523423}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE 08/N&#xBA; Ex. 583, de fecha 14 de abril de 2005, otorga a Molino El Tr&#xE9;bol Ltda., RUT N&#xBA; 76.047.870-9, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las ventas de trigo, establecido en la resoluci&#xF3;n N&#xBA; Ex-5281, de 30-11-2000 de la Direcci&#xF3;n Nacional. La presente autorizaci&#xF3;n surtir&#xE1; efecto a partir del d&#xED;a primero del mes siguiente a la fecha de publicaci&#xF3;n de este extracto en el Diario Oficial y tendr&#xE1; vigencia indefinida.</div><br></div>", "i": 6523424}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Concepci&#xF3;n, 14 de abril de 2005.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6523425}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "583 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-583 EXENTA"}, {"tipo": "3", "numero": "DRE-08-583 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-583 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A MOLINO EL\nTREBOL LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-04-14", "doble_articulado": false, "id_norma": "237401", "numero_fuente": "38146", "tipo_version": "3", "tipo_version_s": "Única", "f