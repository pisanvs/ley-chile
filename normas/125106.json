{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6132771}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 143 de 31 de agosto de 1998, de Serviu Regi&#xF3;n de Coquimbo, se orden&#xF3; expropiaci&#xF3;n, conforme art. 51 ley 16.391 y D.L. 2.186 de 1978, inmueble ubicado en calle Amun&#xE1;tegui N&#xBA; 335 presunto rol aval&#xFA;o 132-7 comuna La Serena, aparentemente dominio de don(&#xF1;a): Juan Alvarado Castillo. Comisi&#xF3;n Peritos integrada por don Patricio Mena L&#xF3;pez, Alfredo Prieto Parra y do&#xF1;a Iris Marcich Moller, arquitectos, seg&#xFA;n informe de 30 de junio de 1998, fij&#xF3; monto provisional indemnizaci&#xF3;n en $2.736.136 pagadera al contado. </div></div>", "i": 6132772}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Regi&#xF3;n Coquimbo.</div><br></div>", "i": 6132773}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "143", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-143"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN IV REGIÓN DE COQUIMBO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "LA SERENA", "CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-31", "doble_articulado": false, "id_norma": "125106", "numero_fuente": "36177", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-10-01", "vigencias": [{"desde": "1998-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-10-01", "fin_vigencia": "