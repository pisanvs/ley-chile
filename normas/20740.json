{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5942968}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 231 de fecha 24 de mayo de 1993 del Ministerio de Educaci&#xF3;n, se rechaz&#xF3; la solicitud de reconocimiento oficial al Instituto Profesional &quot;Instituto Tecnol&#xF3;gico para la Ciencia de la Inform&#xE1;tica&quot; (en formaci&#xF3;n), presentada por la Sociedad Instituto Tecnol&#xF3;gico para la Ciencia de la Inform&#xE1;tica S.A. y se elimina del Registro de Institutos Profesionales el N&#xB0; 85 de fecha 20 de noviembre de 1990 en el cual se encontraba inscrito.</div><br></div>", "i": 5942969}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 15 de junio de 1993.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5942970}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "231", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-231"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO PROFESIONAL", "INSTITUTO TECNOLOGICO CIENCIA INFORMATICA", "RECONOCIMIENTO OFICIAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-05-24", "doble_articulado": false, "id_norma": "20740", "numero_fuente": "34601", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-06-28", "vigencias": [{"desde": "1993-06-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-06-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-06-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_vers