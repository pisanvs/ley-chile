{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6286351}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.954, de 16 de mayo de 2000, y</div><div class=\"p\">en base a la facultad otorgada por el art&#xED;culo 105 del</div><div class=\"p\">D.F.L. MOP N&#xBA; 850, de 1997, que fij&#xF3; el texto</div><div class=\"p\">actualizado de la ley N&#xBA; 15.840, se expropi&#xF3; el lote de</div><div class=\"p\">terreno N&#xBA; 4-A, para la obra Camino Ruta 115-Ch, sector</div><div class=\"p\">Puente Armerillo - L&#xED;mite Paso Pehuenche Tramo Km.</div><div class=\"p\">64,680 al 70,569.745, que figura a nombre de Renato</div><div class=\"p\">Arturo Villa Peretty, rol de aval&#xFA;o 8-66, comuna de Colb&#xFA;n, VII Regi&#xF3;n, superficie 25,20 m&#xB2;. La Comisi&#xF3;n de Peritos fij&#xF3;, con fecha 6 de mayo de 1999, en la cantidad de $2.016. La indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.</div><br></div>", "i": 6286352}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6286353}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1954", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1954"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-16", "doble_articulado": false, "id_norma": "172069", "numero_fuente": "36702", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-01", "vigen