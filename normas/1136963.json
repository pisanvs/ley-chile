{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10057834}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.111, de 30 de agosto de 2019, de este Servicio, se determinaron incumplimientos menores que dar&#xE1;n lugar a disconformidades conforme al art&#xED;culo 120 C de la Ley General de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n indicada, se encuentra publicado con esta fecha en el sitio de dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y de la Subsecretar&#xED;a de Pesca y Acuicultura.</div><div class=\"p\"> </div></div>", "i": 10057835}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En Valpara&#xED;so, a 30 de agosto de 2019.- Alicia Gallardo Lagno, Directora Nacional, Servicio Nacional de Pesca y Acuicultura.</div><br></div>", "i": 10057836}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4111 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4111 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1661306", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-08-30", "doble_articulado": false, "id_norma": "1136963", "numero_fuente": "42467", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-10-02", "vigencias": [{"desde": "2019-10-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-10-02", "fin_vigenci