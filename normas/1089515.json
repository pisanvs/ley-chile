{"html": [{"t": "<div><br><div class=\"p\">PARTIDO LIBERAL DE CHILE</div></div>", "i": 9697194}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Vlado Mirosevic Verdugo, Presidente de la Directiva Central Provisional del Partido Liberal de Chile, en formaci&#xF3;n, con fecha 1 de abril de 2016, ha solicitado la constituci&#xF3;n legal del partido en las regiones I de Tarapac&#xE1; y II de Antofagasta. La solicitud de inscripci&#xF3;n se&#xF1;ala acompa&#xF1;ar la cantidad de afiliados, que se indica:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  I Regi&#xF3;n&nbsp;  :&nbsp; 263</div><div class=\"p\">&nbsp; &nbsp;  II Regi&#xF3;n&nbsp; :&nbsp; 557</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xBA; de la ley N&#xBA; 18.603, por resoluci&#xF3;n O-N&#xB0; 97, fecha 5 abril de 2016.-&nbsp;  </div></div>", "i": 9697195}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Elizabeth Cabrera Burgos, Directora (S).</div></div>", "i": 9697196}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "97", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-97"}, {"tipo": "3", "numero": "O-97", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-97"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO LIBERAL DE CHILE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1015501; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-04-05", "doble_articulado": false, "id_norma": "1089515", "numero_fuente": "41435", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-04-18", "vigencias": [{"desde": "2016-04-18", "hasta": "", "tip