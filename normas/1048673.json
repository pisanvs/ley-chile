{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9331926}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 257, de 31 de enero de 2013, de esta Subsecretar&#xED;a, rectif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1040861&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.490 de 2012</a> y de esta Subsecretar&#xED;a de Pesca y Acuicultura, que estableci&#xF3; la n&#xF3;mina definitiva de armadores artesanales y sus embarcaciones, que participaron de las pescas de investigaci&#xF3;n a que se refiere el art&#xED;culo 3&#xBA; de la Ley N&#xBA; 20.560, en el sentido de incorporar en su numeral 4.- a las personas indicadas en resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  </div><br></div>", "i": 9331927}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de enero de 2013. - Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9331928}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "257 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-257 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-01-31", "doble_articulado": false, "id_norma": "1048673", "numero_fuente": "40478", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-02-06", "vigencias": [{"desde": "2013-02-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-02-06", "fin_vi