{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8314994}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xBA;1.530 de 11 de Diciembre de 1990 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n N&#xBA;1.099, de 1989, de esta Subsecretar&#xED;a que autoriz&#xF3; al Sindicato de Algas &quot;El Porvenir&quot; de Lechagua, domiciliado en Sector Rural de Lechagua, Comuna de Ancud, en el sentido de se&#xF1;alar que el nombre de la entidad autorizada para instalar y operar un establecimiento de cultivo por la citada Resoluci&#xF3;n es el &quot;SINDICATO DE TRABAJADORES INDEPENDIENTES PRODUCTORES Y RECOLECTORES DE ALGAS &quot;EL PORVENIR&quot; DE LECHAGUA. </div></div>", "i": 8314995}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 11 de Diciembre de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8314996}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1530", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1530"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1990-12-11", "fecha_derogacion": "1995-05-12", "doble_articulado": false, "id_norma": "83362", "numero_fuente": "33851", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1990-12-24", "vigencias": [{"desde": "1995-05-12", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1990-12-24", "hasta": "1995-05-11", "tipo_version": "0", "tipo_version_s": "Texto Origin