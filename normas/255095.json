{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6589130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.954, de 23 de octubre de 2006 de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA EDEN LIMITADA para ampliar las actividades pesqueras de transformaci&#xF3;n autorizadas por las resoluciones citadas precedentemente, en orden a incorporar a la planta ubicada en Hijuela Industrial N&#xBA;286-B Km. 3,5 Norte, Puerto Natales, XII Regi&#xF3;n, en las l&#xED;neas de proceso de Fresco-enfriado, Fresco-refrigerado, Congelado, Seco-salado, Ahumado y Conserva, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6589131}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de octubre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6589132}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2954 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2954 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-10-23", "doble_articulado": false, "id_norma": "255095", "numero_fuente": "38613", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-11-14", "vigencias": [{"desde": "2006-11-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-11-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-11-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe