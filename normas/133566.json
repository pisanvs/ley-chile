{"html": [{"t": "<div><div class=\"p\">MODIFICA ORDENANZA QUE INDICA </div></div>", "i": 6159478}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Con fecha 25 de julio de 1988 la I. Municipalidad de Renca dict&#xF3; el decreto alcaldicio No. 1.034 que modifica la Ordenanza No. 001 de 27 de enero de 1988 sobre derechos municipales por permisos, concesiones y servicios municipales, en el sentido de que el T&#xED;tulo VI, Art, 13&#xBA; No. 1 se rebaja el porcentaje de derechos municipales a pagar, de 30% UTM a 15% UTM.-</div><br></div>", "i": 6159479}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Alcalde.</div><br></div>", "i": 6159480}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1034", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1034"}], "organismos": ["MUNICIPALIDAD DE RENCA"], "titulo_norma": "MODIFICA ORDENANZA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-07-25", "doble_articulado": false, "id_norma": "133566", "numero_fuente": "33134", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-07-30", "vigencias": [{"desde": "1988-07-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-07-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-07-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-03-15", "fecha_version": "1988-07-30", "fecha_actualizacion_texto": "1988-07-30", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6159478}, {"n": "Artículo", "i": 6159479,