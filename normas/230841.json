{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6498994}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.514, de 6 de septiembre de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BAHIA CORONEL S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Toyita&quot;, entre la V a VII Regiones, y en la IX Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, con cerco, sobre los siguientes recursos hidrobiol&#xF3;gicos: Bacaladillo o mote, Bonito, Cojinoba del norte Seriolella violacea, Cojinoba del sur, Cojinoba moteada, Dorado, Machuelo, Palometa, Jurel fino, Anchoa blanca o samasa, Sardina redonda, Vinciguerria, Pota del Atl&#xE1;ntico, Calamar, Pulpo, Jibia. Valpara&#xED;so, 6 de septiembre de 2004.</div><br></div>", "i": 6498995}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Felipe Sandoval Precht, Subsecretario de Pesca. </div></div>", "i": 6498996}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2514 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2514 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-09-06", "fecha_derogacion": "2011-08-25", "doble_articulado": false, "id_norma": "230841", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-10-01", "vigencias": [{"desde": "2011-08-25", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-10-01", "hasta": "2011-08-24", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_