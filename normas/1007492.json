{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8793482}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;3.209, de 23 de septiembre de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a ANTONIO DA VENEZIA RETAMALES para ampliar actividades pesqueras extractivas con la nave &quot;T&#xED;o Gringo&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre la IV a VII Regiones, por fuera del &#xE1;rea de reserva artesanal, con espinel, sobre los siguientes recursos hidrobiol&#xF3;gicos: Azulejo y Tibur&#xF3;n o marrajo.</div><br></div>", "i": 8793483}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de septiembre de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8793484}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3209 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3209 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-09-23", "doble_articulado": false, "id_norma": "1007492", "numero_fuente": "39498", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-10-29", "vigencias": [{"desde": "2009-10-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-10-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-10-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2009-10-29", "fecha_ver