{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br><br></div>", "i": 6575642}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 367 de 14 de junio de 2006 de Serviu Metropolitano, orden&#xF3; expropiaci&#xF3;n parcial, conforme D.L. N&#xBA; 2.186 de 1978, del lote N&#xBA; 3 correspondiente al inmueble ubicado en Avda. Larra&#xED;n N&#xBA; 6925, presunto rol de aval&#xFA;o N&#xBA; 4300-33, comuna de La Reina, aparente dominio de Instituto Chileno de Terapia Familiar. Comisi&#xF3;n integrada por peritos Pedro Almonacid Colin, Ingeniero Civil, Mufida Abuawad Elias, Arquitecto y Miguel Fern&#xE1;ndez C&#xE1;diz, Constructor Civil. Seg&#xFA;n informe de 26 de diciembre de 2005, fij&#xF3; monto provisional indemnizaci&#xF3;n en $25.086.500.- pagadera al contado.</div><br></div>", "i": 6575643}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 6575644}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "367", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-367"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "ORDENA EXPROPIACIONES PARCIALES DE INMUEBLES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-14", "doble_articulado": false, "id_norma": "251242", "numero_fuente": "38514", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-07-15", "vigencias": [{"desde": "2006-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "