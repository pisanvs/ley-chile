{"html": [{"t": "<div><div class=\"p\">CERTIFICADO</div><br><br></div>", "i": 6411133}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 7-2003.-Juan Carlos Gonz&#xE1;lez Romo, Secretario Municipal y Secretario del Concejo Municipal, certifica que en sesi&#xF3;n extraordinaria N&#xBA; 04-2002, del Concejo Municipal de Puchuncav&#xED; celebrada el d&#xED;a mi&#xE9;rcoles 6 de febrero de 2002, se acord&#xF3; por unanimidad de los miembros presentes aprobar la Enmienda al Plan Regulador Comunal, Sector Las Ventanas.</div><br></div>", "i": 6411134}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se extiende el presente certificado a solicitud de la Secretar&#xED;a Comunal de Planificaci&#xF3;n Municipalidad de Puchuncav&#xED;, para ser publicado en el Diario Oficial.- Puchuncav&#xED;, enero 15 de 2003.</div><br></div>", "i": 6411135}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "7", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-7"}, {"tipo": "8", "numero": "7-2003", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-7-2003"}], "organismos": ["MUNICIPALIDAD DE PUCHUNCAVÍ"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-15", "doble_articulado": false, "id_norma": "206994", "numero_fuente": "37466", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-01-23", "vigencias": [{"desde": "2003-01-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-01-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-01-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen