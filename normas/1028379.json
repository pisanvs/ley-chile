{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 6.218 EXENTA, DE 2011</div></div>", "i": 9163203}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 6.218, de 22 de julio de 2011, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Consultor&#xED;a y Capacitaci&#xF3;n Limitada&quot; (Concap Ltda.) RUT 77.629.290-7, contenida en la resoluci&#xF3;n exenta N&#xBA; 3.763, de 7 de noviembre de 2006, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 3, del Art. 21 de la ley 19.518.- </div></div>", "i": 9163204}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Miguel Bergu&#xF1;o Ca&#xF1;as, Director Nacional.</div></div>", "i": 9163205}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6218 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6218 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 6.218 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-07-22", "doble_articulado": false, "id_norma": "1028379", "numero_fuente": "40027", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-08-04", "vigencias": [{"desde": "2011-08-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-08-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-08-04", "fin_vigencia": "", "tipo_version": "3"}], "evento