{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6057787}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 253 de fecha 09 de diciembre de 1991 conforme art&#xED;culo 51 Ley 16.391 y DS 68 de 1991, V. y U., Serviu IX Regi&#xF3;n dispuso expropiaci&#xF3;n inmueble ubicado en ciudad de Villarrica, Avenida Estaci&#xF3;n sin n&#xFA;mero, rol de aval&#xFA;o No. 317-4, de aparente dominio de la sucesi&#xF3;n de Carlos Beker Valdeavellano. Comisi&#xF3;n peritos integrada se&#xF1;ores Pablo Reidel Wanner, arquitecto, Mario Molina Ramwell, constructor civil, Jos&#xE9; M&#xE9;ndez Manr&#xED;quez, ingeniero civil, fij&#xF3; monto provisional indemnizaci&#xF3;n suma de $ 39.750.000.-, seg&#xFA;n informe de 14.10.91, pagadero contado. Yasm&#xED;n Balboa Rojas, Constructor Civil, </div></div>", "i": 6057788}, {"t": "<div><div class=\"p\">Director Serviu IX Regi&#xF3;n.</div><br></div>", "i": 6057789}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "253", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-253"}], "organismos": ["SERVICIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-12-09", "doble_articulado": false, "id_norma": "80635", "numero_fuente": "34143", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-12-16", "vigencias": [{"desde": "1991-12-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-12-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-12-16", "fin_vigencia": "", "