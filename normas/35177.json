{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293284}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 591, de 28 de marzo de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n cad&#xFA;case parcialmente la Resoluci&#xF3;n N&#xB0; 1.348, de 1990, que autoriz&#xF3; a SOCIEDAD PESQUERA NUTRIMAR S.A., a operar la nave &quot;Pacific Sea&quot;, en cuanto a los recursos y &#xE1;reas autorizadas en su numeral 3&#xB0; letras a) y b) Langostino colorado, Langostino amarillo, Merluza com&#xFA;n, Congrio dorado y Jurel, conforme a lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8293285}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 28 de marzo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293286}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "591", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-591"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "SOCIEDAD PESQUERA NUTRIMAR S.A"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-03-28", "doble_articulado": false, "id_norma": "35177", "numero_fuente": "35434", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-04-03", "vigencias": [{"desde": "1996-04-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-04-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-04-03", "fi