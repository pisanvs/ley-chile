{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;164 EXENTO, DE 2003 </div></div>", "i": 6429624}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;164 de fecha 20 de marzo de 2003, de Educaci&#xF3;n, se autoriza al Instituto Profesional Andali&#xE9;n a contar del presente a&#xF1;o acad&#xE9;mico, la creaci&#xF3;n de la Sede de Nueva Imperial.</div><br><div class=\"p\">&nbsp; &nbsp;  Asimismo, se autoriza para impartir en dicha sede la carrera de Relaciones P&#xFA;blicas, conducente al T&#xED;tulo Profesional de Relacionador P&#xFA;blico.</div><br><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase presente para todos los efectos legales y administrativos.</div><br></div>", "i": 6429625}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de abril de 2003.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6429626}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "164 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-164 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº164 EXENTO, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-03-20", "doble_articulado": false, "id_norma": "211918", "numero_fuente": "37598", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-02", "vigencias": [{"desde": "2003-07-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-07-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-07-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient