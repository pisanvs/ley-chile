{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 9.735 EXENTA, DE 2011</div></div>", "i": 9199219}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 9.735, de 12 de octubre de 2011, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Doral Capacita Limitada (Doral Limitada)&quot;, RUT 76.060.987-0, contenida en la resoluci&#xF3;n exenta N&#xBA; 7.882, de 1 de octubre de 2009, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del art. 21 de la ley 19.518.- </div></div>", "i": 9199220}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Francisco Ag&#xFC;ero Larrondo, Director Nacional (Subrogante).</div></div>", "i": 9199221}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9735 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-9735 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 9.735 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-10-12", "doble_articulado": false, "id_norma": "1031607", "numero_fuente": "40096", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-10-27", "vigencias": [{"desde": "2011-10-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-10-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-10-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [