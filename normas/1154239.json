{"html": [{"t": "<div><div class=\"p\">Publicidad de los nombramientos conferidos por el Estado</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago i Abril 25 de 1813.</div></div>", "i": 10193834}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Nada es capaz de estimular mas al bien que hacer p&#xFA;blicos los premios que la Patria dispensa a los ciudadanos benem&#xE9;ritos. En esta atencion decreta el Gobierno que desde hoi en adelante se instruya al pueblo por medio del Monitor de todos los empleos i grados pol&#xED;ticos, militares i eclesi&#xE1;sticos que se confiriesen por las autoridades del Estado.- </div></div>", "i": 10193835}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  P&#xE9;rez.- Infante.- Eyzaguirre.- Ega&#xF1;a, Secretario.</div></div>", "i": 10193836}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Publicidad de los nombramientos conferidos por el Estado", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1813-04-25", "doble_articulado": false, "id_norma": "1154239", "numero_fuente": "1813", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1813-04-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1813-04-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1813-04-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-01-19", "fecha_version": "1813-04-25", "fecha_actualizacion_texto": "2021-