{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Club Social de Parral Lei n&#xFA;m.1,160.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948461}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese al Club Social de Parral el permiso requerido por el art. 556 del C&#xF3;digo Civil para que pueda conservar hasta por treinta a&#xF1;os la posesion de un bien raiz situado en la calle del Puente de esa ciudad.</div><br><br></div>", "i": 5948462}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 2 de Enero de 1899.- FEDERICO ERRAZURIZ.- C&#xE1;rlos A. Palacios Z.</div><br></div>", "i": 5948463}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1160", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1160"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "Club Social de Parral", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CLUB SOCIAL PARRAL", "BIEN RAIZ", "POSESION", "CONCESION", "PLAZO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-01-02", "doble_articulado": false, "id_norma": "22437", "numero_fuente": "6195", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-01-07", "vigencias": [{"desde": "1899-01-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-01-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-01