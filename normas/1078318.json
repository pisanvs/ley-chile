{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N N&#xBA;1.138 EXENTA, DE 2015, QUE OTORG&#xD3; A BRACPESCA S.A. PERMISO EXTRAORDINARIO DE PESCA QUE INDICA</div></div>", "i": 9607879}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.505, de 4 de junio de 2015, de esta Subsecretar&#xED;a, rectif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1077144&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.138 de 2015</a>, que otorg&#xF3; a Bracpesca S.A., un permiso extraordinario de pesca para la unidad de pesquer&#xED;a del recurso hidrobiol&#xF3;gico Langostino colorado, en el sentido de se&#xF1;alar en su numeral 11 que se deja sin efecto la resoluci&#xF3;n exenta N&#xBA; 3.739 de 2014 y no la que all&#xED; se se&#xF1;ala.</div></div>", "i": 9607880}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de junio de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9607881}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1505 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1505 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "RECTIFICA RESOLUCIÓN Nº1.138 EXENTA, DE 2015, QUE OTORGÓ A BRACPESCA S.A. PERMISO EXTRAORDINARIO DE PESCA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-06-04", "doble_articulado": false, "id_norma": "1078318", "numero_fuente": "41180", "tipo_version": "3", "tipo_v