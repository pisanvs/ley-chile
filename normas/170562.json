{"html": [{"t": "<div><div class=\"p\">AUTORIZA A PESQUERA GOMYCAR S.A. PARA AMPLIAR ACTIVIDADES </div></div>", "i": 6280957}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.490 de 18 de diciembre de 1987 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Pesquera Gomycar S.A., domiciliada en Iquique, para ampliar las actividades pesqueras autorizadas por Resoluci&#xF3;n N&#xBA; 347, de 1984, de esta Subsecretar&#xED;a, en orden a facultarle a extraer con la embarcaci&#xF3;n &quot;Drakkar&quot;, el recurso hidrobiol&#xF3;gico Bonito, adem&#xE1;s de los ya autorizados.</div><br></div>", "i": 6280958}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de diciembre de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 6280959}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1490", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1490"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA GOMYCAR S.A. PARA AMPLIAR ACTIVIDADES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-12-18", "doble_articulado": false, "id_norma": "170562", "numero_fuente": "32966", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-01-11", "vigencias": [{"desde": "1988-01-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-01-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-01-11", "fin_vigencia": "", "tipo_version": "3"}], "event