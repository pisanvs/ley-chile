{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 75 EXENTA, DE 2003 </div><br></div>", "i": 6455343}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n Ex. SII N&#xBA; 75, de fecha 16 de diciembre de 2003, se establece formas y plazos de env&#xED;o de informaci&#xF3;n de la Bolsa de Corredores Bolsa de Valores, sobre acciones emitidas por sociedades an&#xF3;nimas con presencia burs&#xE1;til.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra incluido en el sitio web del Servicio en internet, cuya direcci&#xF3;n es www.sii.cl y adem&#xE1;s, se publicar&#xE1; en bolet&#xED;n del SII del mes de diciembre.-</div><br></div>", "i": 6455344}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Toro Rivera, Director.</div><br></div>", "i": 6455345}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "75 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-75 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 75 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-16", "doble_articulado": false, "id_norma": "219242", "numero_fuente": "37741", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-22", "vigencias": [{"desde": "2003-12-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-12-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-12-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul