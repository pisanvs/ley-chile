{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10222931}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 672, de 20 de abril de 2021, de este Servicio, se estableci&#xF3; el procedimiento para la inscripci&#xF3;n de la pesquer&#xED;a de la Breca de Juan Fern&#xE1;ndez, de conformidad a los requisitos establecidos por la Subsecretar&#xED;a de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n y su respectivo Informe T&#xE9;cnico, se encuentran publicados con esta techa en el sitio de dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y en el de la Subsecretar&#xED;a de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10222932}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de abril de 2021.- Fernando Naranjo Gatica, Director Nacional (S), Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\"> </div><br></div>", "i": 10222933}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "672 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-672 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1934000", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-04-20", "doble_articulado": false, "id_norma": "1158887", "numero_fuente": "42941", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-04-28