{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 1,383.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949029}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. C&#xF3;nc&#xE9;dese un suplemento de trescientos mil pesos al &#xED;tem 4 de la partida 24 del presupuesto del Ministerio de Industria i Obras P&#xFA;blicas, para trabajos de defensa en los rios. </div></div>", "i": 5949030}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 16 de Noviembre de 1900.- FEDERICO ERRAZURIZ E.- M. A. Covarrubias.</div><br></div>", "i": 5949031}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1383", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1383"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1900", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-11-16", "doble_articulado": false, "id_norma": "22604", "numero_fuente": "6748", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-11-21", "vigencias": [{"desde": "1900-11-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-11-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1900-11-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vi