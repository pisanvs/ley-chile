{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8317462}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.020 de 26 de Octubre de 1992, de esta Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la resoluci&#xF3;n No. 856, de 1986, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don JOSE ORLANDO PAIDANCA CARCAMO, R.U.T. No. 6.601.555-6, domiciliado en Manao, Chilo&#xE9;, para instalar y operar un establecimiento de cultivo del recurso alga del g&#xE9;nero Gracilaria spp. en Sector de Bah&#xED;a Manao, Comuna de Ancud, Provincia de Chilo&#xE9;, Regi&#xF3;n X, en una superficie de 9.100 m2 por renuncia total de su titular, ya individualizado.</div><br><br></div>", "i": 8317463}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 26 de Octubre de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8317464}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1020", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1020"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-10-26", "doble_articulado": false, "id_norma": "85929", "numero_fuente": "34409", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-11-06", "vigencias": [{"desde": "1992-11-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-11-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-11-06", "fin_vigencia": "", "tipo_version": "3"}]