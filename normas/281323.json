{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 6,344</div><br><div class=\"p\">CONCEDE ABONO DE TIEMPO A DON IGNACIO CARDENAS NU&#xD1;EZ </div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6664630}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Ab&#xF3;nase, por gracia, al se&#xF1;or don Ignacio C&#xE1;rdenas N&#xFA;&#xF1;ez, para todos los efectos legales, el tiempo de un a&#xF1;o y siete meses que sirvi&#xF3; en el Archivo General de los Tribunales de Justicia.</div><div class=\"p\">&nbsp; &nbsp;  La presente ley comenzar&#xE1; a regir desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 6664631}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, ocho de Julio de mil novecientos treinta y nueve.- PEDRO AGUIRRE CERDA.- L. Ra&#xFA;l Puga M.</div><br><br></div>", "i": 6664632}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "6344", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-6344"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDE ABONO DE TIEMPO A DON IGNACIO CARDENAS NUÑEZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1939-07-08", "doble_articulado": false, "id_norma": "281323", "numero_fuente": "18413", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1939-07-12", "vigencias": [{"desde": "1939-07-12", "hasta"