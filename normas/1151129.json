{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10171704}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xB0; 897, de 28 de septiembre de 2020, se modific&#xF3; y desisti&#xF3; parcialmente de la expropiaci&#xF3;n del lote N&#xB0; 21, realizada por <a href=\"https://www.leychile.cl/Navegar?idNorma=1106447&amp;idParte=&amp;idVersion=\">Decreto Exento MOP N&#xB0; 732, de 13 de julio de 2017</a>, reduci&#xE9;ndose la superficie expropiada a 13 m2. y modificando el numeral primero de dicho Decreto, en la parte que se refiere al kilometraje de t&#xE9;rmino, donde dice: Km. 20,77830, debe decir: Km. 20,77534, complementando el informe de tasaci&#xF3;n de 5 de julio de 2013 y acta de fecha 28 de diciembre de 2016, con acta de fecha 24 de abril de 2020, expropiado para la ejecuci&#xF3;n de obra &quot;Mejoramiento Ruta E-525, Sector El Tartaro - Los Patos, Tramo: Km. 15,42000 al Km. 20,96000&quot;, Comuna de Putaendo, Regi&#xF3;n de Valpara&#xED;so. </div><div class=\"p\"> </div><br></div>", "i": 10171705}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10171706}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "897 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-897 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1837275", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-09-28", "doble_articulado": false, "id_norma": "1151129", "numero_fuente": "4279