{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294412}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 828 de 29 de Octubre de 1993 de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la autorizaci&#xF3;n</div><div class=\"p\">solicitada por INDUSTRIA PESQUERA TOMONEL S.A., R.U.T.</div><div class=\"p\">N&#xB0; 93.452.000-9, para ampliar el plazo se&#xF1;alado en el</div><div class=\"p\">numeral 5&#xB0; de la Resoluci&#xF3;n N&#xB0; 450, de 1990, de esta</div><div class=\"p\">Subsecretar&#xED;a, en virtud de lo dispuesto en letra b) del</div><div class=\"p\">art&#xED;culo 143 de la Ley N&#xB0; 18.892 y sus modificaciones.</div><div class=\"p\">&nbsp; &nbsp; Cad&#xFA;case la Resoluci&#xF3;n N&#xB0; 450, de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Industria Pesqueras Timonel S.A., para operar la nave &quot;Tumi&quot;, en raz&#xF3;n de lo dispuesto en la letra b) del art&#xED;culo 143 de la Ley N&#xB0; 18.892 y sus modificaciones.</div><br></div>", "i": 8294413}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 29 de Octubre de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8294414}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "828", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-828"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INDUSTRIA PESQUERA TIMONEL S.A.", "PESCA", "AMPLIACION", "PLAZO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion