{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA EL NOMBRE DE LA CALLE QUE INDICA, DE LA CIUDAD DE LINARES, POR EL QUE SE&#xD1;ALA.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8280774}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. La actual calle Porvenir, de la ciudad de Linares, se denominar&#xE1; en lo sucesivo calle &quot;Ignacio Chac&#xF3;n&quot;.</div><br></div>", "i": 8280775}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintiocho de julio de mil novecientos cincuenta y nueve.- JORGE ALESSANDRI RODRIGUEZ.- S&#xF3;tero del R&#xED;o.</div><br></div>", "i": 8280776}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13354", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13354"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA EL NOMBRE DE LA CALLE QUE INDICA, DE LA\nCIUDAD DE LINARES, POR EL QUE SEÑALA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "CALLE IGNACIO CHACON", "LINARES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1959-07-28", "doble_articulado": false, "id_norma": "27440", "numero_fuente": "24415", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1959-08-11", "vigencias": [{"desde": "1959-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1959-08-11", "fin_vigencia": ""}, "vigencias_