{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; TASA DE INTERES PROMEDIO </div></div>", "i": 5845389}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de agosto de 1996, fue de 7,01% anual.</div><br></div>", "i": 5845390}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, agosto 19 de 1996.- V&#xED;ctor Vial del R&#xED;o, Ministro de Fe.</div><br></div>", "i": 5845391}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "TASA DE INTERES PROMEDIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA INTERES PROMEDIO", "OPERACIONES CREDITO DINERO", "CAPTACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-08-19", "doble_articulado": false, "id_norma": "1872", "numero_fuente": "35548", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-08-22", "vigencias": [{"desde": "1996-08-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-08-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-08-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1996-08-22", "fecha_actualizacion_texto": "1996-08-22", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encab