{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 1, DE 2012</div></div>", "i": 9245455}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1, de 6 de enero de 2012, del Ministerio de Transportes y Telecomunicaciones, se aprob&#xF3; el t&#xE9;rmino anticipado de mutuo acuerdo del Contrato de Concesi&#xF3;n de Uso de V&#xED;as suscrito con la sociedad concesionaria Buses Metropolitana S.A. y se aprueba Contrato Ad-Refer&#xE9;ndum de Concesi&#xF3;n de Uso de V&#xED;as de la Ciudad de Santiago para la prestaci&#xF3;n de servicios urbanos de transporte p&#xFA;blico remunerado de pasajeros mediante buses, de 7 de diciembre de 2011, suscrito entre Buses Metropolitana S.A., concesionario de la Unidad de Negocio N&#xBA; 5 y el Ministerio de Transportes y Telecomunicaciones.- </div></div>", "i": 9245456}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Gloria Hutt Hesse, Ministro de Transportes y Telecomunicaciones (S).</div></div>", "i": 9245457}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 1, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-01-06", "doble_articulado": false, "id_norma": "1038460", "numero_fuente": "40227", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-03-31", "vigencias": [{"desde": "2012-03-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-03-