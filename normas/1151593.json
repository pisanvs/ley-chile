{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xB0; 8.219 EXENTA, DE 2012</div></div>", "i": 10174527}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 3.203, de fecha 6 de noviembre de 2020, del Director Nacional de Aduanas, se modifica la <a href=\"https://www.leychile.cl/Navegar?idNorma=1045882&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 8.219/2012</a> que establece el registro y normas para la Salida y Admisi&#xF3;n Temporal de Veh&#xED;culos pertenecientes a empresas Rent a Car, en lo siguiente:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Se reemplaza el numeral 2.1 de la resoluci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10174528}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de noviembre de 2020.- Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><div class=\"p\"> </div><br></div>", "i": 10174529}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3203 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3203 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCIÓN N° 8.219 EXENTA, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1846072", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-11-06", "doble_articulado": false, "id_norma": "1151593", "numero_fuent