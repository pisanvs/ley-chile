{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6005126}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Resoluci&#xF3;n 072, 21 abril 1995, Serviu Regi&#xF3;n del B&#xED;o</div><div class=\"p\">B&#xED;o orden&#xF3; expropiaci&#xF3;n total Parcelas 7 y 8, inmueble</div><div class=\"p\">ubicado Sector Sur de Michaihue, Rol de Aval&#xFA;os N&#xB0;</div><div class=\"p\">15.009-600, comuna Concepci&#xF3;n, superficie 288.327 m2.,</div><div class=\"p\">dentro pol&#xED;gono y linderos se&#xF1;alados plano expropiaci&#xF3;n</div><div class=\"p\">S8R-11004-E: de aparente dominio de Suc. Olivares</div><div class=\"p\">Saavedra; para programas viviendas, equipamiento</div><div class=\"p\">comunitario y obras de infraestructura, conforme</div><div class=\"p\">art&#xED;culo 51 Ley 16.391 y D.S. 2.186. Comisi&#xF3;n Peritos integrada por Teodoro Medina Reyes, ingeniero civil; Pedro Tagle Mart&#xED;nez, arquitecto, y Luis Abarz&#xFA;a Ceballos, constructor civil, seg&#xFA;n informe de fecha 20 de abril de 1995, fij&#xF3; monto provisional indemnizaci&#xF3;n en $180.204.375.-, pagadera de contado.</div><br></div>", "i": 6005127}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director Serviu Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6005128}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "72", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-72"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "CONCEPCION", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-04-21", "doble_articulado": false, "id_norma": "32836", "numero_fuente": "3518