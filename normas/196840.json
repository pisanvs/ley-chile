{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 3.142 EXENTA, DE 2002 </div></div>", "i": 6377253}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;3.142 de 15 de marzo del a&#xF1;o 2002, se ha aprobado al Instituto Rafael Arizt&#xED;a (Hermanos Maristas) de Quillota, un plan de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; simult&#xE1;neamente en todos los cursos a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 6377254}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de marzo de 2002.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6377255}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3142 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3142 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 3.142 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-15", "doble_articulado": false, "id_norma": "196840", "numero_fuente": "37237", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-17", "vigencias": [{"desde": "2002-04-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-04-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-04-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacione