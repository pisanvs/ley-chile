{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7267545}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 765, de 22 de Noviembre de 1985 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a la Sociedad Pesca Marina Limitada, domiciliada en Quintero, para operar la embarcaci&#xF3;n denominada &quot;Polux&quot;, en el litoral comprendido entre la III y la VI Regi&#xF3;n en labores extractivas de los siguientes recursos: camar&#xF3;n, langostino amarillo y merluza. Dicha embarcaci&#xF3;n deber&#xE1; contar a bordo con sistemas adecuados de preservaci&#xF3;n de la materia prima, tales como contenedores con hielo, c&#xE1;maras isot&#xE9;rmicas o refrigeradas.</div><br></div>", "i": 7267546}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de Noviembre de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7267547}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "765", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-765"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1985-11-22", "fecha_derogacion": "2005-03-04", "doble_articulado": false, "id_norma": "165376", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1985-12-12", "vigencias": [{"desde": "2005-03-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1985-12-12", "hasta": "2005-03-03", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vige