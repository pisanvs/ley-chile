{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6342470}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;723 de fecha 31 de mayo de 2001, se expropi&#xF3; el lote de terreno N&#xBA;3, superficie 2.238 m&#xB2;, rol de aval&#xFA;o N&#xBA;592-11, comuna de Yungay, para la obra &quot;Area de Riego Yungay, Canal San Jos&#xE9;, Ramal 8, Faja Adicional y Prolongaci&#xF3;n Km. 0,005 al 0,977 del Proyecto Laja Diguill&#xED;n&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Jos&#xE9; Guzmaro Campos Sandoval, ascendente a la cantidad de $1.177.900. </div></div>", "i": 6342471}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6342472}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "723", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-723"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-31", "doble_articulado": false, "id_norma": "187581", "numero_fuente": "37012", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-07-16", "vigencias": [{"desde": "2001-07-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-07-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-07-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2001-07-16", "fecha_version": "2001-07-16", "fecha_actualizacion_texto": "2001-07-16", "tipo_tratado": ""}, "alerta