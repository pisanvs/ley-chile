{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9020101}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 584, de 14 de Junio de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case la Resoluci&#xF3;n N&#xB0; 442, de 1992, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA YASIFAH LIMITADA, R.U.T. N&#xB0; 79.839.130-5, para iniciar actividades pesqueras de transformaci&#xF3;n, en el sentido de incorporar a su texto el siguiente numeral 13.-:</div><div class=\"p\">&nbsp; &nbsp; &quot;13.- D&#xE9;jase sin efecto la autorizaci&#xF3;n contenida en el p&#xE1;rrafo segundo del numeral 2&#xB0; de la Resoluci&#xF3;n N&#xB0; 302, de 1990, de esta Subsecretar&#xED;a, atendido lo dispuesto en el cuerpo de la presente Resoluci&#xF3;n&quot;.- </div></div>", "i": 9020102}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 14 de Junio de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 9020103}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "584", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-584"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA YASIFAH LIMITADA", "PESCA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-06-14", "doble_articulado": false, "id_norma": "35154", "numero_fuente": "34899", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-06-25", "vigencias": [{"desde": "1994-06-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"