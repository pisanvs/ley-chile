{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA; 143, DE 1989 </div></div>", "i": 6089500}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 143 de 29 de septiembre de 1989 se incorporan las asignaturas de Orientaci&#xF3;n Profesional Textil y Orientaci&#xF3;n Profesional de la Confecci&#xF3;n, al plan de estudio para el 1er. ciclo de Educaci&#xF3;n Media que se aplica en el Liceo Industrial A No. 60 y Liceo T&#xE9;cnico A No. 57, de la Regi&#xF3;n Metropolitana. Adem&#xE1;s, se aprueban programas para las asignaturas citadas. </div></div>", "i": 6089501}, {"t": "<div><div class=\"p\">Santiago, 13 de Octubre de 1989.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6089502}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "143 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-143 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº 143, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-09-29", "doble_articulado": false, "id_norma": "91645", "numero_fuente": "33500", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-10-19", "vigencias": [{"desde": "1989-10-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-10-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-10-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMZ", "fecha_ingreso": "19