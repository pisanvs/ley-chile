{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6431745}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;556 de fecha 30 de mayo de 2003, se expropi&#xF3; el lote de terreno N&#xBA;98, superficie 310,00 m2, rol de Aval&#xFA;o N&#xBA;764-111, comuna de Lampa, para la obra &quot;Camino Ruta G-184-182, Sector El Noviciado - Cruce Ruta G-16 (Lipangue), tramo de Km. 4,450 a Km.</div><div class=\"p\">15,04419&quot;, Regi&#xF3;n Metropolitana y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietaria Emelinda del Carmen Gonz&#xE1;lez Leiva, ascendente a la cantidad de $3.056.002. </div></div>", "i": 6431746}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6431747}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "556", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-556"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-05-30", "doble_articulado": false, "id_norma": "212539", "numero_fuente": "37609", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-15", "vigencias": [{"desde": "2003-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2003-07-15", "fecha_version": "2003-07-15", "fecha_actualizacion_texto": "2003-07-15", "tipo