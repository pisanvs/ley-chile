{"html": [{"t": "<div><div class=\"p\">CERTIFICADO</div><br><br></div>", "i": 6126573}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de agosto de 1998, fue de 9,78% anual.</div><br></div>", "i": 6126574}, {"t": "<div><div class=\"p\">Santiago, Agosto 20 de 1998. Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6126575}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA DE INTERES PROMEDIO", "OPERACIONES DE CREDITO DE DINERO", "CAPTACION", "TIP"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-20", "doble_articulado": false, "id_norma": "123359", "numero_fuente": "336146", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-08-22", "vigencias": [{"desde": "1998-08-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-08-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-08-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1998-08-25", "fecha_version": "1998-08-22", "fecha_actualizacion_texto": "1998-08-22", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "e