{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8351772}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.978, de 6 de octubre de 1999,</div><div class=\"p\">de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA LA</div><div class=\"p\">PENINSULA S.A. para ampliar las actividades de pesca</div><div class=\"p\">autorizadas por las resoluciones N&#xBA; 1.361 de 1996, N&#xBA;</div><div class=\"p\">1.876 de 1996 y N&#xBA; 498 de 1999, todas de esta</div><div class=\"p\">Subsecretar&#xED;a, con la nave &apos;&apos;Loa 7&apos;&apos;, en el litoral de</div><div class=\"p\">la I y II Regiones, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, con red de cerco, respecto del recurso Anchoa blanca.</div><br></div>", "i": 8351773}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de octubre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8351774}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1978", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1978"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-10-06", "fecha_derogacion": "2002-11-07", "doble_articulado": false, "id_norma": "145632", "numero_fuente": "36493", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-10-20", "vigencias": [{"desde": "2002-11-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-10-20", "hasta": "2002-11-06", "tipo_version": "0", "tipo_vers