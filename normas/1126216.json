{"html": [{"t": "<div><br><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9973105}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 6.659 de 20 de noviembre de 2018, Serviu Regi&#xF3;n de Valpara&#xED;so, dispuesto expropiaci&#xF3;n conforme al art&#xED;culo 51 ley 16.391 y decreto ley 2.186 de 1978, del inmueble signado como lote 18, en el plano &quot;Proyecto de Expropiaciones DRS-P N&#xB0;11965 Lamina 06 de 15, de la comuna de Valpara&#xED;so, para la ejecuci&#xF3;n del proyecto &quot;Construcci&#xF3;n Calle Mesana, comuna de Valpara&#xED;so&quot;. Presunto Dominio de Jaime Solar Sep&#xFA;lveda y otros, rol aval&#xFA;o No Registrado. Comisi&#xF3;n Tasadora integrada por Ismael Allendes Marin; Jorge Giacaman Valle y Alvaro Verdejo Vidal, seg&#xFA;n informe de 2018 fijo monto indemnizaci&#xF3;n provisional en $1.101.214.-, que ser&#xE1; pagada al contado.- </div></div>", "i": 9973106}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Directora (S) Serviu. </div><br></div>", "i": 9973107}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6659 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6659 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "V REGIÓN DE VALPARAÍSO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1503853", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-11-20", "doble_articulado": false, "id_norma": "1126216", "numero_fuente": "42219", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-12-01", "vigencias": [{"desde": "201