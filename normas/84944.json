{"html": [{"t": "<div><div class=\"p\">PRORROGA AUTORIZACION QUE INDICA </div></div>", "i": 8316780}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 80, de 23 de Enero de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por seis meses a contar del 02 de Enero de 1990, el plazo otorgado a Pesquera Trans Antartic Limitada, R.U.T. No. 84.925.700-5, domiciliada en Santiago, para empezar a operar el establecimiento de cultivo autorizado por la resoluci&#xF3;n No. 1.349, de 1987, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8316781}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 23 de Enero de 1990.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8316782}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "80", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-80"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-23", "doble_articulado": false, "id_norma": "84944", "numero_fuente": "33601", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-20", "vigencias": [{"desde": "1990-02-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "