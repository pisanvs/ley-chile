{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6271370}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 714, de 29 de febrero del 2000, se expropi&#xF3; el lote de terreno N&#xBA; 10, superficie 397,6 rol de aval&#xFA;o 160-76, comuna de Pto. Octay, Obra Camino Nochaco-Ensenada, sector Bif. Lago Rupanco-Pte. Las Cascadas y se acord&#xF3; precio de indemnizaci&#xF3;n con su propietaria Bette Carlota Galle Tampier, ascendente a la cantidad de $284.171.</div><br></div>", "i": 6271371}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6271372}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "714", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-714"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-29", "doble_articulado": false, "id_norma": "167454", "numero_fuente": "36652", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-02", "vigencias": [{"desde": "2000-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2000-05-02", "fecha_version": "2000-05-02", "fecha_actualizacion_texto": "2000-05-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6271370}, {"n": "Artículo", "i": 627137