{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6101334}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 581 de 12 de Junio de 1989 de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL 2.186 de 1978, inmueble ubicado en calle. Ricardo Santa Cruz No. 617, presunto rol aval&#xFA;os 593-12 comuna de Santiago aparentemente dominio de do&#xF1;a Mar&#xED;a S&#xE1;nchez Cari. Comisi&#xF3;n integrada por peritos Sres. Gabriel Urrutia Benavente y Mario Vergara Navarrete, arquitectos y Walter Soto Silva, ingeniero civil seg&#xFA;n informe de 31 de Enero de 1989, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 3.497.250., pagadera al contado. </div></div>", "i": 6101335}, {"t": "<div><div class=\"p\">Director SERVIU Metropolitano.</div><br></div>", "i": 6101336}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "581", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-581"}], "organismos": ["SERVICIO DE VIVIENDA Y URBANIZACIÓN REGIÓN METROPOLITANA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-06-12", "doble_articulado": false, "id_norma": "95922", "numero_fuente": "33411", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-07-01", "vigencias": [{"desde": "1989-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMB", "fecha_ingreso": "1998-03-17", "fecha_version": "1989-07-01", "fecha_actu