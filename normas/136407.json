{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,125.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6168733}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a las hijas solteras de don C&#xE1;rlos Boizard una pension anual de mil doscientos pesos ($ 1,200).</div><br></div>", "i": 6168734}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, cinco de setiembre de mil novecientos ocho.- Pedro Montt.- Eduardo Su&#xE1;rez Mujica.</div><br></div>", "i": 6168735}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2125", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2125"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1908-09-05", "doble_articulado": false, "id_norma": "136407", "numero_fuente": "9189", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1908-09-16", "vigencias": [{"desde": "1908-09-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1908-09-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1908-09-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-05-14", "fecha_version": "1908-09-16", "fecha_actual