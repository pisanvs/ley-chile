{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7340949}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 935, de 27 de marzo de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a CRISTINA DEL CARMEN BARRIOS TOTO para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en calle Principal s/n&#xBA;, Pichicuy, comuna de La Ligua, Provincia de Petorca, V Regi&#xF3;n, donde podr&#xE1; elaborar, en las l&#xED;neas de proceso Cocido, Fresco-refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 7340950}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de marzo de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7340951}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "935 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-935 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-03-27", "doble_articulado": false, "id_norma": "260420", "numero_fuente": "38748", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-04-26", "vigencias": [{"desde": "2007-04-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-04-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-04-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "J