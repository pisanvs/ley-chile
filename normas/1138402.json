{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10066998}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 1.161, de fecha 2 de octubre de 2019, de esta Secretar&#xED;a Regional, se aprobaron los Planes y Programas de ense&#xF1;anza conducentes a la obtenci&#xF3;n de Licencias de Conductor No Profesionales o Clase B, de la &quot;Escuela de Conductores Carlos Ignacio Poblete Cruz E.I.R.L.&quot;, cuyo propietario y director es el se&#xF1;or Carlos Ignacio Poblete Cruz, y su sede estar&#xE1; ubicada en calle Baquedano N&#xB0; 559, comuna de Cunco. Las horas autorizadas a la referida escuela son 12 horas pedag&#xF3;gicas te&#xF3;ricas y 12 horas pr&#xE1;cticas, con un total de 24 horas pedag&#xF3;gicas.- </div><br></div>", "i": 10066999}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis R. Calder&#xF3;n Ram&#xED;rez, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de la Araucan&#xED;a.</div><br></div>", "i": 10067000}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1161 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1161 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "XII REGIÓN DE MAGALLANES Y ANTÁRTICA CHILENA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1677303", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-10-02", "doble_articulado": false, "id_norma": "1138402", "numero_fuente": "42496", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-11-07", "vigencias": [{"desde": "2019-11-07", "hasta": "", "tipo_