{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 3.591 EXENTA, DEL 14 DE AGOSTO DE 2018</div></div>", "i": 10248218}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 1.548, del 25 de junio de 2021, del Director Nacional de Aduanas, se modific&#xF3; la <a href=\"https://www.leychile.cl/Navegar?idNorma=1122808&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.591</a>, del 14 de agosto de 2018, del mismo origen, sustituy&#xE9;ndose el numeral II, relativo a la fecha a partir de la cual se derogan las instrucciones que permiten la tramitaci&#xF3;n de una Declaraci&#xF3;n Almac&#xE9;n Particular de Importaci&#xF3;n para rotulaci&#xF3;n de calzado, en la forma que se indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10248219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de junio de 2021.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><div class=\"p\"> </div><br></div>", "i": 10248220}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1548 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1548 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 3.591 EXENTA, DEL 14 DE AGOSTO DE 2018", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1972078", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-08-14", "doble_articulado": fals