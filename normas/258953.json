{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6603652}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 724, de 28 de febrero de 2007, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de la resoluci&#xF3;n exenta N&#xBA; 38, modificada mediante resoluci&#xF3;n exenta N&#xBA; 151, ambas de 2007, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Investigaci&#xF3;n evaluaci&#xF3;n hidroac&#xFA;stica reclutamiento Anchoveta y Sardina com&#xFA;n V-X Regiones, 2006-2007&quot; en el sentido de extender el per&#xED;odo de la citada pesca de investigaci&#xF3;n hasta el d&#xED;a 15 de marzo de 2007, inclusive.</div><br></div>", "i": 6603653}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de febrero de 2007.- Mar&#xED;a Angela Barbieri Bellolio, Subsecretaria de Pesca (S). </div></div>", "i": 6603654}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "724 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-724 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-02-28", "doble_articulado": false, "id_norma": "258953", "numero_fuente": "38708", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-03-08", "vigencias": [{"desde": "2007-03-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vi