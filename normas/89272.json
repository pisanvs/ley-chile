{"html": [{"t": "<div><div class=\"p\">MODIFICA ORDENANZA No. 1 DE 1988</div><br><div class=\"p\">Con fecha 13 de agosto de 1990 la I. Municipalidad de Renca, dict&#xF3; el Decreto Alcaldicio No. 1360 - 90 mediante el cual se modifica la Ordenanza No. 001 de 27 de enero de 1988, sobre derechos municipales por permisos, concesiones y servicios municipales, en el sentido de agregar a continuaci&#xF3;n del No. 9 del art&#xED;culo 15 de la referida Ordenanza y con el No. 10, lo siguiente:</div><br></div>", "i": 6081975}, {"t": "<div><div class=\"p\">&quot;10.- Letreros a&#xE9;reos que floten en forma aerost&#xE1;tica, semana o fracci&#xF3;n: a) M&#xF3;viles 3 UTM b) Fijos 1 UTM La presente modificaci&#xF3;n comenzar&#xE1; a regir desde la fecha de la presente publicaci&#xF3;n.-</div><br></div>", "i": 6081976}, {"t": "<div><div class=\"p\">El Alcalde.</div><br></div>", "i": 6081977}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1360", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1360"}], "organismos": ["MUNICIPALIDAD DE RENCA"], "titulo_norma": "MODIFICA ORDENANZA No. 1 DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-08-13", "doble_articulado": false, "id_norma": "89272", "numero_fuente": "33751", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-08-22", "vigencias": [{"desde": "1990-08-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-08-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-08-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por"