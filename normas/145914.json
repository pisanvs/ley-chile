{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8352206}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.134, de 15 de octubre de 1999,</div><div class=\"p\">de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de</div><div class=\"p\">la resoluci&#xF3;n N&#xBA; 835, de 1996, de esta Subsecretar&#xED;a, en</div><div class=\"p\">cuanto autoriz&#xF3; a la EMPRESA PESQUERA EPERVA S.A., para</div><div class=\"p\">realizar actividades pesqueras extractivas con la nave</div><div class=\"p\">&apos;&apos;Eperva 65&apos;&apos; respecto de los recursos Anchoveta y</div><div class=\"p\">Sardina espa&#xF1;ola, en el litoral de la III y IV Regiones,</div><div class=\"p\">de conformidad con lo establecido en la letra b) del</div><div class=\"p\">art&#xED;culo 143 del D.S. N&#xBA; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8352207}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de octubre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8352208}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2134", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2134"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-15", "doble_articulado": false, "id_norma": "145914", "numero_fuente": "36495", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-10-22", "vigencias": [{"desde": "1999-10-22", "hasta": "", "tipo_version": "3", "tipo