{"html": [{"t": "<div><div class=\"p\">APRUEBA REFORMA DE ESTATUTOS A &quot;ADMINISTRADORA BANCHILE DE FONDOS MUTUOS S.A.&quot; </div></div>", "i": 6273061}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico: Que por resoluci&#xF3;n N&#xBA; 76 de 10 de Mayo de 1985, se aprob&#xF3; reforma estatutos sociedad an&#xF3;nima &quot;Administradora Banchile de Fondos Mutuos S.A.&quot;, que consta de la escritura p&#xFA;blica de 02 de Mayo de 1985, otorgada en la Notar&#xED;a de Santiago de don Patricio Zald&#xED;var Mackenna.</div><div class=\"p\">&nbsp; &nbsp;  La reforma consiste en establecer como renumeraci&#xF3;n de los Directores una dieta por asistencia a sesiones, que ser&#xE1; fijada anualmente por la Junta Ordinaria de Accionistas.</div><br></div>", "i": 6273062}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de Mayo de 1985.- Ana Mar&#xED;a Siefer Navas, Secretario General.</div><br></div>", "i": 6273063}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "76", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-76"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "APRUEBA REFORMA DE ESTATUTOS A ADMINISTRADORA BANCHILE DE FONDOS MUTUOS S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-10", "doble_articulado": false, "id_norma": "167970", "numero_fuente": "32176", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-05-22", "vigencias": [{"desde": "1985-05-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-05-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio