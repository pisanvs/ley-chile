{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 1.248 EXENTA, DE 2015</div></div>", "i": 9603205}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.248, de 29 de mayo de 2015, se aprueba la aceptaci&#xF3;n de Servicio de Transporte de Personas Santiago S.A. para asumir la prestaci&#xF3;n de los servicios de transporte p&#xFA;blico urbano remunerado de pasajeros al interior de la zona F (Unidad de Negocio N&#xBA; 7), del Sistema de Transporte P&#xFA;blico de Pasajeros de la Ciudad de Santiago, que ser&#xE1;n prestados a partir del 1&#xBA; de junio de 2015 bajo condiciones espec&#xED;ficas de operaci&#xF3;n y de utilizaci&#xF3;n de v&#xED;as. Texto &#xED;ntegro de la resoluci&#xF3;n exenta N&#xBA; 1.248, de 2015, se encuentra en la p&#xE1;gina web www.dtpm.cl.</div><br></div>", "i": 9603206}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Pedro Huichalaf Roa, Ministro de Transportes y Telecomunicaciones (s).</div></div>", "i": 9603207}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1248 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-1248 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 1.248 EXENTA, DE 2015", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-05-29", "doble_articulado": false, "id_norma": "1078038", "numero_fuente": "41170", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-05-30", "vigencias": [{"desde": "2015-05-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "v