{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6191714}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1 del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables de 90 a 365 d&#xED;as, correspondiente a la primera quincena de diciembre de 1987, fue de 4.53% anual. </div></div>", "i": 6191715}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de diciembre de 1987.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6191716}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE HACIENDA", "BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-12-17", "doble_articulado": false, "id_norma": "143563", "numero_fuente": "32949", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-19", "vigencias": [{"desde": "1987-12-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-09-20", "fecha_version": "1987-12-19", "fecha_actualizacion_texto": "1987-12-19", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6191714}, {"n": "Artículo",