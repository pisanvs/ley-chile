{"html": [{"t": "<div><div class=\"p\">PRORROGA AUTORIZACION QUE INDICA </div></div>", "i": 8320297}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 1.795 de 22 de Noviembre de 1989 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por 9 meses a contar del 18 de junio de 1989, el plazo otorgado a don Charles Edward Barter Orams, RUT No. 4.460.009-9, domiciliado en calle Luis Pasteur No. 6703, Santiago, para empezar a operar los establecimientos de cultivo autorizados por las Resoluciones No. 522 y No. 549, ambas de 1988, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8320298}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 22 de Noviembre de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8320299}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1795", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1795"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-11-22", "doble_articulado": false, "id_norma": "91437", "numero_fuente": "33545", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-12-13", "vigencias": [{"desde": "1989-12-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-12-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-12-13", "fin_vigencia": "", "tipo_version": "3"}], "event