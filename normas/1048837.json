{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA LISTA ANEXA QUE CONTIENE RESOLUCI&#xD3;N N&#xBA; 4 EXENTA, DE 2013</div></div>", "i": 9333550}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 19, del 12 de febrero de 2013, rectifica lista anexa que contiene <a href=\"https://www.leychile.cl/Navegar?idNorma=1047993&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 4 exenta, de 2013</a>.</div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta SII N&#xBA; 19, del 12 de febrero de 2013, se rectifica la lista anexa de valores de autom&#xF3;viles y otros veh&#xED;culos motorizados usados para el a&#xF1;o 2013 por contener errores en su emisi&#xF3;n.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en febrero de 2013.</div></div>", "i": 9333551}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "19 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-19 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "RECTIFICA LISTA ANEXA QUE CONTIENE RESOLUCIÓN Nº 4 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-02-12", "doble_articulado": false, "id_norma": "1048837", "numero_fuente": "40485", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-02-14", "vigencias": [{"desde": "2013-02-1