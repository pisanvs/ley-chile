{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6298790}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.716, de 30 de junio de 2000, se expropi&#xF3; el lote de terreno N&#xBA;5, superficie 143,5 m&#xB2;, sin rol de aval&#xFA;o, comuna de Quilicura, para la obra Camino Santiago - Colina - Los Andes, Sector Calle de Servicio Caupolic&#xE1;n, Regi&#xF3;n Metropolitana, y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Emilio del Carmen Villarroel Corro y Otros, ascendente a la cantidad total de $5.759.885.</div><br></div>", "i": 6298791}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6298792}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2716", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2716"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-06-30", "doble_articulado": false, "id_norma": "174890", "numero_fuente": "36754", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-01", "vigencias": [{"desde": "2000-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-09-06", "fecha_version": "2000-09-01", "fecha_actualizacion_texto": "2000-09-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "e