{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 32</div><br><div class=\"p\">Certifico que el Consejo de este Banco Central de Chile en su Sesi&#xF3;n No.32, celebrada el 31 de mayo de 1990, adopt&#xF3; los siguientes acuerdos:</div><br><div class=\"p\">32-12-900531 - Modifica Acuerdo No.1953-11-890816. </div></div>", "i": 8683506}, {"t": "<div><div class=\"p\">Se acord&#xF3; reemplazar, en el inciso segundo del n&#xFA;mero 8 del Acuerdo No.1953-11-890816, la frase &quot;...con pago en cupones (P.R.C.), a un plazo de 10 a&#xF1;os.&quot;, por &quot;(P.R.B.C.), a un plazo de un a&#xF1;o.&quot;.</div><br></div>", "i": 8683507}, {"t": "<div><div class=\"p\">Santiago, 31 de mayo de 1990.- V&#xED;ctor Vial del R&#xED;o, Secretario General Interino </div></div>", "i": 8683508}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "32", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-32"}, {"tipo": "5", "numero": "32-12", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-32-12"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO BANCO CENTRAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-05-31", "doble_articulado": false, "id_norma": "89507", "numero_fuente": "33684", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-06-01", "vigencias": [{"desde": "1990-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p