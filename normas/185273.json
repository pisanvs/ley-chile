{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6334791}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;378, de 29 de diciembre de 2000, se expropi&#xF3; el lote de terreno N&#xBA;9-1, superficie 183 m&#xB2;, rol de aval&#xFA;o 166-34, comuna de Colina, para la obra Camino Santiago-Colina-Los Andes. Sector San Jos&#xE9; Lo Pinto, Regi&#xF3;n Metropolitana y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Ricardo Segundo V&#xE1;squez L&#xF3;pez, ascendente a la cantidad de $1.287.447. </div></div>", "i": 6334792}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6334793}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "378", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-378"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-12-29", "doble_articulado": false, "id_norma": "185273", "numero_fuente": "36962", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-15", "vigencias": [{"desde": "2001-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2001-05-16", "fecha_version": "2001-05-15", "fecha_actualizacion_texto": "2001-05-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado