{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8303266}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 674, de 9 de mayo de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 1 de la Resoluci&#xF3;n N&#xBA; 165 de 1997, de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a ALIMENTOS MARINOS S.A., para operar por sustituci&#xF3;n la nave &quot;Quilpolemu&quot;, en el sentido de se&#xF1;alar que las naves sustitutas que entran a operar son once y no diez como all&#xED; se indica. </div></div>", "i": 8303267}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de mayo de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8303268}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "674", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-674"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "ALIMENTOS MARINOS S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-05-09", "doble_articulado": false, "id_norma": "73017", "numero_fuente": "35776", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-28", "vigencias": [{"desde": "1997-05-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-05-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICAC