{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.485 EXENTO, DE 23/09/2010</div></div>", "i": 9144827}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento que se indica del Ministerio de Educaci&#xF3;n, se aprueban las adecuaciones al plan y programas de estudio de la carrera de T&#xE9;cnico en Enfermer&#xED;a del Centro de Formaci&#xF3;n T&#xE9;cnica CEPONAL, que se encuentran anexas y forman parte del presente decreto. Modif&#xED;case, en consecuencia, el <a href=\"https://www.leychile.cl/Navegar?idNorma=181323&amp;idParte=0&amp;idVersion=\">decreto exento de Educaci&#xF3;n N&#xBA; 546 del 19 de diciembre de 2000</a>, en el sentido de incorporar dichas adecuaciones.</div><br><div class=\"p\">&nbsp; &nbsp;  Las adecuaciones que se aprueban mediante este decreto podr&#xE1;n aplicarse a contar del a&#xF1;o 2010.</div><br></div>", "i": 9144828}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de septiembre de 2010.- Fernando Rojas Ochagav&#xED;a, Subsecretario de Educaci&#xF3;n.</div></div>", "i": 9144829}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1485 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1485 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.485 EXENTO, DE 23/09/2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-09-23", "doble_articulado": false, "id_norma": "1025912", "numero_fuente": "39971", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-05-28", "vigencias": [{"desde": "2011-05-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vi