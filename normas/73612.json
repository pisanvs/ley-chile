{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO NUMERO 535 EXENTO, DE 1997 </div></div>", "i": 8303943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Supremo exento de Educaci&#xF3;n N&#xBA; 535 de 15 de mayo de 1997, se han aprobado a los Colegios &quot;Alliance Francaise&quot; de Chile: Lyc&#xE9;e Antoine de Saint-Exup&#xE9;ry de Santiago; Colegio Charles de Gaulle de Concepci&#xF3;n; Liceo de la Alianza Francesa Claude Gay de Osorno; Coll&#xE9;ge Alliance Francaise Jean Mermoz de Curic&#xF3;; y Coll&#xE9;ge Francaise de Valpara&#xED;so, el siguiente plan de estudio para 1&#xBA; a 5&#xBA; a&#xF1;o (NB.1, NB.2 y NB.3) de Ense&#xF1;anza B&#xE1;sica, el que se empezar&#xE1; a aplicar en 1997, de acuerdo al cronograma establecido en el art&#xED;culo 4&#xBA; del Decreto Supremo de Educaci&#xF3;n N&#xBA; 40 de 1996. </div></div>", "i": 8303944}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de mayo de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8303945}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "535 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-535 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO NUMERO 535 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIO ALLIANCE FRANCAISE", "LYCEE ANTOINE DE SAINT-EXUPERY", "SANTIAGO", "COLEGIO CHARLES DE GAULLE", "CONCEPCION", "LICEO DE LA ALIANZA FRANCESA CLAUDE GAY", "OSORNO", "COLLEGE ALLIANCE FRANCAISE JEAN  MERMOZ", "CURICO", "COLLEGE FRANCAISE", "VALPARAISO", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgaci