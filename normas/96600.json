{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8327637}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xBA;. 164 de 31 de Enero de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por 30 d&#xED;as a contar de la fecha de la presente resoluci&#xF3;n, el plazo concedido en el numeral 4&#xB0; de la resoluci&#xF3;n N&#xBA;. 1.463, de 1990, de esta Subsecretar&#xED;a por la cual se autoriz&#xF3; a don FERNANDO LEONARDO PINO MU&#xD1;OZ, R.U.T. N&#xBA;. 7.608.750-4, domiciliado en Oriente N&#xBA;. 6, Cartagena, para iniciar actividades pesqueras, por haberse acreditado la existencia de una fuerza mayor.</div><br></div>", "i": 8327638}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 31 de Enero de 1991.- Andr&#xE9;s Couve Rioseco Subsecretario de Pesca.</div><br></div>", "i": 8327639}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "164", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-164"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-01-31", "fecha_derogacion": "1996-06-17", "doble_articulado": false, "id_norma": "96600", "numero_fuente": "33900", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-02-21", "vigencias": [{"desde": "1996-06-17", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1991-02-21", "hasta": "1996-06-16", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1996-06-17", "fin_vigenci