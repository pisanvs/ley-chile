{"html": [{"t": "<div><div class=\"p\">RECTIFICACION</div><br><br></div>", "i": 6420072}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA; 37.529, de fecha 7 de abril de 2003, se public&#xF3; el Acuerdo N&#xBA; 1053-02-030403 &quot;Modifica el Compendio de Normas Financieras&quot; con el error que se salva a continuaci&#xF3;n:</div><br><div class=\"p\">En la p&#xE1;gina 5, segunda columna:</div><br><div class=\"p\">Donde dice:&nbsp; &quot;Se acord&#xF3; lo siguiente:&quot;</div><div class=\"p\">Debe decir:&nbsp; &quot;Se acord&#xF3; efectuar, a contar del 5 de</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  mayo de 2003, las siguientes</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  modificaciones en el Compendio de Normas</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Financieras:&quot;</div><br></div>", "i": 6420073}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de abril de 2003.- Jorge Court Larenas, Ministro de Fe (S).</div><br></div>", "i": 6420074}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "AVI-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "RECTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-04-09", "doble_articulado": false, "id_norma": "209149", "numero_fuente": "37532", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-04-10", "vigencias": [{"desde": "2003-04-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-04-10", "fin_vigencia": ""}, "vigenc