{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SUPRIME EL INCISO 5.o DEL ARTICULO 3.o DEL CODIGO DE MINERIA</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5962471}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Supr&#xED;mese el inciso 5.o del</div><div class=\"p\">art&#xED;culo 3.o del C&#xF3;digo de Miner&#xED;a, aprobado por Decreto Ley N.o 488, de 24 de Agosto de 1932.</div><div class=\"p\">&nbsp; &nbsp; La presente Ley regir&#xE1; desde su publicaci&#xF3;n en el Diario Oficial&quot;.</div><br></div>", "i": 5962472}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y, por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintid&#xF3;s de Diciembre de mil novecientos treinta y seis.- ARTURO ALESSANDRI.- Luis Alamos B.</div><br></div>", "i": 5962473}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "5965", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-5965"}], "organismos": ["MINISTERIO DE FOMENTO"], "titulo_norma": "SUPRIME EL INCISO 5.o DEL ARTICULO 3.o DEL CODIGO DE\nMINERIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PERTENENCIA MINERA", "TERRENOS", "ERIALES FISCALES", "NACIONALES USO PUBLICO", "MUNICIPALES", "CONSTRUCCION", "DEROGACION", "CODIGO MINERIA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1936-12-22", "doble_articulado": false, "id_norma": "25247", "numero_fuente": "17652", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion":