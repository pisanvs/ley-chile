{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8298876}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 2.093, de 11 de diciembre de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xB0; 287, de 1982, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA IQUIQUE S.A., hoy Pesquera Iquique-Guanaye S.A., para ampliar actividades pesqueras extractivas con las naves &quot;Eperva 37&quot; y &quot;Eperva 38&quot;, por haberse configurado la causal prevista en el art&#xED;culo 143 letra b) de la Ley N&#xB0; 18.892 y sus modificaciones.</div><br></div>", "i": 8298877}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 11 de diciembre de 1996.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8298878}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2093", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2093"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "PESQUERA IQUIQUE S.A", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-12-11", "doble_articulado": false, "id_norma": "37670", "numero_fuente": "35645", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-12-19", "vigencias": [{"desde": "1996-12-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-12-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-12-19", "fin_vigencia": "