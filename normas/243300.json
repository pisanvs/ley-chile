{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6545478}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.141, de 27 de septiembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a COOPERATIVA DE DESARROLLO PRODUCTIVO, TURISTICO, EDUCACIONAL Y DE MEDIO AMBIENTE para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en G&#xF3;mez Carre&#xF1;o s/n, Puerto Aguirre, comuna de Ays&#xE9;n, XI Regi&#xF3;n, donde podr&#xE1; elaborar, en las l&#xED;neas de proceso de Cocido, Fresco enfriado, Fresco refrigerado, Congelado y Seco salado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6545479}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de septiembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6545480}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3141 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3141 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-27", "doble_articulado": false, "id_norma": "243300", "numero_fuente": "38298", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-10-28", "vigencias": [{"desde": "2005-10-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-10-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-10-28", "fin_vigencia": "", "tipo_v