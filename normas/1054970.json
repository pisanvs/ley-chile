{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N N&#xBA; 2.345 EXENTA, DE 2013</div></div>", "i": 9377014}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.510, de 9 de septiembre de 2013, de esta Subsecretar&#xED;a, rectif&#xED;case la resoluci&#xF3;n exenta N&#xBA; 2.345, de 2013, que modific&#xF3; la resoluci&#xF3;n exenta N&#xBA; 2.276, de 2012, ambas de esta Subsecretar&#xED;a, en el sentido de reemplazar el nombre del proyecto por el siguiente: &quot;Monitoreo de fauna acu&#xE1;tica en aguas continentales de Chile, entre la XV y XI Regiones&quot;.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en el sitio de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura.</div></div>", "i": 9377015}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de septiembre de 2013.-&nbsp; Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9377016}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2510 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2510 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "RECTIFICA RESOLUCIÓN Nº 2.345 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-09-09", "doble_articulado": false, "id_norma": "1054970", "numero_fuente": "40677", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-10-08", "vigencias": [{"desde": "2