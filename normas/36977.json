{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.438, de 2 de agosto de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, rectif&#xED;case la Resoluci&#xF3;n N&#xB0; 1.195, de 1996, de esta Subsecretar&#xED;a, que fij&#xF3; la n&#xF3;mina de armadores y naves habilitados para operar en la unidad de pesquer&#xED;a de Jurel, Trachurus murphyi, de V a la IX Regi&#xF3;n, se&#xF1;alada en la letra d) del Art&#xED;culo 1&#xB0; del Decreto N&#xB0; 354, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, en el sentido de eliminar de dicho listado a la nave &quot;Mar Rojo&quot;, de EMPRESA PESQUERA EPERVA S.A., la cual fue sustituida por Resoluci&#xF3;n N&#xB0; 1.808 de 1995, de esta Subsecretar&#xED;a.</div><br></div>", "i": 8297383}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 2 de agosto de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297384}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1438", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1438"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMINA ARMADORES", "JUREL", "RECTIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-08-02", "fecha_derogacion": "1997-01-14", "doble_articulado": false, "id_norma": "36977", "numero_fuente": "35539", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-08-10", "vigencias": [{"desde": "1997-01-