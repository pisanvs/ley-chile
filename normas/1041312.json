{"html": [{"t": "<div><br><div class=\"p\">SOLICITA CONSTITUCI&#xD3;N DE PARTIDO PROGRESISTA EN V REGI&#xD3;N DE VALPARA&#xCD;SO</div></div>", "i": 9269050}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Marco Enr&#xED;quez-Ominami Gumucio y Cristian Warner Villagr&#xE1;n, Presidente y Secretario General de la Directiva Central del Partido Progresista, han solicitado la constituci&#xF3;n legal del partido en la V Regi&#xF3;n de Valpara&#xED;so. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de cuatro mil quinientos diez (4.510) afiliaciones.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xBA; de la ley N&#xBA; 18.603, por resoluci&#xF3;n O-N&#xBA; 1.052, de fecha 25 de mayo de 2012.- </div></div>", "i": 9269051}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div></div>", "i": 9269052}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1052", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1052"}, {"tipo": "3", "numero": "O-1052", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-1052"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCIÓN DE PARTIDO PROGRESISTA EN V REGIÓN DE VALPARAÍSO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-25", "doble_articulado": false, "id_norma": "1041312", "numero_fuente": "40297", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-26", "vigencias": [{"desde": "2012-06-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"ini