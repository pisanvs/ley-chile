{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 540 EXENTO, DE 1998</div><br><br><br></div>", "i": 6134117}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 540, de 27 de abril de 1998, se ha autorizado al Colegio Sagrado Coraz&#xF3;n de Talagante, para modificar el actual plan de estudio de los cursos de 7&#xBA; y 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica regidos por el decreto supremo de Educaci&#xF3;n N&#xBA; 4.002 de 1980 y sus modificaciones, eliminando las 2 clases semanales de la asignatura de Idioma Extranjero 2: Franc&#xE9;s, y agregando 2 clases m&#xE1;s a la asignatura de Idioma Extranjero 1: Ingl&#xE9;s, a partir del a&#xF1;o escolar 1998, en ambos cursos. </div></div>", "i": 6134118}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 6 de mayo de 1998.- Juan Eduardo Garc&#xED;a-Huidobro S., Subsecretario de Educaci&#xF3;n (S). </div></div>", "i": 6134119}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "540 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-540 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 540 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "COLEGIO SAGRADO CORAZON DE TALAGANTE", "MODIFICACION", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-05-06", "doble_articulado": false, "id_norma": "125597", "numero_fuente": "36182", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-10-07", "vigencias": [{"desde": "1998-10-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-10-0