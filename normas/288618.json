{"html": [{"t": "<div><br><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A ALIMENTOS Y FRUTOS S.A.</div></div>", "i": 8505811}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Grandes Contribuyentes del SII, por Res. Ex. DGC 17.100 N&#xBA; 56/09, de fecha 06.03.2009, revoca a Alimentos y Frutos S.A., RUT. N&#xBA; 96.557.910-9, a partir del d&#xED;a 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las ventas de legumbres, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 17 de la Res. Ex. N&#xBA; 5.280, del 30 de noviembre de 2000, de la Direcci&#xF3;n Nacional.- </div></div>", "i": 8505812}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Bernardo Marchant &#xC1;guila, Director Grandes Contribuyentes.</div></div>", "i": 8505813}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "56", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolucion-56"}, {"tipo": "3", "numero": "56/09", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolucion-56/09"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL", "DIRECCIÓN GRANDES CONTRIBUYENTES"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A ALIMENTOS Y FRUTOS S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-03-06", "doble_articulado": false, "id_norma": "288618", "numero_fuente": "39329", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-04-03", "vigencias": [{"desde": "2009-04-03", "hasta": "", "tipo_version": "3", "tipo_version_s