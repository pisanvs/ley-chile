{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Adoquinado de calles i construccion de aceras en Vallenar i Chillan</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,320.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274256}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Hacense estensivas a las ciudades de Vallenar i de Chill&#xE1;n las disposiciones de las leyes 11 de Septiembre de 1879</div><div class=\"p\">&nbsp; &nbsp; i lei n&#xFA;m. 1,145 de 9 de Enero de 1899, relativas al adoquinado de calles i construcciones de aceras en la ciudad de Concepcion.</div><br><br></div>", "i": 8274257}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, pido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 18 de Enero de 1900.- FEDERICO ERRAZURIZ._ Elias Fern&#xE1;ndez A.</div><br></div>", "i": 8274258}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1320", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1320"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "ADOQUINADO DE CALLES I CONSTRUCCIÓN DE ACERAS EN VALLEENAR I CHILLAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VALLENAR", "CHILLAN", "ACERAS", "CONSTRUCCION", "ADOQUINADO", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-01-18", "doble_articulado": false, "id_norma": "22554", "numero_fuente": "6499", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-01-18", "vigencia