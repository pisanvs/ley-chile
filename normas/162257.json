{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION N&#xB0; 305 DE 12 DE SEPTIEMBRE DE 1985 </div></div>", "i": 6254768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 305 de 12 de septiembre de 1985 se ha procedido a aclarar la forma de aplicaci&#xF3;n del decreto supremo exento de Educaci&#xF3;n N&#xB0; 107 de 1983, que autoriz&#xF3; adecuaci&#xF3;n al plan de estudio vigente a Saint Gabriel&apos;s English School, de Santiago, en el sentido de que debi&#xF3; aplicarse desde 1983 en lo y 2&#xB0; a&#xF1;o medio, simult&#xE1;neamente.</div><br></div>", "i": 6254769}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de Septiembre de 1985. Ren&#xE9; Salam&#xE9; Mart&#xED;n, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6254770}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "305 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-305 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION N° 305 DE 12 DE SEPTIEMBRE DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-09-12", "doble_articulado": false, "id_norma": "162257", "numero_fuente": "32285", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-10-01", "vigencias": [{"desde": "1985-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-10-01", "fin_vigencia": "", "tipo_v