{"html": [{"t": "<div><div class=\"p\">LEY NUM. 16.763</div><br><div class=\"p\">MODIFICA LA LEY NUMERO 15.402, DE 1964</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6501130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Reempl&#xE1;zanse en la ley n&#xFA;mero 15.402, de 4 de Enero de 1964, las palabras &quot;ciento cincuenta escudos (E&#xBA; 150,-)&quot; por &quot;trescientos escudos&quot;. </div></div>", "i": 6501131}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a cuatro de Marzo de mil novecientos sesenta y ocho.- EDUARDO FREI MONTALVA.- Ra&#xFA;l S&#xE1;ez S.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a U. para su conocimiento.- Dios guarde a U.- Jos&#xE9; F. Guzm&#xE1;n C.</div><br></div>", "i": 6501132}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "16763", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-16763"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA LA LEY NUMERO 15.402, DE 1964", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1968-03-04", "doble_articulado": false, "id_norma": "231418", "numero_fuente": "26993", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1968-03-14", "vigencias": [{"desde": "1968-03-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia":