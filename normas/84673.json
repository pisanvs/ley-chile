{"html": [{"t": "<div><div class=\"p\">PRORROGA PLAZO QUE INDICA </div></div>", "i": 8316540}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 440 de 09 de Marzo de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por el t&#xE9;rmino de 30 d&#xED;as a contar del 06 de Marzo de 1990, el plazo otorgado por la Resoluci&#xF3;n No. 196 de 1990 a don Fernando Amador Landeta Ahues, domiciliado en Prat 620, 2&#xB0;. Piso Valpara&#xED;so, para publicar el extracto a que se tefiere el numeral No. 4 de la resoluci&#xF3;n citada, por haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8316541}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 09 de Marzo de 1990. - Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8316542}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "440", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-440"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA PLAZO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-09", "doble_articulado": false, "id_norma": "84673", "numero_fuente": "33634", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-30", "vigencias": [{"desde": "1990-03-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-03-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-03-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFI