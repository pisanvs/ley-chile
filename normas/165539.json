{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6264951}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 806, de fecha 18 de Noviembre de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a Ren&#xE9; Johns Duarte y Juan Esteban Ibarra Vera, para efectuar todo tipo de servicios do transporte de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6264952}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, Noviembre 22 de 1985. Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana. </div></div>", "i": 6264953}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "806 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-806 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-11-18", "doble_articulado": false, "id_norma": "165539", "numero_fuente": "32349", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-17", "vigencias": [{"desde": "1985-12-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-12-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985