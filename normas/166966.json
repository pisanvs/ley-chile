{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.917, DE 1987 </div></div>", "i": 6269712}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.917, de fecha 27 de Agosto de 1987, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se modific&#xF3; el art. 1&#xB0; de la resoluci&#xF3;n exenta de Educaci&#xF3;n No. 2.918 de 1982 del Centro de Formaci&#xF3;n T&#xE9;cnica INCACEA, en el sentido de reemplazar las redes secuenciales de asignaturas de las carreras que a continuaci&#xF3;n se indican, a partir del a&#xF1;o 1986:</div><div class=\"p\">- Dise&#xF1;o y Confecci&#xF3;n de Vestuario.</div><div class=\"p\">- Dise&#xF1;o, Construcci&#xF3;n y Decoraci&#xF3;n de Interiores.</div><div class=\"p\">- Dise&#xF1;o Gr&#xE1;fico y Publicitario.</div><div class=\"p\">- Direcci&#xF3;n y Producci&#xF3;n de Televisi&#xF3;n.</div><br></div>", "i": 6269713}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6269714}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1917 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1917 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.917, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-27", "doble_articulado": false, "id_norma": "166966", "numero_fuente": "32894", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-10-15", "vigencias": [{"desde": "1987-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ú