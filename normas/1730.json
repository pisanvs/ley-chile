{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; TASA DE INTERES PROMEDIO (TIP) QUINCENAL DE CAPTACION PARA OPERACIONES REAJUSTABLES ENTRE 90 y 365 DIAS </div></div>", "i": 7104566}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de marzo de 1993, fue de 6,41% anual.</div><br></div>", "i": 7104567}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 19 de marzo de 1993.- Jorge Carrasco V&#xE1;squez, Ministro de Fe (I).</div><br></div>", "i": 7104568}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "TASA DE INTERES PROMEDIO (TIP) QUINCENAL DE CAPTACION PARA OPERACIONES REAJUSTABLES ENTRE 90 Y 365 DIAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA INTERES PROMEDIO", "TIP", "OPERACIONES CREDITO DINERO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-03-19", "doble_articulado": false, "id_norma": "1730", "numero_fuente": "34521", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-03-20", "vigencias": [{"desde": "1993-03-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-03-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-03-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fe