{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; TRASPASA LA SUMA QUE INDICA DEL ITEM 07/02/01 AL ITEM 04/04/04/j) DE LA LEY DE PRESUPUESTO VIGENTE Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5974095}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Trasp&#xE1;sase la suma de cuatrocientos mil escudos (E&#xB0; 400.000) del &#xED;tem 07/02/01 al &#xED;tem 04/04/04/j) de la ley de Presupuesto vigente.&quot; </div></div>", "i": 5974096}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veinticuatro de Diciembre de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- Eduardo Figueroa G.</div><br></div>", "i": 5974097}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14502", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14502"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "TRASPASA LA SUMA QUE INDICA DEL ITEM 07/02/01 AL\nITEM 04/04/04/j) DE LA LEY DE PRESUPUESTO VIGENTE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O 1960", "MODIFICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-12-21", "doble_articulado": false, "id_norma": "27738", "numero_fuente": "24825", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-12-22", "vigencias": [{"desde": "1960-12-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1960-12-22", "fin_vigencia": ""}, "vige