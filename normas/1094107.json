{"html": [{"t": "<div><br><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA</div></div>", "i": 9725440}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional de Temuco del Servicio de Impuestos Internos, por resoluci&#xF3;n Ex. N&#xBA; 77316062064, de 17/08/2016, deja sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=219762&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n Ex. N&#xBA; 395, de fecha 10.12.2003</a>, que otorga la calidad de agente retenedor de cambio de sujeto de derecho del Impuesto al Valor Agregado en los contratos de instalaci&#xF3;n o confecci&#xF3;n de especialidades, a contar de la fecha de la publicaci&#xF3;n de su extracto en el Diario Oficial al contribuyente Jaime Fernando Pancracio Cordero Cuevas, RUT N&#xBA; 5.854.831-6, conforme a lo establecido en la resoluci&#xF3;n Ex. N&#xBA; 142, de fecha 26.12.2005, de la Direcci&#xF3;n Nacional del Servicio de Impuestos Internos.- </div><br></div>", "i": 9725441, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lidia Castillo Alarc&#xF3;n, Directora Regional. </div></div>", "i": 9725442}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "77316062064 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-77316062064 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1105379; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-08-17", "doble_articulado": false, "id_norma": "1094107", "numero_fuente": "41546", "tipo_version": "3", "tipo_ver