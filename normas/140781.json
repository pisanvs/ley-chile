{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8348097}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.546, de 11 de agosto de 1999, de esta Subsecretar&#xED;a, modif&#xED;case la resoluci&#xF3;n N&#xBA; 3 de 1999, que declar&#xF3; la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.240 de 1994, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA ITATA S.A. para operar la nave &apos;&apos;Allip&#xE9;n I&apos;&apos;, en el sentido de se&#xF1;alar que la caducidad se refiere solamente al recurso hidrobiol&#xF3;gico Jurel, Trachurus murphyi, en el litoral de la III y IV Regiones.</div><br></div>", "i": 8348098}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de agosto de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8348099}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1546", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1546"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-08-11", "fecha_derogacion": "2011-03-24", "doble_articulado": false, "id_norma": "140781", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-08-19", "vigencias": [{"desde": "2011-03-24", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-08-19", "hasta": "2011-03-23", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2011-03-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-08-19", "fin_vigen