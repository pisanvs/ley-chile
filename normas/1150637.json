{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10166954}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta 2.047, de 29 de septiembre 2020, Serviu Regi&#xF3;n del Biob&#xED;o orden&#xF3; expropiaci&#xF3;n parcial de un inmueble ubicado en Collao 1659, Rol de Aval&#xFA;o N&#xB0; 320-27, comuna de Concepci&#xF3;n, de aparente dominio de C&#xED;a de Petr&#xF3;leos de Chile COPEC, en una superficie de 799,55 m2 de terreno, dentro de pol&#xED;gono y linderos se&#xF1;alados plano de expropiaci&#xF3;n S8R-38.450-2, para la ejecuci&#xF3;n de las obras del proyecto &quot;Mejoramiento Par Vial Collao/General Novoa, comuna de Concepci&#xF3;n&quot;, conforme art&#xED;culo 51 ley N&#xB0; 16.391 y DL N&#xB0; 2.186. Comisi&#xF3;n Peritos integrada por arquitecto Claudia Marzullo Garc&#xED;a, arquitecto Daniela Cortez Moraga y arquitecto Priscilla Encalada Rueda, seg&#xFA;n informe de fecha 22 de julio 2020, fij&#xF3; monto provisional indemnizaci&#xF3;n, m&#xE1;s reajuste del art&#xED;culo 5&#xB0; DL 2.186, en $152.435.998, pagadera de contado.- </div></div>", "i": 10166955}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director (S) Serviu Regi&#xF3;n del Biob&#xED;o.</div><div class=\"p\"> </div><br></div>", "i": 10166956}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2047 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2047 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1827155", "EXTRACTO"], "derogac