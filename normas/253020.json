{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.112 EXENTA, DE 2006 </div></div>", "i": 6582028}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.112, de fecha 17 de julio de 2006, de Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se revoca el reconocimiento oficial otorgado a la Escuela de Conductores Profesionales &quot;Sociedad Nacional de Due&#xF1;os de Escuelas de Conductores S.A.&quot; o &quot;Sondec S.A.&quot;, mediante resoluci&#xF3;n exenta N&#xBA;633, de 26 de julio de 2000, de la misma Secretar&#xED;a Regional, en la sede de Av. Irarr&#xE1;zaval N&#xBA;2051, comuna de &#xD1;u&#xF1;oa. </div></div>", "i": 6582029}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Pablo Rodr&#xED;guez Olivares, Secretario Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6582030}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1112 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1112 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.112 EXENTA, DE 2006", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-17", "doble_articulado": false, "id_norma": "253020", "numero_fuente": "38559", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-09-07", "vigencias": [{"desde": "2006-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia":