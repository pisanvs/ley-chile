{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8344380}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 691, de 22 de abril de 1999, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 993 de 1992, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD PROCESADORA DE ALIMENTOS SOCOVEL LIMITADA, para iniciar actividades pesqueras extractivas con la nave &apos;&apos;Oficina California&apos;&apos;, s&#xF3;lo en lo relativo&nbsp; a los recursos Anchoveta, Bonito, Caballa, Cojinoba del norte, Jurel, Machuelo o tritre, Palometa, Sardina espa&#xF1;ola, Sardina com&#xFA;n, en el litoral de la III y IV Regiones, con red de cerco.</div><br></div>", "i": 8344381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de abril de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8344382}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "691", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-691"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-04-22", "doble_articulado": false, "id_norma": "135698", "numero_fuente": "36351", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-04-29", "vigencias": [{"desde": "1999-04-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-04-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-04-29", "fin_vigencia": "", "tipo_version": "3"}], "e