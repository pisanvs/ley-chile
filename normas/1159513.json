{"html": [{"t": "<div><div class=\"p\">OFICIALES DEL EXTERIOR.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Abril 17 de 1830.</div></div>", "i": 10250241}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Aprobadas por decreto de esta fecha las propuestas hechas por el Ministerio de Relaciones Exteriores de los oficiales de que debe componerse este departamento, vengo en nombrar y clasificar por tales oficiales a los siguientes: para oficial primero a don Juan Ramon Casanova, con el sueldo anual de mil doscientos pesos: para oficial segundo a don Domingo Acevedo, con el de setecientos pesos anuales. </div></div>", "i": 10250242}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, declar&#xE1;ndose que las asignaciones relacionadas deben correr y abonarse desde el dia de la fecha.</div><br><div class=\"p\">&nbsp; &nbsp;  OVALLE.</div><div class=\"p\">&nbsp; &nbsp;  Portales.</div></div>", "i": 10250243}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "OFICIALES DEL EXTERIOR.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1830-04-17", "doble_articulado": false, "id_norma": "1159513", "numero_fuente": "1830", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1830-04-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1830-04-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1830-04-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [