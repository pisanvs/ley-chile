{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 72.- Santiago, 8 de Agosto de 1893.- Por cuanto el Congreso Nacional ha aprobado el siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6169958}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al condestable 1.&#xBA; de la Armada Nacional don Manuel Torres el abono de tiempo que necesita para completar veinticinco a&#xF1;os de servicios.</div><br></div>", "i": 6169959}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, o&#xED;do el Consejo de Estado, he tenido &#xE1; bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese &#xE1; efecto como ley de la Rep&#xFA;blica.- JORGE MONTT.- Vicente D&#xE1;vila Larrain.</div><br></div>", "i": 6169960}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "72", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-72"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MANUEL TORRES", "ARMADA DE CHILE", "TIEMPO", "ABONO", "JUBILACION", "GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-08-08", "doble_articulado": false, "id_norma": "136815", "numero_fuente": "4593", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-08-11", "vigencias": [{"desde": "1893-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-08-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-08-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso