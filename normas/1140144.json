{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 5.607 EXENTA, DE 2019</div></div>", "i": 10080181}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por la resoluci&#xF3;n exenta N&#xBA; 5.607, de 05.12.2019, del Director Nacional de Aduanas, teniendo presentes los art&#xED;culos 4 y 39 de la ley N&#xBA; 19.913 en relaci&#xF3;n al art&#xED;culo 4 N&#xBA; 7 del decreto con fuerza de ley N&#xBA; 329, se imparten instrucciones respecto de la retenci&#xF3;n y aplicaci&#xF3;n de multas, de las declaraciones de porte y transporte de moneda en efectivo o instrumentos negociables al portador.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).- </div><br></div>", "i": 10080182}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><br></div>", "i": 10080183}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5607 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5607 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 5.607 EXENTA, DE 2019", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1698215; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-12-05", "doble_articulado": false, "id_norma": "1140144", "numero_fuente": "42531", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-12-18", "vigencias": [{"desde": "2019-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_