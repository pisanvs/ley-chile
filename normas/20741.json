{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 231 EXENTO, DE 1994 </div></div>", "i": 5942971}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 231 de 30 de mayo de 1994, se ha autorizado al Colegio &quot;Scuola Italiana Vittorio Montiglio&quot; de Santiago, para agregar asignatura de Computaci&#xF3;n al plan de estudio de 5&#xB0; a&#xF1;o b&#xE1;sico, con una carga horaria de dos clases semanales.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa de Computaci&#xF3;n para el citado curso.</div><br></div>", "i": 5942972}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 15 de Junio de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5942973}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "231", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-231"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 231 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO SCUOLA ITALIANA VITTORIO MONTIGLIO", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-05-30", "doble_articulado": false, "id_norma": "20741", "numero_fuente": "34907", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-07-06", "vigencias": [{"desde": "1994-07-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-07-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-07-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion