{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6700175}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Acuerdo N&#xBA; 5: Por unanimidad de los se&#xF1;ores Concejales presentes se acuerda aprobar la modificaci&#xF3;n del &quot;Plano Seccional Zona de Conservaci&#xF3;n Hist&#xF3;rica Sector Centro de Coquimbo&quot;, con el fin de continuar con la tramitaci&#xF3;n de ser publicado en el Diario Oficial y archivarlo en el Conservador de Bienes Ra&#xED;ces de Coquimbo.</div><div class=\"p\">&nbsp; &nbsp;  Votan a favor el Se&#xF1;or Alcalde y los Concejales Se&#xF1;or Ram&#xF3;n Vel&#xE1;squez Seguel, Se&#xF1;or Oscar Pereira Tapia, Se&#xF1;or Abd&#xF3;n Hermosilla Cort&#xE9;s, Se&#xF1;or Carlos Yusta Rojas, Srta. Nelsa Pi&#xF1;ones Rivera y Srta. Mabel Rojas Valdivia. </div></div>", "i": 6700176}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Saluda atentamente a Ud., Roberto Valenzuela Galleguillos, Secretario Municipal (S).</div><br></div>", "i": 6700177}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "5", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-5"}], "organismos": ["MUNICIPALIDAD DE COQUIMBO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANO SECCIONAL ZONA DE CONSERVACION HISTORICA", "COQUIMBO", "SECTOR CENTRO DE COQUIMBO", "ACUERDO MUNICIPAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "252660", "numero_fuente": "38551", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-08-29", "vigencias": [{"desde": "2006-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-08-29", "fin_vigencia": ""}, "v