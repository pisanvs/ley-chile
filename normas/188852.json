{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6347398}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.647, de 3 de agosto de 2001, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA SILGAR LIMITADA, para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluci&#xF3;n N&#xBA; 2.521 de 2000, de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Ruta 5, Sector Puranqui s/n, Ancud, Chilo&#xE9;, X Regi&#xF3;n, en las l&#xED;neas de proceso de Seco-salado y Deshidratado, el recurso hidrobiol&#xF3;gico Erizo.</div><div class=\"p\">&nbsp; &nbsp;  La materia prima deber&#xE1; provenir de pescadores artesanales, debidamente autorizados.</div><br></div>", "i": 6347399}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de agosto de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6347400}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1647", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1647"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-08-03", "doble_articulado": false, "id_norma": "188852", "numero_fuente": "37046", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-08-25", "vigencias": [{"desde": "2001-08-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-08-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-08-25", "fin_vigencia": "