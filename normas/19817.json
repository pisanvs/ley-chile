{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO NUMERO 34 EXENTO, DE 1994 </div></div>", "i": 5940012}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 34 de fecha 27 de Enero de 1994 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Escuela Superior de Administraci&#xF3;n de Negocios del Norte - Esane del Norte las adecuaciones introducidas al plan y programas de estudio de la carrera de Turismo y Hoteler&#xED;a, las que se insertaron en la Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xB0; 1.019 de 1985 y N&#xB0; 3.350 de 1986. Dichas adecuaciones podr&#xED;an aplicarse a contar de agosto de 1993.</div><br></div>", "i": 5940013}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 30 de Marzo de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5940014}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "34", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-34"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO NUMERO 34 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA", "ESCUELA SUPERIOR ADMINISTRACION NEGOCIOS NORTE", "ESANE NORTE", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-01-27", "fecha_derogacion": "2020-12-16", "doble_articulado": false, "id_norma": "19817", "numero_fuente": "34844", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-04-20", "vigencias": [{"desde": "2020-12-16", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1994-04-20", "hasta": "