{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6012814}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 814 de 2 de Septiembre de 1994 de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xB0; 2.186, de 1978, de parte del inmueble ubicado en sector prolongaci&#xF3;nde calles Monse&#xF1;or Larra&#xED;n y Trebulco, presunto rol de aval&#xFA;os N&#xB0; 513-182 comuna de Talagante, aparente dominio de don Aurelio Pichilef Pichilef, con una superficie aproximada de 13.685,50 m2. Comisi&#xF3;n integrada por peritos Sres. Jos&#xE9; Miguel Haltenhoff Aenishanslin, constructor civil, Ram&#xF3;n Undurraga Montes, ingeniero civil y Ren&#xE9; Ureta Koster, arquitecto, seg&#xFA;n informe de 14 de Julio de 1994, fij&#xF3; monto proivicional indemnizaci&#xF3;n en $18.270.143.- pagadera al contado.-</div><br></div>", "i": 6012815}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director SERVIU Metropolitano.</div><br></div>", "i": 6012816}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "814", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-814"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "BIEN RAIZ", "TALAGANTE", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-09-02", "doble_articulado": false, "id_norma": "35629", "numero_fuente": "34980-2", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-10-01", "vigencias": [{"desde": "1994-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-10-01", "fin_vigencia": "