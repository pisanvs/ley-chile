{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10341680}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xBA;274, de 11 marzo 2022, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos relativas a la actividad denominada &quot;Aniversario de la Segunda Compa&#xF1;&#xED;a de Bomberos de Coyhaique&quot;, y autoriz&#xF3; a la Segunda Compa&#xF1;&#xED;a Bomba Espa&#xF1;a de Coyhaique, para realizar la siguiente intervenci&#xF3;n en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - Corte de calle que comprende Magallanes entre Avenida Simpson y Lautaro desde las 19:30 a las 22:30 hrs., el d&#xED;a 12 de marzo de 2022.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10341681}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andrea Mac&#xED;as Palma, Gobernadora Regional, Gobierno Regional de Ays&#xE9;n.- Javier Gonz&#xE1;lez Jara, Jefe Unidad Jur&#xED;dica, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10341682}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "274 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-274 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2142480", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-03-11", "doble_articulado": false, "id_norma": "1177447", "numero_fuente": "43278", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-06-14", "vigencias": [{"desde": "2022-06-14", "hasta": "", "tipo_version": "3", "tipo_ve