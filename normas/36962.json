{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;PARTIDO COMUNISTA DE CHILE&quot; </div></div>", "i": 6016688}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Gladys Mar&#xED;n Millie y Lautaro Carmona Soto, Presidente y Secretario General, respectivamente, en representaci&#xF3;n del &quot;Partido Comunista de Chile&quot;, han solicitado la constituci&#xF3;n legal del partido en las Regiones I de Tarapac&#xE1; y II de Antofagasta, acompa&#xF1;ando las siguientes cantidades de afiliaciones.</div><div class=\"p\"> I Regi&#xF3;n&nbsp; &nbsp; &nbsp;  1.035</div><div class=\"p\"> II Regi&#xF3;n&nbsp; &nbsp; &nbsp; 1.231</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la Ley N&#xB0; 18.603, por Resoluci&#xF3;n O-N&#xB0; 1.433 de fecha 4 de Diciembre de 1995.</div><br></div>", "i": 6016689}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 4 de Diciembre de 1995.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6016690}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1433", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1433"}, {"tipo": "3", "numero": "O-1433", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-1433"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO COMUNISTA DE CHILE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDO COMUNISTA CHILE", "PRIMERA REGION", "SEGUNDA", "REGION", "PARTIDOS POLITICOS", "INSCRIPCION", "REGISTRO", "PARTIDOS POLITICOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-12-04", "doble_articulado": false, "id_norma": "36962", "numero_fuente": "35344", "tipo_version"