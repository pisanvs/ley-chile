{"html": [{"t": "<div><div class=\"p\">AUTORIZA EMISOR DE BOLETAS ELECTR&#xD3;NICAS </div></div>", "i": 7359997}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 145, de 30 de noviembre de 2007, que autoriza a contribuyente como emisor de boletas electr&#xF3;nicas.</div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de boletas electr&#xF3;nicas a contribuyente RUT 99.513.400-4, a contar del mes de diciembre de 2007.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de noviembre de 2007. </div></div>", "i": 7359998}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "145 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-145 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISORES ELECTRÓNICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-11-30", "doble_articulado": false, "id_norma": "267270", "numero_fuente": "38930", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-06", "vigencias": [{"desde": "2007-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-12-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-12-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":