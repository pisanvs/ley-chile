{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7293002}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.358 de 2 de julio de 2002 de esta Subsecretar&#xED;a, autor&#xED;zase a FABRICA DE HARINA DE PESCADO LIMITADA para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluci&#xF3;n N&#xBA; 203 de 1996, de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Avenida Matta N&#xBA; 203, Lota, VIII Regi&#xF3;n, en las l&#xED;neas de procesos que se indica, los siguientes recursos hidrobiol&#xF3;gicos: Harina y Aceite: Bacaladillo o mote, Jurel fino, Machuelo o tritre, Anchoveta blanca, Sardina redonda, Vinciguerria. </div></div>", "i": 7293003}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de julio de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7293004}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1358", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1358"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-07-02", "fecha_derogacion": "2004-10-02", "doble_articulado": false, "id_norma": "200741", "numero_fuente": "37317", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-07-25", "vigencias": [{"desde": "2004-10-02", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2002-07-25", "hasta": "2004-10-01", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2004