{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Crea cargo Secretario General Gobierno</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 73.- Santiago, 23 de Junio de 1932.-</div><div class=\"p\">&nbsp; &nbsp; La Junta de Gobierno ha acordado y dicta el siguiente</div><div class=\"p\">&nbsp; &nbsp; Decreto-ley:</div><br></div>", "i": 9035023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Cr&#xE9;ase el cargo de Secretario General de Gobierno, sin perjuicio de las funciones que corresponden al Secretario General de la Junta de Gobierno.</div><div class=\"p\">&nbsp; &nbsp; Dicho cargo no tendr&#xE1; remuneraci&#xF3;n.</div><br></div>", "i": 9035024}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de Leyes y Decretos del Gobierno.- CARLOS DAVILA.- A. Cabero.- Nolasco C&#xE1;rdenas.- Juan Antonio R&#xED;os M.</div><br></div>", "i": 9035025}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "73", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-73"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CREA EL CARGO DE SECRETARIO GENERAL DE GOBIERNO.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SECRETARIO GENERAL GOBIERNO", "CARGO", "CREACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-06-23", "doble_articulado": false, "id_norma": "5726", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-06-25", "vigencias": [{"desde": "1932-06-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1932-06-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1932-06-25", "f