{"html": [{"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  PRODUCTOS DE BIENES SECUESTRADOS EN VALPARAISO.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 6 de 1825.</div><br><div class=\"p\">&nbsp; &nbsp;  El Gobierno acuerda y decreta:</div></div>", "i": 10109847}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1.&#xB0; Todos los productos de bienes secuestrados en Valparaiso deben recaudarse por la Tesorer&#xED;a, quien tomar&#xE1; cuentas al actual encargado, y &#xE9;ste las rendir&#xE1; haciendo efectiva entrega de los caudales que existieren en su poder.</div><br><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; Trascr&#xED;base al Gobernador de Valparaiso y Ministros de aquella Tesorer&#xED;a para su cumplimiento, y t&#xF3;mese razon en la Contadur&#xED;a mayor y Tesorer&#xED;a jeneral. Impr&#xED;mase.</div><br></div>", "i": 10109848}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Correa de Saa.</div></div>", "i": 10109849}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "PRODUCTOS DE BIENES SECUESTRADOS EN VALPARAISO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-07-06", "doble_articulado": false, "id_norma": "1143031", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-07-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-07-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825