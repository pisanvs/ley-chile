{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  EXTRACTO DE RESOLUCION </div></div>", "i": 6272200}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 302 de 06 de Marzo de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n se autoriza a Jorge Manuel Soto Henr&#xED;quez para efectuar todo tipo de transporte de pasajeros por calles y caminos, dentro del territorio nacional a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6272201}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Manuel Coloma Amaro, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n del Maule.</div><br></div>", "i": 6272202}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "302 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-302 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-03-06", "doble_articulado": false, "id_norma": "167736", "numero_fuente": "32164", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-05-07", "vigencias": [{"desde": "1985-05-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-05-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-05-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ing