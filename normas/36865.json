{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297175}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.392, de 25 de julio de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n; decl&#xE1;rase la caducidad de la</div><div class=\"p\">Resoluci&#xF3;n N&#xB0; 1180 de 1988, de esta Subsecretar&#xED;a, que</div><div class=\"p\">autoriz&#xF3; a PESQUERA ROSA NAUTICA S.A., para realizar</div><div class=\"p\">actividades pesqueras extractivas con la nave &quot;Don</div><div class=\"p\">Mat&#xED;as&quot;, en virtud de lo se&#xF1;alado en la letra b) del</div><div class=\"p\">Art. 143 del D.S. N&#xB0; 430 de 1991 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8297176}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 25 de julio de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297177}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1392", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1392"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "PESCA", "PESQUERA ROSA NAUTICA S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-07-25", "doble_articulado": false, "id_norma": "36865", "numero_fuente": "35532", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-08-02", "vigencias": [{"desde": "1996-08-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci