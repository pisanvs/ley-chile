{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6228592}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 33, 06 de Agosto de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n, se autoriza a la L&#xED;nea de Taxibuses Cachapoal-Baquedano para efectuar la prolongaci&#xF3;n de su servicio hasta la Poblaci&#xF3;n Baquedano por las calles que se indican:</div><div class=\"p\">&nbsp; &nbsp;  Ida: Baquedano - Manzanal Viejo - Tamarugo - Tres R&#xED;os - Arboleda - Manzanal Viejo - Baquedano.</div><div class=\"p\">&nbsp; &nbsp;  Regreso: Baquedano - Manzanal Viejo - Arboleda - Tres R&#xED;os - Tamarugo - Manzanal Viejo - retornando recorrido habitual.</div><br></div>", "i": 6228593}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rancagua, Agosto 6 de 1986.- Juan Latife Saadi, Secretario Regional Ministerial de Transportes y Telecomunicaciones Subrogante.</div><br></div>", "i": 6228594}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "33 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-33 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-08-06", "doble_articulado": false, "id_norma": "154305", "numero_fuente": "32544", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-08-09", "vigencias": [{"desde": "1986-08-09", "hasta": "", "tipo_versi