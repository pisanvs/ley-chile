{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;66 EXENTO, DE 1999</div><br><br></div>", "i": 6165631}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;66, de fecha 22 de marzo de 1999, del Ministerio de Educaci&#xF3;n, se declar&#xF3; aprobado a la Universidad de Artes, Ciencias y Comunicaci&#xF3;n, UNIACC, el programa de Licenciatura en Educaci&#xF3;n y Comunicaci&#xF3;n conducente al Grado Acad&#xE9;mico de Licenciado en Educaci&#xF3;n y Comunicaci&#xF3;n, para ser impartido en jornada diurna, en su Sede de la ciudad de Santiago, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6165632}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 6 de abril de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6165633}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "66 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-66 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº66 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-03-22", "doble_articulado": false, "id_norma": "135500", "numero_fuente": "36348", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-04-26", "vigencias": [{"desde": "1999-04-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-04-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-04-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac