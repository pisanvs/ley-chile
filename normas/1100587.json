{"html": [{"t": "<div><br><div class=\"p\">DETERMINA CIRCUNSCRIPCIONES ELECTORALES EN EL EXTRANJERO</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. O-992.- Santiago, 20 de febrero de 2017.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Visto y considerando:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  1. Lo dispuesto en la <a href=\"https://www.leychile.cl/Navegar?idNorma=1095759&amp;idParte=0&amp;idVersion=\">ley 20.960</a>, que regula el ejercicio del derecho a sufragio de los chilenos en el exterior;</div><div class=\"p\">&nbsp; &nbsp;  2. Que para determinar el funcionamiento de mesas receptoras de sufragios, &#xE9;stas deben ser adscritas a una unidad territorial electoral b&#xE1;sica;</div><div class=\"p\">&nbsp; &nbsp;  3. La concurrencia de las circunstancias establecidas en el <a href=\"https://www.leychile.cl/Navegar?idNorma=29951&amp;idParte=9232963&amp;idVersion=\">art&#xED;culo 50</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=29951&amp;idParte=0&amp;idVersion=\">Ley N&#xBA; 18.556</a>, Org&#xE1;nica Constitucional sobre Sistema de Inscripciones Electorales y Servicio Electoral;</div><div class=\"p\">&nbsp; &nbsp;  4. Las atribuciones que me confiere el <a href=\"https://www.leychile.cl/Navegar?idNorma=29951&amp;idParte=8638402&amp;idVersion=\">art&#xED;culo 68</a> letra e) de la ley N&#xBA; 18.556 ya citada.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div></div>", "i": 9775306}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1&#xBA; Determ&#xED;nase la existencia de 121 Circunscripciones Electorales en el extranjero.</div><div class=\"p\">&nbsp; &nbsp;  2&#xBA; El detalle de las 121 Circunscripciones Electorales en el extranjero, y su territorio jurisdiccional se indican en Anexo que es parte integrante de esta resoluci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  3&#xBA; Publ&#xED;quese dentro de 5&#xBA; d&#xED;a h&#xE1;bil en el Diario Oficial.</div></div>", "i": 9775307}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Ra&#xFA;l Garc&#xED;a Aspillaga, Director.</div></div>", "i": 9775308}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; .<img class=\"img-responsive\" src=\"Navegar/imagen/JPG/64968.jpg\">.</div><br></div>", "i": 9775309}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "992", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-992"}, {"tipo": "3", "numero": "O-992", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-992"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "DETERMINA CIRCUNSCRIPCIONES ELECTORALES EN EL EXTRANJERO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1187145"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-02-20", "doble_articulado": false, "id_norma": "1100587", "numero_fuente": "41694", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-02-25", "vigencias": [{"desde": "2017-02-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-02-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2017-02-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresado_por": "98", "fecha_ingreso": "2017-02-27", "fecha_version": "2017-02-25", "fecha_actualizacion_texto": "2017-02-27", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9775306}, {"n": "Artículo", "i": 9775307, "t": 6}, {"n": "Promulgación", "i": 9775308}, {"n": "Anexo TERRITORIO