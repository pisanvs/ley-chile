{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Apertura i reparacion de caminos Lei n&#xFA;m. 1,211._ Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7162943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza al Presidente de la Republica para que invierta, durante el a&#xF1;o en curso, hasta la suma de trescientos mil pesos en la apertura i reparacion de caminos.</div><div class=\"p\">&nbsp; &nbsp; Se dar&#xE1; preferencia a los caminos que de los asientos mineros, van a la costa.</div><br><br></div>", "i": 7162944}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 2 de Febrero de 1899.- FEDERICO ERRAZURIZ.- Arturo Alessandri.</div><br></div>", "i": 7162945}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1211", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1211"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "APERTURA I REPARACIÓN DE CAMINOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMINOS", "CONSTRUCCION", "REPARACION", "AUTORIZACION", "PRESIDENTE REPUBLICA", "FONDOS", "DESTINACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-02-02", "doble_articulado": false, "id_norma": "22478", "numero_fuente": "6220", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-02-03", "vigencias": [{"desde": "1899-02-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia