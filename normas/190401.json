{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7286347}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.888, de 11 de septiembre de</div><div class=\"p\">2001, de esta Subsecretar&#xED;a, autor&#xED;zase a INVERSIONES</div><div class=\"p\">LOS ALAMOS S.A., para ampliar actividades pesqueras</div><div class=\"p\">extractivas con la nave &quot;Pinguin&quot;, autorizada por</div><div class=\"p\">resoluciones citadas, en el &#xE1;rea mar&#xED;tima que se indica,</div><div class=\"p\">con arte de arrastre, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, sobre los siguiente recursos hidrobiol&#xF3;gicos:</div><br><div class=\"p\">a)&nbsp; En el &#xE1;rea mar&#xED;tima comprendida entre la IV y IX Regiones, sobre: Alfonsino, Gamba, Pejerrata y Cojinoba del norte.</div><div class=\"p\">b)&nbsp; En el &#xE1;rea mar&#xED;tima comprendida entre la II y III Regiones, sobre Merluza com&#xFA;n.</div><div class=\"p\">c)&nbsp; En el &#xE1;rea mar&#xED;tima comprendida entre la IV y VII Regiones, sobre Raya.</div><br></div>", "i": 7286348}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de septiembre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7286349}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1888", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1888"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-09-11", "fecha_derogacion": "2002-01-19", "doble_articulado": false, "id_norma": "19