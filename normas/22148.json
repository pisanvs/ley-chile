{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PENSION Lei n&#xFA;m. 297.- Santiago, a 4 de Setiembre de 1895.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947442}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. En atencion a los servicios prestados por el capitan de la Independencia don Jos&#xE9; Labb&#xE9;, conc&#xE9;dese a su hija do&#xF1;a Rosa Labb&#xE9; una pension mensual vitalicia de cincuenta pesos.</div><br><br></div>", "i": 5947443}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- Jorje Montt.- Ismael Valdes Valdes.</div><br></div>", "i": 5947444}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "297", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-297"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ROSA LABBE", "PENSION VITALICIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-09-04", "doble_articulado": false, "id_norma": "22148", "numero_fuente": "5208", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-09-10", "vigencias": [{"desde": "1895-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-09-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1895-09-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM"