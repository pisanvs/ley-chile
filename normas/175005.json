{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6299132}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.993, de 28 de julio de 2000, se modific&#xF3; el decreto MOP N&#xBA;2.913, de 30 de septiembre de 1999, que autoriz&#xF3; la expropiaci&#xF3;n entre otros del lote N&#xBA;20, para la obra Camino Ruta D-597, Monte Patria-Car&#xE9;n, Sector Juntas - Car&#xE9;n, Tramo Km. 8.260,00 a Km. 30.065,19 en la parte que se refiere al N&#xBA;de rol de aval&#xFA;o del lote N&#xBA;20, por cuanto debe decir 252-26 y no 252-18, como all&#xED; se expresa. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto por el art&#xED;culo 7&#xBA; del decreto ley N&#xBA;2.186, de 1978.</div><br></div>", "i": 6299133}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6299134}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2993", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2993"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-07-28", "doble_articulado": false, "id_norma": "175005", "numero_fuente": "36754", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-01", "vigencias": [{"desde": "2000-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "