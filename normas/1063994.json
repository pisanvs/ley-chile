{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.089 EXENTA, DE 2014</div></div>", "i": 9485589}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 3.089, de 19 de junio de 2014, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Asesor&#xED;a y Capacitaci&#xF3;n Elena Castro Acu&#xF1;a E.I.R.L. (Mas Capacitaciones E.I.R.L.)&quot;, RUT 76.270.982-1 contenida en la resoluci&#xF3;n exenta N&#xBA; 4.307 de 10 de junio de 2013, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 3, del Art. 21 de la ley 19.518.</div></div>", "i": 9485590}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Marcia Pardo Gonz&#xE1;lez, Jefe del Departamento de Desarrollo y Regulaci&#xF3;n de Mercado (PT).</div></div>", "i": 9485591}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3089 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3089 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.089 EXENTA, DE 2014", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2014-06-19", "fecha_derogacion": "2014-08-09", "doble_articulado": false, "id_norma": "1063994", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2014-07-04", "vigencias": [{"desde": "2014-08-09", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2014-07-04", "hasta": "2014-08-08", "tipo_version": "0", "tipo_version_s": "Text