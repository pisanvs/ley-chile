{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 54 EXENTO, DE 2003</div><br><br></div>", "i": 6416783}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 54, de fecha 23 de enero de 2003, de Educaci&#xF3;n, se autoriza al Instituto Profesional Andali&#xE9;n la creaci&#xF3;n de la sede de Traigu&#xE9;n, con domicilio en calle Err&#xE1;zuriz N&#xBA; 576, a contar del a&#xF1;o 2003.</div><br><div class=\"p\">&nbsp; &nbsp;  Asimismo, se autoriza para impartir en dicha sede las carreras de Relaciones P&#xFA;blicas conducente al T&#xED;tulo Profesional de Relacionador P&#xFA;blico; Contador P&#xFA;blico Auditor, y Administraci&#xF3;n de Empresas Tur&#xED;sticas.</div><br><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase presente para todos los efectos legales y administrativos.</div><br></div>", "i": 6416784}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de febrero de 2003.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6416785}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "54 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-54 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 54 EXENTO, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-23", "doble_articulado": false, "id_norma": "208300", "numero_fuente": "37504", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-03-08", "vigencias": [{"desde": "2003-03-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-03-08", "fin_vigencia": ""}, "vig