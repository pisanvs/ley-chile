{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6097270}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 503, de 17 de mayo 1989, de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL 2186 de 1978, inmueble ubicado en Avda. Portugal 496, presunto rol aval&#xFA;os 581-18 comuna Santiago, aparentemente dominio de Ameterio Moreno San Juan. Comisi&#xF3;n integrada por peritos Ren&#xE9; Ureta Koster, Teresa Sancho Pernas, arquitectos, Miguel Haltenhoff Aenishanalin, constructor civil, seg&#xFA;n informe de 16 de enero 1989, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 11.850.000, pagadera al contado.</div><br></div>", "i": 6097271}, {"t": "<div><div class=\"p\">- Director SERVIU Metropolitano.</div><br></div>", "i": 6097272}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "503", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-503"}], "organismos": ["SERVICIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIVIENDA Y URBANIZACIÓN REGION METROPOLITANA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-17", "doble_articulado": false, "id_norma": "94503", "numero_fuente": "33398", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-06-15", "vigencias": [{"desde": "1989-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1998-03-06", "fecha_version": "1989-06-15", "fe