{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6052502}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 17, del 12 de Mayo de 1992, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se adjudic&#xF3; a don Juan L. Ben&#xED;tez Almeida, la concesi&#xF3;n para operar, por un plazo de cinco a&#xF1;os a contar de la fecha de publicaci&#xF3;n del presente extracto, un establecimiento ubicado en calle Santa Mar&#xED;a No. 1320, de Curanilahue, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de emisi&#xF3;n de contaminantes de los veh&#xED;culos motorizados, remolques y semirremolques, seg&#xFA;n el Art. 7&#xB0; del DS No. 156/90, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 6052503}, {"t": "<div><div class=\"p\">Mauricio Leiva Chamorro, Secretario Regional Ministerial Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o. </div></div>", "i": 6052504}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "17", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-17"}], "organismos": ["MINISTERIO DE TRANPORTES Y TELECOMUNICACIONES", "TELECOMUNICACIONES SECRETARIA REGIONAL MINISTERIAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-05-12", "doble_articulado": false, "id_norma": "78421", "numero_fuente": "34361", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-09-07", "vigencias": [{"desde": "1992-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci