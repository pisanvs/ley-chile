{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8296398}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 1.216, de 1&#xB0; de julio de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a SOCIEDAD CONSERVERA COQUIMBO LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Baquedano N&#xB0; 230, Coquimbo, IV Regi&#xF3;n, donde podr&#xE1; procesar, en las l&#xED;neas de elaboraci&#xF3;n que se se&#xF1;alan a continuaci&#xF3;n, los siguientes recursos hidrobiol&#xF3;gicos:</div><br><div class=\"p\"> _______________________________________________________</div><div class=\"p\"> | NOTA: VER DIARIO OFICIAL N&#xB0; 35.514, VIERNES 12 DE&nbsp;  |</div><div class=\"p\"> |&nbsp; &nbsp; &nbsp;  JULIO DE 1996, PAGINA 10.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  |</div><div class=\"p\"> |_____________________________________________________|</div><br></div>", "i": 8296399}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 1&#xB0; de Julio de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8296400}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1216", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1216"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "SOCIEDAD CONSERVERA COQUIMBO LIMITADA", "PESCA", "RECURSOS HIDROBIOLOGICOS", "COQUIMBO", "CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-07