{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 12, DE 1988 </div></div>", "i": 7250648}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 12 de 27 de enero de 1988 se ha aprobado al Liceo &quot;Menesiana&quot;, de Melipilla, Regi&#xF3;n Metropolitana, planes especiales de estudio para ser aplicados en la forma que se indica a continuaci&#xF3;n:</div><div class=\"p\">* 1988 en 7&#xB0; a&#xF1;o de Educaci&#xF3;n General B&#xE1;sica y 1&#xB0; de Educaci&#xF3;n Media.</div><div class=\"p\">* 1989 en 8&#xB0; a&#xF1;o de Educaci&#xF3;n General B&#xE1;sica y 2&#xB0; de Educaci&#xF3;n Media.</div><div class=\"p\">* 1990 en 3er. a&#xF1;o de Educaci&#xF3;n Media.</div><div class=\"p\">* 1991 en 4to. a&#xF1;o de Educaci&#xF3;n Media.</div><div class=\"p\">Adem&#xE1;s, se aprueban programas de estudio para las asignaturas correspondientes a los cursos se&#xF1;alados anteriormente.</div><br></div>", "i": 7250649}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 09 de Febrero de 1988.- Mar&#xED;a Piedad Ruiz Ferreras, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 7250650}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "12 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-12 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 12, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-27", "doble_articulado": false, "id_norma": "139533", "numero_fuente": "33004", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion":