{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 214.- Santiago, 15 de Mayo de 1931.- Vistas las facultades extraordinarias que me confiere la ley n&#xFA;mero 4,945, de 6 de Febrero del a&#xF1;o en curso.</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 7119202}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Agr&#xE9;guese a la partida 10, Capitulo 01, &#xED;tem 04, Letra L/10 del Presupuesto de Marina vigente, lo siguiente:</div><div class=\"p\">&nbsp; &nbsp; &quot;y montaje de maquinarias, adquisiciones e instalaciones el&#xE9;ctricas del Apostadero.&quot; </div></div>", "i": 7119203}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de Leyes y decretos del Gobierno.- C. IBA&#xD1;EZ C.- H. Marchant M.- Carlos Castro Ruiz.</div><br></div>", "i": 7119204}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "214", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-214"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O", "1931", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-05-15", "doble_articulado": false, "id_norma": "5072", "numero_fuente": "15983", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-05-29", "vigencias": [{"desde": "1931-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1931-05-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1931-05-29", "fin_vigencia": "", "tipo_version": "3"