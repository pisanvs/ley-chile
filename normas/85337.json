{"html": [{"t": "<div><div class=\"p\">APRUEBA REFORMA DE ESTATUTOS DE &quot;COMPA&#xD1;IA DE SEGUROS DE VIDA LA CHILENA CONSOLIDADA S A.&quot; </div></div>", "i": 7220290}, {"t": "<div><div class=\"p\">Certifico: Que por resoluci&#xF3;n No. 235 de 26 Octubre 1992 se aprob&#xF3; la reforma de estatutos de la sociedad an&#xF3;nima &quot;Compa&#xF1;&#xED;a de Seguros de Vida La Chilena Consolidada S.A.&quot;, que consta en escritura p&#xFA;blica de fecha 21 de octubre de 1992, otorgada en la Notar&#xED;a de Santiago, de don Iv&#xE1;n Torrealba Acevedo.</div><div class=\"p\">La reforma consiste en:</div><div class=\"p\">Establecer la existencia de 5 directores suplentes, modificando al efecto el art&#xED;culo 7&#xB0; del estatuto. </div></div>", "i": 7220291}, {"t": "<div><div class=\"p\">Santiago 26 de Octubre de 1992.- Rodrigo Costa Aranda, Secretario General.</div><br></div>", "i": 7220292}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "235", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-235"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "APRUEBA REFORMA DE ESTATUTOS DE COMPAÑIA DE SEGUROS DE VIDA LA CHILENA CONSOLIDADA S A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-10-26", "doble_articulado": false, "id_norma": "85337", "numero_fuente": "34401", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-10-28", "vigencias": [{"desde": "1992-10-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-10-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-10-