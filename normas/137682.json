{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,698.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6172884}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atenci&#xF3;n a los servicios prestados por el servidor de la Independencia, don Juan Enrique Gonz&#xE1;lez, conc&#xE9;dese a sus nietas, se&#xF1;oritas Jertr&#xFA;dis i Eujenia Rosales Valdovinos, una pensi&#xF3;n anual de mil doscientos pesos, de que disfrutar&#xE1;n con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6172885}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, cuatro de setiembre de mil novecientos doce.- Ramon&nbsp; Barros Luco.- Claudio Vicu&#xF1;a S.</div><br></div>", "i": 6172886}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2698", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2698"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-09-04", "doble_articulado": false, "id_norma": "137682", "numero_fuente": "10371", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-09-05", "vigencias": [{"desde": "1912-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-09-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-09-05", "f