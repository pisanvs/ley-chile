{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6218573}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 559, de 23 de Junio de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Jos&#xE9; T&#xE9;llez Guerrero, Jorge Neira Salinas y Ren&#xE9; Vera Osorio para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 3 &quot;Pichi Pelluco - Angelm&#xF3;&quot; de Puerto Montt, cuyo trazado fue autorizado por resoluci&#xF3;n No. 107, de fecha 22 de Junio de 1984, de esta Secretar&#xED;a Regional.-</div><br></div>", "i": 6218574}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6218575}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "559 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-559 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-23", "doble_articulado": false, "id_norma": "151102", "numero_fuente": "32809", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-02", "vigencias": [{"desde": "1987-07-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-07-02", "fin_vi