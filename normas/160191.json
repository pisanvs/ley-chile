{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 346, DE 1990 </div></div>", "i": 6247754}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 346 de 21 de diciembre de 1990 se han aprobado programas especiales de estudio de orientaci&#xF3;n laboral, por un per&#xED;odo de 4 a&#xF1;os, a la Escuela Especial E No. 13, dependiente de la I. Municipalidad de Copiap&#xF3;, a contar de marzo de 1991, para impartir ense&#xF1;anza a trav&#xE9;s de los cursos talleres Papeles y Cartones; y Tareas Menores y Artesan&#xED;a.</div><br></div>", "i": 6247755}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 08 de Enero de 1991.- Ra&#xFA;l Allard Neumann Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6247756}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "346 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-346 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 346, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-21", "doble_articulado": false, "id_norma": "160191", "numero_fuente": "33876", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-01-24", "vigencias": [{"desde": "1991-01-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-01-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-01-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2000-03-08", "fech