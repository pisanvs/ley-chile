{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE DECLARA &#xC1;REA DE PLAGA QUE INDICA</div></div>", "i": 9368135}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.927, de 30 de julio de 2013, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1050353&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 996, de 2013</a>, de esta Subsecretar&#xED;a, que declar&#xF3; &#xE1;reas de plaga y de riesgo de plaga de la especie Didymosphenia geminata, en los sectores de cuerpos de aguas, ampli&#xE1;ndolos a la XII Regi&#xF3;n, en la forma que se indica en la resoluci&#xF3;n extractada, y publicada &#xED;ntegramente en la p&#xE1;gina web www.subpesca.cl.</div><br></div>", "i": 9368136}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de julio de 2013.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9368137}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1927 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1927 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE DECLARA ÁREA DE PLAGA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-07-30", "doble_articulado": false, "id_norma": "1053445", "numero_fuente": "40626", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-08-05", "vigencias": [{"desde": "2013-08-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-08-05",