{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6006346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 117 de 23 de Noviembre de 1994 de SERVIU I Regi&#xF3;n de Tarapac&#xE1;, se dispuso expropiaci&#xF3;n conforme Decreto Ley N&#xB0; 2.186 de 1978 de una parte del inmueble ubicado en Avda. Diego Portales N&#xB0; 651, presunto Rol de Aval&#xFA;o N&#xB0; 671-1, Comuna de Arica, aparente dominio de Red de Televisi&#xF3;n de la Universidad del Norte S.A. Comisi&#xF3;n integrada por los peritos se&#xF1;ores Jorge Romero Ossio y Ricardo Muixi Decona, Constructores Civiles, y Santiago Vallejos Medicic, Arquitecto, seg&#xFA;n Informe de 05 de Octubre de 1994, fij&#xF3; monto provisional de indemnizaci&#xF3;n en $6.300.000, para los 760 metros cuadrados a expropiar, pagadero al contado.</div><br></div>", "i": 6006347}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director SERVIU I Regi&#xF3;n de Tarapac&#xE1;.</div><br></div>", "i": 6006348}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "117", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-117"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "BIEN RAIZ", "ARICA", "PRIMERA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-11-23", "doble_articulado": false, "id_norma": "33242", "numero_fuente": "35041", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-12-15", "vigencias": [{"desde": "1994-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-12-15", "fin_vigencia": ""}, "vigencias_version