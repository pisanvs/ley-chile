{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7285137}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 786, de 20 de abril de 2001, de esta Subsecretar&#xED;a, apru&#xE9;base la solicitud presentada por ANDRES PIRAZZOLI REGIS para transferir la autorizaci&#xF3;n de acuicultura otorgada por la resoluci&#xF3;n N&#xBA;1.210 de 1987, para operar un centro de cultivo ubicado en el Fundo Esmeralda, Potrero Grande, comuna y provincia de Curic&#xF3;, VII Regi&#xF3;n, a Empresas Altamira Limitada.</div><div class=\"p\">&nbsp; &nbsp;  Apru&#xE9;base el proyecto t&#xE9;cnico y cronograma de actividades (ingreso Subpesca N&#xBA; 2442 de 1998), presentado por Empresas Altamira Limitada.</div><br></div>", "i": 7285138}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de abril de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca </div></div>", "i": 7285139}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "786", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-786"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-20", "doble_articulado": false, "id_norma": "188658", "numero_fuente": "37042", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-08-21", "vigencias": [{"desde": "2001-08-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-08-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-08-21", "fin_vigencia": "", "tipo_versio