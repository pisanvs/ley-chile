{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8910328}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.627, de 26 de agosto de 1999,</div><div class=\"p\">de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las</div><div class=\"p\">resoluciones N&#xBA; 1.370 y N&#xBA; 1.368, ambas de 1996, de esta</div><div class=\"p\">Subsecretar&#xED;a, que autorizaron a do&#xF1;a GLADYS REBECA</div><div class=\"p\">AGUILERA ARANCIBIA, para operar las naves &apos;&apos;Tupungato&apos;&apos;</div><div class=\"p\">y &apos;&apos;Sotavento&apos;&apos;, por no haber iniciado operaciones</div><div class=\"p\">dentro del plazo legal, conforme lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra b), de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8910329}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de agosto de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8910330}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1627", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1627"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-08-26", "doble_articulado": false, "id_norma": "142480", "numero_fuente": "36456", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-03", "vigencias": [{"desde": "1999-09-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-03", "fin_vigencia": ""}, "vigencias_version_norma":