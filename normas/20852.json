{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 270 EXENTO, DE 1995 </div></div>", "i": 7161439}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 270 de fecha 2 de mayo de 1995 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Crownliet, las adecuaciones introducidas al plan y programas de estudio de la carrera Agente de Ventas menci&#xF3;n Visitador M&#xE9;dico, las que se insertaron en la Resoluci&#xF3;n Exenta del Ministerio de Educaci&#xF3;n N&#xB0; 2.900 de 1989. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1995.</div><br></div>", "i": 7161440}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 25 de Mayo de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161441}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "270 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-270 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 270 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA CROWNLIET", "PROGRAMAS", "ESTUDIO", "PLANES ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-02", "doble_articulado": false, "id_norma": "20852", "numero_fuente": "35189", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-06-09", "vigencias": [{"desde": "1995-06-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-06-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-06-09", "fin_vigencia": "", "tipo_versi