{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xBA; 596</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 596, celebrada el 10 de abril de 1997, adopt&#xF3; el siguiente Acuerdo:</div><br><div class=\"p\">596-03-970410 - Opcionalidad en la presentaci&#xF3;n de informes de Importaci&#xF3;n y Exportaci&#xF3;n.</div><br></div>", "i": 9048009}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; establecer que a contar del 1&#xBA; de enero de 1998, la presentaci&#xF3;n de informes de Exportaci&#xF3;n e Importaci&#xF3;n ser&#xE1; opcional para los efectos de lo dispuesto en el art&#xED;culo 45 de la Ley Org&#xE1;nica Constitucional del Banco Central de Chile.</div><br></div>", "i": 9048010}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "596", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-596"}, {"tipo": "5", "numero": "596-03", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-596-03"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "OPCIONALIDAD EN LA PRESENTACION DE INFORMES DE IMPORTACION Y EXPORTACION.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INFORMES DE IMPORTACION", "INFORMES DE EXPORTACION", "LEY ORGANICA CONSTITUCIONAL DEL BANCO CENTRAL DE CHILE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-10", "doble_articulado": false, "id_norma": "70585", "numero_fuente": "35739", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-12", "vigencias": [{"desde": "1997-04-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigen