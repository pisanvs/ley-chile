{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10305554}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta n&#xFA;mero 26, de 19 de enero de 2022, de este Servicio, se establece procedimiento de estimaci&#xF3;n de captura en naves de la flota industrial de arrastre de Merluza com&#xFA;n, para embarcaci&#xF3;n que indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en el sitio de dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y la Subsecretar&#xED;a de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10305555}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de enero de 2022.- Jessica Fuentes Olmos, Directora Nacional (S), Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\"> </div><br></div>", "i": 10305556}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "26 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-26 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2077792", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-01-19", "doble_articulado": false, "id_norma": "1171797", "numero_fuente": "43163", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-01-27", "vigencias": [{"desde": "2022-01-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2022-01