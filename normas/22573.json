{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede fondos para instalar un hospital en Punta Arenas</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 27 de Julio de 1900.- Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br></div>", "i": 8274275}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la suma de veinte mil peso en instalar un hospital en Punta Arenas</div><br><br></div>", "i": 8274276}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- El&#xED;as Fern&#xE1;ndez A.- Rafael Err&#xE1;zuriz Urmeneta.</div><br></div>", "i": 8274277}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1341", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1341"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE FONDOS PARA INSTALAR UN HOSPITAL EN PUNTA ARENAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PUNTA ARENAS", "HOSPITAL", "INSTALACION", "PRESIDENTE", "REPUBLICA", "FONDOS", "DESTINACION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-07-27", "doble_articulado": false, "id_norma": "22573", "numero_fuente": "6655", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-07-28", "vigencias": [{"desde": "1900-07-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-07-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1900-07-28