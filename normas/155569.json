{"html": [{"t": "<div><div class=\"p\">AUTORIZA A DON EDUARDO JAVIER TOLEDO GALDAMES PARA DESARROLLAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 7261197}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xB0; 105 de 06 de Febrero de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a don Eduardo Javier Toledo Galdames, RUT 6.616.644-9, domiciliado en Talcahuano, calle Valdivieso 240, Depto. 42, para instalar y operar un cultivo de alga Gracilaria en una superficie de 27.500 m2 y de ostra del Pac&#xED;fico y de osti&#xF3;n del Norte, en un &#xE1;rea de 2.500 m2, ubicadas en la Comuna de Tom&#xE9;, Provincia de Concepci&#xF3;n, VIII Regi&#xF3;n. </div></div>", "i": 7261198}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 06 de Febrero de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7261199}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "105", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-105"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A DON EDUARDO JAVIER TOLEDO GALDAMES PARA\nDESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-02-06", "fecha_derogacion": "1989-03-04", "doble_articulado": false, "id_norma": "155569", "numero_fuente": "32401", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-02-18", "vigencias": [{"desde": "1989-03-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1986-02-