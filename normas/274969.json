{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD RHELEC LIMITADA </div></div>", "i": 6655723}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional del SII, Regi&#xF3;n de la Araucan&#xED;a, por resoluci&#xF3;n exenta N&#xBA; 225, de fecha 18 de julio de 2008, otorga a Sociedad Rhelec Limitada, RUT N&#xBA; 78.832.020-5, a contar del d&#xED;a 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado en los contratos de instalaci&#xF3;n o confecci&#xF3;n de especialidades que contrate, conforme a la facultad delegada en el dispositivo n&#xFA;mero 7 de la resoluci&#xF3;n exenta de la Direcci&#xF3;n Nacional N&#xBA;142 de fecha 26/12/2005, publicada en el Diario Oficial del d&#xED;a 29/12/2005.</div><br></div>", "i": 6655724}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Cornejo C&#xE1;ceres, Director Regional. </div></div>", "i": 6655725}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "225 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-225 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL DE LA ARAUCANÍA"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD RHELEC LIMITADA", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2008-07-18", "fecha_derogacion": "2016-07-25", "doble_articulado": false, "id_norma": "274969", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2008-07-31", "vigencias": [{"desde": "2016-07-25", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2