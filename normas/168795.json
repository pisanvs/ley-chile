{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 379, DE 1990 </div></div>", "i": 6275690}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 379, de 28 de diciembre de 1990, se ha modificado el decreto supremo exento de Educaci&#xF3;n No. 232, de 1982, que aprob&#xF3; plan especial de estudio al Colegio La Maisonnette, de Santiago, en el sentido de sustituir el plan de estudio para ense&#xF1;anza media human&#xED;stico - cient&#xED;fica y otras que se especifican. </div></div>", "i": 6275691}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de abril de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6275692}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "379 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-379 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 379, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-28", "doble_articulado": false, "id_norma": "168795", "numero_fuente": "33947", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-19", "vigencias": [{"desde": "1991-04-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-04-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-04-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2000-05-16", "fecha_version": "1991-04-19", "fecha_actualizacion_texto": "1991-04-19", "tipo_tratad