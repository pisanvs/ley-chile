{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6577061}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.042, de 6 de julio de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a SERGIO SAMUEL ESPINOZA GONZALEZ, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en sector C de la Mina San Juan Uno al Cinco, Sierra Paposo, comuna de Taltal, provincia de Antofagasta, II Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Alga seca, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6577062}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de julio de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6577063}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2042 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2042 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-07-06", "doble_articulado": false, "id_norma": "251620", "numero_fuente": "38523", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-07-26", "vigencias": [{"desde": "2006-07-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-07-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-07-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "