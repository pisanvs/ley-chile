{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6238639}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 157, de 26.09.84, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se autoriza a los se&#xF1;ores Gilberto y Claudio D&#xED;az Hern&#xE1;ndez, para efectuar todo tipo de transporte de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n del servicio urbano de locomoci&#xF3;n colectiva de pasajeros.- </div></div>", "i": 6238640}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Manuel Coloma Amaro, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n del Maule.</div><br></div>", "i": 6238641}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "157", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-157"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-09-26", "doble_articulado": false, "id_norma": "157493", "numero_fuente": "32120", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-13", "vigencias": [{"desde": "1985-03-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-03-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso"