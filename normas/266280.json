{"html": [{"t": "<div><div class=\"p\">AUTORIZA EMISORES DE BOLETAS ELECTR&#xD3;NICAS </div></div>", "i": 7357629}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA;128, de 31 de octubre de 2007, que autoriza a contribuyentes como emisores de boletas electr&#xF3;nicas.</div><div class=\"p\">&nbsp; &nbsp;  Se autorizan como emisores de boletas electr&#xF3;nicas a contribuyentes RUT 96.800.570-7, RUT 96.783.910-8 y 97.023.000-9 a contar del mes de noviembre de 2007.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de octubre de 2007.</div><br></div>", "i": 7357630}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "128 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-128 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISORES ELECTRONICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-10-31", "doble_articulado": false, "id_norma": "266280", "numero_fuente": "38904", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-11-07", "vigencias": [{"desde": "2007-11-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-11-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-11-07", "fin_vigencia": "", "tipo_version": "3"}],