{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8335705}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.443, de 7 de octubre de 1998, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 2 de la resoluci&#xF3;n N&#xBA; 245 y el numeral 1 de la resoluci&#xF3;n N&#xBA; 544 de 1998, de esta Subsecretar&#xED;a, que autorizaron a PESQUERA IQUIQUE GUANAYE S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, en su planta ubicada en Manuel Rodr&#xED;guez N&#xBA; 302, Talcahuano, VIII Regi&#xF3;n, en el sentido de se&#xF1;alar que los recursos Bacaladillo o mote, Anchoveta y Machuelo o tritre, ser&#xE1;n abastecidos por su flota pesquera autorizada y por terceros.</div><br></div>", "i": 8335706}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de octubre de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8335707}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1443", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1443"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA IQUIQUE GUANAYE S.A.", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-10-07", "doble_articulado": false, "id_norma": "125831", "numero_fuente": "36186", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-10-13", "vigencias": [{"desde": "1998-10-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-10-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc