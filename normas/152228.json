{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA N&#xB0; 1.230, DE 1986 </div><br></div>", "i": 6222476}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.230, de fecha 23 de Mayo de 1986, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se aprobaron las modificaciones introducidas al plan y programas de estudio del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Andr&#xE9;s Bello de Temuco, de la carrera y t&#xED;tulo t&#xE9;cnico que se indica, para impartirse a contar del a&#xF1;o 1986:</div><div class=\"p\">&nbsp; &nbsp;  Carrera: Secretariado Ejecutivo con menci&#xF3;n en Operaci&#xF3;n de Terminales y Microcomputadores.</div><div class=\"p\">&nbsp; &nbsp;  T&#xED;tulo: Secretario(a) Ejecutivo(a) con menci&#xF3;n en Operaci&#xF3;n de Terminales y Microcomputadores.- </div></div>", "i": 6222477}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Mart&#xED;n, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6222478}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1230 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1230 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N° 1.230, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-09-30", "fecha_derogacion": "2020-12-31", "doble_articulado": false, "id_norma": "152228", "numero_fuente": "32.594", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-10-11", "vigencias": [{"desde": "2020-12-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última