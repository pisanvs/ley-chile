{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,526.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6165695}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se declaran de abono, para los efectos de la lei de 20 de agosto de 1857, los servicios prestados por los administradores de estanco. </div></div>", "i": 6165696}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, promulguese i ll&#xE9;vese a efecto en todas sus partes como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de enero de 1902.- JERMAN RIESCO.- Enrique Villegas </div></div>", "i": 6165697}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1526", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1526"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1902-01-23", "doble_articulado": false, "id_norma": "135528", "numero_fuente": "7136", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1902-01-28", "vigencias": [{"desde": "1902-01-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1902-01-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1902-01-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-04-27", "fecha_version": "1902-01-28", "fecha_actualizacion_texto": "1902-01-