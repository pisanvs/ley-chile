{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO</div></div>", "i": 9834355}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP Exento N&#xBA; 1.039 de 04 de septiembre de 2017, se rectific&#xF3; los numerales 2&#xBA; y 3&#xBA; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1102828&amp;idParte=&amp;idVersion=\">Decreto MOP Exento N&#xBA; 225</a> de 25 de abril de 2017, que orden&#xF3; la expropiaci&#xF3;n del lote 27 en el siguiente aspecto: donde dice MARITZA MARTA FARINELLI GONZALEZ, debe decir MARITZA MARTA FARINELLI GONZALEZ GONZALEZ y OMAR ANTONIO SANDOVAL HERNANDEZ. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA; 2.186, de 1978. </div></div>", "i": 9834356}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 9834357}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1039 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1039 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1272377", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-09-04", "doble_articulado": false, "id_norma": "1107993", "numero_fuente": "41861", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-09-15", "vigencias": [{"desde": "2017-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2017-09-15", "fin_vigencia": "", "tipo_versio