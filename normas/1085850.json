{"html": [{"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA</div><div class=\"p\">&nbsp; &nbsp; </div></div>", "i": 9659746}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n de Grandes Contribuyentes del SII. Por resoluci&#xF3;n exenta N&#xBA; 180, de 4 de diciembre del 2015, otorga a contar del d&#xED;a primero del mes siguiente al de esta publicaci&#xF3;n al contribuyente Walmart Chile S.A., RUT N&#xBA; 76.042.014-K, la calidad de agente retenedor del impuesto a las ventas y servicios en las ventas de especies hidrobiol&#xF3;gicas que efect&#xFA;e, en conformidad con la resoluci&#xF3;n exenta N&#xBA; 3.311 del 30 de junio de 2000 de este Servicio. </div><br></div>", "i": 9659747}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Bernardo Seaman Gonz&#xE1;lez, Director de Grandes Contribuyentes.</div></div>", "i": 9659748}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "180 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-180 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN DE GRANDES CONTRIBUYENTES"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2015-12-04", "fecha_derogacion": "2018-12-27", "doble_articulado": false, "id_norma": "1085850", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2015-12-29", "vigencias": [{"desde": "2018-12-27", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2015-12-29", "hasta": "2018-12-26", "tipo_version": "0", "tipo_version_s": "Texto Original"}],