{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6190684}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 30, de 07 de Enero de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se autoriza a don Luis Felipe Mar&#xED;n Mar&#xED;n, para efectuar todo tipo de servicio de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6190685}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Manuel Coloma Amaro, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n del Maule.</div><br></div>", "i": 6190686}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "30 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-30 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-01-07", "doble_articulado": false, "id_norma": "143233", "numero_fuente": "32677", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-01-21", "vigencias": [{"desde": "1987-01-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-01-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-01-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones