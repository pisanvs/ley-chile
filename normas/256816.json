{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;224 EXENTO, DE 2005 </div></div>", "i": 6594993}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;224, de fecha 8 de marzo de 2005, de Educaci&#xF3;n, se declara aprobada a la Universidad Miguel de Cervantes la modificaci&#xF3;n al Plan y a los Programas de estudio de la carrera de Periodismo, conducente al grado acad&#xE9;mico de Licenciado en Comunicaci&#xF3;n Social y al t&#xED;tulo profesional de Periodista, a contar del primer semestre de 2005. Dicha carrera se imparte en jornada diurna en su sede de Santiago.</div><br></div>", "i": 6594994}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de abril de 2005.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6594995}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "224 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-224 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº224 EXENTO, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-03-08", "doble_articulado": false, "id_norma": "256816", "numero_fuente": "38647", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-12-26", "vigencias": [{"desde": "2006-12-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-12-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-12-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2006-12-26", "f