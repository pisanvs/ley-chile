{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10361586}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; DN-01705/2022, de 10 de agosto de 2022, Elimina del Registro Nacional de Acuicultura las inscripciones de las pisciculturas que indica, en conformidad con el art&#xED;culo 90 ter de la Ley General de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se public&#xF3; en el sitio de dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y la Subsecretar&#xED;a de Pesca y Acuicultura.</div></div>", "i": 10361587}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, a 10 de agosto de 2022.- Esteban Donoso Abarca, Director Nacional (S) del Servicio Nacional de Pesca y Acuicultura.</div><br></div>", "i": 10361588}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1705 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1705 EXENTA"}, {"tipo": "3", "numero": "DN-01705/2022 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-DN-01705/2022 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2180310", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-08-10", "doble_articulado": false, "id_norma": "1180700", "numero_fuente": "43342", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-09-01", "vigencias": [{"desd