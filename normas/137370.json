{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8345348}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 927, de 20 de mayo de 1999, de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; PESQUERA LA PENINSULA S.A., para ampliar las actividades de pesca autorizadas por las resoluciones N&#xBA; 543 de 1988, N&#xBA; 641 de 1996, N&#xBA; 1.454 de 1996, N&#xBA; 1.876 de 1996, N&#xBA; 282 de 1999 y N&#xBA; 283 de 1999, todas de esta Subsecretar&#xED;a. La interesada podr&#xE1; realizar actividades pesqueras extractivas con la nave &apos;&apos;Loa 4&apos;&apos;, en el litoral de la I y II Regiones, respecto del recurso Anchoa blanca.</div><br></div>", "i": 8345349}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de mayo de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8345350}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "927", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-927"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-05-20", "fecha_derogacion": "2002-11-07", "doble_articulado": false, "id_norma": "137370", "numero_fuente": "36380", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-06-05", "vigencias": [{"desde": "2002-11-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-06-05", "hasta": "2002-11-06", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2002-11-07", "fin_vigencia"