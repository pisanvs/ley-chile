{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACIONES</div></div>", "i": 9696222}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Res. Ex. N&#xBA;201 de 08/03/16. Exp. N&#xBA;1501942. Vistos: Ley N&#xB0;18.755; Ley N&#xBA;18.575, resoluci&#xF3;n N&#xBA;1.600/2008 de la CGR. Considerando: 1.- ADC N&#xB0;097162, que se&#xF1;ala que al revisar el equipaje, se interceptan 2 unidades de manzanas y 2 unidades de naranjas que no fueron declaradas. 2.- La infractora se&#xF1;ala que no declar&#xF3; la fruta debido a que no ley&#xF3; la declaraci&#xF3;n jurada con rigurosidad. 3.- La infractora no registra denuncias anteriores. Resuelvo: Absu&#xE9;lvase por esta &#xFA;nica vez a do&#xF1;a Miriam Martha Llanque Claros de Sanjines, C&#xE9;dula de Identidad N&#xBA;3443451, nacionalidad boliviana, domicilio indeterminado. </div></div>", "i": 9696223}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Firma: C&#xE9;sar Cardozo Rojas, Director Regional Regi&#xF3;n de Tarapac&#xE1; SAG.</div></div>", "i": 9696224}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "201 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-201 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO REGIÓN DE TARAPACÁ"], "titulo_norma": "NOTIFICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1012763; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-03-08", "doble_articulado": false, "id_norma": "1089419", "numero_fuente": "41433", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-04-15", "vigencias": [{"desde": "2016-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vige