{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6417139}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 562, de 24 de febrero de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a COMPA&#xD1;IA PESQUERA CAMANCHACA S.A. para realizar actividades extractivas en aguas internacionales con la nave &quot;Bucanero I&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2920</div><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CB-5903</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  63,65 m</div><div class=\"p\">T.R.G. (Internacional)&nbsp; &nbsp; &nbsp;  1.533,0</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 1.800,6 m3</div><div class=\"p\">Potencia motor principal&nbsp; &nbsp;  4.787,00 Hp</div><div class=\"p\">Potencia motores auxiliares&nbsp; 1.396,00 Hp</div><br></div>", "i": 6417140}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de febrero de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6417141}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "562", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-562"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-02-24", "doble_articulado": false, "id_norma": "208361", "numero_fuente": "37507", "tipo_version": "3", "tipo_version_s": "Única", "fecha