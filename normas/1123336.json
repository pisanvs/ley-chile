{"html": [{"t": "<div><div class=\"p\">&nbsp;  </div><br><div class=\"p\">&nbsp; &nbsp;  Sueldo de los soldados</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de Junio de 1817.</div></div>", "i": 9963307}, {"t": "<div><div class=\"p\">&nbsp; El prest del soldado ser&#xE1; en adelante abonable por las Tesorer&#xED;as desde el dia en que pase su primera revista de Comisario, i no desde su enganche. P&#xF3;ngase por secretar&#xED;a este decreto en noticia del jefe del estado mayor, a fin de que lo comunique a los cuerpos del Ej&#xE9;rcito.- </div></div>", "i": 9963308}, {"t": "<div><div class=\"p\">T&#xF3;mese razon, e impr&#xED;mase.- Quintana.- Dr. Villegas, Secretario de Hacienda.</div></div>", "i": 9963309}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Sueldo de los soldados", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1817-06-09", "doble_articulado": false, "id_norma": "1123336", "numero_fuente": "1817", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1817-06-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1817-06-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1817-06-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2018-11-08", "fecha_version": "1817-06-09", "fecha_actualizacion_texto": "2018-11-08", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [