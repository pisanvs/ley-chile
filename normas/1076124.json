{"html": [{"t": "<div><br><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESI&#xD3;N ORDINARIA N&#xBA; 1.893</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile, en su Sesi&#xF3;n Ordinaria N&#xBA; 1.893, celebrada el 26 de marzo de 2015, adopt&#xF3; el siguiente Acuerdo:</div></div>", "i": 9588170}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">1893-01-150326 - Designaci&#xF3;n de representante del Banco Central de Chile ante COCHILCO.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Designar, a contar del 1 de abril de 2015 y hasta el d&#xED;a 25 de octubre de 2016, como representante del Banco Central de Chile ante el Consejo de la Comisi&#xF3;n Chilena del Cobre a don Francisco Ruiz Aburto en reemplazo de don Ricardo Vicu&#xF1;a Poblete; todo ello en conformidad al art&#xED;culo 4&#xBA; del DL N&#xBA; 1.349, de 1976.</div></div>", "i": 9588171}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de abril de 2015.- Juan Pablo Araya Marco, Ministro de Fe.</div></div>", "i": 9588172}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1893", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1893"}, {"tipo": "5", "numero": "1893-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1893-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESIÓN ORDINARIA Nº 1.893", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-03-26", "doble_articulado": false, "id_norm