{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 389 EXENTA, DE 11 DE ABRIL DE 2006</div><br><div class=\"p\">&nbsp; &nbsp;  Modifica recursos disponibles para el marco del Programa Subsidio para Vivienda Progresiva a&#xF1;o 2006.</div><br><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n:</div><br></div>", "i": 6567514}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Reb&#xE1;jese los recursos disponibles en 15.968,5 UF del llamado a postulaci&#xF3;n del subsidio habitacional de Vivienda Progresiva 2006, realizado mediante la resoluci&#xF3;n exenta N&#xBA; 273, del 20 de marzo de 2006, de la Seremi Metropolitana de Vivienda y Urbanismo, quedando en un total de 81.531,5 UF.</div><br></div>", "i": 6567515}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Secretario Ministerial Metropolitano de Vivienda y Urbanismo. </div></div>", "i": 6567516}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "389 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-389 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 389 EXENTA, DE 11 DE ABRIL DE\n2006", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-04-11", "doble_articulado": false, "id_norma": "249061", "numero_fuente": "38444", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-04-21", "vigencias": [{"desde": "2006-04-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-04-21", "fin_vigencia": ""}, "vigencias_versio