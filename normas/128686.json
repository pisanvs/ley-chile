{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8337791}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.785, de 11 de diciembre de 1998, de esta Subsecretar&#xED;a, modif&#xED;case la resoluci&#xF3;n N&#xBA; 1.132, de 1998, de esta Subsecretar&#xED;a, que fij&#xF3; la n&#xF3;mina de armadores y embarcaciones que cumplen con los requisitos legales para operar en las unidades de pesquer&#xED;a Anchoveta y Sardina espa&#xF1;ola, declaradas en estado de plena explotaci&#xF3;n y sometidas a dicho r&#xE9;gimen de administraci&#xF3;n, en el litoral comprendido entre la III y IV Regiones, en el sentido de incorporar en su numeral 1&#xBA; lo siguiente:</div><br><div class=\"p\">ALIMENTOS MARINOS S.A.: Ranquilhue.</div><br></div>", "i": 8337792}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de diciembre de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8337793}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1785", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1785"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-12-11", "fecha_derogacion": "1999-01-12", "doble_articulado": false, "id_norma": "128686", "numero_fuente": "36247", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-12-24", "vigencias": [{"desde": "1999-01-12", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-12-24", "hasta": "1999-01-11", "tipo_version": "0", "tipo_v