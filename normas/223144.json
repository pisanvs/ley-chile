{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA; 139, DE 2004 </div></div>", "i": 7310382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 139 de 10 de marzo de 2004, se ha modificado los programas de estudios aprobados en el art&#xED;culo 3&#xBA; del decreto exento de Educaci&#xF3;n N&#xBA; 493 de 1997 al &quot; Lincoln International Academy&quot;&nbsp; de Lo Barnechea, para los cursos de 1&#xBA;, 2&#xBA;, 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica.</div><br><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, en lo no modificado permanecer&#xE1; vigente el decreto exento de Educaci&#xF3;n N&#xBA; 493, de 1997. </div></div>", "i": 7310383}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de marzo de 2004.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 7310384}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "139 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-139 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº 139, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PROGRAMAS DE ESTUDIO", "LINCOLN INTERNATIONAL ACADEMY", "LO BARNECHEA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-10", "doble_articulado": false, "id_norma": "223144", "numero_fuente": "37825", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-31", "vigencias": [{"desde": "2004-03-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-03-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig