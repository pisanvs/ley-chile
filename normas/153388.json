{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6225809}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n de la Fiscal&#xED;a del Ministerio de Obras P&#xFA;blicas F. N&#xB0; 108, de 30 de septiembre de 1986, se ha ordenado pagar la suma de $ 354.924 a don Carlos Paredes Zapata o a quien acredite derecho como valor del 100 % del aval&#xFA;o fijado por la Comisi&#xF3;n de Hombres Buenos m s su reajuste, para el lote 2, de una superficie de 9.950 m2, para Doble V&#xED;a Concepci&#xF3;n a Coronel, sector San Pedro a Lomas Coloradas. Se deja constancia que el plazo para reclamar judicialmente del aval&#xFA;o es de 30 d&#xED;as contados desde la fecha de la 2a. publicaci&#xF3;n que se efectuar&nbsp; en un peri&#xF3;dico de la VIII Regi&#xF3;n.-</div><br></div>", "i": 6225810}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6225811}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "108", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-108"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-09-30", "doble_articulado": false, "id_norma": "153388", "numero_fuente": "32.611", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-10-31", "vigencias": [{"desde": "1986-10-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-10-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-10-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes