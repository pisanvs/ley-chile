{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 138, DE 1990 </div></div>", "i": 7217470}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 138 de 19 de abril de 1990 se ha modificado en lo que se refiere a la asignatura de Arte del Plan Cient&#xED;fico para 3&#xB0; y 4&#xB0; a&#xF1;o medio, a contar del presente a&#xF1;o escolar, el decreto supremo exento de Educaci&#xF3;n No. 189, de 1982, modificado por decreto supremo exento de Educaci&#xF3;n No. 177, de 1988, que aprob&#xF3; un plan de estudio especial a la Scuola Italiana Vittorio Montiglio, de Santiago.</div><br></div>", "i": 7217471}, {"t": "<div><div class=\"p\">Santiago, 01 de Junio de 1990.- Ra&#xFA;l Allard Neumann Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7217472}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "138 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-138 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N°  138, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-04-19", "doble_articulado": false, "id_norma": "82510", "numero_fuente": "33756", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-08-28", "vigencias": [{"desde": "1990-08-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-08-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-08-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MNV", "fecha_ingreso":