{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6176467}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 45, del 12 de Febrero de 1988, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Primera Regi&#xF3;n Tarapac&#xE1;, se autoriza a don Antonio Dura Sempere para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de la locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6176468}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco Alvarez Rojas, Secretario Regional Ministerial de Transportes y Telecomunicaciones I Regi&#xF3;n Tarapac&#xE1; subrogante.</div><br></div>", "i": 6176469}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "45 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-45 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-02-12", "doble_articulado": false, "id_norma": "138784", "numero_fuente": "33002", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-22", "vigencias": [{"desde": "1988-02-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-02-22", "fin_vigencia": "", "tipo_version": "3"}], "evento