{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6507474}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA;3.353 de 25 de noviembre de 2004, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA; de la resoluci&#xF3;n N&#xBA;115 de 2004, de esta Subsecretar&#xED;a que autoriz&#xF3; a PESCA SURIBERICA S.A. para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Factibilidad t&#xE9;cnica de captura de Bacalao de profundidad (Dissostichus eleginoides) con trampas&quot;, en el sentido de reemplazar la nave &quot;Isla Camila&quot; por la nave &quot;Isla Santa Clara&quot;, como nave autorizada para realizar tareas de prospecci&#xF3;n y muestreo en el marco de la presente pesca de investigaci&#xF3;n.</div><br></div>", "i": 6507475}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de noviembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6507476}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3353 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3353 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-25", "doble_articulado": false, "id_norma": "233159", "numero_fuente": "38026", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-02", "vigencias": [{"desde": "2004-12-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenc