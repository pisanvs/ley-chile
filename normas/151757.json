{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6220689}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 1.301 de 29 de Julio de 1987, conforme art. 5&#xB0; transitorio C&#xF3;digo de Aguas determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a sector excluido y sector expropiado predio &quot;La Quinta&quot;, de la comuna de Cabrero, VIII Regi&#xF3;n; y Derechos Aprovechamiento Aguas que corresponden a parcelas N&#xB0;s. 1 a 3 y 6 a 12, sitios N&#xB0;s. 1 a 3 y 5 a 8 y Reserva Cora Casas patronales del Proyecto de Parcelaci&#xF3;n &quot;La Quinta&quot; formado por predio se&#xF1;alado. Los Derechos de Agua se extraen del Canal Za&#xF1;artu derivado del R&#xED;o Laja.</div><div class=\"p\">Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.-</div><br></div>", "i": 6220690}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6220691}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1301 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1301 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-29", "doble_articulado": false, "id_norma": "151757", "numero_fuente": "32835", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-01", "vigencias": [{"desde": "1987-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenci