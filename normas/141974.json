{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 40, DE 1987 </div></div>", "i": 6186943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 40 de 03 de marzo de 1987 se han aprobado, a contar del a&#xF1;o 1987, planes de estudio para el Tercer Nivel de Educaci&#xF3;n B&#xE1;sica y el Primer Ciclo de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica de Adultos que se indican, para ser aplicados por el Establecimiento Educacional Particular de Adultos &quot;Hermann Gmeiner&quot;, de Concepci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  La evaluaci&#xF3;n, promoci&#xF3;n y certificaci&#xF3;n de estudios del Plan de Educaci&#xF3;n General o Plan Com&#xFA;n, se regir&#xE1;n por las disposiciones vigentes sobre la materia. </div></div>", "i": 6186944}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 05 de Marzo de 1987.- Ren&#xE9; Salam&#xE9; Mart&#xED;n, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6186945}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "40 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-40 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 40, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-03-03", "doble_articulado": false, "id_norma": "141974", "numero_fuente": "32723", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-03-16", "vigencias": [{"desde": "1987-03-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-03-16", "f