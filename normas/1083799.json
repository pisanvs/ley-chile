{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">SE CREA EN EL INSTITUTO DE PREVISI&#xD3;N SOCIAL &quot;MESA DE TRABAJO SOBRE PERSONAS EN SITUACI&#xD3;N DE DISCAPACIDAD&quot;</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 9648690}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 546, de 13 de octubre de 2015, se crea en el Instituto de Previsi&#xF3;n Social la &quot;Mesa de Trabajo sobre Personas en Situaci&#xF3;n de Discapacidad&quot;, cuyo objetivo es promover la igualdad de oportunidades de las personas con discapacidad, seg&#xFA;n lo estipulado en el art&#xED;culo 4&#xBA; de la Ley N&#xBA; 20.422.</div><br></div>", "i": 9648691}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 6 de noviembre de 2015.- Patricio Coronado Rojo, Director Nacional.</div></div>", "i": 9648692}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "546 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-546 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARÍA DE PREVISIÓN SOCIAL", "INSTITUTO DE PREVISIÓN SOCIAL"], "titulo_norma": "SE CREA EN EL INSTITUTO DE PREVISIÓN SOCIAL \"MESA DE TRABAJO SOBRE PERSONAS EN SITUACIÓN DE DISCAPACIDAD\"", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-10-13", "doble_articulado": false, "id_norma": "1083799", "numero_fuente": "41306", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-11-13", "vigencias": [{"desde": "2015-11-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2015-11-13", "fin_vi