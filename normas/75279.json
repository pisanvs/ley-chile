{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6044264}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xB0;558, de 30 de junio de 1997, se expropi&#xF3; el lote de terreno N&#xB0;32, superficie 224 m2 respectivamente, rol de aval&#xFA;o 206-14, comuna de Longav&#xED;, para la obra Camino Longav&#xED;-El Tr&#xE1;nsito, Tramo Longav&#xED;-Chalet Quemado y se acord&#xF3; precio de indemnizaci&#xF3;n con su propietario Jorge Leopoldo Avila R&#xED;os, ascendente a la cantidad de $309.960.- </div></div>", "i": 6044265}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6044266}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "558", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-558"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "LONGAVI", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-06-30", "doble_articulado": false, "id_norma": "75279", "numero_fuente": "35843", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-08-16", "vigencias": [{"desde": "1997-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "GMR", "fecha_ingreso": "1997-09-10", "fecha_version": "1997-08-16", "fecha_actualizacion_texto": "1997-08-16", "tipo_tratado": ""}, "alertas": [], "alerta_gl