{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6264294}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 437 de 23 de Octubre de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se autoriza a don Rolando Contreras Elgueta, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro de territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6264295}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 23 de Octubre de 1985.- Francisco Navarro Ruiz, Secretario Regional Ministerial Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6264296}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "437 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-437 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-10-23", "doble_articulado": false, "id_norma": "165310", "numero_fuente": "32309", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-10-30", "vigencias": [{"desde": "1985-10-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-10-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-10-30",