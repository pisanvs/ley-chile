{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8677107}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alcalde I. Municipalidad de Renca, mediante Decreto No. 1581 de 12 de diciembre de 1986, dispone expropiar parte, conforme a decretos leyes 1.289 y 2.186, del terreno ubicado entre las calles Manuel Rodr&#xED;guez y Colo Colo, rol de aval&#xFA;o No. 544-20 aparentemente de propiedad de don Mario Segundo Morales Alfaro, para la apertura y ensanche de la Avda. Balmaceda. Deslindes: Norte, 14,50 m. (con resto predio); Sur: 14,50 (con calle Balmaceda); Oriente: 12,00 m. y, Poniente: 12,00 m. Indemnizaci&#xF3;n provisional $ 174.000.- fijada por la Comisi&#xF3;n Tasadora compuesta por los Sres. Jorge Cavagnaro Michelis; Nancy S&#xE1;nchez Sep&#xFA;lveda y Fernando Merino De la Cerda. Pago al contado con reajuste legal. </div></div>", "i": 8677108}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Alcalde.</div><br></div>", "i": 8677109}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1581", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1581"}], "organismos": ["MUNICIPALIDAD DE RENCA"], "titulo_norma": "EXTRACTOS DE EXPROPIACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-12-12", "doble_articulado": false, "id_norma": "140566", "numero_fuente": "32661", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-01-02", "vigencias": [{"desde": "1987-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-01-02", "fin_vigencia": "", "tipo_vers