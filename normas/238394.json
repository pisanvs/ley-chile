{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6527564}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA;346 de fecha 29 de abril de 2005, se expropi&#xF3; el lote de terreno N&#xBA;217, superficie 60 m&#xB2;, rol de aval&#xFA;o N&#xBA;237-39, comuna de Tolt&#xE9;n, para la obra &quot;Camino Ruta S-790, Sector Nueva Tolt&#xE9;n - L&#xED;mite Regional (Queule), tramo Km. 87,50000 a Km. 103,33500, correspondiente al Subtramo V, Km.</div><div class=\"p\">98,29000 a Km. 103,33500&quot;, IX Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietaria Delinda del Carmen Nahuelpan &#xD1;ancuan, ascendente a la cantidad de $212.531.</div><br></div>", "i": 6527565}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6527566}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "346 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-346 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-04-29", "doble_articulado": false, "id_norma": "238394", "numero_fuente": "38174", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-06-01", "vigencias": [{"desde": "2005-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "200