{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6435125}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decretos M.O.P. N&#xBA; 262 y 267, ambos de 15 de octubre 1991, se expropiaron los lotes de terreno N&#xBA;s.</div><div class=\"p\">32, 37, 45 y 46, superficies 764 m2., 253 m2., 1.577 m2. y 338 m2., roles de aval&#xFA;os 595-005, 595-008, 599-9 y 599-10, Comuna Copiap&#xF3;, para la obra Ruta 31-Ch, sector Copiap&#xF3;-Paipote, tramo doble calzada, y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Olga Zepeda Viera, Bernardo Segundo Zambra; Mar&#xED;a D&#xED;az G. y Petronila Rojas, ascendente a las cantidades de&nbsp; $ 6.324.850, $ 2.430.018, $ 7.966.112 y $ 5.055.628, respectivamente. </div></div>", "i": 6435126}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6435127}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "262", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-262"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-10-15", "doble_articulado": false, "id_norma": "213479", "numero_fuente": "34106", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-02", "vigencias": [{"desde": "1991-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "f