{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACION DE INMUEBLE QUE SE&#xD1;ALA </div></div>", "i": 6027400}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n N&#xBA;1185 de 26 de noviembre de 1996 de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L N&#xBA; 2.186 de 1978, del inmueble ubicado en calle Chacabuco S/N&#xBA;, presento rol de aval&#xFA;os N&#xBA; 143-1(ex-55) comuna de Alhu&#xE9;, de aparente dominio de la Sucesi&#xF3;n Felipe Tapia Tapia. Comisi&#xF3;n integrada por peritos Sres. Carlos Pe&#xF1;a Vermejo, ingeniero civil, ren&#xE9; Ureta Koster, arquitecto y Jos&#xE9; Miguel Altenhoff Aenishanslin seg&#xFA;n informe de 30 de agosto de 1996 fij&#xF3; monto provisional de indemnizaci&#xF3;n en $17.700.000.- pagadera al contado.</div><br></div>", "i": 6027401}, {"t": "<div><div class=\"p\">Director SERVIU Metropolitano.</div><br></div>", "i": 6027402}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1185", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1185"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "ORDENA EXPROPIACION DE INMUEBLE QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "INMUEBLE", "ALHUE", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["extracto"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-11-26", "doble_articulado": false, "id_norma": "50078", "numero_fuente": "35655", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-01-02", "vigencias": [{"desde": "1997-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-01-02", "fin_vigen