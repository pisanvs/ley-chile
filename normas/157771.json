{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 230, DE 1983 </div></div>", "i": 6239500}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 321 del 10 de Junio de 1985 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n No. 230, de 1983, de la misma Subsecretar&#xED;a que autoriz&#xF3; a Pesquera San Francisco S.A. domiciliada en Santiago, para operar la embarcaci&#xF3;n &quot;Eicomar I&quot;, en orden a fijarle como zona de operaci&#xF3;n el litoral comprendido entre los paralelos 27&#xB0; a 40&#xB0; de latitud Sur. </div></div>", "i": 6239501}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de Junio de 1985.- Roberto Verdugo Gorm&#xE1;z, Subsecretario de Pesca.</div><br></div>", "i": 6239502}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "321", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-321"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 230, DE 1983", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-10", "doble_articulado": false, "id_norma": "157771", "numero_fuente": "32216", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-07-08", "vigencias": [{"desde": "1985-07-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-07-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-07-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_