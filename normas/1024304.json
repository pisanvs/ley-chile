{"html": [{"t": "<div><div class=\"p\">COMPLEMENTA RESOLUCI&#xD3;N N&#xBA; 143 EXENTA, DE 2009, EN T&#xC9;RMINOS QUE INDICA</div></div>", "i": 9130910}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 47, de 1 de abril de 2011, que:</div><div class=\"p\">&nbsp; &nbsp;  Complementa <a href=\"https://www.leychile.cl/Navegar?idNorma=1006614&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta SII N&#xBA; 143, del 24 de septiembre de 2009</a>, que autoriz&#xF3; para operar un sistema electr&#xF3;nico de intermediaci&#xF3;n en la venta de colaciones a Accor Services Chile, actualmente Edenred Chile S.A.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de abril de 2011.</div></div>", "i": 9130911}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "47 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-47 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "COMPLEMENTA RESOLUCIÓN Nº 143 EXENTA, DE 2009, EN TÉRMINOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-04-01", "doble_articulado": false, "id_norma": "1024304", "numero_fuente": "39930", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-04-07", "vigencias": [{"desde": "2011-04-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "