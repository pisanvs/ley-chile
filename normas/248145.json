{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 10.827 EXENTA, DE 2005 </div></div>", "i": 6564377}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 10.827, de 30 de diciembre de 2005, se ha aprobado a los Colegios Pumahue-Manquecura de la Sociedad Desarrollos Educacionales S.A., un plan de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2006.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media de los Subsectores que se indican en la presente resoluci&#xF3;n.</div><br></div>", "i": 6564378}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de marzo de 2006.- Xavier Vanni Cucurella, Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6564379}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10827 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-10827 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 10.827 EXENTA, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-30", "doble_articulado": false, "id_norma": "248145", "numero_fuente": "38415", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-16", "vigencias": [{"desde": "2006-03-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-03-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-03-16", "fin_vigencia": "", "tipo_version": "3"}], "event