{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO N&#xBA; 3.559 EXENTO, DE 2008</div><br><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 16 exento.- Rancagua, 6 de enero de 2009. </div></div>", "i": 6931030}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I.- Modif&#xED;quese el decreto exento N&#xBA; 3.559 de fecha 22 de diciembre de 2008, en el siguiente sentido:</div><br><div class=\"p\">&nbsp; &nbsp;  Donde dice: (Treinta y cuatro mil quinientos cuarenta y cuatro pesos) Debe decir: (Treinta y dos mil quinientos cuarenta y cuatro pesos).</div><br><div class=\"p\">&nbsp; &nbsp;  II.- Publ&#xED;quese la presente modificaci&#xF3;n a la &quot;Ordenanza Municipal para determinar Tarifas de Aseo, Cobro y Exenciones parciales o totales de &#xE9;stas&quot;, contenidas en el presente decreto exento en la p&#xE1;gina web municipal.</div><br></div>", "i": 6931031}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, publ&#xED;quese, notif&#xED;quese, comun&#xED;quese y arch&#xED;vese.- Eduardo Soto Romero, Alcalde.- Carlos Morales Lara, Secretario Municipal.</div><br></div>", "i": 6931032}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "16 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-16 EXENTO"}], "organismos": ["MUNICIPALIDAD DE RANCAGUA"], "titulo_norma": "MODIFICA DECRETO Nº 3.559 EXENTO, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-01-06", "doble_articulado": false, "id_norma": "285545", "numero_fuente": "39267", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-01-21", "vigencias": [{"desde": "2009-01-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"