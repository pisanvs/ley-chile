{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 944 EXENTO, DE 2003 </div></div>", "i": 6454385}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 944 de fecha 24 de noviembre de 2003, de Educaci&#xF3;n, se declara aprobada al Instituto Profesional Carlos Casanueva la carrera profesional que se indica:</div><div class=\"p\">Carrera:&nbsp; &nbsp; &nbsp; &nbsp; Psicopedagog&#xED;a</div><div class=\"p\">T&#xED;tulo</div><div class=\"p\">Profesional:&nbsp; &nbsp; Psicopedagogo.</div><br><div class=\"p\">&nbsp; &nbsp;  Dicha carrera podr&#xE1; ser impartida en jornada diurna en su Sede de Santiago, a contar del primer semestre del a&#xF1;o 2004, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6454386}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de diciembre de 2003.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6454387}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "944 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-944 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 944 EXENTO, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-11-24", "fecha_derogacion": "2021-12-31", "doble_articulado": false, "id_norma": "218971", "numero_fuente": "37736", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-12-16", "vigencias": [{"desde": "2021-12-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-12-16", "hasta": "2021-12-30",