{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9312152}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. (Exento) N&#xBA;2534, de 29 de octubre de 2012, y de conformidad a lo dispuesto en el Art. 105 del DFL. MOP. N&#xBA; 850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA; 7, superficie 1.372 m2., Rol N&#xBA; 115-16, Comuna de San Pablo, para la obra &quot;MEJORAMIENTO RUTA U-16, SECTOR BIF. QUILACAHU&#xCD;N &#x2013; PUENTE MOMBERG, TRAMO KM. 12,50000 A KM. 22,30800&quot;, X Regi&#xF3;n. La comisi&#xF3;n de peritos integrada por Leopoldo Ram&#xF3;n Schumacher Guarda, Juan Samuel Barrientos Bahamonde y Juan Celestino Giovannini Mansilla, fij&#xF3; el valor de tasaci&#xF3;n con fecha 6 de octubre de 2010, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietaria MAR&#xCD;A ELBA KEMP MART&#xCD;NEZ, en la cantidad de $1.203.584.-, suma que se pagar&#xE1; al contado.- </div></div>", "i": 9312153}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9312154}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2534 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2534 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-10-29", "doble_articulado": false, "id_norma": "1045769", "numero_fuente": "40410", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-11-15", "vigencias": [{"desde": "2012-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-11-