{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br></div>", "i": 6227863}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 38, del 25 de Agosto de 1986 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se autoriza a don: Mario Enrique Becerra Pavez, para efectuar todo tipo&apos; de servicios de transportes de pasajeros, por calles y caminos, dentro del Territorio Nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos Urbanos de Locomoci&#xF3;n Colectiva de pasajeros.</div><br></div>", "i": 6227864}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rancagua, 05 de Agosto de 1986.- Juan Latife Saadi, Secretario Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n Subrogante. </div></div>", "i": 6227865}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "38 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-38 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-08-25", "doble_articulado": false, "id_norma": "154091", "numero_fuente": "32559", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-08-28", "vigencias": [{"desde": "1986-08-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-08-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-08-28