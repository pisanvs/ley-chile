{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA </div></div>", "i": 6593685}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n ministerial T.R. N&#xBA; 58, de 26 de</div><div class=\"p\">septiembre de 2006, se cancel&#xF3; la personalidad jur&#xED;dica</div><div class=\"p\">de la &quot;Asociaci&#xF3;n Nacional de Energ&#xED;a Solar y Renovables</div><div class=\"p\">No Convencionales Asociaci&#xF3;n Gremial ANES Chile&quot;,</div><div class=\"p\">inscrita bajo el N&#xBA; 3618 por haberse configurado la</div><div class=\"p\">causal contemplada en la letra a), n&#xFA;mero 2, del</div><div class=\"p\">art&#xED;culo 18 del decreto ley N&#xBA; 2.757, de 1979. </div></div>", "i": 6593686}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Javiera Estrada Quezada, Jefe Unidad Asociaciones Gremiales y Martilleros.</div><br></div>", "i": 6593687}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "58", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-58"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PERSONALIDAD JURIDICA", "ASOCIACION NACIONAL DE ENERGIA SOLAR Y RENOVABLES NO CONVENCIONALES ASOCIACION GREMIAL ANES CHILE", "CANCELACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-09-26", "doble_articulado": false, "id_norma": "256463", "numero_fuente": "38641", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-12-18", "vigencias": [{"desde": "2006-12-18", "hasta": "", "tipo_version": "3", "ti