{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 273, DE 1991 </div></div>", "i": 6055017}, {"t": "<div><div class=\"p\">Por Decreto Supremo Exento de Educaci&#xF3;n No. 273, de 01 de octubre de 1991, se ha aprobado para el Colegio Wessex School de Concepci&#xF3;n, un Plan de Estudio Especial para ser aplicado de 1&#xB0; a 6&#xB0; a&#xF1;o b&#xE1;sico en 1992 y progresivamente en 7&#xB0; a&#xF1;o en 1993 y 8&#xB0; a&#xF1;o en 1994.</div><div class=\"p\">Adem&#xE1;s, se aprueban los Programas Especiales de Estudio para las asignaturas: Clubes, Ingl&#xE9;s y Filosof&#xED;a Infantil. </div></div>", "i": 6055018}, {"t": "<div><div class=\"p\">Santiago, 30 de Diciembre de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6055019}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "273 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-273 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 273, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-10-01", "doble_articulado": false, "id_norma": "79491", "numero_fuente": "34230", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-03-28", "vigencias": [{"desde": "1992-03-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-03-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-03-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PGA", "fecha_ingreso": "1997-