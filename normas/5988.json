{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; 4.o A&#xD1;O HUMANIDADES LICEO DE NI&#xD1;AS DE LOS ANGELES N&#xFA;m. 329.- Santiago, 29 de Julio de 1932.- Teniendo presente que por un error se consulta en 07|03|04&#xE1;) un cuarto A&#xF1;o de Humanidades para el Liceo de Ni&#xF1;as de Angol, y que el funcionamiento de ese curso no es necesario en dicho colegio, se dicta el siguiente, Decreto-ley:</div><br></div>", "i": 7123867}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Decl&#xE1;rase que el curso de cuarto A&#xF1;o de Humanidades, que se consulta en la Ley de Presupuestos vigente en 07|03|04|&#xE1;) para el Liceo de Ni&#xF1;as de Angol, es para el Liceo de Ni&#xF1;as de Los Angeles.</div><br></div>", "i": 7123868}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de Leyes y Decretos del Gobierno.- CARLOS DAVILA.- C. Soto.</div><br></div>", "i": 7123869}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "329", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-329"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "4.o AÑO HUMANIDADES LICEO DE NIÑAS DE LOS ANGELES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1932", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-07-29", "doble_articulado": false, "id_norma": "5988", "numero_fuente": "16357", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-08-24", "vigencias": [{"desde": "1932-08-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1932-08-24", "fin_vigencia": ""}, "