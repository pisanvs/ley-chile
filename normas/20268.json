{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 120, DE 1991 </div></div>", "i": 5941447}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 120, de 10 de junio de 1991, se ha autorizado al Colegio San Rafael de Santiago para aplicar, a partir del presente a&#xF1;o escolar, el programa de estudio de la asignatura de Lat&#xED;n para 7&#xB0; y 8&#xB0; a&#xF1;o b&#xE1;sico aprobado por decreto supremo exento de Educaci&#xF3;n N&#xB0; 370, de 1990. </div></div>", "i": 5941448}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 18 de Junio de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5941449}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "120 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-120 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 120, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO SAN RAFAEL", "SANTIAGO", "PROGRAMA ESTUDIO", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-06-10", "doble_articulado": false, "id_norma": "20268", "numero_fuente": "34009", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-07-05", "vigencias": [{"desde": "1991-07-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-07-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-07-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1991-07-05", "fecha_actualizacion_texto": "1991-07-05", "tip