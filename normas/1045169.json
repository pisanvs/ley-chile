{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE ORDENANZA N&#xBA; 120, DE 2012</div></div>", "i": 9309741}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por ordenanza N&#xBA; 120, de 23 de octubre de 2012, se modifica la ordenanza N&#xBA; 22, de 28 de diciembre de 2001, &quot;Ordenanza Local Sobre Derechos Municipales&quot;, que rige para el a&#xF1;o 2012, cuyo texto refundido y sistematizado fue aprobado por <a href=\"https://www.leychile.cl/Navegar?idNorma=1035559&amp;idParte=&amp;idVersion=\">decreto alcaldicio Ex. N&#xBA; 2.466, de 26 de diciembre de 2011</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo se encuentra en la p&#xE1;gina web municipal, Transparencia Activa en Carpeta Marco Normativo Aplicable/Ordenanzas/Derechos/Sobre Derechos Municipales.- </div></div>", "i": 9309742}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  El Alcalde.</div></div>", "i": 9309743}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "120", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "Ordenanza-120"}], "organismos": ["MUNICIPALIDAD DE PROVIDENCIA"], "titulo_norma": "EXTRACTO DE ORDENANZA Nº 120, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-10-23", "doble_articulado": false, "id_norma": "1045169", "numero_fuente": "40398", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-10-30", "vigencias": [{"desde": "2012-10-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-10-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-10-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendien