{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6503650}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.066, de 27 de octubre de 2004, de esta Subsecretar&#xED;a, rectif&#xED;case el numeral 3.- de la resoluci&#xF3;n N&#xBA; 1.983 de 2004, de esta Subsecretar&#xED;a, que otorg&#xF3; a JOSE ARMANDO RODRIGUEZ ENCALADA, una autorizaci&#xF3;n de acuicultura para una piscicultura ubicada en r&#xED;o Picaflor, cerro Guacho, XI Regi&#xF3;n, en el sentido de agregar que las aguas requeridas para las actividades deber&#xE1;n provenir de estero sin nombre, adem&#xE1;s del r&#xED;o Picaflor ya indicado. </div></div>", "i": 6503651}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de octubre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6503652}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3066 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3066 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-27", "doble_articulado": false, "id_norma": "232131", "numero_fuente": "38003", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-11-05", "vigencias": [{"desde": "2004-11-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-11-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-11-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MO