{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6064226}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta No. 184 de 09 de marzo de 1990 del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriz&#xF3; al se&#xF1;or Aquilino Silva Obando, para efectuar servicio internacional de transporte terrestre de pasajeros entre Puerto Natales (Chile) y R&#xED;o Gallegos (Argentina) por el Paso de Laurita con dos frecuencias semanales, de ida y vuelta.- </div></div>", "i": 6064227}, {"t": "<div><div class=\"p\">Sergio Gonz&#xE1;lez Tagle, Subsecretario de Transportes. </div></div>", "i": 6064228}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "184 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-184 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-09", "doble_articulado": false, "id_norma": "83112", "numero_fuente": "33678", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-05-25", "vigencias": [{"desde": "1990-05-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-05-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-05-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MNV", "fecha_ingreso": "1998-01-06", "fecha_version": "1990-05-25", "fecha_actualizacion_texto": "1990-05-25", "tipo_tratad