{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DEROGA DECRETO N&#xB0; 663 EXENTO, DE 1993</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 35 exento.- Santiago, 27 de Enero de 1994.- Visto: Lo dispuesto en las Leyes N&#xB0;s 18.956 y 18.962, Decreto Supremo de Educaci&#xF3;n N&#xB0; 2.039, de 1980; resoluci&#xF3;n N&#xB0; 55, de 1992 y Dictamen N&#xB0; 012962, de 1993, ambos de la Contralor&#xED;a General de la Rep&#xFA;blica y en los art&#xED;culos 32 N&#xB0; 8 y 35 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile,</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 8667295}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico: Der&#xF3;gase, a contar desde su vigencia el decreto supremo exento de Educaci&#xF3;n N&#xB0; 663 de 9 de diciembre de 1993.</div><br></div>", "i": 8667296}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese y publ&#xED;quese.- Por orden del Presidente de la Rep&#xFA;blica, Jorge Arrate mac Niven, Ministro de Educaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8667297}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "35", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-35"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "DEROGA DECRETO N° 663 EXENTO, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "COANIL", "CORPORACION AYUDA NI O LIMITADO", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-01-27", "doble_articulado": false, "id_norma": "19824", "numero_fuen