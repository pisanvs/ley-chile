{"html": [{"t": "<div><div class=\"p\">MODIFICA ANEXO 51-7 DEL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10339363}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 1.349 de 18.05.2022, del Director Nacional de Aduanas (S), se modifica el <a href=\"https://www.leychile.cl/Navegar?idNorma=248540&amp;idParte=&amp;idVersion=\">Compendio de Normas Aduaneras</a>, en el siguiente sentido:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Reempl&#xE1;zase, en el Anexo 51-7, relativo a Operadores, el nombre del Operador que tiene asociado el c&#xF3;digo P10 por &quot;Marina Oxxean Puerto Montt SpA&quot;.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10339364}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gustavo Poblete, Director Nacional de Aduanas (S).</div><br></div>", "i": 10339365}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1349 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1349 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA ANEXO 51-7 DEL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2138291", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-05-18", "doble_articulado": false, "id_norma": "1176991", "numero_fuente": "43270", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicaci