{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9264955}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.430, de 29 de mayo de 2012, de esta Subsecretar&#xED;a de Pesca, modif&#xED;case el numeral 4&#xBA; de la resoluci&#xF3;n exenta N&#xBA; 1.393 de 2012, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del proyecto denominado &quot;Determinaci&#xF3;n de la distribuci&#xF3;n espacial de jurel entre la V y X Regiones, desde las 5 a 600 mn de la costa, a&#xF1;o 2012&quot; en el sentido de incorporar a la nave &quot;Vulcano&quot;, en calidad de suplente de la nave titular &quot;Don Alfonso&quot;, ambas de propiedad del armador Blumar S.A.</div></div>", "i": 9264956}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de mayo de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9264957}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1430 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1430 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-29", "doble_articulado": false, "id_norma": "1040869", "numero_fuente": "40284", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-11", "vigencias": [{"desde": "2012-06-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-06-11", "fin_vigencia": ""}, "vige