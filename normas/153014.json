{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6224910}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alcaldesa de la I. Municipalidad de Providencia, mediante Decreto No. Ex. 292 de 09 de Mayo de 1986, dispone expropiaci&#xF3;n parcial, conforme Decreto Supremo No. 458, de Vivienda, de 1976 y Decretos Leyes 1.289, 2.186 y 3.464, de inmueble ubicado en Av. Bilbao No. 2393, Rol de Aval&#xFA;os No. 3235-8, aparentemente de propiedad de do&#xF1;a Teresa Soto Basoalto, para el ensanche de Av. Bilbao. Deslindes parte expropiada: Al Norte, 3,85 mts. Av. Bilbao; al Sur, 3,85 mts. resto de la propiedad que se expropia; al Oriente, 5 mts. Rol No. 3235-25; al Poniente, 5 mts. Rol No. 3235-7.</div><div class=\"p\">Indemnizaci&#xF3;n provisional $ 239.500.</div><br></div>", "i": 6224911}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Carmen Grez de Anrique, Alcaldesa.- Jorge O. Herrera Ram&#xED;rez, Secretario Abogado Municipal. </div></div>", "i": 6224912}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "292 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-292 EXENTO"}], "organismos": ["MUNICIPALIDAD DE PROVIDENCIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-05-09", "doble_articulado": false, "id_norma": "153014", "numero_fuente": "32537", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-08-01", "vigencias": [{"desde": "1986-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-08-01", "fin_vigencia": "", "t