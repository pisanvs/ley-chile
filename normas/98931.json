{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 414&nbsp; EXENTO, DE 1998 </div></div>", "i": 6110490}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 414, de fecha 23 de marzo de 1998, del Ministerio de Educaci&#xF3;n, se dej&#xF3; sin efecto la autorizaci&#xF3;n de funcionamiento de las sedes N&#xBA; 1 de Talca; N&#xBA; 2 de Temuco y N&#xBA; 4 de Valdivia del Centro de Formaci&#xF3;n T&#xE9;cnica Pit&#xE1;goras, que no se encuentran funcionando y la aprobaci&#xF3;n de sus respectivas carreras que se se&#xF1;alan en el presente documento.</div><br></div>", "i": 6110491}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de mayo de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6110492}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "414 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-414 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 410 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO DE FORMACION TECNICA", "PITAGORAS", ". TALCA", "TEMUCO", "VALDIVIA", "SEDE", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-03-23", "fecha_derogacion": "2021-12-31", "doble_articulado": false, "id_norma": "98931", "numero_fuente": "36063", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-05-13", "vigencias": [{"desde": "2021-12-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-05-13", "hasta": "2021-12-30", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2021-12-31", "fin_vigen