{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6490732}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.762, de 1 de julio de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a VERONICA DEL CARMEN BARO INOSTROZA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Avenida Los Aromos, manzana E, sitio 19, sector Agpia, Alto Hospicio, Iquique, I Regi&#xF3;n, donde podr&#xE1; procesar, en las l&#xED;neas de elaboraci&#xF3;n de cocido, fresco-enfriado, fresco-refrigerado, seco salado y deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6490733}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de julio de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6490734}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1762 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1762 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-07-01", "fecha_derogacion": "2005-03-18", "doble_articulado": false, "id_norma": "228603", "numero_fuente": "37928", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-08-05", "vigencias": [{"desde": "2005-03-18", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-08-05", "hasta": "2005-03-17", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "20