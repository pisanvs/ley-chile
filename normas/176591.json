{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 370&nbsp; EXENTO, DE 2000 </div></div>", "i": 6304313}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 370, de 20 de septiembre de 2000, rectif&#xED;case el art&#xED;culo 1&#xBA; del decreto exento N&#xBA; 103, de 4 de abril de 2000, en el siguiente sentido:</div><br><div class=\"p\">Dice:&nbsp; &apos;&apos; Registro de Institutos Profesionales en que se encuentra inscrito con el N&#xBA; 77&apos;&apos;.</div><br><div class=\"p\">Debe decir: &apos;&apos; Registro de Institutos Profesionales en que se encuentra inscrito con el N&#xBA; 55&apos;&apos;.</div><br></div>", "i": 6304314}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de octubre de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6304315}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "370 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-370 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 370 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-20", "doble_articulado": false, "id_norma": "176591", "numero_fuente": "36785", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-12", "vigencias": [{"desde": "2000-10-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-10-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-10-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text