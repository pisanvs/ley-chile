{"html": [{"t": "<div><br><div class=\"p\">ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xB0; 1.537</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Comit&#xE9; Ejecutivo de este Banco Central de Chile en su Sesi&#xF3;n N&#xB0; 1.537, celebrada el 13 de Octubre de 1983, adopt&#xF3; los siguientes acuerdos:</div><br></div>", "i": 6320565}, {"t": "<div><br><div class=\"p\">1537-O7-831013 - Modifica Cap&#xED;tulo II.B.2.4 del Compendio de Normas Financieras</div><br><div class=\"p\">Se acord&#xF3; reemplazar en el N&#xB0; 2 del Capitulo II.B.2.4 &quot;L&#xED;nea de Cr&#xE9;dito para la Construcci&#xF3;n de Nuevas Viviendas y Ejecuci&#xF3;n de Nuevas Obras de Ingenier&#xED;a&quot;, la fecha &quot;30 de Octubre de 1983&quot; por &quot;30 de Noviembre de 1983&quot;.</div><br></div>", "i": 6320566}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de Octubre de 1983.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6320567}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1537", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1537"}, {"tipo": "5", "numero": "1537-07", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1537-07"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION N° 1.537", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1983-10-13", "doble_articulado": false, "id_norma": "181343", "numero_fuente": "31696", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1983-10-17", "vigencias": [{"desde