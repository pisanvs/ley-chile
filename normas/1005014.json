{"html": [{"t": "<div><br><div class=\"p\">MODIFICA CONCESI&#xD3;N DE ACUICULTURA</div><br></div>", "i": 8768401}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante Resoluci&#xF3;n 1.220, de 9 de junio de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div><br><div class=\"p\">&nbsp; &nbsp;  I.- Modif&#xED;case la resoluci&#xF3;n 1.534, de 19 de agosto de 2003, del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina, en el sentido de reemplazar el p&#xE1;rrafo 4 por el siguiente:</div><div class=\"p\">&nbsp; &nbsp;  &quot;4.- El concesionario deber&#xE1; dar cabal cumplimiento al Proyecto T&#xE9;cnico y Cronograma de Actividades, aprobado por resoluci&#xF3;n exenta 1.471, de 1 de julio de 2003, modificada por la resoluci&#xF3;n exenta 242, de 19 de enero de 2009, ambas del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, Subsecretar&#xED;a de Pesca.&quot;</div></div>", "i": 8768402}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de julio de 2009.- Por la Sra. Subsecretaria, Humberto Ram&#xED;rez Navarro, Subjefe Subsecretar&#xED;a de Marina.</div><br></div>", "i": 8768403}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1220", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-1220"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "MODIFICA CONCESIÓN DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-06-09", "doble_articulado": false, "id_norma": "1005014", "numero_fuente": "39436", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-08-13