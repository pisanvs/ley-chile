{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Redencion de Censos Lei N&#xFA;m. 1,063.- Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948306}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Las cantidades que ingresen anualmente al Tesoro Nacional por redencion de censos se destinar&#xE1;n a la amortizacion estraordinaria de la deuda p&#xFA;blica interna.</div><div class=\"p\">&nbsp; &nbsp; La amortizacion se har&#xE1; por sorteo o por propuestas que no excedan de la par, en proporcion al saldo de cada empr&#xE9;stito, comput&#xE1;ndose el de tres por ciento por el cincuenta por ciento de su valor.</div><br><br></div>", "i": 5948307}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 31 de Agosto de 1898.- FEDERICO ERRAZURIZ.- R. Sotomayor.</div><br></div>", "i": 5948308}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1063", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1063"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "REDENCION DE CENSOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENSOS", "REDENCION", "DEUDA PUBLICA INTERNA", "DESTINACION", "CANTIDADES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-08-31", "doble_articulado": false, "id_norma": "22388", "numero_fuente": "6093", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-09-03", "vigencias": [{"desde": "1898-09-03", "hasta": "", "t