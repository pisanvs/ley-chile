{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,378.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 9050963}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- La Empresa de los Ferrocarriles permitir&#xE1; el arrastre con los trenes de la Empresa, libre de todo pago, del coche-museo destinado por la Direccion Jeneral de los Servicios Agr&#xED;colas a las escursiones de estudio y propaganda de los establecimientos de ense&#xF1;anza y fomento agr&#xED;colas.&quot; </div></div>", "i": 9050964}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a quince de mayo de mil novecientos dieciocho.- Juan Luis Sanfuentes.- Ramon Briones Luco. </div></div>", "i": 9050965}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3378", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3378"}], "organismos": ["MINISTERIO DE FERROCARRILES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1918-05-15", "doble_articulado": false, "id_norma": "141104", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1918-05-17", "vigencias": [{"desde": "1918-05-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1918-05-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1918-05-17", "fin_vigencia": "", "tipo_