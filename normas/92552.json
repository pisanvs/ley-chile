{"html": [{"t": "<div><div class=\"p\">PRORROGA AUTORIZACION QUE INDICA </div></div>", "i": 8321977}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 589 de 26 de Mayo de 1989 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por un a&#xF1;o a contar del 04 de marzo de 1989 el plazo otorgado a Pesquera San Miguel Limitada, R.U.T. No. 81.740.200-3, domiciliada en Talcahuano, para empezar a operar en la planta elaboradora autorizada por la resoluci&#xF3;n No. 238, de 1988, de esta Subsecretar&#xED;a en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8321978}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 26 de Mayo de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8321979}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "589", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-589"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-26", "doble_articulado": false, "id_norma": "92552", "numero_fuente": "33384", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-05-30", "vigencias": [{"desde": "1989-05-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-05-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-05-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION