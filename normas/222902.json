{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 330.- Santiago, 20 de Mayo de 1931.- Vistas las facultades que me confiere la ley n&#xFA;mero 4,945, de 6 de febrero del presente a&#xF1;o,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 6470762}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Personal de la Administraci&#xF3;n P&#xFA;blica que se</div><div class=\"p\">retire voluntariamente del servicio, no tendr&#xE1; derecho a</div><div class=\"p\">la indemnizaci&#xF3;n de desahucio a que se refiere el</div><div class=\"p\">art&#xED;culo 89 del Estatuto Administrativo, salvo que tenga mas de veinte a&#xF1;os de servicios o que en el decreto de aceptaci&#xF3;n de la renuncia se le reconozca tal derecho. </div></div>", "i": 6470763}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese Raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- C. IBA&#xD1;EZ C.- Carlos Castro Ruiz. </div></div>", "i": 6470764}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "330", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-330"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-05-20", "doble_articulado": false, "id_norma": "222902", "numero_fuente": "15984", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-05-29", "vigencias": [{"desde": "1931-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1931-05-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci