{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PENSION Lei n&#xFA;m. 330.-Santiago, a 15 de Enero de 1896.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br><br><br></div>", "i": 5947549}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, a do&#xF1;a Carolina i do&#xF1;a Virjinia Teresa Vivar, hermanas del teniente coronel don Bartolom&#xE9; i del capitan don Pedro Antonio Vivar, muertos en servicio del pais, el goce de la pension que se concedi&#xF3; por lei de 30 de Setiembre de 1890 a su hermana do&#xF1;a Mar&#xED;a Vivar, de la que disfrutar&#xE1;n con arreglo a la lei de montep&#xED;o militar.</div><br><br></div>", "i": 5947550}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.-JORJE MONTT.- Luis Barros Borgo&#xF1;o. </div></div>", "i": 5947551}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "330", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-330"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAROLINA VIVAR", "VIRGINIA TERESA VIVAR", "MONTEPIO", "MILITAR", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-01-15", "doble_articulado": false, "id_norma": "22181", "numero_fuente": "5321", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1896-01-29", "vigencias": [{"desde": "1896-01-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "v