{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 22, DE 2000 </div></div>", "i": 6257913}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA; 22, de 1&#xBA; de marzo del a&#xF1;o 2000, se aprob&#xF3; la reforma parcial al estatuto de la Cooperativa de Servicios M&#xFA;ltiples Quillay Limitada, de sigla Quillay Servicios Limitada; en los t&#xE9;rminos que da testimonio la escritura p&#xFA;blica suscrita con fecha 31 de enero de 2000, ante el Notario P&#xFA;blico de la ciudad de Santiago, Arturo Carvajal Escobar.</div><br></div>", "i": 6257914}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6257915}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "22", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-22"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 22, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-03-01", "doble_articulado": false, "id_norma": "163282", "numero_fuente": "36628", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-31", "vigencias": [{"desde": "2000-03-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici