{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8296035}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.153, de 20 de Junio de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, cad&#xFA;case parcialmente la Resoluci&#xF3;n N&#xB0; 357, de 1989, de esta Subsecretar&#xED;a que autoriz&#xF3; a PESQUERA COLOSO S.A., para desarrollar actividades pesqueras extractivas con la nave &quot;Aventurero&quot;, s&#xF3;lo en lo que se refiere a la autorizaci&#xF3;n para extraer Merluza com&#xFA;n, Congrio colorado, Congrio dorado y Congrio negro, en el litoral comprendido entre la V y X Regiones, en virtud de lo se&#xF1;alado en el art&#xED;culo 143, letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8296036}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 20 de Junio de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8296037}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1153", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1153"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA COLOSO S.A", "PESCA", "CADUCIDAD", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-06-20", "doble_articulado": false, "id_norma": "36372", "numero_fuente": "35506", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-07-03", "vigencias": [{"desde": "1996-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-07-03"