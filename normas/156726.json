{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6236576}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 142, de 19 de enero de 2000 de esta Subsecretar&#xED;a, ot&#xF3;rgase a PESQUERA BALZAK S.A., una ampliaci&#xF3;n de plazo para reanudar operaciones con la nave &apos;&apos;Sebasti&#xE1;n I&apos;&apos;, en raz&#xF3;n de haberse acreditado una circunstancia de fuerza mayor.</div><div class=\"p\">&nbsp; &nbsp;  Pesquera Balzak S.A., deber&#xE1; reanudar operaciones con la nave &apos;&apos;Sebasti&#xE1;n I&apos;&apos; dentro del plazo de un a&#xF1;o contado a partir de noviembre de 1999.</div><br></div>", "i": 6236577}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de enero de 2000.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 6236578}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "142", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-142"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-01-19", "fecha_derogacion": "2003-03-04", "doble_articulado": false, "id_norma": "156726", "numero_fuente": "36592", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-02-18", "vigencias": [{"desde": "2003-03-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2000-02-18", "hasta": "2003-03-03", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2003-03-04", "fin_vigencia": ""}, "vigencias_version_norma": [