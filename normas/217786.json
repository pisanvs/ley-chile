{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 59 EXENTA, DE 2003 </div></div>", "i": 6450277}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Res. SII Ex. N&#xBA; 59, del 15 de octubre de 2003, se &quot; Crea Departamento de Asistencia al Contribuyente y fija su Dependencia, Atribuciones, Responsabilidades y Obligaciones&quot; .</div><div class=\"p\">Esta resoluci&#xF3;n regir&#xE1; a contar de la fecha de publicaci&#xF3;n de su extracto en el Diario Oficial. El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra incluido en el sitio Web del Servicio de Impuestos Internos en Internet, cuya direcci&#xF3;n es http://www.sii.cl y adem&#xE1;s, se publicar&#xE1; en el bolet&#xED;n del Servicio del mes de noviembre de 2003.-</div><br></div>", "i": 6450278}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Toro Rivera, Director.</div><br></div>", "i": 6450279}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "59 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-59 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 59 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SERVICIO DE IMPUESTOS INTERNOS", "DEPARTAMENTO DE ASISTENCIA AL CONTRIBUYENTE", "CREACION", "DEPENDENCIA", "ATRIBUCIONES", "RESPONSABILIDADES", "OBLIGACIONES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-15", "doble_articulado": false, "id_norma": "217786", "numero_fuente": "37720", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-11-26", "vigencias": [{"desde": "2003-11-26", "hasta": "", "tipo_version": "3", "tipo_ve