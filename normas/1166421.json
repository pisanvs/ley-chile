{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10275973}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xBA; 1.002, de 23 septiembre 2021, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos que indica en condiciones que se&#xF1;ala, relativas al Empalme de Uni&#xF3;n Domiciliaria a Alcantarillado, calle Los Calafates en la ciudad de Coyhaique, y autoriz&#xF3; empresa contratista Mario Jaramillo Gallardo para realizar siguiente intervenci&#xF3;n en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - Corte parcial de calle Los Calafates, frente al n&#xFA;mero 1165 (entre calle Las Lumas y Los Notros), por un plazo de 21 d&#xED;as corridos desde el d&#xED;a 23-09-2021.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10275974}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andrea Mac&#xED;as Palma, Gobernadora Regional, Gobierno Regional de Ays&#xE9;n.- Ximena Guti&#xE9;rrez Jaramillo, Asesora Jur&#xED;dica, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10275975}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1002 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1002 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2024053", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-09-23", "doble_articulado": false, "id_norma": "1166421", "numero_fuente": "43077", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-10-14", "vigencias": [{"desde