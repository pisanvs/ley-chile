{"html": [{"t": "<div><br><div class=\"p\">DECLARACI&#xD3;N JURADA ANUAL SOBRE RETIROS DE EXCEDENTES DE LIBRE DISPOSICI&#xD3;N</div></div>", "i": 9335411}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 25, del 22 de febrero de 2013.</div><br><div class=\"p\">&nbsp; &nbsp;  Extiende obligaci&#xF3;n de presentar Declaraci&#xF3;n Jurada Formulario N&#xBA; 1895 sobre Retiros de Excedentes de Libre Disposici&#xF3;n y Certificaci&#xF3;n respectiva a otras instituciones que administren estos recursos, a contar del A&#xF1;o Tributario 2013.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII de febrero de 2013.</div></div>", "i": 9335412}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "25 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-25 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DECLARACIÓN JURADA ANUAL SOBRE RETIROS DE EXCEDENTES DE LIBRE DISPOSICIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-02-22", "doble_articulado": false, "id_norma": "1049121", "numero_fuente": "40496", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-02-27", "vigencias": [{"desde": "2013-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-02-27", "fin_vigen