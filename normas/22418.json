{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Sociedad Protectora de la Infancia de Santiago Lei n&#xFA;m. 1,120.- Santiago, a 25 de Noviembre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274104}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Acu&#xE9;rdase a la Sociedad Protectora de la Infancia de Santiago la cantidad de cuarenta mil pesos para auxiliar la creacion de talleres para ni&#xF1;os i de cunas p&#xFA;blicas.</div><br><br></div>", "i": 8274105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica. FEDERICO ERRAZURIZ.- C. Walker Mart&#xED;nez.</div><br></div>", "i": 8274106}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1120", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1120"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "SOCIEDAD PROTECTORA DE LA INFANCIA DE SANTIAGO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD PROTECTORA INFANCIA", "FONDOS", "TALLERES PARA", "NI OS", "CUNAS PUBLICAS", "DESTINACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-11-25", "doble_articulado": false, "id_norma": "22418", "numero_fuente": "6160", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-11-25", "vigencias": [{"desde": "1898-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-11-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-11-25", "fin_vigen