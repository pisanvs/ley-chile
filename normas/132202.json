{"html": [{"t": "<div><div class=\"p\">DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA </div></div>", "i": 6155587}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n</div><div class=\"p\">Exenta No. 833 de 13 de Mayo de 1988 conforme Art. 5&#xB0;</div><div class=\"p\">Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos</div><div class=\"p\">Aprovechamiento Aguas proporcionales que corresponden a</div><div class=\"p\">parcelas N&#xB0;s. 9 a 12 y Reservas Cora N&#xB0;s. 5A y 6 del</div><div class=\"p\">Proyecto de Parcelaci&#xF3;n &quot;El Combate&quot; de la comuna de</div><div class=\"p\">Yumbel, VIII Regi&#xF3;n, formado por predios &quot;El Quillay&quot; y</div><div class=\"p\">&quot;Parte del Fundo San Crist&#xF3;bal&quot;. Los Derechos de Agua se</div><div class=\"p\">extraen del estero Tapihue. Publicaci&#xF3;n hecha conforme</div><div class=\"p\">Art. 13 Ley No. 18.377.</div><br></div>", "i": 6155588}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Ejecutivo.</div><br></div>", "i": 6155589}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "833 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-833 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-05-13", "doble_articulado": false, "id_norma": "132202", "numero_fuente": "33085", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-06-01", "vigencias": [{"desde": "1988-06-01", "hasta": "", "tipo_ver