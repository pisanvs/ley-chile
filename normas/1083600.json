{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">PARTIDO MOVIMIENTO INDEPENDIENTE REGIONALISTA AGRARIO Y SOCIAL</div></div>", "i": 9647382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Las se&#xF1;oras Alejandra Sep&#xFA;lveda Orbenes y Marta Molina &#xC1;vila, Presidenta y Secretaria General de la Directiva Central Provisional del Partido Movimiento Independiente Regionalista Agrario y Social, en formaci&#xF3;n, con fecha 19 de octubre de 2015, han solicitado la Constituci&#xF3;n Legal del Partido en la Regi&#xF3;n VI del Libertador General Bernardo O&apos;Higgins. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de 946 afiliaciones. </div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el <a href=\"https://www.leychile.cl/Navegar?idNorma=29994&amp;idParte=8285857&amp;idVersion=\">art&#xED;culo 17&#xBA;</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=29994&amp;idParte=0&amp;idVersion=\">Ley N&#xBA; 18.603</a>, por resoluci&#xF3;n O-N&#xBA; 226, de fecha 22 de octubre de 2015.</div></div>", "i": 9647383}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Eduardo Charme Aguirre, Director.</div></div>", "i": 9647384}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "226", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-226"}, {"tipo": "3", "numero": "O-N° 226", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-N° 226"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO MOVIMIENTO INDEPENDIENTE REGIONALISTA AGRARIO Y SOCIAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 962588; EXTRACTO"], "derogacion_taci