{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8306773}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.253 de 25 de septiembre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de las Resoluciones N&#xBA; 270, de 1990 y N&#xBA; 79, de 1991, ambas de esta Subsecretar&#xED;a, que autorizaron a JUAN JOSE ROJAS STUBING, para realizar actividades pesqueras extractivas con la nave &quot;Reina del Quisco&quot;, por suspender operaciones de pesca por m&#xE1;s de 12 meses sucesivos, a contar del mes de octubre de 1995, incurriendo en la causal de caducidad prevista en el art&#xED;culo 143 letra b) de la Ley N&#xBA; 18.892 y sus modificaciones.</div><br></div>", "i": 8306774}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de septiembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8306775}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1253", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1253"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "JUAN JOSE ROJAS STUBING", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-09-25", "doble_articulado": false, "id_norma": "76118", "numero_fuente": "35882", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-10-04", "vigencias": [{"desde": "1997-10-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-10-04", "fin_vigenci