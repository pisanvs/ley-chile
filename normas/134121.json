{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 930.- Santiago, 8 de Julio de 1897.- Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 7247232}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Atala Rosa i do&#xF1;a Ecilda Prat Chacon el goce de montep&#xED;o militar que corresponde al empleo de capitan de nav&#xED;o, el que gozar&#xE1;n en conformidad a la lei de montep&#xED;o militar.</div><br></div>", "i": 7247233}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ E.- Benjam&#xED;n Vergara E.</div><br></div>", "i": 7247234}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "930", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-930"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-07-08", "doble_articulado": false, "id_norma": "134121", "numero_fuente": "5747", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1897-07-08", "vigencias": [{"desde": "1897-07-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1897-07-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1897-07-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"