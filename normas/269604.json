{"html": [{"t": "<div><div class=\"p\">MODIFICA LLAMADO A CONCURSO P&#xDA;BLICO DE LA PLANTA DE PROFESIONALES </div></div>", "i": 7365242}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante Resoluci&#xF3;n Exenta N&#xBA;491 del 26 de febrero de 2008, el Servicio de Salud Aconcagua modifica la p&#xE1;gina 11 de las Bases del Concurso aclarando que el puntaje m&#xED;nimo a obtener en los factores de Experiencia Laboral, Actividades de Capacitaci&#xF3;n y Perfeccionamiento, y Participaci&#xF3;n en Actividades de Docencia, para ser evaluado en el factor de Idoneidad y Competencia, corresponde a 20 puntos, tal como se se&#xF1;ala en los &#xED;tems VIII y XII (p&#xE1;ginas 4, 6 y 12). </div></div>", "i": 7365243}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  DRA. CARMEN CASTILLO TAUCHER</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Directora</div><br><br></div>", "i": 7365244}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "491 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-491 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "SERVICIO DE SALUD ACONCAGUA"], "titulo_norma": "MODIFICA LLAMADO A CONCURSO PÚBLICO DE LA PLANTA DE\nPROFESIONALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-02-26", "doble_articulado": false, "id_norma": "269604", "numero_fuente": "39001", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-03-01", "vigencias": [{"desde": "2008-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-03-01", "fi