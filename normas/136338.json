{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 3.434 EXENTA DE 1999 </div><br></div>", "i": 6168402}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 3.434 de 15 de abril de 1999, se ha aprobado al Colegio Brit&#xE1;nico &apos;&apos;St. Margaret&apos;s&apos;&apos; de Vi&#xF1;a del Mar, un plan de estudio para 1&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 1999, de acuerdo a la gradualidad establecida en el decreto supremo de Educaci&#xF3;n N&#xBA; 220 de 1998.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 6168403}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de abril de 1999.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6168404}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3434", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3434"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 3.434 EXENTA DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-04-15", "doble_articulado": false, "id_norma": "136338", "numero_fuente": "36361", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-05-12", "vigencias": [{"desde": "1999-05-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-05-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-05-12", "fin_vigenc