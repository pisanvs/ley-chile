{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6268224}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 17, de 07 de Febrero de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes de la III Regi&#xF3;n, se autoriza al Sr. Pedro Ferrera Camblor, para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea N&#xB0; 6 &quot;Universidad de Atacama - El Pretil&quot;, cuyo trazado que a continuaci&#xF3;n se indica fue autorizado por resoluci&#xF3;n N&#xB0; 39, de 22.06.84, de esta Secretar&#xED;a Regional:</div><div class=\"p\">&nbsp; &nbsp;  Ida: Pablo - Aromos - Estadio - Copayapu - Vicu&#xF1;a - Carrera - Alameda - Juan - Centenario - Universidad de Atacama.</div><div class=\"p\">&nbsp; &nbsp;  Regreso: Centenario - Pinos - Heras - Alameda -</div><div class=\"p\">O&apos;Higgins - Estadio - Aromos - Pablo.-</div><br></div>", "i": 6268225}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Antonio Acevedo Oyarce, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de Atacama.</div><br></div>", "i": 6268226}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "17 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-17 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-02-07", "doble_articulado": false, "id_norma": "166498", "numero_fuente": "32100", "tipo_version": "3", "tipo_version_s": "Única", "f