{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,496, que concede fondos para el mantenimiento del Cuerpo de Carabineros.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,496.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 8276371}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.&#xB0; Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la suma de ciento diez mil pesos ($ 110,000) en el mantenimiento del Cuerpo de Carabineros.</div><br></div>", "i": 8276372}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, promulguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a cinco de Febrero de mil novecientos diecinueve.- JUAN LUIS SANFUENTES.- Luis Serrano A. </div></div>", "i": 8276373}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3496", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3496"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NÚM. 3,496, QUE CONCEDE FONDOS PARA EL MANTENIMIENTO DEL CUERPO DE CARABINEROS.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CARABINEROS CHILE", "MANTENIMIENTO", "FONDOS", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1919-02-05", "doble_articulado": false, "id_norma": "24017", "numero_fuente": "12298", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1919-02-15", "vigencias": [{"desde": "1919-02-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1919-