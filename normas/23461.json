{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede $ 3,000 para el Hospital de Cauqu&#xE9;nes Lei n&#xFA;m. 2,745.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br><br></div>", "i": 8275533}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la suma de tres mil pesos ($ 3,000) en los servicios del Hospital de Cauqu&#xE9;nes durante el a&#xF1;o 1913.</div><br></div>", "i": 8275534}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 28 de Enero de 1913.- RAMON BARROS LUCO.- Guillermo Barros.</div><br></div>", "i": 8275535}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2745", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2745"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE $ 3,000 PARA EL HOSPITAL DE CAUQUÉNES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["HOSPITAL CAUQUENES", "FONDOS", "INVERSION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["LA PRESENTE LEY HA SIDO REPRODUCIDA EN EL DIARIO OFICIAL Nº 10496 DEL 08.02.1913"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1913-01-28", "doble_articulado": false, "id_norma": "23461", "numero_fuente": "10488", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1913-01-28", "vigencias": [{"desde": "1913-01-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1913-01