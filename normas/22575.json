{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Cesion a la Municipalidad de Valparaiso de cierta porcion de terreno</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,343.- Santiago, a 20 de Agosto de 1900.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274278}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. C&#xE9;dese a la Ilustre Municipalidad de Valparaiso la superficie de terreno fiscal comprendida entre la calle de Bellavista i la bifurcacion de de la calle Blanco, para que la destine a la formacion de un jardin p&#xFA;blico.</div><br><br></div>", "i": 8274279}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- El&#xED;as Fern&#xE1;ndez A.- Rafael Err&#xE1;zuriz Urmeneta.</div><br></div>", "i": 8274280}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1343", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1343"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CESION A LA MUNICIPALIDAD DE VALPARAISO DE CIERTA PORCION DE TERRENO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VALPARAISO", "MUNICIPALIDAD", "CESION", "TERRENOS", "JARDIN", "PUBLICO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-08-20", "doble_articulado": false, "id_norma": "22575", "numero_fuente": "6674", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-08-21", "vigencias": [{"desde": "1900-08-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"i