{"html": [{"t": "<div><div class=\"p\">ACOGE, PARCIALMENTE, RECLAMACION DE PESQUERA SAN ANTONIO S.A </div></div>", "i": 6331687}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por R.M. (ex) N&#xBA; 65, de 15 de&nbsp; marzo de 2001, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ac&#xF3;gese parcialmente el recurso de reclamaci&#xF3;n interpuesto por Pesquera San Antonio S.A., en contra de las resoluciones N&#xBA; 163, N&#xBA; 176 y N&#xBA; 178 de 2001, de la Subsecretar&#xED;a de Pesca. Consid&#xE9;rese en la determinaci&#xF3;n de su l&#xED;mite m&#xE1;ximo de captura en la unidad de pesquer&#xED;a de Anchoveta, V a X Regiones, la siguiente captura total de la nave Vigri, en el mes que se indica:</div><div class=\"p\">&nbsp; &nbsp;  Julio de 1999: 109,800 toneladas.</div><br></div>", "i": 6331688}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; de Gregorio Rebeco, Ministro de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6331689}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "65 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-65 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "ACOGE, PARCIALMENTE, RECLAMACION DE PESQUERA SAN ANTONIO S.A", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-15", "doble_articulado": false, "id_norma": "184427", "numero_fuente": "36941", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-04-19", "vigencias": [{"desde": "2001-04-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}],