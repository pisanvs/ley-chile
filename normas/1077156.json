{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N N&#xBA; 759 EXENTA, DE 2015</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 9594346}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.176, de 30 de abril de 2015, de esta Subsecretar&#xED;a, rectif&#xED;case el numeral 1.- de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1075766&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 759, de 2015</a>, de esta Subsecretar&#xED;a, que modific&#xF3; la resoluci&#xF3;n exenta N&#xBA; 118, de 2015, de esta Subsecretar&#xED;a, en el sentido de reemplazar en su letra b) la expresi&#xF3;n Luga roja, por la frase Luga negra.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><br></div>", "i": 9594347}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de abril de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9594348}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1176 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1176 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "RECTIFICA RESOLUCIÓN Nº 759 EXENTA, DE 2015", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 902394", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-04-30", "doble_articulado": false, "id_norma": "1077156", "numero_fuente": "41153", "tipo_version