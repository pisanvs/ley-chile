{"html": [{"t": "<div><div class=\"p\">@@</div></div>", "i": 8238380}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 674, de 18 de febrero de 2009, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 7&#xBA;.-, Letra b.-, de la resoluci&#xF3;n exenta N&#xBA; 3.226 de 2008 de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a LUNA Y GALAZ LIMITADA, para capturar, en el &#xE1;rea mar&#xED;tima de la X Regi&#xF3;n de Los Lagos, en el plazo de 1 a&#xF1;o contado desde la fecha de la citada resoluci&#xF3;n, la cantidad total de 200 ejemplares de la especie Lobo marino com&#xFA;n Otaria flavescens, en el sentido de indicar que la instalaci&#xF3;n contar&#xE1; con tres recintos similares y no con dos, como se se&#xF1;ala en la resoluci&#xF3;n que por este acto se modifica.</div><br></div>", "i": 8238381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de febrero de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca. </div></div>", "i": 8238382}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "674", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-674"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-02-18", "doble_articulado": false, "id_norma": "287924", "numero_fuente": "39307", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-03-09", "vigencias": [{"desde": "2009-03-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-03-09", "fin_vigencia": ""}, "vigenci