{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 687 EXENTO, DE 1994 </div></div>", "i": 5945879}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 687 de 30 de diciembre de 1994, se ha aprobado, a contar del presente a&#xF1;o escolar, al Liceo Industrial Chileno-Alem&#xE1;n de &#xD1;u&#xF1;oa, Santiago, un plan de estudio de ense&#xF1;anza media t&#xE9;cnicoprofesional, rama industrial, especialidad matricer&#xED;a.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio de las asignaturas del plan de estudio aprobado en el art&#xED;culo 1&#xB0; del presente decreto.</div><br></div>", "i": 5945880}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 18 de Enero de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5945881}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "687", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-687"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 687 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LICEO INDUSTRIAL CHILENO-ALEMAN", "U OA", "SANTIAGO", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-12-30", "doble_articulado": false, "id_norma": "21694", "numero_fuente": "35077", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-01-26", "vigencias": [{"desde": "1995-01-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-01-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-01-26", "f