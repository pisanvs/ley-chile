{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8324713}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 769, de 3 de Julio de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 2&#xB0; de la Resoluci&#xF3;n No. 349, de 1988, de esta Subsecretar&#xED;a, en orden a se&#xF1;alar que la ubicaci&#xF3;n de la planta secadora de algas autorizada por dicha Resoluci&#xF3;n, es Sector Surweste del Morro San Juan, Ensenada San Juan, Comuna de Corral, Valdivia. </div></div>", "i": 8324714}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 3 de Julio de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8324715}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "769", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-769"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-07-03", "doble_articulado": false, "id_norma": "94325", "numero_fuente": "33422", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-07-14", "vigencias": [{"desde": "1989-07-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-07-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-07-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "PMB", "fecha_ingre