{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pension de Gracia Lei n&#xFA;m. 979.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948063}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, a don Juan Wilkis la pension equivalente a las treinta i siete cuarentavas partes del sueldo que gozaba como maquinista de los Ferrocarriles del Estado.</div><br><br></div>", "i": 5948064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 24 de Diciembre de 1897.- FEDERICO ERRAZURIZ.- Julio Ba&#xF1;ados Espinosa.</div><br></div>", "i": 5948065}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "979", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-979"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "PENSION DE GRACIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUAN WILKIS", "PENSION GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-12-24", "doble_articulado": false, "id_norma": "22320", "numero_fuente": "5893", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-01-03", "vigencias": [{"desde": "1898-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-01-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-01-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci