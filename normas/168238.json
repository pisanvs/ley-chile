{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6274049}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 487 del 02 de Diciembre de 1987 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la IV Regi&#xF3;n de Coquimbo, se autoriza a don Manuel Rub&#xE9;n Malebr&#xE1;n Malebr&#xE1;n para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6274050}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Dante Guerra Tallar, Secretario Regional Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n de Coquimbo Subrogante.</div><br></div>", "i": 6274051}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "487 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-487 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IV REGIÓN COQUIMBO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-12-02", "doble_articulado": false, "id_norma": "168238", "numero_fuente": "32956", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-29", "vigencias": [{"desde": "1987-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-29", "fin_vigencia": "", "tipo_version": "3"}],