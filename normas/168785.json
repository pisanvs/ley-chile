{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 12.875 EXENTA, DE 1999 </div><br></div>", "i": 6275660}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 12.875, de 29 de diciembre de 1999, se ha aprobado al Colegio &apos;&apos;The Grange School&apos;&apos;, comuna de La Reina de Santiago, el plan y programas especiales de estudio para Primero y Segundo a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; simult&#xE1;neamente a partir del a&#xF1;o escolar 2000, en ambos cursos, y posteriormente de acuerdo a la gradualidad establecida en el decreto supremo de Educaci&#xF3;n N&#xBA; 220, de 1998 y sus modificaciones.</div><br></div>", "i": 6275661}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 6 de marzo de 2000.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6275662}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "12875 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-12875 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 12.875 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-29", "doble_articulado": false, "id_norma": "168785", "numero_fuente": "36664", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-16", "vigencias": [{"desde": "2000-05-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-16", "fin_vigencia": "", "tipo_vers