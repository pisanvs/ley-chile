{"html": [{"t": "<div><div class=\"p\">EXCEPCIONA DEL REGIMEN DE RETENCION DEL 5% DEL IVA A COMPLEJO PENITENCIARIO DE VALPARAISO </div></div>", "i": 6223044}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La V Direcci&#xF3;n Regional del S.I.I., por resoluci&#xF3;n N&#xBA;Ex. 2.468, de 7 de diciembre de 1999, excepciona a contar del primero del mes siguiente, al de esta publicaci&#xF3;n, al Complejo Penitenciario de Valpara&#xED;so, RUT N&#xBA;61.004.023-3, del r&#xE9;gimen de retenci&#xF3;n del 5% de IVA, por anticipo, en la adquisici&#xF3;n del producto carne, establecido en la resoluci&#xF3;n N&#xBA;Ex. 5.087, de 28.07.99, que dispone la retenci&#xF3;n que indica, a los mataderos y otros en las ventas de carnes.-</div><br></div>", "i": 6223045}, {"t": "<div><div class=\"p\">Francisco C&#xE1;rcamo Avenda&#xF1;o, Director Regional.</div><br><br></div>", "i": 6223046}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2468 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2468 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL DE VALPARAÍSO"], "titulo_norma": "EXCEPCIONA DEL REGIMEN DE RETENCION DEL 5% DEL IVA A\nCOMPLEJO PENITENCIARIO DE VALPARAISO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-07", "doble_articulado": false, "id_norma": "152410", "numero_fuente": "36573", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-01-27", "vigencias": [{"desde": "2000-01-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-01-27", "fin_vigencia": ""}, "vigencias_version_no