{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div></div>", "i": 9100362}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Rectifica extracto publicado en el Diario Oficial de 15 de diciembre de 2010 en cuanto a que la superficie del inmueble expropiado por <a href=\"https://www.leychile.cl/Navegar?idNorma=1020745&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 969, de fecha 22 de noviembre de 2010</a>, del Serviu IV Regi&#xF3;n de Coquimbo, denominado Lote 63 Rol N&#xBA; 27-1, de aparente dominio de Alfonso Aranda Ca&#xF1;as y Otros; ubicado en la comuna de Coquimbo es de una superficie aproximada de 264,07 m&#xB2;. En lo dem&#xE1;s, se mantiene inalterable la publicaci&#xF3;n antes se&#xF1;alada.- </div><br></div>", "i": 9100363, "v": ["MODIFICACION"]}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Director Serviu IV Regi&#xF3;n Coquimbo.</div></div>", "i": 9100364}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "Aviso-S/N"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "IV REGIÓN DE COQUIMBO"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["SIN FECHA DE PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1022079", "numero_fuente": "39860", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-01-15", "vigencias": [{"desde": "2011-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-01-15", "fin_vigencia": "", "tipo_version"