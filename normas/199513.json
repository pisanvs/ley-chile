{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 443 EXENTO, DE 2002 </div></div>", "i": 6385981}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;443 de fecha 22 de mayo de 2002 del Ministerio de Educaci&#xF3;n, se deja sin efecto la aprobaci&#xF3;n del plan y programas de estudios de la carrera de Secretariado Ejecutivo Computacional, concedida mediante decreto exento de Educaci&#xF3;n N&#xBA;62 del 4 de febrero de 2000 para el Centro de Formaci&#xF3;n T&#xE9;cnica Ecatema de la ciudad de Santiago, a petici&#xF3;n de la propia entidad.</div><br></div>", "i": 6385982}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de junio de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6385983}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "443 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-443 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 443 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-22", "doble_articulado": false, "id_norma": "199513", "numero_fuente": "37288", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-20", "vigencias": [{"desde": "2002-06-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-06-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-06-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "IMH", "fecha_in