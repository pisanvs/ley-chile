{"html": [{"t": "<div><div class=\"p\">AUTORIZA CALIDAD DE AGENTE RETENEDOR DEL IVA A COMERCIAL REHUEN S.A.</div><br></div>", "i": 6393447}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional Santiago Poniente del SII, por resoluci&#xF3;n Ex. N&#xBA; 892, de 9 de agosto de 2002, concede la calidad de agente retenedor en las ventas de ganado vivo a la empresa Comercial Rehu&#xE9;n S.A., RUT N&#xBA; 96.952.200-4, la que entrar&#xE1; en vigencia a contar del d&#xED;a primero del mes siguiente de la fecha de su publicaci&#xF3;n en el Diario Oficial, por su cuenta y costo, y en forma indefinida.</div><br></div>", "i": 6393448}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jorge A. de Calisto Bravo, Director Regional. </div></div>", "i": 6393449}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "892 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-892 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO PONIENTE"], "titulo_norma": "AUTORIZA CALIDAD DE AGENTE RETENEDOR DEL IVA A COMERCIAL REHUEN S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-08-09", "doble_articulado": false, "id_norma": "201739", "numero_fuente": "37338", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-08-20", "vigencias": [{"desde": "2002-08-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-08-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-08-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc