{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6315411}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;4.966, de fecha 31 de octubre de 2000, se expropiaron los lotes de terrenos N&#xBA;s. 13, 14, 14-A, 15, 15-A, 15-B, 16, 17 y 17-A, superficies 2.549,7 M2, 2.587,7 M2, 4.240,81 M2, 29.824,7 M2. 14.417,5 M2, 4.254,86 M2, 20.448,4 M2, 44.420,9 M2 y 9.853,9 M2, respectivamente, rol de aval&#xFA;o 356-65, comuna de Constituci&#xF3;n, para la obra &apos;&apos;Camino M-24K Quivolgo-Puente Lautaro, Sector B: La Trinchera-Put&#xFA; (Variante Costera) Km. 13,240 a Km. 30,000&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Agr&#xED;cola y Forestal Fundo Capellan&#xED;a Limitada, ascendente a la cantidad de $177.957.166.-</div><br></div>", "i": 6315412}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6315413}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "4966", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-4966"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-31", "doble_articulado": false, "id_norma": "179853", "numero_fuente": "36851", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-02", "vigencias": [{"desde": "2001-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [