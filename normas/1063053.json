{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA EMISOR DE BOLETAS ELECTR&#xD3;NICAS</div></div>", "i": 9478377}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 55 de 3 de junio de 2014, que autoriza a contribuyente como emisor de boleta electr&#xF3;nica.</div><br><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de boleta electr&#xF3;nica al contribuyente RUT 76.292.834-5, a contar del mes de junio de 2014. En la oficina Virtual del SII en Internet se podr&#xE1;n consultar los documentos que el contribuyente est&#xE1; autorizado a emitir en forma electr&#xF3;nica.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de junio de 2014.</div></div>", "i": 9478378}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "55", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-55"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISOR DE BOLETAS ELECTRÓNICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-06-03", "doble_articulado": false, "id_norma": "1063053", "numero_fuente": "40875", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-06-06", "vigencias": [{"desde": "2014-06-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inici