{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 183 EXENTO, DE 1999</div><br><br></div>", "i": 6189514}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 183 de fecha 09 de julio de 1999 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; la modificaci&#xF3;n introducida al plan y programas de estudios del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto de Secretariado Insec, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar del a&#xF1;o 1999, en las sedes que ya contaban con su autorizaci&#xF3;n, con la siguiente denominaci&#xF3;n:</div><br><div class=\"p\">&nbsp; &nbsp;  Carrera: Secretariado Ejecutivo con menci&#xF3;n en Computaci&#xF3;n; cambia por:</div><div class=\"p\">&nbsp; &nbsp;  Carrera: Secretariado Ejecutivo Computacional.</div><div class=\"p\">&nbsp; &nbsp;  T&#xED;tulo: Secretaria(o) Ejecutiva(o) Computacional. </div></div>", "i": 6189515}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de agosto de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6189516}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "183 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-183 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 183 EXENTO, DE 1999", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-07-09", "fecha_derogacion": "2017-07-05", "doble_articulado": false, "id_norma": "142835", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-09-09", "vigencias": [{"desde": "2017-07-05", "hasta": "", "tipo_version": "