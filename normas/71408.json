{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6036912}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 332, de 31 de marzo de 1997, se expropiaron los lotes de terreno N&#xBA;s. 34, 34-A, 38-A y 45-B, superficies 50, 65, 172 y 250 M2., roles de aval&#xFA;o en tr&#xE1;mite y 47-69, comuna de La Estrella, para la obra Camino L&#xED;mite Regional (Rapel)-Alcones I, sector Litueche-La Rosa, de km. 77.361,39 a Km. 101.610,51 y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Janet del Carmen Herrera Moreno, Jos&#xE9; Manuel Herrera Huerta, Luis Orlando Herrera Huerta y Desiderio del Carmen Caro Escobar, ascendente a las cantidades de $354.660. para el lote 34, $362.370. para el lote 34-A, $3.830.328. para el lote 38-A y $640.444. para el lote 45-B.-</div><br></div>", "i": 6036913}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6036914}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "332", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-332"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "LA ESTRELLA", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-31", "doble_articulado": false, "id_norma": "71408", "numero_fuente": "35766", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-15", "vigencias": [{"desde": "1997-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio