{"html": [{"t": "<div><br><div class=\"p\"> DESIGNA A DON MARIO QUAPPE DE LA MAZA COMO RECEPTOR JUDICIAL</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; N&#xFA;m. 336.- Santiago, 4 de septiembre de 2003.- Vistos: Lo dispuesto en el Art. 11 del decreto ley N&#xBA; 2.974, de 1979.</div><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 6442877}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Receptor Judicial, para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del decreto ley citado, VIII Regi&#xF3;n, al siguiente funcionario:</div><div class=\"p\">&nbsp; &nbsp;  - Mario Quappe de la Maza - RUT 8.795.349-1 </div><br></div>", "i": 6442878}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Ricardo Halabi Caffena, Director Nacional. </div></div>", "i": 6442879}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "336", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-336"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO AGROPECUARIO"], "titulo_norma": "DESIGNA A DON MARIO QUAPPE DE LA MAZA COMO RECEPTOR JUDICIAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-09-04", "doble_articulado": false, "id_norma": "215625", "numero_fuente": "37681", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-10-10", "vigencias": [{"desde": "2003-10-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-10-10",