{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE RESOLUCION EXENTA N&#xB0; 1.145, DE 1993 </div></div>", "i": 6024301}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n Exenta N&#xB0; 1.145 de fecha 18 de Marzo de 1993 del Ministerio de Educaci&#xF3;n, se declar&#xF3; que no se concede el reconocimiento oficial al Centro de Formaci&#xF3;n T&#xE9;cnica Tecnolog&#xED;a y Negocios, organizado por la Sociedad Educaci&#xF3;n Tecnesa S.A., ubicado en calle Libertad N&#xB0; 130 de la ciudad de Valdivia y se elimin&#xF3; del Libro de Registro de Centros de Formaci&#xF3;n T&#xE9;cnica el N&#xB0; 222 de fecha 22 de Octubre de 1992, correspondiente a la instituci&#xF3;n antes mencionada.-</div><br></div>", "i": 6024302}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 23 de Abril de 1993.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6024303}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1145", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1145"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N° 1.145, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECONOCIMIENTO OFICIAL", "CENTRO FORMACION TECNICA", "TECNOLOGIA NEGOCIOS", "VALDIVIA", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-03-18", "doble_articulado": false, "id_norma": "39556", "numero_fuente": "34557", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-05-05", "vigencias": [{"desde": "1993-05-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-05-05", "fin_vigencia": ""}, "