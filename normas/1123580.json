{"html": [{"t": "<div><br><div class=\"p\">ART&#xCD;CULOS 14 E, Y 41 A, B, C Y G DE LA LEY SOBRE IMPUESTO A LA RENTA</div></div>", "i": 9952792}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta SII N&#xBA; 87, de 28 de septiembre de 2018, que establece:</div><br><div class=\"p\">&nbsp; &nbsp;  Complementa la obligaci&#xF3;n de presentar declaraci&#xF3;n jurada anual sobre operaciones en el exterior por medio de formulario N&#xB0; 1929; y modifica la resoluci&#xF3;n Ex. SII N&#xB0; 120 de 2016.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII de septiembre de 2018. </div><br></div>", "i": 9952793}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "87 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-87 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ARTÍCULOS 14 E, Y 41 A, B, C Y G DE LA LEY SOBRE IMPUESTO A LA RENTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1472382", "EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2018-09-28", "fecha_derogacion": "2023-01-04", "doble_articulado": false, "id_norma": "1123580", "numero_fuente": "42172", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2018-10-04", "vigencias": [{"desde": "2023-01-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2018-10-04", "hasta": "2023-01-03", "tipo_version": "0", "tipo_v