{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 1.631 EXENTA, DE 2008 </div></div>", "i": 7368178}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.631, de fecha 10 de marzo de 2008, del Ministerio de Educaci&#xF3;n, se ampl&#xED;a el per&#xED;odo de acreditaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica U. Valpo de Valpara&#xED;so por un per&#xED;odo de cinco a&#xF1;os, a contar de diciembre del a&#xF1;o 2007.</div><div class=\"p\">Se requiere del Centro de Formaci&#xF3;n T&#xE9;cnica U. Valpo el cumplimiento de acciones dentro del plazo se&#xF1;alado, como condici&#xF3;n previa para la obtenci&#xF3;n de la Plena Autonom&#xED;a, correspondiendo al Ministerio de Educaci&#xF3;n la verificaci&#xF3;n de su desarrollo.</div><br></div>", "i": 7368179}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de abril de 2008.- Cristi&#xE1;n Mart&#xED;nez Ahumada, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7368180}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1631 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1631 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 1.631 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2008-03-10", "fecha_derogacion": "2021-06-30", "doble_articulado": false, "id_norma": "270673", "numero_fuente": "39045", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2008-04-24", "vigencias": [{"desde": "2021-06-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2008-04-24", "hasta": "2021-0