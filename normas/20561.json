{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 178 EXENTO, DE 1994 </div><br><br></div>", "i": 5942381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 178 de fecha 22 de abril de 1994 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Chileno Brit&#xE1;nico de Cultura las adecuaciones introducidas al Plan y Programas de Estudios de la Carrera de Secretariado Ejecutivo Biling&#xFC;e con Conocimientos en Computaci&#xF3;n, las que se insertaron en el Decreto Exento de Educaci&#xF3;n N&#xB0; 114 de 1991. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1993.-</div><br></div>", "i": 5942382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5942383}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "178 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-178 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 178 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA CHILENO BRITANICO CULTURA", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "MODIFICACION", "SECRETARIADO EJECUTIVO BILINGUE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO. LA PRESENTE NORMA FUE PUBLICADA NUEVAMENTE EN EL DIARIO OFICIAL DE 13.09.1994"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-04-22", "fecha_derogacion": "2001-05-29", "doble_articulado": false, "id_norma": "20561", "numero_fuente": "34893", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-06-18", "vigencias": [{"desde": "2001-05-29", "hasta": "", "tipo_version": "2", "tipo_version_s