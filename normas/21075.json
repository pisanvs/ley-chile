{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 365, DE 1992 </div><br></div>", "i": 7161693}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 365 de 28 de octubre de 1992, se ha modificado el decreto supremo exento de Educaci&#xF3;n N&#xB0; 17 de 1992, que aprob&#xF3; un plan de estudio especial al Colegio Concepci&#xF3;n de Concepci&#xF3;n sustituyendo el plan de estudio de 1&#xB0; a 4&#xB0; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica, para ser aplicado simult&#xE1;neamente desde 1&#xB0; a 3er. a&#xF1;o a partir del a&#xF1;o escolar 1992 y progresivamente en el resto de los cursos y en los a&#xF1;os escolares siguientes.</div><br></div>", "i": 7161694}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 10 Marzo 1993.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161695}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "365 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-365 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 365, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PROGRAMAS ESTUDIOS", "PLANES ESTUDIOS", "COLEGIO", "CONCEPCION", "CONCEPCION", "OCTAVA REGION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-10-28", "doble_articulado": false, "id_norma": "21075", "numero_fuente": "34535", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-04-06", "vigencias": [{"desde": "1993-04-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-04-06", "fin_vigencia": ""},