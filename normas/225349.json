{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6479737}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.316, de 10 de mayo de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BIO BIO S.A. para ampliar actividades pesqueras extractivas con la nave &quot;&nbsp; Duqueco&quot;&nbsp; , en las &#xE1;reas que a continuaci&#xF3;n se indican, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar los siguientes recursos hidrobiol&#xF3;gicos:</div><div class=\"p\">a) En el &#xE1;rea mar&#xED;tima correspondiente a las Regiones III, IV, V, VI, VII, IX y X con arte de cerco: Jibia; b) En el &#xE1;rea mar&#xED;tima de la III Regi&#xF3;n, con arrastre de media agua: Jibia; c) En el &#xE1;rea mar&#xED;tima correspondiente a las Regiones IV, V, VI, VII, IX y X, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua: Jibia.</div><br></div>", "i": 6479738}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de mayo de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6479739}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1316", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1316"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-05-10", "fecha_derogacion": "2012-09-06", "doble_articulado": false, "id_norma": "225349", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-05-18", "vigencias": [{"desde": "2012-09-06", "hasta": "", "tipo_version": "2", "tipo_version_s": "Últim