{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10357950}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto (Exento) MOP N&#xB0;552, de 21 de julio de 2022, se modific&#xF3; y desisti&#xF3; parcialmente de la expropiaci&#xF3;n del lote N&#xB0;41, realizada por <a href=\"https://www.leychile.cl/Navegar?idNorma=1121877&amp;idParte=&amp;idVersion=\">Decreto (Exento) MOP. N&#xB0;744, de 18 de julio de 2018</a>, reduci&#xE9;ndose la superficie expropiada a 1.186 m2. y modificando el numeral primero de dicho Decreto, se&#xF1;alando como Kilometraje de inicio Km: 27,94540, de la comuna de Quemchi, expropiado para la ejecuci&#xF3;n de obra &quot;Mejoramiento Ruta W-175 Sector: Linao-Quemchi, Comuna de Quemchi, Regi&#xF3;n de Los Lagos. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en los art&#xED;culos 7&#xB0; y 32&#xB0; del Decreto Ley N&#xB0;2186, de 1978.</div></div>", "i": 10357951}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10357952}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "552 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-552 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2169538", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-07-21", "doble_articulado": false, "id_norma": "1180031", "numero_fuente": "43328", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-08-16", "vigencia