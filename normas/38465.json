{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6021082}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xB0; 163, del 29 de Diciembre de 1992, se autoriza a AVARIA Y CIA. LTDA. la concesi&#xF3;n para operar, hasta el 14 de Febrero de 1995, un establecimiento ubicado en Las Tranqueras 952, comuna de Las Condes, destinado a la verificaci&#xF3;n de emisi&#xF3;n de contaminantes de veh&#xED;culos motorizados livianos a que se refiere el D.S. N&#xB0; 211/91, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 6021083}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Juan Fuentes Isla, Secretario Regional Ministerial Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana Subrogante.</div><br></div>", "i": 6021084}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "163", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-163"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION REVISION TECNICA", "PLANTA REVISION TECNICA", "SANTIAGO", "REGION METROPOLITANA", "VEHICULOS MOTORIZADOS LIVIANOS", "AVARIA CIA LTDA."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-12-29", "doble_articulado": false, "id_norma": "38465", "numero_fuente": "34498", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-02-22", "vigencias": [{"desde": "1993-02-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-02-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-02-22", "fin_vigencia": "", "tipo_version": "3"}], "eve