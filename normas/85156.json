{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 86 DE 1992</div><br><br><br></div>", "i": 6069732}, {"t": "<div><div class=\"p\">Por Decreto Exento No. 86 de fecha 10 de abril de 1992 del Ministerio de Educaci&#xF3;n, se aprobaron las modificaciones introducidas al plan y programas de estudio al Centro de Formaci&#xF3;n T&#xE9;cnica Iquique English College de Iquique, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar del a&#xF1;o 1992, en la ciudad de Iquique, con la siguiente denominaci&#xF3;n:</div><div class=\"p\">Carrera: Publicidad Menci&#xF3;n Comercializaci&#xF3;n, cambia por: Carrera: Publicidad Menci&#xF3;n Dibujo Gr&#xE1;fico.</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico en Publicidad Menci&#xF3;n Dibujo Gr&#xE1;fico. </div></div>", "i": 6069733}, {"t": "<div><div class=\"p\">Santiago, 30 de Junio de 1992.- Raol Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6069734}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "86 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-86 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 86 DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1992-04-10", "fecha_derogacion": "2000-12-04", "doble_articulado": false, "id_norma": "85156", "numero_fuente": "34396", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1992-10-22", "vigencias": [{"desde": "2000-12-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1992-10-22",