{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6288077}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.272, de 30 de mayo de 2000, se expropi&#xF3; el lote de terreno N&#xBA;22, superficie 2.231 m2, rol de aval&#xFA;o 17-27, comuna de San Gregorio de &#xD1;iqu&#xE9;n, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: Talca - Chill&#xE1;n, Octava Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Mario Antonio P&#xE9;rez Mu&#xF1;oz, ascendente a la cantidad de $3.865.096. </div></div>", "i": 6288078}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6288079}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2272", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2272"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-30", "doble_articulado": false, "id_norma": "172619", "numero_fuente": "36714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-15", "vigencias": [{"desde": "2000-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2000-07-18", "fecha_version": "2000-07-15", "fecha_actualizacion_texto": "2000-07-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n":