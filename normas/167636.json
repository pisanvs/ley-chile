{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.997, DE 1987 </div></div>", "i": 6271907}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.997, de fecha 07 de Septiembre de 1987, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se aprobaron planes y programas de estudio del &#xE1;rea agropecuaria al Centro de Formaci&#xF3;n T&#xE9;cnica &quot;Escuela Superior de Comercio Exterior ESCE&quot; de Valpara&#xED;so. Para optar al t&#xED;tulo, los alumnos deber&#xE1;n aprobar todas las asignaturas del plan de estudio y cumplir con las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n aprobadas por resoluci&#xF3;n exenta de Educaci&#xF3;n.</div><br></div>", "i": 6271908}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6271909}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1997 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1997 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.997, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-07", "doble_articulado": false, "id_norma": "167636", "numero_fuente": "32941", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-10", "vigencias": [{"desde": "1987-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-10", "fin_vigencia": "", "tipo_versio