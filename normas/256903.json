{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6595312}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 560 de 25 de septiembre de 2006 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n parcial, conforme D.L. N&#xBA; 2.186 de 1978, del inmueble ubicado en calle Santa Rosa N&#xBA;4398, presunto Rol de Aval&#xFA;o N&#xBA; 4238-42, comuna de San Joaqu&#xED;n, aparente dominio de Hern&#xE1;n Andr&#xE9;s del Carmen Riquelme Ubilla;</div><div class=\"p\">correspondiente al Lote N&#xBA;111, del Proyecto Vial &quot;Mejoramiento Eje Santa Rosa entre Avda. Matta y Callej&#xF3;n Lo Ovalle&quot;. Comisi&#xF3;n integrada por peritos Miguel Fern&#xE1;ndez C&#xE1;diz, Constructor civil, Erick Ehrenfeld Allera, Arquitecto y Douglas Herrera Flores, Constructor civil, seg&#xFA;n informe de 17 de agosto de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $3.290.500. pagadera al contado.</div><br></div>", "i": 6595313}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6595314}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "560", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-560"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACION PARCIAL DE INMUEBLES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-09-25", "doble_articulado": false, "id_norma": "256903", "numero_fuente": "38652", "tipo_version": "3", "tipo_version_s