{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10129445}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xBA; 364 de 19 de mayo de 2020, se tuvo por desistida la expropiaci&#xF3;n de los lotes de terreno N&#xBA;s 2 y 3, ordenada por <a href=\"https://www.leychile.cl/navegar?idNorma=1126707&amp;idVersion=2020-06-15\">Decreto Exento MOP N&#xBA; 1690 de 21 de noviembre de 2018</a> y por <a href=\"https://www.leychile.cl/navegar?idNorma=1130607&amp;idVersion=2020-06-15\">Decreto Exento MOP N&#xBA; 71 de 21 de marzo de 2019</a>, para la obra &quot;Concesi&#xF3;n internacional Ruta 5, Tramo: Talca - Chill&#xE1;n. Sector: Calle de Servicio Poniente Las Tinajas. Km. 348.960,00 al Km. 350.050,00&quot;, Regi&#xF3;n del Maule, comuna de Parral. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en los art&#xED;culos 7&#xBA; y 32&#xBA; del Decreto Ley N&#xBA; 2186, de 1978.</div><br><br><br></div>", "i": 10129446, "v": ["MODIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "364 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-364 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1771803", "NORMA SIN PROMULGACIÓN", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-05-19", "doble_articulado": false, "id_norma": "1146589", "numero_fuente": "42681", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-06-15", "vigencias": [{"desde": "2020-06-15", "hasta": "", "tipo_version": "3", "ti