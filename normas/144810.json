{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 26.- Santiago, 16 de Marzo de 1987.- Vistos: Lo dispuesto en el art&#xED;culo 11 del Decreto Ley No. 2.974 de 1979,</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 6195506}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Designase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del Decreto Ley citado, en la Regi&#xF3;n Metropolitana, al se&#xF1;or: - Octavio Osvaldo Jim&#xE9;nez Mellada.</div><br></div>", "i": 6195507}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Arturo Venegas Palacios, Vicepresidente Ejecutivo.</div><br></div>", "i": 6195508}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "26", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-26"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-03-16", "doble_articulado": false, "id_norma": "144810", "numero_fuente": "32758", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-04-29", "vigencias": [{"desde": "1987-04-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-04-29", "fin_vigencia": ""}, "vigencias