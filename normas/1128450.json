{"html": [{"t": "<div><br><div class=\"p\">ART&#xCD;CULOS 14 LETRA B), 58, 60, 63 Y 74 N&#xB0; 4 DE LA LEY SOBRE IMPUESTO A LA RENTA</div></div>", "i": 9996948}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta SII N&#xB0; 11 del 30 de enero de 2019. Establece forma en que debe acreditarse la residencia de las personas sin domicilio ni residencia en Chile para efectos de la retenci&#xF3;n que establece el <a href=\"https://www.leychile.cl/Navegar?idNorma=6368&amp;idParte=8656115&amp;idVersion=\">art&#xED;culo 74</a> N&#xB0; 4 de la <a href=\"https://www.leychile.cl/Navegar?idNorma=6368&amp;idParte=&amp;idVersion=\">Ley sobre Impuesto a la Renta</a>.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de enero de 2019. </div><br></div>", "i": 9996949}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "11 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-11 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ARTÍCULOS 14 LETRA B), 58, 60, 63 Y 74 N° 4 DE LA LEY SOBRE IMPUESTO A LA RENTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1540641; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-01-30", "doble_articulado": false, "id_norma": "1128450", "numero_fuente": "42271", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-02-04", "vigencias": [{"desde": "2019-02-04", "hasta": "", "tipo