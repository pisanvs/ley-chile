{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 104, DE 1989 </div></div>", "i": 8603802}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 104 de 24 de mayo de 1989 se ha agregado un art&#xED;culo 6&#xB0; al decreto supremo exento de Educaci&#xF3;n No. 84 de 1987, que aprob&#xF3; planes y programas especiales de estudio de segundo ciclo de educaci&#xF3;n media en la modalidad t&#xE9;cnico profesional, para el Liceo Industrial A No. 96 de San Miguel, Provincia de Santiago, Regi&#xF3;n Metropolitana, para las especialidades de Fotomec&#xE1;nica, Impresi&#xF3;n Gr&#xE1;fica y Composici&#xF3;n Gr&#xE1;fica. </div></div>", "i": 8603803}, {"t": "<div><div class=\"p\">Santiago, 29 de Mayo de 1989.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 8603804}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "104 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-104 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 104, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-24", "doble_articulado": false, "id_norma": "94739", "numero_fuente": "33394", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-06-10", "vigencias": [{"desde": "1989-06-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-06-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-06-10", "fin_vigencia": "", "tipo_version": "3"}