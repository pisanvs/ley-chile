{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6390863}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.023, de 25 de junio de 2002 y</div><div class=\"p\">en base a la facultad otorgada por el art&#xED;culo 105 del</div><div class=\"p\">D.F.L. MOP N&#xBA;850, de 1997, que fij&#xF3; el texto actualizado</div><div class=\"p\">de la ley N&#xBA;15.840, se expropi&#xF3; el lote de terreno</div><div class=\"p\">N&#xBA;43-C, para la obra Camino Ruta 7, sector Chamiza -</div><div class=\"p\">Quillaipe, Km. 4,83687 a Km. 15,84700, provincia de</div><div class=\"p\">Llanquihue, X Regi&#xF3;n, que figura a nombre de Uribe Jos&#xE9;</div><div class=\"p\">A. Suc., rol de aval&#xFA;o 2205-20, superficie 3.630 m&#xB2;, comuna de Puerto Montt. La Comisi&#xF3;n de Peritos, con fecha 15 de junio de 2001, fij&#xF3; la indemnizaci&#xF3;n provisional en la cantidad de $5.419.000, la que se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA;2.186, de 1978.</div><br></div>", "i": 6390864}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras Publicas </div></div>", "i": 6390865}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1023", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1023"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-25", "doble_articulado": false, "id_norma": "201028", "numero_fuente": "37323", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-08-01", "v