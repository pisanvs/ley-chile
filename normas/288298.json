{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 7.479 EXENTA, DE 2008 </div></div>", "i": 8474227}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 7.479, de 16 de octubre de 2008, se han aprobado planes y programas de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, al Colegio Apoquindo Hombres, comuna de Lo Barnechea, de Santiago, los cuales se aplicar&#xE1;n a contar del a&#xF1;o escolar 2009.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio en los Subsectores del Plan de Formaci&#xF3;n General y del Plan de Formaci&#xF3;n Diferenciada de 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media que se indican en la presente resoluci&#xF3;n.</div><br></div>", "i": 8474228}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de noviembre de 2008.- Rosita Puga Hamilton, Jefa Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 8474229}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7479 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7479 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 7.479 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-10-16", "doble_articulado": false, "id_norma": "288298", "numero_fuente": "39321", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-03-25", "vigencias": [{"desde": "2009-03-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-03-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig