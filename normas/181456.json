{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6320995}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 4,50% anual durante el mes de enero de 2001.</div><br><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad con lo dispuesto en el N&#xB0;5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de enero de 2001, fue de 4,43% anual. </div></div>", "i": 6320996}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 5 de febrero de 2001.- Jorge Carrasco V&#xE1;squez, Ministro de Fe (S).</div><br></div>", "i": 6320997}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-05", "doble_articulado": false, "id_norma": "181456", "numero_fuente": "36882", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-02-07", "vigencias": [{"desde": "2001-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-02-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso"