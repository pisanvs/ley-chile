{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6156780}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 453 de 29 de Marzo de 1988, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos de Aprovechamiento de Aguas proporcionales que corresponden a parcelas N&#xB0;s. 1 a la 84, sitios N&#xB0;s. 1 al 80; 81-A;</div><div class=\"p\">81-B y 82 al 107 y Reserva CORA N&#xB0;s. 1 y 2 del Proyecto de Parcelaci&#xF3;n &quot;San Jos&#xE9; de Catemu&quot;, de la comuna de Catemu, y Regi&#xF3;n formado por los predios: &quot;Hijuela n&#xFA;mero Uno del Fundo Santa Isabel de Reinoso&quot;, &quot;Hijuela N&#xFA;mero Dos del Fundo Santa Isabel de Reinoso&quot; y &quot;La Laguna o San Jos&#xE9; de Catemu&quot;. Los derechos de aguas se extraen del canal La Teja, canal Pepino o Huidobro. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.- </div></div>", "i": 6156781}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6156782}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "453 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-453 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-29", "doble_articulado": false, "id_norma": "132645", "numero_fuente": "33036", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-04-04", "vigencias": [{"desde": "1988-04-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"in