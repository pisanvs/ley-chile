{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACION DE INMUEBLES QUE INDICA</div><br><div class=\"p\">NOTIFICACION </div></div>", "i": 6483207}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 263, de 19 de mayo de 2004, de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xBA; 2.186, de 1978, del lote N&#xBA; 279 correspondiente a parte del inmueble ubicado en Santa Rosa 4375, presunto rol de aval&#xFA;o N&#xBA; 4240-20, comuna de San Miguel, aparente dominio de Guti&#xE9;rrez Cort&#xE9;s Mar&#xED;a Cleofa. Comisi&#xF3;n integrada por peritos Miguel Ortiz Bobadilla, constructor civil; Jimena Asenjo Burgos, arquitecto, y Pedro Almonacid Colin, ingenierio civil. Seg&#xFA;n informe de 30 de septiembre de 2003, fij&#xF3; monto provisional indemnizaci&#xF3;n en $49.500.750 pagadera al contado. </div></div>", "i": 6483208}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 6483209}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "263", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-263"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "ORDENA EXPROPIACION DE INMUEBLES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-19", "doble_articulado": false, "id_norma": "226372", "numero_fuente": "37885", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-15", "vigencias": [{"desde": "2004-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia":