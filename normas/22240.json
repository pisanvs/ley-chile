{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Demonetizacion del Papel Moneda del Estado Lei n&#xFA;m. 891.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947813}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se deroga el art&#xED;culo 2.&#xB0; de la lei n&#xFA;mero 277 de 11 de Febrero de 1895 i se reemplaza por el siguiente:</div><div class=\"p\">&nbsp; &nbsp; &quot;Art. 2.&#xB0; Desde el 31 de Diciembre de 1897 quedar&#xE1; demonetizado el papel moneda del Estado.</div><br><br></div>", "i": 5947814}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 22 de Diciembre de 1896.- FEDERICO ERRAZURIZ.- J. Sotomayor G.</div><br></div>", "i": 5947815}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "891", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-891"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DEMONETIZACION DEL PAPEL MONEDA DEL ESTADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONVERSION METALICA", "BILLETES", "MONEDAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-12-22", "doble_articulado": false, "id_norma": "22240", "numero_fuente": "5588", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1896-12-23", "vigencias": [{"desde": "1896-12-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1896-12-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici