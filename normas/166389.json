{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 107 EXENTO, DE 2000 </div></div>", "i": 6267831}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;107, de fecha 4 de abril de 2000, del Ministerio de Educaci&#xF3;n, se revoc&#xF3; el reconocimiento oficial del Centro de Formaci&#xF3;n T&#xE9;cnica Elipsis de Antofagasta, organizado por la Sociedad An&#xF3;nima Cerrada Centro de Formaci&#xF3;n T&#xE9;cnica Elipsis S.A., y se elimin&#xF3; a dicho Centro del Registro correspondiente en que se encuentra inscrito con el N&#xBA;218.</div><div class=\"p\">&nbsp; &nbsp;  Por este mismo documento, se derog&#xF3; el decreto exento de Educaci&#xF3;n N&#xBA;297 del 7 de septiembre de 1992, que reconoci&#xF3; oficialmente al Centro de Formaci&#xF3;n T&#xE9;cnica Elipsis de Antofagasta.</div><br></div>", "i": 6267832}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de abril de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6267833}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "107 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-107 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 107 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-04", "doble_articulado": false, "id_norma": "166389", "numero_fuente": "36644", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-19", "vigencias": [{"desde": "2000-04-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-04-19", "fin_vigencia": ""}