{"html": [{"t": "<div><br><div class=\"p\">&#xFEFF;INSTALACION DE LA COMISION NACIONAL.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 14 de 1827.</div></div>", "i": 10237863}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto la Comision nombrada por el Congreso a tiempo de disolverse, ha comunicado al Gobierno con esta fecha hallarse instalada; por tanto queda reconocida desde hoy con el car&#xE1;cter y atribuciones que le se&#xF1;ala la ley de su institucion. </div></div>", "i": 10237864}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Trascr&#xED;base a quienes corresponda y publ&#xED;quese.</div><br><br><div class=\"p\">&nbsp; &nbsp;  PINTO.</div><br><div class=\"p\">&nbsp; &nbsp;  Ramos.</div><div class=\"p\">&nbsp; &nbsp;  Pro secretario.</div></div>", "i": 10237865}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "﻿INSTALACION DE LA COMISION NACIONAL", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1827-07-14", "doble_articulado": false, "id_norma": "1156312", "numero_fuente": "1827", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1827-07-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1827-07-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1827-07-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2021-06-04", "fecha_version": "1827-07-14", "fecha_actualizaci