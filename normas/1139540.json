{"html": [{"t": "<div><div class=\"p\">MODIFICA EL AP&#xC9;NDICE XVIII DEL CAP&#xCD;TULO III DEL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10076196}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 5.465, de 28 de noviembre de 2019, del Director Nacional de Aduanas, se modifica el Ap&#xE9;ndice XVIII del Cap&#xED;tulo III del <a href=\"https://www.leychile.cl/Navegar?idNorma=248540&amp;idParte=&amp;idVersion=\">Compendio de Normas Aduaneras</a>, modificando el numeral 1, e incorporando el numeral 2.4 referido a &quot;Normas especiales para las empresas privadas habilitadas como Organismos Competentes&quot;.</div><div class=\"p\">&nbsp; &nbsp;  Esta resoluci&#xF3;n entra en vigencia a contar de la fecha de publicaci&#xF3;n en el Diario Oficial.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\"> </div></div>", "i": 10076197}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de noviembre de 2019.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><br></div>", "i": 10076198}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5465 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5465 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA EL APÉNDICE XVIII DEL CAPÍTULO III DEL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1692069", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-11-28", "do