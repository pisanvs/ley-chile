{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6415769}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;24, de 21 de enero de 2003, se rectific&#xF3; el decreto MOP N&#xBA;782, de fecha 17 de mayo de 2001, que dej&#xF3; sin efecto la expropiaci&#xF3;n del lote N&#xBA;1, para la obra Proyecto Mejoramiento Integral del Servicio de Agua Potable para la Zona de Pirque, en cuanto la fecha correcta del decreto MOP N&#xBA;629 es 29 de febrero de 2000 y no como en &#xE9;l se indic&#xF3;.-</div><br><br></div>", "i": 6415770}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6415771}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "24", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-24"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-21", "doble_articulado": false, "id_norma": "208031", "numero_fuente": "37498", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-03-01", "vigencias": [{"desde": "2003-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-03-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "MAS", "fecha_ingreso": "2003-03-03", "fecha_version": "2003-03-01", "fecha_actualizacion_texto": "2003-03-01", "tipo_tratado": ""}, "alertas": [], "alerta_global":