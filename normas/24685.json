{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><br></div>", "i": 7168717}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Trasp&#xE1;sase la suma de cien mil pesos ($ 100,000), del &#xED;tem 06|17|02|m|2 al &#xED;tem 03|02|02|m|1 del Presupuesto de Hacienda&quot;.</div><br></div>", "i": 7168718}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y, por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veinticinco de Julio de mil novecientos veintiocho.- Carlos Ib&#xE1;&#xF1;ez del Campo.- Pablo Ram&#xED;rez. </div></div>", "i": 7168719}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4358", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4358"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1928", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-07-25", "doble_articulado": false, "id_norma": "24685", "numero_fuente": "15194", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-10-09", "vigencias": [{"desde": "1928-10-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-10-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1928-10-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "in