{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.320, DE 1987 </div></div>", "i": 7259218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.320, de fecha 16 de Junio de 1987, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se aprobaron las modificaciones introducidas al plan y programas de estudio del Centro de Formaci&#xF3;n T&#xE9;cnica Escuela Superior de Administraci&#xF3;n de Negocios ESANE de Santiago, de la carrera y t&#xED;tulo t&#xE9;cnico que se indica, para impartirse a contar del a&#xF1;o 1987:</div><br><div class=\"p\">Carrera: Interpretaci&#xF3;n Ingl&#xE9;s - Alem&#xE1;n.</div><div class=\"p\">T&#xED;tulo: Int&#xE9;rprete Ingl&#xE9;s Alem&#xE1;n con menci&#xF3;n Turismo o Secretariado o Traducci&#xF3;n T&#xE9;cnico-Cient&#xED;fica. </div></div>", "i": 7259219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7259220}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1320 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1320 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.320, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-16", "doble_articulado": false, "id_norma": "152047", "numero_fuente": "32843", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-11", "vigencias": [{"desde": "1987-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-08-11", "fin_vig