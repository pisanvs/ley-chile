{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,880.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6175343}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese a don M&#xE1;ximo R. Lira el derecho a jubilacion que le corresponder&#xED;a como Enviado Estraordinario i Ministro Plenipotenciario, i se le declara de abono el tiempo que le falta para cumplir cuarenta a&#xF1;os de servicios.</div><br></div>", "i": 6175344}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a cuatro de febrero de mil novecientos catorce- Ramon Barros Luco.- Enrique Villegas E. </div></div>", "i": 6175345}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2880", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2880"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1914-02-04", "doble_articulado": false, "id_norma": "138430", "numero_fuente": "10814", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1914-03-06", "vigencias": [{"desde": "1914-03-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1914-03-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1914-03-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_