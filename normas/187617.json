{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6342578}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;832, de 31 de mayo de 2001, se expropi&#xF3; el lote de terreno N&#xBA;47-C, superficie 4.586 m&#xB2;, rol de aval&#xFA;o 1301-51, comuna de La Ligua, para la obra Camino Ruta 5 Norte, Tramo Santiago - Los Vilos, Quinta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Manuela N&#xFA;&#xF1;ez Cortez y otros, ascendente a la cantidad de $9.839.555.-</div><br></div>", "i": 6342579}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6342580}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "832", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-832"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-31", "doble_articulado": false, "id_norma": "187617", "numero_fuente": "37012", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-07-16", "vigencias": [{"desde": "2001-07-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-07-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-07-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2001-07-16", "fecha_version": "2001-07-16", "fecha_actualizacion_texto": "2001-07-16", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6342578},