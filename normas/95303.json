{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6099609}, {"t": "<div><div class=\"p\">Por resuelvo SENDOS No.550, de 24 de Julio de 1989, se expropi&#xF3; el lote de terreno No.2, Rol No.9046-6 de la Comuna de Laguna Verde, V Regi&#xF3;n, de 240 m2 de superficie, para la obra Agua Potable Rural Laguna Verde y se acord&#xF3; el monto de la indemnizaci&#xF3;n con sus propietarios don Francisco y don Guillermo Murillo Soffia, ascendente a $ 60.000. </div></div>", "i": 6099610}, {"t": "<div><div class=\"p\">Director Nacional de Obras Sanitarias.</div><br></div>", "i": 6099611}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "550", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-550"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SERVICIO NACIONAL DE OBRAS SANITARIAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-07-24", "doble_articulado": false, "id_norma": "95303", "numero_fuente": "33463", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-09-01", "vigencias": [{"desde": "1989-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1998-03-12", "fecha_version": "1989-09-01", "fecha_actualizacion_texto": "1989-09-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6099609}, {"n": "Artículo", "i": 6099610, "t": 6}, {"n":