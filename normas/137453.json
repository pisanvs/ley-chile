{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,469.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6172158}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se otorga a la viuda e hija soltera de don Eli ro Infante Valdes una pension anual de dos mil pesos ($ 2,000) que gozar&#xE1;n con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6172159}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, primero de febrero de mil novecientos once.- Ramon Barros Luco.- Roberto S&#xE1;nchez.</div><br></div>", "i": 6172160}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2469", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2469"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-02-01", "doble_articulado": false, "id_norma": "137453", "numero_fuente": "9902", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-02-08", "vigencias": [{"desde": "1911-02-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-02-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-02-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-06-09",