{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AUMENTA LA PLANTA DE OFICIALES DE ADMINISTRACION DE LOS SERVICIOS DE LA ARMADA</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5964767}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1&#xB0;.- Aum&#xE9;ntase la planta de Oficiales de Administraci&#xF3;n de los Servicios de la Armada, en la forma que sigue:</div><div class=\"p\">&nbsp; &nbsp; 2 Tenientes 1&#xB0;s.</div><div class=\"p\">&nbsp; &nbsp; 2 Tenientes 2&#xB0;s.</div><div class=\"p\">&nbsp; &nbsp; 2 Guardiamarinas.</div><br></div>", "i": 5964768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2&#xB0;.- El gasto que demande esta ley se imputar&#xE1; a la mayor entrada que produzca la Cuenta C-36 &quot;Impuesto sobre Alcoholes, licores, vinos y cervezas&quot;. </div></div>", "i": 5964769}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 3&#xB0;.- La presente ley comenzar&#xE1; a regir desde la fecha de su publicaci&#xF3;n en el Diario Oficial&quot;. </div></div>", "i": 5964770}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, diecisiete de Junio de mil novecientos cuarenta y tres.- JUAN ANTONIO RIOS M.- O. Escudero O. </div></div>", "i": 5964771}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "7422", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-7422"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL"], "titulo_norma": "AUMENTA LA PLANTA DE OFICIALES DE ADMINISTRACION DE\nLOS SERVICIOS DE LA ARMADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "PLANTA DE OFICIALES", "ARMADA DE CHILE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "dero