{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6931027}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de enero de 2009, fue de 9,21% anual.</div><br></div>", "i": 6931028}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, enero 19 de 2009.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6931029}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "BANCO CENTRAL DE CHILE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-01-19", "doble_articulado": false, "id_norma": "285544", "numero_fuente": "39267", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-01-21", "vigencias": [{"desde": "2009-01-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-01-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-01-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "GMG", "fecha_ingreso": "2009-01-21", "fecha_version": "2009-01-21", "fecha_actualizacion_texto": "2009-01-21", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6931027}, {"n": "Artíc