{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;866 EXENTO, DE 2001</div><br><br><br></div>", "i": 6359771}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; Por decreto exento N&#xBA;866, de fecha 31 de octubre de 2001, del Ministerio de Educaci&#xF3;n, se modifica el art&#xED;culo 1&#xBA; del decreto exento de Educaci&#xF3;n N&#xBA;72 del 27 enero de 1995 que reconoci&#xF3; oficialmente al Centro de Formaci&#xF3;n T&#xE9;cnica C&#xE1;mara de Comercio de Santiago, en el sentido de modificar su ubicaci&#xF3;n f&#xED;sica y de incorporar el nuevo local de funcionamiento:</div><br><div class=\"p\">Casa Central : Vergara N&#xBA;409 - Santiago</div><div class=\"p\">Local&nbsp; &nbsp; &nbsp; &nbsp; : Grajales N&#xBA;1898 - Santiago (destinado a</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  ampliar las dependencias de la Sede</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Central).</div><br></div>", "i": 6359772}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de noviembre de 2001.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6359773}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "866 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-866 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº866 EXENTO, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-10-31", "fecha_derogacion": "2006-08-28", "doble_articulado": false, "id_norma": "192166", "numero_fuente": "37126", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion"