{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9361765}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.579, de 24 de junio de 2013, de esta Subsecretar&#xED;a, rectif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1043561&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 2.276, del 16 de agosto de 2012</a>, en el sentido de reemplazar el nombre del proyecto por el siguiente: &quot;Monitoreo de fauna acu&#xE1;tica en aguas continentales de Chile, entre la XIV y XI Regiones&quot;.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en el sitio de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura.</div><br></div>", "i": 9361766}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de junio de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9361767}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1579 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1579 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-06-24", "doble_articulado": false, "id_norma": "1052268", "numero_fuente": "40596", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-06-28", "vigencias": [{"desde": "2013-06-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-06-28", "fin_vigencia": ""}, "vigencias_versio