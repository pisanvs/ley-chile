{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6064652}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xB0;. 231, de 11 de abril de 1990, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriz&#xF3; a la Empresa de Transportes Bus Norte, Osvaldo Cid y Compa&#xF1;&#xED;a, para efectuar transporte terrestre de pasajeros entre Osorno y Punta Arenas, en tr&#xE1;nsito por territorio argentino, por los Pasos Puyehue y Monte Aymond, con tres frecuencias semanales, las que se efectuar&#xE1;n en los siguiente d&#xED;as:</div><br><div class=\"p\">Osorno - Punta Arenas: lunes mi&#xE9;rcoles s&#xE1;bado. Punta Arenas - Osorno: martes jueves s&#xE1;bado.- </div></div>", "i": 6064653}, {"t": "<div><div class=\"p\">Sergio Gonz&#xE1;lez Tagle, Subsecretario de Transportes. </div></div>", "i": 6064654}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "231", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-231"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-04-11", "doble_articulado": false, "id_norma": "83192", "numero_fuente": "33667", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-05-11", "vigencias": [{"desde": "1990-05-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-05-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-05-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingres