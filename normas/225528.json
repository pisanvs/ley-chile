{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6480304}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.303, de 10 de mayo de</div><div class=\"p\">2004, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD</div><div class=\"p\">PESQUERA LANDES S.A. para ampliar actividades pesqueras</div><div class=\"p\">con la nave &quot;Araucan&#xED;a I&quot;, en las &#xE1;reas mar&#xED;timas que en</div><div class=\"p\">cada caso se indican, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, con cerco, donde podr&#xE1; capturar el siguiente recurso hidrobiol&#xF3;gico: a) Entre la III a IV Regiones: Jibia; b) Entre la VII a X Regiones: Jibia </div></div>", "i": 6480305}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de mayo de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6480306}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1303 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1303 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-05-10", "fecha_derogacion": "2005-05-07", "doble_articulado": false, "id_norma": "225528", "numero_fuente": "37868", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-05-25", "vigencias": [{"desde": "2005-05-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-05-25", "hasta": "2005-05-06", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inici