{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SUPLEMENTOS Lei n&#xFA;m. 322.-Santiago, a 19 de Diciembre de 1895.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947518}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de 100,000 pesos al &#xED;tem 1 de la partida 35 del presupuesto de Guerra para reponer el ganado de los cuerpos de Artiller&#xED;a i Caballer&#xED;a; i 100,000 pesos al &#xED;tem 1 de la partida 34 del mismo presupuesto, para reparaciones de cuarteles i establecimientos militares.</div><br><br></div>", "i": 5947519}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.-Luis Barros Borgo&#xF1;o.</div><br></div>", "i": 5947520}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "322", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-322"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "SUPLEMENTOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1975", "MODIFICACION", "MINISTERIO", "GUERRA", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-12-19", "doble_articulado": false, "id_norma": "22173", "numero_fuente": "5290", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-12-20", "vigencias": [{"desde": "1895-12-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-12-20", "fin_vigencia": ""}, "vigencias_v