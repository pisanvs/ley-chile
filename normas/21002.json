{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 325, DE 1993 </div></div>", "i": 5943830}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 325 de 25 de junio de 1993 se ha aprobado un plan de estudio para educaci&#xF3;n b&#xE1;sica que se aplicar&#xE1; en las Escuelas que se se&#xF1;alan en el presente decreto, dependientes de la Fundaci&#xF3;n del Magisterio de La Araucan&#xED;a. Adem&#xE1;s, se aprueba el programa de la asignatura de Mapudungun para 1&#xB0; a 8&#xB0; a&#xF1;o b&#xE1;sico.</div><br></div>", "i": 5943831}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 28 de junio de 1993.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943832}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "325", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-325"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 325, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ESTABLECIMIENTOS EDUCACIONALES", "OCTAVA REGION", "FUNDACION MAGISTERIO ARAUCANIA", "PROGRAMAS ESTUDIO", "PLANES ESTUDIO", "EDUCACION BASICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-06-25", "doble_articulado": false, "id_norma": "21002", "numero_fuente": "34602", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-06-30", "vigencias": [{"desde": "1993-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-06-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-06-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos