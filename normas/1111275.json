{"html": [{"t": "<div><div class=\"p\">Academia Militar</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Junio 30 de 1817.</div></div>", "i": 9861375}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Deseoso este Gobierno de consultar el progreso de la Academia Militar i de beneficiar a los hijos de Chile con la jenerosidad que le caracteriza: ha acordado que a mas de las cincuenta plazas que dot&#xF3; en la primera sesion de aquel establecimiento, se aumenta hoi otros cincuenta de la misma clase.- Trascr&#xED;base al Excmo. se&#xF1;or Jeneral en jefe de los Ej&#xE9;rcitos de los Andes i Chile i al Director encargado de aquella, e impr&#xED;mase.- </div></div>", "i": 9861376}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Quintana.</div></div>", "i": 9861377}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Academia Militar", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1817-06-30", "doble_articulado": false, "id_norma": "1111275", "numero_fuente": "1817", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1817-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1817-06-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1817-06-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2017-12-04", "fecha_version": "1817-06-30", "fecha_actualizacion_texto": "2017-12-04", "tipo_tratado": ""}, "alertas": [], "ale