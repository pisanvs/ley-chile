{"html": [{"t": "<div><div class=\"p\">MODIFICA RES. EX. SII N&#xBA; 19, de 12.02.2008</div></div>", "i": 9025300}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA;160 de 22 de octubre de 2010, que modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=269311&amp;idParte=0&amp;idVersion=\">Res. Ex. SII N&#xBA; 19, de 12.02.2008</a>.</div><div class=\"p\">&nbsp; &nbsp;  Autor&#xED;za la emisi&#xF3;n de representaciones impresas de boletas electr&#xF3;nicas en un ancho m&#xED;nimo de 5,7 cent&#xED;metros y un tama&#xF1;o m&#xED;nimo del timbre electr&#xF3;nico de 2 x 4,5 cent&#xED;metros, para contribuyentes no prestadores de servicios peri&#xF3;dicos.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de octubre de 2010.</div></div>", "i": 9025301}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "160 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-160 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RES. EX. SII Nº 19, de 12.02.2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-10-22", "doble_articulado": false, "id_norma": "1018492", "numero_fuente": "39796", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-10-28", "vigencias": [{"desde": "2010-10-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "