{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6539085}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.526, de 8 de agosto de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a SALVADOR DE LA CRUZ AHUMADA CEPEDA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en pasaje Lord Cochrane s/n, Bucalemu, comuna de Paredones, VI Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido el recurso hidrobiol&#xF3;gico indicado en la resoluci&#xF3;n extractada. </div></div>", "i": 6539086}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de agosto de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6539087}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2526 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2526 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-08-08", "doble_articulado": false, "id_norma": "241714", "numero_fuente": "38256", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-09-07", "vigencias": [{"desde": "2005-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-09-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-09-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-09-07", "fecha_version": "2