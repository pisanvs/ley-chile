{"html": [{"t": "<div><div class=\"p\">CAMBIA DENOMINACION A OFICINA DE ARQUITECTURA </div></div>", "i": 7343279}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 44 del 4 de abril de 2007.</div><div class=\"p\">&nbsp; &nbsp;  La resoluci&#xF3;n mencionada cambia denominaci&#xF3;n a la Oficina de Arquitectura dependiente de la Subdirecci&#xF3;n de Administraci&#xF3;n, pasando a denominarse &quot;Oficina de Gesti&#xF3;n de Proyectos de Infraestructura&quot;.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en abril de 2007. </div></div>", "i": 7343280}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "44 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-44 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CAMBIA DENOMINACION A OFICINA DE ARQUITECTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SERVICIO DE IMPUESTOS INTERNOS", "OFICINA DE ARQUITECTURA", "OFICINA DE GESTION DE PROYECTOS DE INFRAESTRUTURA", "DENOMINACION", "CAMBIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-04-04", "doble_articulado": false, "id_norma": "261400", "numero_fuente": "38779", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-06-04", "vigencias": [{"desde": "2007-06-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-06-04", "f