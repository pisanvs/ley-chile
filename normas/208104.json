{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7298343}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;566, de 24 de febrero de 2003, de</div><div class=\"p\">esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la</div><div class=\"p\">resoluci&#xF3;n N&#xBA;460 de 1987, de esta Subsecretar&#xED;a, s&#xF3;lo en</div><div class=\"p\">cuanto autoriz&#xF3; a MARIA BAYCIC BAYCIC para operar la</div><div class=\"p\">nave &quot;Ulises 2&quot;, en la IX Regi&#xF3;n, con arrastre, sobre</div><div class=\"p\">los recursos Camar&#xF3;n nailon, Langostino colorado y</div><div class=\"p\">Langostino amarillo, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7298344}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de febrero de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7298345}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "566", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-566"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-02-24", "doble_articulado": false, "id_norma": "208104", "numero_fuente": "37500", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-03-04", "vigencias": [{"desde": "2003-03-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-03-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc