{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUClON </div></div>", "i": 6174943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 18, de 26 de enero de 1988, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la XII Regi&#xF3;n, Magallanes y Ant&#xE1;rtica Chilena, se autoriza a Enrique Heraldo Seoane Mu&#xF1;oz, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos de locomoci&#xF3;n colectiva urbana de pasajeros.-</div><br></div>", "i": 6174944}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Urbano Peralta Secretario Regional Ministerial XII Regi&#xF3;n.</div><br></div>", "i": 6174945}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "18 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-18 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XII REGIÓN DE MAGALLANES Y ANTÁRTICA CHILENA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-26", "doble_articulado": false, "id_norma": "138279", "numero_fuente": "32987", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-04", "vigencias": [{"desde": "1988-02-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-02-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [],