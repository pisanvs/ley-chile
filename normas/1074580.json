{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N&nbsp; N&#xBA; 9.065 EXENTA, DE 2014</div><div class=\"p\"> </div></div>", "i": 9560826}, {"t": "<div><div class=\"p\">&nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=199167&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 5.937, de 2002, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; planes y programas especiales de estudio de 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Colegio Compa&#xF1;&#xED;a de Mar&#xED;a - Apoquindo, comuna de Las Condes, provincia de Santiago, Regi&#xF3;n Metropolitana.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio de 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media del Plan de Formaci&#xF3;n Diferenciada, que se indican en la presente resoluci&#xF3;n exenta.</div><br></div>", "i": 9560827}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de diciembre de 2014.- Gonzalo Mu&#xF1;oz Stuardo, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><div class=\"p\">&nbsp; </div></div>", "i": 9560828}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9065 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-9065 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 9.065 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-12-19", "doble_articulado": false, "id_norma": "1074580", "numero_fuente": "41077", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion":