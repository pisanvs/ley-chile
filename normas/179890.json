{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6315578}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.714, de 28 de diciembre de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las siguientes resoluciones, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura:</div><div class=\"p\">a)&nbsp;  Resoluci&#xF3;n N&#xBA; 501 de 1987, de esta Subsecretar&#xED;a que autoriz&#xF3; a PESQUERA Y CULTIVOS DE RECURSOS MARINOS LIMITADA para operar la nave &apos;&apos;Pecremar I&apos;&apos; y seis naves en construcci&#xF3;n.</div><div class=\"p\">b)&nbsp;  Resoluci&#xF3;n N&#xBA; 459 de 1991, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Pesquera Isla Mocha Limitada para operar la nave &apos;&apos;Pecremar II&apos;&apos;.</div><br></div>", "i": 6315579}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de diciembre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca. </div></div>", "i": 6315580}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2714", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2714"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-12-28", "doble_articulado": false, "id_norma": "179890", "numero_fuente": "36855", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-06", "vigencias": [{"desde": "2001-01-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-06", "fin_v