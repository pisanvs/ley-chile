{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7416974}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.958, de 11 de noviembre de 2008, de esta Subsecretar&#xED;a, autor&#xED;zase a JORGE ANTONIO CORTEZ ZEPEDA para iniciar actividades pesqueras de transformaci&#xF3;n, para iniciar y operar planta ubicada en sector caleta Huaman, km. 220, ruta B-1, camino Tocopilla-Iquique, para elaborar en las l&#xED;neas de proceso de Alga seca, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div><div class=\"p\">D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 667, de 2008, en virtud del contenido de la presente resoluci&#xF3;n. </div></div>", "i": 7416975}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de noviembre de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca. </div></div>", "i": 7416976}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2958 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2958 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-11-11", "doble_articulado": false, "id_norma": "282334", "numero_fuente": "39225", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-11-29", "vigencias": [{"desde": "2008-11-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-11-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-11-29", "fin_vigencia": "", "tipo_version":