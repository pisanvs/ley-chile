{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N&#xB0; 11,481, DE 20 DE ENERO DE 1954 Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5969927}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Reempl&#xE1;zase en la letra d) del</div><div class=\"p\">art&#xED;culo 4&#xB0; de la ley N&#xB0; 11,481, de 20 de Enero de 1954, el apellido &quot;Cartes&quot; por &quot;Carter&quot;.</div><br></div>", "i": 5969928}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintiocho de Enero de mil novecientos cincuenta y cinco.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Frascisco Cuevas Mackenna.</div><br></div>", "i": 5969929}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11781", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11781"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA LA LEY N° 11,481, DE 20 DE ENERO DE 1954", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PENSION GRACIA", "SINIESTRO", "VALPARAISO", "JUAN CARTES VALENZUELA", "ESTER MATTAR MATTAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1955-01-28", "doble_articulado": false, "id_norma": "26796", "numero_fuente": "23072", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1955-02-12", "vigencias": [{"desde": "1955-02-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1955-02-12", "fin_vigencia": ""}, "vigencias_ve