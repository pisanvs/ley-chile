{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Jubilacion de don Rafael Blanco Lei n&#xFA;m. I666.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente:</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274580}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se concede, por gracia, al Secretario de la C&#xE1;mara de Diputados, don Rafael Blanco, el derecho de jubilar con el sueldo &#xED;ntegro asignado a su empleo.</div><br></div>", "i": 8274581}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 8 de Agosto de 1904.- JERMAN RIESCO.- M.</div><div class=\"p\">E. Ballesteros.</div><br></div>", "i": 8274582}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1666", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1666"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Jubilacion de don Rafael Blanco", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RAFAEL BLANCO", "JUBILACION POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-08-08", "doble_articulado": false, "id_norma": "22830", "numero_fuente": "7974", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1904-08-08", "vigencias": [{"desde": "1904-08-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1904-08-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1904-08-08", "fin_vigencia": "", "t