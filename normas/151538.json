{"html": [{"t": "<div><div class=\"p\">NOTIFICACION </div></div>", "i": 6220050}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 932 de 12 de septiembre 1986 de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. 2.186 de 1078, parte inmueble calle 1&#xB0; de Mayo N&#xB0; 4999, presunto rol aval&#xFA;os 7604-30 comuna San Miguel, aparentemente dominio de don Enrique Maldonado L&#xF3;pez. Comisi&#xF3;n integrada por peritos se&#xF1;ores Luis Nieto Espinoza y Emilio Recabarren Solar ingenieros civiles y Roberto Correa Bezanilia, arquitecto, seg&#xFA;n informe de 3 de Julio de 1986, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 41.600.-, pagadera al contado.-</div><br></div>", "i": 6220051}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director SERVIU Metropolitano.</div><br></div>", "i": 6220052}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "932", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-932"}], "organismos": ["SERVICIO DE VIVIENDA Y URBANIZACIÓN REGIÓN METROPOLITANA"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-09-12", "doble_articulado": false, "id_norma": "151538", "numero_fuente": "32.585", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-10-01", "vigencias": [{"desde": "1986-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-10-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMZ", "fecha_ingre