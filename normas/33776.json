{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291106}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 211, de 24 de Marzo de 1993, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por 1 a&#xF1;o a contar</div><div class=\"p\">del 4 de octubre de 1993, el plazo otorgado a don ELMO</div><div class=\"p\">ARTURO JARAMILLO AROS, R.U.T. N&#xB0; 2.463. 954-1. para operar la nave &quot;Do&#xF1;a Isabel&quot;, autorizada por la Resoluci&#xF3;n N&#xB0; 1239, de 1991, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8291107}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 24 de Marzo de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8291108}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "211", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-211"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ELMO ARTURO JARAMILLO AROS", "PESCA", "AMPLIACION", "PLAZO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-03-24", "doble_articulado": false, "id_norma": "33776", "numero_fuente": "34548", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-04-23", "vigencias": [{"desde": "1993-04-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-04-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-04-23", "fin_vigencia": "", "tipo_ver