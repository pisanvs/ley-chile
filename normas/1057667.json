{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">REEMPLAZA ESTRUCTURA Y CONTENIDO DE DOCUMENTOS QUE INDICA</div></div>", "i": 9394874}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 106, del 24 de diciembre de 2013, que establece:</div><div class=\"p\">&nbsp; &nbsp;  Reemplaza estructura y contenido de las Declaraciones Juradas Formularios Nos 1804, 1812, 1817, 1818, 1821, 1822, 1828, 1832, 1852, 1853, 1884, 1885, 1886 y 1887, y los Modelos de Certificados Nos 3, 4, 5, 6, 11, 15, 16, 22 y 29.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de diciembre de 2013.</div></div>", "i": 9394875}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Alejandro Burr Ort&#xFA;zar, Director (S).</div></div>", "i": 9394876}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "106 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-106 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS"], "titulo_norma": "REEMPLAZA ESTRUCTURA Y CONTENIDO DE DOCUMENTOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-12-24", "doble_articulado": false, "id_norma": "1057667", "numero_fuente": "40745", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-12-31", "vigencias": [{"desde": "2