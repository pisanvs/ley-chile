{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 117, DE 1992 </div></div>", "i": 5941382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 117 de fecha 08 de Mayo de 1992 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a las Sedes que se indican del Centro de Formaci&#xF3;n T&#xE9;cnica PROPAM, para impartir planes y programas de estudios aprobados para la instituci&#xF3;n de las carreras y t&#xED;tulos t&#xE9;cnicos de nivel superior que se se&#xF1;alan, a partir del a&#xF1;o 1992:</div><div class=\"p\"> - Sede N&#xB0; 5 - Ovalle:</div><div class=\"p\"> Carrera: T&#xE9;cnico Agr&#xED;cola (Resoluci&#xF3;n Exenta N&#xB0; 2871/88).</div><div class=\"p\"> T&#xED;tulo: T&#xE9;cnico Agr&#xED;cola.</div><div class=\"p\"> - Sede N&#xB0; 8 - Curic&#xF3;:</div><div class=\"p\"> Carrera: T&#xE9;cnico Forestal (Resoluci&#xF3;n Exenta N&#xB0; 3316/89).</div><div class=\"p\"> T&#xED;tulo: T&#xE9;cnico Forestal.</div><br></div>", "i": 5941383}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 14 de Diciembre de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5941384}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "117", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-117"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 117, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA PROPAM", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "TECNICO AGRICOLA", "TECNICO FORESTAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-12-14", "doble_articulado": false, "id_norma": "20245", "numero_fuente": "34508