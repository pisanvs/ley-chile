{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6519642}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 648, de 8 de marzo de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a BRACPESCA S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Linda Kay&quot;, en las &#xE1;reas mar&#xED;timas que se indica, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar el recurso hidrobiol&#xF3;gico que a continuaci&#xF3;n se se&#xF1;ala: a) En el &#xE1;rea mar&#xED;tima comprendida entre la I y XII regiones, con potera: Jibia.</div><br></div>", "i": 6519643}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de marzo de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6519644}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "648 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-648 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-03-08", "doble_articulado": false, "id_norma": "236456", "numero_fuente": "38115", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-03-19", "vigencias": [{"desde": "2005-03-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-03-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-03-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2005-03-21", "