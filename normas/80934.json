{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 140, DE 1991</div><br><br><br></div>", "i": 7215813}, {"t": "<div><div class=\"p\">Por Decreto Exento No. 140 de fecha 25 de junio de 1991 del Ministerio de Educaci&#xF3;n, se aprobaron las modificaciones introducidas al plan y programas de estudio del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Chileno Alem&#xE1;n de Cultura de San Antonio, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para impartirse a contar del a&#xF1;o 1990, con la siguiente denominaci&#xF3;n:</div><div class=\"p\">Carrera: Secretariado Comercial, cambia por:</div><div class=\"p\">Carrera: Secretariado Ejecutivo</div><div class=\"p\">T&#xED;tulo: Secretario (a) Ejecutivo (a) con conocimiento en Contabilidad.</div><br></div>", "i": 7215814}, {"t": "<div><div class=\"p\">Santiago, 21 de Agosto de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7215815}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "140 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-140 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "OTORGA CONCESION DE RADIODIFUSION SONORA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-06-25", "doble_articulado": false, "id_norma": "80934", "numero_fuente": "34092", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-10-16", "vigencias": [{"desde": "1991-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-10-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"