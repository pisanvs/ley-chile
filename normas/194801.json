{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO CALIDAD DE AGENTE RETENEDOR DEL IVA A ADMINISTRADORA LAS BRISAS SAN FELIPE LTDA.</div><br></div>", "i": 6370035}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La V Direcci&#xF3;n Regional del Servicio de Impuestos Internos, por Res. Ex. N&#xBA; 4 del 1 de febrero de 2002 deja sin efecto la calidad de agente retenedor del IVA a contar de la fecha de su publicaci&#xF3;n en el Diario Oficial, a la sociedad Administradora Las Brisas San Felipe Ltda. RUT N&#xBA; 77.194.610-0, en las adquisiciones de harina, conforme a lo establecido en la resoluci&#xF3;n Ex. N&#xBA; 5.282 del 30.11.2000 de la Direcci&#xF3;n Nacional. </div></div>", "i": 6370036}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Erica Morales Lartiga, Director Regional (S). </div></div>", "i": 6370037}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL DE VALPARAÍSO"], "titulo_norma": "DEJA SIN EFECTO CALIDAD DE AGENTE RETENEDOR DEL IVA A\nADMINISTRADORA LAS BRISAS SAN FELIPE LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-01", "doble_articulado": false, "id_norma": "194801", "numero_fuente": "37193", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-02-22", "vigencias": [{"desde": "2002-02-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-02-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-02-22", "fin_vigenci