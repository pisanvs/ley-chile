{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6438126}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.785, de 6 de agosto de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a GILBERTO LEONCIO ALVAREZ OSORIO para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Vallenar, Panamericana Norte kil&#xF3;metro 667, III Regi&#xF3;n, donde podr&#xE1; procesar, en la l&#xED;nea de elaboraci&#xF3;n que se indica, los siguientes recursos hidrobiol&#xF3;gicos: Picado de algas: Huiro Palo, Chasc&#xF3;n, Huiro, Pelillo.</div><br></div>", "i": 6438127}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6438128}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1785 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1785 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-06", "doble_articulado": false, "id_norma": "214304", "numero_fuente": "37650", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-02", "vigencias": [{"desde": "2003-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-09-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fech