{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6077431}, {"t": "<div><div class=\"p\">Certifico que este Banco Central de Chile, a solicitud de los interesados, ha modificado la autorizaci&#xF3;n concedida a la Casa de Cambios Andino Ocho Ltda. M.C.F. para operar como entidad del mercado cambiario formal en Santiago, Valpara&#xED;so y Vi&#xF1;a del Mar, limitando dicha autorizaci&#xF3;n exclusivamente a la oficina principal de la Casa de Cambio ubicada en calle Arlegui No. 646, Local 1-C de la Ciudad de Vi&#xF1;a del Mar. </div></div>", "i": 6077432}, {"t": "<div><div class=\"p\">Santiago, 19 de Marzo de 1991.- V&#xED;ctor Vial del R&#xED;o, Secretario General.</div><br></div>", "i": 6077433}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["ESTA NORMA NO TIENE TITULO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-03-19", "doble_articulado": false, "id_norma": "87875", "numero_fuente": "33923", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-03-20", "vigencias": [{"desde": "1991-03-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-03-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-03-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1998-02-04", "fecha_version": "1991-03-20", "fecha_actualizacion_texto": "1991-03-20", "tipo_tratado": ""}, "alertas": [], "