{"html": [{"t": "<div><div class=\"p\">MODIFICA SOBRETASA ARANCELARIA</div><br><div class=\"p\">&nbsp; &nbsp;  No. 639.- Santiago, 11 de Julio de 1985.- Visto: Lo dispuesto en el decreto de Hacienda No. 271, de 1985; y </div><div class=\"p\">&nbsp; &nbsp;  Teniendo presente: Lo dispuesto en el art&#xED;culo 4&#xB0; del Decreto de Hacienda No. 10, de 1967,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 8604016}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alzase a 15% la sobretasa arancelaria establecida por el decreto de Hacienda No. 271, de 1985.</div><br></div>", "i": 8604017}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- AUGUSTO PINOCHET UGARTE, General de Ej&#xE9;rcito, Presidente de la Rep&#xFA;blica.- Manual Concha Mart&#xED;nez, Coronel de Ej&#xE9;rcito, Ministro de Hacienda subrogante.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud., para su conocimiento.- Saluda atentamente a Ud.- Manuel Concha Mart&#xED;nez, Coronel de Ej&#xE9;rcito, Subsecretario de Hacienda. </div></div>", "i": 8604018}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "639", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-639"}], "organismos": ["MINISTERIO DE HACIENDA", "SUBSECRETARÍA DE HACIENDA"], "titulo_norma": "MODIFICA SOBRETASA ARANCELARIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-07-11", "doble_articulado": false, "id_norma": "162889", "numero_fuente": "32227", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-07-20", "vigencias": [{"desde": "1985-07-20", "hasta": "", "tipo_version": "3", "tipo_version_s