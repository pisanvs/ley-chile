{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; HABILITA PUNTO &quot;PASO DE JAMA&quot;</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 1.113.- Santiago, 21 de Noviembre de 1991.- Visto: Estos antecedentes y lo dispuesto en los art&#xED;culos 2, 4, 5 y 6 de la Ordenanza de Aduanas.</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 7154903}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico: Agr&#xE9;gase a la letra D, del art&#xED;culo 3, del Decreto Supremo N&#xB0; 1.230, de 1989, del Ministerio de Hacienda, el siguiente punto Habilitado n&#xFA;mero 15 sujeto a la jurisdicci&#xF3;n de la Aduana de Antofagasta:</div><div class=\"p\">&nbsp; &nbsp; &quot;15. Jama Permanente. Paso de personas y todo tipo de operaciones aduaneras, controladas en punto San Pedro de Atacama.</div><br></div>", "i": 7154904, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Alejandro Foxley Rioseco, Ministro de Hacienda.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda atte. a Ud.- Pablo Pi&#xF1;era Echenique, Subsecretario de Hacienda.</div><br></div>", "i": 7154905}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1113", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1113"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "HABILITA PUNTO PASO DE JAMA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PASOS FRONTERIZOS", "ADUANAS", "HABILITACION", "PASO FRONTERIZO JAMA", "II REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-11-21", "doble_articulado": false, "i