{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 898 EXENTA, DE 2009</div></div>", "i": 8655665}, {"t": "<div><div class=\"p\">&nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 898, de 6 de mayo de 2009. del Ministerio de Transportes y Telecomunicaciones, se autoriza de conformidad a lo dispuesto en el N&#xBA; 5 de la resoluci&#xF3;n N&#xBA; 65, de 2000, del Ministerio de Transportes y Telecomunicaciones al taller Truck Service Ltda., con direcci&#xF3;n en An&#xED;bal Pinto N&#xBA; 1577, ciudad de Concepci&#xF3;n, de la empresa Habilitada Futurgas Ltda., para adecuar veh&#xED;culos al uso de gas natural comprimido (GNC) como combustible. Autorizaci&#xF3;n que tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.- </div></div>", "i": 8655666}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Erazo Torricelli, Subsecretario de Transportes.</div></div>", "i": 8655667}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "898 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-898 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 898 EXENTA, DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-05-06", "doble_articulado": false, "id_norma": "1002773", "numero_fuente": "39373", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-05-29", "vigencias": [{"desde": "2009-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio