{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6565557}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;596 de 16 de febrero de 2006, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de la resoluci&#xF3;n N&#xBA;2.220 de 2005, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la UNIVERSIDAD ARTURO PRAT para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Octopus mimus y Enteroctopus megalocyathus para cultivo experimental&quot;, en el sentido de extender el plazo de ejecuci&#xF3;n de la citada pesca de investigaci&#xF3;n por un per&#xED;odo de 8 meses contados desde la fecha de la presente resoluci&#xF3;n inclusive.</div><br></div>", "i": 6565558}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de febrero de 2006.- Jessica Fuentes Olmos, Subsecretario de Pesca (S).</div><br></div>", "i": 6565559}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "596 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-596 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-02-16", "doble_articulado": false, "id_norma": "248490", "numero_fuente": "384126", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-29", "vigencias": [{"desde": "2006-03-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-03-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici