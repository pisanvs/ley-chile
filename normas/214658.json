{"html": [{"t": "<div><div class=\"p\">MODIFICA ORDENANZA N&#xBA; 8 SOBRE FERIAS PERSAS, ARTICULOS USADOS Y DE OCASION </div></div>", "i": 6439849}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En sesi&#xF3;n de fecha 5 de agosto del a&#xF1;o 2003, el Concejo</div><div class=\"p\">Municipal de la comuna de El Bosque ha aprobado diversas</div><div class=\"p\">modificaciones a la Ordenanza N&#xBA; 8 sobre Ferias Persas,</div><div class=\"p\">Art&#xED;culos Usados y de Ocasi&#xF3;n. Dichas modificaciones regir&#xE1;n a contar de la fecha de publicaci&#xF3;n del presente aviso.</div><br><div class=\"p\">&nbsp; &nbsp;  Los interesados podr&#xE1;n tomar conocimiento del texto &#xED;ntegro de estas modificaciones en el Departamento de Patentes Comerciales, ubicado en Alejandro Guzm&#xE1;n N&#xBA; 735, o en la p&#xE1;gina web de esta Municipalidad: www.imelbosque.cl.- </div></div>", "i": 6439850}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sadi Melo Moya, Alcalde </div></div>", "i": 6439851}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "AVI-S/N"}], "organismos": ["MUNICIPALIDAD DE EL BOSQUE"], "titulo_norma": "MODIFICA ORDENANZA Nº 8 SOBRE FERIAS PERSAS, ARTICULOS\nUSADOS Y DE OCASION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-05", "doble_articulado": false, "id_norma": "214658", "numero_fuente": "37659", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-12", "vigencias": [{"desde": "2003-09-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-12", "fin_vigencia": ""}, "vigencias_vers