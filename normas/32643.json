{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8289741}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0;53, de 26 de Enero de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a PESQUERA IQUIQUE-GUANAYE S.A., R.U.T. N&#xB0;91.123.000-3, para continuar desarrollando las actividades pesqueras autorizadas por esta Subsecretar&#xED;a a Pesquera Iquique S.A., R.U.T. N&#xB0;91.123.000-3, domiciliada en Santiago, en virtud de la Escritura P&#xFA;blica de 31 de Agosto de 1992, otorgada ante la Cuadrag&#xE9;sima Primera Notar&#xED;a de Santiago, la que cambi&#xF3; el nombre de Pesquera Iquique S.A. por Pesquera Iquique-Guanaye S.A.</div><br></div>", "i": 8289742, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 26 de Enero de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8289743}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "53", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-53"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "PESQUERA IQUIQUE-GUANAYE S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-01-26", "doble_articulado": false, "id_norma": "32643", "numero_fuente": "34496", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-02-19", "vigencias": [{"desde": "1993-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-02-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci