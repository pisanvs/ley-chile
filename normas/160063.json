{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6247405}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP No. 94, de fecha 27 de marzo de 1992, se expropiaron los lotes de terreno No. s. 5 y 25, superficies 255 m2. y 524 M2., respectivamente, roles de aval&#xFA;os 318-015 y 569-007, Comuna de Copiap&#xF3;, para la obra Ruta 31 Ch, sector Copiap&#xF3;-Paipote, Doble Calzada y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Sociedad Grallert y C&#xED;a. Ltda. y Elena Carrasco Carvajal, ascendente a las cantidades $ 1.463.269 y $ 12.251.930.-</div><br></div>", "i": 6247406}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6247407}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "94", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-94"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-03-27", "doble_articulado": false, "id_norma": "160063", "numero_fuente": "34256", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-05-02", "vigencias": [{"desde": "1992-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-03-08", "fecha_version": "1992-05-02", "fecha_actualizacion_texto": "1992-05-02", "tipo_tratado": ""}, "alertas": [], "ale