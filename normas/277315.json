{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8438201}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto (Exento) MOP N&#xBA; 650 de fecha 31 de julio del 2008, se expropi&#xF3; el lote de terreno N&#xBA; 32, superficie 239 m2, Rol N&#xBA; 2206-184, comuna de Puerto Montt, X Regi&#xF3;n para la obra &apos;Mejoramiento Ruta 7, sector Quillaipe - La Arena, tramo Km. 15,84700 a Km.</div><div class=\"p\">40,41746&apos;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria ROSA ESTER OLAVARRIA OYARZUN, ascendente a la cantidad de $693.892.- para el lote N&#xBA;32. </div></div>", "i": 8438202}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 8438203}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "650 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-650 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-07-31", "doble_articulado": false, "id_norma": "277315", "numero_fuente": "39152", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-09-01", "vigencias": [{"desde": "2008-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "CMV", "fecha_ingreso": "2008-09-01", "fecha_version": "2008-09-01", "fec