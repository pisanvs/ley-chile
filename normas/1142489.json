{"html": [{"t": "<div><div class=\"p\">INCORPORA A PUERTO LIRQU&#xC9;N EN PLAN PILOTO ADUANA DE TALCAHUANO</div></div>", "i": 10101492}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 615, de 10 de febrero de 2020, del Director Nacional de Aduanas, se incorpor&#xF3; a partir del 12 de febrero de 2020, a Puerto Lirqu&#xE9;n en el Plan Piloto de la Aduana de Talcahuano, respecto de la anticipaci&#xF3;n de la legalizaci&#xF3;n del DUS, para aquellas operaciones que se tramiten v&#xED;a SICEX.</div><div class=\"p\">&nbsp; &nbsp;  Esta resoluci&#xF3;n entra en vigencia a contar de la fecha de publicaci&#xF3;n en el Diario Oficial.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10101493}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de febrero de 2020.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><br></div>", "i": 10101494}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "615 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-615 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "INCORPORA A PUERTO LIRQUÉN EN PLAN PILOTO ADUANA DE TALCAHUANO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1727625", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-02-10", "doble_articulado": false, "id_norma": "1142489", "numero_fuente": "42582", "tipo_version": "3", "tipo_v