{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 807 EXENTO, DE 1997 </div></div>", "i": 6044400}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto exento N&#xBA; 807, de fecha 23 de julio de 1997, del Ministerio de Educaci&#xF3;n, se declar&#xF3; aprobada a la Universidad del Mar, inscrita en el Registro de Universidades bajo el Folio C-N&#xBA; 30 de 1989, la carrera de Ingenier&#xED;a de Ejecuci&#xF3;n en Turismo, conducente al t&#xED;tulo profesional de Ingeniero de Ejecuci&#xF3;n en Turismo, para impartirse en su Sede de la ciudad de Valpara&#xED;so, de conformidad al acuerdo adoptado por el Consejo Superior de Educaci&#xF3;n, quien llevar&#xE1; a efecto la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6044401}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 5 de agosto de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6044402}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "807 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-807 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 807 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["UNIVERSIDAD DEL MAR", "APROBACION", "REGISTRO DE UNIVERSIDADES", "VALPARAISO", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-23", "doble_articulado": false, "id_norma": "75299", "numero_fuente": "35851", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-08-26", "vigencias": [{"desde": "1997-08-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-08-26", "fi