{"html": [{"t": "<div><div class=\"p\">PARTIDO RADICAL SOCIALDEMOCRATA </div></div>", "i": 6516406}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Isidro Sol&#xED;s Palma y Ricardo Navarrete Betanzo, Presidente (S) y Secretario General del Partido Radical Socialdem&#xF3;crata, respectivamente, han comunicado la nueva composici&#xF3;n de la Directiva Central de la colectividad con los nombres y cargos que a continuaci&#xF3;n se indican:</div><br><div class=\"p\">&nbsp; &nbsp;  DIRECTIVA CENTRAL:</div><br><div class=\"p\">&nbsp; &nbsp;  Presidente&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Jos&#xE9; Antonio G&#xF3;mez Urrutia</div><div class=\"p\">&nbsp; &nbsp;  Vicepresidente&nbsp; &nbsp; &nbsp; : Isidro Sol&#xED;s Palma</div><div class=\"p\">&nbsp; &nbsp;  Secretario General&nbsp; : Ricardo Navarrete Betanzo</div><div class=\"p\">&nbsp; &nbsp;  Tesorero&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Jos&#xE9; P&#xE9;rez Arriagada</div><br><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada en virtud de lo establecido en el Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por resoluci&#xF3;n O N&#xBA; 4.078 de fecha 9 de febrero de 2005.</div><br></div>", "i": 6516407}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Elizabeth Cabrera Burgos, Director (S). </div></div>", "i": 6516408}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4078", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-4078"}, {"tipo": "3", "numero": "O-4078", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-4078"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO RADICAL SOCIALDEMOCRATA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO RADICAL SOCIALDEMOCRATA", "JOSE ANTONIO GOMEZ URRUTIA", "PRESIDENTE", "DIRECTIVA CENTRAL"], "categorias_norma": [