{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION (A) N&#xBA; 28, DE 2001</div><br><br></div>", "i": 6325937}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En cumplimiento de lo dispuesto en el decreto del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA; 291, de 11 de junio de 1999, publicado en el Diario Oficial de fecha 13 de agosto de 1999, certifico que por resoluci&#xF3;n (A) N&#xBA; 28, de 15 de febrero 2001, del se&#xF1;or Vicepresidente Ejecutivo, se modific&#xF3; la&nbsp; resoluci&#xF3;n (A) N&#xBA; 182, de 2000, que puso en vigencia el Reglamento del Programa de Cofinanciamiento de Asistencia T&#xE9;cnica - FAT.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto completo de la antes referida resoluci&#xF3;n, estar&#xE1; a disposici&#xF3;n de los usuarios en la Secretar&#xED;a General de la Corporaci&#xF3;n y en las Direcciones Regionales.</div><br></div>", "i": 6325938}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de marzo de 2001.- Yerko Koscina Peralta, Secretario General.</div><br></div>", "i": 6325939}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "28", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-28"}, {"tipo": "3", "numero": "A-28", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-A-28"}], "organismos": ["CORPORACIÓN DE FOMENTO DE LA PRODUCCIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION (A) Nº 28, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-15", "doble_articulado": false, "id_norma": "182749", "numero_fuente": "36910", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-12", "vigencia