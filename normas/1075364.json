{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 3.511&nbsp; EXENTA, DE 2014</div></div>", "i": 9579654}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;622, de 5 de marzo de 2015 de esta Subsecretar&#xED;a, modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1072940&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA;3.511. de 2014</a>, que estableci&#xF3; la distribuci&#xF3;n de las fracciones artesanales de las cuotas anuales de captura, por regi&#xF3;n, a&#xF1;o 2015, en el sentido de reemplazar el encabezado de la letra j) del numeral 1&#xBA;, por el siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;j) Pesquer&#xED;as artesanales de Congrio dorado (Genypterus blacodes) en aguas interiores y aguas exteriores de la X, XI y XII Regiones.&quot;.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9579655}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de marzo de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9579656}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "622 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-622 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 3.511 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-03-05", "doble_articulado": false, "id_norma": "1075364", "numero_fuente": "41105", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-03-12", "vigencias": [{"desde": "2015-03-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2015-03-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2015-03-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "98", "fecha_ingreso": "2015-03-12", "fecha_version": "2015-03-12", "fecha_actualizacion_texto": "2015-03-12", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9579654}, {"n": "Artículo", "i": 9579655, "t": 6}, {"n": "Promulgación", "i": 9579656}]}