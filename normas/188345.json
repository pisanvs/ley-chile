{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 63, DE 2001</div><br><br></div>", "i": 6345243}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA; 63, de fecha 5 de julio de 2001, se aprob&#xF3; la disoluci&#xF3;n voluntaria de la Cooperativa de Servicios de Veraneo, Recreaci&#xF3;n y Descanso &quot;La Media Luna Limitada&quot;, de Santiago, que consta en la escritura p&#xFA;blica suscrita con fecha 28 de marzo de 2001, ante el Notario P&#xFA;blico de San Miguel, don Sergio Henr&#xED;quez Silva.</div><br></div>", "i": 6345244}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6345245}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "63", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-63"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 63, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-07-05", "doble_articulado": false, "id_norma": "188345", "numero_fuente": "37033", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-08-09", "vigencias": [{"desde": "2001-08-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-08-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2