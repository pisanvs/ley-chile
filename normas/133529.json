{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7246780}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Se reajustan las cuant&#xED;as de los asuntos no determinados en sueldos vitales ni unidades tributarias, las que regir&#xE1;n a contar del 1&#xBA; de marzo pr&#xF3;ximo:</div><div class=\"p\">&nbsp; &nbsp;  En el inciso final del art&#xED;culo 198 del C&#xF3;digo Org&#xE1;nico de Tribunales, se sustituyen los guarismos &apos;&apos;4010&apos;&apos; y &apos;&apos;2995&apos;&apos; por &apos;&apos;4198 y &apos;&apos;3136&apos;&apos; respectivamente.</div><br></div>", "i": 7246781, "v": ["MODIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "AVI-S/N"}], "organismos": ["CORTE SUPREMA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["AVISO SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "133529", "numero_fuente": "36300", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-02-26", "vigencias": [{"desde": "1999-02-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-02-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-02-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "MEM", "fecha_ingreso": "1999-03-15", "fecha_version": "1999-02-26", "fecha_actualizacion_texto": "1999-02-26", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 7246780}, {"n": "Artículo", "i": 7246781, "t":