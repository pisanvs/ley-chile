{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A PESQUERA CALYPSO LTDA.</div><br><br><br></div>", "i": 6125237}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional del Servicio de Impuestos Internos, por resoluci&#xF3;n DRE08/N&#xBA; Ex. 829, de fecha 5 de agosto de 1998, ha procedido a revocar a petici&#xF3;n del Depto. Regional de Fiscalizaci&#xF3;n, a la Pesquera Calypso Ltda., Rut. N&#xBA; 79.825.760-9, su calidad de agente retenedor del Impuesto al Valor Agregado por la adquisici&#xF3;n de especie hidrobiol&#xF3;gica, de acuerdo a lo dispuesto en el dispositivo N&#xBA; 17, de la resoluci&#xF3;n N&#xBA; Ex. 3.839, de fecha 26.06.98, de la Direcci&#xF3;n Nacional. Dicha revocaci&#xF3;n regir&#xE1; a contar de la fecha de publicaci&#xF3;n del presente extracto.- Se adjunta resoluci&#xF3;n en cuesti&#xF3;n.</div><br></div>", "i": 6125238}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Saluda a Ud., Julio Salame Heresi, Director Regional (S).</div><br></div>", "i": 6125239}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "829 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-829 EXENTA"}, {"tipo": "3", "numero": "DRE-08-829 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-829 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A PESQUERA CALYPSO LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "PESQUERA CALYPSO LTDA.", "REVOCACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulg