{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 106 </div></div>", "i": 6078177}, {"t": "<div><div class=\"p\">Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n No. 106, celebrada el 15 de marzo de 1991, adopt&#xF3; el siguiente acuerdo: 106-02-910315 - Modifica Tasa de Inter&#xE9;s de los Pagar&#xE9;s Reajustables del Banco Central de Chile (P.R.B.C.).</div><div class=\"p\">Se acord&#xF3; modificar, a contar del 18 de marzo de 1991, la Tasa de Inter&#xE9;s de los Pagar&#xE9;s Reajustables del Banco Central de Chile (P.R.B.C.) que se emiten a un plazo de noventa d&#xED;as, en virtud de lo dispuesto en el Cap&#xED;tulo IV.B.7 del Compendio de Normas Financieras, de un 6,20% a un 5,70% anual vencido.</div><br></div>", "i": 6078178}, {"t": "<div><div class=\"p\">Santiago, 15 de marzo de 1991.- Mar&#xED;a Eliana Torres Contreras, Secretario General Subrogante.</div><br></div>", "i": 6078179}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "106", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-106"}, {"tipo": "5", "numero": "106-02", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-106-02"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDO BANCO CENTRAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-03-15", "doble_articulado": false, "id_norma": "88129", "numero_fuente": "33920", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-03-16", "vigencias": [{"desde": "1991-03-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic