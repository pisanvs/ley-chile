{"html": [{"t": "<div><div class=\"p\">AUTORIZA A SOCIEDAD IMPORTADORA ARAUCARIA LTDA., PARA DESARROLLAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 6224588}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 539 de 16 de Julio de 1986 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a la Sociedad Importadora Araucaria Ltda., domiciliada en Santiago, para instalar y operar una planta procesadora del recurso hidrobiol&#xF3;gico anchoa o anchoveta, abastecido por el sector artesanal del puerto de San Antonio, en la l&#xED;nea de sala do, en calle Valpara&#xED;so 101, Melipilla, Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6224589}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de Julio de 1986.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 6224590}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "539", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-539"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A SOCIEDAD IMPORTADORA ARAUCARIA LTDA., PARA DESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-07-16", "fecha_derogacion": "1988-02-26", "doble_articulado": false, "id_norma": "152899", "numero_fuente": "32532", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-07-26", "vigencias": [{"desde": "1988-02-26", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1986-07-26", "hasta": "1988-02-25", "tipo_version": "0