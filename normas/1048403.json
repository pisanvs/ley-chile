{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9329605}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 170, de 17 de enero de 2013, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la<a href=\"https://www.leychile.cl/Navegar?idNorma=254661&amp;idParte=0&amp;idVersion=\"> resoluci&#xF3;n exenta N&#xBA; 3.001 de 2006</a>, de esta Subsecretar&#xED;a, en cuanto autoriz&#xF3; a CAMANCHACA PESCA SUR S.A., para realizar actividades pesqueras extractivas con una nave denominada &quot;Gardar&quot; en el &#xE1;rea mar&#xED;tima correspondiente a la III a VII y IX a X Regiones, sobre el recurso hidrobiol&#xF3;gico Jibia o Calamar rojo, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante Memor&#xE1;ndum T&#xE9;cnico citado en Visto de la resoluci&#xF3;n extractada.</div></div>", "i": 9329606}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de enero de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9329607}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "170 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-170 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-01-17", "doble_articulado": false, "id_norma": "1048403", "numero_fuente": "40468", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-01-25", "vigencias": [{"desde": "2013-01-25", "hasta": "", "tipo_ver