{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO MINISTRO DE FE A FUNCIONARIO QUE INDICA </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 480.- Santiago, 6 de diciembre de 2002.- Vistos: Lo dispuesto en el Art. 4&#xBA; del decreto ley N&#xBA; 2.974 de 1979.</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br></div>", "i": 6409413}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Ministro de Fe para actuar en las localidades ubicadas en la VIII Regi&#xF3;n, en que no hayan Notarios ni Oficiales del Registro Civil, al siguiente funcionario:</div><br><div class=\"p\">- Clemente Eduardo Valck Alvarez </div></div>", "i": 6409414}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Ricardo Halabi Caffena, Director Nacional.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud.- Encargado Oficina de Partes.</div><br></div>", "i": 6409415}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "480", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-480"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO MINISTRO DE FE A FUNCIONARIO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-06", "doble_articulado": false, "id_norma": "206504", "numero_fuente": "37453", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-01-08", "vigencias": [{"desde": "2003-01-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-01-08", "fin_vigencia": ""}, "vigencias_versio