{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7330686}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.487, de 2 de junio de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA ISLA DEL REY S.A. para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Los Condestables N&#xBA; 390, Niebla, Valdivia, X Regi&#xF3;n, la l&#xED;nea de proceso de Conserva, respecto de los recursos autorizados en la resoluci&#xF3;n N&#xBA; 1.930, de 1995 y donde podr&#xE1; elaborar en las l&#xED;neas de Proceso Fresco Refrigerado, Congelado y Conserva, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 7330687}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de junio de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7330688}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1487 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1487 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-02", "doble_articulado": false, "id_norma": "250762", "numero_fuente": "38496", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-06-23", "vigencias": [{"desde": "2006-06-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-06-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-06-23", "fin_vigencia": "", "tipo_v