{"html": [{"t": "<div><div class=\"p\">APRUEBA DISOLUCION DE &quot;CLUBSEGUROS COMPA&#xD1;IA DE SEGUROS GENERALES S.A.&quot;</div><br><br><div class=\"p\">&nbsp; &nbsp;  Certifico:</div><br><br></div>", "i": 7245515}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Que por resoluci&#xF3;n No. 184. de 07.10.88, se aprob&#xF3; la disoluci&#xF3;n anticipada de la sociedad an&#xF3;nima &quot;Clubseguros Compa&#xF1;&#xED;a de Seguros Generales S.A.&quot;, que consta de la escritura p&#xFA;blica de fecha 02 de agosto de 1988, otorgada en la Notar&#xED;a de Santiago de don Ra&#xFA;l Iv&#xE1;n Perry Pefaur, autoriz&#xE1;ndola a practicar su propia liquidaci&#xF3;n, cumpliendo la legislaci&#xF3;n vigente y las normas e instrucciones que imputa la Superintendencia de Valores y Seguros.</div><br><br></div>", "i": 7245516}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 07.10.88.- Rodrigo O. Costa Aranda, Secretario General.</div><br></div>", "i": 7245517}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "184", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-184"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "APRUEBA DISOLUCION DE CLUBSEGUROS COMPAÑIA DE SEGUROS GENERALES S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-10-07", "doble_articulado": false, "id_norma": "131549", "numero_fuente": "33200", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-10-20", "vigencias": [{"desde": "1988-10-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-10-20", "fin_vigencia": ""}, "vigencias_versio