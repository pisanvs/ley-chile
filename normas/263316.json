{"html": [{"t": "<div><div class=\"p\">EXCEPCIONA DE CALIDAD DE AGENTE RETENEDOR DEL IVA A COMERCIAL CHILETABACOS S.A.</div><br></div>", "i": 7349388}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Grandes Contribuyentes del SII, por resoluci&#xF3;n Ex N&#xBA;100 de 30 de julio de 2007, certifica que a contar del d&#xED;a primero del mes siguiente al de esta publicaci&#xF3;n al contribuyente Comercial Chiletabacos S.A., RUT N&#xBA;88.502.900-0, se le autoriz&#xF3; excepcionarse del r&#xE9;gimen de cambio de sujeto del IVA en venta de cigarros, cigarrillos y tabaco manufacturados, de acuerdo a lo establecido en la Res. Ex. N&#xBA;22/2007 de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del d&#xED;a 09.02.2007.-</div><br></div>", "i": 7349389}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Norberto San Mart&#xED;n Soto, Director (S) de la Direcci&#xF3;n Grandes Contribuyentes.</div><br></div>", "i": 7349390}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "100 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-100 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN GRANDES CONTRIBUYENTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-07-30", "doble_articulado": false, "id_norma": "263316", "numero_fuente": "38829", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-08-03", "vigencias": [{"desde": "2007-08-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-08-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-08-