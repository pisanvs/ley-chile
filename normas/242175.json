{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.205 EXENTO, DE 2005 </div><br></div>", "i": 6540643}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.205, de fecha 31 de agosto de 2005, del Ministerio de Educaci&#xF3;n, se deja sin efecto el decreto exento de Educaci&#xF3;n N&#xBA; 778 del 15 de junio de 2005 que aprob&#xF3; las modificaciones introducidas al plan y programas de estudios del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Umbrales de Santiago, de la carrera de Decoraci&#xF3;n de Interiores, por cuanto fue aprobada anteriormente mediante decreto exento de Educaci&#xF3;n N&#xBA; 657, de 26 de mayo de 2005.</div><br></div>", "i": 6540644}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de septiembre de 2005.- Pedro Montt Leiva, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6540645}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1205 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1205 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.205 EXENTO, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-08-31", "doble_articulado": false, "id_norma": "242175", "numero_fuente": "38265", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-09-17", "vigencias": [{"desde": "2005-09-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-09-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-09-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":