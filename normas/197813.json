{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7291563}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n n&#xFA;mero 782, de 22 de abril de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA SAN JOSE S.A. para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluciones N&#xBA; 903 de 1987, N&#xBA; 250 de 1992, N&#xBA; 850 de 1993, N&#xBA; 860 de 1994, N&#xBA; 916 de 1995, N&#xBA; 748 y N&#xBA; 1.843, ambas de 1996, N&#xBA; 1.207 de 1999, N&#xBA; 2.494 de 2000 y N&#xBA; 2.403 de 2001, todas de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Playa Blanca s/n, Coquimbo, IV Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de Harina y Aceite, los siguientes recursos hidrobiol&#xF3;gicos: Bacaladillo o mote, Jurel fino, Machuelo o tritre, Anchoveta blanca, Sardina redonda y Vinciguerria.</div><br></div>", "i": 7291564}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de abril de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7291565}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "782", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-782"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-22", "doble_articulado": false, "id_norma": "197813", "numero_fuente": "37253", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-08", "vigencias": [{"desde": "2002-05-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"