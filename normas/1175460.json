{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N</div></div>", "i": 10329929}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  La VI Direcci&#xF3;n Regional Rancagua del SII, por resoluci&#xF3;n Ex. N&#xB0; 77322113047, de fecha 18.04.2022, otorga la calidad de Agente Retenedor del Impuesto al Valor Agregado en las ventas de chatarras, a Juan Vaneso L&#xF3;pez Valenzuela, RUT N&#xB0; 15.531.824-4. Dicho acto de autoridad regir&#xE1; a contar del d&#xED;a de esta publicaci&#xF3;n, de acuerdo a lo establecido en la resoluci&#xF3;n exenta SII N&#xB0; 86 del 24.08.2016, de la Subdirecci&#xF3;n de Fiscalizaci&#xF3;n del Servicio de Impuestos Internos, publicada en el Diario Oficial el 30.08.2016.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10329930}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rancagua, 18 de abril de 2022.- Claudia Carolina Zuleta Munizaga, Directora Regional.</div><div class=\"p\"> </div><br></div>", "i": 10329931}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "77322113047 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-77322113047 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL RANCAGUA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2120800", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-04-18", "doble_articulado": false, "id_norma": "1175460", "numero_fuente": "43240", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-04-29", "vigencias": [{"desde": "2022-04-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "