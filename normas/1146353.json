{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO RESOLUCIONES EXENTAS QUE SE INDICAN</div></div>", "i": 10127203}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.357, de 5 de junio de 2020, de esta Subsecretar&#xED;a, se dejan sin efecto las resoluciones exentas Nos 709, 710, 711, 712, 713, 751 y <a href=\"https://www.leychile.cl/navegar?idNorma=1143701&amp;idVersion=2020-06-09\">817</a>, todas de 2020, y de esta repartici&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n extractada se publicar&#xE1; en el sitio de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><br></div>", "i": 10127204, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de junio de 2020.- Jos&#xE9; Pedro N&#xFA;&#xF1;ez Barruel, Subsecretario de Pesca y Acuicultura (S).</div><br></div>", "i": 10127205}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1357 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1357 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DEJA SIN EFECTO RESOLUCIONES EXENTAS QUE SE INDICAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1770523", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-06-05", "doble_articulado": false, "id_norma": "1146353", "numero_fuente": "42676", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-06-09", "vigencias": [{"desde": "2020-06-09", "hasta": "", "tipo_version": "3