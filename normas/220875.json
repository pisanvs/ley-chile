{"html": [{"t": "<div><div class=\"p\">ACUERDO DE SESION N&#xBA; 922, DE 2004</div><br><br></div>", "i": 8496073}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Consejo Superior de la H&#xED;pica Nacional, en uso</div><div class=\"p\">de la facultad establecida en la letra c) del art&#xED;culo</div><div class=\"p\">3&#xBA; del D.S. del Ministerio de Hacienda N&#xBA; 1.588, del a&#xF1;o</div><div class=\"p\">1943, y de conformidad en lo dispuesto en el D.S. N&#xBA; 211</div><div class=\"p\">del Ministerio de Hacienda, de 13 de marzo de 2003,</div><div class=\"p\">acord&#xF3; en su sesi&#xF3;n N&#xBA; 922, de fecha 20 de enero de</div><div class=\"p\">2004, introducir al Reglamento de Carreras de Chile la</div><div class=\"p\">siguiente modificaci&#xF3;n: &quot;Suprimir el inciso segundo del</div><div class=\"p\">art&#xED;culo 36.&quot;.</div><br></div>", "i": 8496074}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Domingo Romero Cort&#xE9;s, Presidente.</div><br></div>", "i": 8496075}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "S/N", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-S/N"}, {"tipo": "23", "numero": "922", "abreviacion": "SES", "descripcion": "Sesión", "compuesto": "SES-922"}], "organismos": ["CONSEJO SUPERIOR DE LA HÍPICA NACIONAL"], "titulo_norma": "ACUERDO DE SESION Nº 922, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REGLAMENTO DE CARRERAS DE CHILE", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-20", "doble_articulado": false, "id_norma": "220875", "numero_fuente": "37777", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-04", "vigencias": [{"desde": "2004-02-04", "hasta": "", "tipo_ve