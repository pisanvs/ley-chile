{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 46</div></div>", "i": 10025864}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.847, de 16 de mayo de 2019, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1129272&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xB0; 660 de 2019</a>, de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 46, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para el centro de cultivo que indica en la resoluci&#xF3;n extractada.</div></div>", "i": 10025865}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de mayo de 2019.- Eduardo Riquelme Portilla, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 10025866}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1847 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1847 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 46", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1594752", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-05-16", "doble_articulado": false, "id_norma": "1132023", "numero_fuente": "42363", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-05-27", "vigencias": [{"desde": "2019-05-27", "hasta": "", "tipo_version