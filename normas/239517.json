{"html": [{"t": "<div><br><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A SUN BELLE BERRIES S.A.</div><br></div>", "i": 6530917}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/N&#xBA; exento 628, de fecha 20 de abril de 2005, otorga a Sun Belle Berries S.A., RUT N&#xBA; 77.522.330-8, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de Sujeto en las ventas de berries, establecido en la resoluci&#xF3;n N&#xBA; Ex-26, de 24-02-2005 de la Direcci&#xF3;n Nacional. La presente autorizaci&#xF3;n surtir&#xE1; efecto a partir del d&#xED;a primero del mes siguiente a la fecha de publicaci&#xF3;n de este extracto en el Diario Oficial y tendr&#xE1; vigencia hasta el 31-05-2005.</div><br></div>", "i": 6530918}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Concepci&#xF3;n, 20 de abril de 2005.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6530919}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "628 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-628 EXENTA"}, {"tipo": "3", "numero": "DRE-08-628 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-628 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A SUN BELLE BERRIES S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-04-20", "doble_articulado": false, "id_norma": "239517", "numero_fuente": "38195", "tipo_version": "3", "tipo_versio