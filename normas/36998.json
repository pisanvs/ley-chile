{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SOLICITA CONSTITUCION LEGAL DEL PARTIDO COMUNISTA DE CHILE EN LAS REGIONES VIII Y XII </div></div>", "i": 6016787}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Gladys Mar&#xED;n Millie y Lautaro Carmona Soto, Presidente y Secretario General, respectivamente, en representaci&#xF3;n del &quot;Partido Comunista de Chile&quot;, han solicitado la constituci&#xF3;n legal del Partido en las regiones VIII del Biob&#xED;o y XII de Magallanes y de la Ant&#xE1;rtica Chilena, acompa&#xF1;ando las siguientes declaraciones de afiliaciones:</div><div class=\"p\"> VIII Regi&#xF3;n&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 5.069</div><div class=\"p\"> XII Regi&#xF3;n&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  434</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la ley N&#xB0; 18.603, por Resoluci&#xF3;n O-N&#xB0;1.452 de fecha, 7 de junio de 1996.</div><br></div>", "i": 6016788}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 7 de junio de 1996.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6016789}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1452", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1452"}, {"tipo": "3", "numero": "O-1452", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-1452"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCION LEGAL DEL PARTIDO COMUNISTA DE\nCHILE EN LAS REGIONES VIII Y XII", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO COMUNISTA CHILE", "OCTAVA REGION", "DECIMOSEGUNDA REGION", "CONSTITUCION LEGAL", "SOLICITUD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observacio