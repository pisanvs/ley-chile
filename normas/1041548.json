{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 5.820 EXENTA, DE 2012</div></div>", "i": 9271858}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 5.820, de 25 de junio de 2012, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Capacitaci&#xF3;n Mar&#xED;tima e Industrial Vig&#xED;a S.A. (Vig&#xED;a S.A.)&quot;, RUT 77.565.180-6, contenida en la resoluci&#xF3;n exenta N&#xBA; 418, de 25 de enero de 2007, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del art. 21 de la ley 19.518.-</div></div>", "i": 9271859}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (PT).</div></div>", "i": 9271860}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5820 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5820 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 5.820 EXENTA, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-25", "doble_articulado": false, "id_norma": "1041548", "numero_fuente": "40304", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-07-05", "vigencias": [{"desde": "2012-07-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-07-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-07-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p