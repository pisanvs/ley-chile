{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO DEL&nbsp; BANCO&nbsp; CENTRAL&nbsp; DE</div><div class=\"p\">CHILE&nbsp;  EN&nbsp; SU SESION N&#xBA; 634</div><br></div>", "i": 6048833}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 634, celebrada el 30 de octubre de 1997, adopt&#xF3; el siguiente Acuerdo:</div><br><br><br><div class=\"p\">&nbsp; &nbsp;  634-02-971030 - Creaci&#xF3;n billete de $20.000 </div><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; lo siguiente:</div><br><br><div class=\"p\">1.&nbsp;  Crear un billete de $20.000, agregando dicho corte a las denominaciones de billetes actualmente en circulaci&#xF3;n.</div><br><br><div class=\"p\">2.&nbsp;  Instruir al Gerente General, quien podr&#xE1; delegar en el Tesorero General, para desarrollar, trabajando con la Casa de Moneda de Chile, un dise&#xF1;o, que considere como motivo principal a don Andr&#xE9;s Bello, y una especificaci&#xF3;n de las caracter&#xED;sticas del billete de $20.000, los que deber&#xE1;n ser sometidos a la consideraci&#xF3;n del Consejo. </div></div>", "i": 6048834}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de octubre de 1997.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6048835}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "634", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-634"}, {"tipo": "5", "numero": "634-02", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-634-02"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CREACION BILLETE DE $20.000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MONEDA NACIONAL", "UNIDAD MONETARIA", "BILLETE DE VEINTE MIL PESOS", "CREACION", "BANCO CENTRAL DE CHILE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-10-30", "doble_articulado": false, "id_norma": "76697", "numero_fuente": "35907", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-11-04", "vigencias": [{"desde": "1997-11-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-11-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-11-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CAV", "fecha_ingreso": "1997-11-20", "fecha_version": "1997-11-04", "fecha_actualizacion_texto": "1997-11-04", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6048833}, {"n": "Artículo", "i": 6048834, "t": 6}, {"n": "Promulgación", "i": 6048835}]}