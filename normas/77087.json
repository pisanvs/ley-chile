{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8307628}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.364, de 22 de octubre de 1997,</div><div class=\"p\">de esta Subsecretar&#xED;a de Pesca del Ministerio de</div><div class=\"p\">Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a</div><div class=\"p\">PESQUERA ITATA S.A., para ampliar las actividades</div><div class=\"p\">pesqueras extractivas con la nave &quot;Calcurrupe&quot;,</div><div class=\"p\">matr&#xED;cula 2301, en orden a realizar actividades</div><div class=\"p\">pesqueras con la nave se&#xF1;alada precedentemente, en el</div><div class=\"p\">litoral de la X Regi&#xF3;n, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; capturar con red de cerco los siguientes recursos hidrobiol&#xF3;gicos: Agujilla, Anchoveta, Caballa, Jurel, Merluza de cola, Sardina com&#xFA;n.</div><div class=\"p\">&nbsp; &nbsp;  Deni&#xE9;gase la autorizaci&#xF3;n solicitada respecto de los recursos y &#xE1;reas no mencionados en la presente Resoluci&#xF3;n, en virtud de los informes y normas legales se&#xF1;aladas en visto.</div><br></div>", "i": 8307629}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de octubre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8307630}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1364", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1364"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESQUERA ITATA S.A.", "AMPLIACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-10-22", "fecha_derogacion": "1998-09-07", "doble_articulado": false, "id_norma": "77087", "numero_fuente": "35916", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-11-14", "vigencias": [{"desde": "1998-09-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1997-11-14", "hasta": "1998-09-06", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1998-09-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-11-14", "fin_vigencia": "1998-09-06", "tipo_version": "0"}, {"inicio_vigencia": "1998-09-07", "fin_vigencia": "", "tipo_version": "2"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "CAV", "fecha_ingreso": "2004-05-14", "fecha_version": "1998-09-07", "actualizado_por": "CMV", "fecha_actualizacion_texto": "1998-09-07", "tipo_tratado": ""}, "alertas": [{"clase": "derogado", "texto": "Derogado", "mensaje": "Esta norma ha sido derogada el 07-SEP-1998"}], "alerta_global": {"m": ["Esta norma ha sido derogada el 07-SEP-1998"], "e": {"i": "", "p": "", "f": "", "t": ""}}, "estructura": [{"n": "Encabezado", "i": 8307628}, {"n": "Artículo", "i": 8307629, "t": 6}, {"n": "Promulgación", "i": 8307630}]}