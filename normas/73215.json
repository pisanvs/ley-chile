{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 483 EXENTO, DE 1997 </div></div>", "i": 6038160}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 483 de 28 de abril de 1997, se ha aprobado al Colegio Suizo de Santiago, Regi&#xF3;n Metropolitana, a partir del a&#xF1;o escolar 1997, planes y programas de estudio biling&#xFC;e por los cursos de 1&#xBA; a 8&#xBA; a&#xF1;o (NB.1, NB.2, NB.3, NB.4, NB.5 y NB.6) de Ense&#xF1;anza B&#xE1;sica, de acuerdo al cronograma establecido en el art&#xED;culo 4&#xBA; del Decreto Supremo de Educaci&#xF3;n N&#xBA; 40 de 1996.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio de 1&#xBA; a 8&#xBA; a&#xF1;o (NB.1, NB.2, NB.3, NB.4, NB.5 y NB.6) de Ense&#xF1;anza B&#xE1;sica para las asignaturas (subsectores de aprendizaje).</div><br></div>", "i": 6038161}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de mayo de 1997.- Jaime P&#xE9;rez de Arce<span class=\"n\" id=\"n_0\">RECTIFICACION<br>D.O.13.06.1997</span> Araya, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 6038162}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "2", "numero": "483 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-483 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 483 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIO SUIZO DE SANTIAGO", "ENSE ANZA BASICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-28", "doble_articulado": false, "id_norma": "73215", "numero_fuente": "35780", "tipo_version": "2", "tipo_version_s": "Última Versió