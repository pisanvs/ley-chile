{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6444352}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.283, de 26 de septiembre</div><div class=\"p\">de 2003, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad</div><div class=\"p\">parcial de la resoluci&#xF3;n N&#xBA; 810 de 2001, de esta</div><div class=\"p\">Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA DELFIN</div><div class=\"p\">LIMITADA para ampliar actividades pesqueras extractivas</div><div class=\"p\">con una nave en construcci&#xF3;n, respecto del recurso</div><div class=\"p\">hidrobiol&#xF3;gico Alfonsino, en el &#xE1;rea mar&#xED;tima de la I</div><div class=\"p\">Regi&#xF3;n y &#xE1;rea mar&#xED;tima de las Islas Oce&#xE1;nicas y su Zona</div><div class=\"p\">Econ&#xF3;mica Exclusiva, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 6444353}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de septiembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6444354}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2283 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2283 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-09-26", "doble_articulado": false, "id_norma": "216079", "numero_fuente": "37689", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-10-20", "vigencias": [{"