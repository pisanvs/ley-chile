{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,082.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 8346495}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.-&nbsp; Se sustituye en el art&#xED;culo 69 de la Lei de Organizaci&#xF3;n i Atribuciones de las Municipalidades la frase que dice &quot;en la segunda quincena de abril&quot; por esta otra: &quot;En la segunda quincena de noviembre&quot;.</div><div class=\"p\">&nbsp; &nbsp; Las asambleas de contribuyentes votar&#xE1;n los presupuestos para el a&#xF1;o siguiente, en cumplimiento de lo dispuesto en el art&#xED;culo 89 de la citada lei, en el mes de diciembre, en vez de en el mes de mayo.</div><br></div>", "i": 8346496}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a cinco de abril de mil novecientos dieciseis.-&nbsp; Juan Luis Sanfuentes.-&nbsp; Maximiliano Ib&#xE1;&#xF1;ez.</div><br></div>", "i": 8346497}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3082", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3082"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-04-05", "doble_articulado": false, "id_norma": "138942", "numero_fuente": "11442", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-04-10", "vigencias": [{"desde": "