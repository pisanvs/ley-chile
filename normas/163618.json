{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6258952}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alcaldesa I. Municipalidad de Providencia, mediante decreto N&#xB0; 1.176, de 17.05.85, dispone expropiaci&#xF3;n total, conforme decreto supremo N&#xB0; 458, de Vivienda, de 1976, y decretos leyes 1.289, 2.186 y 3.464, de inmueble ubicado en Avda. Santa Isabel N&#xB0; 826-830, rol de aval&#xFA;os N&#xB0; 3.908-25, aparentemente de propiedad de do&#xF1;a Ana Garc&#xED;a Pavez, para la ampliaci&#xF3;n de Complejo Municipal Santa Isabel. Deslindes: Norte, 20 mts. con Complejo Municipal; Sur, 20 mts. con Avda. Santa Isabel; Oriente, 38,80 mts. con rol N&#xB0; 3.908-26, y Poniente, 38.80 mts. con otros propietarios. Indemnizaci&#xF3;n provisional: $ 4.026.560.</div><br></div>", "i": 6258953}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Carmen Grez de Anrique, Alcaldesa.- Jorge O. Herrera Ram&#xED;rez, Secretario Abogado Municipal. </div></div>", "i": 6258954}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1176", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1176"}], "organismos": ["MUNICIPALIDAD DE PROVIDENCIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-17", "doble_articulado": false, "id_norma": "163618", "numero_fuente": "32249", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-08-16", "vigencias": [{"desde": "1985-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-08-16", "fin_vigencia": "", "t