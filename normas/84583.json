{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 97, DE 1990 </div></div>", "i": 6068225}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 97 de 07 de marzo de 1990 se ha modificado a contar del a&#xF1;o escolar 1990, el plan especial de estudio del Colegio San Ignacio El Bosque, de Santiago, aprobado por decreto supremo exento de Educaci&#xF3;n No. 136, de 1982, en el sentido de sustituir el plan especial para 1&#xB0; y 2&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica.</div><br></div>", "i": 6068226}, {"t": "<div><div class=\"p\">Santiago, 09 de Marzo de 1990.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6068227}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "97 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-97 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 97, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-07", "doble_articulado": false, "id_norma": "84583", "numero_fuente": "33630", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-26", "vigencias": [{"desde": "1990-03-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-03-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-03-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MNV", "fecha_ingreso": "1998-01-13", "fecha_version": "1990-03