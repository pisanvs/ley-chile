{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,524, que anexa al departamento de Talca la subdelegacion de Libun.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,524.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 8276427}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Segr&#xE9;gase del departamento de Curepto la subdelegacion 6a., Libun, i an&#xE9;xase al departamento de Talca.</div><br></div>", "i": 8276428}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a treinta de Julio de mil novecientos diecinueve.- JUAN LUIS SANFUENTES.- Luis Serrano A. </div></div>", "i": 8276429}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3524", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3524"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NÚM. 3.524, QUE ANEXA AL DEPARTAMENTO DE TALCA LA SUBDELEGACION DE LIBUN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DIVISION POLITICA ADMINISTRATIVA", "MODIFICACION", "TALCA", "SUBDELEGACION LIBUN", "ANEXION", "CUREPTO", "SEGREGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1919-07-30", "doble_articulado": false, "id_norma": "24037", "numero_fuente": "12445", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1919-08-11", "vigencias": [{"desde": "1919-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci