{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 134, DE 1988 </div></div>", "i": 6147132}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 134 de 27 de julio de 1988, se han aprobado al Liceo Polit&#xE9;cnico B No. 43 &quot;Escuela Normal Rural Experimental de Ancud&quot;, programas de estudio para las asignaturas que consulta el plan de estudio aprobado por decreto supremo exento de Educaci&#xF3;n No. 67 de 1985, para 2&#xB0;, 3&#xB0; y 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media.</div><div class=\"p\">&nbsp; &nbsp;  Se dan otras normas relacionadas.</div><br></div>", "i": 6147133}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de Agosto de 1988.- Ren&#xE9; Salam&#xE9; Martin Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6147134}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "134 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-134 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 134, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-07-27", "doble_articulado": false, "id_norma": "129484", "numero_fuente": "33159", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-08-30", "vigencias": [{"desde": "1988-08-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-08-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-08-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_p