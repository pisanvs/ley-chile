{"html": [{"t": "<div><br><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESI&#xD3;N N&#xBA; 1793</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile, en su Sesi&#xF3;n Ordinaria N&#xBA; 1793, celebrada el 12 de diciembre de 2013, adopt&#xF3; el siguiente Acuerdo:</div></div>", "i": 9393220}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  1793-02-131212 - Modifica Anexo del Cap&#xED;tulo I del Compendio de Normas de Cambios Internacionales.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Sustituir la letra a) del Anexo del Cap&#xED;tulo I del Compendio de Normas de Cambios Internacionales del Banco Central de Chile, por la siguiente:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&quot;a)&nbsp; El valor de la CRM antes indicado se corregir&#xE1;, diariamente, en 0,008099% entre el 10 de enero de 2014 y el 9 de enero de 2015, ambas fechas incluidas.&quot;.</div></div>", "i": 9393221}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de diciembre de 2013.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div></div>", "i": 9393222}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1793", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1793"}, {"tipo": "5", "numero": "1793-02", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1793-02"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESIÓN Nº 1793", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false,