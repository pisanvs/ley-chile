{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ACEPTA RENUNCIA COMO PRESIDENTE DEL CONSEJO NACIONAL DE TELEVISION</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 68.- Santiago, 20 de Septiembre de 1994.- Visto: lo establecido en el art&#xED;culo 32, N&#xB0; 12, de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile y la Ley N&#xB0; 19.131;</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 5889924}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Ac&#xE9;ptase la renuncia como Presidente del Consejo Nacional de Televisi&#xF3;n, a don Jos&#xE9; Joaqu&#xED;n Brunner Ried, a contar del 20 de Septiembre de 1994.</div><br></div>", "i": 5889925}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese y comun&#xED;quese.- EDUARDO FREI RUIZ-TAGLE, Presidente de la Rep&#xFA;blica.- Jos&#xE9; Joaqu&#xED;n Brunner Ried, Ministro Secretario General de Gobierno.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud., para su conocimiento.- Edgardo Riveros Mar&#xED;n, Subsecretario General de Gobierno.</div><br></div>", "i": 5889926}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "68", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-68"}], "organismos": ["MINISTERIO SECRETARÍA GENERAL DE GOBIERNO"], "titulo_norma": "ACEPTA RENUNCIA COMO PRESIDENTE DEL CONSEJO NACIONAL\nDE TELEVISION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RENUNCIA", "CONSEJO NACIONAL TELEVISION", "PRESIDENTE", "JOSE JOAQUIN BRUNNER RIED"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-09-20", "doble_articulado": false, "id_norma": "8622", "numero_fuente": "34979", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-09-