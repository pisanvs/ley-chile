{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8586270}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto (Exento) MOP N&#xBA; 493 de fecha 31 de marzo del 2009, se expropi&#xF3; el lote de terreno N&#xBA;92, superficie 167 m2, Rol N&#xBA;3300-420, comuna de Puerto Montt, X Regi&#xF3;n para la obra &quot;Mejoramiento Ruta 7, sector Quillaipe - La Arena, tramo Km. 15,84700 a Km. 40,41746, Provincia de Llanquihue, X Regi&#xF3;n &quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario EDITH SALDIVIA REYES, ascendente a la cantidad de $1.942.709.- para el lote N&#xBA;92. </div></div>", "i": 8586271}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 8586272}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "493 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-493 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-03-31", "doble_articulado": false, "id_norma": "1001727", "numero_fuente": "39351", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-05-02", "vigencias": [{"desde": "2009-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2009-05-05", "fecha_version": "2009-05-02", "actualizado_por": "1289", "fecha