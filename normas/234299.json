{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7317302}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.627, de 22 de diciembre de 2004, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA; 471, de 1985, y el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 1.381, de 1998, ambas de esta Subsecretar&#xED;a, que autorizaron a la SUCESION MARCELINO GONZALEZ HERNANDEZ para desarrollar actividades pesqueras extractivas con la nave &quot;Genoveva&quot;, en el sentido de incorporar y actualizar las siguientes caracter&#xED;sticas n&#xE1;uticas:</div><div class=\"p\"> Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 27,74 m.</div><div class=\"p\">&nbsp; &nbsp;  T.R.G. (Internacional)&nbsp; &nbsp; &nbsp; &nbsp; 154,44 m.</div><div class=\"p\">&nbsp; &nbsp;  Potencia principal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 65,00 HP.</div><div class=\"p\">&nbsp; &nbsp;  Potencia auxiliar&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  120,00 HP.</div><br><br></div>", "i": 7317303}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de diciembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7317304}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3627 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3627 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-12-22", "fecha_derogacion": "2007-10-09", "doble_articulado": false, "id_norma": "234299", "numer