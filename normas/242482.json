{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6542062}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 79, de fecha 9 de septiembre de 2005, del Serviu Regi&#xF3;n de Coquimbo, se orden&#xF3; expropiar, conforme art. 51 ley 16.391 y DL 2.186 de 1978, el inmueble denominado Lote 3 de la comuna de La Serena, de aparente dominio del Fisco de Chile, de una superficie aproximada de 42.045,32 metros cuadrados. Comisi&#xF3;n Peritos integrada por profesionales do&#xF1;a Elisa Tapia Fern&#xE1;ndez, Marcia Aqueveque Mart&#xED;nez y don V&#xED;ctor Vargas Reyes, seg&#xFA;n informe de 27 de julio de 2005, fij&#xF3; monto provisional indemnizaci&#xF3;n, debidamente reajustado en 2.129,60 U.F. pagadero al contado.-</div><br></div>", "i": 6542063}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n Coquimbo.</div><br></div>", "i": 6542064}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "79", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-79"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "IV REGIÓN DE COQUIMBO"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-09", "doble_articulado": false, "id_norma": "242482", "numero_fuente": "38276", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-10-01", "vigencias": [{"desde": "2005-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"