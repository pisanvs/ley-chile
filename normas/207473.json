{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6413939}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 275, de 28 de enero de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a CORPESCA S.A. para realizar actividades extractivas en aguas internacionales con la nave &quot;Eperva 51&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2254<span class=\"n\" id=\"n_0\">RECTIFICACION<br>D.O. 13.02.2003</span></div><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CB-2119</div><div class=\"p\">Eslora arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 36,66 m</div><div class=\"p\">T.R.G. (Nacional)&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 220,16</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 347,10 m3.</div><br></div>", "i": 6413940}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de enero de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6413941}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "3", "numero": "275", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-275"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-28", "doble_articulado": false, "id_norma": "207473", "numero_fuente": "37480", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-02-08", "vigencias": [{"desde": "2003-02-13", "has