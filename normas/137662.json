{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,681.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6172823}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados durante la Guerra del Pac&#xED;fico por el sarjento-mayor de Ej&#xE9;rcito, don Jos&#xE9; Antonio Err&#xE1;zuriz, conc&#xE9;dese, por gracia, a su viuda do&#xF1;a C&#xE1;rmen Paulsen, derecho a disfrutar de la pension de montep&#xED;o militar que corresponde al empleo de sarjento-mayor.</div><br></div>", "i": 6172824}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiocho de agosto de mil novecientos doce.- Ramon Barros Luco.- Claudio Vicu&#xF1;a S. </div></div>", "i": 6172825}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2681", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2681"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-08-28", "doble_articulado": false, "id_norma": "137662", "numero_fuente": "10365", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-08-29", "vigencias": [{"desde": "1912-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-08-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-08-29",