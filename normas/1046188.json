{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.988 EXENTA, DE 19 DE JUNIO DE 2012</div></div>", "i": 9315546}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta se han aprobado planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Colegio &quot;The British School&quot;, de Punta Arenas, Regi&#xF3;n de Magallanes y de la Ant&#xE1;rtica Chilena.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas especiales de estudio para los sectores que se indican en la presente resoluci&#xF3;n exenta.</div></div>", "i": 9315547}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de junio de 2012.- Ver&#xF3;nica Simpson Cifuentes, Jefa (S) Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 9315548}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3988 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3988 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "DIVISIÓN DE EDUCACIÓN GENERAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.988 EXENTA, DE 19 DE JUNIO DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-19", "doble_articulado": false, "id_norma": "1046188", "numero_fuente": "40422", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-11-29", "vigencias": [{"desde": "2012-11-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-11-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-11-29", "fin_vigencia": "", "tipo_version": "3"}], "