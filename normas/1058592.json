{"html": [{"t": "<div><div class=\"p\">CARTA CIRCULAR</div><div class=\"p\">BANCOS&nbsp; N&#xB0; 24</div><div class=\"p\">FINANCIERAS&nbsp; &nbsp;  N&#xB0; 21</div><div class=\"p\">COOPERATIVAS&nbsp; &nbsp; N&#xB0;&nbsp; 1</div><div class=\"p\">Santiago, 18 de febrero de 1992.</div><div class=\"p\">SE&#xD1;OR GERENTE:</div><br><div class=\"p\">Feriado legal el 22 de abril de 1992.</div></div>", "i": 9565417}, {"t": "<div><div class=\"p\">En el Diario Oficial del 29 de enero del a&#xF1;o en curso, se public&#xF3; la </div><div class=\"p\"><a href=\"https://www.leychile.cl/Navegar?idNorma=30483&amp;idParte=0&amp;idVersion=\">Ley N&#xB0; 19.116</a> que, con motivo de la realizaci&#xF3;n del XVI Censo feriado </div><div class=\"p\">legal el dia 22 de abril de 1992.</div><br><div class=\"p\">Al respecto las instituciones financieras deben tener presente que, </div><div class=\"p\">por aplicaci&#xF3;n del <a href=\"https://www.leychile.cl/Navegar?idNorma=1974&amp;idParte=9326724&amp;idVersion=\">art&#xED;culo 111</a> del <a href=\"https://www.leychile.cl/Navegar?idNorma=1974&amp;idParte=0&amp;idVersion=\">C&#xF3;digo de Comercio</a>, todos los </div><div class=\"p\">vencimientos de operaciones pactados a esa fecha quedan prorrogados </div><div class=\"p\">hasta el 23 de abril, d&#xED;a h&#xE1;bil siguiente. En consecuencia, para los </div><div class=\"p\">efectos del c&#xE1;lculo de los intereses y reajustes de los dep&#xF3;sitos y</div><div class=\"p\">captaciones y de las colocaciones que venzan el 22 de abril de 1992, las </div><div class=\"p\">instituciones fiscalizadas deben computar esa pr&#xF3;rroga</div></div>", "i": 9565418}, {"t": "<div><div class=\"p\">Saludo atentamente a Ud.,</div><br><div class=\"p\">LUIS MORAND VALDIVIESO</div><div class=\"p\">Superintendente de Bancos e</div><div class=\"p\">Instituciones Financieras</div><div class=\"p\">Subrogante</div></div>", "i": 9565419}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "31", "numero": "Bancos 24", "abreviacion": "CCI", "descripcion": "Carta Circular", "compuesto": "Carta Circular-Bancos 24"}, {"tipo": "31", "numero": "Financieras 21", "abreviacion": "CCI", "descripcion": "Carta Circular", "compuesto": "Carta Circular-Financieras 21"}, {"tipo": "31", "numero": "Cooperativas 1", "abreviacion": "CCI", "descripcion": "Carta Circular", "compuesto": "Carta Circular-Cooperativas 1"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE BANCOS E INSTITUCIONES FINANCIERAS"], "titulo_norma": "Feriado legal el 22 de abril de 1992", "fuente": "Recopilación de instrucciones SBIF", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-02-18", "doble_articulado": false, "id_norma": "1058592", "numero_fuente": "0", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1992-02-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-02-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-02-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresado_por": "153828", "fecha_ingreso": "2015-02-16", "fecha_version": "1992-02-18", "fecha_actualizacion_texto": "2015-02-16", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9565417}, {"n": "Artículo", "i": 9565418, "t": 6}, {"n": "Promulgación", "i": 9565419}]}