{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10164743}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 127, de fecha 30 de septiembre de 2020, establece forma y plazo para los contribuyentes que tributen conforme a lo dispuesto en los art&#xED;culos 14 letra B) N&#xBA; 1 y N&#xBA; 2 y N&#xBA; 34 de la Ley sobre Impuesto a la Renta, entreguen y certifiquen la informaci&#xF3;n que se detalla. Deja sin efecto <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=1109517&amp;idVersion=2020-10-06\">resoluci&#xF3;n Ex. SII N&#xBA; 102, de 2017</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento est&#xE1; publicado en &quot;www.sii.cl&quot;.</div><br><br></div>", "i": 10164744, "v": ["MODIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "127 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-127 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1826257", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2020-09-30", "fecha_derogacion": "2024-09-06", "doble_articulado": false, "id_norma": "1150365", "numero_fuente": "42773", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2020-10-06", "vigencias": [{"desde": "2024-09-06", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2020-10-06", "hasta": "2024-09-05", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigenci