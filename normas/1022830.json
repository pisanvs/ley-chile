{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9108407}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 274, de 27 de enero de 2011, de esta Subsecretar&#xED;a ampl&#xED;ase por 12 meses a contar del 1 de noviembre de 2010, el plazo otorgado en el numeral 4&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1007388&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.397, de 2009</a>, de esta Subsecretar&#xED;a de Pesca a SOUTHPACIFIC KORP S.A. para iniciar actividades pesqueras extractivas con la nave &quot;Guanaye 5&quot;, sobre los recursos hidrobiol&#xF3;gicos Alfonsino y Besugo, en el &#xE1;rea mar&#xED;tima comprendida entre la XV, I, II, III, IV, VII, IX, XIV y X Regiones, e Islas de Pascua, Salas y G&#xF3;mez, Desventuradas y Archipi&#xE9;lago de Juan Fern&#xE1;ndez.</div></div>", "i": 9108408, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de enero de 2011.- Felipe Palacio Rives, Subsecretario de Pesca (S).</div></div>", "i": 9108409}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "274 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-274 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-01-27", "doble_articulado": false, "id_norma": "1022830", "numero_fuente": "39879", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-02-07", "vigencias": [{"desde": "2011-02-07", "hasta": "", "tipo_versi