{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6357281}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.469, de 28 de septiembre de 2001, se expropi&#xF3; el lote de terreno N&#xBA;7, superficie 166 m2., rol de aval&#xFA;o 524-40, comuna de Estaci&#xF3;n Central, para la obra Sistema Norte-Sur. Tramo G: Nudo Alameda. Sector Km. 1.400,00 al Km. 1.700,00, Regi&#xF3;n Metropolitana se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietaria Gladys Guillermina Salgado Gonz&#xE1;lez y otra, ascendente a la cantidad de $36.989.452. </div></div>", "i": 6357282}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6357283}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1469", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1469"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-09-28", "doble_articulado": false, "id_norma": "191604", "numero_fuente": "37111", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-15", "vigencias": [{"desde": "2001-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2001-11-15", "fecha_version": "2001-11-15", "fecha_actualizacion_texto": "2001-11-15", "tipo_tratado": ""}, "alertas": [], "alerta_globa