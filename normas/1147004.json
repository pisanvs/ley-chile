{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 886 EXENTA, DE 2020, DE ESTA SUBSECRETAR&#xCD;A</div></div>", "i": 10132154}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.419, de 22 de junio de 2020, de esta Subsecretar&#xED;a, se modifica la <a href=\"https://www.leychile.cl/Navegar?idNorma=1144125&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 886, de 2020</a>, de esta repartici&#xF3;n, en el sentido que se indica en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10132155}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de junio de 2020.- Rom&#xE1;n Zelaya R&#xED;os, Subsecretario de Pesca y Acuicultura.</div><div class=\"p\"> </div><div class=\"p\"> </div><br></div>", "i": 10132156}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1419 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1419 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 886 EXENTA, DE 2020, DE ESTA SUBSECRETARÍA", "fuente": "Diario Oficial", "resumenes": [], "materias": ["CORONAVIRUS", "COVID-19", "CORONAVIRUS COVID-19"], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1778630; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-06-22", "doble_articulado": false, "id_norma": "1147004", "numero_fuente": "42691", "tipo_versio