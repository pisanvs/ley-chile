{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n de gracia a do&#xF1;a Carmen Rodr&#xED;guez Rivero</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br><br></div>", "i": 5959315}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia y por el t&#xE9;rmino de diez a&#xF1;os, a do&#xF1;a Carmen Rodr&#xED;guez Rivero, una pensi&#xF3;n mensual de cien pesos, en m&#xE9;rito de los servicios prestados por ella, en el ramo de la instrucci&#xF3;n p&#xFA;blica.</div><br></div>", "i": 5959316}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintinueve de Febrero de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- J. Eduardo Barrios. </div></div>", "i": 5959317}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4324", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4324"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "Concede pensión de gracia a doña Carmen Rodríguez;Rivero", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CARMEN RODRIGUEZ RIVERO", "PENSION GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-02-29", "doble_articulado": false, "id_norma": "24663", "numero_fuente": "15021", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-03-10", "vigencias": [{"desde": "1928-03-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vi