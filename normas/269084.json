{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7363380}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.618, de 21 de diciembre de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a FISH MARKET LIMITADA para ampliar actividades pesqueras de transformaci&#xF3;n autorizadas por resoluciones citadas en Visto, para incorporar a la planta ubicada en Las Flores N&#xBA; 2985, Boca del Maip&#xFA;, Llo Lleo, San Antonio, en las l&#xED;neas de proceso de Fresco enfriado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div><br></div>", "i": 7363381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de diciembre de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7363382}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3618 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3618 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-12-21", "doble_articulado": false, "id_norma": "269084", "numero_fuente": "38979", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-02-05", "vigencias": [{"desde": "2008-02-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-02-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-02-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso