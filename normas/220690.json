{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6461703}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 247, de 21 de enero de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a ALIMENTOS MARINOS S.A. para ampliar actividades pesqueras extractivas con una nave en construcci&#xF3;n autorizada por las resoluciones N&#xBA; 2.384 de 2001 y N&#xBA; 973 de 2003, de esta Subsecretar&#xED;a, con la cual podr&#xE1; capturar los siguientes recursos hidrobiol&#xF3;gicos: en el &#xE1;rea mar&#xED;tima correspondiente a las Regiones V, VI, VII, VIII y X, con cerco: Jibia; y en el &#xE1;rea mar&#xED;tima correspondiente a las Regiones V, VI, VII, VIII y X, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua: Jibia. </div></div>", "i": 6461704}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de enero de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6461705}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "247 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-247 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-01-21", "fecha_derogacion": "2008-06-11", "doble_articulado": false, "id_norma": "220690", "numero_fuente": "37774", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-01-31", "vigencias": [{"desde": "2008-06-11", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-01-31", "hasta": "2008-06-10", "tipo_ve