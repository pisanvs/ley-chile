{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; </div><div class=\"p\">SE APRUEBA INSTRUCTIVO DENOMINADO &quot;PROCEDIMIENTO GESTI&#xD3;N DE CASOS COMPLEJOS&quot;</div></div>", "i": 9656020}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 606, de 6 de noviembre de 2015, se aprueba para el Instituto de Previsi&#xF3;n Social, el instructivo denominado &quot;Procedimiento Gesti&#xF3;n de Casos Complejos&quot;, que describe la forma de operar en la gesti&#xF3;n, escalamiento y seguimiento de casos complejos, que deben observar los funcionarios que trabajan en los canales de atenci&#xF3;n y telef&#xF3;nico del IPS.</div><br></div>", "i": 9656021}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de diciembre de 2015.- Patricio Coronado Rojo, Director Nacional.</div></div>", "i": 9656022}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "606 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-606 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "INSTITUTO DE PREVISIÓN SOCIAL"], "titulo_norma": "SE APRUEBA INSTRUCTIVO DENOMINADO \"PROCEDIMIENTO GESTIÓN DE CASOS COMPLEJOS\"", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2015-11-06", "fecha_derogacion": "2019-12-17", "doble_articulado": false, "id_norma": "1085110", "numero_fuente": "41329", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2015-12-11", "vigencias": [{"desde": "2019-12-17", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2015-12-11", "hasta": "2019-12-16", "tipo_