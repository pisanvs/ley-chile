{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCIONES QUE INDICA </div></div>", "i": 8572620}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.661 de 06 de Noviembre de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, der&#xF3;gase las resoluciones No. 844 y No.</div><div class=\"p\">1.255, ambas de 1987, de esta Subsecretar&#xED;a, que autorizaron a Australis Sociedad An&#xF3;nima Comercial e Industrial, R.U.T.</div><div class=\"p\">No. 59.017.500-5, domiciliada en Santiago, para iniciar y ampliar actividades pesqueras de transformaci&#xF3;n, respectivamente, por renuncia de su titular.</div><br></div>", "i": 8572621}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 06 de Noviembre de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8572622}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1661", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1661"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "DEROGA RESOLUCIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-11-06", "doble_articulado": false, "id_norma": "92658", "numero_fuente": "33531", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-11-25", "vigencias": [{"desde": "1989-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-11-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-11-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":