{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCIONES QUE INDICA</div><br><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 46.- Santiago, 28 de febrero de 1997.- Vistos: Lo dispuesto en el Art. 11 del Decreto Ley N&#xBA; 2.974 de 1979.</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br></div>", "i": 7205235}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;canse las siguientes resoluciones que</div><div class=\"p\">designan Receptores Judiciales en la VIII Regi&#xF3;n, en la</div><div class=\"p\">forma siguiente:</div><br><br><div class=\"p\">-&nbsp; &nbsp; Resoluci&#xF3;n N&#xBA; 27 de 6.03.84, se elimina a don Exequiel</div><div class=\"p\">&nbsp; &nbsp;  Arteaga Fagnilli.</div><div class=\"p\">-&nbsp; &nbsp; Resoluci&#xF3;n N&#xBA; 119 de 2.05.91, se elimina a don Rodrigo Leiva Lobos.</div><div class=\"p\">-&nbsp; &nbsp; Resoluci&#xF3;n N&#xBA; 278 de 24.10.91, se elimina a don Alejandro Le&#xF1;am Licancura.</div><br></div>", "i": 7205236}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Alfonso Jasmen Correa, Director Nacional (S).</div><br></div>", "i": 7205237}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "46", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-46"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "MODIFICA RESOLUCIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECEPTOR JUDICIAL", "OCTAVA REGION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-02-28", "doble_articulado": false, "id_norma": "70