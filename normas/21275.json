{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 454 EXENTO, DE 1993 </div></div>", "i": 7161886}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 454, de 30 de agosto de 1993 se ha aprobado un plan especial de estudio para ser aplicado por el Colegio &quot;Nido de Aguilas&quot;, de Santiago, en todos los cursos de Educaci&#xF3;n B&#xE1;sica y Media Human&#xED;stico-Cient&#xED;fica, a partir del a&#xF1;o escolar 1993.</div><div class=\"p\">&nbsp; &nbsp; A contar de la fecha de vigencia del presente decreto, se deroga el decreto supremo exento de Educaci&#xF3;n N&#xB0; 182 de 1983.</div><br></div>", "i": 7161887}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 17 de Septiembre de 1993.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 7161888}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "454 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-454 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 454 EXENTO, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "COLEGIO NIDO AGUILAS", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-09-17", "doble_articulado": false, "id_norma": "21275", "numero_fuente": "34675", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-09-25", "vigencias": [{"desde": "1993-09-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-09-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-09-25", "fin_vigencia": "", "tip