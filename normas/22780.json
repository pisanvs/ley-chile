{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede un suplemento al presupuesto del Interior Santiago, a 8 de Julio de 1903.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274469}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se concede un suplemento de veinticuatro mil pesos ($ 24,000) al &#xED;tem 55, de la partida 3.a del presupuesto del Ministerio del Interior, para publicaciones de las actas de las sesiones del Congreso desde su or&#xED;jen hasta el a&#xF1;o 1846. </div></div>", "i": 8274470}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- R. Sotomayor.</div><br></div>", "i": 8274471}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1599", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1599"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE UN SUPLEMENTO AL PRESUPUESTO DEL INTERIOR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1903", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1903-07-08", "doble_articulado": false, "id_norma": "22780", "numero_fuente": "7627", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1903-07-08", "vigencias": [{"desde": "1903-07-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1903-07-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1903-07-08