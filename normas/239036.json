{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6529208}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.626, de 31 de mayo de</div><div class=\"p\">2005, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de</div><div class=\"p\">la resoluci&#xF3;n N&#xBA; 333 de 2005, de esta Subsecretar&#xED;a, que</div><div class=\"p\">autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar</div><div class=\"p\">una pesca de investigaci&#xF3;n de conformidad con los</div><div class=\"p\">T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado</div><div class=\"p\">&quot;Monitoreo biol&#xF3;gico-pesquero de la operaci&#xF3;n de cerco</div><div class=\"p\">artesanal de Jurel en aguas interiores de la X Regi&#xF3;n, a&#xF1;o 2005&quot;, en el sentido de extender el plazo de vigencia de la citada pesca de investigaci&#xF3;n hasta el d&#xED;a 31 de octubre de 2005, inclusive.</div><br></div>", "i": 6529209}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de mayo de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6529210}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1626 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1626 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-05-31", "doble_articulado": false, "id_norma": "239036", "numero_fuente": "38184", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-06-13", "vigencias": [{"desde": "2005-06