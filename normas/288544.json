{"html": [{"t": "<div><div class=\"p\">&amp;#160;</div></div>", "i": 8468890}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA;432 de fecha 27 de febrero del 2009, se expropiaron los lotes de terreno N&#xBA;s. 7 y 8 superficies 85 y 121 m2, Rol N&#xBA;32-168, comuna de Requ&#xED;noa, VI Regi&#xF3;n para la obra &quot;Construcci&#xF3;n de Ciclov&#xED;as en la Sexta Regi&#xF3;n, Camino Rol H-193, sector La Compa&#xF1;&#xED;a - El Carmen, Km. 1,40000 a Km. 2,521000, Comuna de Codegua; Camino Rol H-15, sector Puente Codegua - Los Marcos, Km. 8,71500 a Km.10,14600, Comuna de Codegua; Camino Rol H450, Km. 2,78900 a Km. 3,02500, Comuna de Requ&#xED;noa, Sexta Regi&#xF3;n&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario RIGOBERTO ENRIQUE PALMA MIRANDA, ascendente a la cantidad de $4.229.025.- para los lotes N&#xBA;s. 7 y 8.</div></div>", "i": 8468891}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 8468892}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "432 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-432 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-02-27", "doble_articulado": false, "id_norma": "288544", "numero_fuente": "39327", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-04-01", "vigencias": [{"desde": "2009-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-04-01", "fin_vigencia": ""}, "vigencias_version