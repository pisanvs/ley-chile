{"html": [{"t": "<div><div class=\"p\"> </div><div class=\"p\">SE POSTERGA INICIO PROCESO DE EVALUACI&#xD3;N Y REVISI&#xD3;N MASIVA DEL REQUISITO DEL ART&#xCD;CULO 3&#xB0; LETRA B) DE LA LEY N&#xB0; 20.225</div></div>", "i": 9779837}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 591, de 30 de diciembre de 2016, del Director Nacional del Instituto de Previsi&#xF3;n Social, posterga el inicio del proceso de evaluaci&#xF3;n y revisi&#xF3;n masiva de los beneficios del Sistema Solidario a&#xF1;o 2016, respecto del requisito del <a href=\"https://www.leychile.cl/Navegar?idNorma=269892&amp;idParte=8655374&amp;idVersion=\">art&#xED;culo 3&#xB0;</a>, letra b) de la <a href=\"https://www.leychile.cl/Navegar?idNorma=269892&amp;idParte=0&amp;idVersion=\">ley N&#xB0; 20.255</a> por el tiempo que sea necesario para la emisi&#xF3;n del Informe Final de la Mesa T&#xE9;cnica de Trabajo constituida para el efecto.</div></div>", "i": 9779838}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de marzo de 2017.- Patricio Coronado Rojo, Director Nacional.</div></div>", "i": 9779839}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "591 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-591 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARÍA DE PREVISIÓN SOCIAL", "INSTITUTO DE PREVISIÓN SOCIAL"], "titulo_norma": "SE POSTERGA INICIO PROCESO DE EVALUACIÓN Y REVISIÓN MASIVA DEL REQUISITO DEL ARTÍCULO 3° LETRA B) DE LA LEY N° 20.225", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1192540; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-12-3