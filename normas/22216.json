{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; RECONSTRUCCION DEL FUERTE PAPUDO Lei n&#xFA;m. 366.- Santiago, a 17 de Julio de 1896.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947740}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se declaran de utilidad p&#xFA;blica los terrenos de la poblacion del Recreo, puerto de Valparaiso, que se necesitaren para la reconstruccion del fuerte Papudo, comprendidos entre Valparaiso i Vi&#xF1;a del Mar.</div><div class=\"p\">&nbsp; &nbsp; La espropiacion i pago se har&#xE1; en conformidad con las prescripciones de la lei de 18 de Junio de 1857.</div><br><br></div>", "i": 5947741}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Luis Barros Borgo&#xF1;o.</div><br></div>", "i": 5947742}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "366", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-366"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "RECONSTRUCCION DEL FUERTE PAPUDO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FUERTE PAPUDO", "RECONSTRUCCION", "TERRENOS", "UTILIDAD", "PUBLICA", "EXPROPIACION", "VALPARAISO", "VI A DEL MAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-07-17", "doble_articulado": false, "id_norma": "22216", "numero_fuente": "5467", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1896-07-28", "vigencias": [{"desde": "1896-07-28", "hasta": "", "ti