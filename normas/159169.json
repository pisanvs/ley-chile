{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6244278}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;295, de 7 de febrero de 2000, se dej&#xF3; sin efecto los decretos MOP N&#xBA;s. 2.902 y 2.903, ambos de 31 de diciembre de 1998, que ordenaron la expropiaci&#xF3;n de los lotes N&#xBA;s. 1 y 2, respectivamente, de la obra Ruta 5, Tramo Talca-Chill&#xE1;n, soluci&#xF3;n acceso sur a Los Maquis, ya que por cambio de trazado, no ser&#xE1;n necesarios.</div><br></div>", "i": 6244279}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6244280}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "295", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-295"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-07", "doble_articulado": false, "id_norma": "159169", "numero_fuente": "36602", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-01", "vigencias": [{"desde": "2000-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAS", "fecha_ingreso": "2000-03-01", "fecha_version": "2000-03-01", "fecha_actualizacion_texto": "2000-03-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6244278}, {"n": "Artículo", "i": 6244279, "t": 6}