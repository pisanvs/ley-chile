{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7303777}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.972, de 21 de agosto de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 2.544, de 2001, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA BIO BIO S.A. para realizar actividades pesqueras extractivas con la nave &quot;Mar&#xED;a Bernardita&quot;, en el sentido de incorporar las siguientes caracter&#xED;sticas n&#xE1;uticas de &#xE9;sta:</div><br><div class=\"p\">Potencia principal&nbsp; &nbsp; &nbsp; &nbsp;  1627,00 Hp</div><div class=\"p\">Potencia auxiliar&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  240,00 Hp</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  8,60 m.</div><br></div>", "i": 7303778}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7303779}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1972 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1972 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-08-21", "fecha_derogacion": "2007-12-04", "doble_articulado": false, "id_norma": "214822", "numero_fuente": "37662", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-09-16", "vigencias": [{"desde": "2007-12-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Últim