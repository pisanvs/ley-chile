{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7340590}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.179, de 16 de abril de 2007, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de las resoluciones N&#xBA; 283, de 2000, y N&#xBA; 48, de 2003, ambas de esta Subsecretar&#xED;a de Pesca, s&#xF3;lo en cuanto autorizaron a SOCIEDAD PESQUERA VIENTO SUR S.A. para operar la nave &quot;Do&#xF1;a Claudina&quot;, sobre el recurso hidrobiol&#xF3;gico Reineta, en el &#xE1;rea mar&#xED;tima correspondiente a las Regiones V, VI y VII, con arrastre y espinel, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura. </div></div>", "i": 7340591}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de abril de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7340592}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1179 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1179 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-04-16", "doble_articulado": false, "id_norma": "260279", "numero_fuente": "38744", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-04-21", "vigencias": [{"desde": "2007-04-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-04-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-04-21", "fin_vigencia": "", "tipo_