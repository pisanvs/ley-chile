{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 394 EXENTA, DE 30 DE ENERO DE 2012</div></div>", "i": 9269368}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=248145&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 10.827, de 2005</a>, modificada por la resoluci&#xF3;n exenta N&#xBA; 6.005 de 2011, ambas, del Ministerio de Educaci&#xF3;n, que aprobaron planes y programas especiales de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, a la Sociedad Desarrollos Educacionales S.A., sostenedora de los Colegios Pumahue-Manquecura, en el sentido de sustituir el plan de estudio de 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media.</div></div>", "i": 9269369}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de enero de 2012.- Jorge Poblete Aedo, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 9269370}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "394 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-394 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 394 EXENTA, DE 30 DE ENERO DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-01-30", "doble_articulado": false, "id_norma": "1041355", "numero_fuente": "40298", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-27", "vigencias": [{"desde": "2012-06-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-06-27", "fin_vigencia": ""}, "vigencias_ve