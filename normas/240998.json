{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6536180}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 529, de fecha 30 de junio de 2005, se expropi&#xF3; el lote de terreno N&#xBA; 657, superficie 683 m&#xB2;, Rol en tr&#xE1;mite, comuna de Pichidegua, VI Regi&#xF3;n para la obra &quot;Camino Conexi&#xF3;n Vial Pichidegua - Las Cabras, sector San Roberto - El Toco - Ruta 66, tramo km. 0,00000 al km. 12,70000&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Alejandro Segundo Arru&#xE9; S&#xE1;nchez y Otros, ascendente a la cantidad de $10.657.200, para el lote N&#xBA; 657.</div><br></div>", "i": 6536181}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6536182}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "529", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-529"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-30", "doble_articulado": false, "id_norma": "240998", "numero_fuente": "38237", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-08-16", "vigencias": [{"desde": "2005-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2005-08-16", "fecha_version": "2005-08-16", "fecha_actualizacion_texto":