{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 516 EXENTO, DE 1995 </div></div>", "i": 8667381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 516 de fecha 01 de Septiembre de 1995 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Centro de Estudios Tur&#xED;sticos CET, las adecuaciones introducidas al plan y programas de estudio de la carrera de Turismo, las que se insertaron en la Resoluci&#xF3;n Exenta del Ministerio de Educaci&#xF3;n N&#xB0; 3.271 de 1985. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o de 1995.</div><br></div>", "i": 8667382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 28 de Septiembre de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8667383}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "516 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-516 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 516 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "PLANES ESTUDIO", "CENTRO FORMACION", "TECNICA", "CENTRO ESTUDIOS TURISTICOS CET", "PROGRAMAS", "ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-09-28", "doble_articulado": false, "id_norma": "21395", "numero_fuente": "35286", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-10-07", "vigencias": [{"desde": "1995-10-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-10-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-10-07", "fin_vig