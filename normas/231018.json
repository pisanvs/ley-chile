{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6499556}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n N&#xBA; 2.611, de 10 de septiembre de</div><div class=\"p\">2004, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA; de</div><div class=\"p\">la resoluci&#xF3;n N&#xBA; 114 de 2004, de esta Subsecretar&#xED;a de</div><div class=\"p\">Pesca, que autoriz&#xF3; a la UNIVERSIDAD CATOLICA DEL NORTE,</div><div class=\"p\">Sede Coquimbo, para efectuar una pesca de investigaci&#xF3;n</div><div class=\"p\">de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia</div><div class=\"p\">del Proyecto denominado &quot;Distribuci&#xF3;n espacio temporal</div><div class=\"p\">de las agregaciones de jurel en la IV Regi&#xF3;n, temporada</div><div class=\"p\">2004&quot;, en el sentido de reemplazar la embarcaci&#xF3;n</div><div class=\"p\">artesanal &quot;Nidia I&quot;, por la embarcaci&#xF3;n artesanal &quot;Nidia II&quot;, en la n&#xF3;mina de naves participantes en la presente pesca de investigaci&#xF3;n.</div><br></div>", "i": 6499557}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de septiembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6499558}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2611", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2611"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-09-10", "doble_articulado": false, "id_norma": "231018", "numero_fuente": "37976", "ti