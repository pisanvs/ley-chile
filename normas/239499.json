{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6530875}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;1.912 de esta Subsecretar&#xED;a, autor&#xED;zase a las Organizaciones de Pescadores Artesanales pertenecientes de la XI Regi&#xF3;n, sometidas al R&#xE9;gimen Artesanal de Extracci&#xF3;n en la unidad de pesquer&#xED;a de Merluza del sur, para ampliar el plazo de operaciones para realizar actividades pesqueras extractivas correspondientes al mes de junio, en las fechas que en cada caso se indica: a) Flota Norte 1: 22 al 26 de junio; b) Flota Norte 2: 26 al 30 de junio; c) Flota Sur 1: 27 al 30 de junio; d) Flota Sur 2: 22 al 25 de junio.</div><br></div>", "i": 6530876}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de junio de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6530877}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1912 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1912 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-20", "doble_articulado": false, "id_norma": "239499", "numero_fuente": "38196", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-06-28", "vigencias": [{"desde": "2005-06-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-06-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-06-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_