{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 216, DE 1987 </div></div>", "i": 7312867}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 216, de 02 de noviembre de 1987 se ha declarado que, a partir del presente a&#xF1;o escolar, el Liceo Industrial Siegfried Gildemeister, de Polpaico, impartir&#xE1; ense&#xF1;anza en la Especialidad de Construcci&#xF3;n Habitacional con menciones en Alba&#xF1;iler&#xED;a y Hormig&#xF3;n Armado y en Carpinter&#xED;a de Obra Gruesa y Terminaciones, de acuerdo al plan y programas de estudio aprobado por Decreto Supremo Exento de Educaci&#xF3;n N&#xB0; 178, de 1985.</div><br></div>", "i": 7312868}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de Noviembre de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 7312869}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "216 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-216 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 216, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-02", "doble_articulado": false, "id_norma": "227222", "numero_fuente": "32928", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-24", "vigencias": [{"desde": "1987-11-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-11-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen