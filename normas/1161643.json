{"html": [{"t": "<div><div class=\"p\">MINISTRO DEL INTERIOR.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Octubre 26 de 1832.</div></div>", "i": 10255329}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Habiendo concedido por decreto de esta fecha una licencia temporal al Ministro de Hacienda don Manuel Rengifo, vengo en nombrar al del Interior y Relaciones Exteriores don Joaquin Tocornal, para que durante su ausencia se encargue del despacho de aquel departamento.</div></div>", "i": 10255330}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon y comun&#xED;quese.</div><br><div class=\"p\">&nbsp; &nbsp;  PRIETO.</div><div class=\"p\">&nbsp; &nbsp;  Manuel Carvallo.</div></div>", "i": 10255331}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTRO", "descripcion": "Otro", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "MINISTRO DEL INTERIOR.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-10-26", "doble_articulado": false, "id_norma": "1161643", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-10-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-10-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-10-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2021-07-28", "fecha_version": "1832-10-26", "fecha_actualizacion_texto": "1832-10-26", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "