{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,841.- Por cuanto el Congreso Nacional ha aprobado el siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6175289}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la suma de veinte mil pesos ($ 20,000), oro, en el mejoramiento de los servicios instalados en la Quinta Normal de Agricultura.</div><br></div>", "i": 6175290}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a diecisiete de enero de mil novecientos catorce.- Ramon Barros Luco.- Enrique Za&#xF1;artu P. </div></div>", "i": 6175291}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2841", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2841"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1914-01-17", "doble_articulado": false, "id_norma": "138412", "numero_fuente": "10782", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1914-01-26", "vigencias": [{"desde": "1914-01-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1914-01-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1914-01-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ing