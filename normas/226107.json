{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 17 EXENTO, DE 2004 </div></div>", "i": 6482424}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 17 de fecha 15 de enero de 2004 del Ministerio de Educaci&#xF3;n, se aprueban las modificaciones introducidas al plan y programas de estudios del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Umbrales de Santiago, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar del a&#xF1;o 2004, en la Casa Central de Santiago, con la siguiente denominaci&#xF3;n:</div><br><div class=\"p\">Carrera&nbsp; :&nbsp; Tecnolog&#xED;a de la Construcci&#xF3;n, cambia por: Carrera&nbsp; :&nbsp; T&#xE9;cnico en Construcci&#xF3;n</div><div class=\"p\">T&#xED;tulo&nbsp;  :&nbsp;  T&#xE9;cnico de Nivel Superior en Construcci&#xF3;n </div></div>", "i": 6482425}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de febrero de 2004.- Pedro Henr&#xED;quez Guajardo, Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 6482426}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "17 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-17 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 17 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-15", "doble_articulado": false, "id_norma": "226107", "numero_fuente": "37878", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-05", "vigencias": [{"desde": "2004-06-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "20