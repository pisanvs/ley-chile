{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9366680}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.800, de 17 de julio de 2013, de esta Subsecretar&#xED;a, autor&#xED;zase a ORIZON S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Vesterveg&quot;, en el &#xE1;rea comprendida desde la III a VII y IX a X Regiones, por fuera del &#xE1;rea de reserva artesanal con cerco, los siguientes recursos hidrobiol&#xF3;gicos: Agujilla, Machuelo o Tritre, Pampanito, Vinciguerria y Cubiceps.</div></div>", "i": 9366681}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de julio de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9366682}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1800 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1800 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-07-17", "doble_articulado": false, "id_norma": "1053145", "numero_fuente": "40618", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-07-26", "vigencias": [{"desde": "2013-07-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-07-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-07-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2013-07-26", "fecha_version": "2013-