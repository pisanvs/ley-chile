{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,177.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6179760}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se concede, por gracia, a do&#xF1;a Laura Brice&#xF1;o, viuda del servidor p&#xFA;blico don Francisco Javier Concha, una pension anual de dos mil cuatrocientos pesos ($ 2,400), que se pagar&#xE1; desde la promulgacion de la presente lei.</div><br></div>", "i": 6179761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a dos de enero de mil novecientos diecisiete.- Juan Luis Sanfuentes.- Pedro F. I&#xF1;iguez. </div></div>", "i": 6179762}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3177", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3177"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1917-01-02", "doble_articulado": false, "id_norma": "139804", "numero_fuente": "11666", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1917-01-06", "vigencias": [{"desde": "1917-01-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1917-01-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1917-01-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul