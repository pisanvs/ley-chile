{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6277106}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 809 de 29 de Septiembre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Xa. Regi&#xF3;n, se autoriza a Jos&#xE9; Henr&#xED;quez Vera para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea N&#xB0; 40 &quot;Las Animas - Regional - Centro&quot; de Valdivia, cuyo trazado fue autorizado por resoluci&#xF3;n N&#xB0; 150 de fecha 04 de julio de 1984, modificado por resoluci&#xF3;n N&#xB0; 012 de 04 de Enero de 1985 y resoluci&#xF3;n N&#xB0; 021 de 14 de enero de 1985, de esta Secretar&#xED;a Regional.</div><br></div>", "i": 6277107}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial Transportes y Telecomunicaciones Xa. Regi&#xF3;n. </div></div>", "i": 6277108}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "809 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-809 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-29", "doble_articulado": false, "id_norma": "169238", "numero_fuente": "32918", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-12", "vigencias": [{"desde": "1987-11-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-12", "fin_vigencia