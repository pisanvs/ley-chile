{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO ALCALDICIO No. 283, DE 1988 </div></div>", "i": 6134857}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alcalde I. Municipalidad de Calle Larga mediante Decreto No. 293, de 10 de octubre de 1988 dispone modificaci&#xF3;n, con arreglo al art&#xED;culo 54&#xB0; de la Ley No.</div><div class=\"p\">18.695, Org&#xE1;nica Constitucional de Municipalidades, la denominaci&#xF3;n de doce calles y poblaciones de la Comuna, dan denominaci&#xF3;n a calles y pasajes de cinco poblaciones y ordena numeraci&#xF3;n a las viviendas ubicadas dentro del Radio Urbano de la Comuna.-</div><br></div>", "i": 6134858}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Alcalde.</div><br></div>", "i": 6134859}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "293", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-293"}], "organismos": ["MUNICIPALIDAD DE CALLE LARGA"], "titulo_norma": "EXTRACTO DE DECRETO ALCALDICIO No. 283, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-10-10", "doble_articulado": false, "id_norma": "125866", "numero_fuente": "33214", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-11-07", "vigencias": [{"desde": "1988-11-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-11-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-11-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "1998-10-13", "fecha_version": "1988-11-07", "fecha_actualizacion_texto": "1988-11-07", "