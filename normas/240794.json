{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6535435}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 2.264, de 21 de julio de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA SAN JOSE S.A. para realizar actividades extractivas en aguas internacionales, en orden a operar la nave &quot;Antarctic&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; CB-4552</div><div class=\"p\">Puerto de matr&#xED;cula&nbsp; &nbsp;  Valpara&#xED;so</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  2709</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; 48.77&nbsp;  m</div><div class=\"p\">TRG (Internacional)&nbsp; &nbsp;  786.00</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  9.5&nbsp;  m</div><div class=\"p\">Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 4.85&nbsp;  m.</div><br><div class=\"p\">&nbsp; &nbsp;  Previo al inicio de operaciones de la nave, la solicitante deber&#xE1; inscribirla en el Registro Nacional Pesquero Industrial que lleva el Servicio Nacional de Pesca.</div><br></div>", "i": 6535436}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de julio de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6535437}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2264 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2264 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observa