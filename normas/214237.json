{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6437956}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA;739 de fecha 31 de julio de 2003, se expropi&#xF3; el lote de terreno N&#xBA;34, superficie 413 m&#xB2;, rol de aval&#xFA;o N&#xBA;156-12, comuna de Curarrehue, para la obra &quot;Camino Catripulli-Curarrehue, Sector Km. 108,02 al Km. 114,80&quot;, IX Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Nemecio o Nemesio Dur&#xE1;n M&#xE9;ndez, ascendente a la cantidad de $1.208.535. </div></div>", "i": 6437957}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6437958}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "739 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-739 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-07-31", "doble_articulado": false, "id_norma": "214237", "numero_fuente": "37649", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-01", "vigencias": [{"desde": "2003-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2003-09-02", "fecha_version": "2003-09-01", "fecha_actualizacion_texto": "2003-09-01", "tipo_tratado": ""}, "alertas": [], "alerta_global":