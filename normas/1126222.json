{"html": [{"t": "<div><br><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9973123}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta N&#xB0; 6.693, de 21 de noviembre de 2018, Serviu Regi&#xF3;n de Valpara&#xED;so, dispuesto expropiaci&#xF3;n conforme al art&#xED;culo 51 Ley 16.391 y Decreto Ley 2.186 de 1978, del inmueble signado como lote 435, en el plano &quot;Proyecto de Expropiaciones GS-186 N&quot; L&#xE1;mina 02 de 03, ubicado en Avenida Alemania N&#xB0; 10069, Cerro Las Ca&#xF1;as, comuna de Valpara&#xED;so, para la ejecuci&#xF3;n del proyecto &quot;Saneamiento Sanitario Quebrada Kayser, comuna de Valpara&#xED;so&quot;. Presunto Dominio de Mar&#xED;a Margarita Valencia Paracan, rol aval&#xFA;o 5160-324. Comisi&#xF3;n Tasadora integrada por Julia Venegas Escalante; Guillermo Parra Silva y Jaime Jungers Bittner, seg&#xFA;n informe de 2018 fij&#xF3; monto indemnizaci&#xF3;n provisional en $5.674.868.-, que ser&#xE1; pagada al contado.- </div></div>", "i": 9973124}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Directora (S) Serviu. </div><br></div>", "i": 9973125}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6693 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6693 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "V REGIÓN DE VALPARAÍSO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1503861", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-11-21", "doble_articulado": false, "id_norma": "1126222", "numero_fuente": "42219", "tipo_version": "3", "tipo_version_