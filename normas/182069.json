{"html": [{"t": "<div><div class=\"p\">PRORROGA VIGENTE DE ORDENANZA No. 1, DE 1987</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 16.- Pelarco, Enero 23 de 1989.- Vistos: Teniendo presente: lo dispuesto en el Art. 43 del decreto ley No. 3.063 sobre Rentas Municipales, las facultades que me confiere la Ley 18.695 de 1988, Org&#xE1;nica Constitucional de Municipalidades:</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 7280626}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.- Prorr&#xF3;gase, por el a&#xF1;o 1989 la vigencia de la Ordenanza Municipal No. 1 del a&#xF1;o 1987, publicada en el Diario Oficial No. 33.004 de fecha 24 de Febrero de 1988.</div><br></div>", "i": 7280627}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Publ&#xED;quese por una sola vez en el Diario Oficial.- Comun&#xED;quese, publ&#xED;quese y c&#xFA;mplase.- Bonifacio Correa Echenique, Alcalde.- Hern&#xE1;n Leigh S&#xE1;nchez, Secretario. </div></div>", "i": 7280628}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "16", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-16"}], "organismos": ["MUNICIPALIDAD DE PELARCO"], "titulo_norma": "PRORROGA VIGENTE DE ORDENANZA No. 1, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-01-23", "doble_articulado": false, "id_norma": "182069", "numero_fuente": "33286", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-01-31", "vigencias": [{"desde": "1989-01-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-01-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-01-31", "fin_v