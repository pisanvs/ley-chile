{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8331948}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 985, de 13 de julio de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA;168 de 1997, de esta Subsecretar&#xED;a, que autoriz&#xF3; a ALIMENTOS MARINOS S.A. para realizar actividades pesqueras extractivas con la nave &apos;&apos;Santa Irene&apos;&apos;, s&#xF3;lo en cuanto a las unidades de pesquer&#xED;a se&#xF1;aladas en su numeral 2 letra a), Anchoveta y Sardina espa&#xF1;ola en el litoral de la III y IV Regiones, por no haber operado sobre dichas unidades de pesquer&#xED;a, de conformidad a lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8331949}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de julio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8331950}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "985", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-985"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "ALIMENTOS MARINOS S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-13", "doble_articulado": false, "id_norma": "121483", "numero_fuente": "36117", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-07-18", "vigencias": [{"desde": "1998-07-18", "hasta": "", "tipo_version": "3", "tipo_version_