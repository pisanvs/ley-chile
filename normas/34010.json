{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9016843}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 256, de 8 de Abril de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por 30 d&#xED;as a contar de la fecha de la presente resoluci&#xF3;n, el plazo otorgado a PESQUERA FRIOSUR S.A., R.U.T. N&#xB0;</div><div class=\"p\">86.577.500-8, en orden a publicar en el Diario Oficial la resoluci&#xF3;n N&#xB0; 1407, de 1992, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor.</div><br></div>", "i": 9016844}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 8 de Abril de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 9016845}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "256", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-256"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "PESQUERA FRIOSUR S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-04-08", "doble_articulado": false, "id_norma": "34010", "numero_fuente": "34554", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-04-30", "vigencias": [{"desde": "1993-04-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-04-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-04-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul