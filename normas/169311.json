{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6277295}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 870, de 26 de Octubre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Daniel Solis S&#xE1;nchez para efectuar servicio de taxi colectivo urbano de la L&#xED;nea N&#xB0; 50 &quot;San Luis Regional - Centro&quot; de Valdivia, cuyo trazado fue autorizado por resoluci&#xF3;n exenta N&#xB0; 12, de 04.01.85 y modificado por resoluci&#xF3;n exenta N&#xB0; 474, de 30 de Octubre de 1985, de esta Secretar&#xED;a Regional. </div></div>", "i": 6277296}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6277297}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "870 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-870 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-10-26", "doble_articulado": false, "id_norma": "169311", "numero_fuente": "32922", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-17", "vigencias": [{"desde": "1987-11-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-11-17",