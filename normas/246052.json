{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6556551}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.523 exenta, de 30 de diciembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA CISNE S.A. para realizar operaciones pesqueras, a contar del 1&#xBA; de enero del a&#xF1;o 2006 y hasta el 31 de diciembre del mismo a&#xF1;o, ambas fechas inclusive, con el barco f&#xE1;brica &quot;Cisne Blanco&quot;, en aguas exteriores, por fuera de las l&#xED;neas de base rectas, al sur del paralelo 44&#xB0;30&apos;00 L.S., y con el barco f&#xE1;brica &quot;Cisne Verde&quot;, en aguas exteriores, por fuera de las l&#xED;neas de base rectas, al sur del paralelo 47&#xB0;00&apos;00&quot; L.S., respecto de los recursos y con las obligaciones establecidas en sus respectivas autorizaciones.</div><br></div>", "i": 6556552}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de diciembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6556553}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4523 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4523 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-30", "doble_articulado": false, "id_norma": "246052", "numero_fuente": "38358", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-01-09", "vigencias": [{"desde": "2006-01-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia":