{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE&nbsp; RESOLUCION N&#xBA; 73, DE 1999</div><br><br></div>", "i": 6259120}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 73, de fecha 7 de septiembre de 1999, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la Personalidad Jur&#xED;dica de la Asociaci&#xF3;n Gremial de Due&#xF1;os de Taxibuses L&#xED;nea N&#xBA; 7 de Antofagasta, inscrita bajo el N&#xBA; 1.070, del Registro de Asociaciones Gremiales que para tal efecto lleva este Ministerio, por haberse configurado respecto de ella, la causal de cancelaci&#xF3;n contemplada en el art&#xED;culo 18, N&#xBA; 2, letra d) de la ley 2.757 de 1979.-</div><br></div>", "i": 6259121}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Alvaro D&#xED;az P&#xE9;rez, Subsecretario de Econom&#xED;a, Fomentoy Reconstrucci&#xF3;n.</div><br></div>", "i": 6259122}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "73", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-73"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 73, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-09-07", "doble_articulado": false, "id_norma": "163670", "numero_fuente": "36630", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-03", "vigencias": [{"desde": "2000-04-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-04-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigen