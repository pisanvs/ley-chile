{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8332937}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.077, de 29&nbsp; de julio de 1998, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA OMEGA LIMITADA, para iniciar actividades pesqueras extractivas con una nave denominada &apos;&apos;Portugal II&apos;&apos;, en el litoral correspondiente a las Islas de Pascua, Salas y G&#xF3;mez, Juan Fern&#xE1;ndez y San F&#xE9;lix, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar con espinel los siguientes recursos hidrobiol&#xF3;gicos: Anguila, At&#xFA;n aleta amarilla, At&#xFA;n aleta larga, At&#xFA;n ojos grandes, Bacalao de profundidad, Toremo, Remoremo, Tollo, Marrajo o tibur&#xF3;n y Pez Volador. </div></div>", "i": 8332938}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de julio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8332939}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1077", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1077"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA OMEGA LIMITADA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-29", "doble_articulado": false, "id_norma": "122773", "numero_fuente": "36133", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-08-06", "vigencias": [{"desde": "1998-08-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-08-06", "fin_vigencia": ""}, "