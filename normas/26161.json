{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA EN LA FORMA QUE SE&#xD1;ALA LA LEY N&#xB0; 4,285, RELACIONADA CON LA CAJA DE CREDITO POPULAR</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7172707}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Der&#xF3;gase el art&#xED;culo 4&#xB0; de la ley N&#xB0; 4,285, de 16 de Febrero de 1928.</div><br></div>", "i": 7172708, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, once de Marzo de mil novecientos cincuenta.- GABRIEL GONZALEZ VIDELA.- Ruperto Puga. </div></div>", "i": 7172709}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "9584", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-9584"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "MODIFICA EN LA FORMA QUE SEÑALA LA LEY N° 4,285,\nRELACIONADA CON LA CAJA DE CREDITO POPULAR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DEROGACION", "MODIFICACION", "LEY 4285", "ARTICULO 4", "EMPE O ESPECIES", "PENA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1950-03-11", "doble_articulado": false, "id_norma": "26161", "numero_fuente": "21615", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1950-03-27", "vigencias": [{"desde": "1950-03-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1950-03-27", "fin_vigencia": ""}, "vigencias_vers