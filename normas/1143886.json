{"html": [{"t": "<div><br><div class=\"p\">VIJIAS DEL PUERTO DE VALPARAISO.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 23 de 1825.</div><br><div class=\"p\">&nbsp; &nbsp;  Consultando el ahorro de trescientos pesos anuales que resulta de la reforma en el servicio de las vijias del puerto de Valpara&#xED;so, decreto:</div></div>", "i": 10119906}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1.&#xB0; Desde principio del mes entrante las vijias de la Coroumilla, quebrada Verde, y castillo de San Antonio ser&#xE1;n servidas por marineros de segunda clase.</div><br><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; El Comandante del Apostadero y Comisar&#xED;a de Marina, quedan encargados del cumplimiento de este decreto. Trascr&#xED;base, impr&#xED;mase y t&#xF3;mese razon donde corresponda.</div><br></div>", "i": 10119907}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Correa de Saa.</div><br></div>", "i": 10119908}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "VIJIAS DEL PUERTO DE VALPARAISO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-07-23", "doble_articulado": false, "id_norma": "1143886", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-07-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-07-23", "fin_vigencia": "", "