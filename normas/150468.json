{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br></div>", "i": 6216115}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xB0; 21, de 05 de Enero de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana, se autoriza a do&#xF1;a Azucena de las Mercedes P&#xE9;rez Ortiz para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6216116}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, Enero 7 de 1987. Ramiro Camero Weir, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana subrogante.</div><br><br></div>", "i": 6216117}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "21 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-21 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-01-05", "doble_articulado": false, "id_norma": "150468", "numero_fuente": "32710", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-02-28", "vigencias": [{"desde": "1987-02-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-02-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-02-28", "fi