{"html": [{"t": "<div><br><div class=\"p\">ESTABLECE OBLIGACI&#xD3;N DE PRESENTAR DECLARACI&#xD3;N JURADA QUE INDICA</div></div>", "i": 9916119}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta, del Servicio de Impuestos Internos N&#xB0; 46, del 18 de mayo de 2018, que se&#xF1;ala:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Establece obligaci&#xF3;n de presentar Declaraci&#xF3;n Jurada Anual sobre Trusts; fija formato y mecanismo de declaraci&#xF3;n, y deroga <a href=\"https://www.leychile.cl/Navegar?idNorma=1062582&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta SII N&#xB0; 47, de fecha 19.05.2014</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de mayo de 2018.</div><br></div>", "i": 9916120, "v": ["MODIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "46 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-46 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ESTABLECE OBLIGACIÓN DE PRESENTAR DECLARACIÓN JURADA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1402735", "NORMA SIN PROMULGACIÓN", "EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2018-05-18", "fecha_derogacion": "2020-10-06", "doble_articulado": false, "id_norma": "1118948", "numero_fuente": "42065", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2018-05-25", "vigencias":