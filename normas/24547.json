{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aprueba Tratado de Arbitraje con Espa&#xF1;a, subscrito en Madrid en Enero de 1926</div><br><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><div class=\"ab\"><a href=\"Navegar/pdf/PDF/2352.PDF\">Descargar&nbsp; (PDF, 104 K)</a></div></div>", "i": 8801593}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Apru&#xE9;base el Tratado de Arbitraje con Espa&#xF1;a, subscrito en Madrid, el 28 de Enero pr&#xF3;ximo pasado.</div><br><br></div>", "i": 8801594}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y, por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintitr&#xE9;s de Septiembre de mil novecientos veintisiete.- Carlos Ib&#xE1;&#xF1;ez C.- Conrado R&#xED;os Gallardo.</div><br></div>", "i": 8801595}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4186", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4186"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES"], "titulo_norma": "APRUEBA TRATADO DE ARBITRAJE CON ESPAÑA, SUBSCRITO EN MADRID EN ENERO DE 1926", "fuente": "Recopilación de leyes de la Contraloría", "resumenes": [], "materias": ["Tratado de Arbitraje Chile-España"], "terminos_libres": ["ACUERDOS INTERNACIONALES", "CHILE - ESPAÑA", "TRATADO DE ARBITRAJE", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": ["España"], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1927-09-23", "doble_articulado": false, "id_norma": "24547", "numero_fuente": "14882", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "19