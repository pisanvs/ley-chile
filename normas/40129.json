{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SOLICITA CONSTITUCION LEGAL DEL &quot;PARTIDO DEMOCRATA CRISTIANO&quot; EN LA XII REGION </div></div>", "i": 6025943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Andr&#xE9;s Zald&#xED;var Larra&#xED;n y Felipe Sandoval Precht, en representaci&#xF3;n del Partido Dem&#xF3;crata Cristiano, han solicitado la constituci&#xF3;n legal del Partido en la XII Regi&#xF3;n de Magallanes y Ant&#xE1;rtica Chilena, acompa&#xF1;ando 514 fichas de afiliaciones.</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la Ley N&#xB0; 18.603. Por Resoluci&#xF3;n Exenta N&#xB0; O-2.265 de fecha 29 de Noviembre de 1991.</div><br></div>", "i": 6025944}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 29 de Noviembre de 1991.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6025945}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2265", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-2265"}, {"tipo": "3", "numero": "0-2265 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-0-2265 EXENTA"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCION LEGAL DEL PARTIDO DEMOCRATA CRISTIANO EN LA XII REGION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDO DEMOCRATA CRISTIANO", "XII REGION", "CONSTITUCION LEGAL", "PARTIDOS POLITICOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-11-29", "doble_articulado": false, "id_norma": "40129", "numero_fuente": "34134", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-12-05", "vigencias": [{"desde": "1991-12-05", "hast