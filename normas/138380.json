{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 7250095}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 136, de 26 de enero de 1988, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se modifica la resoluci&#xF3;n No. 1.373/83, publicada en el Diario Oficial de 06 de diciembre de 1983, en el sentido de sustituir los 108 asientos diarios con que la empresa de origen chileno &quot;Ferr&#xE9; y Grau Limitada&quot; (Chile - Bus Ltda.), efect&#xFA;a el servicio internacional de transporte terrestre de pasajeros entre Santiago - Valpara&#xED;so - Vi&#xF1;a del Mar - Mendoza, por una (1) frecuencia diaria de ida y vuelta. La empresa antes individualizada est&#xE1; autorizada para reforzar las frecuencias hasta en un cien por ciento (100%).-</div><br></div>", "i": 7250096}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Patricio Figueroa Cruz, Subsecretario de Transportes Subrogante.</div><br></div>", "i": 7250097}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "136", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-136"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-26", "doble_articulado": false, "id_norma": "138380", "numero_fuente": "32992", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-10", "vigencias": [{"desde": "1988-02-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-10", "fin_vigen