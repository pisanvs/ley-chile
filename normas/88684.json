{"html": [{"t": "<div><div class=\"p\">MODIFICA ORDENANZA No. 1, DE 1988 </div></div>", "i": 6080147}, {"t": "<div><div class=\"p\">I. Municipalidad de Renca, con fecha 19 de octubre de 1990, se dict&#xF3; el Decreto Alcaldicio No. 1793, mediante el cual se modifica la Ordenanza No. 001 de 27 de enero de 1988, sobre derechos municipales por permisos, concesiones y servicios municipales, s&#xF3;lo en el sentido de que se agrega a continuaci&#xF3;n del art&#xED;culo 10&#xB0; de la citada Ordenanza y con el No. 23, lo siguiente: No. 23.- Inscripci&#xF3;n en el Registro Municipal de veh&#xED;culos a tracci&#xF3;n animal y carros de mano..... 5% UTM.</div><div class=\"p\">La referida modificaci&#xF3;n comenzar&#xE1; a regir a contar de la fecha de esta publicaci&#xF3;n.</div><br></div>", "i": 6080148}, {"t": "<div><div class=\"p\">- Jorge Baraona Gonz&#xE1;lez, Alcalde.</div><br></div>", "i": 6080149}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1793", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1793"}], "organismos": ["MUNICIPALIDAD DE RENCA"], "titulo_norma": "MODIFICA ORDENANZA No. 1, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-10-19", "doble_articulado": false, "id_norma": "88684", "numero_fuente": "33802", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-10-25", "vigencias": [{"desde": "1990-10-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-10-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-10-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":