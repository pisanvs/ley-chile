{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA;179, DE 1991 </div></div>", "i": 7215819}, {"t": "<div><div class=\"p\">Por Decreto Exento N&#xBA;179 de fecha 11 de Julio de 1991 del Ministerio de Educaci&#xF3;n se reemplazaron las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica ECACEC, que fueran aprobadas por Resoluci&#xF3;n Exenta N&#xBA;1955 de 1987, las que podr&#xE1;n aplicarse a contar del a&#xF1;o 1991.</div><br></div>", "i": 7215820}, {"t": "<div><div class=\"p\">Santiago, 21 de Agosto de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7215821}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "179 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-179 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº179, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-07-11", "doble_articulado": false, "id_norma": "80948", "numero_fuente": "34094", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-10-18", "vigencias": [{"desde": "1991-10-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-10-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-10-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "CQA", "fecha_ingreso": "1997-12-23", "fecha_version": "1991-10-18", "fecha_actualizacion_texto