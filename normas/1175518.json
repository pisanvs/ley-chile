{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10330002}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xB0; 540, del 22 de abril de 2022, Serviu Regi&#xF3;n de &#xD1;uble orden&#xF3; expropiaci&#xF3;n de inmueble ubicado en Huambaly 707, comuna de Chill&#xE1;n, Rol de Aval&#xFA;o N&#xB0; 001766-00002, de aparente dominio de Ortega Villalobos Mar&#xED;a. La parte afecta a expropiaci&#xF3;n parcial de terreno es de 28,18 m2, cuyos linderos particulares, enmarcados en el plano S16R-168, para el proyecto &quot;Mejoramiento Avenida Huambaly, comuna de Chill&#xE1;n Regi&#xF3;n de &#xD1;uble&quot;, conforme art&#xED;culo 51 Ley 16.391 y DL 2.186. Comisi&#xF3;n Peritos integrada por el Arquitecto don Mario Fabrizzio Bellolio Bostica, Constructor Civil don Italo Renzo Zerga Arancibia y por el Ingeniero Civil don Orlando Javier Paredes V&#xE1;squez, que fij&#xF3; el monto de la indemnizaci&#xF3;n provisional por la expropiaci&#xF3;n, en la suma de $8.302.854.- </div></div>", "i": 10330003}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n de &#xD1;uble.</div><br></div>", "i": 10330004}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "540 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-540 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DE ÑUBLE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2120322", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-04-22", "doble_articulado": false, "id_norma": "11