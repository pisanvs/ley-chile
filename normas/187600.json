{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6342527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;813, de 31 de mayo de 2001, se expropiaron los lotes de terreno N&#xBA;s. 9, 10 y 16-B, superficies 35.902 m&#xB2;, 146.217 m&#xB2; y 1.657 m&#xB2;, rol de aval&#xFA;o 1503-7, comuna de Los Angeles, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: Chill&#xE1;n- Collipulli. By Pass Los Angeles, Octava Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Obispado de la Di&#xF3;cesis de Santa Mar&#xED;a de los Angeles, ascendente a la cantidad total de $217.449.912.- </div></div>", "i": 6342528}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6342529}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "813", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-813"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-31", "doble_articulado": false, "id_norma": "187600", "numero_fuente": "37012", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-07-16", "vigencias": [{"desde": "2001-07-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-07-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-07-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2001-07-16", "fecha_version": "2001-07-16", "fecha_actualizacion_texto": "2