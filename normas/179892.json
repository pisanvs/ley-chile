{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 11.357 EXENTA, DE 2000 </div></div>", "i": 6315584}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 11.357, de 15 de noviembre del a&#xF1;o 2000, se ha aprobado al Colegio &apos;&apos;St. Margaret&apos;s British School&apos;&apos;, comuna de Vi&#xF1;a del Mar, V Regi&#xF3;n de Valpara&#xED;so, un plan de estudio para 3&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 6315585}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de noviembre de 2000.- Javier San Miguel Beltr&#xE1;n, Jefe Divisi&#xF3;n de Educaci&#xF3;n General Subrogante.</div><br></div>", "i": 6315586}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "11357 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-11357 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 11.357 EXENTA, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-11-15", "doble_articulado": false, "id_norma": "179892", "numero_fuente": "36855", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-06", "vigencias": [{"desde": "2001-01-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-01-06", "fin_vigencia": "", "t