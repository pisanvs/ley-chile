{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6630463}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.104, de 29 de octubre de 2007, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2.567 de 2007, de esta Subsecretar&#xED;a, que declar&#xF3; la caducidad de las resoluciones que indica, en virtud de lo dispuesto en el art&#xED;culo 143 letra d) de la Ley General de Pesca y Acuicultura, s&#xF3;lo en lo relativo a las resoluciones N&#xBA; 2.957 de 2002, N&#xBA; 1.956 y N&#xBA; 1.957, ambas de 2003, N&#xBA; 2.669 y N&#xBA; 3.040, ambas de 2006, que autorizaron a SOCIEDAD PESQUERA MARLIMAR LIMITADA para realizar actividades extractivas con la nave &quot;Tiberiades&quot;.</div><br></div>", "i": 6630464}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de octubre de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 6630465}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3104 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3104 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-10-29", "doble_articulado": false, "id_norma": "266696", "numero_fuente": "38917", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-11-21", "vigencias": [{"desde": "2007-11-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-11-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig