{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6077138}, {"t": "<div><div class=\"p\">El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y: 365 d&#xED;as, fue de 5.46% anual durante el mes de mayo de 1991.</div><br><div class=\"p\">Asimismo, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de mayo de 1991, fue de 5,43% anual.</div><br></div>", "i": 6077139}, {"t": "<div><div class=\"p\">Santiago, 5 de junio de 1991.- V&#xED;ctor Vial del R&#xED;o, Secretario General.</div><br></div>", "i": 6077140}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-06-05", "doble_articulado": false, "id_norma": "87759", "numero_fuente": "33985", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-06-06", "vigencias": [{"desde": "1991-06-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-06-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-06-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMB", "fecha_ingreso": "1998-02-04", "fecha_ver