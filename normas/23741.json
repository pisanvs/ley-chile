{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Declara libre de derechos de internacion el monumento a Eleuterio Ram&#xED;rez</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,106.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5954995}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- La Aduana de Iquique despachar&#xE1; libre de derechos de internacion el monumento al Teniente-Coronel don Eleuterio Ram&#xED;rez que se erijir&#xE1; en la ciudad de Iquique.</div><br></div>", "i": 5954996}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 21 de Agosto de 1916.- JUAN LUIS SANFUENTES.- Luis Devoto A.</div><br></div>", "i": 5954997}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3106", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3106"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "Declara libre de derechos de internacion el;monumento a Eleuterio Ramírez", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ELEUTERIO RAMIREZ", "MONUMENTO", "DERECHOS INTERNACION", "LIBERACION", "IQUIQUE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-08-21", "doble_articulado": false, "id_norma": "23741", "numero_fuente": "11560", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-08-29", "vigencias": [{"desde": "1916-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"