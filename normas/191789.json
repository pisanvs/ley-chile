{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7287332}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;2.323, de 8 de noviembre de 2001 de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA;587 de 1995 de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESCA CISNE S.A., para realizar actividades pesqueras extractivas con la nave &apos;&apos;Cisne Blanco&apos;&apos;, en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 44&#xB0;30&apos; LS a 57&#xB0; LS, respecto de los recursos hidrobiol&#xF3;gicos Merluza de cola y Merluza de tres aletas, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura. </div></div>", "i": 7287333}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de noviembre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7287334}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2323", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2323"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-08", "doble_articulado": false, "id_norma": "191789", "numero_fuente": "37112", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-16", "vigencias": [{"desde": "2001-11-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-11-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-11-16", "fin_vigencia"