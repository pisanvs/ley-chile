{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 182 EXENTO, DE 2002 </div></div>", "i": 6393450}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 182, de fecha 11 de marzo de 2002, de Educaci&#xF3;n, se declara aprobada a la Universidad de Ciencias de la Inform&#xE1;tica la modificaci&#xF3;n al plan y a los programas de estudio de la carrera que se indica:</div><br><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  : Auditor&#xED;a</div><div class=\"p\">T&#xED;tulo Profesional: Contador Auditor</div><div class=\"p\">Grado Acad&#xE9;mico&nbsp;  : Licenciado en Contabilidad</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; y Auditor&#xED;a</div><br><div class=\"p\">&nbsp; &nbsp;  Dicha carrera se imparte en jornada diurna y vespertina en su sede de Santiago.</div><br><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase presente para todos los efectos legales y administrativos.</div><br></div>", "i": 6393451}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de abril de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6393452}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "182 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-182 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 182 EXENTO, DE 2002", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-03-11", "fecha_derogacion": "2020-01-01", "doble_articulado": false, "id_norma": "201740", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-08-20", "vigencias": [{"desde