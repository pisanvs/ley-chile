{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 317, DE 1986 </div></div>", "i": 6212693}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 317, de 11 de diciembre de 1986, se ha autorizado al Colegio Arabe de Santiago para aplicar en la asignatura de Idioma Extranjero 2, en 7&#xB0; y 8&#xB0; a&#xF1;o de Educaci&#xF3;n General B&#xE1;sica y desde lo a 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico Cientifica, los programas de estudio de lengua Arabe aprobados al Colegio Arabe de Vi&#xF1;a del Mar por decreto supremo de Educaci&#xF3;n No. 808, de 1978, y decretos supremos exentos de Educaci&#xF3;n N&#xB0;s. 54 y 261, ambos de 1981.</div><br></div>", "i": 6212694}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de Abril de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6212695}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "317 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-317 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 317, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-12-11", "doble_articulado": false, "id_norma": "149569", "numero_fuente": "32788", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-05", "vigencias": [{"desde": "1987-06-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-06-05", "fin_vigencia": "", "tipo_vers