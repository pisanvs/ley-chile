{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACI&#xD3;N</div><br></div>", "i": 7354603}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 822 de 10 de septiembre de 2007 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n total, conforme DL N&#xBA; 2.186 de 1978, del inmueble ubicado en Transversal 3, presunto rol de aval&#xFA;o N&#xBA; 2009-19, comuna de Maip&#xFA;, aparente dominio de Astorga Medel Andr&#xE9;s, correspondiente al lote N&#xBA; 1B, del Proyecto Vial &quot;Habilitaci&#xF3;n Corredor de Transporte P&#xFA;blico Av. Pedro Aguirre Cerda, Estaci&#xF3;n Central, Cerrillos, Maip&#xFA;&quot;. Comisi&#xF3;n integrada por peritos Ricardo Strickler Arellano, Arquitecto; Patricia Zavala Contreras, Constructor Civil; y Gast&#xF3;n Bravo Hurtado, Ingeniero Civil, seg&#xFA;n informe de 20 de noviembre de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $13.680.000.- pagadera al contado.</div><br></div>", "i": 7354604}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 7354605}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "822", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-822"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-09-10", "doble_articulado": false, "id_norma": "265095", "numero_fuente": "38875", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-10-01", "vigenc