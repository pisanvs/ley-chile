{"html": [{"t": "<div><div class=\"p\">CERTIFICA CALIDAD DE AGENTE RETENEDOR DEL IVA A JOSE CAMARENA Y CIA. LTDA.</div><br><br><br></div>", "i": 6038404}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 3.- Certifico que Jos&#xE9; Camarena y C&#xED;a. Ltda., Rut N&#xBA; 79.690.120-9, domiciliada en Avda. Vicu&#xF1;a Mackenna N&#xBA; 690, Melipilla, cumple los requisitos establecidos en la Resoluci&#xF3;n N&#xBA; Ex. 4.325, publicada en el D.O. de 17.09.96, y que, en consecuencia, tiene la calidad de Agente Retenedor del Impuesto al Valor Agregado por las adquisiciones de madera que efect&#xFA;e durante el per&#xED;odo comprendido entre la fecha de publicaci&#xF3;n de este Certificado en el Diario Oficial, por su cuenta y costo, y el 31 de octubre de 1997. </div></div>", "i": 6038405}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de febrero de 1997.- Jorge A. de Calisto Bravo, Director Regional.</div><br></div>", "i": 6038406}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "3", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-3"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO PONIENTE"], "titulo_norma": "CERTIFICA CALIDAD DE AGENTE RETENEDOR DEL IVA A JOSE\nCAMARENA Y CIA. LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "JOSE CAMARENA Y CIA. LTDA.", "MADERA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-02-07", "fecha_derogacion": "2001-03-24", "doble_articulado": false, "id_norma": "73269", "numero_fuente": "35781", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-06-04", "vigencias