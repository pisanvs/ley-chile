{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; CERTIFICADO</div><br></div>", "i": 6474801}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile en conformidad con lo dispuesto en el N&#xBA; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de abril de 2004, fue de 0,04% anual.</div><br></div>", "i": 6474802}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, abril 19 de 2004.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6474803}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-19", "doble_articulado": false, "id_norma": "224096", "numero_fuente": "37841", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-21", "vigencias": [{"desde": "2004-04-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-04-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-04-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2004-04-21", "fecha_version": "2004-04-21", "fecha_actualizacion_texto": "2004-04-21", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estru