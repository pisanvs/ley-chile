{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6237310}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 58, de 26 de Diciembre de 1965, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se autoriza a Jos&#xE9; Alejo Moreno Arros para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del territorio Nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6237311}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Rigoberto G&#xF3;mez Lav&#xED;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n.</div><br></div>", "i": 6237312}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "58", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-58"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-26", "doble_articulado": false, "id_norma": "156991", "numero_fuente": "32368", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-01-10", "vigencias": [{"desde": "1986-01-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-01-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-01-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes":