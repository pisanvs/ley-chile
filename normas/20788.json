{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 244 DE 1993</div><br><br></div>", "i": 7161307}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 244 de fecha 25 de mayo de 1993 del Ministerio de Educaci&#xF3;n, se sustituy&#xF3; el inciso 1&#xB0; del art&#xED;culo 1&#xB0; del Decreto Exento de Educaci&#xF3;n N&#xB0; 197 de 23.12.88 correspondiente al Instituto Profesional Escuela Moderna de M&#xFA;sica, por el siguiente nuevo:</div><div class=\"p\">&nbsp; &nbsp; &quot;Autor&#xED;zase el funcionamiento del Instituto Profesional que se indica, organizado por la persona jur&#xED;dica que se se&#xF1;ala:</div><div class=\"p\"> Nombre de la Instituci&#xF3;n: Instituto Profesional Escuela</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Moderna de M&#xFA;sica.</div><div class=\"p\"> Domicilio&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  : Santiago.</div><div class=\"p\"> Organizador&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  : Sociedad Instituto</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Profesional Escuela Moderna</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  de M&#xFA;sica Limitada.&quot;</div><br></div>", "i": 7161308}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n. + </div></div>", "i": 7161309}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "244 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-244 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 244 DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO PROFESIONAL ESCUELA MODERNA