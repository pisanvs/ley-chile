{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6412645}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 7, de 8 de enero de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a TOMAS HUGO QUEZADA BERNAL para ampliar las actividades pesqueras extractivas con la nave &quot;T&#xED;o Tom&#xE1;s&quot;, en orden a realizar actividades pesqueras con la nave individualizada precedentemente, con las artes de pesca y en el &#xE1;rea mar&#xED;tima que se indica, sobre los siguientes recursos hidrobiol&#xF3;gicos:</div><div class=\"p\">a) En el litoral de la I a III Regiones, por fuera del &#xE1;rea de reserva artesanal con espinel. Reineta; b) Litoral de la V Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal con espinel: Reineta y Raya.</div><br></div>", "i": 6412646}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de enero de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6412647}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-01-08", "fecha_derogacion": "2010-11-24", "doble_articulado": false, "id_norma": "207330", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-02-05", "vigencias": [{"desde": "2010-11-24", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-02-05", "hasta": "2010-11-23", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigenci