{"html": [{"t": "<div><div class=\"p\">LIBROS.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Diciembre 5 de 1832.</div></div>", "i": 10249870}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Deseando el Gobierno que el examen y revision de los libros que se introducen a las aduanas, se verifique con todo el acierto y circunspeccion debida a tan importante objeto, tiene a bien nombrar tres individuos que lo son, el Dr. don Mariano Ega&#xF1;a, don Andr&#xE9;s Bello y don Ventura Marin, para que asociados a los que, por disposiciones anteriores vijentes, tenia comisionados al Reverendo Obispo, gobernador de la Di&#xF3;cesis, o de nuevo elijiere, reconozcan y examinen todos los libros que vengan a las aduanas, antes de ser despachados y entregados a sus due&#xF1;os.</div></div>", "i": 10249871}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Comun&#xED;quese a quienes corresponda e impr&#xED;mase.</div><br><div class=\"p\">&nbsp; &nbsp;  PRIETO.</div><div class=\"p\">&nbsp; &nbsp;  Joaquin Tocornal.</div></div>", "i": 10249872}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "LIBROS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-12-05", "doble_articulado": false, "id_norma": "1161850", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-12-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-12-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-12-05"