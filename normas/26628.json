{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA NOMBRE A LA AVENIDA QUEBRADA VERDE UBICADA EN EL BARRIO PLAYA ANCHA, EN LA CIUDAD DE VALPARAISO.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8279430}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. La actual Avenida Quebrada Verde, ubicada en el barrio de Playa Ancha, de la ciudad de Valpara&#xED;so, se denominar&#xE1; en el futuro Avenida Federico Santa Mar&#xED;a&quot;.</div><br></div>", "i": 8279431}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintitr&#xE9;s de Septiembre de mil novecientos cincuenta y tres.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Osvaldo Koch.</div><br></div>", "i": 8279432}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11263", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11263"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA NOMBRE A LA AVENIDA QUEBRADA VERDE UBICADA EN\nEL BARRIO PLAYA ANCHA, EN LA CIUDAD DE VALPARAISO.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "AVENIDA FEDERICO SANTA MARIA", "PLAYA ANCHA", "VALPARAISO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1953-09-23", "doble_articulado": false, "id_norma": "26628", "numero_fuente": "22665", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1953-10-06", "vigencias": [{"desde": "1953-10-06", "hasta": "", "tipo_version":