{"html": [{"t": "<div><div class=\"p\">FIJA N&#xD3;MINAS DE AGENTES RETENEDORES Y CONTRIBUYENTES SUJETOS A RETENCI&#xD3;N</div></div>", "i": 10346101}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n Ex. del Servicio de Impuestos Internos, N&#xB0; 57 de 28 de junio de 2022, fija n&#xF3;minas de agentes retenedores y de contribuyentes sujetos a retenci&#xF3;n, conforme a <a href=\"https://www.leychile.cl/Navegar?idNorma=1118264&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n Ex. SII N&#xB0; 42, de 30 de abril de 2018</a>, que dispuso el cambio de sujeto total de derecho para el cumplimiento de IVA.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl).- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10346102}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Hern&#xE1;n Andr&#xE9;s Frigolett C&#xF3;rdova, Director.</div><br></div>", "i": 10346103}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "57 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-57 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "FIJA NÓMINAS DE AGENTES RETENEDORES Y CONTRIBUYENTES SUJETOS A RETENCIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2150084", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-06-28", "doble_articulado": false, "id_norma": "1178177", "numero_fuente": "43292", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-07-02", "vigencias": [{"desde": "2022-07-02", "hasta": "", "tip