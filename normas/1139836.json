{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 56</div></div>", "i": 10079159}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.727, de 5 de diciembre de 2019, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1136767&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 3.082, de 2019</a>, de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 56, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a integrar por estructura de cultivo para el centro de cultivo que indica en la resoluci&#xF3;n extractada.</div><div class=\"p\"> </div></div>", "i": 10079160}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de diciembre de 2019.- Jos&#xE9; Pedro N&#xFA;&#xF1;ez Barruel, Subsecretario de Pesca y Acuicultura (S).</div><br></div>", "i": 10079161}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3727 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3727 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 56", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1696877; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-12-05", "doble_articulado": false, "id_norma": "1139836", "numero_fuente": "42528", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-12-14", "vigencias": [{"desde": "2019-12-