{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,620.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6172551}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Decl&#xE1;rase de abono a don Tem&#xED;stocles Urrutia, Inspector Jeneral de Colonizacion e Inmigracion, para los efectos de su jubilacion, ocho a&#xF1;os nueve meses i trece dias que estuvo separado del servicio p&#xFA;blico con motivo de los sucesos del a&#xF1;o de 1891.</div><br></div>", "i": 6172552}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintisiete de enero de mil novecientos doce.- Ramon Barros Luco.- Renato S&#xE1;nchez.</div><br></div>", "i": 6172553}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2620", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2620"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-01-27", "doble_articulado": false, "id_norma": "137598", "numero_fuente": "10203", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-02-12", "vigencias": [{"desde": "1912-02-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-02-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-02-12", "fi