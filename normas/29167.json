{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; OTORGA EL NOMBRE DE &quot;BLAS CUEVAS-RAMON ALLENDE&quot; A LA ESCUELA QUE SE&#xD1;ALA</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7179269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Ot&#xF3;rgase a la Escuela N&#xB0; 157, de Valpara&#xED;so, el nombre de &quot;Blas Cuevas-Ram&#xF3;n Allende&quot;.&quot; </div></div>", "i": 7179270}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, primero de Marzo de mil novecientos setenta y dos.- SALVADOR ALLENDE GOSSENS.- Alejandro R&#xED;os Valdivia, Ministro de Educaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Carlos Valdeavellano Sol&#xED;s, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante.</div><br></div>", "i": 7179271}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "17631", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-17631"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "OTORGA EL NOMBRE DE BLAS CUEVAS-RAMON ALLENDE A LA ESCUELA QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ESCUELA BLAS-CUEVAS RAMON ALLENDE", "VALPARAISO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1972-03-01", "doble_articulado": false, "id_norma": "29167", "numero_fuente": "28194", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1