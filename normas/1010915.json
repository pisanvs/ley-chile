{"html": [{"t": "<div><br><div class=\"p\">MODIFICA CONCESI&#xD3;N DE ACUICULTURA</div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n 2.255, de 19 de noviembre de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div></div>", "i": 8870067}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case la r<a href=\"https://www.leychile.cl/Navegar?idNorma=211052&amp;idParte=0&amp;idVersion=\">esoluci&#xF3;n N&#xBA;1.126, de fecha 21 de abril de 2003</a>, ampliada por resoluci&#xF3;n N&#xBA;1.585, del 16 de septiembre de 2004, ambas del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina, en el siguiente sentido:</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;El concesionario deber&#xE1; dar cabal cumplimiento al Proyecto T&#xE9;cnico y Cronograma de Actividades, aprobado por resoluci&#xF3;n N&#xBA;1.016, de fecha 24 de mayo de 2002, modificada por la resoluci&#xF3;n exenta N&#xBA;3.652, ambas del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, Subsecretar&#xED;a de Pesca.&quot;</div></div>", "i": 8870068}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de enero de 2010.- Por la Sra. Subsecretaria, Gonzalo Campos Narducci, Subjefe Subsecretar&#xED;a de Marina Subrogante.</div></div>", "i": 8870069}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2255", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2255"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "MODIFICA CONCESIÓN DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-11-19", "doble_articulado": fal