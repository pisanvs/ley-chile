{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2 072.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6166511}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese un suplemento de cinco mil pesos ($ 5,000) al &#xED;tem 18 del presupuesto del Ministerio de Industria i Obras P&#xFA;blicas, con el objeto de atender al pago de las publicaciones del Ministerio i demas servicios de su dependencia.</div><br></div>", "i": 6166512}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintisiete de diciembre de mil novecientos siete.- Pedro Montt.- Joaquin Figueroa.</div><br></div>", "i": 6166513}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2072", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2072"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-12-27", "doble_articulado": false, "id_norma": "135770", "numero_fuente": "8986", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-12-28", "vigencias": [{"desde": "1907-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-12-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1907-12-28", "fin_vigencia": "", "tipo_version": "3"}], "evento