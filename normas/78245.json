{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8308594}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.553, de 14 de noviembre de</div><div class=\"p\">1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de</div><div class=\"p\">Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deniega la</div><div class=\"p\">solicitud de concesi&#xF3;n de acuicultura, solicitud N&#xBA;</div><div class=\"p\">95103010, presentada por NARCISO MANSILLA SOTO, para el</div><div class=\"p\">centro de cultivo ubicado en Punta Co&#xF1;ue, Isla Lin Lin,</div><div class=\"p\">Comuna de Quinchao, Provincia de Chilo&#xE9;, X Regi&#xF3;n,</div><div class=\"p\">conforme lo dispuesto en el art&#xED;culo 10, letra c) N&#xBA; 2 y</div><div class=\"p\">art&#xED;culo 14 del Decreto Supremo N&#xBA; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8308595}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de noviembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8308596}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1553", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1553"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "NARCISO MANSILLA SOTO", "QUINCHAO", "DECIMA REGION", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-11-14", "doble_articulado": false, "id_norma": "78245", "numero_fuente": "35924", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-1