{"html": [{"t": "<div><div class=\"p\">OT&#xD3;RGASE CALIDAD DE AGENTE RETENEDOR DE IVA</div></div>", "i": 10294205}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del SII, por resoluci&#xF3;n Ex. N&#xBA; 77321110783 de fecha 30 de noviembre de 2021, otorga al contribuyente Reciclajes Resan SpA, RUT 77.055.402-0, a partir del d&#xED;a 1&#xBA; del mes siguiente de esta publicaci&#xF3;n en Diario Oficial, la calidad de Agente Retenedor del Impuesto al Valor Agregado en ventas de Chatarra, conforme a lo establecido en la resoluci&#xF3;n Ex. N&#xBA; 86 de fecha 24.08.2016 de la Direcci&#xF3;n Nacional del Servicio de Impuestos Internos.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10294206}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Cristian Alberto G&#xF3;mez Castillo, Director Regional Concepci&#xF3;n.</div><div class=\"p\"> </div><br></div>", "i": 10294207}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "77321110783 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-77321110783 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL CONCEPCIÓN"], "titulo_norma": "OTÓRGASE CALIDAD DE AGENTE RETENEDOR DE IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2057675", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-11-30", "doble_articulado": false, "id_norma": "1170178", "numero_fuente": "43131", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-12-18", "vigencias": [{"desde": "2021-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2021-12-18