{"html": [{"t": "<div><div class=\"p\">SE DISPONE LA SEXAG&#xC9;SIMA SEXTA EMISI&#xD3;N DE OTORGAMIENTO DEL APORTE &#xDA;NICO DE CAR&#xC1;CTER REPARATORIO LEY N&#xB0; 20.874, A LAS PERSONAS QUE SE INDIVIDUALIZA Y POR LOS MONTOS QUE EN CADA CASO SE INDICAN</div></div>", "i": 10229072}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 138, de 13 de abril de 2021, el Director Nacional del Instituto de Previsi&#xF3;n Social, dispone el pago de la sexag&#xE9;sima sexta emisi&#xF3;n de otorgamiento del Aporte &#xDA;nico de car&#xE1;cter Reparatorio <a href=\"https://www.leychile.cl/Navegar?idNorma=1083194&amp;idParte=&amp;idVersion=\">Ley N&#xB0; 20.874</a>, a las personas que se individualizan y por los montos que en cada caso se indica.-&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10229073}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Patricio Coronado Rojo, Director Nacional.</div><div class=\"p\">&nbsp; &nbsp;  </div><br></div>", "i": 10229074}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "138 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-138 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARÍA DE PREVISIÓN SOCIAL", "INSTITUTO DE PREVISIÓN SOCIAL"], "titulo_norma": "SE DISPONE LA SEXAGÉSIMA SEXTA EMISIÓN DE OTORGAMIENTO DEL APORTE ÚNICO DE CARÁCTER REPARATORIO LEY N° 20.874, A LAS PERSONAS QUE SE INDIVIDUALIZA Y POR LOS MONTOS QUE EN CADA CASO SE INDICAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1947743", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-04-13", "doble_articulado":