{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8310069}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 120 de 14 de Febrero de 1992 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por 120 d&#xED;as a contar de la fecha de la presente resoluci&#xF3;n, el plazo otorgado a SOCIEDAD PESQUERA SAN ANTONIO S.A., RUT No. 87.992.600-9, domiciliada en Santiago, para empezar a operar la nave &quot;Panilonco&quot;, autorizada por la resoluci&#xF3;n No. 1.589, de 1990, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberes acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8310070}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 14 de Febrero de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8310071}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "120", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-120"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-02-14", "doble_articulado": false, "id_norma": "79603", "numero_fuente": "34205", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-02-28", "vigencias": [{"desde": "1992-02-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-02-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-02-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "m