{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ESTABLECE QUE EL GRUPO ESCOLAR DE CUREPTO SE DENOMINARA &quot;PEDRO AGUIRRE CERDA&quot;.</div><div class=\"p\">&nbsp; &nbsp; El Congreso Nacional ha tenido a bien prestar su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7175741}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. El Grupo Escolar, en que funcionan las escuelas primarias de Curepto, llevar&#xE1; el nombre de &quot;Pedro Aguirre Cerda&quot;.&quot; </div></div>", "i": 7175742}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecisiete de agosto de mil novecientos sesenta y dos.- JORGE ALESSANDRI RODRIGUEZ.- Patricio Barros.</div><br></div>", "i": 7175743}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14880", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14880"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "ESTABLECE QUE EL GRUPO ESCOLAR DE CUREPTO SE DENOMINARA PEDRO AGUIRRE CERDA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMBRE", "GRUPO ESCOLAR PEDRO AGUIRRE CERDA", "CUREPTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1962-08-17", "doble_articulado": false, "id_norma": "27954", "numero_fuente": "25330", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1962-08-29", "vigencias": [{"desde": "1962-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1962-08-29", "fin_vigencia": ""}, "vigencias_