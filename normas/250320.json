{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6572284}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.517, de 5 de junio de 2006, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 4.333 de 2005, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESCA CHILE S.A., para realizar actividades pesqueras extractivas con la nave en construcci&#xF3;n autorizada mediante la resoluci&#xF3;n antes citada, en el &#xE1;rea mar&#xED;tima correspondiente a la III Regi&#xF3;n, y entre el paralelo 41&#xB0;28,6&apos; L.S. y el l&#xED;mite sur de la X Regi&#xF3;n, sobre el recurso Besugo, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura, y lo informado mediante informe t&#xE9;cnico citado en Visto. </div></div>", "i": 6572285}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de junio de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6572286}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1517 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1517 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-05", "doble_articulado": false, "id_norma": "250320", "numero_fuente": "38485", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-06-09", "vigencias": [{"desde": "2006-06-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenc