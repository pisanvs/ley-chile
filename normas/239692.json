{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6531434}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 476 de fecha 31 de mayo del 2005, se expropiaron los lotes de terreno N&#xBA; s. 1, 2 y 3, superficies 575, 418 y 246 m2, rol N&#xBA; 403-4, comuna de Pitrufqu&#xE9;n, IX Regi&#xF3;n, para la obra &quot;Construcci&#xF3;n Puente Polul, Camino Cuarta Faja - Cruce S-65, tramo Km.</div><div class=\"p\">18,912 al Km. 19,164&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Violanda del Carmen Guti&#xE9;rrez Avello, ascendente a la cantidad de $2.893.088.- para los lotes N&#xBA; s. 1, 2 y 3.- </div></div>", "i": 6531435}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6531436}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "476 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-476 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-05-31", "doble_articulado": false, "id_norma": "239692", "numero_fuente": "38199", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-01", "vigencias": [{"desde": "2005-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2005-07-01", "fecha_version": "2005-07-