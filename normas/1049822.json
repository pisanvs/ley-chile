{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9341406}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 801, de 22 de marzo de 2013, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1035620&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.316 de 2011</a>, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA B&#xCD;O B&#xCD;O S.A., para ampliar actividades pesqueras extractivas con la nave en construcci&#xF3;n &quot;BEC 2564-07&quot;, respecto del recurso hidrobiol&#xF3;gico Jibia en el &#xE1;rea mar&#xED;tima comprendida entre la IV a IX Regiones, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum citado en Visto de la resoluci&#xF3;n extractada.</div><br></div>", "i": 9341407}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de marzo de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9341408}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "801 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-801 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-03-22", "doble_articulado": false, "id_norma": "1049822", "numero_fuente": "40523", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-04-02", "vigencias": [{"desde": "2013-04-02", "hasta": "", "tipo_version": "3", "tipo