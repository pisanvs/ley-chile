{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION No. 3.791, DE 1991</div><br><br></div>", "i": 7216195}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n exenta No. 3.791, de 20 de Agosto de 1991, de este Servicio Nacional, se reconoci&#xF3; como organismo t&#xE9;cnico intermedio a la &quot;Corporaci&#xF3;n Privada de Fomento y Desarrollo de la Peque&#xF1;a Industria, Servicios y Artesanado de Chile&quot;, domiciliada en Phillips No. 56 Of. 62, de la ciudad de Santiago, de acuerdo con lo dispuesto en el decreto con fuerza de Ley No. 1, de 1989, del Ministerio del Trabajo y Previsi&#xF3;n Social y su Reglamento contenido en el decreto supremo No. 146, de 1989, de la citada Secretar&#xED;a de Estado. </div></div>", "i": 7216196}, {"t": "<div><div class=\"p\">Santiago, 20 de Agosto de 1991.- Mario Cerda Allende, Director Nacional.</div><br></div>", "i": 7216197}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3791 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3791 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCION N° 3.791, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-08-20", "doble_articulado": false, "id_norma": "81289", "numero_fuente": "34067", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-09-13", "vigencias": [{"desde": "1991-09-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-09-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-09-13", "fin_vigenc