{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5961246}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1.o Trasp&#xE1;sase a 08/08/04/i/1 la suma de ciento veinte mil pesos ($ 120,000), que se deducir&#xE1; de 08/05/04/j).</div><br></div>", "i": 5961247}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 2.o Esta ley comenzar&#xE1; a regir desde su publicaci&#xF3;n en el Diario Oficial&quot; </div></div>", "i": 5961248}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecisiete de Diciembre de mil novecientos treinta y uno.- JUAN E. MONTERO.- Luis Guti&#xE9;rrez A. </div></div>", "i": 5961249}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "5014", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-5014"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O", "1931", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-12-17", "doble_articulado": false, "id_norma": "24997", "numero_fuente": "16151", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-12-17", "vigencias": [{"desde": "1931-12-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1931-12-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1931-12-17", "fin_vigencia": "", "tip