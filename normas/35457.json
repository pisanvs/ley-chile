{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293920}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 736, de 2 de Agosto de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por un a&#xF1;o, a contar del 25 de Junio de 1994, el plazo otorgado a PESQUERA COLOMBA S.A., R.U.T. N&#xB0; 96.530.830-K, en orden a iniciar actividades pesqueras extractivas con la Nave &quot;Colomba V&quot;, autorizada mediante Resoluci&#xF3;n N&#xB0; 494, de 1992, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor.</div><br></div>", "i": 8293921}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 2 de Agosto de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293922}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "736", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-736"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA COLOMBA S.A.", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-08-02", "fecha_derogacion": "1995-12-09", "doble_articulado": false, "id_norma": "35457", "numero_fuente": "34947", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-08-23", "vigencias": [{"desde": "1995-12-09", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1994-08-23", "hasta": "1995-12-08", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigenci