{"html": [{"t": "<div><div class=\"p\">EXTRACTO DECRETOS EXPROPIACI&#xD3;N JAIME REPULLO</div></div>", "i": 10302698}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante decreto alcaldicio N&#xBA; 2.377 de 30.11.2021, modificado por el decreto N&#xBA; 2.552 de 22.12.2021, ambos de la I. Municipalidad de Talcahuano, se dispone expropiaci&#xF3;n parcial, conforme al Art. 65 letra g) de la Ley N&#xBA; 18.695 Org&#xE1;nica Constitucional de Municipalidades, de los inmuebles Rol de Aval&#xFA;o N&#xBA; 1994-1 (Lote 1); N&#xBA; 1994-1 (Lote 2) y N&#xBA; 1993-13, todos de la comuna de Talcahuano, para dar cumplimiento al Plan Regulador Comunal de Talcahuano. El texto &#xED;ntegro de los decretos se encuentra publicado en la p&#xE1;gina web municipal https://www.portaltransparencia.cl/PortalPdT/directorio-de-organismos-regulados/?org=MU313.&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10302699}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Henry Leonardo Campos Coa, Alcalde.- Juan Guillermo Rivera Contreras, Secretario Municipal.</div><br></div>", "i": 10302700}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2377", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2377"}], "organismos": ["MUNICIPALIDAD DE TALCAHUANO"], "titulo_norma": "EXTRACTO DECRETOS EXPROPIACIÓN JAIME REPULLO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2066364", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-11-30", "doble_articulado": false, "id_norma": "1171397", "numero_fuente": "43153", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-01-15", "vigencias": [{"desde": "2022-01-15", "hasta": "", "tipo_ver