{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8298861}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 2.054, de 9 de diciembre de 1996, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;quese el numeral 3&#xB0; de la Resoluci&#xF3;n N&#xB0; 1.352, de 1996, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO, para efectuar una pesca de investigaci&#xF3;n de conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del proyecto &quot;Evaluaci&#xF3;n Indirecta del Stock de Centolla en la XII Regi&#xF3;n&quot;, en el sentido de se&#xF1;alar que la nave que efectuar&#xE1; las faenas de capturas ser&#xE1; la nave &quot;Paso Adventure&quot;.</div><br></div>", "i": 8298862}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 9 de diciembre de 1996.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8298863}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2054", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2054"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "AUTORIZACION", "INSTITUTO DE FOMENTO", "PESQUERO", "PESCA INVESTIGACION", "CENTOLLA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-12-09", "doble_articulado": false, "id_norma": "37664", "numero_fuente": "35646", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-12-20", "vigencias": [{"desde": "1996-12-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"in