{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6490624}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.910, de 14 de julio de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a SERVICIOS MARITIMOS OQUELDAN LIMITADA para iniciar actividades pesqueras de transformaci&#xF3;n en orden instalar y operar una planta en Camino Rural Quell&#xF3;n-Chaiguao, Oqueldan s/n, comuna de Quell&#xF3;n, provincia de Chilo&#xE9;, X Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Fresco-enfriado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6490625}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de julio de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6490626}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1910 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1910 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-07-14", "doble_articulado": false, "id_norma": "228567", "numero_fuente": "37927", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-08-04", "vigencias": [{"desde": "2004-08-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-08-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-08-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "