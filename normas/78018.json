{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 151, DE 1992 </div></div>", "i": 7213147}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 151 de 02 de junio de 1992 se ha aprobado, al Colegio Coyancura de Santiago, programa de estudio para la asignatura Idioma Extranjero 2, Italiano, para ser aplicado en 7&#xB0; y 8&#xB0; a&#xF1;o b&#xE1;sico, a partir del a&#xF1;o escolar 1993.</div><br></div>", "i": 7213148}, {"t": "<div><div class=\"p\">Santiago, 26 de Junio de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7213149}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "151 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-151 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 151, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-06-02", "doble_articulado": false, "id_norma": "78018", "numero_fuente": "34328", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-07-29", "vigencias": [{"desde": "1992-07-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-07-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-07-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "PGA", "fecha_ingreso": "1997-12-02", "fecha_version": "1992-07-29", "fecha_actualizacion_texto": "1992-07-29", "tipo_tratado": ""}, "alertas": [], "aler