{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xB0; 1.290 EXENTA, QUE MODIFICA RESOLUCION N&#xB0; 1.011 EXENTA, DE 2000</div><br><br></div>", "i": 6693847}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 1.290 exenta.- Modifica Res. Ex. N&#xB0; 1.011, del 8 de febrero de 2000, que determina colocar fecha en los documentos, con timbre de goma o impreso por computadora a contar del 01-01-2000.</div><br><div class=\"p\">&nbsp; &nbsp;  1&#xB0; Agr&#xE9;gase en el punto 2&#xB0; de la parte resolutiva de la Res. Ex. N&#xB0; 1.011 del 8 de febrero de 2000, despu&#xE9;s de la frase &apos;&apos;a indicar la fecha pertinente por medio de la aposici&#xF3;n de timbre de goma&apos;&apos;, el siguiente texto: &apos;&apos;o mediante cualquier otro medio manual o mec&#xE1;nico,&apos;&apos;.</div><div class=\"p\">&nbsp; &nbsp;  2&#xB0; La presente resoluci&#xF3;n regir&#xE1; a partir de su publicaci&#xF3;n en el Diario Oficial.-</div><br></div>", "i": 6693848}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Javier Etcheberry Celhay, Director.</div><br></div>", "i": 6693849}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1290 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1290 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION N° 1.290 EXENTA, QUE MODIFICA RESOLUCION N° 1.011 EXENTA, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["RESOLUCION SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "157882", "numero_fuente": "36598", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-02-25"