{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6222055}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 734 de 30 de Julio de 1987 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se autoriza a Retamal y Bustos Ltda., para efectuar todo tipo de servicio de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva.-</div><br></div>", "i": 6222056}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mariano Varas Hern&#xE1;ndez, Secretario Regional Mmisterial (S) de Transportes y Telecomunicaciones Regi&#xF3;n del Maule. </div></div>", "i": 6222057}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "734 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-734 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-30", "doble_articulado": false, "id_norma": "152082", "numero_fuente": "32846", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-14", "vigencias": [{"desde": "1987-08-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-08-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-08-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado