{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6435779}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;681 de fecha 30 de junio de 2003, se expropi&#xF3; el lote de terreno N&#xBA;14-C, superficie 625 m2, rol de aval&#xFA;o N&#xBA;1130-9, comuna de Pichilemu, para la obra &quot;Camino Pichilemu-C&#xE1;huil, Ruta I-500, Km. 0,980 a Km 12,76217&quot;, VI Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Miguel Ignacio Gonz&#xE1;lez Feli&#xFA; y Otros, ascendente a la cantidad de $4.215.094. </div></div>", "i": 6435780}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6435781}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "681", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-681"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-30", "doble_articulado": false, "id_norma": "213679", "numero_fuente": "37636", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-08-16", "vigencias": [{"desde": "2003-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2003-08-18", "fecha_version": "2003-08-16", "fecha_actualizacion_texto": "2003-08-16", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructu