{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6250390}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 249 de 21 de diciembre de 1999, Serviu V Regi&#xF3;n Valpara&#xED;so dispuso expropiaci&#xF3;n parcial, conforme art&#xED;culo 87 Ley 8.946 y decreto ley 2.186 de 1978, de inmueble ubicado en calle Gumercindo D&#xED;az N&#xBA; 296, Cerro Cordillera, Rol de Aval&#xFA;o 2340-1, comuna Valpara&#xED;so, de dominio de Miguel Antonio Mu&#xF1;oz Castillo. Comisi&#xF3;n tasadora integrada por Sres. Osvaldo Mu&#xF1;oz Quintana, arquitecto, Alvaro Verdejo Vidal, ingeniero constructor y Pablo Caria Giurici, constructor civil, seg&#xFA;n informe de fecha 0 de diciembre 1999, fijo monto provisional indemnizaci&#xF3;n en $1.602.500.- que ser&#xE1; pagada al contado.-</div><br></div>", "i": 6250391}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alberto Ram&#xED;rez Urz&#xFA;a, Director Serviu V Regi&#xF3;n. </div></div>", "i": 6250392}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "249", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-249"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "V REGIÓN DE VALPARAÍSO"], "titulo_norma": "DISPONE EXPROPIACIONES PARCIALES DE INMUEBLES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MIGUEL ANTONIO MUÑOZ CASTILLO", "EXPROPIACION PARCIAL", "INMUEBLE", "INDEMNIZACION", "VALPARAISO", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-21", "doble_articulado": false, "id_norma": "160916", "numero_fuente": "36614", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-15", "vigencias": [{"desde": "2000