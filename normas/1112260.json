{"html": [{"t": "<div><div class=\"p\">CREA MODELO DE CERTIFICADO N&#xB0; 59, SOBRE DONACIONES QUE INDICA</div></div>", "i": 9864504}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta SII N&#xBA; 117, del 6 de diciembre de 2017, que establece:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Crea Modelo de Certificado N&#xBA; 59, sobre donaciones efectuadas a la Conferencia Episcopal de Chile con motivo de la visita del Papa, conforme al <a href=\"https://www.leychile.cl/Navegar?idNorma=1111159&amp;idParte=9852095&amp;idVersion=\">art&#xED;culo 3</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1111159&amp;idParte=0&amp;idVersion=\">ley N&#xBA; 21.047</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII de diciembre de 2017.</div></div>", "i": 9864505}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "117 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-117 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CREA MODELO DE CERTIFICADO N° 59, SOBRE DONACIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1316313", "EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-12-06", "doble_articulado": false, "id_norma": "1112260", "numero_fuente": "41930", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-12-12", "vigencias": [{"desde": "2017-12-12", "hasta": "", "t