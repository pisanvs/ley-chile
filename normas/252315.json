{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6579596}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 287 de 27 de enero de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a JUAN SCHNEIDER E HIJOS LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n en orden a instalar y operar una planta ubicada en la Carretera Panamericana Sur kil&#xF3;metro 14, sector San Antonio, Ancud, X Regi&#xF3;n, donde podr&#xE1; elaborar, en las l&#xED;neas de proceso de Cocido y Fresco-enfriado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2.142 de 2003, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6579597}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de enero de 2006.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6579598}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "287 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-287 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-27", "doble_articulado": false, "id_norma": "252315", "numero_fuente": "38541", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-08-17", "vigencias": [{"desde": "2006-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-08-17", "fin_vigencia": ""}, "vi