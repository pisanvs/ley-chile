{"html": [{"t": "<div><div class=\"p\">&#xFEFF;PROVISION DE EMPLEOS ECLESIASTICOS.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso nacional con fecha 21 de este mes ha decretado lo siguiente:</div></div>", "i": 10237501}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Poder Ejecutivo no proveer&#xE1; las Canonj&#xED;as, dignidades y raciones actualmente vacantes; pero podr&#xE1; hacerlo de las que en lo sucesivo vacaren a propuesta de los respectivos Cabildos Eclesi&#xE1;sticos, cuya nominacion ser&#xE1; precisamente en personas de conocido patriotismo.</div><div class=\"p\">&nbsp; &nbsp;  Por tanto ordeno que se publique por lei insert&#xE1;ndose en el Boletin.</div></div>", "i": 10237502}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Dado en la Sala de Gobierno en Santiago de Chile a 22 de Febrero de 827.</div><div class=\"p\">&nbsp; &nbsp;  FREIRE.&nbsp; &nbsp;  Gandarillas.</div></div>", "i": 10237503}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}, {"tipo": "1", "numero": "S/N", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "Ley-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "﻿PROVISION DE EMPLEOS ECLESIASTICOS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1827-02-22", "doble_articulado": false, "id_norma": "1152900", "numero_fuente": "1827", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1827-02-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1827-02-22", "fin_vigencia": ""}, "vigencias_version_norma"