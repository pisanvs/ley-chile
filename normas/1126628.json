{"html": [{"t": "<div><div class=\"p\">Declaracion a favor de don Jos&#xE9; Antonio Mart&#xED;nez</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 7 de 1819.</div></div>", "i": 9986201}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Con las actuaciones presentadas, ha comprobado legalmente don Jos&#xE9; Antonio Mart&#xED;nez ser uno de los mas decididos patriotas, i merecer como tal el aprecio de todo buen ciudadano. Su confinacion fu&#xE9; un efecto sin duda de las apuradas circunstancias en que se decret&#xF3; la de varios disidentes, con quienes equivocadamente fu&#xE9; confundido. Ins&#xE9;rtese en la Gaceta Ministerial esta representacion i su proveido para satisfaccion del interesado.- </div></div>", "i": 9986202}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  O&apos;Higgins.- Echeverr&#xED;a.</div></div>", "i": 9986203}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Declaracion a favor de don José Antonio Martínez", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1819-07-07", "doble_articulado": false, "id_norma": "1126628", "numero_fuente": "1819", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1819-07-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1819-07-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1819-07-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2019-01-08", "fech