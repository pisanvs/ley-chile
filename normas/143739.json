{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 5.885 EXENTA, DE 1999 </div><br></div>", "i": 6192185}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 5.885, de 5 de julio de 1999, se ha aprobado al Colegio Huel&#xE9;n de Vitacura de Santiago, un plan de estudio para primero y segundo a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 1999.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para primero y segundo a&#xF1;o de ense&#xF1;anza media de los subsectores que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 6192186}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de julio de 1999.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6192187}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5885 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5885 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 5.885 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-07-05", "doble_articulado": false, "id_norma": "143739", "numero_fuente": "36469", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-21", "vigencias": [{"desde": "1999-09-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-09-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincula