{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 13.523</div><br><div class=\"p\">MODIFICA LA LEY N.o 12.545</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6319115}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico. reempl&#xE1;zase en el inciso primero de la ley N.o 12.545, la frase &quot;7 a&#xF1;os, 3 meses y 26 d&#xED;as&quot; por la siguiente &quot;9 a&#xF1;os y 10 meses&quot;.&quot; </div></div>", "i": 6319116}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintinueve de Septiembre de mil novecientos cincuenta y nueve. JORGE ALESSANDRI RODRIGUEZ.- Roberto Vergara H.</div><br></div>", "i": 6319117}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13523", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13523"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA LA LEY N.o 12.545", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1959-09-29", "doble_articulado": false, "id_norma": "180953", "numero_fuente": "24466", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1959-10-14", "vigencias": [{"desde": "1959-10-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1959-10-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1959-10-14", "fin_vigencia": "", "tipo_vers