{"html": [{"t": "<div><br><div class=\"p\">CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A FORESTAL TRES EME S.A.</div><br></div>", "i": 9254467}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VII Direcci&#xF3;n Regional Talca del SII, por resoluci&#xF3;n DRE07/ Ex. N&#xBA; 4.236, de fecha 10 de agosto de 2009, concede a la contribuyente Forestal Tres Eme S.A., RUT N&#xBA; 76.026.945-K, a contar del d&#xED;a primero del mes siguiente de la fecha de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de Sujeto en las ventas de madera, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 16&#xB0; de la resoluci&#xF3;n Ex. N&#xBA; 4.916/2000, de la Direcci&#xF3;n Nacional.</div></div>", "i": 9254468}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Talca, 10 de agosto de 2009.- Luis Aguirre P&#xE9;rez, Director Regional.</div></div>", "i": 9254469}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4236 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4236 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VII DIRECCIÓN REGIONAL TALCA"], "titulo_norma": "CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A FORESTAL TRES EME S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-08-10", "doble_articulado": false, "id_norma": "1039663", "numero_fuente": "40253", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-05-04", "vigencias": [{"desde": "2012-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-06-01", "fin_vigencia": ""}, "vigenci