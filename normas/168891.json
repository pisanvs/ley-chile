{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6275974}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 142, de 14.02.85, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a don Luis Donoso D&#xED;az, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos, urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6275975}, {"t": "<div><div class=\"p\">Santiago, 18.02.85. Carlos Osb&#xE9;n Mu&#xF1;oz, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana, subrogante. </div></div>", "i": 6275976}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "142 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-142 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-02-14", "doble_articulado": false, "id_norma": "168891", "numero_fuente": "32107", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-02-26", "vigencias": [{"desde": "1985-02-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-02-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-02-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CAL", "fecha_ingreso": "2000-05-18", "f