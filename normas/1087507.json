{"html": [{"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 702 EXENTA, DE 29.12.2015, SOBRE LA 2&#xBA; EMISI&#xD3;N DE OTORGAMIENTO DEL APORTE &#xDA;NICO DE CAR&#xC1;CTER REPARATORIO LEY N&#xBA; 20.874</div></div>", "i": 9675564}, {"t": "<div><br><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4, de 12 enero de 2016, se modifica el Considerando N&#xBA; 3, de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1086340&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 702, de 29 de diciembre de 2015</a>, sobre la 2a Emisi&#xF3;n del Otorgamiento del Aporte &#xDA;nico Reparatorio del art&#xED;culo 1&#xBA; de la ley N&#xBA; 20.874, en el sentido de rectificar sumatoria de beneficiarios &quot;Titulares&quot; y de &quot;Viudas&quot;, que debe decir &quot;3.566 pagos&quot;.</div></div>", "i": 9675565, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de febrero de 2016.- Patricio Coronado Rojo, Director Nacional.</div></div>", "i": 9675566}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "INSTITUTO DE PREVISIÓN SOCIAL"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 702 EXENTA, DE 29.12.2015, SOBRE LA 2º EMISIÓN DE OTORGAMIENTO DEL APORTE ÚNICO DE CARÁCTER REPARATORIO LEY Nº 20.874", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; IdDO 996951"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-01-12", "doble_articulado": false, "id_norma": "1087507", "numero