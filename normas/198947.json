{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6384193}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA; 631 de fecha 30 de abril del 2002, se expropi&#xF3; el lote de terreno N&#xBA; 32-A, superficie 960.00 m2, Rol N&#xBA; 225-8, comuna de Olmu&#xE9;, para la obra &apos;&apos;Ruta F-10-G, Cuesta La Dormida, Etapa 2, Km. 10,984 a Km.</div><div class=\"p\">34,5000, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Ana Luisa Morelli Alvarez y Otros, ascendente a la cantidad de $1.775.392.</div><br></div>", "i": 6384194}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6384195}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "631 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-631 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-30", "doble_articulado": false, "id_norma": "198947", "numero_fuente": "37272", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-01", "vigencias": [{"desde": "2002-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MAS", "fecha_ingreso": "2002-06-06", "fecha_version": "2002-06-01", "fecha_actualizacion_texto": "2002-06-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "",