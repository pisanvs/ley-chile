{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291535}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 276, de 9 de febrero de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la letra f) del numeral 1&#xB0; de la Resoluci&#xF3;n N&#xB0; 612, de 1995, de esta Subsecretar&#xED;a, que caduc&#xF3; la autorizaci&#xF3;n de PESQUERA Y CULTIVO DE RECURSOS MARINOS LIMITADA, para operar un centro de cultivo ubicado en Caleta Prado, Puerto de Mejillones, Provincia de Antofagasta, II Regi&#xF3;n, en virtud de los informes t&#xE9;cnicos y normas legales y reglamentarias pertinentes.</div><div class=\"p\">&nbsp; &nbsp; Decl&#xE1;rase en consecuencia plenamente vigente la Resoluci&#xF3;n N&#xB0; 426, de 1989, de esta Subsecretar&#xED;a. </div></div>", "i": 8291536, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 9 de febrero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8291537}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "276", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-276"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "PESQUERA Y CULTIVO DE RECURSOS", "MARINOS LIMITADA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-02-09", "doble_articulado": false, "id_norma": "34119", "numero_fuente": "35396", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-02-19", "vigencias": [{"desde": "1996-02-19", "hasta": "", "tipo_