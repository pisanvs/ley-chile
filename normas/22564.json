{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pago por la provision de equipo Lei n&#xFA;m. 1,330.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7163009}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se autoriza al Presidente de la Rep&#xFA;blica para que invierta la suma de trescientos treinta i cinco mil pesos en atender al pago del equipo contratado en virtud de la lei n&#xFA;m. 998, de 17 de Enero de 1898.</div><br></div>", "i": 7163010}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 11 de Enero de 1900.- Federico Errazuriz.- Jos&#xE9; F. Valdes C.</div><br></div>", "i": 7163011}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1330", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1330"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "PAGO POR LA PROVISION DE EQUIPO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTE REPUBLICA", "FONDOS", "INVERSION", "AUTORIZACION", "FERROCARRIL", "TROCHA METRO", "CONSTRUCCION", "EQUIPO", "PROVISION", "PAGO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-01-11", "doble_articulado": false, "id_norma": "22564", "numero_fuente": "6494", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-01-12", "vigencias": [{"desde": "1900-01-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vi