{"html": [{"t": "<div><div class=\"p\">EXTRACTO MODIFICACION DE DECRETO ALCALDICIO</div><br><div class=\"p\">&nbsp; &nbsp;  Rancagua, Julio 13 de 1987.- Con esta fecha la Alcald&#xED;a decret&#xF3; lo siguiente:</div><br></div>", "i": 6200090}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 603 exento.- Reaj&#xFA;stase en un 10.3% los derechos municipales por concesiones permisos y servicios contemplados en la Ordenanza Local de Rancagua contenida en el Decreto Exento No. 890, de 17 de Diciembre de 1985, modificada por los Decretos Exentos n&#xFA;meros 60, 949 y 180 del 22 de Enero y 29 de Diciembre de 1986 y 12 de Marzo de 1987, que se encuentran expresados en pesos, moneda nacional.</div><div class=\"p\">&nbsp; &nbsp;  El presente Decreto rige a contar desde el 1&#xBA; de Julio de 1987.</div><br></div>", "i": 6200091}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese, publ&#xED;quese y arch&#xED;vese.- Ricardo Sandoval Hern&#xE1;ndez, Secretario Municipal.</div><br></div>", "i": 6200092}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "603 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-603 EXENTO"}], "organismos": ["MUNICIPALIDAD DE RANCAGUA"], "titulo_norma": "EXTRACTO MODIFICACION DE DECRETO ALCALDICIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-13", "doble_articulado": false, "id_norma": "146199", "numero_fuente": "32826", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-22", "vigencias": [{"desde": "1987-07-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-22", "fin