{"html": [{"t": "<div><br><div class=\"p\">ASUME VICEPRESIDENCIA DE LA REP&#xDA;BLICA</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 205.- Santiago, 30 de marzo de 2009.- Visto: Este antecedente, el decreto N&#xBA; 204, del 30 de marzo, del Ministerio del Interior; lo dispuesto en los art&#xED;culos 29&#xBA; y 32&#xBA;, N&#xBA; 6, de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile, y teniendo presente que S.E. la Presidenta de la Rep&#xFA;blica se ausent&#xF3; con esta fecha del territorio nacional,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div></div>", "i": 8567001}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Con esta fecha asumo el Mando Supremo de la Naci&#xF3;n con el t&#xED;tulo de Vicepresidente de la Rep&#xFA;blica.</div></div>", "i": 8567002}, {"t": "<div><br><div class=\"p\">T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- ANDR&#xC9;S VELASCO BRA&#xD1;ES, Vicepresidente de la Rep&#xFA;blica.- Patricio Rosende Lynch, Ministro del Interior Subrogante.</div><br><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda atte. a Ud., Jorge Claissac Schnake, Subsecretario del Interior Subrogante.</div></div>", "i": 8567003}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "205", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-205"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARÍA DEL INTERIOR"], "titulo_norma": "ASUME VICEPRESIDENCIA DE LA REPÚBLICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-03-30", "doble_articulado": false, "id_norma": "1001525", "numero_fuente": "39347", "tipo_version": "3", "tipo_versio