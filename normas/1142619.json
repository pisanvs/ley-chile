{"html": [{"t": "<div><div class=\"p\">Tratamiento del vicario jeneral castrense</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Junio 7 de 1822.</div></div>", "i": 10105844}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mientras se acuerda i publica el ceremonial i cortes&#xED;as que deban rejir en el Estado, tendr&#xE1; el vicario jeneral castrense el tratamiento de se&#xF1;or&#xED;a de palabra i por escrito, i en las funciones p&#xFA;blicas se sentar&#xE1; con los mariscales de campo.</div></div>", "i": 10105845}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Comun&#xED;quese a quienes corresponda su cumplimiento e impr&#xED;mase. - O&apos;Higgins.- Doctor Rodr&#xED;guez.</div></div>", "i": 10105846}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Tratamiento del vicario jeneral castrense", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1822-06-07", "doble_articulado": false, "id_norma": "1142619", "numero_fuente": "1822", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1822-06-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1822-06-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1822-06-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2020-03-06", "fecha_version": "1822-06-07", "fecha_actualizacion_texto": "2020-03-06", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura