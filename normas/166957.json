{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6269685}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 815 de 01 de Octubre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Xa. Regi&#xF3;n, se autoriza a Robinson Barr&#xED;a Castro para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 1 &quot;Francke - Centro - Rahue Alto&quot; de Osorno, cuyo trazado fue autorizado por resoluci&#xF3;n No. 90 de 12 de junio de 1984 y modificado por resoluci&#xF3;n No. 464 de 16 de septiembre de 1986, de esta Secretar&#xED;a Regional. </div></div>", "i": 6269686}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial Transportes y Telecomunicaciones Xa. Regi&#xF3;n. </div></div>", "i": 6269687}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "815 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-815 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL V REGIÓN DE VALPARAÍSO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-10-01", "doble_articulado": false, "id_norma": "166957", "numero_fuente": "32893", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-10-14", "vigencias": [{"desde": "1987-10-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-10-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-10-14", "fin_vigenc