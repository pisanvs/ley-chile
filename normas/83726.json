{"html": [{"t": "<div><br><div class=\"p\">CONCEDE PLAZO QUE INDICA</div><br><br></div>", "i": 8315479}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 678 de 24 de Mayo de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se concede un plazo de 30 d&#xED;as a contar de la fecha de esta resoluci&#xF3;n, a la Asociaci&#xF3;n Gremial de Pescadores Artesanales &quot;Olas del Sur&quot;, R.U.T. No.</div><div class=\"p\">71.620.500-2, domiciliada en localidad de Alao, Comuna de Quinchao, Provincia de Chilo&#xE9;, X Regi&#xF3;n, para publicar el extracto de la resoluci&#xF3;n No. 87, de 1990, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8315480}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 24 de Mayo de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8315481}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "678", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-678"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "CONCEDE PLAZO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-05-24", "doble_articulado": false, "id_norma": "83726", "numero_fuente": "33700", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-06-21", "vigencias": [{"desde": "1990-06-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-06-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-06-21", "fin