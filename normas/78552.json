{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8308962}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 541, de 05 de Junio de 1992, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por un a&#xF1;o a contar del 06 de enero de 1992, el plazo otorgado a PESQUERA YELCHO S.A., R.U.T. No. 96.531.750-3, domiciliada en calle Salvador Donoso No. 1487, Valpara&#xED;so, para operar la nave &quot;Lleuque&quot;, autorizada por la resoluci&#xF3;n No. 822, de 1988 y No. 2066, de 1989, ambas de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor. </div></div>", "i": 8308963}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 05 de Junio de 1992.- Jorge Marshall Rivera, Subsecretario de Pesca Subrogante.</div><br></div>", "i": 8308964}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "541", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-541"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-06-05", "doble_articulado": false, "id_norma": "78552", "numero_fuente": "34295", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-06-19", "vigencias": [{"desde": "1992-06-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-06-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-06-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "ur