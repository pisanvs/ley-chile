{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6355621}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA; 1.471, de 28 de septiembre del 2001, se expropiaron los lotes de terreno N&#xBA;s 5, 7 y 8, superficies 275, 661 y 634 m2., rol de aval&#xFA;o en tr&#xE1;mite, comuna del Tabo, para la obra Red Litoral Central Sector 3: Eje Costero Interior Subtramo Quillaicillo Rosario, Quinta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Inmobiliaria Nauantu Ltda., ascendente a las cantidades de $498.753.-, para el lote N&#xBA; 5, $1.368.975.- para el lote N&#xBA; 7 y $1.255.611.- para el lote N&#xBA; 8. </div></div>", "i": 6355622}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6355623}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1471 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1471 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-09-28", "doble_articulado": false, "id_norma": "191237", "numero_fuente": "37100", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-02", "vigencias": [{"desde": "2001-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2001-11-02", "fecha_versio