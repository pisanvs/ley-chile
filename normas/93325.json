{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACION QUE INDICA </div></div>", "i": 8930009}, {"t": "<div><div class=\"p\">Por decreto No. 373 de 1989, la Municipalidad de Macul orden&#xF3; expropiaci&#xF3;n de parte inmueble ubicado en Exequiel Fern&#xE1;ndez No. 2730, conforme al DFL No. 458, DL No. 2.816 y Ley No. 18.695, objeto ensanche calle Exequiel Fern&#xE1;ndez. Dominio aparente Cecilia V&#xE1;squez Schafer, inscrito fojas 53765, No. 42603 Registro de Propiedad de 1988, Conservador Bienes Ra&#xED;ces Santiago. Indemnizaci&#xF3;n $ 37.934, se pagar&#xE1; con compensaci&#xF3;n derecho construcci&#xF3;n mismo inmueble.- </div></div>", "i": 8930010}, {"t": "<div><div class=\"p\">Ram&#xF3;n Sotomayor Madsen, Alcalde.</div><br></div>", "i": 8930011}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "373", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-373"}], "organismos": ["MUNICIPALIDAD DE MACUL"], "titulo_norma": "ORDENA EXPROPIACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["ESTE EXTRACTO, NO TIENE FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "93325", "numero_fuente": "33449", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-08-16", "vigencias": [{"desde": "1989-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1998-03-03", "fecha_version": "1989-08-16", "fecha_actualizacion_texto": "1989-08-16", "