{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8813514}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta 3.789, de 13 de noviembre de 2009, de esta Subsecretar&#xED;a, modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1008019&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.571 de 2009</a>, de esta Subsecretar&#xED;a, que autoriz&#xF3; al Instituto de Investigaci&#xF3;n Pesquera para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto FIP N&#xBA; 2008-10 denominado &quot;Distribuci&#xF3;n de pre-reclutas de Jurel en aguas oce&#xE1;nicas frente a la costa de Chile&quot;, en el sentido de reemplazar, en sus numerales 4.- y 5.-, a la nave industrial &quot;Pehuenco&quot;, del armador Pesquera B&#xED;o B&#xED;o S.A., por la nave industrial &quot;Ventisquero&quot;, del armador Pesquera San Jos&#xE9; S.A.</div></div>", "i": 8813515}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de noviembre de 2009.- Mar&#xED;a &#xC1;ngela Barbieri Bellolio, Subsecretaria de Pesca (S).</div></div>", "i": 8813516}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3789 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3789 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-11-13", "doble_articulado": false, "id_norma": "1008908", "numero_fuente": "39533", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-12-1