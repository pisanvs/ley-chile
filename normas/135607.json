{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,967.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 8344250}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al ex guarda hilos del Tel&#xE9;grafo del Estado, don Ram&#xF3;n Covarrubias una pensi&#xF3;n vitalicia de veinte pesos ($ 20) mensuales.</div><br></div>", "i": 8344251}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, dieciocho de julio de mil novecientos siete.- Pedro Montt.- Luis A. Vergara.</div><br></div>", "i": 8344252}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1967", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1967"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-07-18", "doble_articulado": false, "id_norma": "135607", "numero_fuente": "8852", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-07-18", "vigencias": [{"desde": "1907-07-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-07-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1907-07-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-04-28", "fecha_v