{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6196381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.031, de 30 de julio de 1999, se expropiaron los lotes de terreno N&#xBA;s. 2-A, 2-B, 3-B, 3-C, 5, 14, 15 y 15-A, superficies 223, 90, 371, 195, 661, 1.657, 266 y 550 m&#xB2;, respectivamente, roles de aval&#xFA;o 184-260, 184-14, 184-244, 184-220, 187-30, 187-8 y 184-174, comuna de San Vicente, para la obra Mejoramiento Ruta H-830, sector San Vicente - El Cardal - Millahue y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Celso Augusto Riveros, Mar&#xED;a Silva Lorca y otros, Hern&#xE1;n Lorca Lorca, Luis Pavez Zamorano, Ram&#xF3;n Pastene Urra y Mar&#xED;a Quintanilla Barrientos, ascendente a las cantidades de $1.166.368; $954.024;</div><div class=\"p\">$498.856; $701.040; $22.302.216 y $719.328.-</div><br></div>", "i": 6196382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6196383}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2031", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2031"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-07-30", "doble_articulado": false, "id_norma": "145086", "numero_fuente": "36478", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-10-01", "vigencias": [{"desde": "1999-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig