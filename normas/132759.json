{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6157071}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Secc. 2a. No. 611, de 03.06.88, Alcalde de I. Municipalidad de Stgo. dispone expropiaci&#xF3;n total conforme DS 458 Vivienda y Urbanismo. Decreto Ley 2.186 y Ley 18.695 inmueble Loreto 376 Rol No. 474-52 Stgo. aparentemente dominio Domingo Dur&#xE1;n Morales. Deslindes Norte, 21,70 mts. l&#xED;nea quebrada otro propietario; Sur, 16,70 mts. otro propietario; Oriente 9,90 mts. calle Loreto; Poniente, 13 mts. otro propietario.</div><div class=\"p\">Indemnizaci&#xF3;n provisional $ 6.422.550 pagadera contado. </div></div>", "i": 6157072}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gustavo Alessandri V., Alcalde de Santiago. </div></div>", "i": 6157073}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "611", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-611"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-06-03", "doble_articulado": false, "id_norma": "132759", "numero_fuente": "33096", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-06-15", "vigencias": [{"desde": "1988-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-03-01", "fecha_version": "1988-06-15", "fecha_actualizacion_texto": "1988-06-15", "tipo_t