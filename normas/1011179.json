{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8885583}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 707, de 5 de febrero de 2010, de esta Subsecretar&#xED;a, autor&#xED;zase a &#xD3;SCAR JOVINO ALTAMIRANO SANTANA para iniciar actividades pesqueras de transformaci&#xF3;n, instalar y operar planta en sector Tehuaco Bajo s/n&#xBA; Rural, Ancud, Chilo&#xE9;, X Regi&#xF3;n, para elaborar en las l&#xED;neas de Cocido, Fresco-enfriado, Fresco-refrigerado, Congelado, Conserva y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div></div>", "i": 8885584}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 5 de febrero de 2010.- Germ&#xE1;n Loyola Bast&#xED;as, Subsecretario de Pesca (S).</div></div>", "i": 8885585}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "707 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-707 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-02-05", "doble_articulado": false, "id_norma": "1011179", "numero_fuente": "39591", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-02-19", "vigencias": [{"desde": "2010-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-02-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-02-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingr