{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9047916}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 885 de 5 de Agosto de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por un a&#xF1;o a contar de la fecha de la presente resoluci&#xF3;n, el plazo otorgado a SALMONES PUNTRA S.A., R.U.T N&#xBA; 96.524.770-K, domiciliada en la ciudad de Castro, para empezar a operar la embarcaci&#xF3;n en construcci&#xF3;n autorizada por resoluci&#xF3;n N&#xBA; 463, de 1990, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 9047917}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de Agosto de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 9047918}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "885", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-885"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "SALMONES PUNTRA S.A.", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-08-05", "doble_articulado": false, "id_norma": "70285", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-08-29", "vigencias": [{"desde": "1991-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-08-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-08-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac