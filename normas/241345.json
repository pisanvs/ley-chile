{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6537828}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.626, de 18 de agosto de 2005, de esta Subsecretar&#xED;a de Pesca, modif&#xED;case el numeral 3&#xBA; de la resoluci&#xF3;n N&#xBA; 1.664, modificada por resoluci&#xF3;n N&#xBA; 2.005, ambas de 2005, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO, para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto denominado &quot;Investigaci&#xF3;n Evaluaci&#xF3;n directa de Jurel V y X Regiones, 2005&quot;, en el sentido de extender el per&#xED;odo de operaci&#xF3;n de las naves industriales &quot;Libas&quot; y &quot;L&#xED;der&quot; hasta el d&#xED;a 30 de septiembre de 2005, inclusive.</div><br></div>", "i": 6537829}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 18 de agosto de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6537830}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2626 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2626 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-08-18", "doble_articulado": false, "id_norma": "241345", "numero_fuente": "38246", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-08-26", "vigencias": [{"desde": "2005-08-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-