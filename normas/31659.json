{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTOS DE RESOLUCIONES </div></div>", "i": 8288982}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 762, de 27 de Junio de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de conformidad con el art&#xED;culo 7 del D.S. N&#xB0; 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, de la Resoluci&#xF3;n N&#xB0; 247, de 1987, de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a do&#xF1;a EVELIN ERNA KLEIN WELLMAN, R.U.T. N&#xB0; 9.020.539-0, domiciliada en calle Almeida N&#xB0; 246, Maull&#xED;n, para operar un establecimiento de cultivo de algas Gracilarias, en Lepihu&#xE9; R&#xED;o Maull&#xED;n, Comuna de Maull&#xED;n, Llanquihue, X Regi&#xF3;n.</div><br></div>", "i": 8288983}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 27 de Junio de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8288984}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "762", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-762"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "EXTRACTOS DE RESOLUCIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EVELYN ERNA KLEIN WELLMAN", "PESCA", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-06-27", "doble_articulado": false, "id_norma": "31659", "numero_fuente": "34012", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-07-09", "vigencias": [{"desde": "1991-07-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"