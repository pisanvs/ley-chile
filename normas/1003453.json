{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8684224}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.975, de 3 de junio de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a FUNDACI&#xD3;N CHILE para realizar actividades de proceso y producto sobre la especie Corvina. El objetivo general consiste en iniciar pruebas de proceso, en diferentes l&#xED;neas de elaboraci&#xF3;n, mediante pruebas de producto a nivel nacional y env&#xED;o de muestras al extranjero, de Corvina.</div><div class=\"p\">&nbsp; &nbsp;  La interesada podr&#xE1; cosechar un m&#xE1;ximo de 10 toneladas de Corvina, correspondiente a un estimado total de 9.200 ejemplares.</div><div class=\"p\">&nbsp; &nbsp;  La presente autorizaci&#xF3;n regir&#xE1; por un a&#xF1;o contado desde la publicaci&#xF3;n de este extracto en el Diario Oficial.</div></div>", "i": 8684225}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de junio de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8684226}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1975 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-1975 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-06-03", "doble_articulado": false, "id_norma": "1003453", "numero_fuente": "39386", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-06-13", "vigencias": [{"desde": "2009-06-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vi