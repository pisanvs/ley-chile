{"html": [{"t": "<div><br><div class=\"p\">ESTABLECE DOTACI&#xD3;N M&#xCD;NIMA PARA TRABAJOS DE BUCEO EN SALMONICULTURA</div></div>", "i": 9551693}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n DGTM. y MM. Ord. N&#xBA; 8330/11 Vrs., del 29 de diciembre de 2014, se aprueba la Circular DGTM. y MM. N&#xBA; A-42/008, de la misma fecha, que establece dotaci&#xF3;n m&#xED;nima para trabajos de buceo en salmonicultura.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta Circular est&#xE1; publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl).</div></div>", "i": 9551694}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de enero de 2015.- Osvaldo Schwarzenberg Ashton, Vicealmirante, Director General.- Rodrigo Ram&#xED;rez Daneri, Capit&#xE1;n de Nav&#xED;o JT, Jefe Depto. Jur&#xED;dico.</div></div>", "i": 9551695}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "11", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-11"}, {"tipo": "3", "numero": "8330/11", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-8330/11"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "ESTABLECE DOTACIÓN MÍNIMA PARA TRABAJOS DE BUCEO EN SALMONICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-12-29", "doble_articulado": false, "id_norma": "1074002", "numero_fuente": "41061", "tipo_versi