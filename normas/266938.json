{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7359580}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.188, de 12 de noviembre de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a RA&#xDA;L SEGUNDO FREIRE OLIVARES para iniciar actividades pesqueras de transformaci&#xF3;n, para instalar y operar una planta ubicada en pasaje Chaiguao N&#xBA; 25, Poblaci&#xF3;n Francisco Coloane, Quell&#xF3;n, l&#xED;nea proceso Congelado, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto resoluci&#xF3;n N&#xBA; 2.709-2007 Subpesca, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 7359581}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de noviembre de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7359582}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3188 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3188 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-11-12", "doble_articulado": false, "id_norma": "266938", "numero_fuente": "38924", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-11-29", "vigencias": [{"desde": "2007-11-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-11-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-11-29", "fin_vigencia": "",