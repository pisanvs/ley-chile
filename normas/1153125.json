{"html": [{"t": "<div><div class=\"p\">PROCEDIMIENTOS SIMPLIFICADOS PARA CONTRIBUYENTES NO DOMICILIADOS NI RESIDENTES EN CHILE</div></div>", "i": 10183440}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 150, de fecha 2 de diciembre de 2020, establece procedimiento simplificado para otorgar RUT y eximir de obligaciones de dar aviso de inicio de actividades, llevar contabilidad y declarar anualmente sus rentas, a contribuyentes no domiciliados ni residentes en Chile. Deja sin efecto <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=1023818&amp;idVersion=2020-12-11\">resoluci&#xF3;n exenta SII N&#xBA; 36, de 2011</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento est&#xE1; publicado en &quot;www.sii.cl&quot;.-</div></div>", "i": 10183441, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director.</div></div>", "i": 10183442}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "150 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-150 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "PROCEDIMIENTOS SIMPLIFICADOS PARA CONTRIBUYENTES NO DOMICILIADOS NI RESIDENTES EN CHILE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1861589", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-12-01", "doble_articulado": false, "id_norma": "1153125", "numero_fuente": "42827", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-12-11", "vigencias": [{"desde": "2020-12-11", "hasta": "", "tipo_version": "3", "t