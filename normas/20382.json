{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 141 EXENTO, DE 1996 </div></div>", "i": 5941814}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 141 de 11 de marzo de 1996, se ha aprobado al Colegio Cholgu&#xE1;n de la comuna de Yungay, un plan especial de estudio para la Ense&#xF1;anza B&#xE1;sica y Media Human&#xED;stico-Cient&#xED;fica, el cual se aplicar&#xE1; a partir del a&#xF1;o escolar 1996.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa de estudio para la asignatura de Geometr&#xED;a en los cursos de 1&#xB0; a 8&#xB0; a&#xF1;o b&#xE1;sico.</div><br></div>", "i": 5941815}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 15 de Marzo de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5941816}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "141 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-141 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 141 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO CHOLGUAN", "YUNGAY", "PLAN ESPECIAL ESTUDIO", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-03-11", "doble_articulado": false, "id_norma": "20382", "numero_fuente": "35423", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-03-21", "vigencias": [{"desde": "1996-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-03-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-03-21", "fin_vigencia": "", "tipo_versi