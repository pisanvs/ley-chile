{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6056716}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta No. 1.743 de fecha 07 de Junio de 1991, del Ministerio de Educaci&#xF3;n, se declar&#xF3; que no se concede el reconocimiento oficial al Centro de Formaci&#xF3;n T&#xE9;cnica Instituto de Capacitaci&#xF3;n Integral y T&#xE9;cnico - ICAIT, organizado por la Sociedad Instituto de Capacitaci&#xF3;n Integral y T&#xE9;cnico Ltda., ubicado en calle San Mart&#xED;n No. 60 de Coquimbo.</div><div class=\"p\">Por este mismo cuerpo legal, se elimin&#xF3; del Libro de Registros de Centros de Formaci&#xF3;n T&#xE9;cnica, el No. 210 de fecha 01 de Octubre de 1990, correspondiente a la mencionada instituci&#xF3;n.</div><br></div>", "i": 6056717}, {"t": "<div><div class=\"p\">Santiago 08 de Noviembre de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6056718}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1743 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1743 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-06-07", "doble_articulado": false, "id_norma": "80158", "numero_fuente": "34122", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-21", "vigencias": [{"desde": "1991-11-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-11-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-11-21", "fin_vigencia": "", "tipo_version": "3"}], "