{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6603646}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 695, de 23 de febrero de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a CAPMAR S.A., para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en parcela 4, lote A4, Parcelaci&#xF3;n Estrella de San Vicente, Talca, VII Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Alga seca, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6603647}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de febrero de 2007.- Mar&#xED;a Angela Barbieri Bellolio, Subsecretaria de Pesca (S). </div></div>", "i": 6603648}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "695 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-695 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-02-23", "doble_articulado": false, "id_norma": "258951", "numero_fuente": "38708", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-03-08", "vigencias": [{"desde": "2007-03-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-03-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-03-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2007-03-08", "fecha_v