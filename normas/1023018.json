{"html": [{"t": "<div><br><div class=\"p\">CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA EN VENTAS DE LEGUMBRES</div></div>", "i": 9110445}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  La VII Direcci&#xF3;n Regional Talca del S.I.I., por resoluci&#xF3;n exenta N&#xBA; 237, de fecha 17/01/2011, concede, a la contribuyente Patricia Ximena Lara Vergara, RUT 9.894.531-8, a contar del d&#xED;a primero del mes siguiente, de la fecha de esta publicaci&#xF3;n, la calidad de agente retenedor del impuesta al valor agregado, del cambio de sujeto en las ventas de legumbres, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 16 de la resoluci&#xF3;n exenta N&#xBA; 189/2010, de la Direcci&#xF3;n Nacional.</div></div>", "i": 9110446}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Talca 17 de enero de 2011.- Luis Aguirre P&#xE9;rez, Director Regional.</div></div>", "i": 9110447}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "237 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-237 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VII DIRECCIÓN REGIONAL DE TALCA"], "titulo_norma": "CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA EN VENTAS DE LEGUMBRES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-01-17", "doble_articulado": false, "id_norma": "1023018", "numero_fuente": "39886", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-02-15", "vigencias": [{"desde": "2011-02-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-02-15", "fin_vigencia": ""}, "vigencias_version_no