{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; El D.F.L. que llevaba este n&#xFA;mero fu&#xE9; publicado en el &quot;Diario Oficial&quot; N&#xB0; 22.615, de 5 de agosto de 1953. No obstante, su publicaci&#xF3;n y, por lo tanto, el D.F.L. mismo, carece de valor legal por cuanto se public&#xF3; sin que se hubiera tomado raz&#xF3;n por la Contralor&#xED;a General. (V&#xE9;anse: Oficios 53.643, de 28 de octubre de 1953, y 56.269, de 7 de noviembre de 1953, del se&#xF1;or Contralor General, dirigidos a los se&#xF1;ores Ministros de Hacienda y Presidente de la C&#xE1;mara de Diputados, respectivamente, y &quot;Diario Oficial&quot; N&#xB0; 22.697, de 13 de noviembre de 1953).</div><br></div>", "i": 9034528}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "376", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-376"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "5533", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1953-08-05", "vigencias": [{"desde": "1988-12-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-12-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-12-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}, {"text": "RECTIFICACION", "url_part": "rectificacion"}], "fecha_version": "1988-12-30", "fecha_actualizacion_texto": "1988-12-30", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9034528}]}