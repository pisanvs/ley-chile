{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8304442}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 803, de 6 de junio de 1997, de est&#xE1; Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a PESQUERA HUILLINCO&nbsp; LIMITADA, para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Atacama esquina Los Ba&#xF1;os, Cha&#xF1;aral, III Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de Congelado y Fresco-Enfriado, el recurso hidrobiol&#xF3;gico Reineta.</div><div class=\"p\">&nbsp; &nbsp;  La presente autorizaci&#xF3;n es sin perjuicio de las que corresponda conferir a otras autoridades, de acuerdo a las disposiciones legales y reglamentarias vigentes o que se establezcan.</div><br></div>", "i": 8304443}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de junio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8304444}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "803", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-803"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA HUILLINCO LIMITADA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-06-06", "fecha_derogacion": "1999-09-14", "doble_articulado": false, "id_norma": "74129", "numero_fuente": "35808", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-07-05", "vigencias": [{"desde": "1999-09-14", "hasta": "", "tipo_vers