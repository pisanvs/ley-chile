{"html": [{"t": "<div><br><div class=\"p\">SOLICITA CONSTITUCI&#xD3;N LEGAL DEL PARTIDO IGUALDAD DEL NORTE EN REGIONES QUE INDICA</div></div>", "i": 9407590}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Don Guillermo Gonz&#xE1;lez Castro y don &#xD3;scar Bustamante Y&#xE1;&#xF1;ez, Presidente y Secretario General de la Directiva Central Provisional del Partido Igualdad del Norte, han solicitado la constituci&#xF3;n legal del partido en las Regiones XV de Arica y Parinacota, I de Tarapac&#xE1; y II de Antofagasta. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de 462, 588 y 1.235 afiliaciones, respectivamente.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el <a href=\"https://www.leychile.cl/Navegar?idNorma=29994&amp;idParte=8285857&amp;idVersion=\">art&#xED;culo 17&#xBA;</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=29994&amp;idParte=&amp;idVersion=\">ley N&#xBA; 18.603</a>, por resoluci&#xF3;n O-N&#xBA; 0540, fecha 10 de febrero de 2014.</div></div>", "i": 9407591}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; Jos&#xE9; A. Henr&#xED;quez Miranda, Subdirector (S).</div></div>", "i": 9407592}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "540", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-540"}, {"tipo": "3", "numero": "O Nº 540", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O Nº 540"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCIÓN LEGAL DEL PARTIDO IGUALDAD DEL NORTE EN REGIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion"