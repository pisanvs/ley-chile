{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8290726}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0;150, de 1 de Marzo de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0;1035, de 1989, de esta Subsecretar&#xED;a que autoriz&#xF3; a don NORBERTO MANUEL HOPPE GARAY, R.U.T.</div><div class=\"p\">N&#xB0;6.333.671-8, domiciliado en la ciudad de Castro, calle Chacabuco N&#xB0;430, para operar un establecimiento de cultivo en el Estero Chaular, Pen&#xED;nsula de Lacui, comuna de Ancud, provincia de Chilo&#xE9;, D&#xE9;cima Regi&#xF3;n, por renuncia de su titular ya individualizado.</div><br></div>", "i": 8290727}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 1 de Marzo de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8290728}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "150", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-150"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NORBERTO MANUEL HOPPE GARAY", "RENUNCIA", "AUTORIZACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-03-01", "doble_articulado": false, "id_norma": "33460", "numero_fuente": "34512", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-03-10", "vigencias": [{"desde": "1993-03-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-03-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-03-10", "fin