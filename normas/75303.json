{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6044412}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xB0;589, de 30 de junio de 1997, se expropiaron los lotes de terreno N&#xB0;s. 30, 35, 36, 49 y 50, superficies 153, 67, 71, 290 y 356 m2.</div><div class=\"p\">respectivamente, roles de avalu&#xF3; 30-34, 30-1, 251-2 y 251-3, comunas de Quinta de Tilcoco y San Vicente, para la obra Camino Quinta de Tilcoco Cruce Ruta 66 y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Berta Isolina Pizarro P&#xE9;rez, Luis Manuel G&#xE1;lvez Pe&#xF1;a, Elvira de las Mercedes Garrido Pardo, Lucila Rosa Flores Cabeza y Guillermo Villaseca Flores, ascendente a las cantidades de $398.284, $479.218, $378.375, $441.456 y $544.030.-</div><br></div>", "i": 6044413}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6044414}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "589", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-589"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "QUINTA DE TILCOCO", "SAN VICENTE", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-06-30", "doble_articulado": false, "id_norma": "75303", "numero_fuente": "35843", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-08-16", "vigencias": [{"desde": "1997-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "199