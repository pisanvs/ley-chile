{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 5.394 EXENTA, DE 22.11.2019, DE LA DIRECCI&#xD3;N NACIONAL DE ADUANAS, QUE MODIFICA EL MANUAL DE PAGOS</div></div>", "i": 10074123}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 5.394, de 22.11.2019, del Director Nacional de Aduanas, se modific&#xF3; el contenido de los Cap&#xED;tulos III y IV del Manual de Pagos, ajust&#xE1;ndose al proyecto de automatizaci&#xF3;n de devoluci&#xF3;n de derechos aduaneros.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\"> </div></div>", "i": 10074124}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de noviembre de 2019.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><br></div>", "i": 10074125}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5394 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-5394 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 5.394 EXENTA, DE 22.11.2019, DE LA DIRECCIÓN NACIONAL DE ADUANAS, QUE MODIFICA EL MANUAL DE PAGOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1688356; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-11-22", "doble_articulado": false, "id_norma": "1139162", "numero_fuente": "42514", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-11-28", "vigencias": [{"desde": "2019-11-28", "hasta": "", "tipo_version": "3