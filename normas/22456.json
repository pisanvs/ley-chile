{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Ferrocarril de Temuco a Carahue Lei n&#xFA;m. 1,188.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948528}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO PRIMERO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta quinientos mil pesos en estudiar e iniciar los trabajos de un ramal de ferrocarril que una a la ciudad de Temuco con la de Carahue.</div><br><br></div>", "i": 5948529}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ART. 2.&#xB0; Para dar comienzo a los trabajos deber&#xE1;n ser pr&#xE9;viamente aprobados por el Presidente de la Rep&#xFA;blica los planos i presupuestos de la obra. </div></div>", "i": 5948530}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 25 de Enero de 1899.- FEDERICO ERRAZURIZ.- Arturo Alessandri.</div><br></div>", "i": 5948531}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1188", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1188"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "FERROCARRIL DE TEMUCO A CARAHUE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FERROCARRIL", "TEMUCO", "CARAHUE", "PRESIDENTE REPUBLICA", "INVERSION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-01-25", "doble_articulado": false, "id_norma": "22456", "numero_fuente": "6216", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-02-01", "vigencias": [{"desde": "1899-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-01-29", "fecha_version": "1899-02-01", "fecha_actualizacion_texto": "1899-02-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 5948528}, {"n": "Artículo PRIMERO", "i": 5948529, "t": 6}, {"n": "Artículo 2", "i": 5948530, "t": 6}, {"n": "Promulgación", "i": 5948531}]}