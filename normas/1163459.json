{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 2.280 EXENTA, DE 12 DE JULIO DE 2021</div></div>", "i": 10257569}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0;2.280, de 12 de julio de 2021, de la Subsecretar&#xED;a de Transportes, se autoriza al siguiente taller para adecuar veh&#xED;culos al uso de gas licuado de petr&#xF3;leo (GLP) como combustible:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/129960.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.-</div></div>", "i": 10257570}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Luis Dom&#xED;nguez Covarrubias, Subsecretario de Transportes.</div><br></div>", "i": 10257571}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2280 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2280 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 2.280 EXENTA, DE 12 DE JULIO DE 2021", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1989883", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-07-12", "doble_articulado": false, "id_norma": "1163459", "numero_fuente": "43023", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-08-09", "vigencias": [{"desde": "2021-08-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_v