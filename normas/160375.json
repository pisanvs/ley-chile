{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6248624}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. No. 63, de 14 de Marzo de 1985, se expropi&#xF3; el lote de terreno No. 1, para Agua Potable de Boca Rapel, camino acceso a la Planta, que figura a nombre de don Benito Mel&#xE9;ndez M., superficie 1.420 m2., rol de aval&#xFA;o 38-32, comuna de Navidad, VI Regi&#xF3;n. La Comisi&#xF3;n de Peritos compuesta por los se&#xF1;ores Patricio Estrada, Ren&#xE9; Corval&#xE1;n y Eduardo Schonhaut, fij&#xF3; con fecha 31 de Enero de 1984, el valor provisional de la indemnizaci&#xF3;n en la cantidad de $ 56.800. La indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xB0; del decreto ley No. 2.186, de 1978.-</div><br></div>", "i": 6248625}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras Publicas </div></div>", "i": 6248626}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "63", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-63"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-03-14", "doble_articulado": false, "id_norma": "160375", "numero_fuente": "32136", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-04-01", "vigencias": [{"desde": "1985-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-04-01", "fin_vigencia": "", "tipo_versi