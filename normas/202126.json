{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION N&#xBA;413 EXENTA, DE 2002</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 1.193 exenta.- Santiago, 28 de agosto de 2002.- Visto: El decreto ley N&#xBA;557 de 1974; la ley N&#xBA;18.059 de 1981; la resoluci&#xF3;n exenta N&#xBA;413 de 2002 del Ministerio de Transportes y Telecomunicaciones; y la minuta de la Divisi&#xF3;n de Normas, de 19 de agosto de 2002;</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br></div>", "i": 6394729}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Der&#xF3;gase la resoluci&#xF3;n exenta N&#xBA;413 de 2002, del Ministerio de Transportes y Telecomunicaciones. </div></div>", "i": 6394730}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese y publ&#xED;quese.- Guillermo D&#xED;az Silva, Ministro de Transportes y Telecomunicaciones (S).</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo para su conocimiento.- Saluda a Ud., Patricia Mu&#xF1;oz Villela, Jefe Depto.</div><div class=\"p\">Administrativo.</div><br></div>", "i": 6394731}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1193 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1193 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "DEROGA RESOLUCION Nº413 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-08-28", "doble_articulado": false, "id_norma": "202126", "numero_fuente": "37348", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-08-31", "vigencias": [{"desde": "2002-08-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "