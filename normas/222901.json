{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 310.- Santiago, 20 de Mayo de 1931.- En uso de las facultades que me confiere la ley n&#xFA;mero 4,945, de 6 de febrero ppdo.,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 6470759}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  A contar desde el 1.o de Junio del a&#xF1;o en curso la Direcci&#xF3;n General del Cr&#xE9;dito Popular y Casas de Martillo y sus dependencias, pasar&#xE1; al Ministerio de Bienestar Social, dejando de pertenecer al Ministerio de Hacienda.</div><br></div>", "i": 6470760}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese Raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- C. IBA&#xD1;EZ C- R. Jaramillo B.- Dr. Ricardo Puelma I.</div><br></div>", "i": 6470761}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "310", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-310"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-05-20", "doble_articulado": false, "id_norma": "222901", "numero_fuente": "15984", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-05-29", "vigencias": [{"desde": "1931-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1931-05-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1931-05-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2004-03-24", "fecha_versio