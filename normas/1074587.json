{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 3.639 EXENTA, DE 2014</div></div>", "i": 9561945}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 258, de 3 de febrero de 2015, de esta Subsecretar&#xED;a, modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1073319&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.639, de 2014</a>, que estableci&#xF3; la distribuci&#xF3;n para el recurso Merluza del sur en la X Regi&#xF3;n, en los t&#xE9;rminos se&#xF1;alados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n extractada se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de esta Subsecretar&#xED;a y del Servicio Nacional de Pesca y Acuicultura.</div><br></div>", "i": 9561946}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de febrero de 2015.- Paolo Trejo Carmona, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9561947}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "258 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-258 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 3.639 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-02-03", "doble_articulado": false, "id_norma": "1074587", "numero_fuente": "41078", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-02-09", "vigencias": [{"desde": "2015-02-09", "hasta": "", "tipo_ver