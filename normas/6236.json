{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 624.- Santiago, 17 de octubre de 1925.-</div><div class=\"p\">&nbsp; &nbsp; El Vice-Presidente de la Rep&#xFA;blica, oido el Consejo de Ministros del Despacho, dicta el siguiente DECRETO-LEI:</div><br></div>", "i": 5874660}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Suplem&#xE9;ntase el &#xED;tem 468 del Presupuesto de Marina, en la cantidad de cien mil pesos ($ 100,000) moneda corriente, para atender al pago de pasajes y fletes por los Ferrocarriles del Estado.</div><div class=\"p\">&nbsp; &nbsp; Rija desde su publicacion en el Diario Oficial. </div></div>", "i": 5874661}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese en la Direccion de Contabilidad, t&#xF3;mese razon, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Boletin de las Leyes y Decretos del Gobierno.- Luis Barros Borgo&#xF1;o.- B Bahamonde M.</div><br></div>", "i": 5874662}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "624", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-624"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GASTOS NACION", "A O", "1925", "MODIFICACION", "MINISTERIO MARINA."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1925-10-17", "doble_articulado": false, "id_norma": "6236", "numero_fuente": "14303", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1925-10-22", "vigencias": [{"desde": "1925-10-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1925-10-22", "fin_vigencia": ""}, "vigencias_versio