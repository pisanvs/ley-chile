{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,237.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 7250855}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Autor&#xED;zase a la Empresa de los Ferrocarriles del Estado, por el t&#xE9;rmino de un a&#xF1;o, para cobrar en moneda corriente las tarifas de la Red Central, siempre que el cambio internacional exceda de diez peniques por peso.</div><br></div>", "i": 7250856, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a cinco de febrero de mil novecientos diecisiete.- Juan Luis Sanfuentes.- Ramon Leon Luco. </div></div>", "i": 7250857}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3237", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3237"}], "organismos": ["MINISTERIO DE FERROCARRILES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1917-02-05", "doble_articulado": false, "id_norma": "139811", "numero_fuente": "11692", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1917-02-06", "vigencias": [{"desde": "1917-02-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1917-02-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1917-02-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi