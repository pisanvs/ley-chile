{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA</div><br><br></div>", "i": 8319896}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 1.777 de 14 de Noviembre de 1989 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 3&#xB0; de la Resoluci&#xF3;n No. 946, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don Hern&#xE1;n Caballero Cancino, RUT No. 7.632.971-0, domiciliado en calle An&#xED;bal Pinto No. 869, Concepci&#xF3;n, para iniciar actividades pesqueras, en el sentido de autorizar al solicitante para extraer el recurso Albacora o pez espada, (Xiphias gladius), en el litoral de las Regiones I a X, no obstante lo se&#xF1;alado en dicha Resoluci&#xF3;n, respecto de las zonas a operar.</div><br></div>", "i": 8319897}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 14 de Noviembre de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8319898}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1777", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1777"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1989-11-14", "fecha_derogacion": "1995-05-03", "doble_articulado": false, "id_norma": "91105", "numero_fuente": "33539", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1989-12-05", "vigencias": [{"desde": "1995-05-03", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1989-12-05", "ha