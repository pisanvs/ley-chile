{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6386125}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.145, de 11 de junio de 2002, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 5&#xBA; letra e) inciso 1&#xBA; de la resoluci&#xF3;n N&#xBA; 495 de 2002, de esta Subsecretar&#xED;a que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Monitoreo de la Actividad Extractiva de Pez Espada realizada por la Flota Palangrera Nacional en el Oc&#xE9;ano Pac&#xED;fico&quot;, en el sentido de se&#xF1;alar que la talla m&#xED;nima de desembarque de la mencionada especie, para efectos espec&#xED;ficos de la presente investigaci&#xF3;n ascender&#xE1; a 100 cent&#xED;metros, medidos desde la primera a la segunda aleta dorsal. </div></div>", "i": 6386126}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de junio de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6386127}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1145", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1145"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-11", "doble_articulado": false, "id_norma": "199559", "numero_fuente": "37289", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-21", "vigencias": [{"desde": "2002-06-21", "hasta": "", "tipo_version": "3", "tipo_version_