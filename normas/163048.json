{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6257238}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 472 de 28 de Octubre de 1985, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Sergio L&#xF3;pez del R&#xED;o para efectuar servicio de taxi colectivo urbano en la L&#xED;nea, No. 50 &quot;San Luis- Regional Centro&quot; de Valdivia, cuyo trazado fue autorizado por resoluci&#xF3;n exenta No. 012 de fecha 04 de Enero de 1985 y modificado por resoluci&#xF3;n exenta No. 014 de 14 de Enero de 1985, de esta Secretar&#xED;a Regional. </div></div>", "i": 6257239}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6257240}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "472 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-472 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-10-28", "doble_articulado": false, "id_norma": "163048", "numero_fuente": "32312", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-11-04", "vigencias": [{"desde": "1985-11-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-11-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-11-04", "f