{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7381630}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 3.118 de 28 de noviembre de 2008 de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n exenta N&#xB0; 1.322 de 2003 de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA EL GOLFO para ampliar actividades pesqueras extractivas con la nave &quot;Tricahue&quot; en el &#xE1;rea mar&#xED;tima correspondiente al Archipi&#xE9;lago de Juan Fern&#xE1;ndez, Islas Sala y G&#xF3;mez, Isla de Pascua e Islas Desventuradas, sobre el recurso Alfonsino, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante Informe T&#xE9;cnico citado en resoluci&#xF3;n extractada. </div></div>", "i": 7381631}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de noviembre de 2008. Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca. </div></div>", "i": 7381632}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3118 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3118 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-11-28", "doble_articulado": false, "id_norma": "282869", "numero_fuente": "39231", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-12-06", "vigencias": [{"desde": "2008-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-12-