{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6553459}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.233, de 7 de diciembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA SUR AUSTRAL DOS S.A. para continuar desarrollando las actividades pesqueras autorizadas a desarrollar a Friosur X S.A. mediante resoluciones N&#xBA; 1.415 de 1999, N&#xBA; 515, N&#xBA; 2.225, N&#xBA; 2240 y N&#xBA; 2.589, todas de 2000, N&#xBA; 2.382 de 2001, N&#xBA; 777 de 2002, N&#xBA; 3.647 y N&#xBA; 3.648, ambas de 2004, de esta Subsecretar&#xED;a, con la nave &quot;Friosour X&quot;, en virtud de la escritura p&#xFA;blica y disposiciones legales citadas en Visto.</div><br></div>", "i": 6553460}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de diciembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6553461}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4233 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4233 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-07", "doble_articulado": false, "id_norma": "245273", "numero_fuente": "38339", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-12-17", "vigencias": [{"desde": "2005-12-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-12-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-12-17", "fin_vigencia": "", "tipo_versio