{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7377580}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.095, de 8 de agosto de 2008, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n exenta N&#xBA; 2.564, de 2007, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA B&#xCD;O B&#xCD;O S.A. para realizar actividades pesqueras extractivas con la nave en construcci&#xF3;n en el &#xE1;rea mar&#xED;tima comprendida entre la IV y IX Regiones, sobre el recurso Besugo, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura, y lo informado mediante informe t&#xE9;cnico citado en la resoluci&#xF3;n extractada.</div><br></div>", "i": 7377581}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de agosto de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7377582}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2095 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2095 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-08-08", "doble_articulado": false, "id_norma": "276508", "numero_fuente": "39139", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-08-16", "vigencias": [{"desde": "2008-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig