{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA NOMBRE A LA CALLE QUE SE&#xD1;ALA EN LA CIUDAD DE COPIAPO</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Honorable Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8280114}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- La calle &quot;Borgo&#xF1;o&quot;, de la ciudad de Copiap&#xF3;, se denominar&#xE1;, en lo sucesivo, calle &quot;R&#xF3;mulo Pe&#xF1;a Maturana&quot;.&quot;.</div><br></div>", "i": 8280115}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, tres de Julio de mil novecientos cincuenta y seis.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Benjam&#xED;n Videla V. </div></div>", "i": 8280116}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "12056", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-12056"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA NOMBRE A LA CALLE QUE SEÑALA EN LA CIUDAD DE\nCOPIAPO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "CALLE", "COPIAPO", "BORGO O", "ROMULO PE A MATURANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1956-07-03", "doble_articulado": false, "id_norma": "27018", "numero_fuente": "23496", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1956-07-12", "vigencias": [{"desde": "1956-07-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1956-07-12", "fin_vigencia": ""}, "vigencia