{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 294.- Santiago, 20 de Mayo de 1931.- Vistos estos antecedentes y en uso de las facultades que me confiere la ley n&#xFA;mero 4,945, de 6 de Febrero de 1931, Decreto:</div><br></div>", "i": 7120252}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Trasp&#xE1;sase la cantidad de trescientos mil pesos ($ 300,000), del &#xED;tem E-0901, letra f) de la partida IX del Presupuesto Extraordinario al &#xED;tem E-0902, letra a) de la misma partida del citado Presupuesto.</div><br></div>", "i": 7120253}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese en la Contralor&#xED;a General de la Rep&#xFA;blica, t&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese en el Bolet&#xED;n Oficial e ins&#xE9;rtese en el Bolet&#xED;n de Leyes y Decretos del Gobierno.- C. IBA&#xD1;EZ C.- P. Charp&#xED;n.- Rodolfo Jaramillo.</div><br></div>", "i": 7120254}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "294", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-294"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO EXTRAORDINARIO NACION", "1931", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-05-20", "doble_articulado": false, "id_norma": "5338", "numero_fuente": "15983", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-05-29", "vigencias": [{"desde": "1931-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1931-05-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1931-05-29", "fin_vigencia": "", "tipo_version": "3"}], "evento