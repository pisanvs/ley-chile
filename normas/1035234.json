{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.201 EXENTA, DE 2011</div></div>", "i": 9219887}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.201, de 2 de noviembre de 2011, del Ministerio de Transportes y Telecomunicaciones, se complementaron las resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=1031514&amp;idParte=0&amp;idVersion=\">N&#xBA; 2.982</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=1031515&amp;idParte=0&amp;idVersion=\">N&#xBA; 2.983</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=1031516&amp;idParte=0&amp;idVersion=\">N&#xBA; 2.984</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=1031517&amp;idParte=0&amp;idVersion=\">N&#xBA; 2.985</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1031518&amp;idParte=0&amp;idVersion=\">N&#xBA; 2.986</a>, todas de 2011, de la misma autoridad, en el sentido de incorporar en su anexo N&#xBA; 1 los buses clase B2. Texto &#xED;ntegro se encuentra en la p&#xE1;gina web www.transantiago.gob.cl.-</div></div>", "i": 9219888}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Pedro Pablo Err&#xE1;zuriz Dom&#xED;nguez, Ministro de Transportes y Telecomunicaciones.</div></div>", "i": 9219889}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3201 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3201 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.201 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-11-02", "doble_articu