{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6193997}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 190, de 11.02.87, del Ministerio de Transportes y Telecomunicaciones, Subsecretaria de Transportes, se autoriza en forma complementaria a la empresa de origen argentino &quot;El R&#xE1;pido S.R.L.&quot;, para efectuar servicio internacional de transporte terrestre de pasajeros entre Mendoza (Argentina) y Santiago-Valpara&#xED;so-Vi&#xF1;a del Mar (Chile), por paso Caracoles (T&#xFA;nel Cristo Redentor), con un m&#xE1;ximo de 80 pasajeros (asientos) diarios.</div><br></div>", "i": 6193998}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Carlos Villegas Lorca, Subsecretario de Transportes subrogante.</div><br></div>", "i": 6193999}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "190", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-190"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-11", "doble_articulado": false, "id_norma": "144375", "numero_fuente": "32697", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-02-13", "vigencias": [{"desde": "1987-02-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-02-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-02-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAS", "fecha_ingreso": "1999-09