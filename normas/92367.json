{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 3.466, DE 1980 </div><br></div>", "i": 7226911}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n Exenta No. 3.466 de fecha 22 de diciembre de 1988 de la Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica, se reemplazaron las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica Escuela Superior de Comercio Exterior de Valpara&#xED;so ESCE, aprobadas por Resoluci&#xF3;n Exenta de Educaci&#xF3;n No. 455 de 1982, las que podr&#xE1;n aplicarse a contar del segundo semestre 1988.- </div></div>", "i": 7226912}, {"t": "<div><div class=\"p\">Paulina Dittborn Cordua, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 7226913}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3466 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3466 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 3.466, DE 1980", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-22", "doble_articulado": false, "id_norma": "92367", "numero_fuente": "33358", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-04-27", "vigencias": [{"desde": "1989-04-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-04-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-04-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_po