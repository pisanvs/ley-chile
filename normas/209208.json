{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6420260}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 697 de 19 de marzo de 2003 de</div><div class=\"p\">esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA LANDES S.A.,</div><div class=\"p\">para ampliar actividades pesqueras extractivas con la</div><div class=\"p\">nave &quot;Don Boris&quot;, en las &#xE1;reas mar&#xED;timas que en cada</div><div class=\"p\">caso se indican, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; capturar, con cerco, los siguientes recursos hidrobiol&#xF3;gicos: a) Entre la V a X Regiones: Cojinoba del sur; b) En la X Regi&#xF3;n, con cerco: Bonito.</div><br><br></div>", "i": 6420261}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de marzo de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6420262}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "697", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-697"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-03-19", "doble_articulado": false, "id_norma": "209208", "numero_fuente": "37534", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-04-12", "vigencias": [{"desde": "2003-04-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-04-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-04-12", "fin_vigencia": "", "tipo_version": "3"}], "eve