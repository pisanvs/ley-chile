{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.044 EXENTO, DE 2004 </div></div>", "i": 6571591}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.044 de fecha 30 de noviembre de 2004, de Educaci&#xF3;n, se declara aprobada al Instituto Profesional Instituto Nacional del F&#xFA;tbol la carrera t&#xE9;cnica de nivel superior que se indica:</div><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; : T&#xE9;cnico en Deportes y Actividad F&#xED;sica.</div><div class=\"p\">T&#xED;tulo T&#xE9;cnico : T&#xE9;cnico de Nivel Superior en Deportes</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  y Actividad F&#xED;sica, con menciones en</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Fitness, Deportes Individuales,</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Deportes Colectivos y Poblaciones</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Especiales.</div><br><div class=\"p\">&nbsp; &nbsp;  Dicha carrera podr&#xE1; ser impartida en jornada diurna en su Sede de la ciudad de Santiago, a contar del primer semestre del a&#xF1;o 2005.</div><br></div>", "i": 6571592}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de diciembre de 2004.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6571593}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1044 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1044 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.044 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "der