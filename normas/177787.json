{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6308536}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 4.416, de 29 de septiembre de 2000, y en base a la facultad otorgada por el art&#xED;culo 105 del D.F.L. MOP N&#xBA; 850, de 1997, que fij&#xF3; el texto actualizado de la ley N&#xBA; 15.840, se expropi&#xF3; el lote de terreno N&#xBA; 1, para la obra Regad&#xED;o Pencahue, Canal Oriente, Canal Las Brujas Kms. 0,000 al 0,275, que figura a nombre de Blanca Leppe Corval&#xE1;n y otros, rol de aval&#xFA;o 103-18, comuna de Pencahue, superficie 2.052,80 m2. La Comisi&#xF3;n de Peritos, fij&#xF3; con fecha 11 de abril de 1999, en la cantidad de $513.200. La indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.</div><br></div>", "i": 6308537}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6308538}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "4416", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-4416"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-29", "doble_articulado": false, "id_norma": "177787", "numero_fuente": "36813", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-11-14", "vigencias": [{"desde": "2000-11-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-11-14", "fin_vigencia": ""}, "vigencias_version_norma