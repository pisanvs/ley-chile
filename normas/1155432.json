{"html": [{"t": "<div><div class=\"p\">FIJA TARIFAS QUE SE&#xD1;ALA</div></div>", "i": 10198416}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n D.G.T.M. y M.M. Exenta N&#xB0; 12600/28, del 20 de enero de 2021, fija las siguientes tarifas por la prestaci&#xF3;n de servicios de recopilaci&#xF3;n, procesamiento, an&#xE1;lisis y entrega de informaci&#xF3;n estad&#xED;stica.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de estas resoluciones se encuentra publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10198417}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de enero de 2021.- Paul Miguras Silva, Teniente 1&#xB0; AB, Jefe Depto. Abastecimiento.</div><div class=\"p\"> </div><br></div>", "i": 10198418}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "28 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-28 EXENTA"}, {"tipo": "3", "numero": "12600/28 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-12600/28 EXENTA"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "FIJA TARIFAS QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1889978", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-01-20", "doble_articulado": false, "id_norma": "1155432", "numero_fuente": "42871", "tipo_version": "3", "tipo