{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 6.273 EXENTA, DE 2001 </div></div>", "i": 6340672}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 6.273, de 7 de junio del a&#xF1;o 2001, se ha aprobado al Liceo Experimental Art&#xED;stico de Santiago, comuna de Santiago, Regi&#xF3;n Metropolitana, un plan de estudio para Tercer A&#xF1;o de Ense&#xF1;anza Media T&#xE9;cnico Profesional, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio correspondientes a los Planes Complementarios, que se se&#xF1;alan en la presente resoluci&#xF3;n.</div><br></div>", "i": 6340673}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago 15 de junio de 2001.- Juan Ruz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6340674}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6273 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-6273 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 6.273 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-06-07", "doble_articulado": false, "id_norma": "187083", "numero_fuente": "36999", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-06-29", "vigencias": [{"desde": "2001-06-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-06-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-06-29", "fin_vigencia": "", "tipo_version": "3"}], "event