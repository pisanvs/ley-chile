{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div><br></div>", "i": 10383270}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n Ex. N&#xB0; 4.671, de fecha 23/11/2022, se rectifica la <a href=\"https://www.leychile.cl/Navegar?idNorma=1180088&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n Ex. N&#xB0; 3.064, de fecha 04/08/2022</a>, Proyecto &quot;Mejoramiento Avenida Pablo Neruda y Sim&#xF3;n Bol&#xED;var/Imperial, Temuco&quot;, Serviu Regi&#xF3;n de la Araucan&#xED;a que orden&#xF3; la expropiaci&#xF3;n parcial del bien ra&#xED;z denominado Inmueble ubicado en calle La Ligua n&#xFA;mero cero novecientos once, de esta ciudad, Rol de aval&#xFA;o: 1571-10, comuna de Temuco. Donde dice: &quot;Deslindes generales Lote 44-0A a expropiar&quot;, debe decir: &quot;Deslindes generales Lote 13-0A a expropiar&quot;. Lo no rectificado permanece vigente.- </div></div>", "i": 10383271}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Director, Serviu Regi&#xF3;n de la Araucan&#xED;a.</div></div>", "i": 10383272}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4671 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-4671 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2225292", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-11-23", "doble_articulado": false, "id_norma": "1185319", "numero_fuente": "43415", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-12-01", "vigencias": [{"desde": "202