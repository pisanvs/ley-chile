{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 36 EXENTO, DE 1995 </div></div>", "i": 7160173}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 36 de fecha 9 de Enero de 1995 del Ministerio de Educaci&#xF3;n, se elimin&#xF3; del Registro de Institutos Profesionales el N&#xB0; 73 correspondiente al Instituto Profesional de Massachusetts de Talca, organizado por la Sociedad Instituto de Massachusetts Limitada, autorizado a funcionar por Decreto Exento de Educaci&#xF3;n N&#xB0; 68 de fecha 27 de febrero de 1990, ello a solicitud de la propia instituci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Decl&#xE1;rase que lo dispuesto precedentemente importa la p&#xE9;rdida del reconocimiento oficial del Instituto Profesional de Massachusetts de Talca.</div><br></div>", "i": 7160174}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 30 de Enero de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160175}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "36 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-36 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 36 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "INSTITUTO PROFESIONAL DE", "MASSACHUSSETTS", "TALCA", "SEPTIMA REGION", "ELIMINACION", "REGISTRO NACIONAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-01-09", "doble_articulado": false, "id_norma": "19833", "numero_fuente": "35089", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-02-09", "vigencias": [{"desde": "1995-02-09", "hasta": "", "tipo_version": "3",