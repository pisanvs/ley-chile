{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xBA; 644</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 644, celebrada el 24 de diciembre de 1997, adopt&#xF3; los siguientes Acuerdos:</div><br><br><div class=\"p\">644-06-971224 - Reelecci&#xF3;n de Vicepresidente del Consejo y del Banco Central de Chile.</div><br></div>", "i": 6077183}, {"t": "<div><div class=\"p\">Se acord&#xF3; reelegir, a contar del 7 de diciembre de 1997 y por el plazo de dos a&#xF1;os, a don Jorge Marshall Rivera, en el cargo de Vicepresidente del Consejo y del Banco Central de Chile.</div><br></div>", "i": 6077184}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de diciembre de 1997.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6077185}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "644", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-644"}, {"tipo": "5", "numero": "644-06", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-644-06"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "REELECCION DE VICEPRESIDENTE DEL CONSEJO Y DEL BANCO CENTRAL DE CHILE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ELECCIONES", "VICEPRESIDENTE", "CONSEJO", "BANCO CENTRAL DE CHILE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-24", "doble_articulado": false, "id_norma": "87776", "numero_fuente": "35951", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-12-29", "vigencias": [{"desde": "1997-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_