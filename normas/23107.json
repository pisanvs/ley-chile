{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,074, que concede derecho a jubilar al Ministro de la Corte Suprema don Abel Saavedra Lei n&#xFA;m. 2,074.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5952736}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, al Ministro de la Corte Suprema de Justicia, don Abel Saavedra, derecho a jubilar con una pension anual de diez mil pesos ($ 10,000).</div><br></div>", "i": 5952737}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 15 de Enero de 1908.- PEDRO MONTT.- Domingo Amun&#xE1;tegui.</div><br></div>", "i": 5952738}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2074", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2074"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "LEI NUM. 2,074, QUE CONCEDE DERECHO A JUBILAR AL MINISTRO DE LA CORTE SUPREMA DON ABEL SAAVEDRA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CORTE SUPREMA JUSTICIA", "ABEL SAAVEDRA", "MINISTRO", "JUBILACION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1908-01-15", "doble_articulado": false, "id_norma": "23107", "numero_fuente": "9006", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1908-01-23", "vigencias": [{"desde": "1908-01-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio