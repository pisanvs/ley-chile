{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6414173}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 239, de 28 de enero de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA ISLADAMAS S.A. para realizar actividades extractivas en aguas internacionales con la nave &quot;Foche&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><div class=\"p\"> Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2111</div><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CB-3496</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  21,95 m</div><div class=\"p\">T.R.G. (Internacional)&nbsp; &nbsp; &nbsp;  84,08</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 138,17 m3</div><div class=\"p\">Potencia motor principal&nbsp; &nbsp;  425,00 Hp</div><div class=\"p\">Potencia motor auxiliar&nbsp; &nbsp; &nbsp; 13,00 Hp</div><br></div>", "i": 6414174}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de enero de 2003.- Felipe&nbsp; Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6414175}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "239", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-239"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-28", "doble_articulado": false, "id_norma": "207571", "numero_fuente": "37481", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "200