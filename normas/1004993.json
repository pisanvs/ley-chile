{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA;1.427 EXENTA, DE 2009</div></div>", "i": 8766871}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;1.427, de 14 de julio de 2009, se autoriz&#xF3;, de conformidad a lo dispuesto en el N&#xBA;5 de la resoluci&#xF3;n N&#xBA;65, de 2000, del Ministerio de Transportes y Telecomunicaciones, al taller que a continuaci&#xF3;n se individualiza para adecuar veh&#xED;culos al uso de gas licuado de petr&#xF3;leo y gas natural comprimido como combustible:</div><br><div class=\"p\">Empresa&nbsp; &nbsp; &nbsp;  Nombre del&nbsp; Direcci&#xF3;n del&nbsp; &nbsp; Ciudad</div><div class=\"p\">Habilitada&nbsp; &nbsp; Taller&nbsp; &nbsp; &nbsp; Taller&nbsp; &nbsp; </div><br><div class=\"p\">Italgas .&nbsp; &nbsp; Taller s&nbsp; &nbsp; Porvenir N&#xBA;427&nbsp; &nbsp; Santiago</div><div class=\"p\">Ltda.&nbsp; &nbsp; &nbsp; &nbsp; Italgas </div><br><div class=\"p\">&nbsp; &nbsp;  La autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.- </div></div>", "i": 8766872}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Erazo Torricelli, Subsecretario de Transportes.</div></div>", "i": 8766873}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1427 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-1427 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº1.427 EXENTA, DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-07-14", "doble_articulado