{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9156058}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.504 de 6 de junio de 2011 de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3.- de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1022826&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 218 de 2011</a>, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la UNIVERSIDAD ARTURO PRAT, para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Distribuci&#xF3;n espacio temporal y estructura de tama&#xF1;os de las capturas de Jurel, Regiones de Arica y Parinacota; Tarapac&#xE1; y Antofagasta, a&#xF1;o 2011&quot;, en el sentido de incorporar en el &#xE1;rea de operaci&#xF3;n la tabla de distribuci&#xF3;n geogr&#xE1;fica indicada en la resoluci&#xF3;n extractada.</div><br></div>", "i": 9156059}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de junio de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9156060}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1504 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1504 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-06-06", "doble_articulado": false, "id_norma": "1027431", "numero_fuente": "40001", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-07-04", "vigencias": [{"desde": "2011-07-04", "hasta": "", "ti