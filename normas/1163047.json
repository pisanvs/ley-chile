{"html": [{"t": "<div><div class=\"p\">CUMPLIMIENTO DE OBLIGACI&#xD3;N DEL ART. 29 LEY N&#xB0;16.271 POR CONSERVADORES</div></div>", "i": 10255607}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0;85, de fecha 23 de julio de 2021, instruye sobre el cumplimiento de la obligaci&#xF3;n del <a href=\"https://www.leychile.cl/Navegar?idNorma=172986&amp;idParte=8720785&amp;idVersion=\">art&#xED;culo 29</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=172986&amp;idParte=&amp;idVersion=\">ley N&#xB0;16.271</a>, sobre Impuesto a las Herencias, asignaciones y donaciones, que ordena a los conservadores remitir por medios electr&#xF3;nicos las n&#xF3;minas de las inscripciones de posesiones efectivas practicadas en el mes anterior.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento, est&#xE1; publicado en &quot;www.sii.cl&quot;.</div><br><br></div>", "i": 10255608}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "85 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-85 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CUMPLIMIENTO DE OBLIGACIÓN DEL ART. 29 LEY N°16.271 POR CONSERVADORES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1984455", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-07-23", "doble_articulado": false, "id_norma": "1163047", "numero_fuente": "43014", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-07-29", "vigencias": [{"desde": "2021-07-29", "hasta": "", "tipo_