{"html": [{"t": "<div><br><div class=\"p\">SOLICITA CONSTITUCI&#xD3;N DEL &quot;PARTIDO DEMOCRACIA REGIONAL PATAG&#xD3;NICA&quot;</div></div>", "i": 9594311}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  El se&#xF1;or Manuel Jos&#xE9; Ben&#xED;tez Gibbons, Secretario General de la Directiva Central Provisional del Partido Democracia Regional Patag&#xF3;nica, en formaci&#xF3;n, ha solicitado la constituci&#xF3;n legal del Partido en las regiones X de Los Lagos, XI de Ays&#xE9;n del General Carlos Ib&#xE1;&#xF1;ez del Campo y XII de Magallanes y la Ant&#xE1;rtica Chilena. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de 1.705, 235 y 500 afiliaciones, respectivamente.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n se ordena para los efectos contemplados en el art&#xED;culo 17&#xBA; de la ley 18.603, por resoluci&#xF3;n O-N&#xBA; 24 de fecha 25 de febrero de 2015.</div><br></div>", "i": 9594312}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Elizabeth Cabrera Burgos, Directora (S).</div></div>", "i": 9594313}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "24", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-24"}, {"tipo": "3", "numero": "O-24", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-O-24"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCIÓN DEL \"PARTIDO DEMOCRACIA REGIONAL PATAGÓNICA\"", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "IdDO 901968"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-02-25", "doble_articulado": false, "id_norma": "1077137", "numero_fuente": "41152", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-05-08", "vigen