{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 7.847 EXENTA, DE 2011</div></div>", "i": 9179725}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 7.847, de 31 de agosto de 2011, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Munelec Capacitaci&#xF3;n Sociedad An&#xF3;nima (Munelec S.A.)&quot;, RUT: 77.688.510-K, contenida en la resoluci&#xF3;n exenta N&#xBA; 2.339 de 12 de abril de 2007, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2 del Art. 21 de la Ley 19.518.- </div></div>", "i": 9179726}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Francisco Ag&#xFC;ero Larrondo, Director Nacional Subrogante.</div></div>", "i": 9179727}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7847 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-7847 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 7.847 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-08-31", "doble_articulado": false, "id_norma": "1029553", "numero_fuente": "40060", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-09-13", "vigencias": [{"desde": "2011-09-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-09-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-09-13", "fin_vigencia": "", "tipo_version": "3"}], "event