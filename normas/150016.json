{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 133, DE 1987 </div></div>", "i": 6214567}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 133 de 11 de junio de 1987 se ha aprobado para el Liceo A No. 7, de la comuna de Talen, provincia de Talen, VIl Regi&#xF3;n del Maule, un Plan y Programa Especial de Estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico- Profesional, que se aplicar&#xE1; gradualmente a contar del a&#xF1;o escolar 1987 y hasta el a&#xF1;o escolar de 1900, en la Especialidad de Atenci&#xF3;n de P&#xE1;rvulos. </div></div>", "i": 6214568}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Junio de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6214569}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "133 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-133 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 133, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-11", "doble_articulado": false, "id_norma": "150016", "numero_fuente": "32807", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-30", "vigencias": [{"desde": "1987-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-06-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha