{"html": [{"t": "<div><br><div class=\"p\">ARRENDAMIENTO DEL ANTIGUO CASTILLO DE S. JOS&#xC9; EN VALPARAISO.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 6 de 1825.</div><br><div class=\"p\">&nbsp; &nbsp;  El Gobierno decreta lo siguiente:</div></div>", "i": 10108696}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Los arrendamientos del antiguo castillo de S. Jos&#xE9;, como propiedad fiscal, enterense en la Tesorer&#xED;a principal de Valparaiso. Trascr&#xED;base al Gobernador y Comisar&#xED;a, t&#xF3;mese razon en la Contadur&#xED;a mayor e imprimase.</div><br><br></div>", "i": 10108697}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Correa de Saa.</div></div>", "i": 10108698}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "ARRENDAMIENTO DEL ANTIGUO CASTILLO DE S. JOSÉ EN VALPARAISO", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-07-06", "doble_articulado": false, "id_norma": "1143032", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-07-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-07-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-07-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2020-03-16", "fecha_version": "1825-07-06", "fecha_actualizacion_texto": "2020-03-16", "tipo_