{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 589 EXENTO, DE 1994 </div></div>", "i": 5945373}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 589 de 29 de Noviembre de 1994, se ha aprobado al Colegio &quot;Jos&#xE9; Manuel Balmaceda&quot; de Pe&#xF1;aflor, Regi&#xF3;n Metropolitana, un plan especial de estudio para 1&#xB0; y 2&#xB0; a&#xF1;o de Ense&#xF1;anza Media Human&#xED;stico-Cient&#xED;fica, que se comenzar&#xE1; a aplicar a partir del a&#xF1;o escolar 1995.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas para la asignatura de Filosof&#xED;a de 1&#xB0; y 2&#xB0; a&#xF1;o de ense&#xF1;anza media. </div></div>", "i": 5945374}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 13 de Diciembre de 1994.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5945375}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "589", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-589"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 589 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIO", "PROGRAMAS ESTUDIOS", "MODIFICACION", "COLEGIO JOSE MANUEL BALMACEDA", "PE AFLOR", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-11-29", "doble_articulado": false, "id_norma": "21521", "numero_fuente": "35047", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-12-22", "vigencias": [{"desde": "1994-12-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-12-22", "fin_vigencia":