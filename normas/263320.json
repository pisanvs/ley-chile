{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A CONTRIBUYENTE QUE INDICA </div></div>", "i": 7349396}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La IV Direcci&#xF3;n Regional La Serena revoca la calidad de agente retenedor del Impuesto al Valor Agregado en las ventas que se indican del contribuyente que se se&#xF1;ala:</div><br><div class=\"p\">Contribuyente&nbsp; &nbsp; RUT N&#xBA;&nbsp; &nbsp;  Res. N&#xBA;&nbsp;  Fecha&nbsp; &nbsp; Venta de</div><br><div class=\"p\">Soc.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 79.964.150-K&nbsp;  292&nbsp; &nbsp; 08-03-2006&nbsp;  Ganado</div><div class=\"p\">Agroganadera&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; vivo</div><div class=\"p\">Unida del</div><div class=\"p\">Norte Ltda.</div><br><div class=\"p\">&nbsp; &nbsp;  A contar de la fecha de la publicaci&#xF3;n de este extracto en el Diario Oficial conforme a la facultad delegada en el dispositivo N&#xBA; 18 de la resoluci&#xF3;n exenta N&#xBA; 3.721, de fecha 28/07/2000, emanada de la Direcci&#xF3;n Nacional de este Servicio.</div><br></div>", "i": 7349397}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Serena, 8 de marzo de 2006.- Alonso Vergara Arce, Director Regional (S).</div><br></div>", "i": 7349398}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "292", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-292"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IV DIRECCIÓN REGIONAL LA SERENA"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A CONTRIBUYENTE QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "dero