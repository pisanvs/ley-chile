{"html": [{"t": "<div><div class=\"p\">MODIFICA EL DECRETO N&#xBA; 110, DE 1963</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de Febrero de 1973.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 137.- Visto: los antecedentes adjuntos y la facultad que me confiere el N&#xBA; 2 del art&#xED;culo 72, de la Constituci&#xF3;n Pol&#xED;tica del Estado,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 8868881}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Introd&#xFA;cese la siguiente modificaci&#xF3;n al art&#xED;culo 91&#xBA; del decreto N&#xBA; 110, de 26 de Junio de 1963, reemplazado por el N&#xBA; 3, del decreto N&#xBA; 2, de 3 de Enero de 1973.</div><br><div class=\"p\">&nbsp; &nbsp;  Sustit&#xFA;yese el punto final (.) por una coma (,) y agr&#xE9;guese la siguiente frase: &quot;m&#xE1;s una asignaci&#xF3;n de est&#xED;mulo del 33%&quot;.</div><br></div>", "i": 8868882}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese y comun&#xED;quese.- S. ALLENDE G.- Arturo Jir&#xF3;n Vargas.</div><br><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a U. para su conocimiento.- Saluda a U.- Carlos Molina Bustos, Subsecretario de Salud P&#xFA;blica.</div><br></div>", "i": 8868883}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "137", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-137"}], "organismos": ["MINISTERIO DE SALUD PÚBLICA"], "titulo_norma": "MODIFICA EL DECRETO Nº 110, DE 1963", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1973-02-22", "doble_articulado": false, "id_norma": "254384", "numero_fuente": "28534", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1973-04-23", "vigencias": [{"desde": "1973-04-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1973-04-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1973-04-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2006-10-20", "fecha_version": "1973-04-23", "fecha_actualizacion_texto": "1973-04-23", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8868881}, {"n": "Artículo", "i": 8868882, "t": 6}, {"n": "Promulgación", "i": 8868883}]}