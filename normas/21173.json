{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 409, DE 1992 </div><br><br><br></div>", "i": 8860882}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 409 de fecha 03 de Diciembre de 1992 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica INLECAP las adecuaciones introducidas a las carreras de Traducci&#xF3;n y/o Interpretariado Ingl&#xE9;s-Espa&#xF1;ol; Traducci&#xF3;n y/o Interpretariado Franc&#xE9;s-Espa&#xF1;ol; Secretariado Ejecutivo Biling&#xFC;e con Traducci&#xF3;n y/o Interpretariado Franc&#xE9;s-Espa&#xF1;ol y Secretariado Ejecutivo Biling&#xFC;e con Traducci&#xF3;n y/o Interpretariado Ingl&#xE9;s- Espa&#xF1;ol y se insertaron en la Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xB0; 828 de 1987. Dichas adecuaciones rigen a contar de Agosto de 1992, para aplicarse en la ciudad de Santiago. </div></div>", "i": 8860883}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago 1&#xB0; de Junio de 1993. Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8860884}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "409 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-409 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 409, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA INLECAP", "TRADUCCION", "SECRETARIADO EJECUTIVO BILINGUE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1992-12-03", "fecha_derogacion": "2004-11-12", "doble_articulado": false, "id_norma": "21173", "numero_fuente": "34638", "tipo_version": "2", "tipo_version_s": "Última Versión