{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6554082}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.118, de 29 de noviembre de 2005, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de la resoluci&#xF3;n N&#xBA;732 de 2005, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la PONTIFICIA UNIVERSIDAD CATOLICA DE VALPARAISO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Factibilidad t&#xE9;cnica y operativa de la utilizaci&#xF3;n de nasas en la unidad de pesquer&#xED;a de bacalao de profundidad (Dissostichus eleginoides), en el sentido de extender el plazo de ejecuci&#xF3;n de la citada pesca de investigaci&#xF3;n hasta el d&#xED;a 30 de marzo de 2006, inclusive.</div><br></div>", "i": 6554083}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de noviembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6554084}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4118 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4118 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-29", "doble_articulado": false, "id_norma": "245421", "numero_fuente": "38343", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-12-22", "vigencias": [{"desde": "2005-12-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-12-22"