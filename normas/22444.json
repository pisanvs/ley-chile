{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Espropiacion de Terrenos Lei n&#xFA;m.1,169.- Santiago, a 1.&#xB0; de Febrero de 1899.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274125}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se declara de utilidad p&#xFA;blica una estension de terreno de propiedad de la testamentar&#xED;a de don Agust&#xED;n Barbaro, de ciento cincuenta metros de largo por 15 metros de ancho, a la orilla del rio Copiap&#xF3; i en la direccion del curso de sus aguas.</div><div class=\"p\">&nbsp; &nbsp; El terreno que se espropia se destinar&#xE1; por la Municipalidad a la construccion de un malecon.</div><div class=\"p\">&nbsp; &nbsp; La espropiacion se verificar&#xE1; con arreglo a lo dispuesto en la lei de 18 de Junio de 1857</div><br><br></div>", "i": 8274126}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C. Walker Mart&#xED;nez.</div><br></div>", "i": 8274127}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1169", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1169"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "ESPROPIACION DE TERRENOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ESPROPIACION", "TERRENOS", "RIO COPIAPO", "UTILIDAD", "PUBLICA", "DECLARACION", "MALECON", "CONSTRUCCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-02-01", "doble_articulado": false, "id_norma": "22444", "numero_fuente": "6216", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-02-01", "vigencias": [{"desde": "1899-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-01-29", "fecha_version": "1899-02-01", "fecha_actualizacion_texto": "1899-02-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8274125}, {"n": "Artículo UNICO", "i": 8274126, "t": 6}, {"n": "Promulgación", "i": 8274127}]}