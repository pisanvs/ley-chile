{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6560794}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 224, de 19 de enero de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA SEAWEED S.A. para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Km. 2 Norte, camino a Puerto Bories, Puerto Natales, XII Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco-enfriado, Fresco-refrigerado, Congelado, Seco-salado, Ahumado, Conserva, Alga seca, Aceite, Deshidratado, Extracto l&#xED;quido y Polvo de algas los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 822, de 1985, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6560795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de enero de 2006.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6560796}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "224 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-224 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-19", "doble_articulado": false, "id_norma": "247212", "numero_fuente": "38386", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-02-10", "vigencias": [{"desde": "2006-02-10", "hasta": "", "tipo_version": "3