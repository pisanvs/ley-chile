{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ley n&#xFA;m. 4,689</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 8368787}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico. Conc&#xE9;dese por gracia, y por el t&#xE9;rmino de diez a&#xF1;os, a do&#xF1;a Sara Briones viuda del ex - Comisario de la Polic&#xED;a de Santiago, don Francisco Javier Arriagada Maturana una pensi&#xF3;n de tres mil seiscientos pesos anuales, de la que disfrutar&#xE1; a contar desde el 1&#xBA; de Enero de 1930&quot; </div></div>", "i": 8368788}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y, por cuanto he tenido a bien aprobarlo y sancionarlo, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, dieciocho de Noviembre de mil novecientos veintinueve.- Carlos Ib&#xE1;&#xF1;ez C.- Enrique Berm&#xFA;dez.</div><br></div>", "i": 8368789}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4689", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4689"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEY NUM. 4,689", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-11-18", "doble_articulado": false, "id_norma": "209005", "numero_fuente": "15528", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-11-21", "vigencias": [{"desde": "1929-11-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-11-21", "fin_vigencia": ""}, "vigencias_vers