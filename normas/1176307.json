{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10334775}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 172, de 29 de marzo de 2022, de este Servicio, se fijaron los par&#xE1;metros, criterios b&#xE1;sicos y procedimiento para el c&#xE1;lculo de la Habitualidad, as&#xED; como la Habitualidad en la Actividad Pesquera Artesanal del a&#xF1;o 2021, para su aplicaci&#xF3;n en el a&#xF1;o 2022.</div><div class=\"p\">&nbsp; &nbsp;  El Texto &#xED;ntegro de la presente resoluci&#xF3;n y su respectivo Informe T&#xE9;cnico, se encuentran publicados con esta fecha en el sitio de dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y en el de la Subsecretar&#xED;a de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10334776}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de marzo de 2022.- Claudio B&#xE1;ez Beltr&#xE1;n, Director Nacional, Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\"> </div><br></div>", "i": 10334777}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "172 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-172 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2129626", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-03-29", "doble_articulado": false, "id_norma": "1176307", "numero_fuente": "43257", "tipo_version": "3", "tipo_version_s": "Única", "