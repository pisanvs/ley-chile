{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9314703}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.929, de 7 de noviembre de 2012, de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA CHILE S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Puerto Williams&quot; en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 47&#xBA; al 57&#xBA; LS, con palangre, por fuera de las l&#xED;neas de base recta, sobre los siguientes recursos hidrobiol&#xF3;gicos: Br&#xF3;tula, Reineta, Cojinoba moteada, Cojinoba del sur, Chancharro, Raya Zearaja spp., Raya Dipturus spp., Raya Psammobatis spp. y Tollo.</div></div>", "i": 9314704}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de noviembre de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9314705}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2929 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2929 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2012-11-07", "fecha_derogacion": "2014-12-06", "doble_articulado": false, "id_norma": "1046028", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2012-11-26", "vigencias": [{"desde": "2014-12-06", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2012-11-26", "hasta": "2014-12-05", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2014-12-06", "fin_vigencia": "