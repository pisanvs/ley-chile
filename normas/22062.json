{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SUPLEMENTO Lei n&#xFA;m. 204.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947142}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese un suplemento de dos mil libras esterlinas (L2,000) al &#xED;tem 3 de la partida 3.a del presupuesto en oro correspondiente al Ministerio de Relaciones Exteriores, destinado a pagar la reclamaci&#xF3;n deducida por el ciudadano arjentino don Juan Quevedo, con motivo del apresamiento de la Jeanne Amelie.</div><br><br></div>", "i": 5947143}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto en todas sus partes como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 6 de Setiembre de 1894.-JORGE MONTT.-M.</div><div class=\"p\">S&#xE1;nchez Fontecilla.</div><br></div>", "i": 5947144}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "204", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-204"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1894", "MODIFICACION", "MINISTERIO", "RELACIONES EXTERIORES", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-09-06", "doble_articulado": false, "id_norma": "22062", "numero_fuente": "4915", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-09-13", "vigencias": [{"desde": "