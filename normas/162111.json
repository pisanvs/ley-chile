{"html": [{"t": "<div><div class=\"p\">AUTORIZA A DON ANDRES MANUEL VIDAL MENAY PARA DESARROLLAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 6254336}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 531, de 28 de Agosto de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a don Andr&#xE9;s Manuel Vidal Menay, R.U.T. 7.088.776-2, domiciliado en Antofagasta, calle Zenreno No. 675, para instalar y operar un establecimiento de cultivo de osti&#xF3;n del Norte y alga Gracilaria spp., en un &#xE1;rea de 56.000 m2, ubicada en Caleta Chacaya, Mejillones, Antofagasta, II Regi&#xF3;n. </div></div>", "i": 6254337}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de Agosto de 1985.- Roberto Verdugo Gormal Subsecretario de Pesca.</div><br></div>", "i": 6254338}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "531", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-531"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A DON ANDRES MANUEL VIDAL MENAY PARA\nDESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1985-08-28", "fecha_derogacion": "1988-06-08", "doble_articulado": false, "id_norma": "162111", "numero_fuente": "32268", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1985-09-07", "vigencias": [{"desde": "1988-06-08", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1985-09-07", "hasta": "1988-06-07", "tipo_version": "0", "tipo_version_s": "Texto Or