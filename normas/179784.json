{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6315204}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;5.018, de fecha 31 de octubre de 2000, se expropi&#xF3; el lote de terreno N&#xBA;34-A, superficie 2.600 m&#xB2;, rol de aval&#xFA;o 139-1, comuna de Chonchi, para la obra &apos;&apos;Camino Ruta 5, Sector Chonchi - Tara, Km.</div><div class=\"p\">1.205,160 a Km. 1.215,004&apos;&apos;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Jos&#xE9; P&#xE9;rez C&#xE1;rcamo, ascendente a la cantidad de $1.854.780.</div><br></div>", "i": 6315205}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6315206}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "5018", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-5018"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-31", "doble_articulado": false, "id_norma": "179784", "numero_fuente": "36851", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-02", "vigencias": [{"desde": "2001-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2001-01-05", "fecha_version": "2001-01-02", "fecha_actualizacion_texto": "2001-01-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": ""