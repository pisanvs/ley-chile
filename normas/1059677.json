{"html": [{"t": "<div><br><br><div class=\"p\">ABONA EL TIEMPO QUE INDICA A DON CAMILO PROTO SANDRONE</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div></div>", "i": 9408780}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico. Ab&#xF3;nese, por gracia, al ingeniero civil de la Tesoreria de Beneficencia de Valpara&#xED;so, don Camilo Proto Sandrone, siete a&#xF1;os en su hoja de servicios, para todos los efectos legales.</div><div class=\"p\">&nbsp; &nbsp;  Esta ley regir&#xE1; desde su publicaci&#xF3;n en el Diario Oficial&quot;.</div></div>", "i": 9408781}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintid&#xF3;s de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Ignacio Lorca G.</div></div>", "i": 9408782}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10896", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "Ley-10896"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ABONA EL TIEMPO QUE INDICA A DON CAMILO PROTO SANDRONE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-22", "doble_articulado": false, "id_norma": "1059677", "numero_fuente": "22405", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-11-21", "vigencias": [{"desde": "1852-11-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"