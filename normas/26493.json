{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY QUE INDICA, RELACIONADA CON UN EMPRESTITO PARA LA MUNICIPALIDAD DE CALBUCO.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8279117}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Reempl&#xE1;zase en el art&#xED;culo 1.o de la ley N&#xB0; 10,296, de 10 de Junio de 1952, que autoriz&#xF3; un empr&#xE9;stito para la Municipalidad de Calbuco, la expresi&#xF3;n &quot;8 o&#xF3;&quot; por la siguiente: &quot;10 o&#xF3;&quot;. </div></div>", "i": 8279118}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintiuno de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Carlos Torres H.</div><br></div>", "i": 8279119}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10835", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10835"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA LA LEY QUE INDICA, RELACIONADA CON UN\nEMPRESTITO PARA LA MUNICIPALIDAD DE CALBUCO.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "LEY 10.296", "MUNICIPALIDAD CALBUCO", "EMPRESTITO", "PRESTAMO", "CREDITO."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-21", "doble_articulado": false, "id_norma": "26493", "numero_fuente": "22403", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-11-19", "vigencias": [{"desde": "1