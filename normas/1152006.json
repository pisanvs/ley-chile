{"html": [{"t": "<div><br><div class=\"p\">COMISOS.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Febrero 27 de 1826.</div></div>", "i": 10195357}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Para evitar la repeticion de consultas que se hacen de las provincias sobre el dividendo de los comisos en aquellos casos que el producido de su valor en p&#xFA;blica almoneda no alcanza a cubrir el duplo de los derechos aplicados al fisco por el art. 6.&#xB0; de la lei de 19 de marzo de 1824; impr&#xED;mase en el Boletin y diario a continuacion de este decreto la resolucion dictada por el Senado conservador y lejislador en 28 de mayo del mismo a&#xF1;o, por consulta de la Aduana jeneral, que le remiti&#xF3; el Ejecutivo.</div></div>", "i": 10195358}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  INFANTE.</div><br><div class=\"p\">&nbsp; &nbsp;  Gandarillas.</div></div>", "i": 10195359}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "COMISOS", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1826-02-27", "doble_articulado": false, "id_norma": "1152006", "numero_fuente": "1826", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1826-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1826-02-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1826-02-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ing