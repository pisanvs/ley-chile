{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7371633}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.351, de 29 de mayo de 2008, de esta Subsecretar&#xED;a, autor&#xED;zase a GERARDO ANTONIO GRIMALDI ROJAS E.I.R.L. para iniciar actividades pesqueras de transformaci&#xF3;n, para instalar y operar planta ubicada camino de acceso a Pica s/n, Iquique, para elaborar en la l&#xED;nea de proceso Alga seca, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xB0; 775 de 2008, de esta Subsecretar&#xED;a.</div><br></div>", "i": 7371634}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de mayo de 2008.- Mar&#xED;a &#xC1;ngela Barbieri Bellolio, Subsecretaria de Pesca (S). </div></div>", "i": 7371635}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1351 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1351 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-05-29", "doble_articulado": false, "id_norma": "271832", "numero_fuente": "39081", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-06-07", "vigencias": [{"desde": "2008-06-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-06-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-06-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v