{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6433884}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 594 de fecha 30 de junio de 2003, se expropi&#xF3; el lote de terreno N&#xBA; 4, superficie 314 m2, Rol N&#xBA; 302-200, comuna de Cunco, IX Regi&#xF3;n, para la obra &quot;Camino Ruta S-61, sector Cunco - Melipeuco, Km. 55,000 al Km. 87,46783, correspondiente al Tramo I Km. 55,000 al Km.</div><div class=\"p\">62,784&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Irene del Carmen Gonz&#xE1;lez D&#xED;az y otros, ascendente a la cantidad de $1.573.308.-</div><br></div>", "i": 6433885}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6433886}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "594 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-594 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-30", "doble_articulado": false, "id_norma": "213148", "numero_fuente": "37624", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-08-01", "vigencias": [{"desde": "2003-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2003-08-01", "fecha_version": "2003-08-01", "fecha_actualizacion_tex