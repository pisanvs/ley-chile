{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,261.-&nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se concede, por gracia, a do&#xF1;a Ana Fitz Henry, viuda de Donoso, i a sus hijas solteras Estela i Ana Fitz Henry una pension anual de dos mil cuatrocientos pesos ($ 2,400), de que gozar&#xE1;n con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6170526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Boletin de las Leyes i Decretos del Gobierno,-&nbsp; Santiago, tres de febrero de mil novecientos diez.- Pedro Montt.-</div><div class=\"p\">An&#xED;bal Rodr&#xED;guez H.</div><br></div>", "i": 6170527}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2261", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2261"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-02-03", "doble_articulado": false, "id_norma": "136992", "numero_fuente": "9622", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-02-21", "vigencias": [{"desde": "1910-02-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-02-21",