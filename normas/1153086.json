{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 3.361, DE 19 DE NOVIEMBRE DE 2020, REGULA SUBASTA ELECTR&#xD3;NICA DEL SERVICIO NACIONAL DE ADUANAS</div></div>", "i": 10183063}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 3.361, de 19 de noviembre de 2020, del Director Nacional de Aduanas, se regula la Subasta Electr&#xF3;nica del Servicio Nacional de Aduanas, en aplicaci&#xF3;n de lo dispuesto en el <a href=\"https://www.leychile.cl/Navegar?idNorma=238919&amp;idParte=8666235&amp;idVersion=\">art&#xED;culo 137</a> de la Ordenanza de Aduanas.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10183064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de noviembre de 2020.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><br></div>", "i": 10183065}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3361 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3361 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 3.361, DE 19 DE NOVIEMBRE DE 2020, REGULA SUBASTA ELECTRÓNICA DEL SERVICIO NACIONAL DE ADUANAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1861579", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-11-19", "doble_articulado": false, "id_norma": "1153086", "numero_fuente": "42826", "tipo_version": "3", "tipo_version_s": "Ún