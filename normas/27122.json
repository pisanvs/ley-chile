{"html": [{"t": "<div><div class=\"p\">DEROGA LA LEY NUMERO 12,452</div><br><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8280242}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Der&#xF3;gase la ley n&#xFA;mero 12,452, publicada en el &quot;Diario Oficial&quot; de fecha 16 de Abril de 1957.&quot; </div><br></div>", "i": 8280243, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veinticinco de Abril de mil novecientos cincuenta y siete.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Jorge Aravena Carrasco.</div><br></div>", "i": 8280244}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "12454", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-12454"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DEROGA LA LEY NUMERO 12,452", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTE REPUBLICA", "FACULTADES EXTRAORDINARIAS", "DEROGACION", "DEFENSA ESTADO", "REGIMEN CONSTITUCIONAL", "DERECHO REUNION", "LIBERTAD PERSONAL", "LIBERTAD IMPRENTA", "PAZ INTERIOR", "RADIODIFUSIONES", "TELECOMUNICACIONES", "CENSURA", "SENADORES", "DIPUTADOS", "EXCLUSION", "AUTORIZACION", "ARRESTOS", "VIGILANCIA", "PLAZO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1957-04-25", "doble_articulado": false, "id_norma": "27122", "numero_fuente": "23732", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1957-04-26", "vigen