{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8337655}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.652, de 23 de noviembre de 1998, de esta Subsecretar&#xED;a, autor&#xED;zase a JUAN ASTUDILLO VALDES, para ampliar actividades pesqueras autorizadas por resoluci&#xF3;n N&#xBA; 664, de 1991, de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en R&#xED;o de Janeiro N&#xBA; 167, Antofagasta, II Regi&#xF3;n, en la l&#xED;nea de elaboraci&#xF3;n que se indica los siguientes recursos hidrobiol&#xF3;gicos: Precocido: Jibia, Langosta de J. Fern&#xE1;ndez, Culengue, Caracol locate, Osti&#xF3;n del norte, Osti&#xF3;n del sur, Reineta y Pepino de mar.</div><div class=\"p\">&nbsp; &nbsp;  El recurso Osti&#xF3;n del norte, deber&#xE1; provenir de centros de cultivos autorizados.</div><br></div>", "i": 8337656}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de noviembre de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8337657}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1652", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1652"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-23", "doble_articulado": false, "id_norma": "128607", "numero_fuente": "36245", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-12-22", "vigencias": [{"desde": "1998-12-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-12