{"html": [{"t": "<div><div class=\"p\">FIJA PROCEDIMIENTO ESPECIAL Y PREVIO PARA RESTITUIR APORTE FISCAL QUE SE&#xD1;ALA</div></div>", "i": 10166050}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 132, de fecha 2 de octubre de 2020, fija procedimiento especial y previo para restituir el aporte fiscal del <a href=\"https://www.leychile.cl/Navegar?idNorma=1147923&amp;idParte=10145878&amp;idVersion=\">Art. 4&#xBA;</a> del Art&#xED;culo Primero de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1147923&amp;idParte=&amp;idVersion=\">ley N&#xBA; 21.252</a> para la protecci&#xF3;n de los ingresos de la clase media con motivo de la propagaci&#xF3;n de la enfermedad denominada Covid-19, para los casos en que se haya obtenido sin cumplir con los requisitos legales.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento est&#xE1; publicado en &quot;www.sii.cl&quot;.</div><br></div>", "i": 10166051}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "132 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-132 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "FIJA PROCEDIMIENTO ESPECIAL Y PREVIO PARA RESTITUIR APORTE FISCAL QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": ["CORONAVIRUS COVID-19", "CORONAVIRUS", "COVID-19"], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1828093", "EXTRACTO", "NORMA SIN PROMUGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-10-02", "doble_articulado": false, "id_norma": "1150464", "numero_fuente": "42776", "tipo_version": "3", "tipo_version_s": "Única", "fecha