{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9328203}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 65, de 10 de enero de 2013, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la <a href=\"https://www.leychile.cl/Navegar?idNorma=221751&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 439 de 2004</a>, que autoriz&#xF3; a ALIMENTOS MARINOS S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Don Mauro&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre la V a VII y IX Regiones al paralelo 43&#xBA; L.S., sobre el recurso hidrobiol&#xF3;gico Jibia, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum t&#xE9;cnico citado en Visto de la resoluci&#xF3;n extractada.</div><br></div>", "i": 9328204, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de enero de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9328205}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "65 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-65 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-01-10", "doble_articulado": false, "id_norma": "1048150", "numero_fuente": "40460", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-01-16", "vigencias": [{"desde": "2013-01-16", "hasta": "", "tipo_version": "3", "tipo_version_s