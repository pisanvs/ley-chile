{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8296149}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.173, de 24 de Junio de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por FILIMON LUIS</div><div class=\"p\">EDUARDO ORTIZ DEL PINO, para un centro de cultivo</div><div class=\"p\">ubicado en Bah&#xED;a Barnes, Comuna de Coquimbo, Provincia</div><div class=\"p\">de Elqui, IV Regi&#xF3;n, conforme lo dispuesto en el</div><div class=\"p\">art&#xED;culo 78&#xB0;, inciso 2&#xB0; de la Ley General de Pesca y Acuicultura y el art&#xED;culo 14&#xB0;, inciso 2&#xB0;, del D.S. N&#xB0; 290, de 1993, modificado por el D.S. N&#xB0; 604, de 1994, ambos del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8296150}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 24 de Junio de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8296151}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1173", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1173"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION ACUICULTURA", "FILIMON ORTIZ DEL PINO", "DENEGACION", "COQUIMBO", "CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-06-24", "doble_articulado": false, "id_norma": "36414", "numero_fuente": "35506", "tipo_version": "3", "tipo_version_s": "Única