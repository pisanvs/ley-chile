{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 190 EXENTO, DE 2003</div><br><br></div>", "i": 6421511}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 190 de fecha 26 de marzo de 2003 se aprueban las adecuaciones al plan y programas de estudios de la carrera de Asistente T&#xE9;cnico del Educador de P&#xE1;rvulos del Centro de Formaci&#xF3;n T&#xE9;cnica Diego Portales, que se encuentran anexas y forman parte del decreto. Modif&#xED;case, en consecuencia, el decreto exento de Educaci&#xF3;n N&#xBA; 1.008 del 4 de diciembre de 2001, en el sentido de incorporar dichas adecuaciones.</div><div class=\"p\">&nbsp; &nbsp;  Las adecuaciones que se aprueban, podr&#xE1;n aplicarse a contar del a&#xF1;o 2003.</div><br></div>", "i": 6421512}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de abril de 2003.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6421513}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "190 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-190 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 190 EXENTO, DE 2003", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-03-26", "fecha_derogacion": "2015-06-25", "doble_articulado": false, "id_norma": "209574", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-04-24", "vigencias": [{"desde": "2015-06-25", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-04-24", "hasta": "2015-06-24", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigen