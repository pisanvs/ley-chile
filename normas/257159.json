{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6596286}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de diciembre de 2006, fue de 5,72% anual.</div><br></div>", "i": 6596287}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, diciembre 28 de 2006.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6596288}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-12-28", "doble_articulado": false, "id_norma": "257159", "numero_fuente": "38651", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-12-30", "vigencias": [{"desde": "2006-12-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-12-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-12-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2007-01-08", "fecha_version": "2006-12-30", "fecha_actualizacion_texto": "2006-12-30", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6596286}, {"n": "Artículo", "i"