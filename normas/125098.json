{"html": [{"t": "<div><div class=\"p\">DERECHOS DE APROVECHAMIENTO DE AGUAS EN LAS COMUNAS DE LA LIGUA Y PAPUDO </div></div>", "i": 6132747}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n</div><div class=\"p\">exenta No. 2.106 de 12 de Diciembre de 1988, conforme</div><div class=\"p\">Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, modific&#xF3; la resoluci&#xF3;n exenta No. 1.690 de fecha 06.10.88 que aprob&#xF3; la distribuci&#xF3;n de Derechos de Aprovechamiento de Aguas de parte del Proyecto de Parcelaci&#xF3;n &quot;Las Salinas&quot; de las comunas de La Ligua y Papudo, en el sentido de eliminar de dicha resoluci&#xF3;n la distribuci&#xF3;n de los derechos de aprovechamiento de aguas captados en forma mec&#xE1;nica mediante la Bomba La Vi&#xF1;ita o</div><div class=\"p\">Vi&#xF1;itas.Publicaci&#xF3;n hecha conforme Art. 13 Ley No.</div><div class=\"p\">18.377.-</div><br></div>", "i": 6132748}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6132749}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2106 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2106 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DERECHOS DE APROVECHAMIENTO DE AGUAS EN LAS COMUNAS DE LA LIGUA Y PAPUDO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-12", "doble_articulado": false, "id_norma": "125098", "numero_fuente": "33246", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-12-15", "vigencias": [{"desde": "1988-12-15", "hasta": "", "tipo_version": "3