{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6473223}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 903, de 31 de marzo de 2004 ,de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA SAN JOSE S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Antarctic&quot;, pudiendo capturar los siguientes recursos hidrobiol&#xF3;gicos: a) En el &#xE1;rea mar&#xED;tima correspondiente a la III a VII y IX a X Regiones, con cerco: Jibia, b) En el &#xE1;rea mar&#xED;tima correspondiente a la III Regi&#xF3;n, con arrastre de media agua: Jibia, c) En el &#xE1;rea mar&#xED;tima de la IV a VII y IX a X Regiones, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua: Jibia.</div><br></div>", "i": 6473224}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de marzo de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6473225}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "903 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-903 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-03-31", "fecha_derogacion": "2011-10-19", "doble_articulado": false, "id_norma": "223600", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-04-14", "vigencias": [{"desde": "2011-10-19", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-04-14", "hasta": "2011-10-18", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigen