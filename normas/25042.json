{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DEROGA LOS DECRETOS-LEYES NUMEROS 240 Y 470 DE 1932 </div><br><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5961442}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1.o Der&#xF3;ganse los decretos-leyes n&#xFA;meros 240 y 470, de 19 de Julio y 20 de Agosto de 1932, respectivamente.</div><br></div>", "i": 5961443, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 2.o La presente ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial&quot;.</div><br></div>", "i": 5961444}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta y uno de Marzo de mil novecientos treita y tres.- ARTURO ALESSANDRI.- Domingo Dur&#xE1;n. </div></div>", "i": 5961445}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "5151", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-5151"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "DEROGA LOS DECRETOS-LEYES NUMEROS 240 Y 470 DE 1932", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["POLITECNICO ELEMENTAL MENORES ALCIBIADES VICENCIO", "CASA MENORES SANTIAGO", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1933-03-31", "doble_articulado": false, "id_norma": "25042", "numero_fuente": "6544", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1933-04-05", "vigencias": [{"desde": "1933-04-05", "hasta