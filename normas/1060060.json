{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9411554}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 679, de 25 de febrero de 2014, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la <a href=\"https://www.leychile.cl/Navegar?idNorma=191398&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.251 de 2001</a>, que autoriz&#xF3; a MAR&#xCD;A BAYCIC BAYCIC, para ampliar actividades pesqueras extractivas con la nave &quot;Ulises 2&quot;, respecto del recurso hidrobiol&#xF3;gico Reineta Brama australis en el &#xE1;rea mar&#xED;tima comprendida entre la XV y III Regiones, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante Memor&#xE1;ndum citado en Visto de la resoluci&#xF3;n extractada.</div><br><br></div>", "i": 9411555, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de febrero de 2014.- Maximiliano Alarma Carrasco, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9411556}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "679 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-679 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-02-25", "doble_articulado": false, "id_norma": "1060060", "numero_fuente": "40799", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-03-05", "vigencias": [{"desde": "2014-03-05", "hasta": "", "tipo_version": "3", "tipo_ver