{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 2,209.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170181}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados a la Nacion por el ex-Ministro de la Corte Suprema don Agustin Rodr&#xED;guez, se concede, por gracia, a su viuda e hijas solteras una pension anual de dos mil cuatrocientos pesos ($ 2,400), de que disfrutar&#xE1;n con arreglo a la lei de montep&#xED;o militar y sin derecho de acrecer.</div><br></div>", "i": 6170182}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, siete de setiembre de mil novecientos nueve.- Pedro Montt.- Domingo Amun&#xE1;tegui.</div><br></div>", "i": 6170183}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2209", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2209"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1909-09-07", "doble_articulado": false, "id_norma": "136876", "numero_fuente": "9490", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1909-09-13", "vigencias": [{"desde": "1909-09-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1909-09-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1909-0