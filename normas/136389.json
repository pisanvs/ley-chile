{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 87.- Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6168672}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir, en el resto del presente a&#xF1;o, hasta la suma de diecinueve mil pesos en atender al servicio de mensura &#xE9; hijuelaci&#xF3;n de los terrenos fiscales en la provincia de Llanquihue.</div><br></div>", "i": 6168673}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, o&#xED;do el Consejo de Estado, he tenido &#xE1; bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese &#xE1; efecto como ley de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de Agosto de 1893.- JORGE MONTT.- V. Blanco.</div><br></div>", "i": 6168674}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "87", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-87"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-08-28", "doble_articulado": false, "id_norma": "136389", "numero_fuente": "4607", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-08-29", "vigencias": [{"desde": "1893-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-08-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-08-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_