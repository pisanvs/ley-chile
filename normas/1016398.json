{"html": [{"t": "<div><br><div class=\"p\">PROH&#xCD;BE CIRCULACI&#xD3;N DE VEH&#xCD;CULOS MOTORIZADOS EN D&#xCD;A QUE INDICA</div></div>", "i": 8967810}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xBA; 1.652, de fecha 9 de julio de 2010, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, que produce efectos desde su fecha de dictaci&#xF3;n, proh&#xED;be el d&#xED;a s&#xE1;bado 10 de julio del presente a&#xF1;o, la circulaci&#xF3;n de veh&#xED;culos motorizados de cuatro o m&#xE1;s ruedas que se se&#xF1;alan en el presente cuadro, seg&#xFA;n tipo o servicio y &#xFA;ltimo d&#xED;gito de placa patente, en los horarios y per&#xED;metros que se indican, encontr&#xE1;ndose exceptuados de esta prohibici&#xF3;n todos los veh&#xED;culos aludidos en el numeral 4&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1012171&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 831/2010</a>, de esta Secretar&#xED;a Regional Ministerial.</div><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/12855.jpg\"></div></div>", "i": 8967811}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Raimundo Cruzat Correa, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div></div>", "i": 8967812}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1652 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1652 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL REGIÓN METROPOLITANA"], "titulo_norma": "PROHÍBE CIRCULACIÓN DE VEHÍCULOS MOTORIZADOS EN DÍA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso