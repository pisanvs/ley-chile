{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,223.- Santiago, 1&#xBA; de julio de 1899.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6162726}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados al pais i al Ej&#xE9;rcito por el jeneral de division, don Marco Aurelio Arriagada, se concede, por gracia, a su esposa e hijas una pension de dos mil pesos anuales, que gozar&#xE1;n en conformidad a las prescripciones de la lei de montep&#xED;o militar i con esclusion de toda otra pension fiscal.&quot; </div></div>", "i": 6162727}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- J. A. Figueroa.</div><br></div>", "i": 6162728}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1223", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1223"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-07-01", "doble_articulado": false, "id_norma": "134551", "numero_fuente": "6338", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-07-03", "vigencias": [{"desde": "1899-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-07-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-07-03", "fin_vigencia": "", "tipo_version": "3"}], "