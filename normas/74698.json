{"html": [{"t": "<div><div class=\"p\">ACEPTA RENUNCIA DE MINISTRO DE VIVIENDA Y URBANISMO </div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de julio de 1997.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 1.756.- Visto: Lo dispuesto en el art&#xED;culo 32&#xBA;, N&#xBA; 9 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  D e c r e t o:</div><br></div>", "i": 8305114}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico: Ac&#xE9;ptase a contar de esta fecha, la renuncia presentada al cargo de Ministro de Vivienda y Urbanismo a don Edmundo Sebasti&#xE1;n Hermosilla Hermosilla. </div></div>", "i": 8305115}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- EDUARDO FREI RUIZ-TAGLE, Presidente de la Rep&#xFA;blica.- Carlos Figueroa Serrano, Ministro del Interior.</div><br><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud., Belisario Velasco Baraona, Subsecretario del Interior.</div><br></div>", "i": 8305116}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1756", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1756"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARIA DEL INTERIOR"], "titulo_norma": "ACEPTA RENUNCIA DE MINISTRO DE VIVIENDA Y URBANISMO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RENUNCIA", "MINISTRO DE VIVIENDA Y URBANISMO", "EDMUNDO SEBASTIAN HERMOSILLA HERMOSILLA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-24", "doble_articulado": false, "id_norma": "74698", "numero_fuente": "35835", "tipo_version": "3", "tipo_version_