{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 228, DE 2004 </div></div>", "i": 6510156}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA; 228, de 8 de noviembre de 2004, se ha aprobado el convenio de fecha 4 de octubre de 2004 celebrado entre el Ministerio de Educaci&#xF3;n y la I. Municipalidad de Pitrufqu&#xE9;n, que rectifican el Convenio de Traspaso de la Escuela B&#xE1;sica G N&#xBA; 695, de Pitrufqu&#xE9;n, traspasada a dicha Corporaci&#xF3;n por Convenio aprobado por decreto supremo de Educaci&#xF3;n N&#xBA; 8.849, de 16 de noviembre de 1981.</div><br></div>", "i": 6510157}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de diciembre de 2004.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6510158}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "228", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-228"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 228, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-08", "doble_articulado": false, "id_norma": "233943", "numero_fuente": "38045", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-27", "vigencias": [{"desde": "2004-12-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-12-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-12-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2004-12-27", "fecha_v