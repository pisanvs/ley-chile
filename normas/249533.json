{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A LUIS AUSSET E HIJO LTDA.</div><br></div>", "i": 6569548}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VI Direcci&#xF3;n Regional Rancagua del Servicio de Impuestos Internos, por resoluci&#xF3;n N&#xBA;41, de fecha 15 de febrero de 2006, otorga la calidad de Agente Retenedor de I.V.A. en la actividad cambio de sujeto de derecho del IVA en las Ventas de Ganado Vivo a Luis Ausset e Hijo Ltda., RUT N&#xBA;77.009.460-7.</div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n que entrar&#xE1; en vigencia a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, de acuerdo a lo establecido por la resoluci&#xF3;n ex. N&#xBA;3.721, del 28 de julio de 2000, de la Direcci&#xF3;n Nacional.-</div><br></div>", "i": 6569549}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Mu&#xF1;oz Arratia, Director Regional.</div><br></div>", "i": 6569550}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "41", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-41"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VI DIRECCIÓN REGIONAL DE RANCAGUA"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A LUIS AUSSET E HIJO LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-02-15", "doble_articulado": false, "id_norma": "249533", "numero_fuente": "38461", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-05-12", "vigencias": [{"desde": "2006-05-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-05-12", "fin_vigencia": ""}, "vige