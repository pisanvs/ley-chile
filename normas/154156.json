{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6228130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 749, de 09 de Septiembre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Sixto Barrientos Bahamondes para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 1 &quot;Bellavista - Techo para Todos&quot; de Puerto Montt, cuyo trazado fue autorizado por resoluci&#xF3;n No. 82, de 07 de Junio de 1984, y modificado por resoluci&#xF3;n No. 694, de 20 de Agosto de 1987, de esta Secretar&#xED;a Regional.-</div><br></div>", "i": 6228131}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6228132}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "749 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-749 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-09", "doble_articulado": false, "id_norma": "154156", "numero_fuente": "32875", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-22", "vigencias": [{"desde": "1987-09-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-09-22