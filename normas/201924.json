{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6394044}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.683 de 8 de agosto de 2002 de esta Subsecretar&#xED;a, autor&#xED;zase a SOUTHPACIFIC KORP S.A., para ampliar las actividades pesqueras extractivas con la nave &quot;Montserrat&quot;, autorizada por resoluciones N&#xBA; 829, N&#xBA; 1904 y N&#xBA; 1919, todas del 2001, de esta Subsecretar&#xED;a, en orden a desarrollar con la nave se&#xF1;alada precedentemente, en el &#xE1;rea mar&#xED;tima correspondiente a la VII, VIII y X Regiones, por fuera del &#xE1;rea de reserva artesanal, con cerco, sobre los siguientes recursos hidrobiol&#xF3;gicos: Jurel fino, Anchoa blanca o samasa, Sardina redonda, Vinciguerria. </div></div>", "i": 6394045}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de agosto de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6394046}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1683", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1683"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-08-08", "doble_articulado": false, "id_norma": "201924", "numero_fuente": "37342", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-08-24", "vigencias": [{"desde": "2002-08-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-08-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-08-24", "fi