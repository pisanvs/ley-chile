{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8722173}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.118, de 17 de junio de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA VILLA ALEGRE Y COMPA&#xD1;&#xCD;A LIMITADA para iniciar actividades pesqueras de transformaci&#xF3;n, para instalar y operar planta ubicada en Los Talleres N&#xBA;1955, Barrio Industrial, Coquimbo, IV Regi&#xF3;n, para elaborar en l&#xED;nea de Cocido, Fresco Enfriado, Fresco Refrigerado, Congelado, Seco Salado, Ahumado y Alga Seca, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA;1.184 de 2003, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 8722174, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de junio de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 8722175}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2118 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-2118 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-06-17", "doble_articulado": false, "id_norma": "1003800", "numero_fuente": "39398", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-06-27", "vigencias": [{"desde": "2009-06-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigen