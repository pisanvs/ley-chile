{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8335559}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.042, de 06.10.88, de esta Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se sustituye el numeral 7 de la resoluci&#xF3;n No. 691, de 06.07.88, de esta Subsecretaria, que autoriz&#xF3; a Pesquera Iquique S.A., para realizar actividades de pesca exploratoria, por el siguiente: &quot;7. La presente autorizaci&#xF3;n se confiere por el plazo de 6 meses a contar del 19 de octubre de 1988. La peticionaria deber&#xE1; comunicar por escrito al Servicio Nacional de Pesca la fecha de inicio de las faenas&quot;. </div></div>", "i": 8335560}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 06.10.88.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8335561}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1042", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1042"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-10-06", "doble_articulado": false, "id_norma": "125687", "numero_fuente": "33202", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-10-22", "vigencias": [{"desde": "1988-10-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-10-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigen