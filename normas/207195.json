{"html": [{"t": "<div><div class=\"p\">EXCEPCIONA DEL REGIMEN DE CAMBIO DE SUJETO DEL IVA A GRANOTOP S.A.</div><br></div>", "i": 6412226}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional del SII, por resoluci&#xF3;n DRE09.00 N&#xBA; Ex. 22, de fecha 29 de enero de 2003, excepciona a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n a Granotop S.A. RUT 99.508.830-4, del r&#xE9;gimen de cambio de sujeto del Impuesto al Valor Agregado en las ventas de trigo, establecido en la resoluci&#xF3;n N&#xBA; Ex. 5.281 de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del 04/12/2000. El peticionario excepcionado pasa a tener la calidad de retenedor del Impuesto al Valor Agregado en sus operaciones de compra de trigo.-</div><br></div>", "i": 6412227}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Octavio Sep&#xFA;lveda Becker, Director Regional (S). </div></div>", "i": 6412228}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "22 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-22 EXENTA"}, {"tipo": "3", "numero": "DRE-09-00-22 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-09-00-22 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "EXCEPCIONA DEL REGIMEN DE CAMBIO DE SUJETO DEL IVA A GRANOTOP S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-29", "doble_articulado": false, "id_norma": "207195", "numero_fuente": "37473", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-01-31", "vigencias": [{"desde": "2003-01-31