{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7353063}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.461, de 20 de agosto de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a BRAULIO ANTONIO ARAYA ROBLES para ampliar las actividades pesqueras de transformaci&#xF3;n autorizadas por la resoluci&#xF3;n citada en Visto, en orden a incorporar a la planta ubicada en Caleta San Marcos, Manzana C, Sitio N&#xBA; 8, Iquique, I Regi&#xF3;n, en la l&#xED;nea de proceso de Alga Seca, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 7353064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de agosto de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7353065}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2461 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2461 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-08-20", "doble_articulado": false, "id_norma": "264568", "numero_fuente": "38860", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-09-10", "vigencias": [{"desde": "2007-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-09-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-09-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingre