{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 466 EXENTA, 16.01.2020</div></div>", "i": 10156635}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por la presente, se ha modificado, a contar del a&#xF1;o escolar 2020, la <a href=\"https://www.leychile.cl/Navegar?idNorma=1019786&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 5.450, de 2010, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al establecimiento educacional Instituto Miguel Le&#xF3;n Prado, RBD 9570-2, comuna de San Miguel, Regi&#xF3;n Metropolitana, en el sentido de sustituir los planes de estudio de 1&#xBA;, 2&#xBA; y 3&#xBA; a&#xF1;o de Educaci&#xF3;n Media.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10156636}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Figueroa Salas, Subsecretario de Educaci&#xF3;n. </div><br></div>", "i": 10156637}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "466 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-466 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 466 EXENTA, 16.01.2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1811003", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-01-16", "doble_articulado": false, "id_norma": "1149233", "numero_fuente": "42750", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-09-07", "vigencias": [{"desde": "2020-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci