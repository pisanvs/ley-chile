{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8312812}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.615, de 28 de noviembre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de ampliaci&#xF3;n de actividades pesqueras extractivas presentada por ALIMENTOS MARINOS S.A., para sus naves &quot;Loa 3&quot;, &quot;Ranquilhue&quot;, &quot;Panilonco&quot;, &quot;Seiko&quot;, &quot;Arequipa VII&quot;, &quot;Alimar VII&quot;, &quot;Alimar IX&quot;, &quot;Quilpolemu&quot;, &quot;Alc&#xE1;ntara&quot;, &quot;Santa Irene&quot;, &quot;Paniahue&quot;, &quot;Alcones&quot; y &quot;Querelema&quot;, por tratarse en cada caso de recursos que se presentan como fauna acompa&#xF1;ante del Jurel, respecto del cual las antedichas naves no tienen permisos en las &#xE1;reas de pesca solicitadas.</div><br></div>", "i": 8312813}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de noviembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8312814}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1615", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1615"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "AMPLIACION", "PESCA", "ALIMENTOS MARINOS S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-11-28", "doble_articulado": false, "id_norma": "81750", "numero_fuente": "35936", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-12-09", "vigencias"