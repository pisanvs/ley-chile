{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,939.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165844}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que pueda invertir hasta la cantidad de un millon de pesos en los estudios definitivos del ferrocarril que debe unir la ciudad de la Ligua con el puerto de Arica. </div></div>", "i": 6165845}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a ocho de febrero de mil novecientos siete.- Pedro Montt.- C&#xE1;rlos G. Avalos.</div><br></div>", "i": 6165846}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1939", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1939"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-02-08", "doble_articulado": false, "id_norma": "135562", "numero_fuente": "8784", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-04-27", "vigencias": [{"desde": "1907-04-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-04-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1907-04-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [