{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6175007}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 5, de 22 de Enero de 1988, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la XII Regi&#xF3;n Magallanes y Ant&#xE1;rtica Chilena, se autoriza a do&#xF1;a Cecilia Savareses Furche para efectuar todo tipo de servicios de transporte terrestre de pasajeros, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos de locomoci&#xF3;n colectiva urbana de pasajeros.- </div></div>", "i": 6175008}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Urbano Peralta, Secretario Regional Ministerial XII Regi&#xF3;n.</div><br></div>", "i": 6175009}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XII REGIÓN DE MAGALLANES Y ANTÁRTICA CHILENA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-22", "doble_articulado": false, "id_norma": "138302", "numero_fuente": "32988", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-05", "vigencias": [{"desde": "1988-02-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-02-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacio