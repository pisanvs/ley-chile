{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DICTA ORDENANZA SOBRE VENTA DE SEGUROS AUTOMOTRIZ OBLIGATORIO </div></div>", "i": 5998816}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Se comunica que la I. Municipalidad de La Pintana ha dictado la Ordenanza Municipal N&#xB0; 02 del a&#xF1;o 1995 de fecha 10 de Noviembre de 1995, sobre Venta de Seguros Automotriz Obligatorio, la que entrar&#xE1; en vigencia quince d&#xED;as despu&#xE9;s de esta publicaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Los ejemplares pueden ser adquiridos en la Direcci&#xF3;n de Administraci&#xF3;n y Finanzas de la I. Municipalidad de La Pintana.</div><br></div>", "i": 5998817}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, comun&#xED;quese, publ&#xED;quese y arch&#xED;vese.- Jaime Pavez Moreno, Alcalde.- Angela Alvear Morales, Secretario Municipal.</div><br></div>", "i": 5998818}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "2", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "ORZ-2"}], "organismos": ["MUNICIPALIDAD DE LA PINTANA"], "titulo_norma": "DICTA ORDENANZA SOBRE VENTA DE SEGUROS AUTOMOTRIZ\nOBLIGATORIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ORDENANZA MUNICIPAL", "VENTA", "SEGURO AUTOMOTRIZ OBLIGATORIO", "MUNICIPALIDAD LA PINTANA", "DERECHOS MUNICIPALES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-11-10", "doble_articulado": false, "id_norma": "30946", "numero_fuente": "35330", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-11-30", "vigencias": [{"desde": "1995-11-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-11-30", "fin_vigencia": ""}, "vigencias_version_norma"