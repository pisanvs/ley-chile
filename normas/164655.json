{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6262198}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.163 de fecha Octubre 3 de 1984, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a don Miguel Eduardo Diez Pascal, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6262199}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 05 de Octubre de 1984.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial, Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana. </div></div>", "i": 6262200}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1163 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1163 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-10-03", "doble_articulado": false, "id_norma": "164655", "numero_fuente": "32095", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-02-12", "vigencias": [{"desde": "1985-02-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-02-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-02-12", "fin_vigencia": "", "tipo