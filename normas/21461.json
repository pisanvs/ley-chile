{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 557 EXENTO, DE 1994 </div></div>", "i": 5945213}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento de Educaci&#xF3;n N&#xB0; 557, de fecha 17 de Noviembre de 1994, se ha complementado el plan de estudio del &quot;Colegio Eagle School&quot;, de Antofagasta, agregando la Asignatura de Inform&#xE1;tica desde el 3er. A&#xF1;o de Educaci&#xF3;n B&#xE1;sica hasta el 4&#xB0; A&#xF1;o de Educaci&#xF3;n Media, a partir del a&#xF1;o 1995, la que ser&#xE1; aplicada en forma consecuencial y progresiva.</div><br></div>", "i": 5945214}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 5 Diciembre 1994.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5945215}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "557", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-557"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 557 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "COLEGIO EAGLE SCHOOL", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-11-17", "doble_articulado": false, "id_norma": "21461", "numero_fuente": "35054", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-12-30", "vigencias": [{"desde": "1994-12-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-12-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-12-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "19