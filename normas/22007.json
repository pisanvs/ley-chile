{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Casa de Orates de Santiago Lei n&#xFA;m. 145.- Santiago, a 2 de Enero de 1894.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto del Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273764}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza la inversion de cuarenta i siete mil pesos en el servicio de la casa de Orates de Santiago.</div><br><br></div>", "i": 8273765}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Pedro Montt.</div><br></div>", "i": 8273766}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "145", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-145"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CASA DE ORATES DE SANTIAGO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CASA ORATES SANTIAGO", "INVERSION FONDOS", "FUNCIONAMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-01-02", "doble_articulado": false, "id_norma": "22007", "numero_fuente": "4707", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-01-02", "vigencias": [{"desde": "1894-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-03-19", "fecha_version": "189