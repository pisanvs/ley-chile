{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No.123, DE 1990 </div></div>", "i": 7218555}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No.123, de 9 de abril de 1990 se ha aprobado, a partir del a&#xF1;o escolar 1990, un plan especial de estudio al Colegio Cordillera de Las Condes, de Santiago, para ser aplicado simult&#xE1;neamente en 7&#xBA; y 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica y en 1&#xBA; y 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media Human&#xED;stico-Cient&#xED;fica.</div><br></div>", "i": 7218556}, {"t": "<div><div class=\"p\">Santiago, 10 de Abril de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7218557}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "123 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-123 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 123, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-04-09", "doble_articulado": false, "id_norma": "83249", "numero_fuente": "33665", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-05-09", "vigencias": [{"desde": "1990-05-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-05-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-05-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1998-01-07", "fecha_version": "1990-05-09", "fecha_actualizacion_texto": "1990-05