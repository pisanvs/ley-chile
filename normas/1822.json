{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5845239}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Subsecretario de Educaci&#xF3;n, quien suscribe, certifica que la Universidad Bernardo O&apos;Higgins inscrita bajo el Folio C-54 del Registro de Universidades del Ministerio de Educaci&#xF3;n, podr&#xE1; impartir la siguiente carrera y otorgar el t&#xED;tulo profesional que se indica, en la Sede Central de Santiago, a contar del a&#xF1;o 1995.</div><br><div class=\"p\"> - Carrera&nbsp;  : Relaciones P&#xFA;blicas</div><div class=\"p\"> - T&#xED;tulo&nbsp; &nbsp; : Relacionador P&#xFA;blico</div><br><div class=\"p\">&nbsp; &nbsp; La mencionada carrera se encuentra liberada de la obligaci&#xF3;n de someter sus planes y programas de estudios a una entidad examinadora, en virtud de lo dispuesto por el D.S. N&#xB0; 1.076 de 1986.</div><br></div>", "i": 5845240}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 6 de Febrero de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5845241}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["UNIVERSIDAD BERNARDO O'HIGGINS", "AUTORIZACION", "CARRERAS PROFESIONALES", "RELACIONES PUBLICAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-02-06", "doble_articulado": false, "id_norma": "1822", "numero_fuente": "35123", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-03-21", "vigencias": [{"desde": "1995-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s"