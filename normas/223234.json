{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6471937}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 378 de fecha 27 de febrero de 2004, se expropiaron los lotes de terreno N&#xBA; s. 67 y 68, superficies 3.365 y 131 m2 respectivamente, rol N&#xBA; 26415, comuna de San Javier, para la obra Camino Mejoramiento Ruta 126 Los Conquistadores, sector 2 Carrizal - Puente Belco, tramo Km. 23,38000 a Km.</div><div class=\"p\">41,26600&quot;, VII Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Jos&#xE9; Candelario Becerra Salgado, ascendente a la cantidad de $1.778.700. </div></div>", "i": 6471938}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6471939}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "378 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-378 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-27", "doble_articulado": false, "id_norma": "223234", "numero_fuente": "37826", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-01", "vigencias": [{"desde": "2004-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2004-04-01", "fecha_version": "2004-04-01", "fecha_act