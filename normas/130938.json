{"html": [{"t": "<div><div class=\"p\">DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE SE&#xD1;ALA </div></div>", "i": 6151555}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 1.451 de 29 de Agosto de 1988, conforme art. 5&#xB0; transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a parcelas N&#xB0;s. 1 a la 11, sitios N&#xB0;s. 1 al 3 del Proyecto de Parcelaci&#xF3;n &quot;Mesam&#xE1;vida&quot;, de la comuna de Los Angeles, VIII Regi&#xF3;n formado por predios &quot;Parte del Predio Denominado Mesam&#xE1;vida&quot; y &quot;Mesam&#xE1;vida&quot;. Los Derechos de Agua se extraen del r&#xED;o Paillihue y del canal Duqueco - Cuel derivado del r&#xED;o Duqueco. Publicaci&#xF3;n hecha conforme Art. 13 Ley No.</div><div class=\"p\">18.377.</div><br></div>", "i": 6151556}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6151557}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1451 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1451 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-29", "doble_articulado": false, "id_norma": "130938", "numero_fuente": "33161", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-09-01", "vigencias": [{"desde": "1988-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-09-01",