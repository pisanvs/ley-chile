{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; REHABILITA EN SU NACIONALIDAD CHILENA A DON LUIS OLAVE LUNA</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8281135}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Rehabil&#xED;tase en su nacionalidad chilena a don Luis Olave Luna, quien la hab&#xED;a perdido por nacionalizaci&#xF3;n en pa&#xED;s extranjero&quot;.</div><br></div>", "i": 8281136}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, dos de Agosto de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- S&#xF3;tero del R&#xED;o Gundi&#xE1;n. </div></div>", "i": 8281137}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13980", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13980"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "REHABILITA EN SU NACIONALIDAD CHILENA A DON LUIS\nOLAVE LUNA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REHABILITACION", "NACIONALIDAD CHILENA", "LUIS OLAVE LUNA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-08-02", "doble_articulado": false, "id_norma": "27612", "numero_fuente": "24718", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-08-13", "vigencias": [{"desde": "1960-08-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1960-08-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici