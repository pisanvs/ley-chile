{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;249, DE 2000 </div></div>", "i": 6278606}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA;249, de 2 de mayo de 2000, se ha aprobado el Convenio de fecha 3 de abril de 2000, celebrado entre el Ministerio de Educaci&#xF3;n y la I. Municipalidad de San Vicente de Tagua-Tagua, que modifica el Convenio de Traspaso de la Escuela B&#xE1;sica F N&#xBA;168, de San Vicente de Tagua-Tagua, traspasada a dicha Corporaci&#xF3;n, por convenio aprobado por decreto supremo de Educaci&#xF3;n N&#xBA;5.427, de 19 de agosto de 1981.</div><br></div>", "i": 6278607}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de mayo de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6278608}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "249", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-249"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº249, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-02", "doble_articulado": false, "id_norma": "169653", "numero_fuente": "36677", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-31", "vigencias": [{"desde": "2000-05-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2000-05-31", "fecha_vers