{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 129 EXENTO, DE 2001 </div></div>", "i": 6333111}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 129, de fecha 5 de abril de 2001, del Ministerio de Educaci&#xF3;n, se aprueba el plan y programas de estudios del Centro de Formaci&#xF3;n T&#xE9;cnica Centro Nacional de Estudios Param&#xE9;dicos y Agropecuarios Propam, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida en las sedes que se se&#xF1;alan, a contar del a&#xF1;o 2001:</div><br><div class=\"p\">Sede Central - Santiago, Sede N&#xBA; 10 - Concepci&#xF3;n y Sede N&#xBA; 19 - Puerto Montt.</div><br><div class=\"p\">Carrera&nbsp; : Cocina Internacional y Tradicional Chilena.</div><div class=\"p\">T&#xED;tulo&nbsp;  : T&#xE9;cnico en Cocina Internacional y</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Tradicional Chilena de Nivel Superior.</div><br></div>", "i": 6333112}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de abril de 2001.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6333113}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "129 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-129 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 129 EXENTO, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-05", "doble_articulado": false, "id_norma": "184815", "numero_fuente": "36953", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-04", "vigencias": [{"desde": "2001-05-04", "h