{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 695, EXENTO DE 2006 </div></div>", "i": 7331426}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 695 de fecha 30 de mayo de 2006 del Ministerio de Educaci&#xF3;n, se aprueban las modificaciones introducidas al plan y programas de estudio del Centro de Formaci&#xF3;n T&#xE9;cnica Educap, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar del a&#xF1;o 2006, en la Sede Central de Quillota, con la siguiente denominaci&#xF3;n:</div><br><div class=\"p\">Carrera&nbsp;  :&nbsp; Contabilidad y Auditor&#xED;a, cambia por:</div><div class=\"p\">Carrera&nbsp;  :&nbsp; Gesti&#xF3;n Contable y Tributaria</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; :&nbsp; T&#xE9;cnico de Nivel Superior en Gesti&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Contable y Tributaria</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; (Decreto exento N&#xBA; 265 del 11.10.90)</div><br></div>", "i": 7331427}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 21 de julio de 2006.- Pilar Romaguera Gracia, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 7331428}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "695 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-695 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 695, EXENTO DE 2006", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-05-30", "doble_articulado": false, "id_norma": "251754", "numero_fuente": "38527", "tipo_version": "3", "tipo_version_s": "Úni