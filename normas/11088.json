{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5901336}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto M.O.P. N&#xB0; 215, de 30 de Julio de 1993, se expropiaron los lotes de terreno N&#xB0;s. 2 y 3, superficies 1.040 M2 y 2.250 M2., roles de aval&#xFA;os 328-142 y 328-140, Comuna de Villarrica, para la obra Camino Villarrica Co&#xF1;aripe, sector Villarrica Licanray y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Vicariato Apost&#xF3;lico de la Araucan&#xED;a y Mireya Huilip&#xE1;n Lagos, ascendente a las cantidades de $ 478.034 y $ 547.113.</div><br></div>", "i": 5901337}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 5901338}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "215", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-215"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BIEN INMUEBLE", "EXPROPIACION", "VILLARRICA", "NOVENA", "REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-07-30", "doble_articulado": false, "id_norma": "11088", "numero_fuente": "34656-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-09-01", "vigencias": [{"desde": "1993-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1993-09-01", "fecha_actualizacion_texto": "1993-09-01", "tipo_tratado": ""}, "alertas": [],