{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N&#xBA; 1169 </div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 1169, celebrada el 16 de diciembre de 2004, adopt&#xF3; el siguiente Acuerdo:</div><br></div>", "i": 6509890}, {"t": "<div><div class=\"p\">1169-02-041216 - Tasa de inter&#xE9;s para pago diferido de derechos de Aduana.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3;, en conformidad con lo establecido en la letra c) del art&#xED;culo 10 de la Ley N&#xBA; 18.634, que la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de derechos de aduana durante el semestre que expira el 30 de junio de 2005, ser&#xE1; de 5,9% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.</div><br></div>", "i": 6509891}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de diciembre de 2004.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6509892}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1169", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1169"}, {"tipo": "5", "numero": "1169-02", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1169-02"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION Nº 1169", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-16", "doble_articulado": false, "id_norma": "233877", "numero_fuente": "38041", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-21", "vigencias": [{"desde": "2004-12-21", "hasta": "", "tipo_version": "3", "tipo_version