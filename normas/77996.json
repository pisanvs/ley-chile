{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8308410}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 684, de 24 de Julio de 1992, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la resoluci&#xF3;n No. 975, de 1987 de esta Subsecretar&#xED;a, que autoriz&#xF3; a la ASOCIACION GREMIAL DE PESCADORES ARTESANALES Y ALGUEROS DE LOLCURA, R.U.T. No. 71.534.100-k domiciliada en la X Regi&#xF3;n, para instalar y operar un establecimiento de cultivo del recurso alga, del g&#xE9;nero Gracilaria, en el R&#xED;o Maull&#xED;n, localidad de Lolcura, Comuna de Maull&#xED;n, X Regi&#xF3;n, en un &#xE1;rea de 90.000 M2, por renuncia de su titular.</div><br></div>", "i": 8308411}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 24 de Julio de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8308412}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "684", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-684"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-07-24", "doble_articulado": false, "id_norma": "77996", "numero_fuente": "34330", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-07-31", "vigencias": [{"desde": "1992-07-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-07-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-07-31", "fin_vigencia": "", "tipo_version": "3"}],