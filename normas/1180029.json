{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10357932}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;531, de 13 de julio de 2022, se modific&#xF3; y desisti&#xF3; parcialmente de la expropiaci&#xF3;n del lote N&#xBA;85, realizada por <a href=\"https://www.leychile.cl/Navegar?idNorma=1095588&amp;idParte=&amp;idVersion=\">Decreto Exento MOP. N&#xBA;736, de 13 de septiembre de 2016</a>, reduci&#xE9;ndose la superficie expropiada a 2.143 m2. y modificando el numeral primero de dicho Decreto, se&#xF1;alando como nuevo kilometraje de t&#xE9;rmino, debe decir: Km. 24,71043, expropiado para la ejecuci&#xF3;n de obra &quot;Mejoramiento Ruta L-31, Sector la Floresta - Queri, comuna Yerbas Buenas, Regi&#xF3;n del Maule&quot;. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en los art&#xED;culos 7&#xBA; y 32&#xBA; del Decreto Ley N&#xBA;2186, de 1978.</div></div>", "i": 10357933}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10357934}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "531 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-531 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2169978", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-07-13", "doble_articulado": false, "id_norma": "1180029", "numero_fuente": "43328", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-08-16", "vigencias": [{"