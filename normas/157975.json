{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6240183}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 188, de 05.03.85, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana se autoriza los se&#xF1;ores Williams Kenneth Michell Trewhela y Eritrea de las Mercedes Carrasco Cordero, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6240184}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 08 de Marzo de 1985. Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6240185}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "188", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-188"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-03-25", "doble_articulado": false, "id_norma": "157975", "numero_fuente": "32131", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-26", "vigencias": [{"desde": "1985-03-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-03-26", "fin_vigencia": "