{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO NUMERO 711 EXENTO, DE 1993 </div></div>", "i": 5945957}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 711 de fecha 31 de Diciembre de 1993 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; al Centro de Formaci&#xF3;n T&#xE9;nica CENAFOM, las adecuaciones introducidas al plan y programas de estudio de la carrera de Administraci&#xF3;n de Empresas con especialidad en Comercio Exterior, las que se insertaron en la Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xB0; 1 de 1985. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1994.- </div></div>", "i": 5945958}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5945959}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "711", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-711"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO NUMERO 711 EXENTO, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "CENTRO FORMACION TECNICA", "CENAFOM", "MODIFICACION", "ADMINISTRACION EMPRESA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-12-31", "doble_articulado": false, "id_norma": "21724", "numero_fuente": "34850", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-04-27", "vigencias": [{"desde": "1994-04-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-04-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-04-27", "fin_vigencia": "", "tipo_version": "3"}], "ev