{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293182}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 574, de 18 de Mayo de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, cad&#xFA;canse las Resoluciones N&#xB0; 243, de 1990 y N&#xB0; 917, de 1994, ambas de esta Subsecretar&#xED;a, que autorizaron a SARPESCA S.A., R.U.T.</div><div class=\"p\">N&#xB0; 96.539.160-6, para operar las naves &quot;Sarpesca I&quot;, &quot;Sarpesca II&quot;, &quot;Sarpesca III&quot; y &quot;Sarpesca IV&quot;, en virtud de lo dispuesto en el art&#xED;culo 143&#xB0; letra b) del D.S. N&#xB0; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, que fij&#xF3; el texto refundido de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8293183}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 18 de Mayo de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293184}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "574", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-574"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "PESCA", "SARPESCA S.A"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-18", "doble_articulado": false, "id_norma": "35131", "numero_fuente": "35178", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-05-27", "vigencias": [{"desde": "1995-05-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_v