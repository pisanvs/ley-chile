{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 7 EXENTO, DE 1996</div><br><br></div>", "i": 7159941}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 7, de fecha 9 de enero de 1996 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Centro Nacional de Estudios Param&#xE9;dicos y Agropecuarios Propam, las adecuaciones introducidas al plan y programas de estudio de la carrera T&#xE9;cnico Pecuario, las que se insertaron en la Resoluci&#xF3;n Exenta del Ministerio de Educaci&#xF3;n N&#xB0; 2.297, de 1987. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1996.</div><br></div>", "i": 7159942}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 8 de febrero de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7159943}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "7 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-7 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 7 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA", "CENTRO NACIONAL ESTUDIOS", "PARAMEDICOS AGROPECUARIOS PROPAM", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-01-09", "doble_articulado": false, "id_norma": "19591", "numero_fuente": "35420", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-03-18", "vigencias": [{"desde": "1996-03-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-03-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"in