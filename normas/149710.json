{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6213435}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, certifica, a requerimiento de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante, para los efectos de lo dispuesto en el art&#xED;culo N&#xBA; 116 del decreto supremo de la Subsecretar&#xED;a de Marina N&#xBA; 427, de 25 de junio de 1979, que la variaci&#xF3;n experimentada por el Indice de Precios al Consumidor de los Estados Unidos de Am&#xE9;rica, entre el 1&#xBA; de diciembre de 1998 y el 30 de noviembre de 1999, fue de 2,6%.</div><br></div>", "i": 6213436}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de diciembre de 1999.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6213437}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-16", "doble_articulado": false, "id_norma": "149710", "numero_fuente": "36544", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-12-21", "vigencias": [{"desde": "1999-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-12-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-12-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-12-21", "fecha_version": "1999-12-21", "fecha_actualizacion_texto": "1999-12-21", "tipo_tratad