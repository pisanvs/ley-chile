{"html": [{"t": "<div><br><div class=\"p\">PONE T&#xC9;RMINO AL NOMBRAMIENTO COMO ALCALDE DE MAR AD-HONOREM</div></div>", "i": 10043264}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n D.G.T.M. y M.M. Ord. N&#xBA; 1.120/37 Vrs., del 13 de febrero de 2019, pone t&#xE9;rmino al nombramiento como Alcalde de Mar Ad-honorem de la Caleta Pajonales al Sr. Leonildo Corrotea Lobos.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl).</div></div>", "i": 10043265}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de junio de 2019.- Ignacio Mardones Costa, Vicealmirante, Director General.- Cristi&#xE1;n Pfeifer Rojas, Capit&#xE1;n de Nav&#xED;o JT, Jefe Depto. Jur&#xED;dico.</div></div>", "i": 10043266}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "37", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-37"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "PONE TÉRMINO AL NOMBRAMIENTO COMO ALCALDE DE MAR AD-HONOREM", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1630019", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-02-13", "doble_articulado": false, "id_norma": "1134434", "numero_fuente": "42418", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-08-01", "vigencias": [{"desde": "2019-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "v