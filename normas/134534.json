{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,173.- Santiago, 19 de enero de 1899.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6162674}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Domitila Silva, madre-viuda del teniente coronel don Pedro Nolasco del Canto, el goce de la pensi&#xF3;n de montep&#xED;o correspondiente al empleo de coronel, en vez de la de teniente coronel que actualmente percibe.</div><br></div>", "i": 6162675}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C&#xE1;rlos Concha.</div><br></div>", "i": 6162676}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1173", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1173"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-01-19", "doble_articulado": false, "id_norma": "134534", "numero_fuente": "6205", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-01-19", "vigencias": [{"desde": "1899-01-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-01-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-01-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso