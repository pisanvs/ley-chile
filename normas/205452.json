{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6405760}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.027, de 24 de septiembre de 2002, de esta Subsecretar&#xED;a, apru&#xE9;base la modificaci&#xF3;n del proyecto t&#xE9;cnico y cronograma de actividades presentado por MARIO LUIS TRONCOSO JARA para una piscicultura ubicada en sector El Tumi, IX Regi&#xF3;n, autorizada por resoluci&#xF3;n N&#xBA; 551 de 2000, de esta Subsecretar&#xED;a.</div><div class=\"p\">&nbsp; &nbsp;  El peticionario podr&#xE1; cultivar en el centro individualizado los recuros pertenecientes al grupo de especies salm&#xF3;nidas.</div><br></div>", "i": 6405761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de septiembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6405762}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2027", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2027"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-09-24", "doble_articulado": false, "id_norma": "205452", "numero_fuente": "37432", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-12", "vigencias": [{"desde": "2002-12-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-12-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-12-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICAC