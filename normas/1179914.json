{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10357416}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xB0; 1.546, de 8 de julio de 2022, deja sin efecto parcialmente la <a href=\"https://www.leychile.cl/Navegar?idNorma=1175333&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0;450, de fecha 11 de marzo de 2022</a>, que extendi&#xF3; la vigencia de certificados de calibraci&#xF3;n y suspendi&#xF3; prestaciones del Departamento de Salud Ocupacional.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10357417}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Heriberto Garc&#xED;a Escorza, Director (S), Instituto de Salud P&#xFA;blica de Chile.</div><br></div>", "i": 10357418}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1546 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1546 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2170672", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-07-08", "doble_articulado": false, "id_norma": "1179914", "numero_fuente": "43325", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-08-11", "vigencias": [{"desde": "2022-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2022-08-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vi