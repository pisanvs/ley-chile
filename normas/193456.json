{"html": [{"t": "<div><div class=\"p\">ORDENANZA SOBRE TENENCIA, CUIDADO Y CONTROL DE ANIMALES </div></div>", "i": 6364958}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Con fecha 31 de diciembre de 2001 la I.</div><div class=\"p\">Municipalidad de Renca dict&#xF3; la Ordenanza N&#xBA; 004 sobre tenencia, cuidado y control de animales en la comuna de Renca la cual entrar&#xE1; en vigencia el d&#xED;a subsiguiente al de publicaci&#xF3;n de este aviso. Esta ordenanza establece los requisitos exigibles en la comuna para la tenencia de perros en especial y de otros animales en general, en todo lo que les sea aplicable, sus inspecciones, procedimiento e infracciones. La Ordenanza estar&#xE1; a disposici&#xF3;n del p&#xFA;blico en hall del edificio municipal (Blanco Encalada N&#xBA; 1335).- </div></div>", "i": 6364959}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Vicky Barahona Kunstmann, Alcaldesa.</div><br></div>", "i": 6364960}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "AVI-S/N"}, {"tipo": "21", "numero": "4", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "ORZ-4"}], "organismos": ["MUNICIPALIDAD DE RENCA"], "titulo_norma": "ORDENANZA SOBRE TENENCIA, CUIDADO Y CONTROL DE ANIMALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PERROS", "ANIMALES DOMESTICOS", "ORDENANZA MUNICIPAL", "MUNICIPALIDAD DE RENCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-31", "doble_articulado": false, "id_norma": "193456", "numero_fuente": "37155", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-09", "vigencias": [{"desde": "2002-01-09", "hasta": "", "tipo_version": "3", "ti