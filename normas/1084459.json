{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 7.316, DE 19.11.2015</div><div class=\"p\">&nbsp; &nbsp; </div></div>", "i": 9652426}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=236211&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 14.695, de 2004, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media al Colegio Cumbres, comuna de Las Condes, provincia de Santiago, Regi&#xF3;n Metropolitana.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Sectores de Econom&#xED;a y Gesti&#xF3;n; el Hombre desde una Mirada &#xC9;tica Psicol&#xF3;gica y Teor&#xED;a de la Comunicaci&#xF3;n y Taller de Periodismo para 3er a&#xF1;o de Educaci&#xF3;n Media del Plan de Formaci&#xF3;n Diferenciada, que se indican en la presente resoluci&#xF3;n exenta.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><br></div>", "i": 9652427}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de noviembre de 2015.- Gonzalo Mu&#xF1;oz Stuardo, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 9652428}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7316 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-7316 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 7.316, DE 19.11.2015", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; IdDO 971391"], "derogacion_tacita": [], "de