{"html": [{"t": "<div><div class=\"p\">DELEGA FACULTAD QUE INDICA</div><br><br></div>", "i": 7340031}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta de la Direcci&#xF3;n de Grandes Contribuyentes del Servicio de Impuestos Internos N&#xBA; 64, del 3 de abril de 2007, que delega facultad de autorizar a los contribuyentes de la N&#xF3;mina de Grandes Contribuyentes, el pago diferido del Impuesto a la Renta, en funcionarios de su dependencia. Bernardo Seaman Gonz&#xE1;lez, Director Direcci&#xF3;n Grandes Contribuyentes.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl).</div><br></div>", "i": 7340032}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "64 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-64 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DELEGA FACULTAD QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-04-03", "doble_articulado": false, "id_norma": "260090", "numero_fuente": "38740", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-04-17", "vigencias": [{"desde": "2007-04-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-04-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-04-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fech