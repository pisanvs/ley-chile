{"html": [{"t": "<div><div class=\"p\">DELEGA FACULTADES QUE SE INDICAN</div></div>", "i": 10116943}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n N&#xB0; 1.341, de 20 de abril de 2020, de la Direcci&#xF3;n Regional Aduana Valpara&#xED;so del Servicio Nacional de Aduanas, delega la facultad de disponer la devoluci&#xF3;n de derechos pagados en los casos de los art&#xED;culos 131 bis, 132 y 134 todos de la Ordenanza de Aduanas, a los funcionarios que se indican.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento est&#xE1; publicado en la p&#xE1;gina web www.aduana.cl.- </div><br></div>", "i": 10116944}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Roberto Fern&#xE1;ndez&nbsp; Olivares, Director Regional Aduana Valpara&#xED;so.</div></div>", "i": 10116945}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1341", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1341"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN REGIONAL ADUANA DE VALPARAÍSO"], "titulo_norma": "DELEGA FACULTADES QUE SE INDICAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1755927", "EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2020-04-20", "fecha_derogacion": "2024-12-27", "doble_articulado": false, "id_norma": "1144702", "numero_fuente": "42643", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2020-04-29", "vigencias": [{"desde": "2024-12-27", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2020-04-29", "hasta": "2024-12-26", "tipo_version": "0", "tipo_vers