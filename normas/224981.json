{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6478343}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 1.126, de 29 de abril de 2004, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de la resoluci&#xF3;n N&#xBA; 63 de 2004, modificada mediante resoluci&#xF3;n N&#xBA; 771 de 2004, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Distribuci&#xF3;n espacio-temporal de las capturas de Jurel, I y II Regi&#xF3;n (A&#xF1;o 2004), en el sentido de se&#xF1;alar que la pesca de investigaci&#xF3;n se extender&#xE1; hasta el 31 de diciembre de 2004.</div><br></div>", "i": 6478344}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Valpara&#xED;so, 29 de Abril de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6478345}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1126 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1126 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-29", "doble_articulado": false, "id_norma": "224981", "numero_fuente": "37857", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-05-11", "vigencias": [{"desde": "2004-05-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-05-11", "fin_vigencia": ""}, "vigencias_ve