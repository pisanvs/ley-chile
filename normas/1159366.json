{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Venta de naipes</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 6 de setiembre de 1814.</div></div>", "i": 10227868}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Es libre la declaracion de naipes como parece a la Direccion de tabacos, Ministerios Fiscales, e Intendencia de Hacienda. Los individuos que se encarguen de esta industria, deber&#xE1;n vender precisamente a la administracion de ramos unidos las barajas, estim&#xE1;ndose contrabando i, responsables a comiso los que se trataren de otro modo o espedicion entre particulares. T&#xF3;mese razon para su cumplimiento, i h&#xE1;gase notorio a los pretendientes. - </div></div>", "i": 10227869}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Uribe. - Mu&#xF1;oz.</div></div>", "i": 10227870}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Venta de naipes", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1814-09-06", "doble_articulado": false, "id_norma": "1159366", "numero_fuente": "1814", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1814-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1814-09-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1814-09-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2021-05-17", "fecha_version": "1814-09-06", "fecha_actualizacion_texto": "2021-05-17