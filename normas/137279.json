{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A COMERCIAL IMXE S.A.</div><br><br></div>", "i": 6171413}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/N&#xBA; Ex. 590, de fecha 29 de abril de 1999, otorga a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n a Comercial Imxe S.A., Rut.</div><div class=\"p\">N&#xBA;96.731.180-4, la calidad de agente retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las ventas de especies hidrobiol&#xF3;gicas, establecido en la resoluci&#xF3;n N&#xBA; Ex. 3.839/98, de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del d&#xED;a 01-07-98. </div></div>", "i": 6171414}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 29 de abril de 1999.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6171415}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "590 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-590 EXENTA"}, {"tipo": "3", "numero": "DRE-08-590 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-590 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A COMERCIAL IMXE S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-04-29", "doble_articulado": false, "id_norma": "137279", "numero_fuente": "36378", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-06-02", "vigencias": [{"desde": "199