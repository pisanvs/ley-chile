{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 183 EXENTO, DE 1994 </div></div>", "i": 5942442}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 183 de fecha 22 de Abril de 1994 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; al Centro de Formaci&#xF3;n T&#xE9;cnica Instituto de Massachussets, el Plan y Programa de Estudios de la Carrera y T&#xED;tulo de Nivel Superior que se indica, para ser impartida en la Casa Central de Talca, Sede N&#xB0; 1 de Curic&#xF3; y Sede N&#xB0; 2 de Linares, a contar del a&#xF1;o 1994:</div><br><div class=\"p\"> Carrera: Administraci&#xF3;n en Empresas menci&#xF3;n Personal o</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Marketing.</div><div class=\"p\"> T&#xED;tulo : T&#xE9;cnico en Administraci&#xF3;n de Empresas; o</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; T&#xE9;cnico en Administraci&#xF3;n de Empresas menci&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Personal o Marketing.-</div><br></div>", "i": 5942443}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5942444}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "183", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-183"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 183 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA INSTITUTO MASSACHUSSETS", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "ADMINISTRACION EMPRESAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-04-22", "doble_articulado": false, "id_norma": "20582", "numer