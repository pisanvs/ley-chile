{"html": [{"t": "<div><div class=\"p\">AMPLIA RESOLUCION EXENTA SEC No. 185/86</div><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 271 exenta.- Santiago, 22 de Abril de 1986.- Visto: Lo dispuesto en la Resoluci&#xF3;n Exenta de SEC No. 185/86, publicada en el Diario Oficial No. 32.431 de fecha 25.03.86.</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 6242539}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1&#xB0; Ampl&#xED;ase dicha resoluci&#xF3;n en el sentido de agregar al Resuelvo 1&#xB0;, lo siguiente:</div><div class=\"p\">&nbsp; &nbsp;  13.- Calefones</div><div class=\"p\">&nbsp; &nbsp;  14.- Llaves de control</div><br><div class=\"p\">&nbsp; &nbsp;  2&#xB0; La presente resoluci&#xF3;n entrar&#xE1; en vigencia una vez que haya sido publicada en el Diario Oficial por cuenta del interesado.</div><br></div>", "i": 6242540}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, notif&#xED;quese y publ&#xED;quese.- Francisco Cabello Riveros, Coronel (B) Superintendente.</div><div class=\"p\">&nbsp; &nbsp;  Lo que comunico a Ud. para su conocimiento.- Saluda atentamente a Ud.- Gregoria Castillo M., Jefe Div. Administraci&#xF3;n y Finanzas.</div><br></div>", "i": 6242541}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "271 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-271 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "SUPERINTENDENCIA DE ELECTRICIDAD Y COMBUSTIBLES"], "titulo_norma": "AMPLIA RESOLUCION EXENTA SEC No. 185/86", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fe