{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6128426}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP No. 879, de 30 de junio de 1998, se expropiaron los lotes de terreno No. s. 13 y 11-A, superficies 158 y 2.131 m2. respectivamente, rol de aval&#xFA;o 46-36 y rol de aval&#xFA;o en tr&#xE1;mite, comuna de Teno, para la obra Camino Ruta J-30-I, Sector Cuesta El Peral Teno y se acord&#xF3; precio de las indemnizaciones con su propietario Jos&#xE9; Mar&#xED;a Garc&#xED;a Aretio, ascendentes a las cantidades de $ 20.572.- para el lote No. 13 y en $ 392.627.- para el lote No. 11-A.</div><br></div>", "i": 6128427}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6128428}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "879", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-879"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "TENO", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-06-30", "doble_articulado": false, "id_norma": "123872", "numero_fuente": "36154", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-09-01", "vigencias": [{"desde": "1998-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1998-09-04", "fecha_version": "1998-09-01",