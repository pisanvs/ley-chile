{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6466532}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 443, de 17 de febrero de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a ALIMENTOS MARINOS S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Panilonco&quot;, donde podr&#xE1; capturar los siguientes recursos hidrobiol&#xF3;gicos: a) En el &#xE1;rea mar&#xED;tima correspondiente a las Regiones III, IV, V, VI, VIII y X, por fuera del &#xE1;rea de reserva artesanal, con cerco: Jibia; b) En el &#xE1;rea mar&#xED;tima correspondiente a III Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, con arrastre de media agua: Jibia; c) En el &#xE1;rea mar&#xED;tima correspondiente a las Regiones IV, V, VI, VII y X, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua: Jibia.</div><br></div>", "i": 6466533}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de febrero de 2004.- Jessica Fuentes Olmos, Subsecretario de Pesca (S).</div><br></div>", "i": 6466534}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "443", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-443"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-02-17", "fecha_derogacion": "2020-12-30", "doble_articulado": false, "id_norma": "221755", "numero_fuente": "37797", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-02-27", "vigencias": [{"desde": "2020-12-30", "hasta": "", "tipo_version": "2", "tipo_versio