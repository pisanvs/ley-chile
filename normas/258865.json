{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6603220}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 740, de 28 de febrero de 2007, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de las resoluciones N&#xBA; 284, de 2000, y N&#xBA; 52, de 2003, ambas de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autorizaron a SOCIEDAD PESQUERA VIENTO SUR S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Do&#xF1;a Mariana&quot;, entre la IV a VIII Regiones, sobre el recurso hidrobiol&#xF3;gico Reineta, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado en informe t&#xE9;cnico citado en Visto.</div><br></div>", "i": 6603221}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de febrero de 2007.- Mar&#xED;a Angela Barbieri Bellolio, Subsecretaria de Pesca (S). </div></div>", "i": 6603222}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "740 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-740 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-02-28", "doble_articulado": false, "id_norma": "258865", "numero_fuente": "38707", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-03-07", "vigencias": [{"desde": "2007-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-03-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-03-07",