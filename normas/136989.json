{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,246.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170516}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.-&nbsp; En atencion a los servicios prestados al pais por el teniente-coronel de Ej&#xE9;rcito, don Ismael Guzman, el&#xE9;vase, por gracia, a ciento cincuenta pesos mensuales la pension de montep&#xED;o militar de que actualmente disfrutan su viuda e hijos.</div><br></div>", "i": 6170517}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica. T&#xF3;mese razon, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Boletin de las Leyes i Decretos del Gobierno.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veinticuatro de enero de mil novecientos diez.-&nbsp; Pedro Montt.-&nbsp; A. Rodr&#xED;guez H.</div><br></div>", "i": 6170518}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2246", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2246"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-01-24", "doble_articulado": false, "id_norma": "136989", "numero_fuente": "9614", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-02-11", "vigencias": [{"desde": "1910-02-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-02-11", "fin_vigenc