{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6231476}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n</div><div class=\"p\">exenta N&#xB0; 103 de 27 de Enero de 1986, conforme al</div><div class=\"p\">art&#xED;culo 5&#xB0; transitorio del C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento de aguas proporcionales que corresponden a las Parcelas N&#xB0;s. 1 a 29 y sitios N&#xB0;s A a P del Proyecto de Parcelaci&#xF3;n &quot;Vaquer&#xED;a&quot; de la Comuna de Negrete VIII Regi&#xF3;n, formado por el predio &quot;Una porci&#xF3;n de terreno que forma parte del fundo Vaquer&#xED;a&quot;. Los derechos de agua se extraen del R&#xED;o B&#xED;o-B&#xED;o, Canal B&#xED;o-B&#xED;o Negrete.- Publicaci&#xF3;n hecha conforme al art&#xED;culo 13 de la Ley N&#xB0; 18.377.</div><br></div>", "i": 6231477}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Ejecutivo.</div><br></div>", "i": 6231478}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "103 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-103 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-01-27", "doble_articulado": false, "id_norma": "155194", "numero_fuente": "32287", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-02-01", "vigencias": [{"desde": "1986-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-02-01", "fin