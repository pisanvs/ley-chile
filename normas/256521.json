{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N&#xBA; 1.310 </div></div>", "i": 6593855}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n Ordinaria N&#xBA; 1310, celebrada el 14 de diciembre de 2006, adopt&#xF3; el siguiente Acuerdo:</div><br><div class=\"p\">1310-01-061214 - Tasa de Inter&#xE9;s para pago diferido de Derechos de Aduana.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3;, en conformidad con lo establecido en la letra c) del art&#xED;culo 10 de la ley N&#xBA; 18.634, que la Tasa de Inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de Derechos de Aduana durante el semestre que expira el 30 de junio de 2007, ser&#xE1; de 6,9% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.</div><br></div>", "i": 6593856}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de diciembre de 2006.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6593857}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1310", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1310"}, {"tipo": "5", "numero": "1310-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1310-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION Nº 1.310", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA DE INTERES", "PAGO DIFERIDO", "DERECHOS DE ADUANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-12-14", "doble_articulado": false, "id_norma": "256521", "numero_fuente": "38642", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-12-19", "vigencias": [{"d