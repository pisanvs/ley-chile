{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 56 DE 1992 </div></div>", "i": 8667429}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 56 de 06 de marzo de 1992 se ha sustituido el plan de estudio aprobado por decreto supremo de Educaci&#xF3;n No. 42, de 1980, modificado por decreto supremo exento de Educaci&#xF3;n No. 278, de 1986, al Instituto Hebreo Comprehensivo Chaim Weizmann Ort, de Santiago, por el que se indica en este decreto, para ser aplicado a partir de 1992 de 1er. a&#xF1;o de Educaci&#xF3;n B&#xE1;sica a 4to. a&#xF1;o de Educaci&#xF3;n Media, simult&#xE1;neamente. Adem&#xE1;s, se aprueban programas para la asignatura de Historia Jud&#xED;a y Biblia.</div><br></div>", "i": 8667430, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">Santiago, 01 de Abril de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8667431}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "56 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-56 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 56 DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-03-06", "doble_articulado": false, "id_norma": "79002", "numero_fuente": "34247", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-04-20", "vigencias": [{"desde": "1992-04-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-04-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-04-20", "f