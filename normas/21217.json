{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 421, DE 1993 </div></div>", "i": 5944474}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 421 de 5 de agosto de 1993 se ha aprobado al Colegio &quot;Girolamo Longhi&quot;, de Villa Alemana, V Regi&#xF3;n de Valpara&#xED;so, un plan especial de estudio para los cursos de 1&#xB0; a 8&#xB0; a&#xF1;o b&#xE1;sico, para aplicarse a partir del a&#xF1;o escolar 1993.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa de la asignatura de Italiano para los cursos de 1&#xB0; a 8 a&#xF1;o b&#xE1;sico. </div></div>", "i": 5944475}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 19 de agosto de 1993.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5944476}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "421", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-421"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 421, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO GIROLAMO LONGHI", "VILLA ALEMANA", "QUINTA REGION", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "ESTABLECIMIENTOS EDUCACIONALES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-08-05", "doble_articulado": false, "id_norma": "21217", "numero_fuente": "34651", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-08-26", "vigencias": [{"desde": "1993-08-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-08-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-08-