{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 105, DE 1993 </div></div>", "i": 7160528}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 105 de fecha 08 de Marzo de 1993, del Ministerio de Educaci&#xF3;n, se aprobaron las adecuaciones introducidas al plan y programas de estudio del Centro de Formaci&#xF3;n T&#xE9;cnica CET de Santiago, correspondientes a la carrera de Turismo, las que se insertaron en la Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xB0; 887 de 1987 y Resoluci&#xF3;n Exenta N&#xB0; 1.410 de 1989 del Centro de Formaci&#xF3;n T&#xE9;cnica mencionado.</div><div class=\"p\">&nbsp; &nbsp; Dichas adecuaciones rigen para su sede Santiago, desde Agosto de 1992.-</div><br></div>", "i": 7160529}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n. + </div></div>", "i": 7160530}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "105 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-105 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 105, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA CET SANTIAGO", "PROGRAMAS", "ESTUDIOS. PLANES ESTUDIOS", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-03-08", "doble_articulado": false, "id_norma": "20178", "numero_fuente": "34627", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-07-29", "vigencias": [{"desde": "1993-07-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-07-29", "fin_vigencia": ""}, "vigencias_version_