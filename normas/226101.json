{"html": [{"t": "<div><div class=\"p\">SOLICITA CONSTITUCION DEL PARTIDO HUMANISTA EN LA XII REGION </div></div>", "i": 6482406}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Efr&#xE9;n Osorio Jara y Maril&#xE9;n Cabrera Olmos, Presidente y Secretaria General del Partido Humanista, respectivamente, han solicitado la constituci&#xF3;n legal del partido en la Regi&#xF3;n XII de Magallanes y de la Ant&#xE1;rtica Chilena, acompa&#xF1;ando 542 fichas de afiliaciones.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xBA; de la ley N&#xBA; 18.603, por resoluci&#xF3;n O-N&#xBA; 0915 de fecha 27 de mayo de 2004. </div></div>", "i": 6482407}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Elizabeth Cabrera Burgos, Directora (S). </div></div>", "i": 6482408}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "915", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-915"}, {"tipo": "3", "numero": "O-915", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-915"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCION DEL PARTIDO HUMANISTA EN LA XII\nREGION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO HUMANISTA", "DECIMOSEGUNDA REGION", "CONSTITUCION LEGAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-27", "doble_articulado": false, "id_norma": "226101", "numero_fuente": "37878", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-05", "vigencias": [{"desde": "2004-06-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-06-05", "fin_vigencia":