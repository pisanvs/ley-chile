{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 192, DE 1990 </div></div>", "i": 7217358}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 192 de 31 de julio de 1990 se ha modificado el decreto supremo exento de Educaci&#xF3;n No. 178, de 1986 que aprob&#xF3; planes y programas especiales de estudio para 2&#xB0; ciclo de la Educaci&#xF3;n Media T&#xE9;cnico - Profesional al Liceo T&#xE9;cnico A No. 57 de &#xD1;u&#xF1;oa.</div><br><div class=\"p\">Adem&#xE1;s, se ha modificado el art&#xED;culo 2&#xB0; del decreto supremo exento de Educaci&#xF3;n No. 144, de 1990 en la forma que indica este decreto.</div><br></div>", "i": 7217359}, {"t": "<div><div class=\"p\">Santiago, 28 de Agosto de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7217360}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "192 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-192 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 192, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-07-31", "doble_articulado": false, "id_norma": "82407", "numero_fuente": "33763", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-09-05", "vigencias": [{"desde": "1990-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-09-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-09-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"