{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 33 EXENTO, DE 1995 </div></div>", "i": 7160154}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 33 de fecha 9 de Enero de 1995 del Ministerio de Educaci&#xF3;n, se elimin&#xF3; del Registro de Institutos Profesionales el N&#xB0; 67 correspondiente al Instituto Profesional de Ays&#xE9;n, organizado por la Sociedad Acherma Limitada, autorizado a funcionar por Decreto Exento de Educaci&#xF3;n N&#xB0; 53 de fecha 14 de febrero de 1990.</div><div class=\"p\">&nbsp; &nbsp; Decl&#xE1;rase que lo dispuesto precedentemente importa la p&#xE9;rdida del reconocimiento oficial del Instituto Profesional de Ays&#xE9;n.</div><br></div>", "i": 7160155}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 25 de Enero de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160156}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "33 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-33 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 33 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA", "INSTITUTO PROFESIONAL", "AYSEN", "RECONOCIMIENTO OFICIAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-01-09", "doble_articulado": false, "id_norma": "19811", "numero_fuente": "35085", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-02-04", "vigencias": [{"desde": "1995-02-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-02-04", "fin_vigencia": ""}, "vigencias_version_norm