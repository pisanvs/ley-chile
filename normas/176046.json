{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6302437}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.919, de 6 de septiembre de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a LINO DEL TRANSITO CONTRERAS TAPIA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en Panamericana Norte Km. 898, Caldera, comuna de Caldera, provincia de Copiap&#xF3;, III Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Secado y picado de algas: Huiro negro o Chasc&#xF3;n, Huiro palo, Huiro flotador.</div><br></div>", "i": 6302438}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de septiembre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6302439}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1919", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1919"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-06", "doble_articulado": false, "id_norma": "176046", "numero_fuente": "36771", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-25", "vigencias": [{"desde": "2000-09-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-09-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac