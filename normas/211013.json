{"html": [{"t": "<div><div class=\"p\">AUTORIZA A PESQUERA GUANAYE S.A. PARA AMPLIAR SUS ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 6426187}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 358, de 26 de Octubre de 1981, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Pesquera Guanaye S.A. para incluir en el establecimiento de cultivo que tiene autorizado por decreto de Agricultura N&#xB0; 73, de 1975, en Bah&#xED;a Mejillones del Sur, II Regi&#xF3;n, el recurso hidrobiol&#xF3;gico osti&#xF3;n, Chlamys purpurata. Emplear&#xE1; en la formaci&#xF3;n del cultivo la semilla que capte en 4 balsas de 1.000 cuerdas cada una, que ubicar&#xE1; en la concesi&#xF3;n donde tiene instalado el establecimiento.</div><br></div>", "i": 6426188}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Roberto Verdugo Gormaz, Subsecretario de Pesca. </div></div>", "i": 6426189}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "358", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-358"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA GUANAYE S.A. PARA AMPLIAR SUS\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1981-10-26", "fecha_derogacion": "1995-05-30", "doble_articulado": false, "id_norma": "211013", "numero_fuente": "31107", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1981-11-04", "vigencias": [{"desde": "1995-05-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1981