{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6510144}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.398, de 29 de noviembre de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a CARLOS EDUARDO BELLO BARRIA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Alberto De Agostini N&#xBA; 918, Puerto Natales, XII Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco-enfriado, Fresco-refrigerado, Congelado, Seco, Salado, Ahumado y Alga seca, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6510145}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de noviembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6510146}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3398 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3398 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-29", "doble_articulado": false, "id_norma": "233939", "numero_fuente": "38045", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-27", "vigencias": [{"desde": "2004-12-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-12-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-12-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci