{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8327557}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xBA;. 185 de 31 de Enero de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 2&#xB0; de la resoluci&#xF3;n No. 27, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a EXPORTACIONES PRODUCTOS DEL MAR B &amp; D S.A., RUT No.</div><div class=\"p\">96.513.150-7 domiciliada en Santiago, para ampliar actividades pesqueras extractivas, en el sentido de autorizar la sustituci&#xF3;n de 2 embarcaciones en construcci&#xF3;n de 650 m3 cada una de capacidad de bodega por la nave &quot;Antartic&quot; de 1.171 m3 de capacidad de bodega, especific&#xE1;ndose adem&#xE1;s sus restantes caracter&#xED;sticas n&#xE1;uticas.</div><br></div>", "i": 8327558}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 31 de Enero de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8327559}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "185", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-185"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-01-31", "fecha_derogacion": "1993-10-26", "doble_articulado": false, "id_norma": "96562", "numero_fuente": "33896", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-02-16", "vigencias": [{"desde": "1993-10-26", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1991-02-16", "hasta": "19