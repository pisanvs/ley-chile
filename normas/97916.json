{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE EXPROPIACION </div></div>", "i": 6107632}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Decreto Secc. 2&#xBA; N&#xBA; 156, de 9/3/98, Alcalde Municipalidad Santiago dispone expropiaci&#xF3;n parcial, conforme Art. 85 decreto 458 Ministerio Vivienda y Urbanismo inmueble Catedral 1239/1267 (S&#xF3;tero del R&#xED;o 508-554), Rol N&#xBA; 188-103, comuna Santiago, dominio aparente Inmobiliaria Deza y C&#xED;a. Ltda. superficie aproximada 575 mts.2. Deslindes: Norte, 10 mts. otros propietarios; Sur, 15,66 mts. utilizando 2 ochavos reglamentarios en Catedral; Oriente, 56,90 mts. con resto predio; Poniente, 56,90 mts. resto predio. Indemnizaci&#xF3;n $209.624.000.- pagadera contado. </div></div>", "i": 6107633}, {"t": "<div><div class=\"p\">Jaime Ravinet de la Fuente, Alcalde de Santiago. </div></div>", "i": 6107634}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "156", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-156"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "EXTRACTO DE EXPROPIACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-03-09", "doble_articulado": false, "id_norma": "97916", "numero_fuente": "36030", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-04-01", "vigencias": [{"desde": "1998-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe