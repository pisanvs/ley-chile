{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 600 EXENTO, DE 1998</div><br><br></div>", "i": 7234301}, {"t": "<div><div class=\"p\">Por decreto exento N&#xBA; 600 de fecha 20 de mayo de 1998 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Inacap, las adecuaciones al plan y programas de estudios de la carrera de Mec&#xE1;nica Automotriz. En consecuencia, se modifica el decreto exento del Ministerio de Educaci&#xF3;n N&#xBA; 500 del 6 de mayo de 1997, en el sentido de incorporar dichas adecuaciones, las que podr&#xE1;n aplicarse a contar del a&#xF1;o 1998.</div><br></div>", "i": 7234302}, {"t": "<div><div class=\"p\">Santiago, 5 de junio de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7234303}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "600 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-600 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 600 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "CENTRO DE FORMACION TECNICA INACAP", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-05-20", "doble_articulado": false, "id_norma": "120397", "numero_fuente": "36096", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-06-23", "vigencias": [{"desde": "1998-06-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-06-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-06-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p