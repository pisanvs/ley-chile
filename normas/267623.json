{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6745846}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 757, de 24 de octubre de 2007, y de conformidad a la facultad otorgada por el DL N&#xBA; 2.186, de 1978, se modific&#xF3; el decreto MOP N&#xBA; 1.970, de 16 de mayo de 2000, s&#xF3;lo en cuanto a dejar sin efecto la expropiaci&#xF3;n del lote de terreno N&#xBA; 26-2, de 631 m2, rol de aval&#xFA;o 329-116, comuna de Purranque, de propiedad de Gimpel Nannig Alfredo C., para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: R&#xED;o Bueno - Puerto Montt. Sector: Cuatro Vientos Km. 959,840 al Km. 961,200, D&#xE9;cima Regi&#xF3;n, por no ser necesario para la obra. </div></div>", "i": 6745847}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6745848}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "757", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-757"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-24", "doble_articulado": false, "id_norma": "267623", "numero_fuente": "38937", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-15", "vigencias": [{"desde": "2007-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-12-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion