{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 1,941.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al teniente del Resguardo de la Aduana de Puerto Montt, don Nicasio Andrade Huidobro, para los efectos de su jubilacion, el abono del tiempo que sirvi&#xF3; en los empleos de cajero en la oficina de enganche de marineros en la provincia de Chilo&#xE9; i de comandante de polic&#xED;a de Puerto Montt. </div></div>", "i": 6165944}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veinticuatro de junio de mil novecientos siete.- Pedro Montt.- Guillermo Subercaseaux. </div></div>", "i": 6165945}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1941", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1941"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-06-24", "doble_articulado": false, "id_norma": "135595", "numero_fuente": "8842", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-07-06", "vigencias": [{"desde": "1907-07-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-07-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1907