{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA</div><br><br><br><br></div>", "i": 8322467}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.604, de 06 de Noviembre de 1989 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n se modifica el numeral 3&#xB0; de la resoluci&#xF3;n No. 1.170, de 1989, de esta Subsecretar&#xED;a que autoriz&#xF3; a don Jacobo Ortiz Moreno R.U.T. No. 2.883 536-1, domiciliado en San Antonio, calle Luis Cabrera No. 107, para iniciar actividades pesqueras, en el sentido de autorizar al solicitante para extraer el recurso Albacora o pez espada, (Xiphias gladius), en el litoral de las Regiones I a X, no obstante lo se&#xF1;alado en dicha resoluci&#xF3;n, respecto de las zonas a operar.</div><br></div>", "i": 8322468}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 06 de Noviembre de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8322469}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1604", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1604"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1989-11-06", "fecha_derogacion": "1990-06-01", "doble_articulado": false, "id_norma": "92921", "numero_fuente": "33534", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1989-11-29", "vigencias": [{"desde": "1990-06-01", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1989-11-29", "hasta": "1