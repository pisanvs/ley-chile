{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 1.235 EXENTA, DE 2010</div></div>", "i": 8945677}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.235 de fecha 10 de mayo de 2010, el Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, autoriz&#xF3; a la empresa chilena &quot;Transportes Cometa S.A.&quot;, para efectuar transporte internacional terrestre de pasajeros, por 5 meses a contar del 15 de mayo de 2010, entre Chile y Per&#xFA;, y viceversa, atendiendo el servicio Santiago (Chile)/Lima (Per&#xFA;), utilizando el paso fronterizo Concordia con 1 (una) frecuencia semanal de ida y vuelta.- </div></div>", "i": 8945678}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Gloria Hutt Hesse, Subsecretaria de Transportes.</div></div>", "i": 8945679}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1235 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1235 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 1.235 EXENTA, DE 2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-05-10", "doble_articulado": false, "id_norma": "1015222", "numero_fuente": "39709", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-07-13", "vigencias": [{"desde": "2010-07-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-07-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-07-13", "fin_vigencia": "", "tipo_version": "3"}], "