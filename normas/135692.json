{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8344362}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;651, de 22 de abril de 1999, de esta Subsecretar&#xED;a, modif&#xED;case la resoluci&#xF3;n N&#xBA;1.901 de 1998, de esta Subsecretar&#xED;a, que fij&#xF3; la n&#xF3;mina&nbsp; de armadores y embarcaciones autorizados para operar en la unidad de pesquer&#xED;a de Camar&#xF3;n nailon, Heterocarpus reedi, declarada en estado de plena explotaci&#xF3;n y sometido a dicho r&#xE9;gimen de administraci&#xF3;n, en el litoral de la II a la VIII Regiones por el D.S. N&#xBA;611 de 1995, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, en el &#xE1;rea se&#xF1;alada en sus respectivas autorizaciones, en el sentido de incorporar en su numeral 1&#xBA; lo siguiente: &apos;&apos;Gast&#xF3;n Edmundo Mendoza G&#xF3;mez: Ikela&apos;&apos;.</div><br></div>", "i": 8344363}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de abril de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8344364}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "651", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-651"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-04-22", "fecha_derogacion": "1999-07-17", "doble_articulado": false, "id_norma": "135692", "numero_fuente": "36351", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-04-29", "vigencias": [{"desde": "1999-07-17", "hasta": "", "tipo_v