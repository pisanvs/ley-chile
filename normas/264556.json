{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7353030}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.667, de 3 de septiembre</div><div class=\"p\">de 2007, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad</div><div class=\"p\">parcial de la resoluci&#xF3;n N&#xBA; 694 de 2003, de esta</div><div class=\"p\">Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PEMESA S.A.</div><div class=\"p\">para realizar actividades pesqueras extractivas con la</div><div class=\"p\">nave &quot;Don Manuel&quot;, en la Isla de Pascua, Archipi&#xE9;lago de</div><div class=\"p\">Juan Fern&#xE1;ndez, Islas Sala y G&#xF3;mez e Islas</div><div class=\"p\">Desventuradas, con arrastre, sobre el recurso Alfonsino</div><div class=\"p\">Beryx splendens, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la ley General de Pesca y Acuicultura y lo informado mediante informe t&#xE9;cnico citado en Visto.</div><br></div>", "i": 7353031}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de septiembre de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7353032}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2667 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2667 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-09-03", "doble_articulado": false, "id_norma": "264556", "numero_fuente": "38859", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publica