{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6364292}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.835, de 31 de octubre del 2001, se expropi&#xF3; el lote de terreno N&#xBA;1-1, superficie 958 m2., rol de aval&#xFA;o 230-116, comuna de Chimbarongo, para la obra Concesi&#xF3;n Internacional Ruta 5, Tramo: Santiago-Talca Sector J: Kms. 151.500,00 al 161.650,00, Sexta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Juan Carlos Ahumada Cabello, ascendente a la cantidad de $2.871.904.</div><br></div>", "i": 6364293}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6364294}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1835", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1835"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-10-31", "doble_articulado": false, "id_norma": "193279", "numero_fuente": "37149", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-02", "vigencias": [{"desde": "2002-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2002-01-04", "fecha_version": "2002-01-02", "fecha_actualizacion_texto": "2002-01-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estruc