{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 465 EXENTO, DE 1994 </div></div>", "i": 7161901}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 465 de fecha 10 de Octubre de 1994 del Ministerio de Educaci&#xF3;n, se sustituy&#xF3; el art&#xED;culo 1&#xB0; del Decreto Exento N&#xB0; 134 de 1989, correspondiente al Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Bernardo O&apos;Higgins IBO, por el siguiente nuevo:</div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1&#xB0;: Autor&#xED;zase el funcionamiento del Centro de Formaci&#xF3;n T&#xE9;cnica que se indica, organizado por la persona jur&#xED;dica que se se&#xF1;ala, cuyo fin es la docencia a nivel t&#xE9;cnico para egresados de ense&#xF1;anza media:</div><div class=\"p\"> Nombre de la Instituci&#xF3;n&nbsp; : Centro de Formaci&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  T&#xE9;cnica Bernardo</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  O&apos;Higgins de Copiap&#xF3;.</div><br><div class=\"p\"> Domicilio&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  : Copiap&#xF3;</div><br><div class=\"p\"> Organizador&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  : Sociedad Grawe y Compa&#xF1;&#xED;a</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Limitada o Centro de</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Formaci&#xF3;n T&#xE9;cnica Bernardo</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  O&apos;Higgins de Copiap&#xF3;</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Limitada.&quot;.</div><br></div>", "i": 7161902}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 26 de Octubre de 1994.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161903}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "465 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-465 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 465 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "CENTRO FORMACION TECNICA BERNARDO", "O'HIGGINS", "COPIAPO", "TERCERA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-10-10", "doble_articulado": false, "id_norma": "21297", "numero_fuente": "35119", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-03-16", "vigencias": [{"desde": "1995-03-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-03-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-03-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "fecha_version": "1995-03-16", "fecha_actualizacion_texto": "1995-03-16", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 7161901}, {"n": "Artículo", "i": 7161902, "t": 6}, {"n": "Promulgación", "i": 7161903}]}