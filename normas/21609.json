{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 637 EXENTO, DE 1993 </div></div>", "i": 7162158}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 637 de fecha 7 de diciembre de</div><div class=\"p\">1993 del Ministerio de Educaci&#xF3;n, se sustituy&#xF3; el</div><div class=\"p\">art&#xED;culo 1&#xB0; del Decreto Exento de Educaci&#xF3;n N&#xB0; 66 del 27 de febrero de 1990, correspondiente al Instituto Profesional Instituto John F. Kennedy, por el siguiente nuevo:</div><div class=\"p\">&nbsp; &nbsp; &quot;Autor&#xED;zase el funcionamiento del Instituto Profesional que se indica, organizado por la persona jur&#xED;dica que se se&#xF1;ala:</div><br><div class=\"p\"> Nombre de la Instituci&#xF3;n : Instituto Profesional John F. Kennedy.</div><div class=\"p\"> Domicilio : Santiago.</div><div class=\"p\"> Organizador : Sociedad Instituto Profesional John F. Kennedy Limitada&quot;.</div><br></div>", "i": 7162159}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n. + </div></div>", "i": 7162160}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "637 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-637 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 637 EXENTO, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "INSTITUTO PROFESIONAL JOHN F. KENNEDY"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-12-07", "doble_articulado": false, "id_norma": "21609", "numero_fuente": "34822", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-03-23", "vigencias": [{"desde": "1