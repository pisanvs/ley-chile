{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETO N&#xBA; 1.336 EXENTO, DE 2012</div></div>", "i": 9372458}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 846, de 26 de agosto de 2013, de este Ministerio, modif&#xED;case el art&#xED;culo 2&#xBA; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1047817&amp;idParte=0&amp;idVersion=\">decreto exento N&#xBA; 1.336 de 2012</a>, modificado mediante los decretos exentos N&#xBA; 195, N&#xBA; 427 y N&#xBA; 579, todos de 2013 y del Ministerio de Econom&#xED;a, Fomento y Turismo, en el sentido de reemplazar la tabla ah&#xED; indicada por la siguiente:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/34342.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9372459}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de agosto de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9372460}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "846 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-846 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA DECRETO Nº 1.336 EXENTO, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_prom