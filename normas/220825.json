{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6462174}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 237 exenta, de 21 de enero de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA UNI SEA FOODS S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, en orden de incorporar a la planta ubicada en camino Astillero, sector Hue&#xF1;ocoihue, comuna de Dalcahue, X Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de Cocido, Fresco-Enfriado, Fresco-Refrigerado, Congelado, Seco-Salado, Conserva y Deshidratado, el recurso hidrobiol&#xF3;gico indicado en la resoluci&#xF3;n extractada. </div></div>", "i": 6462175}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de enero de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6462176}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "237 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-237 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-01-21", "fecha_derogacion": "2005-06-28", "doble_articulado": false, "id_norma": "220825", "numero_fuente": "37776", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-02-03", "vigencias": [{"desde": "2005-06-28", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-02-03", "hasta": "2005-06-27", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2005-06-28", "fin_vigencia": ""}, "vigencias