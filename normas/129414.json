{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 115, DE 1988 </div></div>", "i": 6146939}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 115 de 24 de junio de 1988 se ha aprobado para el Liceo Industrial A No. 96 de San Miguel, provincia de Santiago, Regi&#xF3;n Metropolitana, planes y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico-Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar de 1988 y hasta el a&#xF1;o escolar de 1990, en la Rama Industrial, Especialidades de: Fotomec&#xE1;nica Impresi&#xF3;n Gr&#xE1;fica y Composici&#xF3;n Gr&#xE1;fica. </div></div>", "i": 6146940}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13.07.88.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6146941}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "115 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-115 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 115, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-06-24", "doble_articulado": false, "id_norma": "129414", "numero_fuente": "33149", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-08-18", "vigencias": [{"desde": "1988-08-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-08-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-08-18", "fin_vigencia": "", "tipo_version": "