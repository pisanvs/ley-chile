{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8315259}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.661, de 3 de diciembre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case&nbsp; el numeral 1 de la Resoluci&#xF3;n N&#xBA; 652 de 1997 y numeral 2 de la Resoluci&#xF3;n N&#xBA; 653 de 1997, ambas de esta Subsecretar&#xED;a, que se&#xF1;alan las caracter&#xED;sticas n&#xE1;uticas de la nave &quot;Angamos 3&quot;, de EMPRESA PESQUERA EPERVA S.A., ex Pesquera Punta Angamos S.A., en el sentido de establecer que la capacidad de Bodega de dicha nave es 440,42 m3.</div><br></div>", "i": 8315260}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de diciembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8315261}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1661", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1661"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "EMPRESA PESQUERA EPERVA S.A.", "NAVES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-03", "doble_articulado": false, "id_norma": "83553", "numero_fuente": "35944", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-12-19", "vigencias": [{"desde": "1997-12-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-12-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-12-19", "fin_vigencia": "