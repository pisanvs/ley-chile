{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8303298}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 678, de 9 de mayo de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 1 de la Resoluci&#xF3;n N&#xBA; 169 de 1997, de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a ALIMENTOS MARINOS S.A., para operar por sustituci&#xF3;n la nave &quot;Panilonco&quot;, en el sentido de se&#xF1;alar que las naves sustitutas que entran a operar son once y no diez como all&#xED; se indica. </div></div>", "i": 8303299}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de mayo de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8303300}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "678", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-678"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "AUTORIZACION", "PESCA", "ALIMENTOS MARINOS S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-05-09", "fecha_derogacion": "2020-12-30", "doble_articulado": false, "id_norma": "73037", "numero_fuente": "35777", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-05-30", "vigencias": [{"desde": "2020-12-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1997-05-30", "hasta": "2020-12-29", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2020-12-30", "fin_vigencia": ""