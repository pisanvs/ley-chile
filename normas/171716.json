{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7271397}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 1.100, de 20 de junio de 2000, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xB0; de la resoluci&#xF3;n N&#xB0;1.761, de 1996, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a PESQUERA BIO BIO S.A., para ampliar actividades pesqueras extractivas con la nave &apos;&apos;Loa 24&apos;&apos;, matr&#xED;cula 2840, en el sentido de eliminar la frase que indica que los recursos all&#xED; autorizados lo fueron en calidad de fauna acompa&#xF1;ante, en virtud de constituir especies objetivo.</div><br></div>", "i": 7271398}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de junio de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7271399}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1100", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1100"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-06-20", "fecha_derogacion": "2006-11-23", "doble_articulado": false, "id_norma": "171716", "numero_fuente": "36703", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-07-03", "vigencias": [{"desde": "2006-11-23", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2000-07-03", "hasta": "2006-11-22", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2006-11-23", "fin_vigencia": ""}, "vigenc