{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6526459}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP N&#xB0; 473, de 28 de junio de 1996. se expropiaron los lotes de terreno N&#xBA;s. 46, 47, 47-A, 48, 49 y 51, superficies 7.920, 3.840, 1.681, 490, 761 y 144 M2., rol de aval&#xFA;o 315-55; comuna de Quirihue, para la obra Camino Cauquenes L&#xED;mite Regional Quirihue, sector Cuesta y se acord&#xF3; precio de la indemnizaci&#xF3;n con su propietario Ra&#xFA;l Molina Molina, ascendente a la cantidad de $1.362.624.</div><br></div>", "i": 6526460}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6526461}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "473", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-473"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-06-28", "doble_articulado": false, "id_norma": "238090", "numero_fuente": "35557", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-09-02", "vigencias": [{"desde": "1996-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-09-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-05-16", "fecha_version": "1996-09-02", "fecha_actualizacion_texto": "1996-09-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n