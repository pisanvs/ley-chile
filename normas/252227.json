{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACIONES DE INMUEBLES QUE INDICA </div><div class=\"p\">NOTIFICACION </div></div>", "i": 6579322}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 426, de 25 de julio de 2006, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n total, conforme D.L. N&#xBA; 2.186 de 1978, del inmueble ubicado en calle Pir&#xE1;mide 519, presunto Rol de Aval&#xFA;o N&#xBA; 4940-69, comuna de San Miguel, aparente dominio de don Francisco Javier Fern&#xE1;ndez Gonz&#xE1;lez. Comisi&#xF3;n integrada por peritos Victoria Blanco Costa, arquitecto, Ver&#xF3;nica Olivier Valdebenito, arquitecto y Nicol&#xE1;s Romero Morales, ingeniero comercial. Seg&#xFA;n informe de 30 de mayo de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $29.638.200.- pagadera al contado.</div><br></div>", "i": 6579323}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 6579324}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "426", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-426"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "ORDENA EXPROPIACIONES DE INMUEBLES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-25", "doble_articulado": false, "id_norma": "252227", "numero_fuente": "38540", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-08-16", "vigencias": [{"desde": "2006-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vi