{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,125.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6177075}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Emma Munizaga, viuda del piloto primero de la Armada, don Lennart Dehlberg i a sus hijos menores, una pension anual de&nbsp; un mil ochocientos pesos ($ 1,800) de que disfrutar&#xE1;n en conformidad a la lei de montep&#xED;o militar.</div><br></div>", "i": 6177076}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, a cuatro de setiembre de mil novecientos dieciseis.- Juan Luis Sanfuentes.- J. Boonen Rivera. </div></div>", "i": 6177077}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3125", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3125"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-09-04", "doble_articulado": false, "id_norma": "138954", "numero_fuente": "11567", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-09-06", "vigencias": [{"desde": "1916-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1916-09-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1916-09-06", "fin_vigencia": "", "tipo_version": "3"}], "even