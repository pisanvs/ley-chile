{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9253946}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (Exento) N&#xB0;538 de fecha 23 de marzo de 2012, de conformidad a lo dispuesto en el art. 105 del DFL. MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;14, superficie 2.169 m2, rol de aval&#xFA;o 1225-9, para la obra &quot;REPOSICI&#xD3;N PUENTE MECHAICO Y ACCESOS EN RUTA 5&quot;, Comuna de Ancud, Provincia de Chilo&#xE9;, Regi&#xF3;n DE LOS LAGOS. La comisi&#xF3;n de peritos, integrada por Patricio Fernando Casagrande Ulloa, Sonia Catalina Gallegos Blanch y Norman Estanislao Calder&#xF3;n Pontiggia, fij&#xF3; el valor de tasaci&#xF3;n con fecha 09 de marzo de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietaria MAR&#xCD;A HERMINIA BUSTAMANTE, en la cantidad de $3.294.331.- suma que e pagar&#xE1; al contado.</div></div>", "i": 9253947}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9253948}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "538 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-538 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-03-23", "doble_articulado": false, "id_norma": "1039579", "numero_fuente": "40251", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-05-02", "vigencias": [{"desde": "2012-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-05-02", "fin_vigencia": ""}, "vigencia