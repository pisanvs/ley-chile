{"html": [{"t": "<div><div class=\"p\">EXTRACTO&nbsp; DE DECRETO&nbsp; N&#xBA; 457&nbsp; EXENTO, DE&nbsp; 1999</div><br></div>", "i": 6295708}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 457 de 29 de diciembre de 1999, se ha aprobado a la &apos;&apos;Scuola Italiana Arturo Dell&apos;Oro&apos;&apos;, de Valpara&#xED;so, para los cursos de Ense&#xF1;anza B&#xE1;sica, las adecuaciones de planes y programas especiales de estudio, las que ser&#xE1;n aplicadas conforme&nbsp; a la gradualidad establecida en el decreto supremo N&#xBA; 40 de 1996 y sus modificaciones.</div><br></div>", "i": 6295709}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de marzo de 2000.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6295710}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "457 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-457 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 457 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-29", "doble_articulado": false, "id_norma": "174013", "numero_fuente": "36735", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-09", "vigencias": [{"desde": "2000-08-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-08-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2000-