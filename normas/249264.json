{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6568701}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA;162 de fecha 31 de marzo del 2006, se expropi&#xF3; el lote de terreno N&#xBA;18, superficie 1.947,8 m2, Rol N&#xBA; 386-62, comuna de Pitrufqu&#xE9;n, IX Regi&#xF3;n para la obra &quot;Dise&#xF1;o Definitivo de la Red Secundaria y Terciaria de Canales de Riego Proyecto Faja Maisan, Obra Canal California&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Mariano Tripailaf Reyes, ascendente a la cantidad de</div><div class=\"p\">$1.187.909.- para el lote N&#xBA;18.</div><br></div>", "i": 6568702}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6568703}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "162 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-162 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-03-31", "doble_articulado": false, "id_norma": "249264", "numero_fuente": "38452", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-05-02", "vigencias": [{"desde": "2006-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2006-05-02", "fecha_version": "2006-05-02", "fecha_actualizac