{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9401908}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.766, de 30 de diciembre de 2013, de esta Subsecretar&#xED;a, modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1051739&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.325 del 24 de mayo de 2013</a>, de esta Subsecretar&#xED;a, que autoriz&#xF3; a JAIME ILLANES Y ASOCIADOS CONSULTORES S.A., para efectuar pescas de investigaciones, en el sentido de ampliar el plazo de vigencia de la autorizaci&#xF3;n por el t&#xE9;rmino de 3,5 meses.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en el sitio de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura.</div></div>", "i": 9401909}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de diciembre de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9401910}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3766 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-3766 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-12-30", "doble_articulado": false, "id_norma": "1058555", "numero_fuente": "40766", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-01-25", "vigencias": [{"desde": "2014-01-25", "hasta": "", "tipo_version": "3", "tipo_versi