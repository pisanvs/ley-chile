{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xBA; 200, DE 1999</div><br><br></div>", "i": 6284686}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 73 de 24 mayo 2000, de Serviu V Regi&#xF3;n, se modifica resoluci&#xF3;n N&#xBA; 200 de 16 noviembre 1999, en sentido expropiaci&#xF3;n afecta 32,82 metros cuadrados de inmueble Manuel Rodr&#xED;guez 12 rol 13-13, La Cruz, de Ignacio y Guvier Sep&#xFA;lveda. Comisi&#xF3;n tasadora, seg&#xFA;n informe 10 mayo 2000 fij&#xF3; monto provisional indemnizaci&#xF3;n en $295.380, que se pagar&#xE1; al contado.- </div></div>", "i": 6284687}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu V Regi&#xF3;n.</div><br></div>", "i": 6284688}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "73", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-73"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAISO"], "titulo_norma": "MODIFICA RESOLUCION Nº 200, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-24", "doble_articulado": false, "id_norma": "171697", "numero_fuente": "36702", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-01", "vigencias": [{"desde": "2000-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "MEM", "fecha_ing