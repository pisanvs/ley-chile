{"html": [{"t": "<div><div class=\"p\">PRORROGA AUTORIZACION QUE INDICA </div></div>", "i": 8320626}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 1.656, de 06 de Noviembre de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por 6 meses a contar del 06 de noviembre de 1989. el plazo otorgado a Pesquera Antares Limitada, actualmente Pesquera Antares S.A., RUT No.</div><div class=\"p\">79.674.170-8, domiciliada en la ciudad de Santiago, para empezar a operar el establecimiento de cultivo autorizado por la Resoluci&#xF3;n No. 943, de 1988, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8320627}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 06 de Noviembre de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8320628}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1656", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1656"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-11-06", "doble_articulado": false, "id_norma": "91725", "numero_fuente": "33526", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-11-20", "vigencias": [{"desde": "1989-11-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-11-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-11-20", "fin_vigencia": "", "tip