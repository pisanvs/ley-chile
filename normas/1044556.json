{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9304435}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exentas N&#xBA; 1.634, de 14 de junio de 2012, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1037032&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 107, de 2012</a>, que autoriz&#xF3; a la UNIVERSIDAD DE MAGALLANES para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Microsporidiosis en Centolla (Lithodes santolla). Evaluaci&#xF3;n de una amenaza a la pesquer&#xED;a de Magallanes&quot;, en el sentido de se&#xF1;alar que el estudio se extender&#xE1; hasta el 31 de agosto de 2012, inclusive.</div></div>", "i": 9304436}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de junio de 2012.- Felipe Palacio Rives, Subsecretario de Pesca (S).</div></div>", "i": 9304437}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1634 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1634 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-14", "doble_articulado": false, "id_norma": "1044556", "numero_fuente": "40382", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-10-10", "vigencias": [{"desde": "2012-10-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-10-10", "fin_vig