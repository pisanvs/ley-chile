{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AUTORIZA A EMPRESA QUE INDICA PARA EFECTUAR TRANSPORTE INTERNACIONAL TERRESTRE DE PASAJEROS </div></div>", "i": 6024960}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n Exenta N&#xB0; 1439 de 18 de Noviembre de 1994, se autoriz&#xF3; a la Empresa TRAMACA S.A., para efectuar transporte internacional terrestre de pasajeros entre Antofagasta (Chile) y Salta (Argentina), por el paso Sico o Jama efectuando dos frecuencias semanales de ida y vuelta.-</div><br></div>", "i": 6024961}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Claudio Hohmann Barrientos, Subsecretario de Transportes.</div><br></div>", "i": 6024962}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1439", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1439"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "AUTORIZA A EMPRESA QUE INDICA PARA EFECTUAR\nTRANSPORTE INTERNACIONAL TERRESTRE DE PASAJEROS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TRANSPORTE INTERNACIONAL", "CHILE", "ARGENTINA", "EMPRESA TRAMACA S.A.", "AUTORIZACION", "TRANSPORTE PASAJEROS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-11-18", "doble_articulado": false, "id_norma": "39780", "numero_fuente": "35038", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-12-12", "vigencias": [{"desde": "1994-12-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-12-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-12-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1994-