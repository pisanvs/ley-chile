{"html": [{"t": "<div><div class=\"p\">ACUERDO DEL TRIBUNAL CONSTITUCIONAL RELATIVO AL DIA EN QUE CELEBRARA SUS SESIONES ORDINARIAS</div><br><br></div>", "i": 6326206}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En Santiago a 7 de marzo del a&#xF1;o 2001, se reuni&#xF3; el Tribunal Constitucional, bajo la presidencia de don Osvaldo Fa&#xFA;ndez Vallejos, y con la asistencia de sus Ministros se&#xF1;or Eugenio Valenzuela Somarriva, se&#xF1;ora Luz Bulnes Aldunate, se&#xF1;ores Servando Jord&#xE1;n L&#xF3;pez, Juan Colombo Campbell y Hern&#xE1;n Alvarez Garc&#xED;a y acord&#xF3; que a partir del d&#xED;a martes 20 de marzo en curso sus sesiones ordinarias se celebrar&#xE1;n esos d&#xED;as de cada semana, a las 18 horas.</div><br></div>", "i": 6326207}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Publ&#xED;quese en el Diario Oficial.- Rafael Larra&#xED;n Cruz, Secretario.</div><br></div>", "i": 6326208}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "4", "numero": "S/N", "abreviacion": "AA", "descripcion": "Auto Acordado", "compuesto": "AA-S/N"}], "organismos": ["TRIBUNAL CONSTITUCIONAL"], "titulo_norma": "ACUERDO DEL TRIBUNAL CONSTITUCIONAL RELATIVO AL DIA EN QUE CELEBRARA SUS SESIONES ORDINARIAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TRIBUNAL CONSTITUCIONAL", "SESIONES ORDINARIAS", "CELEBRACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-07", "doble_articulado": false, "id_norma": "182792", "numero_fuente": "36912", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-14", "vigencias": [{"desde": "2001-03-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-14", "fin_vigencia": ""}, "vigencias_versi