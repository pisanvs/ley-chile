{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO RECEPTOR JUDICIAL FUNCIONARIOS QUE INDICA </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 195.- Santiago, 16 de mayo de 2003.- Vistos: Lo dispuesto en el Art. 11 del decreto ley N&#xBA;2.974 de 1979,</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br></div>", "i": 6427573}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del decreto ley citado, X Regi&#xF3;n a los siguientes funcionarios:</div><br><div class=\"p\">- Jorge Ra&#xFA;l Rivera Uribe</div><div class=\"p\">- Sergio Waldemar Ojeda Almonacid</div><div class=\"p\">- Franklin Freddy Linz Linz</div><br></div>", "i": 6427574}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Ricardo Halabi Caffena, Director Nacional.</div><br></div>", "i": 6427575}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "195", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-195"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL FUNCIONARIOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-05-16", "doble_articulado": false, "id_norma": "211437", "numero_fuente": "37588", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-20", "vigencias": [{"desde": "2003-06-20", "hasta": "