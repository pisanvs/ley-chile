{"html": [{"t": "<div><div class=\"p\">CERTIFICADO</div></div>", "i": 10068994}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  El Ministro de Fe de las actuaciones del Consejo y del Banco Central de Chile que suscribe, certifica que, de conformidad con lo establecido en el Cap&#xED;tulo III.F.5 del Compendio de Normas Financieras, la clasificaci&#xF3;n de riesgo del estado soberano que se indica a continuaci&#xF3;n es, para los efectos previstos en dicho Cap&#xED;tulo, la siguiente:</div><br><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/100252.jpg\"></div><br><br><div class=\"p\">&nbsp; &nbsp;  Se deja constancia que la clasificaci&#xF3;n de riesgo que precede se ha elaborado sobre la base de la informaci&#xF3;n disponible en el Banco Central de Chile hasta el 6 de noviembre de 2019, y que ella reemplaza parcialmente las contenidas en el N&#xB0; 1 del Anexo del Cap&#xED;tulo III.F.5 del Compendio de Normas Financieras.</div><br></div>", "i": 10068995}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de noviembre de 2019.- Juan Pablo Araya Marco, Ministro de Fe.</div><div class=\"p\"> </div><br></div>", "i": 10068996}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "Certificado-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1682886"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-11-11", "doble_articulado": false, "id_norma": "1138806", "numero_fuente": "42504", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-11-16", "vigencias": [{"desde": "2019-11-16", "hasta":