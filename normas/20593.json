{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 184 EXENTO, DE 1996 </div></div>", "i": 5942472}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 184 de 29 de marzo de 1996, se ha aprobado, a contar del a&#xF1;o escolar 1996, al Liceo Industrial Chileno-Alem&#xE1;n de &#xD1;u&#xF1;oa, un plan especial de estudio de Ense&#xF1;anza Media T&#xE9;cnico-Profesional, para las Especialidades de Electro Automatizaci&#xF3;n Industrial y Construcciones Met&#xE1;licas.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio para asignaturas que se se&#xF1;alan en el presente decreto. </div></div>", "i": 5942473}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 9 de abril de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5942474}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "184", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-184"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 184 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIO", "LICEO INDUSTRIAL CHILENO ALEMAN", "U OA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-03-29", "doble_articulado": false, "id_norma": "20593", "numero_fuente": "35443", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-04-16", "vigencias": [{"desde": "1996-04-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-04-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-04-16", "fin_vig