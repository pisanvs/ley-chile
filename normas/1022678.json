{"html": [{"t": "<div><br><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A CONSTRUCTORA F&#xC9;NIX LTDA.</div></div>", "i": 9106844}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La VI Direcci&#xF3;n Regional Rancagua del SII, por resoluci&#xF3;n Ex. N&#xBA; 303 de fecha 20.01.2011, otorga la calidad de Agente Retenedor del Impuesto al Valor Agregado en los contratos de instalaci&#xF3;n o confecci&#xF3;n de especialidades, a Constructora F&#xE9;nix Ltda., RUT N&#xBA; 78.528.690-1. Dicho acto de autoridad regir&#xE1; a contar del d&#xED;a primero del mes siguiente al de esta publicaci&#xF3;n, de acuerdo a lo establecido en la resoluci&#xF3;n exenta SII N&#xBA; 142 del 26.12.2005, de la Direcci&#xF3;n Nacional.</div></div>", "i": 9106845}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Rancagua, 20 de enero de 2011.- Luis Aguilar Z&#xFA;&#xF1;iga, Director Regional (S).</div></div>", "i": 9106846}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "303 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-303 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VI DIRECCIÓN REGIONAL DE RANCAGUA"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A CONSTRUCTORA FÉNIX LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-01-20", "doble_articulado": false, "id_norma": "1022678", "numero_fuente": "39875", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-02-02", "vigencias": [{"desde": "2011-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-02-02", "fin_vigenc