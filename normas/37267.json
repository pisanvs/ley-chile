{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297937}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.627, de 14 de noviembre de 1995,</div><div class=\"p\">de esta Subsecretar&#xED;a de Pesca del Ministerio de</div><div class=\"p\">Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, cad&#xFA;canse las</div><div class=\"p\">Resoluciones N&#xB0; 734, de 1986 y N&#xB0; 1.358, de 1987, de</div><div class=\"p\">esta Subsecretar&#xED;a, en cuanto autorizaron a don MANUEL</div><div class=\"p\">BARRIENTOS SANCHEZ, R.U.T. N&#xB0; 5.353.608-5, para operar</div><div class=\"p\">la nave &quot;Fabiola I&quot;, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143&#xB0; letra b) del D.S. N&#xB0; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8297938}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 14 de noviembre de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297939}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1627", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1627"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "PESCA", "MANUEL BARRIENTOS", "SANCHEZ"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-11-14", "doble_articulado": false, "id_norma": "37267", "numero_fuente": "35323", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-11-22", "vigencias": [{"desde": "1995-11-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "