{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO CALIDAD DE AGENTE RETENEDOR DEL IVA A CLIFT Y SEGUEL LTDA.</div><br></div>", "i": 6588931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La II Direcci&#xF3;n Regional Antofagasta del Servicio de Impuestos Internos, por resoluci&#xF3;n ex. N&#xBA; 1.495, de 02.11.06, deja sin efecto el otorgamiento de la calidad de Agente Retenedor del IVA, en las actividades de la construcci&#xF3;n conforme a lo dispuesto en resoluci&#xF3;n exenta N&#xBA; 28, de 28 de enero de 2004, a la empresa Clift y Seguel Ltda., RUT N&#xBA; 78.027.960-5, por haber dejado de cumplir los requisitos establecidos en resoluci&#xF3;n ex. N&#xBA; 46, de 01.09.2003, a contar de su publicaci&#xF3;n en extracto en el Diario Oficial.</div><br></div>", "i": 6588932}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Oscar Urdanivia Noriega, Director Regional. </div></div>", "i": 6588933}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1495 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1495 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "II DIRECCIÓN REGIONAL ANTOFAGASTA"], "titulo_norma": "DEJA SIN EFECTO CALIDAD DE AGENTE RETENEDOR DEL IVA A\nCLIFT Y SEGUEL LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-11-02", "doble_articulado": false, "id_norma": "255032", "numero_fuente": "38611", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-11-11", "vigencias": [{"desde": "2006-11-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-11-11", "fin_vigencia": ""}, "vigen