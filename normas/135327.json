{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,737.- Santiago, 14 de julio de 1905.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 7247811}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- El&#xE9;vase, por gracia, a dos mil cuatrocientos pesos al a&#xF1;o la pension que, en virtud de lei de 28 de setiembre de 1864, disfruta actualmente do&#xF1;a Elvira Carrera Pinto.</div><br></div>", "i": 7247812}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.-</div><div class=\"p\">R. Corbalan Melgarejo.</div><br></div>", "i": 7247813}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1737", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1737"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-07-14", "doble_articulado": false, "id_norma": "135327", "numero_fuente": "8258", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-07-15", "vigencias": [{"desde": "1905-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1905-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1905-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "IMH", "fecha_i