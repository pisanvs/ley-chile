{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293062}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 547 de 3 de junio de 1994 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto las Resoluci&#xF3;n N&#xB0; 268, de 1986, la Resoluciones N&#xB0; 48, de 1988 que modific&#xF3; y la Resoluci&#xF3;n N&#xB0; 1276, de 1990, todas de esta Subsecretar&#xED;a, que autorizaron a don LUIS ESBERTO ANDRADE PINTO, R.U.T. N&#xB0; 5.746.949-8, para operar un establecimiento de cultivo, ubicado en un Sector de Playa Sur &quot;Reloncav&#xED;&quot;, Isla Tenglo, Comuna de Puerto Montt, Provincia de Llanquihue, X Regi&#xF3;n, por haberse caducado el Decreto Supremo de concesi&#xF3;n de acuicultura.</div><br></div>", "i": 8293063}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 3 de junio de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293064}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "547", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-547"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "AUTORIZACION", "LUIS ASBERTO ANDRADE PINTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-06-03", "doble_articulado": false, "id_norma": "35079", "numero_fuente": "34892", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-06-17", "vigencias": [{"desde": "1994-06-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-06-17",