{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7264825}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;492, de 3 marzo de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA;680 de 1989, de esta Subsecretar&#xED;a, en cuanto autoriz&#xF3; a PESQUERA EL GOLFO S.A., para operar la nave &apos;&apos;Southport&apos;&apos; Matr&#xED;cula 2566, respecto de los recursos Jurel, Sardina espa&#xF1;ola, Sierra, Cojinoba del norte, Cojinoba del sur, Cabinza, Sardina com&#xFA;n, Caballa y Bonito, en el litoral de la IV Regi&#xF3;n, de conformidad con lo establecido en el inciso segundo de la letra b) del art&#xED;culo 143 del D.S. N&#xBA;430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 7264826}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de marzo de 2000.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 7264827}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "492", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-492"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA EL GOLFO S.A.", "NAVE SOUTHPORT", "PESCA", "JUREL", "SARDINA ESPAÑOLA", "SIERRA", "COJINOBA", "CABALLA", "CADUCA", "DEROGA", "PARCIAL CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-03-03", "fecha_derogacion": "2004-05-03", "doble_articulado": false, "id_norma": "160475", "numero_fuente": "35611", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000