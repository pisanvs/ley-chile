{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6395112}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.848, de 29 de agosto de 2002, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1.825, de 1989, de esta Subsecretar&#xED;a que autoriz&#xF3; a SOCIEDAD PESQUERA ALGAZO LIMITADA&nbsp; para la instalaci&#xF3;n y operaci&#xF3;n de un centro de cultivo en el R&#xED;o Maull&#xED;n, X Regi&#xF3;n, en virtud del art&#xED;culo 78 de la Ley General de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp;  Rem&#xED;tase la presente solicitud de concesi&#xF3;n de acuicultura a la Subsecretar&#xED;a de Marina, para su denegaci&#xF3;n.</div><br></div>", "i": 6395113}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de agosto de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6395114}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1848", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1848"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-08-29", "doble_articulado": false, "id_norma": "202242", "numero_fuente": "37350", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-09-03", "vigencias": [{"desde": "2002-09-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-09-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-09-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe