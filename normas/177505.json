{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 442 EXENTO, DE 2000</div><br><br></div>", "i": 6307564}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 442 de 11 de octubre de 2000, se ha aprobado al Colegio &apos;&apos;Maim&#xF3;nides&apos;&apos;, comuna de Las Condes, de Santiago, un plan de estudio para 5&#xBA; a&#xF1;o (NB. 3) de Ense&#xF1;anza B&#xE1;sica, el cual se aplicar&#xE1; a partir del a&#xF1;o escolar 2001, de acuerdo con el cronograma establecido por el establecimiento para implementar planes y programas propios biling&#xFC;es.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en el presente decreto. </div></div>", "i": 6307565}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de octubre de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br><br></div>", "i": 6307566}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "442 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-442 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 442 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-11", "doble_articulado": false, "id_norma": "177505", "numero_fuente": "36805", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-11-06", "vigencias": [{"desde": "2000-11-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-11-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-11-