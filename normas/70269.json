{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 260 EXENTO, DE 1997 </div></div>", "i": 6033241}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 260 de 5 de marzo de 1997, se ha aprobado, a partir del a&#xF1;o escolar 1997, un programa de Religi&#xF3;n de la Iglesia Metodista de Chile para los cursos de 1&#xBA; a 8&#xBA; a&#xF1;o (NB.1 a NB.6) de ense&#xF1;anza b&#xE1;sica, el que podr&#xE1; aplicarse conforme a la gradualidad establecida en el art&#xED;culo 4&#xBA; del Decreto Supremo de Educaci&#xF3;n N&#xBA; 40 de 1996: 1&#xBA; y 2&#xBA; a&#xF1;o en 1997; 3&#xBA;, 4&#xBA; y 5&#xBA; a&#xF1;o en 1998; 6&#xBA; a&#xF1;o en 1999; 7&#xBA; a&#xF1;o en 2000; y 8&#xBA; a&#xF1;o en 2001.</div><br></div>", "i": 6033242}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de marzo de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6033243}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "260", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-260"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 260 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RELIGION", "PROGRAMAS DE ESTUDIO", "IGLESIA METODISTA DE CHILE", "ENSE ANZA BASICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-05", "doble_articulado": false, "id_norma": "70269", "numero_fuente": "35728", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-03-31", "vigencias": [{"desde": "1997-03-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-03-31", "fin_vigenc