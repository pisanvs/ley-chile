{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6251472}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 270, de fecha 01 de Abril de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a don Ad&#xE1;n D&#xED;az Carrasco, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6251473}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 03 de Abril de 1985.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6251474}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "270 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-270 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-04-01", "doble_articulado": false, "id_norma": "161230", "numero_fuente": "32148", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-04-17", "vigencias": [{"desde": "1985-04-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-04-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-04-17", "fin_vigencia": "", "tipo_ve