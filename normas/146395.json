{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 2,856.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6200849}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Clarisa Silva, viuda de Didier i a sus hijas, una pension de montep&#xED;o de cinco mil pesos ($ 5,000) anuales, de que disfrutar&#xE1;n por el t&#xE9;rmino de diez a&#xF1;os, con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6200850}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintiseis de enero de mil novecientos catorce.- R. Barros Luco.- Enrique Za&#xF1;artu P.- Ricardo Salas Edwards.</div><br></div>", "i": 6200851}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2856", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2856"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1914-01-26", "doble_articulado": false, "id_norma": "146395", "numero_fuente": "10785", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1914-01-29", "vigencias": [{"desde": "1914-01-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1914-01-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1914-01-29", "fin_