{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pension de Gracia a do&#xF1;a Clorinda L&#xF3;pez Lei n&#xFA;m. 896.- Santiago, a 15 de Enero de 1897.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947825}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, a do&#xF1;a Clorinda L&#xF3;pez, viuda del capitan don Jos&#xE9; Ramon Lira, el goce de la pension de montep&#xED;o correspondiente al empleo de sarjento mayor, en vez de la de capitan que actualmente percibe.</div><br><br></div>", "i": 5947826}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- El&#xED;as Fern&#xE1;ndez A.</div><br></div>", "i": 5947827}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "896", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-896"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION DE GRACIA A DOÑA CLORINDA LOPEZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CLORINDA LOPEZ", "MONTEPIO MILITAR", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-01-15", "doble_articulado": false, "id_norma": "22245", "numero_fuente": "5605", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1897-01-15", "vigencias": [{"desde": "1897-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1897-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1897-01-15", "fin_vigencia