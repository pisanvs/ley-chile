{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6228776}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.343, de Diciembre 10 de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones Regional Metropolitana, se autoriza a don Juan de Dios Moreno Ibarra para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6228777}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, Diciembre 10 de 1986.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6228778}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1343 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1343 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-12-10", "doble_articulado": false, "id_norma": "154367", "numero_fuente": "32653", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-12-22", "vigencias": [{"desde": "1986-12-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-12-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-12-22", "fin_vigencia": "", "tipo_version": "3"}], "eve