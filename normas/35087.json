{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293074}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 549 de 3 de Junio de 1994 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el n&#xFA;mero 2&#xB0; de la Resoluci&#xF3;n N&#xB0; 137, de 1994, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don JORGE GARCIA GIL, R.U.T. N&#xB0; 5.967.599-0, para ampliar actividades pesqueras de procesamiento, en el sentido de sustituir su actual encabezado por el siguiente:</div><div class=\"p\">&nbsp; &nbsp; &quot;2.- El peticionario podr&#xE1; operar una planta ubicada en la XII Regi&#xF3;n, Puerto Toro, Isla Navarino, Ant&#xE1;rtica Chilena, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n que se indica, los siguientes recursos hidrobiol&#xF3;gicos:&quot; </div></div>", "i": 8293075}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 3 de junio de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293076}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "549", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-549"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "AUTORIZACION", "JORGE GARCIA GIL", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-06-03", "doble_articulado": false, "id_norma": "35087", "numero_fuente": "34892", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-06-17", "vigencias": [{"desde": "1994-06-17", "hasta": "", "tipo_version": "3"