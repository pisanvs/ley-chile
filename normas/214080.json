{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 612 EXENTO, DE 2003</div><br><br></div>", "i": 6437370}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 612, de fecha 5 de agosto de 2003, de Educaci&#xF3;n, se autoriza al Instituto Profesional Agrario Adolfo Matthei para impartir la siguiente carrera y t&#xED;tulo t&#xE9;cnico de Nivel Superior que se indica, a contar del segundo semestre del a&#xF1;o 2003.</div><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; : Tecnolog&#xED;a Agroindustrial menci&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Productos C&#xE1;rnicos y L&#xE1;cteos.</div><div class=\"p\">T&#xED;tulo T&#xE9;cnico : T&#xE9;cnico de Nivel Superior en</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Agroindustria, menci&#xF3;n Productos</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  C&#xE1;rnicos y L&#xE1;cteos.</div><br></div>", "i": 6437371}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de agosto de 2003.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 6437372}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "612 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-612 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 612 EXENTO, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-05", "doble_articulado": false, "id_norma": "214080", "numero_fuente": "37647", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-08-2