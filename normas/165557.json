{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6265006}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 280 de noviembre 27 de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n, se autoriza a do&#xF1;a Lila del Carmen Rivera Castillo para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6265007}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jorge Vargas Borcosky, Secretario Regional Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n de Coquimbo.</div><br></div>", "i": 6265008}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "280 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-280 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IV REGIÓN COQUIMBO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-11-27", "doble_articulado": false, "id_norma": "165557", "numero_fuente": "32350", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-18", "vigencias": [{"desde": "1985-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-12-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-12-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul