{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6405196}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;2.515, de 7 de noviembre de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a EXPORTADORA DE ALGAS SUDAMERICANA LIMITADA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en Sitio N, Sector La Chimba, Antofagasta, II Regi&#xF3;n, donde podr&#xE1; procesar en la l&#xED;nea de elaboraci&#xF3;n que se indica, los siguientes recursos hidrobiol&#xF3;gicos: Alga Seca: Chasc&#xF3;n, Huiro Lessonia trabeculata, Huiro Macrocystis spp.</div><br></div>", "i": 6405197}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de noviembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6405198}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2515", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2515"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-11-07", "doble_articulado": false, "id_norma": "205345", "numero_fuente": "37427", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-06", "vigencias": [{"desde": "2002-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-12-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-12-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2002-