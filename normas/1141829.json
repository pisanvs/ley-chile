{"html": [{"t": "<div><div class=\"p\">SUSPENDE HASTA EL 9 DE JULIO DE 2021 LA APLICACI&#xD3;N DE LA RESOLUCI&#xD3;N N&#xBA; 4.277, DE 2019</div></div>", "i": 10097146}, {"t": "<div><br><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 234, del 15 de enero de 2020, del Director Nacional de Aduanas, se suspende hasta el 9 de julio de 2021, las instrucciones impartidas por la <a href=\"https://www.leychile.cl/Navegar?idNorma=1135874&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 4.277, de 2019</a>, relacionada con la aplicaci&#xF3;n del art&#xED;culo 23 ter de la Ordenanza de Aduanas.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10097147}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de enero de 2020.- Gustavo Poblete Morales, Director Nacional de Aduanas (S).</div><br></div>", "i": 10097148}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "234 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-234 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "SUSPENDE HASTA EL 9 DE JULIO DE 2021 LA APLICACIÓN DE LA RESOLUCIÓN Nº 4.277, DE 2019", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1719699; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-01-15", "doble_articulado": false, "id_norma": "1141829", "numero_fuente": "42567", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-01-31", "vig