{"html": [{"t": "<div><div class=\"p\">ACEPTA RENUNCIA QUE INDICA</div><br><div class=\"p\">N&#xFA;m. 58.- Santiago, 29 de Enero de 1990.- Visto: La facultad que me confiere el Art. No. 32 en su No. 9 y No. 10 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile, </div><div class=\"p\">Decreto:</div><br><br></div>", "i": 8319243}, {"t": "<div><div class=\"p\">Ac&#xE9;ptase la renuncia a D. Roberto Cabezas Bello (RUT No.</div><div class=\"p\">4.583.382-8), al cargo de Subsecretario de Pesca a contar desde el 11 de Marzo de 1990.</div><br></div>", "i": 8319244}, {"t": "<div><div class=\"p\">T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- AUGUSTO PINOCHET UGARTE, General de Ej&#xE9;rcito, Presidente de la Rep&#xFA;blica.- Pedro Larrondo Jara, Contralmirante, Ministro de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><div class=\"p\">Lo que transcribo a Ud. para su conocimiento.- Saluda atentamente a Ud.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8319245}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "58", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-58"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "ACEPTA RENUNCIA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-29", "doble_articulado": false, "id_norma": "89742", "numero_fuente": "33609", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-01", "vigencias": [{"desde": "1990-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-03-01", "fin_vigenc