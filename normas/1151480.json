{"html": [{"t": "<div><div class=\"p\">OFICIO DEL TRIBUNAL DEL CONSULADO.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Setiembre 24 de 1825. </div></div>", "i": 10176285}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Este tribunal, como todo el comercio ha visto con placer la &#xFA;ltima ampliacion del decreto de seis de julio &#xFA;ltimo, y mirando desde luego en ella una prueba del decidido empe&#xF1;o, con que procura el Gobierno el fomento del comercio no puede menos, que tributarle su mas cordial gratitud, por s&#xED; y a nombre del comercio en jeneral.</div><div class=\"p\">&nbsp; &nbsp;  Admita U. S. con este motivo nuestros mejores sentimientos de aprecio y consideracion.-</div></div>", "i": 10176286}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Felipe Santiago del Solar.- Pedro de Salas.- Onofre Bunster.- Sr. Ministro de Hacienda.</div></div>", "i": 10176287}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "﻿OFICIO DEL TRIBUNAL DEL CONSULADO", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-09-24", "doble_articulado": false, "id_norma": "1151480", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-09-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-09-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-09-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "