{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 63 EXENTO, DE 1999</div><br><br></div>", "i": 6181987}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 63, de fecha 22 de marzo de 1999, del Ministerio de Educaci&#xF3;n, se declar&#xF3; aprobada a la Universidad de San Andr&#xE9;s, la carrera de Educaci&#xF3;n Parvularia conducente al grado acad&#xE9;mico de Licenciado en Educaci&#xF3;n y al t&#xED;tulo profesional de Educador de P&#xE1;rvulos, para ser impartida en jornada diurna y vespertina, en su sede de la ciudad de Santiago, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6181988}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de marzo de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6181989}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "63", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-63"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 63 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-03-22", "doble_articulado": false, "id_norma": "140408", "numero_fuente": "36437", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-08-12", "vigencias": [{"desde": "1999-08-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-08-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-08-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_