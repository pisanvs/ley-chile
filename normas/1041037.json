{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9266870}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (exento) N&#xBA;960 de fecha 31 de mayo de 2012, y de conformidad a lo dispuesto en el Art. 105 del DFL. MOP. N&#xBA;850 de 1997, se expropiaron los lotes de terreno N&#xBA;s 1 y 1-A, superficies 2.376 y 307 m2 respectivamente, rol N&#xBA;596-99, para la obra &quot;Reposici&#xF3;n Puente Las Toscas en Ruta I-710, Km. 7,44299 a Km. 7,70775&quot;, Comuna de Santa Cruz, VI Regi&#xF3;n. La Comisi&#xF3;n de Peritos integrada por Marlene R&#xED;os Marcuello, Robert Hilliard Jorquera y Sergio Shipley Rubio, fij&#xF3; valor de tasaci&#xF3;n con fecha 01 de abril de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario MANUEL IGNACIO GUTI&#xC9;RREZ JIM&#xC9;NEZ, en la cantidad de $13.522.161, suma que se pagar&#xE1; al contado. </div></div>", "i": 9266871}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9266872}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "960 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-960 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-31", "doble_articulado": false, "id_norma": "1041037", "numero_fuente": "40288", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-15", "vigencias": [{"desde": "2012-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-06-15", "fin_vigencia": ""}, "vigencias_version