{"html": [{"t": "<div><div class=\"p\">DESIGNA A DO&#xD1;A BELEN DE LOURDES ORME&#xD1;O HERNANDEZ, TESORERO PROVINCIAL DE EL LOA</div><br><div class=\"p\">Santiago, 12 de Abril de 1991.Hoy se resolvi&#xF3; lo que sigue:</div><div class=\"p\">N&#xFA;m. 297 exenta.- Vistos: El Art. 5&#xB0; del DFL No. 5, de 1963, del Ministerio de Hacienda y la Resoluci&#xF3;n No. 1.050, de 1980, de la Contralor&#xED;a General de la Rep&#xFA;blica, dicto la siguiente</div><br><div class=\"p\">Resoluci&#xF3;n </div></div>", "i": 6076611}, {"t": "<div><br><div class=\"p\">Des&#xED;gnase Tesorero Provincial de El Loa, Calama, a do&#xF1;a Bel&#xE9;n de Lourdes Orme&#xF1;o Hern&#xE1;ndez, Rut 6.521.195-5. </div></div>", "i": 6076612}, {"t": "<div><div class=\"p\">An&#xF3;tese y publ&#xED;quese.- V. Humberto Vega Fern&#xE1;ndez, Tesorero General.</div><div class=\"p\">Lo que transcribo para su conocimiento.- Saluda a Ud.- Francisco J. Andrade Adriazola, Jefe Departamento de Personal.</div><br></div>", "i": 6076613}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "297 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-297 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "TESORERÍA GENERAL DE LA REPÚBLICA"], "titulo_norma": "DESIGNA A DOÑA BELEN DE LOURDES ORMEÑO HERNANDEZ, TESORERO PROVINCIAL DE EL LOA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-04-12", "doble_articulado": false, "id_norma": "87567", "numero_fuente": "33949", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-22", "vigencias": [{"desde": "1991-04-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio