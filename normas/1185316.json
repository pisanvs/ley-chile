{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10383208}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto (Exento) MOP. N&#xBA;1033, de 04 de noviembre de 2022, se modific&#xF3; y desisti&#xF3; parcialmente de la expropiaci&#xF3;n del lote N&#xBA;27-A, realizada por <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=1153324\">Decreto (Exento) MOP. N&#xBA;1204, de 12 de noviembre de 2020</a>, reduci&#xE9;ndose la superficie expropiada a 5.623 m2. y modificando el numeral segundo de dicho Decreto, en cuanto al nombre del propietario, de la comuna de Calbuco, expropiado para la ejecuci&#xF3;n de obra &quot;Construcci&#xF3;n Puente sobre el canal Chacao y Accesos&quot;, Comuna de Ancud, Calbuco, Provincia de Llanquihue, Chilo&#xE9;, Regi&#xF3;n de Los Lagos. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en los art&#xED;culos 7&#xBA; y 32&#xBA; del Decreto Ley N&#xBA;2186, de 1978. </div><br></div>", "i": 10383209}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10383210}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1033 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1033 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2225341", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-11-04", "doble_articulado": false, "id_norma": "1185316", "numero_fuente": "43415", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-12-01", "vigencias": [{"desde": "202