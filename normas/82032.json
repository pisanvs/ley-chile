{"html": [{"t": "<div><div class=\"p\">PRORROGA AUTORIZACION QUE INDICA</div><br><br></div>", "i": 8313204}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 1.105 de 07 de Septiembre de 1990 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por seis meses a contar de esta fecha, el plazo otorgado a la Asociaci&#xF3;n Gremial de Algueros, Pescadores Artesanales y Ramos Afines del Estero de Huildad, Comuna de Quell&#xF3;n, R.U.T. No. 71.410.100-5, domiciliada en la ciudad de Quell&#xF3;n, en el numeral 5 de la Resoluci&#xF3;n No. 498, de 1989, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor. </div></div>", "i": 8313205}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 07 de Septiembre de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8313206}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1105", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1105"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1990-09-07", "fecha_derogacion": "1995-07-29", "doble_articulado": false, "id_norma": "82032", "numero_fuente": "33786", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1990-10-05", "vigencias": [{"desde": "1995-07-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1990-10-05", "hasta": "1995-07-28", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vig