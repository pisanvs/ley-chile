{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza la enajenaci&#xF3;n de los ex-transportes &quot;Rancagua&quot; y &quot;Maipo&quot; de la Armada Nacional.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7169958}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para enajenar en p&#xFA;blica subasta los ex-transportes &quot;Rancagua&quot; y &quot;Maipo&quot; de la Armada Nacional.</div><br></div>", "i": 7169959}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta y uno de Enero de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Carlos O. Frodden. </div></div>", "i": 7169960}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4809", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4809"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "AUTORIZA LA ENAJENACIÓN DE LOS EX-TRANSPORTES RANCAGUA\" Y \"MAIPO\" DE LA ARMADA NACIONAL.\"", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EX TRANSPORTE RANCAGUA", "EX TRANSPORTE MAIPO", "ENAJENACION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-01-31", "doble_articulado": false, "id_norma": "24929", "numero_fuente": "15597", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-02-12", "vigencias": [{"desde": "1930-02-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vige