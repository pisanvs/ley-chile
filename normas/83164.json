{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION No. 3,319 EXENTA, DE 1989 </div><br><br></div>", "i": 7218475}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta No. 3.319, de fecha 28 de diciembre de 1989 de la Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica, se modific&#xF3; el art&#xED;culo 1&#xB0; de la Resoluci&#xF3;n Exenta de Educaci&#xF3;n No. 1175 de 1989 del Centro de Formaci&#xF3;n T&#xE9;cnica Iquique English College de Iquique, en el sentido de impartir la carrera de Secretariado Ejecutivo con menci&#xF3;n en Computaci&#xF3;n, en un a&#xF1;o acad&#xE9;mico a partir de septiembre de 1989 a Junio de 1990, por &#xFA;nica vez, a fin de regularizar, las diferentes situaciones acad&#xE9;micas de sus postulantes.</div><br></div>", "i": 7218476}, {"t": "<div><div class=\"p\">Santiago, 03 de Mayo de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7218477}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3319 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3319 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION No. 3,319 EXENTA, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1989-12-28", "fecha_derogacion": "2000-12-04", "doble_articulado": false, "id_norma": "83164", "numero_fuente": "33670", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1990-05-15", "vigencias": [{"desde": "2000-12-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1990-05-15", "hasta": "2000-12-03", "tipo_version": "0"