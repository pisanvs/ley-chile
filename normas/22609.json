{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Intendencia Jeneral del Ej&#xE9;rcito Adquisicion de un edificio</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,388.- Santiago, a 21 de Noviembre de 1900.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949044}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la cantidad de cien mil pesos en la adquisicion de un edificio para la Intendencia Jeneral del Ej&#xE9;rcito, i en la instalacion de sus oficinas.</div><br><br></div>", "i": 5949045}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ E.- Arturo Besa.</div><br></div>", "i": 5949046}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1388", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1388"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "INTENDENCIA JENERAL DEL EJERCITO ADQUISICION DE UN EDIFICIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTE REPUBLICA", "INTENDENCIA GENERAL EJERCITO", "EDIFICIO", "ADQUISICION", "INVERSION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-11-21", "doble_articulado": false, "id_norma": "22609", "numero_fuente": "6753", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-11-27", "vigencias": [{"desde": "1900-11-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "190