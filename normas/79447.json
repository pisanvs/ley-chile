{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8309882}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 238, de 10 de Marzo de 1992 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 3&#xB0; de la Resoluci&#xF3;n No. 813, de 1988, de esta Subsecretar&#xED;a que autoriz&#xF3; a PESQUERA AURO S.A, R.U.T. No.</div><div class=\"p\">95.268.000-5, domiciliada en Avda. An&#xED;bal Pinto No. 222, Of. 16 Talcahuano, para ampliar actividades pesqueras, en el sentido de incluir entre los recursos que puede capturar en el litoral de la V, VI, VII y IX Regi&#xF3;n, con el arte de pesca Cerco, el denominado Merluza de cola, Macruronus magellanicus.</div><br><br></div>", "i": 8309883}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de Marzo de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br><br></div>", "i": 8309884}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "238", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-238"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1992-03-10", "fecha_derogacion": "2001-12-27", "doble_articulado": false, "id_norma": "79447", "numero_fuente": "34225", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1992-03-23", "vigencias": [{"desde": "2001-12-27", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1992-03-23", "hasta": "2001-12-26", "tipo_version": "0", "tipo_versi