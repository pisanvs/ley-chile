{"html": [{"t": "<div><div class=\"p\">DESIGNA VICEPRESIDENTE DEL CONSEJO SUPERIOR DE EDUCACION </div><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">N&#xFA;m.78.- Santiago, 11 de Junio de 1992.- Vistos: Lo dispuesto en los Art&#xED;culos 32 y 37 de la Ley No. 18.962 y lo acordado por el Consejo Superior de Educaci&#xF3;n en su Sesi&#xF3;n de hoy.</div><br><div class=\"p\">Resuelvo:</div><br></div>", "i": 6073127}, {"t": "<div><div class=\"p\">Art&#xED;culo Unico.- Des&#xED;gnase al se&#xF1;or Iv&#xE1;n Arturo Lavados Montes como Vice Presidente del Consejo Superior de Educaci&#xF3;n.</div><div class=\"p\">La persona indicada asumir&#xE1; de inmediato sus funciones y permanecer&#xE1; en la calidad de Vice Presidente por el tiempo que le reste como Consejero.</div><br></div>", "i": 6073128}, {"t": "<div><div class=\"p\">An&#xF3;tese, reg&#xED;strese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- Ricardo Lagos Escobar, Presidente Consejo Superior de Educaci&#xF3;n. </div></div>", "i": 6073129}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "78", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-78"}], "organismos": ["CONSEJO SUPERIOR DE EDUCACIÓN"], "titulo_norma": "DESIGNA VICEPRESIDENTE DEL CONSEJO SUPERIOR DE EDUCACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-06-11", "doble_articulado": false, "id_norma": "86441", "numero_fuente": "34306", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-07-03", "vigencias": [{"desde": "1992-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-07-03", "fin_vigencia": ""}, "vigencias_