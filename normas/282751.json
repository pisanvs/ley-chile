{"html": [{"t": "<div><div class=\"p\">AUTORIZA A EMISOR DE DOCUMENTOS ELECTR&#xD3;NICOS </div></div>", "i": 6666247}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 155, de 28 de noviembre de 2008, que autoriza a contribuyente como emisor electr&#xF3;nico.</div><br><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de documentos electr&#xF3;nicos, a contar del mes de diciembre de 2008, al contribuyente RUT N&#xBA;96.625.470-K.</div><div class=\"p\">El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de noviembre de 2008. </div></div>", "i": 6666248}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "155 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-155 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A EMISOR DE DOCUMENTOS ELECTRÓNICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-11-28", "doble_articulado": false, "id_norma": "282751", "numero_fuente": "39229", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-12-04", "vigencias": [{"desde": "2008-12-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-12-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-12-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [],