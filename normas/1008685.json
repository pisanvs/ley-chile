{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8812019}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.791, de 13 de noviembre de 2009, de esta Subsecretar&#xED;a, modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1002194&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.593, de 2009, de esta Subsecretar&#xED;a de Pesca</a>, que autoriz&#xF3; a la PONTIFICIA UNIVERSIDAD CAT&#xD3;LICA DE VALPARA&#xCD;SO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto &quot;Monitoreo del stock de Langostino colorado de la VII y VIII Regiones&quot;, en el sentido que a continuaci&#xF3;n se indica:</div><br><div class=\"p\">&nbsp; &nbsp;  a) Reemplazar la tabla contenida en el numeral 4&#xBA; por la siguiente:</div><div class=\"p\">&nbsp; &nbsp;  b) Reemplazar la tabla contenida en el numeral 6&#xBA; por la siguiente:</div></div>", "i": 8812020}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de noviembre de 2009.- Mar&#xED;a &#xC1;ngela Barbieri Bellolio, Subsecretaria de Pesca (S).</div></div>", "i": 8812021}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3791 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3791 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-11-13", "doble_articulado": false, "id_norma": "1008685", "numero_fuente": "39526", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "