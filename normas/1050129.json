{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9343478}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. (Exento) N&#xBA;382 de 25 de marzo de 2013, se dej&#xF3; sin efecto el <a href=\"https://www.leychile.cl/Navegar?idNorma=1033638&amp;idParte=0&amp;idVersion=\">Decreto MOP (Exento) N&#xB0;3638 de 11 de noviembre de 2011</a>, que ordena la expropiaci&#xF3;n del lote N&#xB0;20, debido a que se celebr&#xF3; Convenio Ad Refer&#xE9;ndum entre el Consorcio Inmobiliario Palom S.A. y la Direcci&#xF3;n Regional de Obras Hidr&#xE1;ulicas de la Regi&#xF3;n del B&#xED;o B&#xED;o, para la obra p&#xFA;blica: Dise&#xF1;o de Obras Fluviales R&#xED;o Andalien, Esteros Nongu&#xE9;n y Palomares, Comuna de Concepci&#xF3;n, Provincia de Concepci&#xF3;n, Regi&#xF3;n del B&#xED;o B&#xED;o. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xB0; del Decreto Ley N&#xBA;2186, de 1978. </div><br><br></div>", "i": 9343479, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9343480}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "382 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-382 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-03-25", "doble_articulado": false, "id_norma": "1050129", "numero_fuente": "40534", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-04-15", "vigencias": [{"desde": "2013-04-15", "hasta": "", "tipo_version": "3", "tipo_