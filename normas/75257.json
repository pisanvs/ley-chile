{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 142 EXENTO, DE 1990 </div></div>", "i": 9048703}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 142, de 25 de abril de 1990, se aprob&#xF3; con car&#xE1;cter de experimental, a contar del a&#xF1;o lectivo 1990 y por un per&#xED;odo de seis a&#xF1;os, a la Escuela Especial D N&#xBA; 76 de la Regi&#xF3;n Metropolitana, Plan Especial de estudio de Orientaci&#xF3;n Laboral para deficientes mentales.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban los programas de estudios correspondientes a las asignaturas de dicho Plan. </div></div>", "i": 9048704}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de Mayo de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 9048705}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "142 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-142 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 142 EXENTO, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["APROBACION", "ESCUELA ESPECIAL D N 76", "REGION METROPOLITANA", "PLANES DE ESTUDIO", "ORIENTACION LABORAL", "DEFICIENTES MENTALES", "DISCAPACIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-04-25", "doble_articulado": false, "id_norma": "75257", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-05-14", "vigencias": [{"desde": "1990-05-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-05-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1