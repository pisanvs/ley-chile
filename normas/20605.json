{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 187 EXENTO, DE 1994 </div></div>", "i": 5942504}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 187 de 25 de Abril de 1994, se ha autorizado al Liceo Santa Marta de Vallenar, III Regi&#xF3;n de Atacama, para impartir como 2&#xB0; Idioma Extranjero el Italiano en reemplazo del Idioma Extranjero Franc&#xE9;s, en 7&#xB0; y 8&#xB0; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica, a partir del a&#xF1;o escolar 1994.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s se aprueba programa especial de estudio de la asignatura Idioma Extranjero 2-Italiano.</div><br></div>", "i": 5942505}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 20 de Mayo de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n </div></div>", "i": 5942506}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "187", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-187"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 187 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LICEO SANTA MARTA", "VALLENAR", "TERCERA REGION", "PROGRAMAS ESTUDIOS", "PLANES ESTUDIOS", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-04-25", "doble_articulado": false, "id_norma": "20605", "numero_fuente": "34877", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-05-30", "vigencias": [{"desde": "1994-05-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-05-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-05-30", "fin_