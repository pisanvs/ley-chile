{"html": [{"t": "<div><br><div class=\"p\">DECLARACI&#xD3;N JURADA ANUAL FORMULARIO N&#xBA; 1924</div></div>", "i": 9684581}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 17 del 15 de marzo de 2016.</div><div class=\"p\">&nbsp; &nbsp;  Ampl&#xED;a plazo de presentaci&#xF3;n de la Declaraci&#xF3;n Jurada Anual Formulario N&#xBA; 1924, sobre rentas y cr&#xE9;ditos correspondientes a propietarios, socios, comuneros o accionistas de contribuyentes acogidos al r&#xE9;gimen tributario de la letra a) del art&#xED;culo 14 ter de la <a href=\"https://www.leychile.cl/Navegar?idNorma=6368&amp;idParte=&amp;idVersion=\">Ley sobre Impuesto a la Renta</a>, y el de su certificaci&#xF3;n respectiva.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de marzo de 2016.</div></div>", "i": 9684582}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "17 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-17 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DECLARACIÓN JURADA ANUAL FORMULARIO Nº 1924", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1007480; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-03-15", "doble_articulado": false, "id_norma": "1088568", "numero_fuente": "41413", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-03-21",