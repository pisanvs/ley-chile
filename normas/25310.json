{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; COMPLEMENTA EL D. F. L. N.o 178, DE 1931- CODIGO DEL TRABAJO</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente:</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5962782}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2.o Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 5962783}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo, por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, tres de Febrero de mil novecientos treinta y ocho.- ARTURO ALESSANDRI.- Mat&#xED;as Silva.</div><br></div>", "i": 5962784}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "6177", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-6177"}], "organismos": ["MINISTERIO DEL TRABAJO"], "titulo_norma": "COMPLEMENTA EL D. F. L. N.o 178, DE 1931- CODIGO DEL\nTRABAJO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUZGADO ESPECIAL TRABAJO", "TURNO", "CODIGO TRABAJO", "MODIFICACION", "TRIBUNAL ALZADA", "FERIADO", "CODIGO TRABAJO", "MODIFICACION", "JUECES", "TRABAJO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1938-02-03", "doble_articulado": false, "id_norma": "25310", "numero_fuente": "17985", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1938-02-05", "vigencias": [{"desde": "1938-02-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1938-02-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia