{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO NUMERO 364, DE 1992 </div></div>", "i": 7161687}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 364 de fecha 28 de octubre de 1992, se ha modificado el decreto supremo exento de Educaci&#xF3;n N&#xB0; 230 de 1987, modificado por decreto supremo exento de Educaci&#xF3;n N&#xB0; 129 de 1990, que aprob&#xF3; plan de estudio al Colegio San Benito de Santiago, en la siguiente forma:</div><br><div class=\"p\"> - Agregar de 1&#xB0; a 4&#xB0; a&#xF1;o b&#xE1;sico, una clase semanal en la asignatura de Matem&#xE1;tica.</div><br><div class=\"p\"> - Agregar de 1&#xB0; a 8&#xB0; a&#xF1;o b&#xE1;sico, dos clases semanales, en la asignatura de Educaci&#xF3;n F&#xED;sica.</div><br><div class=\"p\"> - Agregar en 1&#xB0; y 2&#xB0; a&#xF1;o medio, una clase semanal en la asignatura de Ciencias Naturales.</div><br></div>", "i": 7161688}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 10 de marzo de 1993.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161689}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "364 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-364 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO NUMERO 364, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "PLANES DE ESTUDIOS", "COLEGIO SAN", "BENITO", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-10-28", "doble_articulado": false, "id_norma": "21071", "numero_fuente": "34645", "tipo_version": "3", "tipo_version_s": "Única", "f