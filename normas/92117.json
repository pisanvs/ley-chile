{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8321247}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 134, de fecha 24 de Agosto de 1989 del</div><div class=\"p\">Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3;</div><div class=\"p\">la personalidad jur&#xED;dica de la &quot;Federaci&#xF3;n Gremial Nacional</div><div class=\"p\">de Corredores de Seguros de Chile&quot;, inscrita bajo el n&#xFA;mero</div><div class=\"p\">1756, del Registro que lleva este Ministerio, por haberse</div><div class=\"p\">configurado respecto de ella la causal de cancelaci&#xF3;n</div><div class=\"p\">contemplada en el articulo 5&#xB0; inciso 3&#xB0;, en relaci&#xF3;n con el</div><div class=\"p\">art&#xED;culo 18 No. 2 letra a) del Decreto Ley No. 2.757, de 1979.</div><br></div>", "i": 8321248}, {"t": "<div><div class=\"p\">Ximena del Pozo Parada, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n subrogante.</div><br></div>", "i": 8321249}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "134", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-134"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-08-24", "doble_articulado": false, "id_norma": "92117", "numero_fuente": "33495", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-10-13", "vigencias": [{"desde": "1989-10-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-10-13", "fin_vigencia": ""}, "vige