{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA DENOMINACION A LA CALLE QUE INDICA DE LA CIUDAD DE SAN FERNANDO</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8281233}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Denom&#xED;nase calle &quot;Olegario Lazo Baeza&quot; a la actual calle &quot;Nacimiento&quot; de la ciudad de San Fernando.&quot; </div></div>", "i": 8281234}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, catorce de Septiembre de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- S&#xF3;tero del R&#xED;o Gundi&#xE1;n.</div><br></div>", "i": 8281235}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14039", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14039"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA DENOMINACION A LA CALLE QUE INDICA DE LA\nCIUDAD DE SAN FERNANDO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "CALLE OLEGARIO LAZO BAEZA", "SAN FERNANDO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-09-14", "doble_articulado": false, "id_norma": "27653", "numero_fuente": "24755", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-09-28", "vigencias": [{"desde": "1960-09-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1960-09-28", "fin_vigencia": ""}, "vigencias_version_norma"