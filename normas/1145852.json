{"html": [{"t": "<div><div class=\"p\">CERTIFICADO N&#xBA; 271</div></div>", "i": 10124310}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Certifico: Que por escritura p&#xFA;blica de fecha 30 de agosto de 2019, otorgada en la Quinta Notar&#xED;a de Santiago del Notario P&#xFA;blico don Patricio Raby Benavente, domiciliado en calle Gertrudis Eche&#xF1;ique N&#xBA; 30, oficina 32, comuna de Las Condes, se redujo el acta de la junta extraordinaria de accionistas de SRM Administradora General de Fondos S.A. celebrada el 23 de agosto de 2019.</div><div class=\"p\">&nbsp; &nbsp;  Que, por resoluci&#xF3;n exenta N&#xBA; 2.900, de fecha 20 de mayo de 2020, de esta Comisi&#xF3;n para el Mercado Financiero, se autoriz&#xF3; la disoluci&#xF3;n anticipada de SRM Administradora General de Fondos S.A.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10124311}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de mayo de 2020.- Por orden del Consejo de la Comisi&#xF3;n para el Mercado Financiero, Gerardo Bravo Riquelme, Secretario General. </div><br></div>", "i": 10124312}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2900 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2900 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "COMISIÓN PARA EL MERCADO FINANCIERO"], "titulo_norma": "CERTIFICADO Nº 271", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1766756"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-05-20", "doble_articulado": false, "id_norma": "1145852", "numero_fuente": "42667", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-05-29", "vigencias": [{"desde": "2020-05-29", "hast