{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO RESOLUCI&#xD3;N EXENTA N&#xBA; 5.239, DE 2011</div></div>", "i": 9155716}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En cumplimiento de lo se&#xF1;alado en el art&#xED;culo 48 de la ley N&#xBA; 19.880, el Servicio Nacional de Capacitaci&#xF3;n y Empleo cumple con informar que mediante resoluci&#xF3;n exenta N&#xBA; 5.239 de 16 de junio de 2011, se dej&#xF3; sin efecto la resoluci&#xF3;n exenta N&#xBA; 672 de 19 de enero de 2011, modificada por la resoluci&#xF3;n exenta N&#xBA; 2.974 de 8 de abril de 2011, se aprobaron las Instrucciones para la Ejecuci&#xF3;n del &quot;Programa Formaci&#xF3;n en el Puesto de Trabajo 2011&quot; y se deleg&#xF3; facultades en los Directores Regionales y funcionarios a contrata del Sence.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio, www.sence.cl.- </div><br></div>", "i": 9155717}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Miguel Bergu&#xF1;o Ca&#xF1;as, Director Nacional.</div></div>", "i": 9155718}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5239 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5239 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO RESOLUCIÓN EXENTA Nº 5.239, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-06-16", "doble_articulado": false, "id_norma": "1027423", "numero_fuente": "40001", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-07-04", "vigencias": [{"desde": "2011-07-04", "hasta": "", "ti