{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6176276}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP No. 1.030, de 29 de abril de 1999, se expropiaron los lotes de terreno No. s.1, 3 y 11, superficie 11, 30 y 75 M2, respectivamente, roles de aval&#xFA;o 3198-38, S/R y 3198-19, comuna de Chill&#xE1;n, para la obra Camino Ruta N-545 Chill&#xE1;n, Tanilvoro, Sector Chill&#xE1;n - Universidad Adventista y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Eladio Edgardo Hermosilla San Mart&#xED;n, Ren&#xE9; Wenceslao Henr&#xED;quez S&#xE1;nchez y Aurora Elena del Carmen Parra Sep&#xFA;lveda, ascendentes a la cantidad de $ 195.098.- para el lote No. 1; $ 469.890.- para el lote No. 3 y $ 426.938.- para el lote No. 11.-</div><br></div>", "i": 6176277}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6176278}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1030", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1030"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-04-29", "doble_articulado": false, "id_norma": "138722", "numero_fuente": "36401", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-07-01", "vigencias": [{"desde": "1999-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul