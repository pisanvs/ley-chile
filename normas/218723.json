{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6743193}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n P&#xFA;blica Subrogante que suscribe, certifica que la Universidad Central inscrita en el folio C N&#xBA; 4, del Libro de Registro de Universidades, ha presentado los planes y programas de estudio de la carrera de Ingenier&#xED;a Civil en Obras Civiles, conducente al grado acad&#xE9;mico de Licenciado en Ciencias de la Ingenier&#xED;a y el t&#xED;tulo profesional de Ingeniero Civil en Obras Civiles, a la Universidad de Chile como entidad examinadora ( art. 24&#xBA; DFL. 1/1980) y revisados por &#xE9;sta, han sido aprobados en tiempo y forma.</div><br></div>", "i": 6743194}, {"t": "<div><div class=\"p\">Santiago, 08 Feb. 1988</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  RAUL MOHR RAY</div><div class=\"p\">&nbsp; &nbsp;  Subsecretario de Educaci&#xF3;n P&#xFA;blica (S)</div><br></div>", "i": 6743195}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-02-08", "doble_articulado": false, "id_norma": "218723", "numero_fuente": "33006", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-26", "vigencias": [{"desde": "1988-02-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"in