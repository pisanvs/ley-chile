{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9344068}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por <a href=\"https://www.leychile.cl/Navegar?idNorma=1050122&amp;idParte=0&amp;idVersion=\">Decreto MOP (Exento) N&#xBA;278, de 28 de febrero de 2013</a>, modificado por Decreto MOP (Exento) N&#xBA;448, de 28 de marzo de 2013, y de conformidad a lo dispuesto en el art. 105 del DFL MOP N&#xBA;850 de 1997, se expropi&#xF3; el lote N&#xBA;48, superficie 1.434 m2, rol N&#xBA;2115-18, Comuna de Puerto Montt, para la obra &quot;MEJORAMIENTO RUTA V-815, TRAMO BIF. ILQUE - CRUCE RUTA V-85&quot;, PROVINCIA DE LLANQUIHUE, X REGION DE LOS LAGOS. La Comisi&#xF3;n de Peritos integrada por Nelson Bernardo Turra Turra, Christian Emil Rauch Y&#xE1;&#xF1;ez y Nelson Fabi&#xE1;n Igor Flores, fij&#xF3; el valor de tasaci&#xF3;n con fecha 05 de diciembre de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario JOS&#xC9; DEL CARMEN MANSILLA GALLARDO, en la cantidad de $2.623.448.- suma que se pagar&#xE1; al contado.- </div><br></div>", "i": 9344069}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9344070}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "448 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-448 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-03-28", "doble_articulado": false, "id_norma": "1050185", "numero_fuente": "40534", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-04-15", "vigencias":