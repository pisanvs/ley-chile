{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n de gracia al ex-guardi&#xE1;n de la Polic&#xED;a de Quirihue don Gonzalo Sep&#xFA;lveda.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 8277407}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, al ex-guardi&#xE1;n de la Polic&#xED;a de Quirihue, don Gonzalo Sep&#xFA;lveda, el goce de una pensi&#xF3;n mensual de cincuenta pesos.</div><div class=\"p\">&nbsp; &nbsp; La pensi&#xF3;n otorgada por esta ley se disfrutar&#xE1; por el plazo de diez a&#xF1;os.</div><br></div>", "i": 8277408}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, quince de Febrero de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- Enrique Balmaceda. </div></div>", "i": 8277409}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4314", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4314"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE PENSION DE GRACIA AL EX-GUARDIAN DE LA POLICIA DE QUIRIHUE DON GONZALO SEPULVEDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["GONZALO SEPULVEDA", "PENSION GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-02-15", "doble_articulado": false, "id_norma": "24653", "numero_fuente": "15005", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-02-21", "vigencias": [{"desde": "1928-02-21", 