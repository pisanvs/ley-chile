{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6409512}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.897, de 19 de diciembre de</div><div class=\"p\">2002, de esta Subsecretar&#xED;a, autor&#xED;zase a ANTONIO DA</div><div class=\"p\">VENECIA RETAMALES, para ampliar las actividades</div><div class=\"p\">pesqueras extractivas con la nave &quot;T&#xED;o Gringo&quot;, con los</div><div class=\"p\">artes de pesca y en el &#xE1;rea mar&#xED;tima que se indica, por fuera del &#xE1;rea de reserva artesanal, sobre los siguientes recursos hidrobiol&#xF3;gicos: a) En el litoral de la V Regi&#xF3;n, con espinel: Reineta, Besugo, Congrio negro y Palometa; b) Litoral de la V Regi&#xF3;n, con arrastre: Gamba, Besugo y Calamar; c) Litoral de la IV a VIII Regiones, con poteras: Jibia y Calamar; d) Litoral de la IV a VI Regiones, con trampas: Centoll&#xF3;n&nbsp; del norte, Centolla del norte y Centolla.</div><br></div>", "i": 6409513}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de diciembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6409514}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2897", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2897"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-19", "doble_articulado": false, "id_norma": "206527", "numero_fuente": "37454", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-01-09", "vigencias": [{"desde": "2003-01-09", "ha