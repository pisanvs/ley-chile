{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 757 EXENTA, DE 2006 </div></div>", "i": 6570519}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 757, de 24 de abril de 2006, se autoriz&#xF3; de conformidad a lo dispuesto en el N&#xBA; 5 de la resoluci&#xF3;n N&#xBA; 65, de 2000, del Ministerio de Transportes y Telecomunicaciones, al taller que a continuaci&#xF3;n se individualiza para adecuar veh&#xED;culos al uso de gas licuado de petr&#xF3;leo como combustible:</div><br><div class=\"p\">Empresa&nbsp; &nbsp; &nbsp; &nbsp;  Nombre del&nbsp; &nbsp; Direcci&#xF3;n&nbsp; &nbsp; &nbsp;  Ciudad</div><div class=\"p\">Habilitada&nbsp; &nbsp; &nbsp; Taller&nbsp; &nbsp; &nbsp; &nbsp; del Taller</div><br><div class=\"p\">Emasa S.A.&nbsp; &nbsp; &nbsp; Sociedad&nbsp; &nbsp; &nbsp; Longitudinal&nbsp; &nbsp; Rancagua</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Inversiones&nbsp;  Sur 0339</div><div class=\"p\">Elecser Ltda.&nbsp;  El Cardal</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Limitada</div><br><div class=\"p\">&nbsp; &nbsp;  La autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.</div><br></div>", "i": 6570520}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Danilo N&#xFA;&#xF1;ez Izquierdo, Subsecretario de Transportes.</div><br><br></div>", "i": 6570521}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "757 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-757 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 757 EXENTA, DE 2006", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "p