{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6575731}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (Exento) N&#xBA; 297 de fecha 31 de mayo de 2006, se expropi&#xF3; el lote de terreno N&#xBA; 6, superficie 4.830,22 m2, Rol N&#xBA; 385-59, comuna de Pitrufqu&#xE9;n, IX Regi&#xF3;n para la obra &quot;Dise&#xF1;o Definitivo de la Red Secundaria y Terciaria de Canales de Riego Proyecto Faja Maisan, Canal Cantarrana&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Oscar Rolando Lincop&#xE1;n Millahueque, ascendente a la cantidad de $3.118.104.- para el lote N&#xBA; 6.</div><br></div>", "i": 6575732}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6575733}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "297 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-297 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-05-31", "doble_articulado": false, "id_norma": "251273", "numero_fuente": "38514", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-07-15", "vigencias": [{"desde": "2006-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2006-07-17", "fecha_version": "2006-07-15", "fecha_actualizacion_texto"