{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA EL D.F.L. N.o 178, DE 13 DE MAYO DE 1931, QUE APROBO LAS LEYES DEL TRABAJO</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5962422}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.o Los plazos de d&#xED;as establecidos en el Libro IV, T&#xED;tulo I, P&#xE1;rrafo II, del D. F. L. N.o 178, se entender&#xE1;n suspendidos durante los d&#xED;as feriados. </div></div>", "i": 5962423}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo transitorio.- Lo dispuesto en la presente Ley regir&#xE1; para todos los plazos que estuvieren pendientes a la fecha de su promulgaci&#xF3;n.</div><br></div>", "i": 5962424}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo final.- La presente Ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial. </div></div>", "i": 5962425}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto, en todas sus partes, como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, ocho de Junio de mil novecientos treinta y seis.- ARTURO ALESSANDRI.- Dr. Pedro Fajardo. </div></div>", "i": 5962426}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "5831", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-5831"}], "organismos": ["MINISTERIO DEL TRABAJO"], "titulo_norma": "MODIFICA EL D.F.L. N.o 178, DE 13 DE MAYO DE 1931,\nQUE APROBO LAS LEYES DEL TRABAJO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TRIBUNALES TRABAJO", "INSPECCION GENERAL TRABAJO", "DEMANDAS", "NOTIFICACIONES", "PLAZOS", "DIAS FERIADOS", "EXCLUSION", "CODIGO TRABAJO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1936-06-08", "doble_articulado": false, "id_norma": "25216", "numero_fuente": "17497", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1936-06-20", "vigencias": [{"desde": "1936-06-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1936-06-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1936-06-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "fecha_version": "1936-06-20", "fecha_actualizacion_texto": "1936-06-20", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 5962422}, {"n": "Artículo 1", "i": 5962423, "t": 6}, {"n": "Artículo 1 Transitorio", "i": 5962424, "t": 6}, {"n": "Artículo 2 FINAL", "i": 5962425, "t": 6}, {"n": "Promulgación", "i": 5962426}]}