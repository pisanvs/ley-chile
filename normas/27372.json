{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA EL ITEM QUE SE&#xD1;ALA DE LA LEY DE PRESUPUESTO DEL A&#xD1;O 1958</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5972642}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Interc&#xE1;lase en el &#xED;tem 12/08/11/a-32-a de la Ley de Presupuesto del a&#xF1;o 1958, entre las palabras &quot;aguas subterr&#xE1;neas&quot; y &quot;San Pedro de Atacama&quot;, la frase: &quot;y otras obras de riego en&quot;.&quot; </div></div>", "i": 5972643}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a diecisiete de Octubre de mil novecientos cincuenta y ocho.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Eduardo Y&#xE1;&#xF1;ez Zavala.</div><br></div>", "i": 5972644}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13110", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13110"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "MODIFICA EL ITEM QUE SEÑALA DE LA LEY DE PRESUPUESTO\nDEL AÑO 1958", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O 1958", "MODIFICA", "OBRAS RIEGO", "SAN PEDRO ATACAMA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1958-10-17", "doble_articulado": false, "id_norma": "27372", "numero_fuente": "24117", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1958-10-24", "vigencias": [{"desde": "1958-10-24", "hasta": ""