{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Club Concepcion Lei n&#xFA;m. 77.- Santiago, a 16 de Agosto de 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7162482}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese al Club Concepcion el permiso requerido por el art&#xED;culo 556 del C&#xF3;digo Civil para que pueda conservar por treinta a&#xF1;os la propiedad del sitio que posee en la calle de O&apos;Higgins de la ciudad de Concepcion.</div><br><br></div>", "i": 7162483}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- J. Rodr&#xED;guez Rozas.</div><br></div>", "i": 7162484}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "77", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-77"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "CLUB CONCEPCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CLUB CONCEPCION", "PREDIO", "PROPIEDAD", "CONSERVACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-08-16", "doble_articulado": false, "id_norma": "21948", "numero_fuente": "4597", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-08-17", "vigencias": [{"desde": "1893-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-08-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-08-17", "fin_vigenc