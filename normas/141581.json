{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 38, DE 1987 </div></div>", "i": 6185691}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 38 de 25 de febrero de 1987 se han aprobado, a contar del presente a&#xF1;o escolar, planes y programas de estudios especiales para el segundo ciclo de Educaci&#xF3;n General B&#xE1;sica con especialidad en Agricultura de la Escuela &quot;La Granja&quot;, de la comuna de Nueva Imperial, provincia de Caut&#xED;n, IX Regi&#xF3;n de La Araucan&#xED;a, dependiente de la Corporaci&#xF3;n Metodista de Chile.</div><br><br><br></div>", "i": 6185692}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 06 de Marzo 1987.- Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 6185693}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "38 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-38 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 38, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-25", "doble_articulado": false, "id_norma": "141581", "numero_fuente": "32725", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-03-18", "vigencias": [{"desde": "1987-03-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-03-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-03-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_p