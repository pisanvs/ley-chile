{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8584866}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto (Exento) MOP N&#xBA; 526 de fecha 31 de marzo del 2009, se expropi&#xF3; el lote de terreno N&#xBA; 51, superficie 288 m2, Rol N&#xBA; 631-31, comuna de Molina, VII Regi&#xF3;n para la obra &quot;Camino Mejoramiento Ruta K-155, Sector Quechereguas - Buena Paz, Tramo Km. 0,00000 a Km. 10,40000. Camino Mejoramiento Ruta K-15, Sector Quechereguas, Tramo Km. 5,70000 a Km. 5,90000&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario RIGOBERTO SANTIAGO DEL CARMEN AMBIADO VERGARA, ascendente a la cantidad de $7.587.619.- para el lote N&#xBA;51. </div></div>", "i": 8584867}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 8584868}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "526 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-526 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-03-31", "doble_articulado": false, "id_norma": "1001757", "numero_fuente": "39351", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-05-02", "vigencias": [{"desde": "2009-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso":