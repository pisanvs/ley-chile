{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6257129}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto No. 286, de 30 de septiembre de 1985, se expropiaron los lotes No.s. 4 y 4-B, cuyas superficies son 220 m2 y 64 m2., rol de aval&#xFA;o 44-67, Comuna de Peumo, para Ruta H66-G Pelequ&#xE9;n Cruce Las Ara&#xF1;as, sector Codao-Las Cabras y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios don Juan Lobos Ulloa y don Juan Arriaza Maldonado, ascendente a $ 96.968 y $ 631.504, respectivamente.</div><br></div>", "i": 6257130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6257131}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "286", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-286"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-09-30", "doble_articulado": false, "id_norma": "163011", "numero_fuente": "32311", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-11-02", "vigencias": [{"desde": "1985-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-03-30", "fecha_version": "1985-11-02", "fecha_actualizacion_texto": "1985-11-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado