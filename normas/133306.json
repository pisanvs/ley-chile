{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;1.065 EXENTO, DE 1998</div><br><br></div>", "i": 6158690}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA;1.065 de 1&#xBA; de diciembre de 1998, se ha aprobado a partir del a&#xF1;o escolar 1999, un programa de Religi&#xF3;n de las Iglesias y Corporaciones Evang&#xE9;licas de Chile para los cursos de 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que podr&#xE1; aplicarse conforme a la gradualidad establecida en el decreto supremo de Educaci&#xF3;n N&#xBA; 220 de 1998.</div><br></div>", "i": 6158691}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de diciembre de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6158692}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1065 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1065 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº1.065 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-12-01", "doble_articulado": false, "id_norma": "133306", "numero_fuente": "36309", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-03-09", "vigencias": [{"desde": "1999-03-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-03-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-03-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_