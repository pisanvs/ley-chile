{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 5.629 EXENTA, DE 2003 </div></div>", "i": 6449981}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 5.629, de 28 de abril del a&#xF1;o 2003, se han modificado las resoluciones exentas de Educaci&#xF3;n N&#xBA;s. 12.880, de 1999, y 5.114, de 2001, que aprobaron planes y programas especiales de estudio para 1&#xBA;, 2&#xBA;, 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media al Colegio Academia de Humanidades (Padres Dominicos), de la comuna de Recoleta, provincia de Santiago, en el sentido de sustituir los planes de estudio para todos los cursos de Ense&#xF1;anza Media, a partir del a&#xF1;o escolar 2003, por los que se indican en la presente resoluci&#xF3;n.</div><br></div>", "i": 6449982}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de abril de 2003.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6449983}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5629 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5629 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 5.629 EXENTA, DE 2003", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-04-28", "fecha_derogacion": "2015-08-31", "doble_articulado": false, "id_norma": "217688", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-11-24", "vigencias": [{"desde": "2015-08-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-11-24", "hasta": "2015-08-30", "tipo_version": "0", "tipo_version_s": "Te