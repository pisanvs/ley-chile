{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N&#xB0; 14.948 Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5979508}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Reempl&#xE1;zase en el art&#xED;culo 2&#xB0;, letra b), de la ley n&#xFA;mero 14.948, la frase &quot;para la reparaci&#xF3;n total&quot;, por la siguiente: &quot;para la reconstrucci&#xF3;n&quot;.</div><br></div>", "i": 5979509}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintitr&#xE9;s de Agosto de mil novecientos sesenta y ocho.- EDUARDO FREI MONTALVA.- Sergio Ossa Pretot.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Dios gue. a Ud.- Carlos Valenzuela R., Subsecretario de Obras P&#xFA;blicas.</div><br></div>", "i": 5979510}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "16915", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-16915"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS Y TRANSPORTES"], "titulo_norma": "MODIFICA LA LEY N° 14.948", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FACULTAD", "PRESIDENTE REPUBLICA", "INVERSION", "PRIMER CENTENARIO", "LEBU", "DESTINACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1968-08-23", "doble_articulado": false, "id_norma": "28699", "numero_fuente": "27138", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1968-09-06", "vigencias": [{"desde": "1968-09-06", "hasta": "", "tipo_