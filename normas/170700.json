{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 9051930}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.730, de fecha 23 de Diciembre de 1987, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana se autoriza a don Juan Bautista Castillo, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 9051931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de Diciembre de 1987.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 9051932}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1730 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1730 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-23", "doble_articulado": false, "id_norma": "170700", "numero_fuente": "32979", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-01-26", "vigencias": [{"desde": "1988-01-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-01-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-01-26", "fin_vigencia": "", "tipo_version": "3