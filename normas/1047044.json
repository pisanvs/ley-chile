{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9321007}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP Exento N&#xBA;2911 de 29 de noviembre de 2012, de conformidad lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;7-A, superficie 86 m2, rol de Aval&#xFA;o N&#xBA;114-7, comuna de Malloa, para la obra &quot;CONSTRUCCI&#xD3;N CICLOV&#xCD;AS EN DIVERSAS COMUNAS, PROVINCIA DE CACHAPOAL, SEXTA REGI&#xD3;N&quot;. La Comisi&#xF3;n de peritos, integrada por MARLENE R&#xCD;OS MARCUELLO, ORLANDO FARI&#xD1;A V&#xC1;SQUEZ Y PELAYO VIAL VIAL, fij&#xF3; el valor de tasaci&#xF3;n con fecha 15 de marzo de 2012, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario H&#xC9;CTOR ANTONIO CORNEJO GONZ&#xC1;LEZ, en la cantidad de $923.559.-, suma que se pagar&#xE1; al contado. </div></div>", "i": 9321008}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9321009}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2911 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2911 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-11-29", "doble_articulado": false, "id_norma": "1047044", "numero_fuente": "40435", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-12-15", "vigencias": [{"desde": "2012-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"