{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9305836}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP Exento N&#xBA;2118 de 28 de septiembre de 2012, de conformidad a lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;2, superficie 1.133 m2, rol de Aval&#xFA;o N&#xBA;113-15, comuna de Coihueco, para la obra &quot;CONSTRUCCI&#xD3;N PASARELA VEGUILLAS, COMUNAS SAN FABI&#xC1;N - COIHUECO&quot;, VIII Regi&#xF3;n. La Comisi&#xF3;n de peritos, integrada por ADRIANA FASCE CASANUEVA, ROXANA CECILIA ABARZ&#xDA;A GAJARDO Y FRANCISCO JOS&#xC9; LAMA VERGARA, fij&#xF3; el valor de tasaci&#xF3;n con fecha 28 de diciembre de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario don MIGUEL ARTURO GONZ&#xC1;LEZ GONZ&#xC1;LEZ, en la cantidad de $1.813.613.-, suma que se pagar&#xE1; al contado.</div></div>", "i": 9305837}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9305838}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2118 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2118 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-09-28", "doble_articulado": false, "id_norma": "1044786", "numero_fuente": "40386", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-10-16", "vigencias": [{"desde": "2012-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-10-16", "fin_vigencia": ""}, "vigenci