{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 6.210 EXENTA, DE 1999 </div><br></div>", "i": 6188401}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 6.210 de fecha 8 de julio de 1999 del Ministerio de Educaci&#xF3;n, no se concedi&#xF3; el reconocimiento oficial al Centro de Formaci&#xF3;n T&#xE9;cnica Leonardo Da Vinci, organizado por la Sociedad Instituto de Educaci&#xF3;n Superior Da Vinci Limitada, ubicado en Avenida Pedro de Valdivia N&#xBA; 801, de la ciudad de Concepci&#xF3;n y elim&#xED;nase del Libro de Registro de Centros de Formaci&#xF3;n T&#xE9;cnica en que se encuentra inscrito con el N&#xBA; 258 de fecha 27 de agosto de 1998.</div><br></div>", "i": 6188402}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de agosto de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6188403}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6210", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-6210"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 6.210 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-07-08", "doble_articulado": false, "id_norma": "142483", "numero_fuente": "36456", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-03", "vigencias": [{"desde": "1999-09-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-09-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen