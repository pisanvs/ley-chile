{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8579276}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xBA;604 de 03 de Julio de 1992, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por un a&#xF1;o, a contar de la fecha de esta resoluci&#xF3;n, el plazo otorgado a AQUACHILE S.A., R.U.T.</div><div class=\"p\">N&#xBA;79.800.600-2, domiciliada en la ciudad de Puerto Montt calle Varas N&#xBA;802, para iniciar actividades que tiene autorizadas por resoluci&#xF3;n N&#xBA;1.751, de 1989 prorrogada por resoluci&#xF3;n N&#xBA;578, de 1991, ambas de esta Subsecretar&#xED;a en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8579277}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 03 de Julio de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8579278}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "604", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-604"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-07-03", "doble_articulado": false, "id_norma": "78207", "numero_fuente": "34319", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-07-18", "vigencias": [{"desde": "1992-07-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-07-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-07-18", "fin_vigencia": "", "tipo_version": "3"}], "event