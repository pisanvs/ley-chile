{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,022.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6176585}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.-&nbsp; Conc&#xE9;dese, por gracia, a don Gonzalo G&#xF3;mez, derecho a jubilar con arreglo al sueldo de que disfrutaba como empleado de los Ferrocarriles del Estado, i debiendo comput&#xE1;rsele, para este efecto, el tiempo que ha servido en este ramo i en los demas empleos p&#xFA;blicos que ha desempe&#xF1;ado.</div><br></div>", "i": 6176586}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a cuatro de setiembre de mil novecientos quince.-&nbsp; Ramon Barros Luco.-&nbsp; Fernando Freire.</div><br></div>", "i": 6176587}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3022", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3022"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1915-09-04", "doble_articulado": false, "id_norma": "138825", "numero_fuente": "11340", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1915-12-10", "vigencias": [{"desde": "1915-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1915-12-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"