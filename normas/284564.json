{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7417892}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 3.403, de 30 de diciembre de 2008, de esta Subsecretar&#xED;a, rectificase el numeral 1.- letra a) de la resoluci&#xF3;n exenta N&#xB0; 3.252 de 2008, que modific&#xF3; la pesca de investigaci&#xF3;n autorizada mediante resoluci&#xF3;n exenta N&#xB0; 442 de 2008, y modificaciones posteriores, todas de esta Subsecretar&#xED;a, en el sentido de indicar que el nombre correcto de la embarcaci&#xF3;n artesanal all&#xED; indicada es &quot;Oceani III&quot;, y no &quot;Oceani I&quot;, como all&#xED; se indica. </div></div>", "i": 7417893}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de diciembre de 2008. Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca. </div></div>", "i": 7417894}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3403 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3403 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-12-30", "doble_articulado": false, "id_norma": "284564", "numero_fuente": "39255", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-01-07", "vigencias": [{"desde": "2009-01-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-01-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-01-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci