{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6167200}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 13 de 25 de Marzo de 1988 de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se autoriza a D&#xF1;a. Mar&#xED;a Elo&#xED;sa Anselmo Galaz, para efectuar todo tipo de servicios de transportes de pasajeros, por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6167201}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rancagua, 25 de Marzo de 1988.- Juan Latife Saadi, Secretario Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n (S).</div><br></div>", "i": 6167202}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "13 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-13 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-25", "doble_articulado": false, "id_norma": "135952", "numero_fuente": "33034", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-03-30", "vigencias": [{"desde": "1988-03-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-03-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-03-30", "fin_vigencia": "",