{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,335.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6163443}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Se autoriza al Presidente de la Rep&#xFA;blica, por el t&#xE9;rmino de un a&#xF1;o, para invertir hasta la suma de treinta mil pesos en una Esposicion Industrial de productos i artefactos nacionales, i hasta diez mil pesos en la adquisicion de los objetos espuestos que puedan servir de base a un Museo Industrial.</div><br></div>", "i": 6163444}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de enero de 1900.- FEDERICO ERRAZURIZ.-</div><div class=\"p\">J.F. Valdes C.</div><br></div>", "i": 6163445}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1335", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1335"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-01-25", "doble_articulado": false, "id_norma": "134786", "numero_fuente": "6508", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-01-29", "vigencias": [{"desde": "1900-01-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-01-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1900-0