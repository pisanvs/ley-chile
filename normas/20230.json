{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 113 EXENTO, DE 1996 </div></div>", "i": 5941338}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Supremo exento de Educaci&#xF3;n N&#xB0; 113, de 13 de febrero de 1996, se derog&#xF3; el Decreto Supremo de Educaci&#xF3;n N&#xB0; 184, de 1983, que aprob&#xF3; plan especial de estudio al Colegio Saint Dominic de Vi&#xF1;a del Mar.</div><div class=\"p\">&nbsp; &nbsp; A partir del a&#xF1;o escolar 1996, el Colegio se regir&#xE1; por el Decreto Supremo de Educaci&#xF3;n N&#xB0; 300, de 1981. </div></div>", "i": 5941339}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 8 de marzo de 1996.- Jaime P&#xE9;rez de Arce Araya, Ministro de Educaci&#xF3;n (S).</div><br></div>", "i": 5941340}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "113", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-113"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 113 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DEROGACION", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "COLEGIO SAINT DOMINIC", "VI A DEL MAR", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-02-13", "doble_articulado": false, "id_norma": "20230", "numero_fuente": "35640", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-12-13", "vigencias": [{"desde": "1996-12-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-12-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-12-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [],