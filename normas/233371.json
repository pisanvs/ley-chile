{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8048023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.483 de 6 de diciembre de 2004, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto parcialmente la resoluci&#xF3;n N&#xBA; 3.298 de 2004, s&#xF3;lo en cuanto declar&#xF3; la caducidad de la resoluci&#xF3;n N&#xBA; 2.542 de 2001, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA AGUA FRIA S.A. para desarrollar actividades pesqueras extractivas con la nave &quot;Dubrovnik II&quot;, en virtud de lo dispuesto en la presente resoluci&#xF3;n. </div></div>", "i": 8048024}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de diciembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 8048025}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3483 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3483 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-06", "doble_articulado": false, "id_norma": "233371", "numero_fuente": "38033", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-11", "vigencias": [{"desde": "2004-12-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-12-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-12-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}],