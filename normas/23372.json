{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede fondos para cancelar cuentas pendientes del Ministerio de Justicia</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,581.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7165879}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que invierta hasta la suma de ciento veintisiete mil ochenta pesos treinta i cuatro centavos ($ 127,080.34) en cancelar las cuentas de a&#xF1;os anteriores que hai pendientes en el Ministerio de Justicia.</div><br></div>", "i": 7165880}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 7 de Diciembre de 1911.- RAMON BARROS LUCO.- Benjam&#xED;n Montt.</div><br></div>", "i": 7165881}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2581", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2581"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDE FONDOS PARA CANCELAR CUENTAS PENDIENTES DEL MINISTERIO DE JUSTICIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MINISTERIO JUSTICIA", "CUENTAS PENDIENTES", "PAGO", "FONDOS", "INVERSION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-12-07", "doble_articulado": false, "id_norma": "23372", "numero_fuente": "10151", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-12-09", "vigencias"