{"html": [{"t": "<div><div class=\"p\">CARTAS DE NATURALEZA.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Noviembre 3 de 1832.</div><br><div class=\"p\">&nbsp; &nbsp;  Con esta fecha S.E. el Presidente de la Rep&#xFA;blica ha acordado y decreta:</div></div>", "i": 10250028}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. 1.&#xB0; Los extranjeros que, hall&#xE1;ndose con las calidades que exije la Constitucion para ser chilenos legales, solicitasen esta declaracion del Senado, o Comision permanente, para obtener carta de naturaleza conforme a la lei del Congreso de 4 de noviembre de 1828 (Bol. n&#xFA;n. 5 lib. 4) expresar&#xE1;n en sus memoriales la nacion a que pertenecen.</div></div>", "i": 10250029}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; Las Municipalidades de los pueblos, encargadas de refrendar los justificativos que exijen los art&#xED;culos 2 y 3 de la espresada lei, no dar&#xE1;n curso a los expedientes que carezcan del requisito prevenido en el art&#xED;culo anterior.</div></div>", "i": 10250030}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  3.&#xB0; Circ&#xFA;lese y publ&#xED;quese para que llegue a noticia de todos.</div></div>", "i": 10250031}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  PRIETO.&nbsp; </div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; Joaquin Tocornal.</div></div>", "i": 10250032}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "CARTAS DE NATURALEZA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-11-03", "doble_articulado": false, "id_norma": "1161854", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-11-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-11-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-11-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "504", "fecha_ingreso": "2021-07-12", "fecha_version": "1832-11-03", "fecha_actualizacion_texto": "2021-07-12", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10250028}, {"n": "Artículo 1", "i": 10250029, "t": 6}, {"n": "Artículo 2", "i": 10250030, "t": 6}, {"n": "Artículo 3", "i": 10250031, "t": 6}, {"n": "Promulgación", "i": 10250032}]}