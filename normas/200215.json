{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A DON GENARO LORENZO DIAZ ULLOA</div><br><br></div>", "i": 6388273}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional del S.I.I., por resoluci&#xF3;n DRE09.00 N&#xBA; Ex. 1.130, de fecha 20/06/02, y resoluci&#xF3;n DRE09.00 N&#xBA; Ex. 1.147, de fecha 26/06/02, revoca a contar de la fecha de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado en las operaciones de ventas de harina de trigo y compra de trigo, al contribuyente RUT N&#xBA;3.772.939-6, Genaro Lorenzo D&#xED;az Ulloa, conforme a lo establecido en el resolutivo&nbsp; N&#xBA; 17 de la resoluci&#xF3;n N&#xBA;5.282/2000 y el resolutivo N&#xBA; 18 de la resoluci&#xF3;n N&#xBA;5.281/2000 respectivamente, de la Direcci&#xF3;n Nacional.</div><br></div>", "i": 6388274}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Ren&#xE9; Cornejo C&#xE1;ceres, Director Regional. </div></div>", "i": 6388275}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1147 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1147 EXENTA"}, {"tipo": "3", "numero": "DRE-09-00-1147 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-09-00-1147 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A DON GENARO LORENZO DIAZ ULLOA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-26", "doble_articulado": false, "id_norma": "200215", "numero_fuente": "37305", "tipo_version": "3", "tipo_vers