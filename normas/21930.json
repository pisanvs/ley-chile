{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Montep&#xED;o Lei n&#xFA;m. 57.-Santiago, a 7 de Agosto de 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946634}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese por gracia a do&#xF1;a Demofila P&#xE9;rez de Valenzuela, v. de Valverde, el montep&#xED;o correspondiente a teniente de Ej&#xE9;rcito.</div><br><br></div>", "i": 5946635}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- V. D&#xE1;vila Larrain.</div><br></div>", "i": 5946636}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "57", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-57"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "MONTEPIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DEMOFILA PEREZ VIUDA DE VALVERDE", "MONTEPIO POR", "GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-08-07", "doble_articulado": false, "id_norma": "21930", "numero_fuente": "4594", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-08-12", "vigencias": [{"desde": "1893-08-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-08-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-08-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-01-07", "