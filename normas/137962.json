{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,739.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6173723}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Eufemia Rodr&#xED;guez Fontecilla, viuda de Rodr&#xED;guez, nieta del coronel servidor de la Independencia, don Pedro Nolasco Fontecilla, el goce de una pension mensual de sesenta i cinco pesos ($ 65), de que disfrutar&#xE1; con arreglo a la lei jeneral de montep&#xED;o militar.</div><br></div>", "i": 6173724}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a quince de enero de mil novecientos trece.- Ramon Barros Luco.- Claudio Vicu&#xF1;a S.</div><br></div>", "i": 6173725}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2739", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2739"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1913-01-15", "doble_articulado": false, "id_norma": "137962", "numero_fuente": "10481", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1913-01-20", "vigencias": [{"desde": "1913-01-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1913-01-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1913-01-20"