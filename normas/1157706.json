{"html": [{"t": "<div><div class=\"p\">DISTINTIVO DE LOS CADETES DEL EJ&#xC9;RCITO.</div></div>", "i": 10229391}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En contestacion a la apreciable de U.S. n&#xFA;m. 497 tenemos el honor de decir que el distintivo de los Cadetes del Ej&#xE9;rcito sea un galon de cinco hilos puesto al rededor del cuello de la casaca.</div><div class=\"p\">&nbsp; &nbsp;  Dios guarde a U.S. muchos a&#xF1;os. Santiago, Mayo 12 de 1823.- Francisco Calderon.- Bernardo C&#xE1;ceres.- Francisco Elizalde.- Luis Jos&#xE9; Pereira.- Benjamin Viel.- Jos&#xE9; Antonio Mangas, Secretario.- Sr. Ministro de Estado en el Departamento de guerra.</div></div>", "i": 10229392}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Mayo 12 de 1823.</div><br><div class=\"p\">&nbsp; &nbsp;  75 Aprobado: y avisese para su cumplimiento.</div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; Rivera</div></div>", "i": 10229393}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["DEPARTAMENTO DE GUERRA Y MARINA"], "titulo_norma": "DISTINTIVO DE LOS CADETES DEL EJÉRCITO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-05-12", "doble_articulado": false, "id_norma": "1157706", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-05-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-05-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-05-12"