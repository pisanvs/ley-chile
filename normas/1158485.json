{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  FIJA PROCEDIMIENTO PARA OTORGAR BONO DE CLASE MEDIA A PENSIONADOS</div></div>", "i": 10217224}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0;40, de fecha 14 de abril de 2021, fija procedimiento para otorgar bono de clase media a los pensionados indicados en el inciso tercero del <a href=\"https://www.leychile.cl/Navegar?idNorma=1157843&amp;idParte=10214355&amp;idVersion=\">art&#xED;culo 4</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1157843&amp;idParte=&amp;idVersion=\">ley N&#xB0;21.323</a>, que establece un nuevo bono clase media y un pr&#xE9;stamo solidario para la protecci&#xF3;n de los ingresos de la clase media.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento est&#xE1; publicado en www.sii.cl.</div><div class=\"p\"> </div><br></div>", "i": 10217225}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "40 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-40 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "FIJA PROCEDIMIENTO PARA OTORGAR BONO DE CLASE MEDIA A PENSIONADOS", "fuente": "Diario Oficial", "resumenes": [], "materias": ["CORONAVIRUS COVID-19", "CORONAVIRUS", "COVID-19"], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1929503", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-04-14", "doble_articulado": false, "id_norma": "1158485", "numero_fuente": "42932", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-04-17", "vigencias": [{"desde": "20