{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTOS DE RESOLUCIONES</div><br><br><br></div>", "i": 8288805}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 659, de 11 de Junio de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modificase el numeral 3 de la Resoluci&#xF3;n N&#xB0; 179, de 1991, de esta Subsecretar&#xED;a, que autoriz&#xF3; a LITA DEL CARMEN VILLARROEL GUTIERREZ R:U.T.</div><div class=\"p\">N&#xB0; 4.967.975-0, domiciliada en Avda. El Dique N&#xB0; 1584 Constituci&#xF3;n, para ampliar actividades pesqueras, en el sentido de autorizar la extracci&#xF3;n del recurso Albacora o pez espada, (Xiphias gladius), en el litoral de las Regiones a X, con el arte de pesca enmalle.</div><br></div>", "i": 8288806}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 11 de Junio de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8288807}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "659", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-659"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "EXTRACTOS DE RESOLUCIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LITA CARMEN VILLARROEL GUTIERREZ", "PESCA", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-06-11", "fecha_derogacion": "1996-06-17", "doble_articulado": false, "id_norma": "31583", "numero_fuente": "34004", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-06-28", "vigencias": [{"desde": "1996-06-17", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "199