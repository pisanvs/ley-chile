{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6440695}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.040 de 21 de agosto de 2003 de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA;1.855 de 2000, de esta Subsecretar&#xED;a, que autoriz&#xF3; a&nbsp; PESQUERA EL GOLFO S.A. para realizar actividades pesqueras extractivas con la nave &quot;Hakon&quot;, en el sentido de incorporar las siguientes caracter&#xED;sticas n&#xE1;uticas de &#xE9;sta:</div><br><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; 48,85 m</div><div class=\"p\">Potencia principal&nbsp; &nbsp; &nbsp; 1.420 Hp</div><div class=\"p\">Potencia auxiliar&nbsp; &nbsp; &nbsp;  634,00 Hp</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  8,20 m.</div><br><br></div>", "i": 6440696}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6440697}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2040 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2040 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-08-21", "fecha_derogacion": "2011-01-18", "doble_articulado": false, "id_norma": "214958", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-09-23", "vigencias": [{"desde": "2011-01-18", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-09