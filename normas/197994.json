{"html": [{"t": "<div><div class=\"p\">LEY NUM. 4,884</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6381064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Elim&#xED;nase del inciso 3.o del art&#xED;culo 4.o de la ley n&#xFA;mero 4,157 de 5 de Agosto de 1927, la frase final que dice: &quot;y que hayan pagado patente que los habilite para ejercer su profesi&#xF3;n ante dicho Tribunal&quot;.</div><br></div>", "i": 6381065, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, cuatro de Septiembre de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Humberto Arce.</div><br></div>", "i": 6381066}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4884", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4884"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "LEY NUM. 4,884", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-09-04", "doble_articulado": false, "id_norma": "197994", "numero_fuente": "15768", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-09-06", "vigencias": [{"desde": "1930-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1930-09-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1930-09-06", "fin_vigencia": "", "tipo_version": "3"}], "eve