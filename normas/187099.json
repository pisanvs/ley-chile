{"html": [{"t": "<div><div class=\"p\">AUTORIZA A EMPRESA PESQUERA ZONA CENTRAL LTDA. PARA DESRROLLAR ACTIVIDADES PESQUERAS</div><br><br><br></div>", "i": 7283889}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 380 de 26 de Octubre de 1983 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Empresa Pesquera Zona Central Ltda., domiciliada en Santiago, para instalar y operar una planta de harina y aceite de pescado ubicada en el recinto portuario de San Antonio, Avda. El Molo s/n, en la que podr&#xE1; utilizar como materia prima sardina espa&#xF1;ola, sardina com&#xFA;n, jurel, machuelo, raya y merluza.</div><br></div>", "i": 7283890}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Octubre de 1983.- Manuel Concha Mart&#xED;nez, Coronel de Ej&#xE9;rcito, Subsecretario de Pesca subrogante.</div><br></div>", "i": 7283891}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "380", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-380"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A EMPRESA PESQUERA ZONA CENTRAL LTDA. PARA DESRROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1983-10-26", "fecha_derogacion": "2001-06-29", "doble_articulado": false, "id_norma": "187099", "numero_fuente": "31726", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1983-11-22", "vigencias": [{"desde": "2001-06-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1983-11-22", "has