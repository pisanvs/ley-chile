{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 271 EXENTO, DE 1997 </div></div>", "i": 8949564}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 271 de<div class=\"n rnp\" id=\"rnp0\"><a href=\"#np0\">NOTA:</a></div> 13 de marzo de 1997, se ha aprobado al &quot;Colegio Brit&#xE1;nico St. Margaret&apos;s&quot; de Vi&#xF1;a del Mar, un plan de estudio para los cursos de 1&#xBA; a 4&#xBA; a&#xF1;o de ense&#xF1;anza b&#xE1;sica, que se comenzar&#xE1;n a aplicar a partir del a&#xF1;o escolar 1997.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio de las asignaturas (Subsectores de Aprendizaje) Lenguaje y Comunicaci&#xF3;n; Ingl&#xE9;s; Matem&#xE1;tica; Estudio y Comprensi&#xF3;n del Medio Natural; Estudio y Comprensi&#xF3;n del Medio Social y Cultural; Educaci&#xF3;n F&#xED;sica; Orientaci&#xF3;n; Educaci&#xF3;n Tecnol&#xF3;gica; Educaci&#xF3;n Art&#xED;stica; Educaci&#xF3;n Musical.</div><br><div class=\"np\" id=\"np0\"><a href=\"#rnp0\">NOTA:</a> <br>&nbsp; &nbsp;  El DTO 1267 Exento, Educaci&#xF3;n, publicado el 28.04.1998, complementa el presente decreto.<br></div></div>", "i": 8949565, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Santiago, 19 de marzo de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8949566}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "2", "numero": "271 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-271 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 271 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO BRITANICO ST. MARGARET'S", "VI A DEL MAR", "QUINTA REGION", "PLAN DE ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_