{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 10.960</div><br><div class=\"p\">ABONA EL TIEMPO QUE INDICA ENLA HOJA DE SERVICIOS DE DO&#xD1;A AMANDINA BARRERA PRIETO</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6587186}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Ab&#xF3;nanse, por gracia, en la hoja de servicios de do&#xF1;a Arandina Barrera Prieto, y para todos los efectos legales, los 8 a&#xF1;os, 1 mes y 16 d&#xED;as que sirvi&#xF3; en la Caja Nacional de Ahorros.</div><br></div>", "i": 6587187}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintiocho de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Ignacio Lorca G.</div><br></div>", "i": 6587188}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10960", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10960"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ABONA EL TIEMPO QUE INDICA ENLA HOJA DE SERVICIOS DE\nDOÑA AMANDINA BARRERA PRIETO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-28", "doble_articulado": false, "id_norma": "254513", "numero_fuente": "22409", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-11-26", "vigencias": [{"desde": "1952-11-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_v