{"html": [{"t": "<div><div class=\"p\">EXTRACTO </div></div>", "i": 6429845}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 198 de fecha 26 de junio de 2003 de la Secretar&#xED;a Regional Ministerial Minvu Regi&#xF3;n de Coquimbo, se modific&#xF3; el guarismo 101.220 UF por 121.520 unidades de fomento.</div><div class=\"p\">&nbsp; &nbsp;  Lo no modificado por la mencionada resoluci&#xF3;n, mantendr&#xE1; plenamente vigente la resoluci&#xF3;n exenta N&#xBA; 100 de fecha 26 de marzo de 2003 de la Seremi Minvu, Regi&#xF3;n de Coquimbo.</div><br></div>", "i": 6429846}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese, reg&#xED;strese y publ&#xED;quese en el Diario Oficial.- Secretario Regional Ministerial Vivienda y Urbanismo Regi&#xF3;n de Coquimbo.</div><br></div>", "i": 6429847}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "198 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-198 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SECRETARÍA REGIONAL MINISTERIAL IV REGIÓN COQUIMBO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-26", "doble_articulado": false, "id_norma": "211986", "numero_fuente": "37599", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-03", "vigencias": [{"desde": "2003-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-07-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-07-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacio