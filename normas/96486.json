{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0;275 DE 199O</div><br><br></div>", "i": 7230931}, {"t": "<div><div class=\"p\">Por decreto exento No. 275 de fecha 25 de octubre de 1990 del Ministerio de Educaci&#xF3;n, se aprobaron las modificaciones introducidas al plan y programa de estudio del Centro de Formaci&#xF3;n T&#xE9;cnica Jorge Alvarez Echeverr&#xED;a de La Serena, de la carrera y t&#xED;tulo t&#xE9;cnico que se indica, para impartirse a contar del a&#xF1;o 1990, con la siguiente denominaci&#xF3;n:</div><br><div class=\"p\">Carrera: Secretariado Ejecutivo en Espa&#xF1;ol con menci&#xF3;n en Computaci&#xF3;n o Ingl&#xE9;s.</div><br><div class=\"p\">T&#xED;tulo: Secretario (a) Ejecutivo (a) en Espa&#xF1;ol o Secretario (a) Ejecutivo (a) con menci&#xF3;n en Computaci&#xF3;n, o </div><div class=\"p\">Secretario (a) Ejecutivo (a) con menci&#xF3;n en Ingl&#xE9;s.</div><br><br></div>", "i": 7230932}, {"t": "<div><div class=\"p\">Santiago, 07 de Enero de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7230933}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "275 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-275 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N°275 DE 199O", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1990-10-25", "fecha_derogacion": "2013-12-10", "doble_articulado": false, "id_norma": "96486", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-02-08", "vigencias": [{"desde": "2013-12-10", "hasta": "", "tipo_version": "2", "tipo_