{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A SANTA TERESITA S.A.</div><br></div>", "i": 6366392}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VII Direcci&#xF3;n Regional Talca del Servicio de Impuestos Internos, por resoluci&#xF3;n N&#xBA; ex. 1.410 de 26.12.2001, revoca, a Santa Teresita S.A., RUT.</div><div class=\"p\">96.832.770-4, a contar de la fecha de esta publicaci&#xF3;n la calidad de agente retenedor del Impuesto al Valor Agregado, en las ventas de ganado, conforme a la facultad delegada en el dispositivo N&#xBA; 18 de la resoluci&#xF3;n N&#xBA; ex. 3.721 de 28.07.2000, de la Direcci&#xF3;n Nacional.</div><br></div>", "i": 6366393}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Luis Encina Barros, Director Regional&nbsp; (S).</div><br></div>", "i": 6366394}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1410 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1410 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VII DIRECCIÓN REGIONAL DE TALCA"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A SANTA\nTERESITA S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-26", "doble_articulado": false, "id_norma": "193913", "numero_fuente": "37164", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-19", "vigencias": [{"desde": "2002-01-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-19", "fin_vigencia": "", "tipo_version": "3"}], "ev