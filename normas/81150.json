{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8311895}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.186 de 03 de Septiembre de 1991 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2&#xB0; de la resoluci&#xF3;n No. 715, de 1991, de esta Subsecretar&#xED;a, que autoriz&#xF3; a COMPA&#xD1;IA COMERCIO MONTEMAR S.A, R.U.T. No. 92.227.000-7, domiciliada en Santiago, para iniciar actividades pesqueras de procesamiento, en el sentido de incluir la autorizaci&#xF3;n para procesar en las mismas l&#xED;neas de proceso los recursos Mero Cherna, Epinephelus oxygeneios y Mero o Bacalao, Polyprion ya&#xF1;ezi/Dissostichus eleginoides.</div><br></div>", "i": 8311896}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 03 de Septiembre de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8311897}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1186", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1186"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-09-03", "fecha_derogacion": "1994-03-24", "doble_articulado": false, "id_norma": "81150", "numero_fuente": "34077", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-09-27", "vigencias": [{"desde": "1994-03-24", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1991-09-27", "hasta": "1994-03-23", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia"