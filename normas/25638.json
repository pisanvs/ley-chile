{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AUMENTA EN UN PLAZA DE COMODORO DEL AIRE, LA ACTUAL PLANTA DE LA FUERZA AEREA DE CHILE.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley </div></div>", "i": 5965111}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1.&#xB0; Aum&#xE9;ntase en una plaza de Comodoro del Aire, la actual planta de la Fuerza A&#xE9;rea de Chile. </div></div>", "i": 5965112}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2.&#xB0; Esta Ley comenzara a regir desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 5965113}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintiocho de Enero de mil novecientos cuarenta y cuatro.-JUAN ANTONIO RIOS M.- O. Escudero O. </div></div>", "i": 5965114}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "7766", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-7766"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL"], "titulo_norma": "AUMENTA EN UN PLAZA DE COMODORO DEL AIRE, LA ACTUAL\nPLANTA DE LA FUERZA AEREA DE CHILE.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1944-01-28", "doble_articulado": false, "id_norma": "25638", "numero_fuente": "19774", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1944-02-03", "vigencias": [{"desde": "1944-02-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigen