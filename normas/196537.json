{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6376283}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA; 123, de fecha 28 de diciembre del a&#xF1;o 2001, se autoriz&#xF3; la existencia y se aprob&#xF3; el estatuto de la Cooperativa de Trabajo Producci&#xF3;n de la Tierra, de nombre de fantas&#xED;a &quot;ATAC&quot;, de Puerto Montt, D&#xE9;cima Regi&#xF3;n, en los t&#xE9;rminos que da testimonio el instrumento protocolizado con fecha 23 de noviembre del a&#xF1;o 2001, ante el Notario de Puerto Montt, don Heriberto Barrientos Bahamonde, con el n&#xFA;mero 328. </div></div>", "i": 6376284}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Sr. Subsecretario, Cecilia Gonz&#xE1;lez Mart&#xED;nez, Jefe Departamento de Cooperativas (S), Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 6376285}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "123", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-123"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-28", "doble_articulado": false, "id_norma": "196537", "numero_fuente": "37230", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-09", "vigencias": [{"desde": "2002-04-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-04-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-04