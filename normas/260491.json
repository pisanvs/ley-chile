{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7341196}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;1.266, de 17 de abril de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a NANAIMO S.A. para ampliar las actividades pesqueras de transformaci&#xF3;n autorizadas por las resoluciones citadas en Visto, en orden a incorporar a la planta ubicada en Camino La Vara N&#xBA;2980, San Bernardo, Santiago, Regi&#xF3;n Metropolitana, en las l&#xED;neas de proceso de Fresco-Enfriado, Fresco-Refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 7341197}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de abril de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7341198}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1266 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1266 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-04-17", "doble_articulado": false, "id_norma": "260491", "numero_fuente": "38751", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-04-30", "vigencias": [{"desde": "2007-04-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-04-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-04-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "