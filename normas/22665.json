{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Reparaciones del malecon de Valparaiso Lei n&#xFA;m. 1,458.- Valparaiso, a 9 de Febrero de 1901.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7163090}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir la suma de trescientos cincuenta mil pesos en ejecutar los trabajos de reparacion en el malecon de Valparaiso.</div><br></div>", "i": 7163091}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ E.- Nicolas Gonz&#xE1;lez E.</div><br></div>", "i": 7163092}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1458", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1458"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "REPARACIONES DEL MALECON DE VALPARAISO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VALPARAISO", "MALECON", "REPARACION", "INVERSION", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-02-09", "doble_articulado": false, "id_norma": "22665", "numero_fuente": "6815", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-02-11", "vigencias": [{"desde": "1901-02-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1901-02-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1901-02-11"