{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA NOMBRE A LA CALLE QUE INDICA DE LA CIUDAD DE PUNTA ARENAS</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 9045282}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. La actual calle Progreso de la ciudad de Punta Arenas, se denominar&#xE1; en lo sucesivo &quot;Yugoeslavia&quot;.&quot;.</div><br></div>", "i": 9045283}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, quince de octubre de mil novecientos sesenta y cuatro.- JORGE ALESSANDRI RODRIGUEZ.- S&#xF3;tero del R&#xED;o.</div><br></div>", "i": 9045284}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "15740", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-15740"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA NOMBRE A LA CALLE QUE INDICA DE LA CIUDAD DE PUNTA ARENAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "CALLE YUGOESLAVIA", "PUNTA ARENAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1964-10-15", "doble_articulado": false, "id_norma": "28295", "numero_fuente": "25974", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1964-10-27", "vigencias": [{"desde": "1964-10-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1964-10-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1964-10-27",