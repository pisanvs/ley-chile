{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza la inversion de 100 000 pesos en la defensa de las ciudades del norte de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1795.- Santiago, a 22 de Enero de 1906.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional, ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274700}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de cien mil pesos ($ 100 000) en la defensa de las ciudades del norte del pa&#xED;s contra las inundaciones de los rios.</div><br></div>", "i": 8274701}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Miguel Cruchaga.</div><br></div>", "i": 8274702}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1795", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1795"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA LA INVERSION DE 100 000 PESOS EN LA DEFENSA DE LAS CIUDADES DEL NORTE DE LA REPUBLICA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTE REPUBLICA", "INVERSION", "AUTORIZACION", "CIUDADES DEL NORTE", "DEFENSAS", "INUNDACIONES."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-01-22", "doble_articulado": false, "id_norma": "22921", "numero_fuente": "8410", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1906-01-22", "vigencias": [{"desde": "1906-01-22", "hasta": "", "tipo_versi