{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div><br><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA; 39.488, de 17 de octubre de 2009, se public&#xF3; extracto de resoluci&#xF3;n N&#xBA; 5.220 exenta, de 2009, con los errores que se salvan a continuaci&#xF3;n: en el sumario, primera columna y p&#xE1;gina siete, segunda columna, donde dice &quot;... Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes ...&quot; debe decir &quot;... Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Telecomunicaciones ...&quot;.</div><br></div>", "i": 8791106}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "63", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-63"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TELECOMUNICACIONES"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1007325", "numero_fuente": "39491", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-10-21", "vigencias": [{"desde": "2009-10-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-10-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-10-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "RECTIFICACION", "url_part": "rectificacion"}], "ingresado_por": "362", "fecha_ingreso": "2009-10-22", "fecha_version": "2009-10-21", "actualizado_por": "362", "fecha_actualizacion_texto": "2009-10-22", "tipo_tratado": ""}, "alertas"