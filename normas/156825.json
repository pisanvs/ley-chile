{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6236813}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta N&#xB0; 177 de 18 de Febrero de 1985, conforme Art. 5&#xB0; transitorio C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento de aguas proporcionales que corresponden a Reserva y Sector expropiado predio &quot;Resto de la Hijuela Uno del Fundo Santa Amelia de Almahue&quot; de la comuna de Pichidegua, Sexta Regi&#xF3;n; y derechos de aprovechamiento de aguas que corresponden a las parcelas N&#xB0;s 5, parte de la 6, 7 a la 17 y parte de la 45 y sitios N&#xB0;s 2 al 13 y parte del 30, del proyecto de parcelaci&#xF3;n &quot;Almahue&quot; formado entre otros por predio se&#xF1;alado. Los derechos de agua se extraen del Canal Almahue. Publicaci&#xF3;n hecha conforme Art. 13, Ley N&#xB0; 18.377.-</div><br></div>", "i": 6236814}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6236815}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "177 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-177 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-02-18", "doble_articulado": false, "id_norma": "156825", "numero_fuente": "32110", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-01", "vigencias": [{"desde": "1985-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-01", "fin_vigencia": ""}, "vig