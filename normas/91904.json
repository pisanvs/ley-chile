{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA N&#xBA; 23, DE 1989 </div></div>", "i": 6090143}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n N&#xBA; 23 de fecha 28-02-89, la Secretar&#xED;a Ministerial de Educaci&#xF3;n de la Regi&#xF3;n de Antofagasta ha aprobado Planes y Programas de Estudio de 1&#xB0; a 4&#xB0; a&#xF1;o de la Educaci&#xF3;n Media T&#xE9;cnico Profesional, para el Liceo Polit&#xE9;cnico C-1 &quot;Julio Montt Salamanca&quot; Pedro de Valdivia.</div><br><div class=\"p\">En las Especialidades de:</div><br><div class=\"p\">- Electromec&#xE1;nico.</div><div class=\"p\">- Operaci&#xF3;n M&#xE1;quinas pesada.</div><div class=\"p\">- Secretariado Administrativo</div><div class=\"p\">&nbsp; Computacional</div><div class=\"p\">- Laboratorio Qu&#xED;mico.</div><div class=\"p\">- Vestuario.</div><br><div class=\"p\">Los Planes y Programas aprobados tendr&#xE1;n vigencia a contar del a&#xF1;o escolar 1989 y hasta el a&#xF1;o 1982.</div><br></div>", "i": 6090144}, {"t": "<div><div class=\"p\">Fecha 15 de Abril de 1989.- Luis Humberto Alvear L&#xF3;pez, Secretario Ministerial de Educaci&#xF3;n Regi&#xF3;n de Antofagasta. </div></div>", "i": 6090145}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "23 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-23 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA Nº 23, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-02-28", "doble_articulado": false, "id_norma": "91904", "numero_fuente": "33487", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989