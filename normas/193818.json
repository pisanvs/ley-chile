{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6366022}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.973, de 30 de noviembre de 2001, se expropi&#xF3; el lote de terreno N&#xBA;52, superficie 4.878 m2, rol de aval&#xFA;o 537-31, comuna de R&#xED;o Bueno, X Regi&#xF3;n, para la obra &quot;Camino R&#xED;o Bueno-Crucero, Sector T-90-U y T-933, tramo Km. 0,0000 al 20,90000&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario V&#xED;ctor Germ&#xE1;n Heinrich Heinrich, ascendente a la cantidad de $10.618.441.</div><br></div>", "i": 6366023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6366024}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1973", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1973"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-30", "doble_articulado": false, "id_norma": "193818", "numero_fuente": "37160", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-15", "vigencias": [{"desde": "2002-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2002-01-16", "fecha_version": "2002-01-15", "fecha_actualizacion_texto": "2002-01-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "