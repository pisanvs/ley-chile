{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 1.767 EXENTA, DE 6 DE ABRIL DE 2017</div></div>", "i": 9794788}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta se han modificado las resoluciones exentas Nos <a href=\"https://www.leychile.cl/Navegar?idNorma=141615&amp;idParte=0&amp;idVersion=\">4.095, de 1999</a>; <a href=\"https://www.leychile.cl/Navegar?idNorma=182653&amp;idParte=0&amp;idVersion=\">592, de 2001</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=194934&amp;idParte=0&amp;idVersion=\">16.277, de 2001</a>, todas del Ministerio de Educaci&#xF3;n, que aprobaron planes y programas especiales de estudio de 1&#xB0; a 4&#xBA; a&#xF1;o de educaci&#xF3;n media, al Colegio Cordillera, RBD 8902, Comuna de Las Condes, Provincia de Santiago, Regi&#xF3;n Metropolitana, en el sentido de sustituir su plan de estudio de 1&#xB0; a 4&#xBA; a&#xF1;o de educaci&#xF3;n media por los que se indican en dicha resoluci&#xF3;n exenta.- </div></div>", "i": 9794789, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Valentina Karina Quiroga Canahuate, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 9794790}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1767 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1767 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 1.767 EXENTA, DE 6 DE ABRIL DE 2017", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1209335", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-04-06", "doble_articulado": false, "