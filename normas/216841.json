{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 13.169 EXENTA, DE 2003 </div></div>", "i": 6446972}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 13.169, de 27 de octubre de 2003, del Servicio Nacional de Capacitaci&#xF3;n y Empleo, se revoc&#xF3; la autorizaci&#xF3;n otorgada al organismo t&#xE9;cnico de capacitaci&#xF3;n &quot;Instituto de Capacitaci&#xF3;n y Gesti&#xF3;n Empresarial Limitada&quot;, R.U.T. N&#xBA; 77.630.250-3, cancel&#xE1;ndose su inscripci&#xF3;n en el Registro Nacional correspondiente, atendido lo dispuesto en el art&#xED;culo 77 letra a) de la ley N&#xBA; 19.518.</div><br></div>", "i": 6446973}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Eduardo Rodr&#xED;guez Olivares, Jefe Departamento Capacitaci&#xF3;n en Empresas.</div><br></div>", "i": 6446974}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "13169 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-13169 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 13.169 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-27", "doble_articulado": false, "id_norma": "216841", "numero_fuente": "37702", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-11-05", "vigencias": [{"desde": "2003-11-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-11-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-11-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones