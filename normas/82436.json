{"html": [{"t": "<div><div class=\"p\">PRORROGA PLAZO QUE INDICA</div><br><br></div>", "i": 8313674}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 946, de 08 de agosto de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por 270 d&#xED;as a contar del 23 de mayo de 1990, el plazo otorgado a do&#xF1;a Nancy Isabel Hern&#xE1;ndez Mardones, R.U.T. N&#xB0;8.155.830-2, domiciliada en calle Hernando de Magallanes No. 2, Villa Londres, Recreo Alto, Vi&#xF1;a del Mar, para empezar a operar el establecimiento de cultivo autorizado por la resoluci&#xF3;n No. 485, de 1989, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8313675}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 08 de Agosto de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8313676}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "946", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-946"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "PRORROGA PLAZO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-08-08", "doble_articulado": false, "id_norma": "82436", "numero_fuente": "33753", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-08-24", "vigencias": [{"desde": "1990-08-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-08-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-08-24", "fin_vigenc