{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION QUE INDICA </div></div>", "i": 8321253}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 449, de 25 de Abril de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deroga la Resoluci&#xF3;n No. 1.434, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Martelli y Martelli Sociedad Limitada, domiciliada en Santiago, para desarrollar actividades pesqueras de transformaci&#xF3;n, en una planta ubicada en calle Jos&#xE9; Luis Caro No. 1795, Padre Hurtado, Santiago, por renuncia de su titular.</div><br></div>", "i": 8321254}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 25 de Abril de 1989.- Roberto Cabezas Bello. Subsecretario de Pesca.</div><br></div>", "i": 8321255}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "449", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-449"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "DEROGA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-04-25", "doble_articulado": false, "id_norma": "92119", "numero_fuente": "33374", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-05-17", "vigencias": [{"desde": "1989-05-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-05-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-05-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}