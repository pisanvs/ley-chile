{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6538760}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.820, de 26 de agosto de 2005, de esta Subsecretar&#xED;a, rectif&#xED;case el extracto de la resoluci&#xF3;n exenta N&#xBA; 2.591 de 2005, de esta Subsecretar&#xED;a de Pesca, que aplic&#xF3; a PESCA SURIBERICA S.A. la sanci&#xF3;n establecida en el art&#xED;culo 11 inciso 1&#xBA; de la ley N&#xBA; 19.713, respecto de la unidad de pesquer&#xED;a de Congrio dorado, individualizada en el art&#xED;culo 2&#xBA; letra k) de la ley N&#xBA; 19.713, en el sentido de reemplazar en su p&#xE1;rrafo segundo la expresi&#xF3;n &quot;Merluza com&#xFA;n&quot; por la expresi&#xF3;n &quot;Congrio dorado sur exterior&quot;. </div></div>", "i": 6538761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de agosto de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6538762}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2820 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2820 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-08-26", "doble_articulado": false, "id_norma": "241602", "numero_fuente": "38253", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-09-03", "vigencias": [{"desde": "2005-09-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-09-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia