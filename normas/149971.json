{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 119, DE 1987 </div></div>", "i": 6214435}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 119 de 11 de junio de 1987 se ha aprobado para el Colegio &quot;Monse&#xF1;or Luis Arturo P&#xE9;rez&quot;, de La Cisterna, provincia de Santiago, Regi&#xF3;n Metropolitana, planes y programas especiales de estudio para la Educaci&#xF3;n Media, modalidad T&#xE9;cnico - Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar 1987 y hasta el a&#xF1;o escolar de 1992, en las Especialidades de: Secretariado Administrativo, con menci&#xF3;n en Computaci&#xF3;n y Programaci&#xF3;n en Computaci&#xF3;n. </div></div>", "i": 6214436}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de Junio de 1987.- Ren&#xE9; Salam&#xE9; Mart&#xED;n, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6214437}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "119 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-119 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 119, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-11", "doble_articulado": false, "id_norma": "149971", "numero_fuente": "32805", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-26", "vigencias": [{"desde": "1987-06-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-0