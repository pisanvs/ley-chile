{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291037}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 200, de 3 de marzo de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a SOCIEDAD BAQUEDANO LTDA., R.U.T. N&#xB0; 79.700.600-9, en orden a incorporar a la planta ubicada en Camino al Fuerte N&#xB0; 42, Coquimbo, en la l&#xED;nea de elaboraci&#xF3;n de Congelado, el recurso hidrobiol&#xF3;gico: Puye.</div><div class=\"p\">&nbsp; &nbsp; Cad&#xFA;case la Resoluci&#xF3;n N&#xB0; 524, de 1994, de esta Subsecretar&#xED;a, en virtud de lo dispuesto en el art&#xED;culo 6&#xB0; del D.S. N&#xB0; 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br><br></div>", "i": 8291038}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 3 de marzo de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8291039}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "200", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-200"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD BAQUEDANO LIMITADA", "INDUSTRIA PESQUERA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-03-03", "doble_articulado": false, "id_norma": "33712", "numero_fuente": "35116", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-03-13", "vigencias": [{"desde": "1995-03-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-03-13", "fin_v