{"html": [{"t": "<div><div class=\"p\">DECLARA A PACIFICBLU SpA ACOGIDA A LEY 20.872 RESPECTO DE LAS NAVES QUE INDICA</div></div>", "i": 10173046}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.310, de 27 de octubre de 2020, de esta Subsecretar&#xED;a, decl&#xE1;rase que Pacificblu SpA se encuentra acogida a lo dispuesto en el art&#xED;culo 1&#xBA; de la ley N&#xBA; 20.872, respecto de las autorizaciones de pesca de las naves &quot;Biomar IV&quot;, &quot;Bonn&quot; y &quot;Polaris II&quot;, sobre el recurso hidrobiol&#xF3;gico Jibia, contenidas en las resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=1096869&amp;idParte=&amp;idVersion=\">N&#xBA; 3.405</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=1096870&amp;idParte=&amp;idVersion=\">N&#xBA; 3.406</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=1096845&amp;idParte=&amp;idVersion=\">N&#xBA; 3.363</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1098296&amp;idParte=&amp;idVersion=\">N&#xBA; 3.895</a>, todas de 2016; N&#xBA; 447, <a href=\"https://www.leychile.cl/Navegar?idNorma=1108730&amp;idParte=&amp;idVersion=\">N&#xBA; 3.077</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=1113452&amp;idParte=&amp;idVersion=\">N&#xBA; 4.476</a>, todos de 2017; <a href=\"https://www.leychile.cl/Navegar?idNorma=1114898&amp;idParte=&amp;idVersion=\">N&#xBA; 323</a>, de 2018; todas de esta Subsecretar&#xED;a de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><br><br></div>", "i": 10173047}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de octubre de 2020.- Rom&#xE1;n Zelaya R&#xED;os, Subsecretario de Pesca y Acuicultura.</div><br></div>", "i": 10173048}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2310 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2310 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DECLARA A PACIFICBLU SpA ACOGIDA A LEY 20.872 RESPECTO DE LAS NAVES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1841917", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-10-27", "doble_articulado": false, "id_norma": "1151397", "numero_fuente": "42798", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-11-06", "vigencias": [{"desde": "2020-11-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2020-11-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2020-11-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresado_por": "1795", "fecha_ingreso": "2020-11-06", "fecha_version": "2020-11-06", "fecha_actualizacion_texto": "2020-11-06", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10173046}, {"n": "Artículo", "i": 10173047, "t": 6}, {"n": "Promulgación", "i": 10173048}]}