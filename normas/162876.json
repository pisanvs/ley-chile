{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6256747}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 605, de 23 de marzo de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las resoluciones N&#xBA; 717 y N&#xBA; 718 ambas de 1996, de esta Subsecretar&#xED;a, en cuanto autorizaron a&nbsp; PESQUERA SOCOMAR&nbsp; LTDA. para operar las naves &apos;&apos;Monte Br&#xFA;jula&apos;&apos; y &apos;&apos;Monte Alondra&apos;&apos;, respectivamente, por haber suspendido actividades extractivas por m&#xE1;s de 12 meses sucesivos, respecto del recurso Albacora, en el litoral de la I a la X Regiones.</div><br></div>", "i": 6256748}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de marzo de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6256749}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "605", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-605"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-03-23", "doble_articulado": false, "id_norma": "162876", "numero_fuente": "36626", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-29", "vigencias": [{"desde": "2000-03-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODI