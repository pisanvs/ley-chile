{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 9958588}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 4.582, de fecha 12 de octubre de 2018, de este Servicio, se modifica el Registro Pesquero Artesanal del Servicio Nacional de Pesca y Acuicultura en orden a reorganizar las inscripciones pesqueras artesanales que indica, de la Regi&#xF3;n del Biob&#xED;o a la Regi&#xF3;n de &#xD1;uble. El texto &#xED;ntegro de la resoluci&#xF3;n indicada, se encuentra publicado con esta fecha en el dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y en el de la Subsecretar&#xED;a de Pesca y Acuicultura.</div></div>", "i": 9958589}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En Valpara&#xED;so, 12 de octubre de 2018.- Alicia Lorena Gallardo Lagno, Directora Nacional, Servicio Nacional de Pesca y Acuicultura. </div></div>", "i": 9958590}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4582 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4582 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1484209", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-10-12", "doble_articulado": false, "id_norma": "1124603", "numero_fuente": "42190", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-10-26", "vigencias": [{"desde": "2018-10-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2018-10-26", "fin_vigencia": ""}, "