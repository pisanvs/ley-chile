{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A PABLO RODRIGO OLIVARES LAVANCHY </div></div>", "i": 7342913}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional Santiago Poniente del S.I.I., por resoluci&#xF3;n N&#xBA; Ex. 318, de 11 de mayo de 2007, revoca la calidad de Agente Retenedor del IVA de la Construcci&#xF3;n, autorizada mediante resoluci&#xF3;n N&#xBA; 46 del 01.09.2003 y N&#xBA; 142 del 26.12.2005 de la Direcci&#xF3;n Nacional, en actual vigencia a Pablo Rodrigo Olivares Lavanchy, RUT N&#xBA; 7.767.114-5, la que entrar&#xE1; en vigencia a contar del 1&#xBA; del mes siguiente al de su publicaci&#xF3;n en el Diario Oficial, por cuenta y costo del peticionario.</div><br></div>", "i": 7342914}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Teresa Conejeros Pe&#xF1;a, Directora Regional. </div></div>", "i": 7342915}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "318 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-318 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO PONIENTE"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A PABLO\nRODRIGO OLIVARES LAVANCHY", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-05-11", "doble_articulado": false, "id_norma": "261194", "numero_fuente": "38773", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-05-28", "vigencias": [{"desde": "2007-05-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-05-28", "fin_vigencia": ""}, "vigencias