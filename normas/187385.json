{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 172, DE 2001</div><br><br></div>", "i": 6341815}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA; 172, de 10 de abril de 2001, se ha aprobado el Convenio de fecha 28 de febrero de 2001, celebrado entre el Ministerio de Educaci&#xF3;n y la I. Municipalidad de Valdivia, que rescilia el Convenio de Traspaso de la Escuela B&#xE1;sica G N&#xBA; 44 de Valdivia, traspasada a dicha Corporaci&#xF3;n, por Convenio aprobado por decreto supremo de Educaci&#xF3;n N&#xBA; 726, de 11 de junio de 1986.</div><br></div>", "i": 6341816}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de junio de 2001.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6341817}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "172", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-172"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 172, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-10", "doble_articulado": false, "id_norma": "187385", "numero_fuente": "37005", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-07-07", "vigencias": [{"desde": "2001-07-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-07-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-07-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2001-07-09", "fecha_version": "2001-07-07", "fec