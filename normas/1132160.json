{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO</div></div>", "i": 10027462}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xBA; 307 de 14 de mayo de 2019, se modificaron los Decretos Exentos MOP N&#xBA; s <a href=\"https://www.leychile.cl/Navegar?idNorma=1130603&amp;idParte=&amp;idVersion=\">67</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=1130604&amp;idParte=&amp;idVersion=\">68</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=1130605&amp;idParte=&amp;idVersion=\">69</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=1130606&amp;idParte=&amp;idVersion=\">70</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=1130607&amp;idParte=&amp;idVersion=\">71</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=1130608&amp;idParte=&amp;idVersion=\">72</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=1130609&amp;idParte=&amp;idVersion=\">73</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=1130610&amp;idParte=&amp;idVersion=\">74</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1130611&amp;idParte=&amp;idVersion=\">75</a>, todos de 21 de marzo de 2019, de la obra Concesi&#xF3;n Internacional Ruta 5, Tramo Talca - Chill&#xE1;n, Regiones del Maule y &#xD1;uble, antes Regi&#xF3;n del Biob&#xED;o, en el sentido de se&#xF1;alar que, en el numeral sexto de los Decretos modificados, donde dice Asignaci&#xF3;n Presupuestaria &quot;08 31 02 003&quot;, debe decir &quot;03 01 31 02 003&quot;. En todo lo no modificado se mantienen plenamente vigentes los Decretos Exentos MOP N&#xBA; s 67, 68, 69, 70, 71, 72, 73, 74 y 75, todos de 21 de marzo de 2019. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA; 2186, de 1978.</div></div>", "i": 10027463}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "307", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-307"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1598469", "EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-05-14", "doble_articulado": false, "id_norma": "1132160", "numero_fuente": "42368", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-06-01", "vigencias": [{"desde": "2019-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2019-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "1289", "fecha_ingreso": "2019-06-03", "fecha_version": "2019-06-01", "fecha_actualizacion_texto": "2019-06-03", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10027462}, {"n": "Artículo", "i": 10027463, "t": 6}]}