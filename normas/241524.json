{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6538472}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 773 de fecha 29 de julio de 2005, se expropi&#xF3; el lote de terreno N&#xBA; 18, superficie 5.220 m&#xB2;, Rol N&#xBA; 158-139, comuna de Cocham&#xF3;, X Regi&#xF3;n para la obra &quot;Camino Puelo Paso El Bols&#xF3;n, Sector Lago Tagua Tagua-Llanada Grande Km. 12,530 a Km.</div><div class=\"p\">32,500&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Jos&#xE9; Ladislao Morales Villarroel, ascendente a la cantidad de $821.615.- para el lote N&#xBA; 18. </div></div>", "i": 6538473}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6538474}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "773 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-773 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-07-29", "doble_articulado": false, "id_norma": "241524", "numero_fuente": "38251", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-09-01", "vigencias": [{"desde": "2005-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-09-01", "fecha_version": "2005-09-01", "fecha_actualizacion_texto":