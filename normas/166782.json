{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6269173}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 215, de 28 de Septiembre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n, se autoriza a do&#xF1;a Otilia Mora Rubilar para efectuar toda clase de servicios de transporte de pasajeros, dentro del territorio nacional por calles y caminos, a excepci&#xF3;n de los servicios p&#xFA;blicos de locomoci&#xF3;n colectiva urbanos de acuerdo a lo dispuesto en el DS No. 163/84. </div></div>", "i": 6269174}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Temuco, 28 de Septiembre de 1987.- Oscar C&#xF3;rdova Jim&#xE9;nez, Secretario Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n.</div><br></div>", "i": 6269175}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "215", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-215"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-28", "doble_articulado": false, "id_norma": "166782", "numero_fuente": "32884", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-10-02", "vigencias": [{"desde": "1987-10-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-10-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-10-02", "fin_vigencia": "", "tipo_version":