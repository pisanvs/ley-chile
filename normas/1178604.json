{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div><br></div>", "i": 10349133}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 635, de 19 de mayo de 2022, Serviu Regi&#xF3;n de &#xD1;uble rectifica <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=1175522\">resoluci&#xF3;n exenta N&#xBA; 544 de fecha 22 de abril de 2022</a>, que dispuso expropiaci&#xF3;n conforme al art&#xED;culo 51 ley N&#xBA; 16.391 y decreto ley N&#xBA; 2.186 de 1978, del inmueble ubicado en Alonso de Ercilla 1755 AMP S Gajardo, comuna de Chill&#xE1;n, enmarcado en el plano S16R-176, para el proyecto &quot;Mejoramiento Avenida Diagonal Las Termas, Chill&#xE1;n&quot;, de la comuna de Chill&#xE1;n, en la Regi&#xF3;n de &#xD1;uble, de presunto dominio de Luengo Quezada Nanci Josefina, rectificando el rol aval&#xFA;o fiscal del inmueble objeto de expropiaci&#xF3;n, indicando que el rol de Aval&#xFA;o Fiscal del Lote corresponde efectivamente al 001606-00011, de la comuna de Chill&#xE1;n.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10349134}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director (S) Serviu.</div><br></div>", "i": 10349135}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "635 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-635 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DE ÑUBLE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2155668", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-05-19", "doble_articulado": false, "id_norma": "1178604", "numero_fuente": "43303",