{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6229684}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta N&#xB0; 618 de fecha 16 de Junio de 1986 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Va. Regi&#xF3;n, se autoriza a la se&#xF1;ora Hilda Cort&#xE9;s Bast&#xED;as para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6229685}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de Junio de 1986.- Hern&#xE1;n V&#xE1;squez Wacquez, Capit&#xE1;n de Navio, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Va. Regi&#xF3;n.</div><br></div>", "i": 6229686}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "618 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-618 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL V REGIÓN DE VALPARAÍSO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-16", "doble_articulado": false, "id_norma": "154668", "numero_fuente": "32503", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-06-23", "vigencias": [{"desde": "1986-06-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-06-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-