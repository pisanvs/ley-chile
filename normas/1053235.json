{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETO N&#xBA; 184 EXENTO, DE 2013</div></div>", "i": 9367253}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 750, de 29 de julio de 2013, de este Ministerio, modif&#xED;case el art&#xED;culo 1&#xBA; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1048732&amp;idParte=&amp;idVersion=\">decreto exento N&#xBA; 184, de 2013</a>, modificado mediante decretos exentos N&#xBA; 503 y N&#xBA; 606, de 2013, todos del Ministerio de Econom&#xED;a, Fomento y Turismo, en el sentido de se&#xF1;alar que la cuota global de captura de la pesquer&#xED;a de Bacalao de profundidad, al norte del paralelo 47&#xB0; L.S., ascender&#xE1; a 1.393 toneladas distribuidas de la siguiente manera:</div><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/33954.jpg\"> </div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><br></div>", "i": 9367254}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de julio de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9367255}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "750 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-750 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA DECRETO Nº 184 EXENTO, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fe