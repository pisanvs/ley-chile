{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ORDENA EXPROPIACIONES QUE SE&#xD1;ALA </div></div>", "i": 6007483}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 188 de 26 de Septiembre de 1994, del Serviu V Regi&#xF3;n Valpara&#xED;so, se dispuso expropiaci&#xF3;n parcial, conforme Decreto Ley 2.186, de 1978; y Decreto Supremo N&#xB0; 101 (V. y U.), de 1992, de inmueble rol de aval&#xFA;o 9037-1, resto del Fundo Centinela, Cerro La Virgen, San Antonio, aparente dominio de Miguel Solari Morchio y Otros, en 1500 Mts.2. Comisi&#xF3;n Tasadora integrada por Sres. Osvaldo Mu&#xF1;oz Quintana, arquitecto, y constructores civiles Sres. Pablo Caria Giurici y Alvaro Verdejo Vidal, seg&#xFA;n informe de 31 Agosto 1994, fij&#xF3; monto provisional indemnizaci&#xF3;n en $7.500.000, que se pagar&#xE1; de contado.-</div><br></div>", "i": 6007484}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Alberto Ram&#xED;rez Urz&#xFA;a, Arquitecto, Director Serviu V Regi&#xF3;n.</div><br></div>", "i": 6007485}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "188", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-188"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "ORDENA EXPROPIACIONES QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "BIEN RAIZ", "SAN ANTONIO", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-09-26", "doble_articulado": false, "id_norma": "33637", "numero_fuente": "34991-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-10-15", "vigencias": [{"desde": "1994-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigen