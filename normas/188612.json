{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6346266}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA; 67, de fecha 13 de julio del a&#xF1;o 2001, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se aprob&#xF3; la disoluci&#xF3;n voluntaria de la Cooperativa de Consumo del Personal de la F&#xE1;brica de Celulosa Laja Limitada, que consta en la escritura p&#xFA;blica, suscrita con fecha 9 de mayo del a&#xF1;o 2001, ante el Notario P&#xFA;blico de Santiago, don Rub&#xE9;n Galecio G&#xF3;mez.</div><br></div>", "i": 6346267}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Sr. Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6346268}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "67", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-67"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-07-13", "doble_articulado": false, "id_norma": "188612", "numero_fuente": "37039", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-08-17", "vigencias": [{"desde": "2001-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-08-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-08-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vin