{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE REGLAMENTO MUNICIPAL DEL FONDO DEPORTIVO CONCURSABLE</div><br></div>", "i": 8884902}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Con fecha 14 de enero del 2010, se dict&#xF3; el Reglamento Municipal del Fondo Deportivo Concursable, que permita apoyar actividades deportivas de las distintas organizaciones de la comuna que desarrollan alg&#xFA;n tipo de actividad F&#xED;sica.</div><br><div class=\"p\">&nbsp; &nbsp;  Que comprende los siguientes T&#xED;tulos:</div><br><div class=\"p\">a)&nbsp;  Generalidades</div><div class=\"p\">b)&nbsp;  Procedimiento</div><div class=\"p\">c)&nbsp;  L&#xED;neas de Postulaci&#xF3;n</div><div class=\"p\">d)&nbsp;  Evaluaci&#xF3;n</div><div class=\"p\">e)&nbsp;  Sanciones</div><div class=\"p\">f)&nbsp;  Vigencia del FODECO</div><div class=\"p\">g)&nbsp;  Situaciones de Excepci&#xF3;n</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta ordenanza se encuentra publicado en la p&#xE1;gina web de la Municipalidad, {HYPERLINK &quot;http://www.muniflorida.cl&quot;}.</div><br></div>", "i": 8884903}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Antonio Vergara Reyes, Alcalde.</div><br></div>", "i": 8884904}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "S/N", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "Ordenanza-S/N"}], "organismos": ["MUNICIPALIDAD DE FLORIDA"], "titulo_norma": "EXTRACTO DE REGLAMENTO MUNICIPAL DEL FONDO DEPORTIVO CONCURSABLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-01-14", "doble_articulado": false, "id_norma": "1011140", "numero_fuente": "39590", "tipo_version": "3", "t