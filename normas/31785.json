{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6001940}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1 del 7 de Febrero de 1995, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la IV Regi&#xF3;n se adjudic&#xF3; a don Guillermo Horacio G&#xF3;mez Rivera, la concesi&#xF3;n para operar, hasta el 11 de Enero de 1999 y a contar de la fecha de publicaci&#xF3;n del presente extracto, un establecimiento ubicado en Avda. Las Delicias N&#xB0; 393 de la comuna de Vicu&#xF1;a, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de emisi&#xF3;n de contaminantes de todos los veh&#xED;culos no comprendidos en el inciso 1&#xB0;, art&#xED;culo 7&#xB0; del D.S. N&#xB0; 156/90, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 6001941}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Freddy Bonilla Torreblanca, Secretario Regional Ministerial de Transportes y Telecomunicaciones, IV Regi&#xF3;n de Coquimbo.</div><br></div>", "i": 6001942}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANTA REVISION TECNICA", "CONCESION REVISION TECNICA", "GUILLERMO HORACIO GOMEZ RIVERA", "VICU A", "CUARTA REGION", "VEHICULOS MOTORIZADOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-02-07", "doble_articulado": false, "id_norma": "31785", "numero_fuente": "35125", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-03-23", "vigencias": [{"desde": "19