{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 14,358</div><br><div class=\"p\">AUMENTA, POR GRACIA, LA PENSION DE DON ARTURO GORDON GONZALEZ</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6579652}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Aum&#xE9;ntase, por gracia, a E&#xBA; 35 mensuales la pensi&#xF3;n de que disfruta don Arturo Gordon Gonz&#xE1;lez.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande esta ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda. </div></div>", "i": 6579653}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintid&#xF3;s de Noviembre de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- Eduardo Figueroa Geisse.</div><br></div>", "i": 6579654}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14358", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14358"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "AUMENTA, POR GRACIA, LA PENSION DE DON ARTURO GORDON\nGONZALEZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-11-22", "doble_articulado": false, "id_norma": "252330", "numero_fuente": "24816", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-12-12", "vigencias": [{"desde": "1960-12-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "