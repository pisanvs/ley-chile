{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; TASA DE INTERES PROMEDIO MENSUAL DE CAPTACION PARA OPERACIONES REAJUSTABLES ENTRE 90 Y 365 DIAS CERTIFICADO </div></div>", "i": 5845338}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 6,77% anual durante el mes de enero de 1996.</div><div class=\"p\">&nbsp; &nbsp; Asimismo, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de enero de 1996, fue de 6,64% anual. </div></div>", "i": 5845339}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, febrero 6 de 1996.- Jorge Carrasco V&#xE1;squez, Ministro de Fe (S).</div><br></div>", "i": 5845340}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA INTERES PROMEDIO", "OPERACIONES CREDITO DINERO", "CAPTACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-02-06", "doble_articulado": false, "id_norma": "1855", "numero_fuente": "35387", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-02-08", "vigencias": [{"desde": "1996-02-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-02-08", "fin_vigencia": ""}, "vigencia