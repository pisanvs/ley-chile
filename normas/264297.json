{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 7352331}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 638, de 23 de julio de 2007, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme DL N&#xBA; 2.186 de 1978, del Lote N&#xBA; 18, correspondiente a parte del inmueble ubicado en Los Pajaritos 927, Rol de aval&#xFA;o N&#xBA; 165-1, comuna de Maip&#xFA;, aparente dominio de Soc. Educacional Poeta Rub&#xE9;n Dar&#xED;. Comisi&#xF3;n integrada por peritos se&#xF1;ores Fernando Merino de la Cerda, arquitecto; Adriano Urrutia San Mart&#xED;n, ingeniero civil y Patricia Morales Rivera, constructor civil. Seg&#xFA;n informe de 20 de septiembre de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $29.520.220.-, pagadera al contado.</div><br></div>", "i": 7352332}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 7352333}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "638", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-638"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES DE INMUEBLES QUE INDICA; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-07-23", "doble_articulado": false, "id_norma": "264297", "numero_fuente": "38853", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-09-01", "vigencias": [{"desde": "2007-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "