{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 17, DE 1985 </div></div>", "i": 6268752}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 17, de 18 de Enero de 1985 se ha rectificado el decreto supremo exento de Educaci&#xF3;n N&#xB0; 216, de 1983 que aprob&#xF3; planes y programas de estudios de Educaci&#xF3;n Media, T&#xE9;cnico-Profesional para los Liceos Industriales A N&#xB0; 77 y A N&#xB0; 97, ambos de Santiago, en el sentido de que en la asignatura de &quot;Orientaci&#xF3;n e Informaci&#xF3;n Profesional&quot; es s&#xF3;lo 1 clase y no como se indico anteriormente.</div><br></div>", "i": 6268753}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de Enero de 1985.- Marta Stefanowsky Bandyra, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 6268754}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "17 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-17 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 17, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-18", "doble_articulado": false, "id_norma": "166649", "numero_fuente": "32105", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-02-23", "vigencias": [{"desde": "1985-02-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-02-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-02-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendien