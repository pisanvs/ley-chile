{"html": [{"t": "<div><div class=\"p\">COMISION DE INSTRUCCION PRIMARIA</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Marzo 26 de 1828.</div></div>", "i": 10237687}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Se comisiona a D. Manuel Salas, D. Francisco Ruiz Tagle y Jos&#xE9; Joaquin de Mora para que entiendan y pasen al Gobierno los informes que les pida y los proyectos que entre s&#xED; acordaren acerca de la instruccion primeria de la juventud; y sobre todo lo que concierna al establecimiento de escuelas y de cualesquiera&nbsp; otros objetos de la misma especie; esper&#xE1;ndose de su patriotismo y amor a las luces, que se prestar&#xE1;n a este servicio con el celo y eficacia que los distingue.</div></div>", "i": 10237688}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  PINTO - Rodr&#xED;guez.</div></div>", "i": 10237689}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "COMISION DE INSTRUCCION PRIMARIA", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1828-03-26", "doble_articulado": false, "id_norma": "1157110", "numero_fuente": "1828", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1828-03-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1828-03-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1828-03-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "2932", "fecha_ingreso": "2021-06-04", "fecha_version