{"html": [{"t": "<div><div class=\"p\">MODIFICA ORDENANZA LOCAL SOBRE DERECHOS MUNICIPALES </div></div>", "i": 8674191}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto alcaldicio No. 614 de 30 de mayo de 1988, se determina la siguiente modificaci&#xF3;n de la Ordenanza Local sobre Derechos Municipales, aprobada por decreto alcaldicio No. 74 de 21 de enero de 1988:</div><div class=\"p\">&nbsp; &nbsp;  &quot;2.- Modif&#xED;case la ordenanza local de derechos municipales en el sentido de agregar en el art&#xED;culo 9&#xB0; el siguiente, No. 20 Carros y Remolques: Certificado de empadronamiento 0,20 UTM; - Duplicado certificado de empadronamiento 0,05 UTM; - Certificado de modificaci&#xF3;n en el Registro 0,10 UTM; - Placa provisoria y duplicado 0,20 UTM.-</div><br></div>", "i": 8674192}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alberto Krumm Valencia, Alcalde.</div><br></div>", "i": 8674193}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "614", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-614"}], "organismos": ["MUNICIPALIDAD DE MAIPÚ"], "titulo_norma": "MODIFICA ORDENANZA LOCAL SOBRE DERECHOS MUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-05-30", "doble_articulado": false, "id_norma": "133074", "numero_fuente": "33108", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-06-30", "vigencias": [{"desde": "1988-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-06-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-06-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes":