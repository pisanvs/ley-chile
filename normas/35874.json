{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294868}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 921 del 26 de Julio de 1995 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a INDUSTRIA PESQUERA OCEANICA LTDA., R.U.T. N&#xB0; 82.957.700-3, para ampliar actividades pesqueras, en orden a instalar y operar la planta ubicada en Barrio Industrial, Manzana A, Sitio N&#xB0; 2, Iquique, en las l&#xED;neas de elaboraci&#xF3;n de Harina y Aceite de Pescado, los siguientes recursos hidrobiol&#xF3;gicos: Anchoveta, Caballa, Jurel, Sardina espa&#xF1;ola.</div><div class=\"p\">&nbsp; &nbsp; D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 779, de 1986, de esta Subsecretar&#xED;a, en virtud de lo dispuesto en la presente Resoluci&#xF3;n.</div><br></div>", "i": 8294869}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 26 de Julio de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294870}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "921", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-921"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INDUSTRIA PESQUERA OCEANICA LTDA", "PESCA", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1995-07-26", "fecha_derogacion": "2000-01-24", "doble_articulado": false, "id_norma": "35874", "numero_fuente": "35243", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1995-08-14", "vigencias": [{"desde": "2000-01-24", "hasta": "", "tipo_versi