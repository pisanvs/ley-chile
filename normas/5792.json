{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 132.- Santiago, 1.o de diciembre de 1924.- Vistos estos antecedentes,</div><div class=\"p\">&nbsp; &nbsp; La Junta de Gobierno ha acordado y dicta el siguiente,</div><div class=\"p\">&nbsp; &nbsp; DECRETO-LEI:</div><br></div>", "i": 8255812}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Agr&#xE9;gase a las glosas de los &#xED;tem 363 de la partida 4.a y 3,188 de la partida 8.a del presupuesto del Interior en vijencia, la siguiente frase: &quot;..al hacerse cargo de sus funciones o cesar en su empleo, incluyendo el transporte de su mujer e hijos menores que vivan a su lado, y para el desempe&#xF1;o de comisiones&quot;.</div><br></div>", "i": 8255813}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese razon, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- Luis Altamirano.- Francisco E. Nef. J. P. Bennett.- Alcib&#xED;ades Roldan.</div><br></div>", "i": 8255814}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "132", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-132"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O", "1924", "MODIFICACION", "PRESUPUESTO GASTOS ADMINISTRACION PUBLICA", "MINISTERIO INTERIOR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1924-12-01", "doble_articulado": false, "id_norma": "5792", "numero_fuente": "14044", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1924-12-03", "vigencias": [{"desde": "1924-12-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vi