{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 3.435, DE 1988 </div></div>", "i": 6094934}, {"t": "<div><br><div class=\"p\">Por resoluci&#xF3;n exenta No. 3.435 de fecha 21 de diciembre de 1988, de la Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica, se reemplazaron las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica Luis Alberto Vera de Illapel, aprobadas por resoluci&#xF3;n exenta de Educaci&#xF3;n No. 738 de 1983, las que podr&#xE1;n aplicarse a contar del a&#xF1;o 1989.</div><br></div>", "i": 6094935}, {"t": "<div><div class=\"p\">Santiago, 15 de Febrero de 1989.- Paulina Dittborn Cordua, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6094936}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3435 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3435 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 3.435, DE 1988", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1988-12-21", "fecha_derogacion": "2020-07-31", "doble_articulado": false, "id_norma": "93653", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1989-03-23", "vigencias": [{"desde": "2020-07-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1989-03-23", "hasta": "2020-07-30", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2020-07-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-03-23", "fin_vigencia": "2020-07-30", "tipo_version": "0"}, {"in