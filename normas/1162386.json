{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10249579}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional de Ays&#xE9;n, por Res. Ex. N&#xB0; 704 de 30 junio 2021, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos que indica en las condiciones que se&#xF1;ala, por ejecuci&#xF3;n obra &quot;Proyecto de Pavimentaci&#xF3;n calle Juan Jos&#xE9; Latorre, Puerto Chacabuco&quot;, y autoriz&#xF3; a empresa constructora Bellavista SpA para realizar siguientes intervenciones en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  &#x2013; corte de v&#xED;a durante faenas de pavimentaci&#xF3;n de calle Juan Jos&#xE9; Latorre de Puerto Chacabuco, entre calles Bernardo O&apos;Higgins y Pilcomayo, desde el d&#xED;a 25-05-2021 hasta el d&#xED;a 13-09-2021.- Margarita Ossa Rojas, Intendente, Ejecutivo Gobierno Regional de Ays&#xE9;n.- </div></div>", "i": 10249580}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Ximena Guti&#xE9;rrez Jaramillo, Asesora Jur&#xED;dica.</div><div class=\"p\"> </div></div>", "i": 10249581}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "704 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-704 EXENTA"}], "organismos": ["MINISTERIO DEL INTERIOR Y SEGURIDAD PÚBLICA", "GOBIERNO REGIONAL DE AYSÉN"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1973879", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-06-30", "doble_articulado": false, "id_norma": "1162386", "numero_fuente": "42998", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-07-09", "v