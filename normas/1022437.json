{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 26 EXENTO, DE 2011</div></div>", "i": 9104553}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por el presente decreto se ha modificado el <a href=\"https://www.leychile.cl/Navegar?idNorma=226420&amp;idParte=0&amp;idVersion=\">decreto exento N&#xBA; 235, de 2004, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; planes y programas especiales de estudio biling&#xFC;e de 1&#xBA; a 8&#xBA; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica al Liceo Lorenzo Baeza Vega, de Isla de Pascua, Regi&#xF3;n de Valpara&#xED;so.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para 2&#xBA; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica de los Sectores que se indican y que se anexan, pasando a formar parte del presente decreto.</div></div>", "i": 9104554}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de enero de 2011.- Fernando Rojas Ochagav&#xED;a, Subsecretario de Educaci&#xF3;n.</div></div>", "i": 9104555}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "26 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-26 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 26 EXENTO, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-01-25", "doble_articulado": false, "id_norma": "1022437", "numero_fuente": "39871", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-01-28", "vigencias": [{"desde": "2011-01-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-01-28", "fin_vigencia": ""}, "vigenci