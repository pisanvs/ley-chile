{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10338283}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.657 de 23 mayo 2022, de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n parcial, conforme art&#xED;culo 51 ley 16.391, de inmueble ubicado en Av. El Dique, Rol Aval&#xFA;o 1-27, comuna Constituci&#xF3;n, superficie terreno 386 metros cuadrados, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Fisco de Chile. Comisi&#xF3;n integrada por peritos Patricio Dur&#xE1;n Marcos, Arquitecto; Rodrigo Silva Lazo, Constructor Civil y Pedro Pablo Cruz Weston, Arquitecto, seg&#xFA;n informe tasaci&#xF3;n de fecha 16 mayo 2022, fij&#xF3; monto provisional indemnizaci&#xF3;n en $74.860.000.- pagados al contado.- </div></div>", "i": 10338284}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Nebenka Donoso San Mart&#xED;n, Directora (S) Serviu Regi&#xF3;n del Maule.</div><div class=\"p\"> </div><br></div>", "i": 10338285}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2657 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2657 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2134043", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-05-23", "doble_articulado": false, "id_norma": "1176896", "numero_fuente": "43267", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-06-01", "vigencias": [{"desde": "2022-06-01", "hast