{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5845104}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Ministro de Fe de las actuaciones del Consejo y del Banco Central de Chile que suscribe, conforme lo dispone el N&#xB0; 6 del Art&#xED;culo 18 de la Ley N&#xB0; 18.840, certifica que de conformidad con lo establecido en el Cap&#xED;tulo III.F.5 del Compendio de Normas Financieras, las clasificaciones de Riesgo de los estados soberanos y las entidades bancarias contenidas en el Anexo de la citada norma permanecen, para los efectos previstos en dicho Cap&#xED;tulo, sin variaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Se deja constancia que las clasificaciones de riesgo corresponden a la informaci&#xF3;n disponible en el Banco Central de Chile hasta el 15 de febrero de 1994. </div></div>", "i": 5845105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, febrero 15 de 1994.- V&#xED;ctor Vial del R&#xED;o, Ministro de Fe.</div><br></div>", "i": 5845106}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CLASIFICACION RIESGO", "ENTIDADES BANCARIAS EXTRANJERAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-02-15", "doble_articulado": false, "id_norma": "1772", "numero_fuente": "34793", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-02-17", "vigencias": [{"desde": "1994-02-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-02-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci