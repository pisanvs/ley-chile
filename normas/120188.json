{"html": [{"t": "<div><div class=\"p\">DISPONE EXPROPIACION PARCIAL DE INMUEBLE QUE SE&#xD1;ALA </div><div class=\"p\">(Extracto)</div><br><br><br></div>", "i": 6115264}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Decreto Secc. 2da. N&#xBA; 379, del 13.05.98, Alcalde Municipalidad Santiago dispone expropiaci&#xF3;n parcial, conforme art. 85 decreto 458 Ministerio Vivienda y Urbanismo inmueble San Isidro 480, Rol N&#xBA; 592-022, comuna Santiago, dominio aparente Sociedad Don Horacio S.A., superficie aproximada 93 metros cuadrados. Deslindes: Norte, 32 mts. l&#xED;nea oblicua resto predio; Sur, 31 mts. otro propietario; Oriente, 6 mts. otro propietario y Poniente, 0,00 mt. v&#xE9;rtice deslindes Sur y Norte. Indemnizaci&#xF3;n $16.703.000.- pagadera contado. </div></div>", "i": 6115265}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jaime Ravinet de la Fuente, Alcalde Santiago. </div></div>", "i": 6115266}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "379", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-379"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "DISPONE EXPROPIACION PARCIAL DE INMUEBLE QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-05-13", "doble_articulado": false, "id_norma": "120188", "numero_fuente": "36078", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-06-01", "vigencias": [{"desde": "1998-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1