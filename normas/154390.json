{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6228847}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 186 del 26 de Agosto de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la II Regi&#xF3;n, se modifica el recorrido autorizado por resoluci&#xF3;n exenta No. 57 del 19 de Junio de 1984 de esta Secretar&#xED;a Regional, quedando como sigue:</div><br><div class=\"p\">&quot;LINEA No. C-3 DE SIN - TAXLOA&quot; Ida: 10 de Julio, Hamburgo, Francfurt, recorrido habitual hasta Quetena para continuar por su trazado normal. Regreso: Trazado habitual hasta Hurtado de Mendoza continuando por Florida, Alonso de Ercilla hasta el Terminal en 10 de Julio.-</div><br></div>", "i": 6228848}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Guido M. Ram&#xED;rez Maturana, Secretario Regional Ministerial de Transportes y Telecomunicaciones II Regi&#xF3;n. </div></div>", "i": 6228849}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "186 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-186 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL II REGIÓN DE ANTOFAGASTA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-26", "doble_articulado": false, "id_norma": "154390", "numero_fuente": "32880", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-28", "vigencias": [{"desde": "1987-09-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"ini