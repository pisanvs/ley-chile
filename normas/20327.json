{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 131 EXENTO, DE 1994 </div><br></div>", "i": 7160709}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 131 de fecha 29 de marzo de 1994 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Centro de Estudios Navieros Concepci&#xF3;n, los Planes y Programas de Estudios de las Carreras y T&#xED;tulos de Nivel Superior que se indican, para ser impartidas en la ciudad de Concepci&#xF3;n, a contar del a&#xF1;o 1994:</div><br><div class=\"p\"> Carrera: T&#xE9;cnico en Transporte Mar&#xED;timo Internacional.</div><div class=\"p\"> T&#xED;tulo : T&#xE9;cnico en Transporte Mar&#xED;timo Internacional. Carrera: T&#xE9;cnico en Navegaci&#xF3;n y Extracci&#xF3;n Pesquera.</div><div class=\"p\"> T&#xED;tulo : T&#xE9;cnico en Navegaci&#xF3;n y Extracci&#xF3;n Pesquera. </div></div>", "i": 7160710}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 20 de Mayo de 1994.-</div><div class=\"p\">&nbsp; &nbsp; Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160711}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "131 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-131 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 131 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA CENTRO ESTUDIOS NAVIEROS", "CONCEPCION", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "TECNICO", "TRANSPORTE MARITIMO INTERNACIONAL", "TECNICO NAVEGACION", "EXTRACCION PESQUERA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-29", "doble_articula