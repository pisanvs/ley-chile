{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6288137}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.739 de fecha 28 de abril de 2000, se expropi&#xF3; el lote de terreno N&#xBA;3, superficie 330,62 m&#xB2;, rol de aval&#xFA;o 107-32, comuna de Copiap&#xF3;, para la obra &apos;&apos;Acceso Sur a Copiap&#xF3; y Puente La Paz Camino Ruta 5 Longitudinal Norte&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Lidia de la Cruz Ponggi D&#xED;az y otros, ascendente a la cantidad de $20.728.392. </div></div>", "i": 6288138}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6288139}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1739", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1739"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-28", "doble_articulado": false, "id_norma": "172639", "numero_fuente": "36714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-15", "vigencias": [{"desde": "2000-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-07-18", "fecha_version": "2000-07-15", "fecha_actualizacion_texto": "2000-07-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructu