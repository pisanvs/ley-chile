{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0;. 174, DE 1989 </div></div>", "i": 6082353}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 174, de 09 de noviembre de 1989, se ha aprobado para la Escuela Industrial Salesiana &quot;El Salvador&quot;, de Talca, VII Regi&#xF3;n del Maule, un plan especial de estudio para el 2&#xB0; ciclo de educaci&#xF3;n media modalidad t&#xE9;cnico-profesional de adultos, especialidad Electromec&#xE1;nica, que se aplicar&#xE1; en 3er. a&#xF1;o medio en 1989 y en 4to a&#xF1;o medio en 1990. </div></div>", "i": 6082354}, {"t": "<div><div class=\"p\">Santiago, 06 de diciembre de 1989.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6082355}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "174 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-174 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N°. 174, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-11-09", "doble_articulado": false, "id_norma": "89364", "numero_fuente": "33551", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-12-21", "vigencias": [{"desde": "1989-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-12-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-12-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1998-0