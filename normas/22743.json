{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento de 442,000 pesos al presupuesto de Guerra para forraje i paja larga.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,555.- Santiago, a 4 de Setiembre de 1902.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7164188}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de cuatrocientos cuarenta i dos mil pesos ($ 442,000) al &#xED;tem 10,862 de la partida 353 del presupuesto de Guerra, para forraje i paja larga.</div><br></div>", "i": 7164189}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- V&#xED;ctor Manuel Lamas.</div><br></div>", "i": 7164190}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1555", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1555"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "SUPLEMENTO DE 442,000 PESOS AL PRESUPUESTO DE GUERRA PARA FORRAJE I PAJA LARGA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1902", "MODIFICACION GUERRA", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1902-09-04", "doble_articulado": false, "id_norma": "22743", "numero_fuente": "7348", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1902-09-06", "vigencias": [{"desde": "1902-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1902-09-06", "fin_vigencia