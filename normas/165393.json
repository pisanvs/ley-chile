{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 410, DE 1985 </div></div>", "i": 7267554}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 826, de 10 de Diciembre de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n No. 410; de 1985, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a la Sociedad &quot;Jim&#xE9;nez y C&#xED;a. Limitada&quot;, &quot;Pesquera Aldebar&#xE1;n Ltda.&quot; para operar las embarcaciones denominadas &quot;La Chimba&quot; y &quot;La Portada&quot;, en orden a incluir en el numeral 5&#xB0;, entre las especies que la Sociedad puede extraer con dichas embarcaciones, los recursos: bonito y cojinova, que destinar&#xE1; a su industrializaci&#xF3;n para consumo humano directo. Las embarcaciones deber&#xE1;n contar a bordo, con sistemas adecuados de preservaci&#xF3;n de la materia prima. </div></div>", "i": 7267555}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de Diciembre de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7267556}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "826", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-826"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 410, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-10", "doble_articulado": false, "id_norma": "165393", "numero_fuente": "32346", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-13", "vigencias": [{"desde