{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6466182}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 394, de 11 de febrero de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA SAN JOSE S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Don Julio&quot;, donde podr&#xE1; capturar los siguientes recursos hidrobiol&#xF3;gicos: a) En el &#xE1;rea mar&#xED;tima correspondiente a las regiones III, IV, V, VI, VII, IX y X, por fuera del &#xE1;rea de reserva artesanal, con cerco: Jibia; b) En el &#xE1;rea mar&#xED;tima de la III Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, con arrastre de media agua: Jibia; c) En el &#xE1;rea mar&#xED;tima correspondiente a las regiones IV, V, VI, VII, IX y X, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua: Jibia.</div><br></div>", "i": 6466183}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de febrero de 2004.- Jessica Fuentes Olmos, Subsecretario de Pesca (S).</div><br></div>", "i": 6466184}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "394", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-394"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-11", "doble_articulado": false, "id_norma": "221673", "numero_fuente": "37796", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-26", "vigencias": [{"desde": "2004-02-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia