{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 233 EXENTO, DE 1996 </div><br><br><br></div>", "i": 8950615}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 233 de fecha 24 de abril de 1996 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; al Centro de Formaci&#xF3;n T&#xE9;cnica CES, el plan y programas de estudios de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida en la ciudad de Santiago, a contar del a&#xF1;o 1996.</div><div class=\"p\">&nbsp; &nbsp; Carrera: Dise&#xF1;o, Producci&#xF3;n y Manejo de Areas Verdes T&#xED;tulo: T&#xE9;cnico de Nivel Superior en Dise&#xF1;o, Producci&#xF3;n y Manejo de Areas Verdes.</div><br></div>", "i": 8950616}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 12 de junio de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8950617}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "233", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-233"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 233 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA CES", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-04-24", "fecha_derogacion": "1999-11-24", "doble_articulado": false, "id_norma": "20749", "numero_fuente": "35496", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-06-20", "vigencias": [{"desde": "1999-11-24", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1996-06-20", "hasta": "1999-