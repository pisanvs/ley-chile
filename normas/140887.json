{"html": [{"t": "<div><div class=\"p\">EXCEPCIONA DEL REGIMEN DE CAMBIO DE SUJETO DE IVA A</div><div class=\"p\">GENDARMERIA DE CHILE, CENTRO&nbsp; DE&nbsp; READAPTACION&nbsp; SOCIAL</div><div class=\"p\">DE COLINA I</div><br></div>", "i": 6183677}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Res. N&#xBA; Ex 2.466, de 10 de agosto de 1999, de esta Direcci&#xF3;n Regional, se excepciona a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n y hasta el 31 de julio del a&#xF1;o 2000, a Gendarmer&#xED;a de Chile, Centro de Readaptaci&#xF3;n Social de Colina I, Rut N&#xBA; 70.988.400-K, del r&#xE9;gimen de cambio de sujeto del Impuesto al Valor Agregado, en las operaciones de ventas de carnes establecido en la Res. N&#xBA; 5.087, de 1999 (D.O.</div><div class=\"p\">31.07.1999), del Director del Servicio.-</div><br></div>", "i": 6183678}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jorge A. de Calisto Bravo, Director Regional. </div></div>", "i": 6183679}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2466 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2466 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA", "SANTIAGO PONIENTE"], "titulo_norma": "EXCEPCIONA DEL REGIMEN DE CAMBIO DE SUJETO DE IVA A\nGENDARMERIA DE CHILE, CENTRO DE READAPTACION SOCIAL\nDE COLINA I", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-08-10", "doble_articulado": false, "id_norma": "140887", "numero_fuente": "36444", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-08-20", "vigencias": [{"desde": "1999-08-20", "has