{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8316462}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.736, de 17 de diciembre de</div><div class=\"p\">1997, de esta Subsecretar&#xED;a de Pesca del&nbsp; Ministerio de</div><div class=\"p\">Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la</div><div class=\"p\">solicitud de concesi&#xF3;n de acuicultura N&#xBA; 97032004,</div><div class=\"p\">presentada por IVAN ANTONIO FIGUEROA, para operar un</div><div class=\"p\">centro de cultivo en Bah&#xED;a Calderilla, comuna de</div><div class=\"p\">Caldera, provincia de Copiap&#xF3;, III Regi&#xF3;n, conforme lo</div><div class=\"p\">dispuesto en el art&#xED;culo 67, inciso 5&#xBA; y el art&#xED;culo 78,</div><div class=\"p\">inciso 2&#xBA; de la Ley General de Pesca y Acuicultura y el</div><div class=\"p\">art&#xED;culo 14 del D.S. N&#xBA; 290 de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8316463}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de diciembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8316464}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1736", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1736"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION DE ACUICULTURA", "IVAN ANTONIO FIGUEROA", "CALDERA", "TERCERA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-17", "doble_articulado": false, "id_norma": "84604", "numero_fuente": "35