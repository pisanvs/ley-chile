{"html": [{"t": "<div><div class=\"p\">CREA PLAZA DE DEFENSOR PUBLICO EN CABRERO</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de junio de 2004.- Hoy se decret&#xF3; lo que sigue:</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 486.- Vistos: Estos antecedentes, lo dispuesto en el art&#xED;culo 32 N&#xBA; 8 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica, en el art&#xED;culo 365 del C&#xF3;digo Org&#xE1;nico de Tribunales,</div><br><div class=\"p\">&nbsp; &nbsp;  D e c r e t o:</div><br></div>", "i": 6484764}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Cr&#xE9;ase una plaza de Defensor P&#xFA;blico, para el servicio de la comuna que constituye el territorio jurisdiccional del Juzgado de Letras y Garant&#xED;a de Cabrero.</div><br></div>", "i": 6484765}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- Por orden del Presidente de la Rep&#xFA;blica, Luis Bates Hidalgo, Ministro de Justicia.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Le saluda atentamente, Jaime Arellano Quintana, Subsecretario de Justicia.</div><br></div>", "i": 6484766}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "486", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-486"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CREA PLAZA DE DEFENSOR PUBLICO EN CABRERO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CARGOS JUDICIALES", "PLAZA DE DEFENSOR PUBLICO", "CABRERO", "CREACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-06-09", "doble_articulado": false, "id_norma": "226787", "numero_fuente": "37895", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion":