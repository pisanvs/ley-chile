{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 320, DE 1993 </div><br><br></div>", "i": 7161583}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 320 de 25 de junio de 1993 se ha aprobado un plan especial de estudio para educaci&#xF3;n media t&#xE9;cnico-profesional de adultos, en las especialidades de Contabilidad, Secretariado Ejecutivo, Computaci&#xF3;n y Ventas y Publicidad, conducentes a los t&#xED;tulos de t&#xE9;cnico de nivel medio. Adem&#xE1;s, se aprueban los programas de estudio para las asignaturas del Area Profesional. </div></div>", "i": 7161584}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 28 de junio de 1993.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161585}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "320 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-320 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 320, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EDUCACION DE ADULTOS", "PLANES DE ESTUDIO", "ESTABLECIMIENTOS EDUCACIONALES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-06-25", "doble_articulado": false, "id_norma": "20987", "numero_fuente": "34602", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-06-30", "vigencias": [{"desde": "1993-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-06-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-06-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "