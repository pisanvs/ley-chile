{"html": [{"t": "<div><br><div class=\"p\">MODIFICA CIRCULAR N&#xBA; 23, DEL 14 DE ABRIL DE 2005</div></div>", "i": 8597381}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de circular del Servicio de Impuestos Internos N&#xBA; 27 de 8 de mayo de 2009, que:</div><div class=\"p\">&nbsp; &nbsp;  Modifica las instrucciones contenidas en la circular N&#xBA;23 del 14 de abril de 2005, en el sentido de dejar en car&#xE1;cter de opcional la inclusi&#xF3;n de la imagen de la representaci&#xF3;n impresa del documento cedido, en el archivo electr&#xF3;nico correspondiente a la cesi&#xF3;n de cr&#xE9;ditos contenidos en una factura electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta circular est&#xE1; publicado en el sitio Web del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de mayo de 2009.</div></div>", "i": 8597382}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "27", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-27"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA CIRCULAR Nº 23, DEL 14 DE ABRIL DE 2005", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2009-05-08", "fecha_derogacion": "2013-11-30", "doble_articulado": false, "id_norma": "1002175", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2009-05-14", "vigencias": [{"desde": "2013-11-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2009-05-14", "hasta": "2013-11-29", "tipo_version": "0", "tipo_version_s": "Texto Origin