{"html": [{"t": "<div><div class=\"p\">&#xFEFF;Comision de salud p&#xFA;blica</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago de Chile, 7 de Agosto de 1813.</div></div>", "i": 10197946}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  El Gobierno ha formado una comision de salud p&#xFA;blica dirijida especialmente a remediar los estragos del mal ven&#xE9;reo; i se previene a todos los Cuerpos, gremios, casas p&#xFA;blicas, i empleados del estado que con el aviso del Protom&#xE9;dico doctor don Jos&#xE9; Rios, franqueen todos los auxilios, instrucciones, i conocimientos que halle por conveniente para evacuar su comision, i sean relativos a ella. T&#xE9;ngase por circulado este decreto con su publicacion en El Monitor.</div></div>", "i": 10197947}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - P&#xE9;rez. - Eyzaguirre. - Ega&#xF1;a.</div></div>", "i": 10197948}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Comision de salud pública", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1813-08-07", "doble_articulado": false, "id_norma": "1154505", "numero_fuente": "1813", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1813-08-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1813-08-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1813-08-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "906", "fecha_ingreso": "2021-02-01", "fec