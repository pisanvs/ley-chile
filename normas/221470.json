{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7309096}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 428, de 17 de febrero de</div><div class=\"p\">2004, de esta Subsecretar&#xED;a, rectif&#xED;case el numeral 2&#xBA;</div><div class=\"p\">de la resoluci&#xF3;n N&#xBA; 2808 de 2003, de esta Subsecretar&#xED;a,</div><div class=\"p\">que autoriz&#xF3; a INVERSIONES DELFINES S.A. CERRADA, para</div><div class=\"p\">sustituir la nave &quot;Punta Arenas&quot; por una nave en</div><div class=\"p\">construcci&#xF3;n, en el sentido de reemplazar en ella el</div><div class=\"p\">arte &quot;cerco&quot; por el de &quot;arrastre&quot;.</div><br></div>", "i": 7309097}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de febrero de 2004.- Jessica Fuentes Olmos, Subsecretario de Pesca (S).</div><br></div>", "i": 7309098}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "428 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-428 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-02-17", "fecha_derogacion": "2004-05-17", "doble_articulado": false, "id_norma": "221470", "numero_fuente": "37792", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-02-21", "vigencias": [{"desde": "2004-05-17", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-02-21", "hasta": "2004-05-16", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "20