{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 3.732 EXENTA, DE 2001 </div></div>", "i": 6332708}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 3.732 de 30 de marzo del a&#xF1;o 2001, se ha aprobado al Colegio Padre Hurtado y Juanita de los Andes de Santiago, el siguiente plan de estudio para 3&#xBA; y 4&#xBA; de a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Apru&#xE9;banse los siguientes programas de estudio, para 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, para los Subsectores que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 6332709}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de abril de 2001.- Javier San Miguel Bertr&#xE1;n, Jefe Divisi&#xF3;n Educaci&#xF3;n General, Subrogante. </div></div>", "i": 6332710}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3732 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3732 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 3.732 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-30", "doble_articulado": false, "id_norma": "184698", "numero_fuente": "36950", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-04-30", "vigencias": [{"desde": "2001-04-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-04-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-04-30", "fin_vigencia": "", "tipo_versio