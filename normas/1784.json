{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5845128}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Subsecretario de Educaci&#xF3;n, quien suscribe, certifica que el Instituto Profesional Los Leones, autorizado a funcionar por Decreto Exento N&#xB0; 36 de 1990, impartir&#xE1; las siguientes carreras y otorgar&#xE1; los t&#xED;tulos profesionales que se indican, a contar del a&#xF1;o 1994 en la ciudad de Santiago.</div><br><div class=\"p\"> Carrera&nbsp; : Publicidad</div><div class=\"p\"> T&#xED;tulo&nbsp;  : Publicista Carrera&nbsp; : Comunicaci&#xF3;n Social en Marketing T&#xED;tulo&nbsp;  : Comunicador Social en Marketing.</div><br><div class=\"p\">&nbsp; &nbsp; Las mencionadas carreras se encuentran liberadas de la obligaci&#xF3;n de someter sus planes y programas de estudios a una entidad examinadora, en virtud de lo dispuesto por los Decretos Supremos N&#xB0; 1.076 de 1986 y N&#xB0; 972 de 1987, respectivamente.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 14 de Abril de 1994.</div><br></div>", "i": 5845129}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; GONZALO UNDURRAGA MACKENNA Subsecretario de Educaci&#xF3;n </div></div>", "i": 5845130}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO PROFESIONAL LEONES", "PUBLICIDAD", "COMUNICACION SOCIAL", "MARKETING", "CARRERA PROFESIONAL", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-04-14", "doble_articulado": false, "id_norma": "1784", "numero_fuente": "34851", "tipo_version"