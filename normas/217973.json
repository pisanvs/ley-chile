{"html": [{"t": "<div><div class=\"p\">AUTORIZA COMO EMISOR DE DOCUMENTOS TRIBUTARIOS ELECTRONICOS A CONTRIBUYENTE QUE INDICA </div></div>", "i": 6450981}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resol. Ex. SII N&#xBA; 66, del 26 de noviembre de 2003, se autoriza como emisor de documentos tributarios electr&#xF3;nicos a contar del mes de diciembre de 2003 al contribuyente RUT 90.749.000-9. En el sitio web del SII se podr&#xE1; consultar los documentos que el contribuyente est&#xE1; autorizado a emitir en forma electr&#xF3;nica.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra incluido en el sitio web del SII en internet, cuya direcci&#xF3;n es www.sii.cl y en el Bolet&#xED;n del mes de noviembre de 2003.-</div><br></div>", "i": 6450982}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Toro Rivera, Director.</div><br></div>", "i": 6450983}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "66 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-66 EXENTA"}], "organismos": ["SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA COMO EMISOR DE DOCUMENTOS TRIBUTARIOS\nELECTRONICOS A CONTRIBUYENTE QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-11-26", "doble_articulado": false, "id_norma": "217973", "numero_fuente": "37724", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-01", "vigencias": [{"desde": "2003-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v