{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; AUTORIZA EMISORES ELECTRONICOS</div><br></div>", "i": 6566518}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 36, de 4 abril 2006, que autoriza a contribuyentes como emisores electr&#xF3;nicos. Se autoriza como emisores de documentos tributarios electr&#xF3;nicos a RUT 84.671.700-5, RUT 88.770.900-9, RUT 82.833.200-7, RUT 96.698.110-5 y RUT 78.048.910-3 a contar del mes de abril de 2006. En la Oficina Virtul del SII en Internet se podr&#xE1; consultar los documentos que los contribuyentes est&#xE1;n autorizados a emitir en forma electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de abril de 2006.</div><br></div>", "i": 6566519}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "36 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-36 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISORES ELECTRONICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONTRIBUYENTES", "EMISORES ELECTRONICOS", "AUTORIZACION", "DOCUMENTOS TRIBUTARIOS ELECTRONICOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-04-04", "doble_articulado": false, "id_norma": "248794", "numero_fuente": "38435", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-04-08", "v