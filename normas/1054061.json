{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9373639}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.413, de 29 de agosto de 2013, de esta Subsecretar&#xED;a, rectif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1053146&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.801, de 2013</a>, que autoriz&#xF3; a ORIZON S.A. para ampliar actividades pesqueras extractivas con la nave &quot;San Jos&#xE9;&quot;, en el sentido de agregar en el numeral 2&#xBA;, la siguiente letra f): &quot;f) En el &#xE1;rea mar&#xED;tima comprendida desde la III a VII y IX a X Regiones, por fuera del &#xE1;rea de reserva artesanal, con cerco, el recurso hidrobiol&#xF3;gico Machuelo o Tritre Ethmidium maculatum.&quot;.</div></div>", "i": 9373640}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de agosto de 2013.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9373641}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2413 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-2413 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-08-29", "doble_articulado": false, "id_norma": "1054061", "numero_fuente": "40654", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-09-07", "vigencias": [{"desde": "2013-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-09-07", "fin_vigencia": ""}, "vigenc