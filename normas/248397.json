{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6565253}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 716, de 28 de febrero de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a GUILLERMO ANTONIO ROJAS PE&#xD1;A, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Sector Sur Caleta Las Conchas, Los Vilos, provincia de Coquimbo, IV Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Alga picada, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 222 de 2006, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6565254}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de febrero de 2006.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6565255}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "716 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-716 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-02-28", "doble_articulado": false, "id_norma": "248397", "numero_fuente": "38424", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-27", "vigencias": [{"desde": "2006-03-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-03-27", "fin_vigencia": ""}, "vigencias_version_norm