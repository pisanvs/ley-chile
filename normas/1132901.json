{"html": [{"t": "<div><br><div class=\"p\">CREA MODELO DE CERTIFICADO N&#xBA; 63</div><div class=\"p\"> </div></div>", "i": 10031771}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 75, del 12 de junio de 2019, que establece:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Crea modelo de Certificado N&#xBA; 63, sobre donaciones efectuadas a la Fundaci&#xF3;n Imagen de Chile para llevar a cabo la organizaci&#xF3;n y ejecuci&#xF3;n de la Conferencia de las Partes de la Convenci&#xF3;n Marco de las Naciones Unidas sobre cambio clim&#xE1;tico &quot;COP 25&quot;.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n en el mes de junio de 2019.</div></div>", "i": 10031772}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "75 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-75 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CREA MODELO DE CERTIFICADO Nº 63", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1607344", "EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-06-12", "doble_articulado": false, "id_norma": "1132901", "numero_fuente": "42383", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-06-19", "vigencias": [{"desde": "2019-06-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vige