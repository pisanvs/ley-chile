{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 12.376 EXENTA, DE 2001 </div><br></div>", "i": 6355843}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 12.376 de 22 de octubre de 2001, se ha aprobado, al Colegio Universitario Ingl&#xE9;s, comuna de Providencia, de Santiago, el siguiente plan de estudio para 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se se&#xF1;alan en la presente resoluci&#xF3;n. </div></div>", "i": 6355844}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de octubre de 2001.- Juan Ruz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6355845}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "12376 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-12376 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 12.376 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-10-22", "doble_articulado": false, "id_norma": "191291", "numero_fuente": "37103", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-06", "vigencias": [{"desde": "2001-11-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-11-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-11-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_p