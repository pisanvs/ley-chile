{"html": [{"t": "<div><div class=\"p\">APRUEBA ORDENANZA SOBRE &quot;OTORGAMIENTO, RECEPCION Y REGISTRO DE SUBVENCIONES Y DONACIONES DE LA MUNICIPALIDAD DE MACHALI&quot; </div></div>", "i": 6472454}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Municipalidad de Machal&#xED; pone en conocimiento de la comunidad que&nbsp;  por decreto alcaldicio N&#xBA; 168 de&nbsp; 29 de marzo de 2004, fue aprobada la Ordenanza Municipal que norma el procedimiento sobre &quot;Otorgamiento, Recepci&#xF3;n y Registro de Subvenciones y Donaciones&quot;.</div><div class=\"p\">&nbsp; &nbsp;  Se informa que el texto completo de la citada ordenanza est&#xE1; a disposici&#xF3;n de quien lo solicite en Secretar&#xED;a del Municipio, ubicada en Plaza de Armas N&#xBA; 11, Machal&#xED;.</div><br></div>", "i": 6472455}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Juan Abud Figueroa, Alcalde.</div><br></div>", "i": 6472456}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "168", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-168"}], "organismos": ["MUNICIPALIDAD DE MACHALÍ"], "titulo_norma": "APRUEBA ORDENANZA SOBRE OTORGAMIENTO, RECEPCION Y REGISTRO DE SUBVENCIONES Y DONACIONES DE LA MUNICIPALIDAD DE MACHALI", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTARCTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-29", "doble_articulado": false, "id_norma": "223409", "numero_fuente": "37830", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-06", "vigencias": [{"desde": "2004-04-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-04-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "20