{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6009501}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Resoluci&#xF3;n 348, 13 diciembre 1993, SERVIU Regi&#xF3;n del B&#xED;o B&#xED;o orden&#xF3; expropiaci&#xF3;n total, conforme art. 51 Ley 16.391, y D.L. 2.186 de 1978, para programa obras infraestructura, inmueble ubicado en Avda. Arturo Prat N&#xB0;1493, rol de aval&#xFA;os N&#xB0; 618-13, comuna de Concepci&#xF3;n, aparente dominio de Ferrocarriles del Estado. Comisi&#xF3;n integrada por Peritos Sres. Teodoro Medina Reyes, ingeniero civil, Pedro Tagle Mart&#xED;nez, arquitecto y Luis Abarz&#xFA;a Ceballos, constructor civil, seg&#xFA;n informe de fecha 23 de noviembre de 1993, fij&#xF3; monto provisional indemnizaci&#xF3;n en $77.040.000, pagadera de contado. </div></div>", "i": 6009502}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director SERVIU Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6009503}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "348", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-348"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "DECRETO EXPROPIATORIO", "BIEN RAIZ", "BIEN INMUEBLE", "CONCEPCION", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-12-13", "doble_articulado": false, "id_norma": "34406", "numero_fuente": "34765-3", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-01-15", "vigencias": [{"desde": "1994-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"