{"html": [{"t": "<div><div class=\"p\">INSTRUYE SOBRE LAS MODIFICACIONES INTRODUCIDAS POR LA LEY N&#xB0; 21.210</div></div>", "i": 10133440}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de circular del Servicio de Impuestos Internos N&#xB0; 44, del 26 de junio de 2020, que instruye sobre las modificaciones introducidas por la <a href=\"https://www.leychile.cl/Navegar?idNorma=1142667&amp;idParte=&amp;idVersion=\">Ley N&#xB0; 21.210</a>, Moderniza la Legislaci&#xF3;n Tributaria, a los art&#xED;culos <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=8573324&amp;idVersion=\">6&#xB0;</a> letra A) N&#xB0; 2 y B), N&#xB0; 4, <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=8573385&amp;idVersion=\">56</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=9510273&amp;idVersion=\">26 bis</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=8573436&amp;idVersion=\">98</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=8573437&amp;idVersion=\">99</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=9510279&amp;idVersion=\">100 bis</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=10104241&amp;idVersion=\">111 bis</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=8573515&amp;idVersion=\">165</a> del <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=&amp;idVersion=\">C&#xF3;digo Tributario</a>, en materia de ejercicio de la facultad de condonar total o parcialmente los intereses penales por la mora en el pago de los impuestos, facultad de aplicaci&#xF3;n e interpretaci&#xF3;n de las normas tributarias, procedimiento de consulta en materia de medidas antielusi&#xF3;n, aplicaci&#xF3;n de normas penales tributarias e instruye sobre el beneficio extraordinario consagrado en el <a href=\"https://www.leychile.cl/Navegar?idNorma=1142667&amp;idParte=10103283&amp;idVersion=\">art&#xED;culo treinta y tres transitorio</a> de la referida ley.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta circular est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl).</div></div>", "i": 10133441}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "44", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-44"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "INSTRUYE SOBRE LAS MODIFICACIONES INTRODUCIDAS POR LA LEY N° 21.210", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1780523", "EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-06-26", "doble_articulado": false, "id_norma": "1147204", "numero_fuente": "42696", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-07-03", "vigencias": [{"desde": "2020-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2020-07-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2020-07-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresado_por": "10418", "fecha_ingreso": "2020-07-03", "fecha_version": "2020-07-03", "fecha_actualizacion_texto": "2020-07-03", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10133440}, {"n": "Artículo", "i": 10133441, "t": 6}]}