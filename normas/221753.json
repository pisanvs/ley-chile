{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6466526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 441, de 17 de febrero de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a ALIMENTOS MARINOS S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Cacique I&quot;, donde podr&#xE1; capturar los siguientes recursos hidrobiol&#xF3;gicos: a) En el &#xE1;rea mar&#xED;tima de las Regiones V, VI, VII, IX y X, por fuera del &#xE1;rea de reserva artesanal, con cerco: Jibia; b) En el &#xE1;rea mar&#xED;tima de las Regiones V, VI, VII, IX y X, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua: Jibia.</div><br></div>", "i": 6466527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de febrero de 2004.- Jessica Fuentes Olmos, Subsecretario de Pesca (S).</div><br></div>", "i": 6466528}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "441", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-441"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-02-17", "fecha_derogacion": "2013-01-16", "doble_articulado": false, "id_norma": "221753", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-02-27", "vigencias": [{"desde": "2013-01-16", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-02-27", "hasta": "2013-01-15", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2013-01-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_