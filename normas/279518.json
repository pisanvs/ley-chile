{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6661904}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 643 de 29 de agosto de 2008, se dej&#xF3; sin efecto el decreto MOP. N&#xBA; 454, de fecha 30 de junio de 2008, se orden&#xF3; la expropiaci&#xF3;n, se aprob&#xF3; el Plano y Cuadro de Expropiaci&#xF3;n y se autoriz&#xF3; el Convenio Directo de Precio del lote de terreno N&#xBA; 32, superficie 7.283 m2., rol de aval&#xFA;o 147-745, comuna de Dalcahue, X Regi&#xF3;n de Los Lagos, para la obra &quot;Nuevo Aer&#xF3;dromo Isla de Chilo&#xE9;&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario FRANCISCO TORRES MIRANDA, ascendente a la cantidad de $6.709.392.</div><br></div>", "i": 6661905}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6661906}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "643", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-643"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-08-29", "doble_articulado": false, "id_norma": "279518", "numero_fuente": "39188", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-10-15", "vigencias": [{"desde": "2008-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-10-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingr