{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO RESOLUCI&#xD3;N SII N&#xBA; 111 EXENTA, DE 22 DE SEPTIEMBRE DE 2008, POR LAS RAZONES QUE INDICA</div></div>", "i": 10062851}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 115, del 15 de octubre de 2019, que establece:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Se deja sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=278287&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n Ex. SII N&#xBA; 111 de 22.09.2008</a>, que estableci&#xF3; la obligaci&#xF3;n de efectuar una declaraci&#xF3;n jurada a los propietarios de bienes ra&#xED;ces agr&#xED;colas que cuenten con terrenos beneficiados con la exenci&#xF3;n del Impuesto Territorial. A contar de esta fecha, los contribuyentes no estar&#xE1;n obligados a presentar esta declaraci&#xF3;n jurada.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento est&#xE1; publicado en www.sii.cl.</div><br><br></div>", "i": 10062852, "v": ["MODIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "115 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-115 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEJA SIN EFECTO RESOLUCIÓN SII Nº 111 EXENTA, DE 22 DE SEPTIEMBRE DE 2008, POR LAS RAZONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1669591", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-10-15", "doble_articulado": false, "id_norma": "1137803", "numero_fuente": "42480", "tipo