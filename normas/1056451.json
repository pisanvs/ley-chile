{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9386655}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.084, de 12 de noviembre de 2013, de esta Subsecretar&#xED;a, ampl&#xED;ese por un a&#xF1;o, a contar del 10 de agosto de 2014, el plazo otorgado en los numerales 4&#xBA; de las resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=1025826&amp;idParte=0&amp;idVersion=\">N&#xBA; 1.102, de 2011</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1043297&amp;idParte=0&amp;idVersion=\">N&#xBA; 2.278, de 2012</a>, a PESQUERA SUR AUSTRAL S.A. para realizar actividades pesqueras extractivas con la nave en construcci&#xF3;n &quot;BEC 1102-2011&quot;, en virtud de haberse acreditado una circunstancia de fuerza mayor.</div></div>", "i": 9386656}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de noviembre de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S). </div></div>", "i": 9386657}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3084 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3084 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2013-11-12", "fecha_derogacion": "2015-07-27", "doble_articulado": false, "id_norma": "1056451", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2013-11-20", "vigencias": [{"desde": "2015-07-27", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "20