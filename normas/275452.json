{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 4.715 EXENTA, DE 2008 </div></div>", "i": 8437692}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 4.715, de 27 de junio de 2008, se han modificado las resoluciones exentas de Educaci&#xF3;n Nos 540, de 2001, y 2.614, de 2002, que aprobaron planes y programas especiales de estudio de 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, al Colegio Saint John&apos;s Villa Academy, comuna de La Reina, de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba el programa de estudio del Subsector Actualidad Nacional y Mundial del Plan de Formaci&#xF3;n Diferenciada para 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media.</div><br></div>", "i": 8437693}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 1 de agosto de 2008.- Rosita Puga Hamilton, Jefa Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 8437694}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4715 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4715 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 4.715 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-06-27", "doble_articulado": false, "id_norma": "275452", "numero_fuente": "39132", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-08-07", "vigencias": [{"desde": "2008-08-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-08-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci