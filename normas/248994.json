{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6567151}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 986, de 3 de abril de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a OSVALDO RICHARD HENRIQUEZ RIVERA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Luis Orione N&#xBA; 920, Quintero, V Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco enfriado, Fresco refrigerado, Salado h&#xFA;medo, Salado seco, Congelado y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6567152}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de abril de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6567153}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "986 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-986 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-04-03", "doble_articulado": false, "id_norma": "248994", "numero_fuente": "38442", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-04-19", "vigencias": [{"desde": "2006-04-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-04-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-04-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":