{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,524.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6172194}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados al pais por el injeniero segundo de la Armada Nacional, don Francisco V&#xE1;rgas, i mui especialmente a la circunstancia de haber sido uno de los sobrevivientes del combate naval de Iquique, el&#xE9;vase, por gracia, a treinta pesos la pension mensual de que actualmente disfruta su viuda do&#xF1;a Elisa Stoller.</div><br></div>", "i": 6172195}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, dos de agosto de mil novecientos once.- Ramon Barros Luco.- An&#xED;bal Rodr&#xED;guez.</div><br></div>", "i": 6172196}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2524", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2524"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-08-02", "doble_articulado": false, "id_norma": "137465", "numero_fuente": "10053", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-08-10", "vigencias": [{"desde": "1911-08-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-08-10", "fin_vigencia": ""}, "vigencias_version_norma": 