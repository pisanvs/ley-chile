{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 8369090}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico. Autorizase a la Municipalidad de Puerto Montt para que cambie el nombre de la calle &quot;Cayenel&quot; de esa ciudad por el de Antonio Var&#xE1;s&quot;.</div><div class=\"p\">&nbsp; &nbsp;  La presente ley comenzar&#xE1; a regir desde su publicaci&#xF3;n en el Diario Oficial&quot;.</div><br></div>", "i": 8369091}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, catorce de Agosto de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Carlos O. Fr&#xF6;dden. </div></div>", "i": 8369092}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4872", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4872"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA CAMBIO NOMBRE DE CALLE CAYENEL POR ANTONIO VARAS, PUERTO MONTT", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-08-14", "doble_articulado": false, "id_norma": "211587", "numero_fuente": "15755", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-08-22", "vigencias": [{"desde": "1930-08-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1930-08-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1930-08-22