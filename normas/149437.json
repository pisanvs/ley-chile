{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6212227}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 170 del 29 de Abril de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la I Regi&#xF3;n, se autoriza a Ernesto Segundo Ruiz Rodr&#xED;guez, para efectuar el servicio p&#xFA;blico urbano de locomoci&#xF3;n colectiva de pasajeros &quot;L&#xED;nea No. 8 Variante 7 Taxibuses de Arica&quot;, cuyo trazado fue autorizado por resoluci&#xF3;n No. 105 del 28 de Septiembre de 1983, de esta Secretar&#xED;a Regional. </div></div>", "i": 6212228}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Eliecer Aedo Rivera, Secretario Regional Ministerial Transportes y Telecomunicaciones I Regi&#xF3;n Tarapac&#xE1;.</div><br></div>", "i": 6212229}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "170 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-170 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-04-29", "doble_articulado": false, "id_norma": "149437", "numero_fuente": "32781", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-05-28", "vigencias": [{"desde": "1987-05-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-05-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-05-28", "fin_vigencia": "", "tipo_versio