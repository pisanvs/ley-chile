{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m 1,150.- Santiago, 29 de diciembre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6161607}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a los menores do&#xF1;a Mar&#xED;a Luisa, do&#xF1;a Cora i don Juan A. Greene, nietos del coronel de la Independencia don Juan Adams Greene, el goce de la respectiva pensi&#xF3;n de montep&#xED;o de coronel, de la que disfrutar&#xE1;n conjuntamente i con&nbsp; arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6161608}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto,&nbsp; prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Carlos Concha.</div><br></div>", "i": 6161609}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1150", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1150"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-12-29", "doble_articulado": false, "id_norma": "134198", "numero_fuente": "6190", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-12-31", "vigencias": [{"desde": "1898-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-12-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-12-31", "fin_vigencia": "", "tipo_version": "3"}], "evento