{"html": [{"t": "<div><br><div class=\"p\">ADICION A LA CONVOCATORIA.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Setiembre 10 de 1824.</div><br><div class=\"p\">&nbsp; &nbsp;  He acordado y decreto:</div></div>", "i": 10097288}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1.&#xB0; Todos los individuos, que segun lo prevenido en la Convocatoria y decreto adicional, sean inhabiles para electores, lo son igualmente para ser elejidos.</div><br><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; El presente decreto, de cuyo cumplimiento es encargado el Ministro del Interior, se observar&#xE1; como adicion a la Convocatoria. Al efecto se circular&#xE1; imprimi&#xE9;ndose en el Boletin.</div><br></div>", "i": 10097289}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  F. A. Pinto.</div><br></div>", "i": 10097290}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "ADICION A LA CONVOCATORIA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-09-10", "doble_articulado": false, "id_norma": "1141021", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-09-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-09-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2020-01-31",