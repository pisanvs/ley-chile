{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede una remuneracion de 3,000 pesos a don Luis Barriga</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,626.- Santiago, a 3 de Diciembre de 1903.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5950742}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese a don Luis Barriga la suma de tres mil pesos ($ 3,000) en remuneracion de los servicios que ha prestado como Secretario de la Comision Mista de ambas C&#xE1;maras encargada del estudio del C&#xF3;digo Org&#xE1;nico de los Tribunales.</div><br></div>", "i": 5950743}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Francisco J. Concha.</div><br></div>", "i": 5950744}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1626", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1626"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDE UNA REMUNERACION DE 3,000 PESOS A DON LUIS BARRIGA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LUIS BARRIGA", "REMUNERACION", "SERVICIOS PRESTADOS", "COMISION ESTUDIO", "CODIGO ORGANICO TRIBUNALES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1903-12-03", "doble_articulado": false, "id_norma": "22801", "numero_fuente": "7775", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1903-12-10", "vigencias": [{"desde": "1903-12-10", "hasta": "", "tipo_version": "3", "tip