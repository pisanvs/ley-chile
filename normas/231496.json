{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.304 EXENTA, DE 2004 </div></div>", "i": 6501431}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.304, de 04.10.2004, del Ministerio de Transportes y Telecomunicaciones, se invalida la resoluci&#xF3;n exenta N&#xBA; 444 de 02.04.2004, del Ministerio de Transportes y Telecomunicaciones, publicada en extracto en el Diario Oficial del 22.04.2004, que declara desierta la comuna de Lampa, en el concurso p&#xFA;blico de radiodifusi&#xF3;n sonora en m&#xED;nima cobertura, correspondiente al tercer cuatrimestre de 2002.</div><br></div>", "i": 6501432}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Subsecretar&#xED;a de Telecomunicaciones.</div><br></div>", "i": 6501433}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1304 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1304 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TELECOMUNICACIONES"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.304 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-04", "doble_articulado": false, "id_norma": "231496", "numero_fuente": "37989", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-10-19", "vigencias": [{"desde": "2004-10-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-10-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-10-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url