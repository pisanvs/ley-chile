{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 374, DE 1990 </div></div>", "i": 7269929}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 374 de 28 de diciembre de 1990 se ha aprobado, al Colegio de Los Sagrados Corazones, de Talcahuano, un plan especial de estudio para ser aplicado simult&#xE1;neamente de 1&#xB0; a 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, a partir del a&#xF1;o escolar de 1991.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas para algunas asignaturas del presente plan de estudio.</div><br></div>", "i": 7269930}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de Abril de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7269931}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "374 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-374 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 374, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-28", "doble_articulado": false, "id_norma": "168974", "numero_fuente": "33953", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-26", "vigencias": [{"desde": "1991-04-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-04-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-04-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificaci