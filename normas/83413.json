{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 2901 DE 1989. </div></div>", "i": 6065291}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta No. 2.901 de fecha 09 de noviembre de 1989 de la Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica, se aprob&#xF3; el siguiente plan y programas de estudio de la carrera y t&#xED;tulo t&#xE9;cnico que se indica, del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Superior de Educaci&#xF3;n, Ciencia y Cultura Gabriela Mistral de Iquique, para impartirse a contar del a&#xF1;o 1989: Carrera: Turismo y Hoteler&#xED;a</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico en Turismo y Hoteler&#xED;a </div></div>", "i": 6065292}, {"t": "<div><div class=\"p\">Santiago, 09 de Marzo de 1990.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6065293}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2901 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2901 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 2901 DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-11-09", "doble_articulado": false, "id_norma": "83413", "numero_fuente": "33655", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-04-26", "vigencias": [{"desde": "1990-04-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-04-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-04-26", "fin_vigencia": "", "tipo_version": "3"}], "ev