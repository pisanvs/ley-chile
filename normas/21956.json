{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Cr&#xE9;ditos con los Bancos Lei n&#xFA;m. 88.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946718}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza al Presidente de la Rep&#xFA;blica para mantener, por lo que resta del presente a&#xF1;o, cr&#xE9;ditos con los Bancos que no excedan de dos millones quinientos mil pesos ($ 2.500,000). El interes no ser&#xE1; superior al seis por ciento anual.</div><br><br></div>", "i": 5946719}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 28 de Agosto de 1893.- JORJE MONTT.- Alejandro Vial.</div><br></div>", "i": 5946720}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "88", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-88"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CREDITOS CON LOS BANCOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BANCOS", "CREDITOS", "MANTENCION", "PRESIDENTE REPUBLICA", "FACULTAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-08-28", "doble_articulado": false, "id_norma": "21956", "numero_fuente": "4606", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-08-28", "vigencias": [{"desde": "1893-08-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-08-28", "fin_vigencia": ""}, "vigencias_versi