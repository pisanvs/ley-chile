{"html": [{"t": "<div><br><div class=\"p\">SOLICITA CONSTITUCI&#xD3;N LEGAL DE PARTIDO IGUALDAD EN REGIONES QUE INDICA</div></div>", "i": 9262790}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lautaro Guanca Vallejos, Presidente de la Directiva Central del Partido Igualdad, ha solicitado la constituci&#xF3;n legal del partido en las Regiones IV de Coquimbo y Metropolitana de Santiago. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de mil quinientas dos (1.502) y catorce mil novecientas noventa y cinco (14.995) afiliaciones, respectivamente.</div><br><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la ley N&#xB0; 18.603, por resoluci&#xF3;n O-N&#xB0;1.053 de fecha 25 de mayo de 2012.- </div></div>", "i": 9262791}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div></div>", "i": 9262792}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1053", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1053"}, {"tipo": "3", "numero": "O-1053", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-1053"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCIÓN LEGAL DE PARTIDO IGUALDAD EN REGIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-25", "doble_articulado": false, "id_norma": "1040698", "numero_fuente": "40277", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-02", "vigencias": [{"desde": "2012-06-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"i