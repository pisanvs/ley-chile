{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297295}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.422, de 05 de Octubre de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la letra b) del numeral 1&#xB0; de la Resoluci&#xF3;n N&#xB0; 800, de 1995, en cuanto caduc&#xF3; la Resoluci&#xF3;n N&#xB0; 210, de 1986, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; a don JUAN ALBERTO CARRIZO URBINA, R.U.T. N&#xB0; 2.379.923-5, para operar las naves &quot;Do&#xF1;a Aurora&quot; y &quot;Aurora Patricia&quot;, por haberse acreditado el pago de la patente pesquera. </div></div>", "i": 8297296}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 05 de Octubre de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297297}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1422", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1422"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUAN ALBERTO CARRIZO URBINA", "PESCA", "CADUCIDAD", "REVOCACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-10-05", "doble_articulado": false, "id_norma": "36938", "numero_fuente": "35304", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-10-30", "vigencias": [{"desde": "1995-10-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-10-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-10-30", "fin_vigenci