{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 7270264}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.477, de 05 de noviembre de 1987, del Ministerio de Transportes y Telecomunicaciones, Subsecretaria de Transportes se renueva la concesi&#xF3;n otorgada a la Empresa de Transportes Bus Norte, Osvaldo Cid y Compa&#xF1;&#xED;a, por resoluci&#xF3;n N&#xB0; 460/82, del Ministerio de Transportes y Telecomunicaciones, Subsecretaria de Transportes, para efectuar servicio internacional de transporte terrestre de pasajeros entre Valdivia (Chile) y San Carlos de Bariloche (Argentina), por Paso Puyehue, efectuando dos frecuencias semanales.</div><br></div>", "i": 7270265}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de Noviembre de 1987.- Carlos Villegas Lorca, Subsecretario de Transportes subrogante. </div></div>", "i": 7270266}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1477 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1477 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-05", "doble_articulado": false, "id_norma": "169436", "numero_fuente": "32929", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-25", "vigencias": [{"desde": "1987-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-25", "fin_vigencia": ""}, "vigencias_ver