{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6176682}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 63, de fecha 08 de Enero de 1988, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a don Luis Felipe Mar&#xED;n Mar&#xED;n, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6176683}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de Enero de 1988.- Ramiro Camero Weir, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana, Subrogante. </div></div>", "i": 6176684}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "63 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-63 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-08", "doble_articulado": false, "id_norma": "138844", "numero_fuente": "33006", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-26", "vigencias": [{"desde": "1988-02-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-02-26", "fin_vigencia": "", "tipo_vers