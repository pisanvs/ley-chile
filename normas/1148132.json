{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 2.762 EXENTA, DE 26.06.2020</div></div>", "i": 10148174}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por la presente, se ha modificado, a contar del a&#xF1;o escolar 2020, la <a href=\"https://www.leychile.cl/Navegar?idNorma=287896&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 9.124, de 2008, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; planes y programas especiales de estudio de 1&#xB0; a 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media, al establecimiento educacional Colegio Suizo de Santiago, RBD 9216-9, comuna de &#xD1;u&#xF1;oa, Regi&#xF3;n Metropolitana, en el sentido de sustituir el plan de estudio de 1&#xB0; a 3&#xB0; a&#xF1;o de Educaci&#xF3;n Media.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10148175}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jorge Poblete Aedo, Subsecretario de Educaci&#xF3;n.</div><div class=\"p\"> </div><br></div>", "i": 10148176}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2762 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2762 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 2.762 EXENTA, DE 26.06.2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1794496", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-06-26", "doble_articulado": false, "id_norma": "1148132", "numero_fuente": "42724", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-08-06", "vigencias": [{"desde": "2020-08-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"