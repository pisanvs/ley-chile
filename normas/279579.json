{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6662060}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 918, de 16 de septiembre</div><div class=\"p\">de 2008, y en base a la facultad otorgada por el</div><div class=\"p\">art&#xED;culo 105 del D.F.L. MOP N&#xBA; 850 de 1997, que fij&#xF3; el texto actualizado de la Ley N&#xBA; 15.840, se expropi&#xF3; el lote de terreno N&#xBA; 2, para la obra &quot;Mejoramiento Ruta C-495, Sector Alto del Carmen - Conay, Km. 0,000 - Km. 19,500, Provincia de Huasco, III Regi&#xF3;n, Etapa IV&quot;, que figura a nombre de ESPINOZA ABEL BENJAMIN, rol de aval&#xFA;o 881-19, superficie 333 M2. La Comisi&#xF3;n de Peritos, fij&#xF3; con fecha 8 de enero de 2006, en la cantidad de $3.488.750. La indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto Ley N&#xBA; 2186, de 1978.</div><br></div>", "i": 6662061}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6662062}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "918 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-918 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-09-16", "doble_articulado": false, "id_norma": "279579", "numero_fuente": "39188", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-10-15", "vigencias": [{"desde": "2008-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia