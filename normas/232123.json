{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6503627}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.983, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de la resoluci&#xF3;n N&#xBA; 3.555 de 2003, modificada mediante resoluciones N&#xBA; 1.494 y N&#xBA; 1.750, ambas de 2004, todas de esta Subsecretar&#xED;a que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO, para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto denominado &quot;Pesca de Investigaci&#xF3;n de Merluza del sur en la Regi&#xF3;n de Magallanes-Fase III, 2004&quot;, en el sentido de se&#xF1;alar que las actividades de investigaci&#xF3;n correspondiente al mes de noviembre se realizar&#xE1;n entre el 4 y el 30 de dicho mes, ambas fechas inclusive.</div><br></div>", "i": 6503628}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de octubre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6503629}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2983 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2983 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-10-20", "fecha_derogacion": "2004-11-11", "doble_articulado": false, "id_norma": "232123", "numero_fuente": "38002", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-11-04", "vigencias": [{"desde": "2004-11-11", "hasta": "", "tipo_version": "2", "tipo