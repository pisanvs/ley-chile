{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6267941}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 267 del 22 de Noviembre de 1984, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se autoriza la Incorporaci&#xF3;n,a la L&#xED;nea 2 &quot;A&quot; desde &quot;La Florida a Terminal Las CoIines&quot;, autorizada a la Asociaci&#xF3;n Gremial de Empresarios de Taxis Colectivos &quot;La Paloma&quot; de Talca, por resoluci&#xF3;n N&#xB0; 243 del 5 de Noviembre de 1984, las siguientes personas:</div><div class=\"p\">&nbsp; &nbsp;  Viviana Vald&#xE9;s Garc&#xED;a - Jos&#xE9; Patricio Palma - Ricardo F&#xE9;lix Avenda&#xF1;o Mu&#xF1;oz - Jaime Mu&#xF1;oz Cerda - Ver&#xF3;nica Herminia Vald&#xE9;s - Juan de Dios Astudillo Torres.-</div><br></div>", "i": 6267942}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Manuel Coloma Amaro, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n del Maule.</div><br></div>", "i": 6267943}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "267 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-267 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-11-22", "doble_articulado": false, "id_norma": "166422", "numero_fuente": "32083", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-01-29", "vigencias": [{"desde