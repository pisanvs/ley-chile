{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6546270}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 960 de fecha 29 de septiembre del 2005, se expropiaron los lotes de terreno N&#xBA;s. 1, 2 y 8 superficies 921, 2.102, 1.268 m2, respectivamente, rol N&#xBA; 608-24, comuna de San Ignacio, VIII Regi&#xF3;n para la obra &quot;Proyecto Laja Diguill&#xED;n, Canal Matriz Diguill&#xED;n Larqui, Camino de Acceso a Puente Km.</div><div class=\"p\">11,080, (lote N&#xBA;1) y Canal Alimentador N&#xBA;6, Km. 0,008 al Km. 0,705 (lotes N&#xBA;s. 2 y 8)&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Tulio Ram&#xF3;n Cartes Aedo, ascendente a las cantidades de $921.117.- para el lote N&#xBA; 1, $1.813.753.- para el lote N&#xBA;2 y $1.158.507; para el lote N&#xBA;8.</div><br></div>", "i": 6546271}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6546272}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "960 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-960 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-29", "doble_articulado": false, "id_norma": "243429", "numero_fuente": "38301", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-11-02", "vigencias": [{"desde": "2005-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-11-0