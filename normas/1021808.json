{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9094069}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.929, de 28 de diciembre de 2010, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto las <a href=\"https://www.leychile.cl/Navegar?idNorma=1019709&amp;idParte=0&amp;idVersion=\">resoluciones exentas N&#xBA; 3.468</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1019710&amp;idParte=0&amp;idVersion=\">N&#xBA; 3.469</a>, ambas de 2010, de esta Subsecretar&#xED;a, que distribuyen la fracci&#xF3;n artesanal de las pesquer&#xED;as de Anchoveta y Sardina com&#xFA;n sometidas al R&#xE9;gimen Artesanal de Extracci&#xF3;n por unidad de asignaci&#xF3;n organizaciones de pescadores artesanales en la V y VIII Regiones, respectivamente, en virtud de lo expuesto en la parte considerativa de la presente resoluci&#xF3;n y lo dispuesto en el art&#xED;culo 61 de la ley N&#xBA; 19.880.</div><br></div>", "i": 9094070, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de diciembre de 2010.- Felipe Palacio Rives, Subsecretario de Pesca (S).</div></div>", "i": 9094071}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3929 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3929 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-28", "doble_articulado": false, "id_norma": "1021808", "numero_fuente": "39851", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-01-05", "vigencias": [{"des