{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9497176}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA; 544, de 15 de abril de 2014, se modific&#xF3; el numeral segundo del <a href=\"https://www.leychile.cl/Navegar?idNorma=1021042&amp;idParte=0&amp;idVersion=\">Decreto MOP. (Exento) N&#xBA; 2791, de 17 de noviembre de 2010</a>, a fin de individualizar correctamente el lote de terreno N&#xBA; 7, ubicado en la comuna de Ovalle, que figura a nombre de MARIN SAMUEL ROJO Y CIA LTDA, rol de aval&#xFA;o 174-55, superficie 3.995 m2., complementando el informe de tasaci&#xF3;n referido al lote N&#xBA; 7, emitido por la Comisi&#xF3;n de Peritos el 18 de agosto de 2010, mediante acta emanada de la misma comisi&#xF3;n de 09 de enero de 2014, expropiado con motivo de la obra: &quot;Habilitaci&#xF3;n Costanera R&#xED;o Limar&#xED;, Ovalle&quot;, Comuna de Ovalle, Provincia de Limar&#xED;, IV Regi&#xF3;n de Coquimbo.</div></div>", "i": 9497177}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9497178}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "544 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-544 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-04-15", "doble_articulado": false, "id_norma": "1065432", "numero_fuente": "40934", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-08-16", "vigencias": [{"desde": "2014-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni