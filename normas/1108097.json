{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO</div></div>", "i": 9834350}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (Exento) N&#xBA;996 de 29 de agosto de 2017, se modific&#xF3; el numeral segundo del <a href=\"https://www.leychile.cl/Navegar?idNorma=1056747&amp;idParte=0&amp;idVersion=\">Decreto MOP (Exento) N&#xBA;1.971 de 18 de noviembre de 2013</a>, que orden&#xF3; la expropiaci&#xF3;n, entre otros, del Lote N&#xBA;143, en la parte que se refiere al nombre del propietario y rol de aval&#xFA;o, seg&#xFA;n certificado de aval&#xFA;o emitido por el Servicio de Impuestos Internos, quedando como a continuaci&#xF3;n se indica: LOTE 143, INVERSIONES LA OBRA S.A., superficie 1484,98 m2., rol de aval&#xFA;o 10500-1, Comuna de Talca. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA; 2.186, de 1978. </div></div>", "i": 9834351}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "996 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-996 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1272385", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-08-29", "doble_articulado": false, "id_norma": "1108097", "numero_fuente": "41861", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-09-15", "vigencias": [{"desde": "2017-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-09-15", "fin_vigencia": ""}, "v