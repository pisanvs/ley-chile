{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO RECEPTORES JUDICIALES A FUNCIONARIOS QUE INDICA</div><br><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 57.- Santiago, 24 de Julio de 1986.- Vistos: Lo dispuesto en el art&#xED;culo 11 del Decreto Ley No.</div><div class=\"p\">2.974, de 1979,</div><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 6229593}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Receptores Judiciales para que permanentemente practiquen las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del Decreto Ley citado, en la VI Regi&#xF3;n, a los se&#xF1;ores:</div><br><div class=\"p\">&nbsp; &nbsp;  -Jaime Salinas Lizama.</div><div class=\"p\">&nbsp; &nbsp;  - Pedro Zuloaga Urra.</div><br></div>", "i": 6229594}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Sergio Retamal Iglesias, Vicepresidente Ejecutivo (S).</div><br></div>", "i": 6229595}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "57", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-57"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO RECEPTORES JUDICIALES A FUNCIONARIOS QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-07-24", "doble_articulado": false, "id_norma": "154640", "numero_fuente": "32544", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-08-09", "vigencias": [{"desde":