{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.119 EXENTO, DE 1997 </div></div>", "i": 6061935}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto exento N&#xBA; 1.119 de fecha 29 de octubre de 1997 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Osorno, las modificaciones introducidas al plan y programas de estudio de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica para ser impartida a contar del a&#xF1;o 1998 en la Casa Central de Osorno y Sede N&#xBA; 1 de Temuco, con la siguiente denominaci&#xF3;n:</div><br><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp;  : Computaci&#xF3;n</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; &nbsp; &nbsp; : T&#xE9;cnico de Nivel Superior en Computaci&#xF3;n.</div><br></div>", "i": 6061936}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de noviembre de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6061937}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1119 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1119 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.119 EXENTO, DE 1997", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "CENTRO DE FORMACION TECNICA OSORNO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-10-29", "fecha_derogacion": "2015-06-25", "doble_articulado": false, "id_norma": "82311", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-12-10", "vigencias": [{"desde": "2015-06-25", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última V