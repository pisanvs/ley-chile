{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6338632}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 489, de 31 de agosto de 1995, se orden&#xF3; la expropiaci&#xF3;n y aprob&#xF3; el plano y cuadro de expropiaci&#xF3;n del lote de terreno N&#xBA; 1, y por decreto MOP N&#xBA; 708, de 30 de abril de 2001, se autoriz&#xF3; el valor de la consignaci&#xF3;n provisional de la expropiaci&#xF3;n por la v&#xED;a judicial, en la cantidad de $1.000.000.- necesario para la ejecuci&#xF3;n de la obra &quot;Camino Calleuque-Palmilla Rol I-340, Sector Puente Los Maquis, Km. 3.900 a Km.</div><div class=\"p\">4.223&quot;, el pago de la indemnizaci&#xF3;n se efectuar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2186, de 1978.</div><br></div>", "i": 6338633}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6338634}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "489", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-489"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-08-31", "doble_articulado": false, "id_norma": "186399", "numero_fuente": "36987", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-06-15", "vigencias": [{"desde": "2001-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-06-15", "fin_vi