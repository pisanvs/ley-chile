{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.991 EXENTO, DE 2006 </div></div>", "i": 6603013}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.991 de fecha 4 de diciembre de 2006 del Ministerio de Educaci&#xF3;n, se aprueban las adecuaciones al plan y programas de estudio de la carrera Laboratorista Dental del Centro de Formaci&#xF3;n T&#xE9;cnica Los Leones, que se encuentran anexas y forman parte del presente decreto. Modif&#xED;case, en consecuencia, la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 3.076 del 20 de noviembre de 1984, en el sentido de incorporar dichas adecuaciones.</div><br><div class=\"p\">&nbsp; &nbsp;  Las adecuaciones que se aprueban mediante este decreto, podr&#xE1;n aplicarse a contar del a&#xF1;o 2007. </div></div>", "i": 6603014}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de febrero de 2007.- Pilar Romaguera Gracia, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 6603015}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1991 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1991 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.991 EXENTO, DE 2006", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2006-12-04", "fecha_derogacion": "2017-09-30", "doble_articulado": false, "id_norma": "258815", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2007-03-05", "vigencias": [{"desde": "2017-09-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2007-03-05", "hasta": "2017-09-29", "tipo_version": "0", "tipo_version_s": "Texto Origina