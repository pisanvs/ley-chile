{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6047495}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. N&#xBA; 782, de 29 de agosto de 1997, se expropiaron los lotes de terrenos N&#xBA;s. 124-A y 125, superficies 1.403 y 7.757 m2., rol de aval&#xFA;o 128-78, comuna de El Carmen, para la obra Proyecto Laja Diguill&#xED;n, Faja de Expropiaci&#xF3;n Canal Matriz, sector Pemuco Diguill&#xED;n y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Juan de Dios V&#xE1;squez Salazar y Mar&#xED;a Mercedes V&#xE1;squez Salazar, ascendentes a las cantidades de $392.428 y $1.763.037, respectivamente.-</div><br></div>", "i": 6047496}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6047497}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "782", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-782"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "EL CARMEN", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-08-29", "doble_articulado": false, "id_norma": "76345", "numero_fuente": "35891", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-10-15", "vigencias": [{"desde": "1997-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-10-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "GMR", "fecha_ingreso": "1997-10-29", "