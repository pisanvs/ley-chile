{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292819}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n n&#xFA;mero 505, de 24 de Mayo de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por un a&#xF1;o a contar del 23 de marzo de 1994, el plazo otorgado a EMPRESA NACIONAL DE PESCA S.A., R.U.T. N&#xB0; 96.540.500-3, en orden a iniciar actividades pesqueras extractivas con la nave &quot;Don Francisco I&quot;, autorizada mediante la Resoluci&#xF3;n N&#xB0; 182, de 1992, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor.</div><br><br></div>", "i": 8292820}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 24 de Mayo de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292821}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "505", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-505"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PLAZO", "PRORROGA", "EMPRESA NACIONAL PESCA S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-05-24", "doble_articulado": false, "id_norma": "34976", "numero_fuente": "34885", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-06-09", "vigencias": [{"desde": "1994-06-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-06-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-06-09", "fin_vigenci