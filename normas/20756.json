{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 236, DE 1990 </div></div>", "i": 5943016}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 236 de 26 de septiembre de 1990 se ha aprobado, a contar del a&#xF1;o escolar 1991, al Colegio Anglo Franc&#xE9;s de la comuna de Quilpu&#xE9;, provincia de Valpara&#xED;so, V Regi&#xF3;n de Valpara&#xED;so, un plan de estudio para el 1er. y 2do, ciclo de Educaci&#xF3;n General B&#xE1;sica, el que se aplicar&#xE1; en todos los cursos simult&#xE1;neamente.</div><br></div>", "i": 5943017}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 17 de Octubre de 1990.- Gast&#xF3;n Gilbert Baettig, Subsecretario de Educaci&#xF3;n subrogante. </div></div>", "i": 5943018}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "236", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-236"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 236, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO ANGLO FRANCES", "QUILPUE", "PLAN ESTUDIO", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-09-26", "doble_articulado": false, "id_norma": "20756", "numero_fuente": "33978", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-05-28", "vigencias": [{"desde": "1991-05-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-05-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-05-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1991-05-28