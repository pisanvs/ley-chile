{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293101}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 553 de 23 de Julio de 1993 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case la Resoluci&#xF3;n N&#xB0; 465, de 1992, de esta Subsecretar&#xED;a, que autoriz&#xF3; a ALIMENTOS MULTIEXPORT S.A., R.U.T. N&#xB0; 96.513.230-9, para ampliar actividades pesqueras de transformaci&#xF3;n, en el sentido de incluir en el numeral 2&#xB0;, en la l&#xED;nea de proceso de Ahumado, deshidratado, seco-salado y marinado de la planta ubicada en Puerto Montt, Cardonal N&#xB0; 2501, los recursos hidrobiol&#xF3;gicos se&#xF1;alados en el numeral 3&#xB0; de la Resoluci&#xF3;n N&#xB0; 432, de 1987, de esta Subsecretar&#xED;a. </div></div>", "i": 8293102, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 23 de Julio de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8293103}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "553", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-553"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "ALIMENTOS MULTIEXPORT S.A.", "AMPLIACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-07-23", "doble_articulado": false, "id_norma": "35096", "numero_fuente": "34641", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-08-14", "vigencias": [{"desde": "1993-08-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_v