{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6071930}, {"t": "<div><div class=\"p\">El Banco Central de Chile, en conformidad con lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1 del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de julio de 1992, fue de 4,93% anual.</div><br></div>", "i": 6071931}, {"t": "<div><div class=\"p\">Santiago, 22 de julio de 1992.- V&#xED;ctor Vial del R&#xED;o, Secretario General.</div><br></div>", "i": 6071932}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-07-22", "doble_articulado": false, "id_norma": "86009", "numero_fuente": "34323", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-07-23", "vigencias": [{"desde": "1992-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-07-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-07-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PGA", "fecha_ingreso": "1998-01-21", "fecha_version": "1992-07-23", "fecha_actualizacion_texto": "1992-07-23", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6071930}, {"n": "Artículo", "i": 6071931, "t": 6}, {"n": "Promulgación", "i": 607