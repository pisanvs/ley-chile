{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8314967}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 579, de 18 de Abril de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n No. 60, de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Pesquera Messamar S.A., R.U.T. No. 96.553.210-2, domiciliada en Santiago, para iniciar actividades pesqueras de transformaci&#xF3;n, en el sentido de incorporar en el numeral 2&#xB0; de la mencionada resoluci&#xF3;n el recurso navaja en el proceso de elaboraci&#xF3;n de conserva de la planta autorizada en Ancud.</div><br></div>", "i": 8314968}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 18 de Abril de 1990.- Andr&#xE9;s Couve Rioseco Subsecretario de Pesca.</div><br></div>", "i": 8314969}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "579", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-579"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-04-18", "doble_articulado": false, "id_norma": "83346", "numero_fuente": "33653", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-04-24", "vigencias": [{"desde": "1990-04-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-04-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-04-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient