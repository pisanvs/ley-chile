{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; APRUEBA REFORMA DE ESTATUTOS DE &quot;AETNA CHILE SEGUROS DE VIDA S.A.&quot; </div></div>", "i": 6005150}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Certifico: Que por resoluci&#xF3;n N&#xB0; 73 de fecha 19 de Abril de 1995 se aprob&#xF3; reforma de estatutos de la sociedad an&#xF3;nima &quot;Aetna Chile Seguros de Vida S.A.&quot;, que consta en escritura p&#xFA;blica de fecha 30 de Marzo de 1995, otorgada en la Notar&#xED;a de Santiago de don Ra&#xFA;l Undurraga Laso.</div><div class=\"p\">&nbsp; &nbsp; La reforma consiste en: Disminuir de 8 a 7 el n&#xFA;mero de miembros del directorio.</div><br></div>", "i": 6005151}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 19 de Abril de 1995.- Rodrigo Costa Aranda, Secretario General.</div><br></div>", "i": 6005152}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "73", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-73"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "APRUEBA REFORMA DE ESTATUTOS DE AETNA CHILE SEGUROS DE VIDA S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AETNA CHILE SEGUROS VIDA S.A.", "REFORMA ESTATUTARIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-04-19", "doble_articulado": false, "id_norma": "32844", "numero_fuente": "35157", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-05-03", "vigencias": [{"desde": "1995-05-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-05-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-05-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci