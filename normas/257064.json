{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6595932}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.571, de 28 de diciembre de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA SUR AUSTRAL S.A. para realizar operaciones pesqueras a contar del 1 de enero del a&#xF1;o 2007 y hasta el 31 de diciembre del mismo a&#xF1;o, ambas fechas inclusive, con la nave f&#xE1;brica denominada &quot;Ocean Dawn&quot;, en aguas exteriores, por fuera de las l&#xED;neas de base recta, entre los paralelos 47&#xB0; L.S. y 57&#xB0; L.S., respecto de los recursos y con las obligaciones establecidas en las respectivas autorizaciones.</div><br></div>", "i": 6595933}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de diciembre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6595934}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3571 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3571 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-12-28", "doble_articulado": false, "id_norma": "257064", "numero_fuente": "38655", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-01-05", "vigencias": [{"desde": "2007-01-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-01-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-01-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendien