{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 158, DE 1990 </div></div>", "i": 7217530}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 158 de 31 de mayo de 1990 se ha procedido a modificar el decreto supremo exento de Educaci&#xF3;n No. 233 de 1982 que aprob&#xF3; plan especial de estudio para la Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica al Colegio de los Sagrados Corazones de Santiago (actual Fundaci&#xF3;n Educacional Colegio de los Sagrados Corazones Alameda) en el sentido de reemplazar a contar del a&#xF1;o 1990 el Plan Diferenciado Human&#xED;stico, de 3&#xB0; y 4&#xB0; a&#xF1;o medio. </div></div>", "i": 7217531}, {"t": "<div><div class=\"p\">Santiago, 16 de Julio de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7217532}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "158 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-158 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº 158  DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-05-31", "doble_articulado": false, "id_norma": "82561", "numero_fuente": "33734", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-08-01", "vigencias": [{"desde": "1990-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones