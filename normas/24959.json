{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dad su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br><br></div>", "i": 7170028}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Se autoriza al Presidente de la Rep&#xFA;blica para traspasar al &#xED;tem E. 1106, Ley 4,600, Sider&#xFA;rgica, Partida XI, Leyes Especiales, Segunda Parte del Presupuesto Extraordinario, la suma de un mill&#xF3;n quinientos mil pesos ($ 1.500,000), al &#xED;tem E. 0101 1) Aysen, Partida 1, Direcci&#xF3;n General de Obras P&#xFA;blicas, Primera Parte del mismo Presupuesto.</div><br></div>", "i": 7170029}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y, por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, dieciseis de Septiembre de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Edecio Torreblanca. </div></div>", "i": 7170030}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4892", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4892"}], "organismos": ["MINISTERIO DE LA PROPIEDAD AUSTRAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O", "1930", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-09-16", "doble_articulado": false, "id_norma": "24959", "numero_fuente": "15776", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-09-16", "vigencias": [{"desde": "1930-09-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1930-09-16