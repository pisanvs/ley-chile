{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6743514}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xB0;373, de 30 de mayo de 1996, se expropiaron los lotes de terreno N&#xB0;s. 11, 15 y 14, superficies 56, 40 y 105 m2, respectivamente, roles de aval&#xFA;o en tr&#xE1;mite y 2214, comuna de Rengo, para la obra Camino Ruta H-65, sector Rengo-Popeta, y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Jos&#xE9; Rodolfo Conejera Orellana y Haroldo Enrique Conejera Arenas, ascendente a las cantidades de $501.959.para los lotes 11 y 15 y $ 348.008.para el lote N&#xB0; 14. </div></div>", "i": 6743515}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6743516}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "373", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-373"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-30", "doble_articulado": false, "id_norma": "224195", "numero_fuente": "35516", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-07-15", "vigencias": [{"desde": "1996-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2004-04-23", "fecha_version": "1996-07-15", "fecha_actualizacion_texto": "1996-07-15", "ti