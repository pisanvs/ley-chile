{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6306819}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;4.003, de 31 de agosto de 2000, se expropi&#xF3; el lote de terreno N&#xBA;6, superficie 386 m2., rol de aval&#xFA;o 189-108, comuna de Longav&#xED;, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo Talca - Chill&#xE1;n.</div><div class=\"p\">S&#xE9;ptima Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Manuel Jes&#xFA;s Ulloa Morales, ascendente a la cantidad de $7.484.648.-</div><br></div>", "i": 6306820}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6306821}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "4003", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-4003"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-08-31", "doble_articulado": false, "id_norma": "177226", "numero_fuente": "36802", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-11-02", "vigencias": [{"desde": "2000-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2000-11-02", "fecha_version": "2000-11-02", "fecha_actualizacion_texto": "2000-11-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura":