{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6535516}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.408 de esta Subsecretar&#xED;a, prorr&#xF3;gase hasta el 14 de agosto de 2005 el per&#xED;odo de extracci&#xF3;n del recurso Loco Concholepas concholepas desde las &#xE1;reas de manejo establecidas entre la VII y XI regiones que, contando con una cuota de extracci&#xF3;n autorizada para el recurso indicado, no hubiere sido extra&#xED;da en su totalidad al 31 de julio del presente, quedando sometido en lo dem&#xE1;s a las disposiciones establecidas en las resoluciones que autorizaron la extracci&#xF3;n.</div><br></div>", "i": 6535517}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de agosto de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6535518}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2408 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2408 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-08-01", "doble_articulado": false, "id_norma": "240813", "numero_fuente": "38228", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-08-04", "vigencias": [{"desde": "2005-08-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-08-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-08-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [