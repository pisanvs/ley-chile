{"html": [{"t": "<div><div class=\"p\">DISPONE EXPROPIACION PARCIAL DE INMUEBLE QUE SE&#xD1;ALA </div></div>", "i": 6423616}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Decreto alcaldicio N&#xBA; 409, 6 de mayo de 2003, el Alcalde de Cabildo dispone la expropiaci&#xF3;n parcial de acuerdo al D.S. 458/76 del Ministerio de Vivienda y Urbanismo, el D.L. 2.186/78, del inmueble ubicado en Bellavista N&#xBA; 445, Rol 75-12, Comuna de Cabildo, dominio Sucesi&#xF3;n Alvarez Ramos, inscrita Fjs. 2.714 N&#xBA; 1.457 a&#xF1;o 89, Conservador La Ligua, &#xE1;rea 10 mts por 35 mts, en cumplimiento del Plan Regulador. Dispone Comisi&#xF3;n Tasadora, para fijar monto provisional de la indemnizaci&#xF3;n.-</div><br></div>", "i": 6423617}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Eduardo Cerda Lecaros, Alcalde Cabildo.</div><br></div>", "i": 6423618}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "409", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-409"}], "organismos": ["MUNICIPALIDAD DE CABILDO"], "titulo_norma": "DISPONE EXPROPIACION PARCIAL DE INMUEBLE QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-05-06", "doble_articulado": false, "id_norma": "210226", "numero_fuente": "37559", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-05-15", "vigencias": [{"desde": "2003-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url