{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8934094}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.804, de 9 junio de 2010, de esta Subsecretar&#xED;a, rectif&#xED;case el numeral 4.- de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1014593&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.671, de 2010</a>, de esta Subsecretar&#xED;a, que autoriz&#xF3; a CONSULTORES PESQUEROS MARACTIVO LTDA. para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Monitoreo de la actividad extractiva artesanal de Anchoveta (Engraulis ringens) y Sardina com&#xFA;n (Strangomera bentincki) en la Regi&#xF3;n de Los R&#xED;os, 2010&quot;, en el sentido de indicar que la embarcaci&#xF3;n artesanal &quot;Jos&#xE9; Luis&quot; (RPA 8180), se encuentra inscrita en el Registro Pesquero Artesanal de la X Regi&#xF3;n, y no como all&#xED; se indica.</div><br><br></div>", "i": 8934095, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de junio de 2010.- Edith Saa Collantes, Susecretaria de Pesca (S).</div><br></div>", "i": 8934096}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1804 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1804 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-06-09", "doble_articulado": false, "id_norma": "1014551", "numero_fuente": "39686", "tipo_version": "3", "tipo_version_s"