{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6020932}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n Exenta N&#xB0; 137 del 1&#xB0; de Diciembre de 1992, se adjudica a Alberto Barroso Ar&#xE1;nguiz la concesi&#xF3;n para operar, hasta el 14 de Febrero de 1995, un establecimiento ubicado en calle Diego Portales 9144 comuna de Melipilla, destinado a la revisi&#xF3;n t&#xE9;cnica de autom&#xF3;viles, station wagons, motocicletas, veh&#xED;culos de carga de menos de 1750 kg. de capacidad de carga &#xFA;til y sus remolques, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.</div><br></div>", "i": 6020933}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Juan Fuentes Isla, Secretario Regional Ministerial Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana, Subrogante.</div><br></div>", "i": 6020934}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "137", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-137"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANTA REVISION TECNICA", "VEHICULOS MOTORIZADOS", "REVISION TECNICA", "MELIPILLA", "REGION METROPOLITANA", "ALBERTO BARROSO ARANGUIZ"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-12-01", "doble_articulado": false, "id_norma": "38414", "numero_fuente": "34494", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-02-17", "vigencias": [{"desde": "1993-02-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-02-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-02-17