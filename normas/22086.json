{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SUPLEMENTO Lei n&#xFA;m. 230.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947230}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de tres mil pesos ($ 3,000) al &#xED;tem 24 de la partida 55 del presupuesto de Instruccion P&#xFA;blica, para gastos jenerales de reparaciones de la Escuela Normal de Preceptoras del Sur, mobiliario i material de ense&#xF1;anza, libros i &#xFA;tiles de dibujo i caligraf&#xED;a.</div><br><br></div>", "i": 5947231}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 26 de Diciembre de 1894.- JORJE MONTT.-</div><div class=\"p\">O. Renjifo.</div><br></div>", "i": 5947232}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "230", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-230"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1894", "MODIFICACION", "MINISTERIO", "INSTRUCCION PUBLICA", "ESCUELA NORMAL PRECEPTORAS SUR", "REPARACIONES", "MOBILIARIO", "MATERIALES", "ADQUISICION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-12-26", "doble_articulado": false, "id_norma": "22086", "numero_fuente": "4998", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-12-26", "vigencias": [{