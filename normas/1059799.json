{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N&nbsp; N&#xBA; 709 EXENTA, DE 2014</div></div>", "i": 9409506}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA;709, de 11 de febrero de 2014, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad Beyond Capacitaci&#xF3;n Limitada. (Beyond Capacitaci&#xF3;n Ltda.)&quot;, RUT 76.145.393-9, contenida en la resoluci&#xF3;n exenta N&#xBA; 8.152 de 8 de septiembre de 2011, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.</div></div>", "i": 9409507}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (S).</div></div>", "i": 9409508}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "709 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-709 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 709 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-02-11", "doble_articulado": false, "id_norma": "1059799", "numero_fuente": "40795", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-02-28", "vigencias": [{"desde": "2014-02-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-02-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014-02-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci