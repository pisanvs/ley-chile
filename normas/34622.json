{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292255}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 399, de 26 de Abril de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case la Resoluci&#xF3;n N&#xB0; 1.393, de 1992, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA LOA SUR S.A., R.U.T. N&#xB0; 95.059.000-9, para operar la nave &quot;Loa 25&quot;, Matr&#xED;cula 2817 de Valpara&#xED;so, en el sentido de se&#xF1;alar que las actuales caracter&#xED;sticas n&#xE1;uticas de dicha nave son las siguientes:</div><br><br><div class=\"p\"> Nombre&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  :&nbsp; &quot;Loa 25&quot;</div><div class=\"p\"> Eslora total&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  :&nbsp; 55,20 m.</div><div class=\"p\"> T.R.G.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  :&nbsp; 650</div><div class=\"p\"> Capacidad de bodega&nbsp; &nbsp; &nbsp; :&nbsp; 844,73 m3</div><div class=\"p\"> Artes de pesca&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  :&nbsp; Cerco.</div><br></div>", "i": 8292256}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 26 de Abril de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292257}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "399", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-399"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESQUERA LOA SUR S.A.", "MODIFICACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fe