{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8306304}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.203, de 28 de agosto de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad parcial de la Resoluci&#xF3;n N&#xBA; 1.721, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA BAHIA INGLESA S.A., para realizar actividades pesqueras con la nave &quot;Javier&quot;, s&#xF3;lo en lo relativo al litoral comprendido entre la III y IV Regiones, respecto de las especies que a continuaci&#xF3;n se indican, en virtud de lo dispuesto en el art&#xED;culo 143&#xBA;, letra b), de la ley N&#xBA; 18.892 de 1989 y sus modificaciones: Agujilla, Anchoveta, Jurel, Machuelo y Sardina espa&#xF1;ola. </div></div>", "i": 8306305}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de agosto de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8306306}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1203", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1203"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA BAHIA INGLESA S.A.", "PESCA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-08-28", "fecha_derogacion": "2002-01-16", "doble_articulado": false, "id_norma": "75537", "numero_fuente": "35860", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-09-05", "vigencias": [{"desde": "2002-01-16", "hasta": "", "tipo_version": "2