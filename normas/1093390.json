{"html": [{"t": "<div><div class=\"p\">Organizacion del Ej&#xE9;rcito</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago i Setiembre 9 de 1814.</div></div>", "i": 9724041}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  No pudiendo el Gobierno por s&#xED; entender en los vastos ramos que la necesidad i las urjencias ponen a su cuidado, siendo uno de los mas preferentes el de la organizacion de los cuerpos de que debe componerse el Ej&#xE9;rcito de la Patria, autoriza al efecto con todo el lleno de sus facultades al Excmo. se&#xF1;or Presidente i Jeneral en Jefe de aqu&#xE9;l, para que en su virtud proceda a realizar la fuerza efectiva, i tome por s&#xED; cuantas providencias por todas las clases, Jenerales i Jefes del Estado.</div></div>", "i": 9724042}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Transcr&#xED;base en El Monitor, i p&#xF3;ngase en noticia de dicho se&#xF1;or Excmo. con copia de este decreto. -Uribe.-Mu&#xF1;oz.</div></div>", "i": 9724043}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADPO"], "titulo_norma": "Organizacion del Ejército", "fuente": "Otro", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1814-09-09", "doble_articulado": false, "id_norma": "1093390", "numero_fuente": "0", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1814-09-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1814-09-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1814-09-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacio