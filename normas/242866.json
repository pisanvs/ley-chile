{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6543604}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.136, de 27 de septiembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a CLAUDIO SALVADOR MAMANI BRAVO para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Caleta Cha&#xF1;aral de Aceituno s/n, lote N&#xBA; 9, comuna de Freirina, provincia de Huasco, III Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Fresco enfriado, Fresco refrigerado, Congelado, Cocido, Conserva, Seco salado y Deshidratado los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6543605}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de septiembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6543606}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3136 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3136 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-27", "doble_articulado": false, "id_norma": "242866", "numero_fuente": "38288", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-10-17", "vigencias": [{"desde": "2005-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-10-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-10-17", "fin_vigencia": "", "tipo_vers