{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6426322}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.049, de 22 de mayo de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA LOTA VEDDE LIMITADA ARIES Y COMPA&#xD1;IA COMANDITA POR ACCIONES para ampliar las actividades pesqueras extractivas con la nave &quot;La Ni&#xF1;a I&quot;, en el &#xE1;rea mar&#xED;tima de la V, VI, VII y IX Regiones, por fuera del &#xE1;rea de reserva artesanal, con cerco, sobre los recursos hidrobiol&#xF3;gicos Agujilla, Bonito, Cojinoba del norte, Cojinoba del sur, Dorado, Machuelo o Tritre, Palometa, Bacaladillo o Mote; en el &#xE1;rea mar&#xED;tima de la V, VI, VII, IX y X Regiones, por fuera del &#xE1;rea de reserva artesanal, con cerco, sobre los recursos hidrobiol&#xF3;gicos Anchoa blanca o Samasa, Vinciguerria, Jurel fino, Sardina redonda.</div><br></div>", "i": 6426323}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de mayo de 2003.-&nbsp; Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6426324}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1049", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1049"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-05-22", "fecha_derogacion": "2005-02-21", "doble_articulado": false, "id_norma": "211056", "numero_fuente": "37582", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-06-12", "vigencias": [{"desde": "2005-02-21", "hasta": "", "tipo_v