{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9293092}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. (Exento) N&#xBA;1466, de fecha 31 de julio de 2012, y de conformidad a lo dispuesto en el art&#xED;culo 105 del DFL MOP. N&#xBA;850 de 1997, se expropiaron los lotes de terreno N&#xB0;s. 1 y 1-A, superficies 508 y 1.212 m2., rol N&#xBA;18-204, para la obra &quot;CONSTRUCCI&#xD3;N PUENTE HACIENDA LOLOL, KM. 0,00000 A KM. 1,88000&quot;, comuna de Lolol, VI Regi&#xF3;n. La comisi&#xF3;n de peritos, integrada por Manuel D&#xED;az Farfan, Eduardo Schonhaut Guendelman y Hugo Leal Paredes, fij&#xF3; el valor de tasaci&#xF3;n con fecha 25 de noviembre de 2010, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario GONZALO MUJICA ORTUZAR, en la cantidad de $8.775.455, suma que se pagar&#xE1; al contado. </div><br></div>", "i": 9293093}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9293094}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1466 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1466 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-31", "doble_articulado": false, "id_norma": "1043420", "numero_fuente": "40352", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-09-01", "vigencias": [{"desde": "2012-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia":