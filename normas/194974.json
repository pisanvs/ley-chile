{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6370863}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;107, de 31 de enero de 2002, se expropi&#xF3; el lote de terreno N&#xBA;9, superficie 443 m&#xB2;, rol de aval&#xFA;o 1299-19, comuna de Quilpu&#xE9;, para la obra Concesi&#xF3;n Internacional Interconexi&#xF3;n Vial Santiago-Valpara&#xED;so-Vi&#xF1;a del Mar. Troncal Sur. Enlace Quilpu&#xE9; Oriente. Km 95.840,00 al Km 97.040,00, Quinta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Francisco Javier Fuenzalida Contreras, ascendente a la cantidad de $17.788.612.-</div><br></div>", "i": 6370864}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6370865}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "107", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-107"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-01-31", "doble_articulado": false, "id_norma": "194974", "numero_fuente": "37199", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-03-01", "vigencias": [{"desde": "2002-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-03-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2002-03-01", "fecha_version": "2002-03-01", "fecha_actualizacion_texto": "2