{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6158067}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 549 de 08 de Abril de 1988, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a parcelas N&#xB0;s. 1 a la 6, 9 a la 32, sitios N&#xB0;s. 1 al 17 y Reservas CORA N&#xB0;s. 1A, 1B, 2 y 3 del Proyecto de Parcelaci&#xF3;n &quot;Casas de Quilpu&#xE9;&quot; formado por predio &quot;Hijuela Las Casas de Quilpu&#xE9;&quot;. Los derechos de agua se extraen del Canal Quilpu&#xE9;, Canal Herrera, Canal Enc&#xF3;n, Estero San Francisco, Derrames del Fundo Jahuel. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.- </div></div>", "i": 6158068}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6158069}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "549 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-549 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-04-08", "doble_articulado": false, "id_norma": "133114", "numero_fuente": "33046", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-04-15", "vigencias": [{"desde": "1988-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-04-15