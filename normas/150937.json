{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 607, DE 1986</div><br><br></div>", "i": 8356120}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 571, de 05 de Junio de 1987, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 2&#xB0; de la resoluci&#xF3;n No. 607, de 12 de Agosto de 1986, de esta entidad, que autoriz&#xF3; a don Arnoldo Poupin Krug, c&#xE9;dula de identidad No.</div><div class=\"p\">4.672.247-7, domiciliado en calle Rengifo No. 840, Puerto Montt, para desarrollar actividades pesqueras, en orden a reemplazar &quot;50.000 m2 de fondo de mar&quot; por &quot;114.450 m2 de playa&quot;; y el V&#xE9;rtice &quot;B&quot; s&#xE9; establece de la siguiente forma:</div><div class=\"p\">&quot;V&#xE9;rtice B Lat. 41&#xB0; 29&apos; 48&quot; S Long 72&#xB0; 57&apos; 49&quot; W&quot;. </div></div>", "i": 8356121}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 05 de Junio de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8356122}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "571", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-571"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 607, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1987-06-05", "fecha_derogacion": "1990-09-10", "doble_articulado": false, "id_norma": "150937", "numero_fuente": "32807", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1987-06-30", "vigencias": [{"desde