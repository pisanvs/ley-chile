{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUA EN COMUNA DE CABILDO</div><br><br><br></div>", "i": 6559643}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xBA;218 del 16 de enero de 2006, conforme art&#xED;culo<span class=\"n\" id=\"n_0\">AVI S/N,<br>AGRICULTURA<br>D.O. 15.06.2006</span> 5&#xBA; transitorio C&#xF3;digo Aguas, aprob&#xF3; estudio de regularizaci&#xF3;n de derechos de aprovechamiento de aguas del predio &quot;Hijuela Numero Uno de Alicahue o Hijuela Paihuen de Alicahue&quot;, de la comuna de Cabildo, provincia de Petorca, V Regi&#xF3;n, que consisten en los recursos extra&#xED;dos de 16 pozos noria. Dichos derechos son consuntivos, de ejercicio permanente y continuo. Publicaci&#xF3;n hecha conforme art&#xED;culo 13&#xBA; ley N&#xBA;18.377.-</div><br></div>", "i": 6559644}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director Nacional.</div><br></div>", "i": 6559645}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "3", "numero": "218 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-218 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUA EN COMUNA DE CABILDO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHOS DE APROVECHAMIENTO DE AGUAS", "CABILDO", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-16", "doble_articulado": false, "id_norma": "246890", "numero_fuente": "38378", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2006-02-01", "vigencias": [{"desde": "2006-06-15", "hasta": "", "tipo_version": "2", "tipo_version_s": "Últi