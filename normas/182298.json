{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A PESQUERA SAN MIGUEL S.A.</div><br></div>", "i": 6324423}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/N&#xBA; ex. 0453, de fecha 15 de febrero de 2001, revoca, a Pesquera San Miguel S.A., RUT N&#xBA; 81.740.200-3, a partir del d&#xED;a 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de Sujeto en las adquisiciones de Especies Hidrobiol&#xF3;gicas, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 18&#xBA; de la resoluci&#xF3;n ex. N&#xBA; 3.311/2000, de la Direcci&#xF3;n Nacional. </div></div>", "i": 6324424}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 15 de febrero de 2001.- Ram&#xF3;n Ram&#xED;rez Toledo, Director Regional (S).</div><br></div>", "i": 6324425}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "453 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-453 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A PESQUERA SAN MIGUEL S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-15", "doble_articulado": false, "id_norma": "182298", "numero_fuente": "36900", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-02-28", "vigencias": [{"desde": "2001-02-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "200