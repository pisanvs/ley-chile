{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  EXTRACTO DE DECRETO EXENTO No. 73, DE 1988 </div></div>", "i": 6167470}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 73 de 12 de Abril de 1988 se ha aprobado para el Liceo T&#xE9;cnico B - 39 de la comuna de Gonchal&#xED;, provincia de Santiago, Regi&#xF3;n Metropolitana, un plan y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico - Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar de 1988 y harta el a&#xF1;o escolar de 1989, en la Rama Comercial, Especialidad Secretariado Ejecutivo con menci&#xF3;n en Computaci&#xF3;n.</div><br></div>", "i": 6167471}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de Abril de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6167472}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "73 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-73 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 73, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-04-12", "doble_articulado": false, "id_norma": "136046", "numero_fuente": "33064", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-05-06", "vigencias": [{"desde": "1988-05-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-05-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-05-06", "fin_vigencia": "",