{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Considera al departamento de Temuco como de segundo &#xF3;rden para los efectos del pago del impuesto de patentes.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m 2,510.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275293}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Para el pago del impuesto de patentes, en conformidad a lo dispuesto en el art. 2&#xBA; de la lei de 22 de Diciembre de 1866, el departamento de Temuco pertenecer&#xE1; al segundo &#xF3;rden de los espresados en dicho art&#xED;culo.</div><br><br><br></div>", "i": 8275294}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 28 de Junio de 1911.- RAMON BARROS LUCO.- Rafael Orrego.</div><br></div>", "i": 8275295}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2510", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2510"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONSIDERA AL DEPARTAMENTO DE TEMUCO COMO DE SEGUNDO ORDEN PARA LOS EFECTOS DEL PAGO DEL IMPUESTO DE PATENTES.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TEMUCO", "DEPARTAMENTO", "IMPUESTO", "PATENTES", "CLASIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "ob