{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO DE EXPROPIACION</div><br><br></div>", "i": 5851023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Secc. 2a. N&#xB0; 9 de 3 Febrero 1993 Alcalde I. Municipalidad de Santiago, dispone expropiaci&#xF3;n total conforme D.S. 458 Vivienda y Urbanismo, Ley N&#xB0; 18.695 y D.L. N&#xB0; 2.186 inmueble Avda. Balmaceda 2857 Rol 3-4, aparentemente dominio Marga Lena Navarrete. Superf. aproximada 2.869,64 m2. Deslindes: Norte, l&#xED;nea quebrada 125 mts. otros propietarios; Sur, l&#xED;nea quebrada 147 mts. Avda. Balmaceda; Oriente, 51 mts. con otro propietario, Poniente, l&#xED;nea quebrada 5 mts. y 6 mts. con otro propietario. Indemnizaci&#xF3;n provisional $ 12.900.000,- pagadera contado.</div><br><br></div>", "i": 5851024}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Alcalde Subrogante Santiago Juan E. Infante Philippi.</div><br></div>", "i": 5851025}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "9", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-9"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "EXTRACTO DE DECRETO DE EXPROPIACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "DECRETO EXPROPIATORIO", "INMUEBLE", "BIEN", "RAIZ", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1993-02-03", "fecha_derogacion": "1995-09-15", "doble_articulado": false, "id_norma": "2043", "numero_fuente": "34516-3", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1993-03-15", "vigencias": [{"desde": "1995-09-15", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1993-03-15", "hasta":