{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 727 EXENTA, DE 9 DE MARZO DE 2021</div></div>", "i": 10212727}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 727, de 2021, de la Subsecretar&#xED;a de Transportes, se modific&#xF3; el art&#xED;culo primero de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1131182&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 757, de 15 de marzo de 2019</a>, en el sentido que la direcci&#xF3;n del taller para adecuar veh&#xED;culos al uso de gas licuado de petr&#xF3;leo (GLP) y gas natural comprimido (GNC) como combustibles, expresada en la tabla del art&#xED;culo primero de la resoluci&#xF3;n exenta N&#xB0; 757, es reemplazada por: &quot;Los Industriales N&#xB0; 2918, comuna de Macul, Regi&#xF3;n Metropolitana&quot;.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10212728}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Luis Dom&#xED;nguez Cobarrubias, Subsecretario de Transportes.</div><div class=\"p\"> </div><br></div>", "i": 10212729}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "727 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-727 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 727 EXENTA, DE 9 DE MARZO DE 2021", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1916757", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-03-09", "doble_articulado": false, "id_norma": "1157512", "numero_fuente": "42917", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacio