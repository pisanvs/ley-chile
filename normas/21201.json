{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 416, DE 1992 </div><br></div>", "i": 8969098}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0;416 de fecha 3 de Diciembre de 1992 del Ministerio de Educaci&#xF3;n, se insert&#xF3; en la Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xB0;397 de 1990 del Centro de Formaci&#xF3;n T&#xE9;cnica ESANE, las adecuaciones introducidas a las carreras de Dise&#xF1;o de Vestuario y Prevenci&#xF3;n de Riesgos y en la Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xB0;1.320 de 1987, las adecuaciones introducidas en la carrera de Interpretaci&#xF3;n Ingl&#xE9;s-Alem&#xE1;n, todas las cuales podr&#xE1;n aplicarse en la ciudad de Santiago, a contar del a&#xF1;o 1992.-</div><br></div>", "i": 8969099}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 19 de Marzo de 1993.- RA&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8969100}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "416 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-416 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 416, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PROGRAMAS ESTUDIOS", "PLANES ESTUDIOS", "DISE O", "VESTUARIO", "PREVENCION RIESGOS", "INTERPRETACION", "INGLES-ALEMAN", "CENTRO FORMACION TECNICA", "ESANE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-12-03", "doble_articulado": false, "id_norma": "21201", "numero_fuente": "34538", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-04-12", "vigencias": [{"desde": "1993-04-12", "hasta": "", "tipo_version": "3", "t