{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concesion al Coronel don Jos&#xE9; Mar&#xED;a 2.&#xB0; Soto Lei n&#xFA;m. 1,140.- Santiago, a 12 de Diciembre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948421}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Ot&#xF3;rgase, por gracia, al coronel don Jos&#xE9; Mar&#xED;a 2.&#xB0; Soto el beneficio que a varios jefes de Ej&#xE9;rcito acuerda la lei de 6 de Octubre de 1883.</div><br><br></div>", "i": 5948422}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Ventura Blanco.</div><br></div>", "i": 5948423}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1140", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1140"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "CONCESION AL CORONEL DON JOSE MARIA 2.° SOTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JOSE MARIA SEGUNDO SOTO", "BENEFICIO POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-12-12", "doble_articulado": false, "id_norma": "22426", "numero_fuente": "6173", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-12-12", "vigencias": [{"desde": "1898-12-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-12-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-12-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes