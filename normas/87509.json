{"html": [{"t": "<div><div class=\"p\">APRUEBA REFORMA DE ESTATUTOS A BOLSA DE COMERCIO DE SANTIAGO,BOLSA DE VALORES </div></div>", "i": 6076453}, {"t": "<div><div class=\"p\">Certifico: Que por Resoluci&#xF3;n Exenta No. 49, de 27 de marzo</div><div class=\"p\">de 1991, se aprob&#xF3; la reforma de estatutos de la entidad</div><div class=\"p\">denominada Bolsa de Comercio de Santiago, Bolsa de Valores,</div><div class=\"p\">que consta de la escritura p&#xFA;blica de 25 de junio de 1990,</div><div class=\"p\">otorgada ante el titular de la 21 Notar&#xED;a de Santiago, don</div><div class=\"p\">Ra&#xFA;l Iv&#xE1;n Perry Pefaur.</div><div class=\"p\">La reforma consiste en aumentar el plazo de duraci&#xF3;n del</div><div class=\"p\">directorio de uno a tres a&#xF1;os, sustituyendo al efecto, el</div><div class=\"p\">art&#xED;culo 35 de los estatutos sociales.</div><br></div>", "i": 6076454}, {"t": "<div><div class=\"p\">Santiago, 27 de Marzo de 1991.- Rodrigo O. Costa Aranda, Secretario General.</div><br></div>", "i": 6076455}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "49 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-49 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "APRUEBA REFORMA DE ESTATUTOS A BOLSA DE COMERCIO\nDE SANTIAGO,BOLSA DE VALORES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-03-27", "doble_articulado": false, "id_norma": "87509", "numero_fuente": "33939", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-10", "vigencias": [{"desde": "1991-04-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-04-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-04-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1998-02-02", "fecha_version": "1991-04-10", "fecha_actualizacion_texto": "1991-04-10", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6076453}, {"n": "Artículo", "i": 6076454, "t": 6}, {"n": "Promulgación", "i": 6076455}]}