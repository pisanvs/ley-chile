{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8617102}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.718, de 15 de mayo de 2009, de esta Subsecretar&#xED;a, modif&#xED;canse los numerales 2, 3, 4, 5, 6, 7, 8 y 9 de la resoluci&#xF3;n exenta N&#xBA; 3.613, de 2007, que autoriz&#xF3; a la UNIVERSIDAD CAT&#xD3;LICA DEL NORTE para efectuar una pesca de investigaci&#xF3;n de conforme T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto &quot;Caracterizaci&#xF3;n de la pesquer&#xED;a de Algas Pardas de las Regiones XV a IV&quot;, de acuerdo con lo se&#xF1;alado en resoluci&#xF3;n extractada.</div></div>", "i": 8617103}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de mayo de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8617104}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1718 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-1718 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-05-15", "doble_articulado": false, "id_norma": "1002547", "numero_fuente": "39367", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-05-22", "vigencias": [{"desde": "2009-05-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-05-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-05-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones