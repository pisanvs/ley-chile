{"html": [{"t": "<div><div class=\"p\">CAUSAS DE HACIENDA.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago Agosto 28 de 1824</div></div>", "i": 10102385}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Vista la consulta de la Contadur&#xED;a mayor; y el expediente que la motiva, el Gobierno declara: Que el art. 13 de las adiciones al Reglamento de Justicia comprende todas las causas de Hacienda de cualesquiera naturaleza y condicion que sean, como lleguen a ser contenciosas, y conozcan con ellas los Jueces de primera instancia. Av&#xED;sese as&#xED; en contestacion, trascribase e imprimase.</div></div>", "i": 10102386}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Diego Jos&#xE9; Benavente.</div></div>", "i": 10102387}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["DEPARTAMENTO DE HACIENDA"], "titulo_norma": "CAUSAS DE HACIENDA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-08-28", "doble_articulado": false, "id_norma": "1141031", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-08-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-08-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-08-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2020-02-21", "fecha_version": "1824-08-28", "fecha_actualizacion_texto": "2020-02-21", "tipo_tratado": ""}, "a