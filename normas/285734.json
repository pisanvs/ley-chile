{"html": [{"t": "<div><div class=\"p\">REASUME MANDO DEL ESTADO</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de diciembre de 2008.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 1.475.- Visto: Lo dispuesto en los art&#xED;culos 29&#xBA; y 32&#xBA;, N&#xBA; 6 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile, y teniendo presente que he regresado al territorio nacional a las 20:55 horas del presente d&#xED;a,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 6931282}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Con ocasi&#xF3;n de mi regreso al pa&#xED;s, a contar de esta fecha reasumo el mando del Estado.</div><br></div>", "i": 6931283}, {"t": "<div><div class=\"p\">T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- MICHELLE BACHELET JERIA, Presidenta de la Rep&#xFA;blica.- Edmundo P&#xE9;rez Yoma, Ministro del Interior.</div><br><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud., para su conocimiento.- Saluda Atte. a Ud., Patricio Rosende Lynch, Subsecretario del Interior.</div><br></div>", "i": 6931284}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1475", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1475"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARIA DEL INTERIOR"], "titulo_norma": "REASUME MANDO DEL ESTADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-12-17", "doble_articulado": false, "id_norma": "285734", "numero_fuente": "39268", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-01-22", "vigencias": [{"desde": "2009-01-22", "hasta": "", "tipo_version"