{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6743172}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. N&#xBA; 654, de 31 de octubre de 1995, se expropiaron los lotes de terreno N&#xBA;s 107, 108 y 115, superficies 60 m2., 120 m2., y 147 m2., roles de aval&#xFA;o 668-1, 668-2 y 675-11, comuna de Rancagua, para la obra Mejoramiento Ruta 5 Sur, sector Pasada por Rancagua Camino Ruta 5 Sur y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Sucesi&#xF3;n Francisco Javier Garrido Gallegos y Sucesi&#xF3;n Clodomiro Quitral C&#xE9;spedes, ascendente a las cantidades de $15.070.550, para los lotes N&#xBA;s 107 y 108 y $3.816.318, para el lote N&#xBA;115. </div></div>", "i": 6743173}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6743174}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "654", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-654"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-10-31", "doble_articulado": false, "id_norma": "218636", "numero_fuente": "35331", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-12-01", "vigencias": [{"desde": "1995-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2003-12-15", "fe