{"html": [{"t": "<div><div class=\"p\">SEPTIMO PROGRAMA PRIORIZADO DE NORMAS</div><br><div class=\"p\">EXTRACTO </div></div>", "i": 8658589}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  De conformidad con lo dispuesto en decreto supremo N&#xBA; 93 de 1995, del Ministerio Secretar&#xED;a General de la Presidencia, con fecha 29 de mayo del a&#xF1;o 2002, el Consejo Directivo de la Comisi&#xF3;n Nacional del Medio Ambiente aprob&#xF3; el S&#xE9;ptimo Programa Priorizado de Normas, cuyo contenido es el siguiente:</div><br><br><div class=\"p\">1. Agua</div><br><div class=\"p\">-&nbsp; &nbsp; Revisi&#xF3;n del D.S. N&#xBA; 609/98 del Ministerio de Obras P&#xFA;blicas, &quot;Norma de Descarga de Residuos L&#xED;quidos a Sistemas de Alcantarillados&quot; -&nbsp; &nbsp; Norma de Emisi&#xF3;n para Efluentes Provenientes de Relaves Mineros.</div><br><div class=\"p\">2. Aire</div><br><div class=\"p\">-&nbsp; &nbsp; Revisi&#xF3;n del D.S. N&#xBA; 54/1994 de MINTRATEL, que Establece Normas de Emisi&#xF3;n Aplicables a Veh&#xED;culos Motorizados Medianos.</div><br></div>", "i": 8658590}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gianni L&#xF3;pez Ram&#xED;rez, Director Ejecutivo CONAMA </div></div>", "i": 8658591}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "AVI-S/N"}], "organismos": ["MINISTERIO SECRETARÍA GENERAL DE LA PRESIDENCIA", "COMISIÓN NACIONAL DEL MEDIO AMBIENTE"], "titulo_norma": "SEPTIMO PROGRAMA PRIORIZADO DE NORMAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONTAMINACION AMBIENTAL", "PROGRAMA PRIORIZADO DE NORMAS", "APROBACION", "RESIDUOS LIQUIDOS", "DESCARGA EN ALCANTARILLADOS", "RELAVES MINEROS", "EMISION PARA EFLUENTES", "VEHICULOS MOTORIZADOS LIVIANOS", "NORMAS DE EMISION", "REVISION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-29", "doble_articulado": false, "id_norma": "202112", "numero_fuente": "37349", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-09-02", "vigencias": [{"desde": "2002-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-09-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2002-09-02", "fecha_version": "2002-09-02", "fecha_actualizacion_texto": "2002-09-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8658589}, {"n": "Artículo", "i": 8658590, "t": 6}, {"n": "Promulgación", "i": 8658591}]}