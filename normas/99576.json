{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8330309}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;691, de 20 de mayo de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a PESQUERA IQUIQUE GUANAYE S.A., para ampliar actividades pesqueras extractivas autorizadas por resoluci&#xF3;n N&#xBA;161 de 1996, de esta Subsecretar&#xED;a, en orden a operar la nave &apos;&apos;Don Gino&apos;&apos;, en el litoral de la I, II y III Regiones, por fuera del &#xE1;rea de reserva artesanal, con red de cerco, en la captura del recurso Bacaladillo o Mote. </div></div>", "i": 8330310}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de mayo de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8330311}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "691", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-691"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA IQUIQUE GUANAYE S.A.", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-05-20", "fecha_derogacion": "2000-03-06", "doble_articulado": false, "id_norma": "99576", "numero_fuente": "36079", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-06-02", "vigencias": [{"desde": "2000-03-06", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-06-02", "hasta": "2000-03-05", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vi