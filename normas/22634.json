{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 1,419.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br><br><br></div>", "i": 7163064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de cincuenta mil pesos al &#xED;tem 1 de la partida 28 del presupuesto del Ministerio de Industria i Obras P&#xFA;blicas, para estudios de nuevas l&#xED;neas f&#xE9;rreas.</div><br><br></div>", "i": 7163065}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 26 de Diciembre de 1900.- FEDERICO ERRAZURIZ E.- M. A. Covarrubias.</div><br></div>", "i": 7163066}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1419", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1419"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1900", "MODIFICACION", "MINISTERIO", "INDUSTRIA OBRAS PUBLICAS", "LINEAS FERREAS", "ESTUDIO", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["LA PRESENTE LEY HA SIDO REPRODUCIDA EN EL DIARIO OFICIAL Nº 6780 DEL 31.12.1900"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-12-26", "doble_articulado": false, "id_norma": "22634", "numero_fuente": "6778", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-12-28", "vigencias": [{"desde": "1900-12-28", "hasta": "", "tipo_version": "3", "tipo_version_