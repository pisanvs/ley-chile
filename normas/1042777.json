{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 185.- Santiago, 14 de febrero de 1906. - Vistos estos antecedentes i lo informado por la Inspecci&#xF3;n de Ferrocarriles Particulares, </div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div></div>", "i": 9288731}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Se autoriza a la Sociedad, Agr&#xED;cola e Industrial &#xAB;Nueva Italia&#xBB;, concesionaria del ferrocarril de Los Sauces a Capit&#xE1;n Pastene, en virtud del decreto n&#xFA;mero 3.048, de 23 de noviembre &#xFA;ltimo, para presentar los planos a la aprobacion del Gobierno por secciones, pudiendo iniciar la construccion de cada seccion del ferrocarril una vez aprobados los planos respectivos.</div></div>", "i": 9288732}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, comun&#xED;quese i publ&#xED;quese.- RIESCO.- J. Ram&#xF3;n Guti&#xE9;rrez.</div></div>", "i": 9288733}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "185", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-185"}], "organismos": ["MINISTERIO DE INDUSTRIA I OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-02-14", "doble_articulado": false, "id_norma": "1042777", "numero_fuente": "8436", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1906-02-21", "vigencias": [{"desde": "1906-02-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1906-02-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1906-02-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincula