{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 206.-Santiago, 15 de Mayo de 1931.- Visto, las facultades que me confiere la ley n&#xFA;mero 4,945, de 6 de Febrero de 1931 y lo informado por la Contralor&#xED;a General de la Rep&#xFA;blica, seg&#xFA;n oficio que se acompa&#xF1;a, Decreto:</div><br></div>", "i": 8254907}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Efect&#xFA;ense los siguientes traspasos en los &#xED;tem que se indican del Presupuesto del Ministerio del Interior (Subsecretar&#xED;a de Aviaci&#xF3;n), del presente a&#xF1;o, como sigue:</div><br><div class=\"p\"> De 04/12/02/e&nbsp; &nbsp; a&nbsp; 04/12/02/b___&nbsp; &nbsp; $&nbsp; &nbsp; 95,000.-</div><div class=\"p\"> De 04/12/02/e&nbsp; &nbsp; a&nbsp; 04/12/01_____&nbsp; &nbsp; &nbsp; &nbsp;  45,000.-</div><br></div>", "i": 8254908}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese en la Contralor&#xED;a General de la Rep&#xFA;blica, t&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Bolet&#xED;n Oficial.- C. IBA&#xD1;EZ C.- C. O. Froedden. </div></div>", "i": 8254909}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "206", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-206"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O", "1931", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-05-15", "doble_articulado": false, "id_norma": "5035", "numero_fuente": "15984", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-05-30", "vigencias": [{"desde": "1931-05-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}]