{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6275755}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 31 de 25 de Marzo de 1982, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se autoriza al se&#xF1;or Guillermo Acu&#xF1;a Jorquera para efectuar todo tipo de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n del servicio urbano de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6275756}, {"t": "<div><div class=\"p\">Manuel Coloma Amaro, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n del Maule </div></div>", "i": 6275757}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "31", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-31"}], "organismos": ["MINISTERIO DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1982-03-25", "doble_articulado": false, "id_norma": "168816", "numero_fuente": "32106", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-02-25", "vigencias": [{"desde": "1985-02-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-02-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-02-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CAL", "fecha_ingreso": "2000-05-16", "fecha_version": "1985-02-25", "fecha_actualizacion_texto": "1985-02-25", "tipo_tratado": ""}, "alertas": [], "