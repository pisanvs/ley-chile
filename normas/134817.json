{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 1,491.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6163526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese un suplemento de cincuenta mil pesos ($ 50,000) al &#xED;tem 1 de la partido 35 del presupuesto del Ministerio de Industria i Obras P&#xFA;blicas. </div></div>", "i": 6163527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, a 5 de diciembre de 1901.- JERMAN RIESCO.- Rafael Orrego </div></div>", "i": 6163528}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1491", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1491"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-12-05", "doble_articulado": false, "id_norma": "134817", "numero_fuente": "7093", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-12-10", "vigencias": [{"desde": "1901-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1901-12-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1901-12-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-04-13", "fecha_version": "1901-12-10",