{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10298058}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.132 de 14 de diciembre de 2021 de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n total, conforme art&#xED;culo 51 ley 16391, del inmueble ubicado en Fdo. Prosperidad PC 17, Rol Aval&#xFA;o N&#xBA; 3706-48 comuna Talca, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Serviu Regi&#xF3;n del Maule. Comisi&#xF3;n integrada por peritos Patricio Dur&#xE1;n Marcos, arquitecto; Pedro Pablo Cruz Weston, arquitecto; y Rodrigo Silva Lazo, constructor civil, seg&#xFA;n informe de tasaci&#xF3;n evacuado con fecha 16 de agosto de 2021, fij&#xF3; monto provisional indemnizaci&#xF3;n en $1.103.608.428.- monto que conforme a lo dispuesto en el art&#xED;culo 5&#xBA; del DL 2186 de 1978 fue reajustado a la suma de $1.141.131.110.- pagados al contado.- </div></div>", "i": 10298059}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Claudio Daneck Mu&#xF1;oz, Director (S) Serviu Regi&#xF3;n del Maule.</div><br></div>", "i": 10298060}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1132 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1132 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2064525", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-12-14", "doble_articulado": false, "id_norma": "1170807", "numero_fuente": "43142", "tipo_version":