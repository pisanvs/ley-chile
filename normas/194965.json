{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6370836}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 52, de 29 de enero de 2002, se rectific&#xF3; el decreto MOP N&#xBA; 846 de 31 de mayo de 2001, que orden&#xF3; la expropiaci&#xF3;n de los lotes de terreno Nos 3 y 5, en el sentido de sustituir en la frase &quot;Fiscal Regional o al Abogado Jefe del Departamento de Concesiones&quot; por la siguiente &quot;Fiscal Regional de la Quinta Regi&#xF3;n o al Abogado Jefe del Departamento de Expropiaciones&quot;. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto Ley N&#xBA; 2.186, de 1978.</div><br></div>", "i": 6370837}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6370838}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "52", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-52"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-01-29", "doble_articulado": false, "id_norma": "194965", "numero_fuente": "37199", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-03-01", "vigencias": [{"desde": "2002-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-03-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2002-03-01", "fecha_version": "2