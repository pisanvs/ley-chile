{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; NOTIFICACION EXPROPIACION </div></div>", "i": 6014475}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1089 de 7 de diciembre de 1992 de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xB0; 2.186 de 1978, de parte del inmueble ubicado en Avenida Departamental N&#xB0; 914, presunto rol de aval&#xFA;os N&#xB0; 8346-39 comuna San Miguel, de aparente dominio de don Alejandro Bunster Soto. Comisi&#xF3;n integrada por peritos Sres. Mario Vergara Navarrete y Fernando Merino de la Cerda, arquitectos y Luis Rojas Quezada, constructor civil, seg&#xFA;n informe de 22 de octubre de 1992, fij&#xF3; monto provisional indemnizaci&#xF3;n en $220.000.- pagadera al contado.-</div><br></div>", "i": 6014476}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Directora, SERVIU Metropolitano.</div><br></div>", "i": 6014477}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1089", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1089"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "NOTIFICACION EXPROPIACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "BIEN RAIZ", "SAN MIGUEL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-12-07", "doble_articulado": false, "id_norma": "36192", "numero_fuente": "34466", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-01-15", "vigencias": [{"desde": "1993-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-01-15", "fin_vigencia": "", "t