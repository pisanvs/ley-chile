{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8437905}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.094, de 8 de agosto de 2008, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad total de las resoluciones N&#xBA; 4.030 de 2005 y N&#xBA; 820, de 2008, ambas de esta Subsecretar&#xED;a, que autorizaron a don GIOVANNI ARANCIBIA FUENTES para desarrollar actividades pesqueras extractivas con la nave &apos;Isla Tab&#xF3;n&apos;, en virtud de lo dispuesto en el art&#xED;culo 143 letra d) de la Ley General de Pesca y Acuicultura, y de lo informado en el informe t&#xE9;cnico citado en la resoluci&#xF3;n extractada. </div></div>", "i": 8437906}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de agosto de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 8437907}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2094 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2094 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2008-08-05", "fecha_derogacion": "2008-10-22", "doble_articulado": false, "id_norma": "276507", "numero_fuente": "39139", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2008-08-16", "vigencias": [{"desde": "2008-10-22", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2008-08-16", "hasta": "2008-10-21", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2008-10-