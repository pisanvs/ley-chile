{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6024554}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n Exenta N&#xB0;1.256 de 14.10.93, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriza complementariamente a la empresa de origen argentino &quot;Angel Giobbi&quot; S.A., para efectuar servicio de transporte terrestre internacional de pasajeros entre Comodoro Rivadavia-R&#xED;o Mayo (Argentina) y Coyhaique (Chile) y viceversa, utilizando los pasos fronterizos de Camino Alto R&#xED;o Mayo-Coyhaique y Huemules, realizando (2) frecuencias semanales.-</div><br></div>", "i": 6024555}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Sergio Gonz&#xE1;lez Tagle, Subsecretario de Transportes. </div></div>", "i": 6024556}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1256", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1256"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ANGEL GIOBBI S.A.", "TRANSPORTE PASAJEROS", "ARGENTINA", "CHILE", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-10-14", "doble_articulado": false, "id_norma": "39646", "numero_fuente": "34733", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-12-04", "vigencias": [{"desde": "1993-12-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-12-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-12-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1993-12-04", "