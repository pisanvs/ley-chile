{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div><br><br></div>", "i": 6419951}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA; 29, de fecha 21 de marzo del a&#xF1;o 2003, se autoriz&#xF3; la existencia y aprob&#xF3; el estatuto de la &quot;Cooperativa de Ahorro y Cr&#xE9;dito Personal Colegio Concepci&#xF3;n Limitada&quot;, de la ciudad de Concepci&#xF3;n, Octava Regi&#xF3;n, en los t&#xE9;rminos que da cuenta el acta constitutiva protocolizada con fecha 24 de febrero del a&#xF1;o 2003, al final de los registros de la Notario de la ciudad de Concepci&#xF3;n, do&#xF1;a Guacolda Elizabeth Aedo Orme&#xF1;o, bajo el N&#xBA; 261-2003.</div><br></div>", "i": 6419952}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Ra&#xFA;l Oliva Camadro, Jefe Departamento de Cooperativas Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6419953}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "29", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-29"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-03-21", "doble_articulado": false, "id_norma": "209109", "numero_fuente": "37530", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-04-08", "vigencias": [{"desde": "2003-04-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic