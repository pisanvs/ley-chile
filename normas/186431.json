{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6338728}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA; 548, de fecha 30 de abril de 2001, se expropiaron los lotes de terreno N&#xBA;s. 29-A, 29-B, 31-A, 33-A, 34-A, 34-B, 35-A, 38-A, 39-A, 40-A, 41-A, 42-A y 45-A, superficies 128 M2, 58 M2, 633 M2, 50 M2, 203 M2, 323 M2, 381 M2, 153 M2, 211 M2, 158 M2, 250 M2, 280 M2 y 358 M2, respectivamente, Rol de aval&#xFA;o 27-18 comuna de Paredones, para la obra &quot;Camino Lolol-Paredones-Bucalemu, Sector Alto Nilahue-Acceso Paredones , Tramo Km. 12,700 al 27,800&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Gladys Mar&#xED;a Ang&#xE9;lica L&#xF3;pez del Campo, ascendente a la cantidad de $5.860.320.-</div><br></div>", "i": 6338729}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6338730}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "548 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-548 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-30", "doble_articulado": false, "id_norma": "186431", "numero_fuente": "36987", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-06-15", "vigencias": [{"desde": "2001-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v