{"html": [{"t": "<div><div class=\"p\">LEY NUM. 14.847</div><br><div class=\"p\">ELEVA EL VALOR DE LAS ENTRADAS A LAS SALAS DE JUEGO Y CABARET DEL CASINO MUNICIPAL DE VI&#xD1;A DEL MAR </div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 9005217}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- DEROGADO<span class=\"n\" id=\"n_0\">DL 567, HACIENDA<br>Art. 1&#xBA;<br>D.O. 20.07.1974</span>&nbsp; </div></div>", "i": 9005218, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, cinco de Abril de mil novecientos sesenta y dos.- JORGE ALESSANDRI RODRIGUEZ.- S&#xF3;tero del R&#xED;o G. </div></div>", "i": 9005219}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "1", "numero": "14847", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14847"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "ELEVA EL VALOR DE LAS ENTRADAS A LAS SALAS DE JUEGO Y\nCABARET DEL CASINO MUNICIPAL DE VIÑA DEL MAR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1962-04-05", "doble_articulado": false, "id_norma": "250589", "numero_fuente": "25224", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1962-04-18", "vigencias": [{"desde": "1974-07-20", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1962-04-18", "hasta": "1974-07-19", "tipo_versi