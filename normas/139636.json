{"html": [{"t": "<div><div class=\"p\">EXTRACTO&nbsp; DE&nbsp; DECRETO N&#xBA; 625 EXENTO, DE 1998</div><br></div>", "i": 6179178}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 625 de fecha 1&#xBA; de junio de</div><div class=\"p\">1998 del Ministerio de Educaci&#xF3;n, se declararon</div><div class=\"p\">aprobadas las modificaciones a la carrera de</div><div class=\"p\">Comunicaci&#xF3;n Audiovisual del Instituto Profesional de</div><div class=\"p\">Arte y Comunicaci&#xF3;n Arcos, la cual a contar desde octubre de 1992 pasa a denominarse como sigue, de conformidad al acuerdo adoptado por el Consejo Superior de Educaci&#xF3;n:</div><br><div class=\"p\">&nbsp; &nbsp;  Carrera: Comunicaci&#xF3;n Audiovisual conducente al T&#xED;tulo Profesional de Comunicador Audiovisual, con menci&#xF3;n en Cine, Televisi&#xF3;n y Video.</div><br></div>", "i": 6179179}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de julio de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6179180}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "625 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-625 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 625 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-06-01", "doble_articulado": false, "id_norma": "139636", "numero_fuente": "36421", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-07-24", "vigencias": [{"desde": "1999-07-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-