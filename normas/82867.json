{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6063559}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 232 de 11 de abril de 1990, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriz&#xF3; al se&#xF1;or Carlos Ren&#xE9; Silva Puratic, para efectuar transporte terrestre de pasajeros entre Osorno y Punta Arenas, en tr&#xE1;nsito por territorio argentino, por los Pasos Puyehue y Monte Aymond, con Dos frecencias semanales, las que se efectuar&#xE1;n en los siguientes d&#xED;as: Osorno-Punta Arenas: martes - jueves. Punta Arenas-Osorno: martes - viernes.-</div><br></div>", "i": 6063560}, {"t": "<div><div class=\"p\">Sergio Gonz&#xE1;lez Tagle, Subsecretario de Transportes. </div></div>", "i": 6063561}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "232", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-232"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-04-11", "doble_articulado": false, "id_norma": "82867", "numero_fuente": "33698", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-06-19", "vigencias": [{"desde": "1990-06-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-06-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-06-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMZ", "fecha_ingreso": "1998-01-06", "fecha_version": "1990-06-19", "fecha_a