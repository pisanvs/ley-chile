{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 58 EXENTA, DE 11 DE FEBRERO DE 2020</div></div>", "i": 10162437}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0;58, del 11 de febrero de 2020, la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n del Biob&#xED;o, modific&#xF3; la <a href=\"https://www.leychile.cl/Navegar?idNorma=1051280&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 125, de fecha 15 de abril de 2013</a>, en el sentido de fijar la capacidad m&#xE1;xima del terminal en 60 buses urbanos. En lo no modificado, la resoluci&#xF3;n exenta N&#xB0; 125 citada se mantiene &#xED;ntegramente vigente.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10162438}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jaime Aravena Selman, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n del Biob&#xED;o.</div><br></div>", "i": 10162439}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "58 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-58 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 58 EXENTA, DE 11 DE FEBRERO DE 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1822735", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-02-11", "doble_articulado": false, "id_norma": "1149864", "numero_fuente": "42767", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-09-29", "vigencias": [{"desde": "2020-09-29", "hasta": "", "tip