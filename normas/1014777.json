{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA A INSTITUCI&#xD3;N SIN FINES DE LUCRO, COMO RECEPTORA DE ALIMENTOS CUYA COMERCIALIZACI&#xD3;N SEA INVIABLE</div><br></div>", "i": 8936558}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n Ex. del Servicio de Impuestos Internos N&#xBA; 105, del 21 de junio de 2010, que autoriza a instituci&#xF3;n sin fines de lucro como receptora en forma gratuita de alimentos, cuya comercializaci&#xF3;n sea inviable.</div><div class=\"p\">&nbsp; &nbsp;  La entidad autorizada al efecto corresponde a Rol &#xDA;nico Tributario N&#xBA; 71.735.400-1.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en junio de 2010.- </div></div>", "i": 8936559}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Mario Vila Fern&#xE1;ndez, Director (S).</div></div>", "i": 8940773}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "105 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-105 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A INSTITUCIÓN SIN FINES DE LUCRO, COMO RECEPTORA DE ALIMENTOS CUYA COMERCIALIZACIÓN SEA INVIABLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN."], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-06-21", "doble_articulado": false, "id_norma": "1014777", "numero_fuente": "39695", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-06-25", "vigencias": [{"desde": "2010-