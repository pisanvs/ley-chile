{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Tesorero fiscal de Magallanes </div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,242.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948667}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. F&#xED;jase en tres mil pesos anuales, a contar desde el 1.&#xB0; de junio del presente a&#xF1;o, el sueldo del tesorero fiscal de Magallanes, el cual tendr&#xE1; a su cargo la contabilidad especial de los terrenos de colonizacion.</div><br><br></div>", "i": 5948668}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 3 de Agosto de 1899.- FEDERICO ERRAZURIZ.- F. Pinto Izarra.</div><br></div>", "i": 5948669}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1242", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1242"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "Tesorero fiscal de Magallanes", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TESORERO FISCAL", "MAGALLANES", "TERRENOS", "COLONIZACION", "SUELDO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-08-03", "doble_articulado": false, "id_norma": "22496", "