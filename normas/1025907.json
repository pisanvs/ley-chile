{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9144672}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.369, de 16 de mayo de 2011, de esta Subsecretar&#xED;a, rech&#xE1;zanse las solicitudes de concesi&#xF3;n de acuicultura n&#xFA;meros 208121076, 208121075, 208121073, 208121072, 208121078, 208121087, 208122131 y 208122138, se&#xF1;aladas en la resoluci&#xF3;n extractada, y publicada &#xED;ntegramente en la p&#xE1;gina web www.subpesca.cl, en virtud de los art&#xED;culos 78 de la Ley General de Pesca y Acuicultura, 11 y 13 del DS N&#xBA; 320, de 2001, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div></div>", "i": 9144673}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de mayo de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9144674}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1369 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1369 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-05-16", "doble_articulado": false, "id_norma": "1025907", "numero_fuente": "39971", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-05-28", "vigencias": [{"desde": "2011-05-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-05-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-05-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincula