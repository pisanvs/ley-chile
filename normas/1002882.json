{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8666385}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;1.585, de 29 de abril de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD COMERCIAL QUELL&#xD3;N VIEJO LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, para instalar y operar planta ubicada en Sector Rural Quell&#xF3;n Viejo, Quell&#xF3;n, Chilo&#xE9;, X Regi&#xF3;n, para elaborar en l&#xED;neas de procesos Cocido, Fresco enfriado, Fresco refrigerado, Congelado y Alga seca, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div></div>", "i": 8666386}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de abril de 2009.- Mar&#xED;a &#xC1;ngela Barbieri Bellolio, Subsecretaria de Pesca (S).</div></div>", "i": 8666387}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1585 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-1585 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-04-29", "doble_articulado": false, "id_norma": "1002882", "numero_fuente": "39375", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-06-01", "vigencias": [{"desde": "2009-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":