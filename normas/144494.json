{"html": [{"t": "<div><div class=\"p\">NOTIFICACION </div></div>", "i": 6194392}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xB0; 38, de fecha 05 de Febrero de 1987, del SERVIU V Regi&#xF3;n de Valpara&#xED;so, se dispuso expropiaci&#xF3;n conforme art. 87 Ley 8.946 y DL N&#xB0; 2.186, de 1978, de parte de inmueble ubicado calle Ramaditas N&#xB0; 890, rol aval&#xFA;o N&#xB0; 6096-12, comuna de Valpara&#xED;so, aparentemente de dominio de Jos&#xE9; Rojas Pulgar. Comisi&#xF3;n tasadora integrada por srs. Osvaldo Mu&#xF1;oz Quintana, arquitecto; Edmundo Bravo Ubilla, arquitecto, y Pablo Cari&#xE1; Giurici, constructor civil, seg&#xFA;n informe de fecha 09 de Diciembre de 1986, fij&#xF3; monto provisional indemnizaci&#xF3;n en la suma de $ 19.200. Indemnizaci&#xF3;n se pagar&#xE1; de contado.</div><br></div>", "i": 6194393}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director SERVIU V Regi&#xF3;n.</div><br></div>", "i": 6194394}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "38", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-38"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SUBSECRETARIA DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAISO"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-05", "doble_articulado": false, "id_norma": "144494", "numero_fuente": "32699", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-02-16", "vigencias": [{"desde": "1987-02-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-02-16", "fin_vigencia": ""},