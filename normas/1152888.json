{"html": [{"t": "<div><div class=\"p\">CONSTRUCCION DE CAMINO Y PUENTE CARRIL EN EL ESTERO DE PAINE.</div><br><div class=\"p\">&nbsp; &nbsp;  AVISO OFICIAL.</div></div>", "i": 10237498}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Gobierno ha dispuesto se construya un puente capaz de ser transitado en carruajes, sobre el estero de la Angostura de Paine, y que se compongan 25 cuadras de camino al norte y otras tantas al sur del mismo estero, d&#xE1;ndoles igual comodidad. Los que quieran emprender esta obra pueden dirijir sus propuestas al Ministerio del interior desde esta fecha hasta el d&#xED;a 1.&#xB0; de julio. </div></div>", "i": 10237499}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, Junio 1.&#xB0; de 1827.</div></div>", "i": 10237500}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "Aviso-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONSTRUCCION DE CAMINO Y PUENTE CARRIL EN EL ESTERO DE PAINE.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1827-06-01", "doble_articulado": false, "id_norma": "1152888", "numero_fuente": "1827", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1827-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1827-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1827-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-06-03", "fecha_version": "1827-06-01", "fecha_actualizacion_texto": "2021-