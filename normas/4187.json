{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 35.- Santiago, 13 de Marzo de 1931.- Vista la nota n&#xFA;mero 186, de la Direcci&#xF3;n de Educaci&#xF3;n F&#xED;sica y en uso de las facultades que me confiere la ley n&#xFA;mero 4,945.</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 7116089}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; 1.o Red&#xFA;cese a nueve mil pesos anuales ($ 9,000), la renta del cargo de Administrador de la Piscina Temperada Escolar, consultado en 07-07-01.</div><div class=\"p\">&nbsp; &nbsp; 2.o Trasp&#xE1;sese la suma de seis mil pesos ($ 6,000), que de acuerdo con el n&#xFA;mero anterior quedar&#xE1; sin invertir en 07-07-01, al &#xED;tem 07-07-04-a y reempl&#xE1;zase la glosa del n&#xFA;mero 2) de esta letra por la siguiente:</div><div class=\"p\">&nbsp; &nbsp; 2) Para contratar los siguientes empleados de la Revista de Educaci&#xF3;n F&#xED;sica:</div><div class=\"p\"> Uno del grado 13.o____________&nbsp; &nbsp; $&nbsp; 12,000</div><div class=\"p\"> Uno del grado 12.o____________&nbsp; &nbsp; &nbsp; &nbsp; 6,000</div><br></div>", "i": 7116090}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n y comun&#xED;quese.- C. IBA&#xD1;EZ C.- Alberto Edwards.- Carlos Castro Ruiz.</div><br></div>", "i": 7116091}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "35", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-35"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O", "1931", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-03-13", "doble_articulado": false, "id_norma": "