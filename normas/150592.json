{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6216566}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 38, de 18 de Febrero de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Atacama, se autoriza a Walker Contreras Bordones para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6216567}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Pablo Gabriel Rojas Valenzuela, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de Atacama subrogante.</div><br></div>", "i": 6216568}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "38 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-38 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-18", "doble_articulado": false, "id_norma": "150592", "numero_fuente": "32787", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-04", "vigencias": [{"desde": "1987-06-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-06-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente