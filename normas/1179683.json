{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xB0; 1.758 EXENTA, DE 24 DE JUNIO DE 2022</div></div>", "i": 10353910}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 1.942, del 18 de julio de 2022, del Director Nacional de Aduanas, se rectific&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1178247&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta del mismo origen N&#xB0; 1.758, del 24 de junio de 2022</a>, la cual extiende la vigencia de instrucciones correspondientes al rotulado de calzado, con la finalidad de precisar su contenido.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10353911}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de julio de 2022.- Gustavo Poblete Morales, Director Nacional de Aduanas (S).</div><div class=\"p\"> </div><br></div>", "i": 10353912}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1942 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1942 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCIÓN N° 1.758 EXENTA, DE 24 DE JUNIO DE 2022", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2167509", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-07-18", "doble_articulado": false, "id_norma": "1179683", "numero_fuente": "43321", "tipo_version": "3", "tipo_version_s": "Única", "fech