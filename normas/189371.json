{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 522 EXENTO, DE 2001</div><br><br></div>", "i": 7285828}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 522, de fecha 7 de agosto de 2001 del Ministerio de Educaci&#xF3;n, se autoriza a la sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica Escuela Superior de Administraci&#xF3;n de Negocios del Norte - Esane del Norte, para impartir plan y programas de estudios aprobados para la instituci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, a partir del a&#xF1;o 2000:</div><br><div class=\"p\">Sede N&#xBA; 3 - Calama</div><br><div class=\"p\">Carrera: Relaciones P&#xFA;blicas</div><div class=\"p\">T&#xED;tulo:&nbsp; T&#xE9;cnico en Relaciones P&#xFA;blicas</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp;  (Decreto exento N&#xBA; 272 del 02.05.95) </div></div>", "i": 7285829}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de agosto de 2001.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7285830}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "522 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-522 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 522 EXENTO, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-08-07", "fecha_derogacion": "2020-12-16", "doble_articulado": false, "id_norma": "189371", "numero_fuente": "37063", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2001-09-15", "vigencias": [{"desde": "2020-12-16", "hasta": "", "tipo_version": "2",