{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6269709}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 234, de 26 de Febrero de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se declara la caducidad de la resoluci&#xF3;n No. 95 de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don PATRICIO FUENTES LEON Y COMPA&#xD1;IA LIMITADA, RUT No. 79.769.340-5, domiciliado en la ciudad de Santiago, para desarrollar actividades pesqueras de transformaci&#xF3;n, de conformidad al art&#xED;culo 7&#xB0; del Decreto No. 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 6269710}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de Febrero de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 6269711}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "234", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-234"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-02-26", "doble_articulado": false, "id_norma": "166965", "numero_fuente": "33909", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-03-04", "vigencias": [{"desde": "1991-03-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-03-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-03-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v