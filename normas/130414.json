{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.456, DE 1988 </div><br><br></div>", "i": 7244481}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.456 de fecha 03 de junio de 1988, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se aprobaron las modificaciones introducidas a las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n Instituto Chileno Brit&#xE1;nico de Cultura de Vi&#xF1;a del Mar, las que podr&#xE1;n aplicarse a contar del primer semestre acad&#xE9;mico 1988. </div></div>", "i": 7244482}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 05 de Julio de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7244483}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1456 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1456 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.456, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1988-06-03", "fecha_derogacion": "2001-05-29", "doble_articulado": false, "id_norma": "130414", "numero_fuente": "33123", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1988-07-18", "vigencias": [{"desde": "2001-05-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1988-07-18", "hasta": "2001-05-28", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2001-05-29", "fin_vigencia": ""}, "vigencias_version_norma