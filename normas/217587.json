{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6449665}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.684, de 29 de octubre de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a ISMAEL MADARIAGA OLIVARES para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en sector Punta Salinas s/n, Cha&#xF1;aral, III Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso que se indica, los siguientes recursos hidrobi&#xF3;logicos: Alga Seca: Chasc&#xF3;n, Huiro negro y Chasc&#xF3;n, Huiro palo, Palo colorado. </div></div>", "i": 6449666}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de octubre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6449667}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2684 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2684 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-29", "doble_articulado": false, "id_norma": "217587", "numero_fuente": "37716", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-11-21", "vigencias": [{"desde": "2003-11-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-11-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-11-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2003-11-