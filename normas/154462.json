{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7260484}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 138, de 19 de enero de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; PESQUERA EL GOLFO S.A., para ampliar actividades pesqueras extractivas con la nave &apos;&apos;Vulcano&apos;&apos;, matr&#xED;cula 2919, autorizada por las resoluciones N&#xBA; 831 de 1997 y N&#xBA; 1642 de 1998, ambas de esta Subsecretar&#xED;a y podr&#xE1; realizar actividades pesqueras extractivas con la nave &apos;&apos;Vulcano&apos;&apos;, con arrastre de media agua en el litoral de la V a la VII y entre la IX y la X Regiones, por fuera de las 60 millas marinas, sobre los siguientes recursos hidrobiol&#xF3;gicos: Jurel, Sardina com&#xFA;n, Anchoveta, Caballa y Merluza de cola.</div><br></div>", "i": 7260485}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de enero de 2000.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 7260486}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "138", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-138"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA EL GOLFO", "ACTIVIDADES PESQUERAS", "NAVE VULCANO", "JUREL", "SARDINA COMUN", "ANCHOVETA", "CABALLA", "MERLUZA DE COLA", "LITORAL REGIONES", "PESCA ARRASTRE", "AUTORIZA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-01-19", "fecha_derogacion": "2011-01-18", "doble_articulado": false, "id_norma": "154462", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-02-03", "