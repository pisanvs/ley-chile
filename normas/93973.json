{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 196, DE 1988 </div></div>", "i": 7228335}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 196 de 23 de diciembre de 1988 se ha modificado, a contar del a&#xF1;o escolar 1989, el art&#xED;culo 1&#xB0; del decreto supremo exento de Educaci&#xF3;n N&#xB0; 230 de 1985, que aprob&#xF3; planes y programas especiales de estudio de segundo ciclo de Educaci&#xF3;n Media en la modalidad T&#xE9;cnico - Profesional, para el Liceo Industrial B N&#xB0; 16 de Osorno, Xa. Regi&#xF3;n de Los Lagos.</div><br></div>", "i": 7228336}, {"t": "<div><div class=\"p\">Santiago, 6 de Enero de 1989.- Paulina Dittborn Cordua, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7228337}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "196 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-196 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 196, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-23", "doble_articulado": false, "id_norma": "93973", "numero_fuente": "33288", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-02-02", "vigencias": [{"desde": "1989-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-02-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-02-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}],