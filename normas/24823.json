{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aumenta la pensi&#xF3;n de que disfruta la se&#xF1;ora Juana R. Rodr&#xED;guez M., ex-telegrafista de 3.a clase de La Serena.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 8277580}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Aum&#xE9;ntase, por gracia, a $ 86.66 mensuales, la pensi&#xF3;n de que disfruta actualmente la se&#xF1;ora Juana R. Rodr&#xED;guez M., ex-telegrafista de 3.a clase de La Serena.</div><br></div>", "i": 8277581}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, cinco de Noviembre de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Enrique Berm&#xFA;dez. </div></div>", "i": 8277582}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4674", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4674"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUMENTA LA PENSIÓN DE QUE DISFRUTA LA SEÑORA JUANA R. RODRÍGUEZ M., EX TELEGRAFISTA DE 3A CLASE DE LA SERENA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUANA R. RODRIGUEZ M", "PENSION POR GRACIA", "REAJUSTE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-11-05", "doble_articulado": false, "id_norma": "24823", "numero_fuente": "15517", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-11-08", "vigencias": [{"desde": "1929-11-08", "hasta": "", "tipo_version": "3", "tipo_version_s"