{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6282955}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.052, de 13 de junio de 2000, modif&#xED;case la resoluci&#xF3;n N&#xBA; 99 del a&#xF1;o 2000, de esta Subsecretar&#xED;a, que fij&#xF3; la n&#xF3;mina de armadores y embarcaciones que cumplen con los requisitos legales para operar en la unidad de pesquer&#xED;a de Anchoveta Engraulis ringens y Sardina espa&#xF1;ola&nbsp; Sardinops Sagax, declaradas en estado de plena explotaci&#xF3;n y sometidas a dicho r&#xE9;gimen de administraci&#xF3;n, en el litoral de las III y IV Regiones, en el &#xE1;rea se&#xF1;alada en sus respectivas autorizaciones, al 30 de junio de 1999, en el sentido de incorporar lo siguiente:</div><br><div class=\"p\">Nombre del Armador&nbsp; &nbsp; &nbsp; &nbsp;  Nave</div><br><div class=\"p\">Gajardo Venegas, Mario&nbsp; &nbsp;  Noel I</div><br></div>", "i": 6282956}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de junio de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6282957}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1052", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1052"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-06-13", "fecha_derogacion": "2000-08-02", "doble_articulado": false, "id_norma": "171201", "numero_fuente": "36693", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-06-20", "vigencias": [{"desde": "2000