{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 357 EXENTA, DE 2002 </div></div>", "i": 6403509}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 357, de 14 de enero de 2002, se ha aprobado al Colegio La Dehesa de Lo Barnechea de Santiago el siguiente plan de estudio para 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2002.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 6403510}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de enero de 2002.- Juan Ruz Ruz, Jefe Divisi&#xF3;n Educaci&#xF3;n General.</div><br></div>", "i": 6403511}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "357 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-357 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 357 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-01-14", "doble_articulado": false, "id_norma": "204833", "numero_fuente": "37413", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-11-20", "vigencias": [{"desde": "2002-11-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-11-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-11-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2002-11-20", "fecha_version"