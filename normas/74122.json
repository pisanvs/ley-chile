{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6040916}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 6,34% anual durante el mes de junio de 1997.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad con lo dispuesto en el N&#xBA; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de junio de 1997, fue de 6,32% anual. </div></div>", "i": 6040917}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 2 de julio de 1997.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6040918}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA DE INTERES PROMEDIO", "OPERACIONES DE CREDITO DE DINERO", "CAPTACION", "TIP"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-02", "doble_articulado": false, "id_norma": "74122", "numero_fuente": "35808", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-07-05", "vigencias": [{"desde": "1997-07-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-07-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-07-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie