{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6374199}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n n&#xFA;mero 538, de 12 de marzo de 2002, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 6&#xBA; de la resoluci&#xF3;n N&#xBA; 37 de 2002, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO&nbsp; para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Distribuci&#xF3;n espacio temporal de las capturas de Jurel en la I y II Regi&#xF3;n (Primera Etapa, 2002)&quot;, en el sentido de reemplazar las naves &quot;La Huaica&quot; y &quot;Mar del Plata&quot; por la nave &quot;Don Ernesto Ayala M&#xE1;fil&quot;, todas de propiedad de Corpesca S.A., de la n&#xF3;mina de naves participantes en la se&#xF1;alada pesca de investigaci&#xF3;n.</div><br></div>", "i": 6374200}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de marzo de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6374201}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "538", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-538"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-12", "doble_articulado": false, "id_norma": "195977", "numero_fuente": "37219", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-03-25", "vigencias": [{"desde": "2002-03-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia