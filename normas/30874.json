{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ORDENANZA N&#xB0; 01/93 SOBRE DERECHOS MUNICIPALES POR PERMISOS, CONCESIONES Y SERVICIOS MUNICIPALES </div></div>", "i": 9047388}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Modifica art&#xED;culos y valores por pago derechos en lo que a continuaci&#xF3;n se indica:</div><div class=\"p\"> TITULO IV</div><div class=\"p\">&nbsp; &nbsp; Reempl&#xE1;zase el concepto indicado en el Art&#xED;culo 12, N&#xB0; 17 de la Ordenanza del rubro, por el siguiente:</div><br><div class=\"p\"> Examen psicot&#xE9;cnico y psicom&#xE9;trico para aquellas</div><div class=\"p\"> empresas que lo requieren, por postulante___25% U.T.M.</div><br><div class=\"p\">&nbsp; TITULO VI</div><div class=\"p\">Modif&#xED;case el valor indicado en el art&#xED;culo 16&#xB0; N&#xB0; 14,</div><div class=\"p\">que dice: 0,05 U.T.M. debe decir___________0,5% U.T.M.</div><br></div>", "i": 9047389}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "1", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "ORZ-1"}], "organismos": ["MUNICIPALIDAD DE ANTOFAGASTA"], "titulo_norma": "ORDENANZA N° 01/93 SOBRE DERECHOS MUNICIPALES POR\nPERMISOS, CONCESIONES Y SERVICIOS MUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "DERECHOS MUNICIPALES", "MUNICIPALIDAD ANTOFAGASTA", "ORDENANZA MUNICIPAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "30874", "numero_fuente": "34506", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-03-03", "vigencias": [{"desde": "1993-03-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-03-03", "fin_vigencia": ""}, "vigencias_versio