{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTOS DE RESOLUCIONES </div></div>", "i": 8288985}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 764, de 27 de Junio de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorrogase por 30 d&#xED;as, a contar de la fecha de esta Resoluci&#xF3;n, el plazo otorgado a don JOSE SEGUNDO QUEZADA JEREZ, R.U.T. N&#xB0; 4.598.947-K, domiciliado en calle Manuel Montt N&#xB0; 854, Coronel, en el numeral 4 respectivamente por las Resoluciones N&#xB0; 1888, de 1989 y N&#xB0; 272, de 1990, ambas de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8288986}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 27 de Junio de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8288987}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "764", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-764"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "EXTRACTOS DE RESOLUCIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JOSE SEGUNDO QUEZADA JEREZ", "PESCA", "PLAZO", "PRORROGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-06-27", "doble_articulado": false, "id_norma": "31661", "numero_fuente": "34018", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-07-16", "vigencias": [{"desde": "1991-07-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-07-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-07-1