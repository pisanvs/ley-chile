{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACI&#xD3;N</div><br></div>", "i": 7354606}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 823, de 10 de septiembre de 2007, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n parcial, conforme DL N&#xBA; 2.186 de 1978, del inmueble ubicado en Carmen 718, presunto rol de aval&#xFA;o N&#xBA; 2786-51, comuna de Santiago, de aparente dominio de IHL Clericus Juan Guillermo; correspondiente al lote N&#xBA; 77, del proyecto vial &quot;Habilitaci&#xF3;n Corredor Transporte P&#xFA;blico Avda. Las Industrias&quot;. Comisi&#xF3;n integrada por In&#xE9;s Ot&#xE1;rola Castillo, arquitecto; Patricia Morales Rivera, constructor civil, y Gast&#xF3;n Bianchi Aqueveque, constructor civil, seg&#xFA;n informe de 25 de junio de 2007, fij&#xF3; monto provisional indemnizaci&#xF3;n en $25.545.000, pagadera al contado.</div><br></div>", "i": 7354607}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 7354608}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "823", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-823"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-09-10", "doble_articulado": false, "id_norma": "265096", "numero_fuente": "38875", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-10-01", "vigencias": [{"desde": "2007-10-01", "hasta": "", "tipo_ve