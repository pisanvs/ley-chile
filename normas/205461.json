{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6405787}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n que suscribe,</div><div class=\"p\">certifica que la carrera de &quot;Ingenier&#xED;a de Ejecuci&#xF3;n</div><div class=\"p\">de en Inform&#xE1;tica&quot; que ofrece el Instituto Profesional</div><div class=\"p\">de Providencia, autorizada seg&#xFA;n Certificado N&#xBA; 82 de</div><div class=\"p\">1985, ha cumplido los requisitos establecidos en el</div><div class=\"p\">Art&#xED;culo 14&#xBA; del DFL N&#xBA; 5 de 1981 del Ministerio de Educaci&#xF3;n, seg&#xFA;n lo certifica la Universidad T&#xE9;cnica Federico Santa Mar&#xED;a, quien actu&#xF3; como entidad examinadora de los alumnos de dicha carrera.</div><br><div class=\"p\">&nbsp; &nbsp;  El Instituto Profesional est&#xE1; en condiciones de otorgar independientemente el t&#xED;tulo correspondiente a la carrera de &quot;Ingenier&#xED;a de Ejecuci&#xF3;n de en Inform&#xE1;tica&quot;, a contar del a&#xF1;o 1990.</div><br></div>", "i": 6405788}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de Enero de 1991.</div><div class=\"p\">&nbsp; &nbsp;  RAUL ALLARD NEUMANN Subsecretario de Educaci&#xF3;n </div></div>", "i": 6405789}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-24", "doble_articulado": false, "id_norma": "205461", "numero_fuente": "33893", "tipo_version": "3", "tipo_version