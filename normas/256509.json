{"html": [{"t": "<div><div class=\"p\">AUTORIZA A RECEPTOR ELECTRONICO</div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA;162 de 13 de diciembre, que autoriza a Organismo P&#xFA;blico como receptor electr&#xF3;nico. </div></div>", "i": 6593822}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como receptor de documentos tributarios electr&#xF3;nicos, a contar del mes de diciembre de 2006, a organismo p&#xFA;blico RUT 69.255.200-8.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de diciembre de 2006. </div></div>", "i": 6593823}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "162 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-162 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A RECEPTOR ELECTRONICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-12-13", "doble_articulado": false, "id_norma": "256509", "numero_fuente": "38642", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-12-19", "vigencias": [{"desde": "2006-12-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-12-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-12-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones