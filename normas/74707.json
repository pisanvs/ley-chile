{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 352 EXENTO, DE 1997 </div></div>", "i": 7209611}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento N&#xBA; 352 de fecha 26 de marzo de 1997 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Centro de Estudios Tur&#xED;sticos CET, las adecuaciones al plan y programas de estudios de la carrera de Turismo, modific&#xE1;ndose en consecuencia, el Decreto Exento N&#xBA; 516 de 1995 y Decreto Exento N&#xBA; 231 de 1996, respectivamente. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1997.</div><br></div>", "i": 7209612}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de abril de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7209613}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "352 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-352 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 352 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO DE FORMACION TECNICA", "CENTRO DE ESTUDIOS TURISTICOS CET", "PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-26", "doble_articulado": false, "id_norma": "74707", "numero_fuente": "35835", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-08-06", "vigencias": [{"desde": "1997-08-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-08-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-08-06", "fin_vigencia": "", "ti