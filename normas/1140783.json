{"html": [{"t": "<div><br><br><div class=\"p\">SUPRESION DE LA ESCRIBANIA MAYOR DE GOBIERNO</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Agosto 2 de 1824.</div></div>", "i": 10093544}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  No necesitando el Gobierno Supremo de peculiar escribano para su despacho, que exclusivamente se desempe&#xF1;a por los respectivos Ministros de Estado segun el ramo a que corresponden los negocios, queda por consiguiente suprimida desde esta fecha la plaza de escribano mayor de Gobierno. T&#xF3;mese razon de este decreto e imprimase en el Boletin.</div><br></div>", "i": 10093545}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE</div><br><div class=\"p\">&nbsp; &nbsp;  F.A. Pinto.</div><br></div>", "i": 10093546}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "SUPRESION DE LA ESCRIBANIA MAYOR DE GOBIERNO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-08-02", "doble_articulado": false, "id_norma": "1140783", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "", "vigencias": [{"desde": "1824-08-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-08-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-08-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2020-01-17", "fecha_version": "1824-08-02", "fecha_actualizacion_texto