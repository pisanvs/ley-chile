{"html": [{"t": "<div><div class=\"p\">SOLICITA CONSTITUCION LEGAL DEL &quot;PARTIDO LIBERAL&quot; EN LA CUARTA REGION</div><br><br></div>", "i": 7219794}, {"t": "<div><div class=\"p\">Eduardo D&#xED;az Herrera y Hern&#xE1;n Villalobos Chand&#xED;a, en representaci&#xF3;n de la entidad pol&#xED;tica denominada Partido Liberal, han solicitado la constituci&#xF3;n legal del Partido en la IV Regi&#xF3;n de Coquimbo acompa&#xF1;ando 1.296 fichas de afiliaciones.</div><div class=\"p\">Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 11&#xB0; de la ley No. 18.603, por resoluci&#xF3;n O No.</div><div class=\"p\">2.904 de fecha 15 de Septiembre de 1992.-</div><br></div>", "i": 7219795}, {"t": "<div><div class=\"p\">Santiago, 15 de Septiembre de 1992.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director Servicio Electoral.</div><br></div>", "i": 7219796}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2904", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-2904"}, {"tipo": "3", "numero": "0-2904", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-0-2904"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCION LEGAL DEL PARTIDO LIBERAL EN LA CUARTA REGION SEÑALA, SEGUN ALTERNATIVA DE POSTULACION EN PROCESO DE SELECCION EN COMUNA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-09-15", "doble_articulado": false, "id_norma": "84708", "numero_fuente": "34385", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-10-08", "vigencias": [{"desde": "1992-10-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vig