{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7294987}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.248, de 18 de octubre de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a AQUAPURO S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluci&#xF3;n N&#xBA; 1.154 de 1994, de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Industriales N&#xBA; 665, Huechuraba, Santiago, Regi&#xF3;n Metropolitana, en las l&#xED;neas de proceso que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Fresco-Enfriado, Fresco Refrigerado y Congelado: Hirame y Catfish.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1.976 del 2002, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 7294988}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de octubre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7294989}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2248", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2248"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-10-18", "doble_articulado": false, "id_norma": "204145", "numero_fuente": "37399", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-11-04", "vigencias": [{"desde": "2002-11-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-11-0