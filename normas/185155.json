{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6334443}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA;269 de fecha 30 de marzo de 2001, se expropi&#xF3; los lotes de terreno N&#xBA;s. 130, 131, 132 y 132-B, superficie 3.059, 160, 9.968,1 y 200 m&#xB2; respectivamente, rol de aval&#xFA;o 515-38, comuna de Carahue, para la obra &apos;&apos;Camino Costero Tir&#xFA;a-Carahue, Tramo Bajo Yupehue-Cruce Puyanhue, Km. 23.348,46 al Km.</div><div class=\"p\">45.286,79, correspondiente al Subtramo V Km. 39.858 al Km. 45.286,79&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Carlos Rebolledo Roa, ascendente a la cantidad de $3.737.211.</div><br></div>", "i": 6334444}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6334445}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "269 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-269 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-30", "doble_articulado": false, "id_norma": "185155", "numero_fuente": "36962", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-15", "vigencias": [{"desde": "2001-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_in