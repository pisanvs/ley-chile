{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10192499}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.432 de 29 de diciembre 2020 de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n total, conforme art&#xED;culo 51 ley 16.391, del Lote 2.3 correspondiente al inmueble ubicado en calle 6 Sur N&#xB0; 1390 Costanera, Rol de Aval&#xFA;o N&#xB0; 470-23 Comuna Talca, superficie 118,624 metros cuadrados, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Jacqueline del Pil Carter Norambuena. Comisi&#xF3;n integrada por peritos Mar&#xED;a Carolina Letelier Bopp, arquitecto; &#xC1;lvaro Hern&#xE1;n Vergara Mej&#xED;as, ingeniero civil industrial; y Claudia Poblete Ram&#xED;rez, arquitecto; seg&#xFA;n informe de tasaci&#xF3;n evacuado con fecha 28 de diciembre de 2020, fij&#xF3; monto provisional indemnizaci&#xF3;n en $47.186.590.-, pagados al contado.- </div></div>", "i": 10192500}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Claudio Daneck Mu&#xF1;oz, Director (S) Serviu Regi&#xF3;n del Maule.</div><br></div>", "i": 10192501}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2432 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2432 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "VII REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1878652", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-12-29", "doble_articulado": false, "id_norma": "1154685", "numero_fuente": "42855", "tipo_