{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6470425}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 812, de 16 de marzo de 2004, de esta Subsecretar&#xED;a, rectif&#xED;case el numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA; 2.986 de 2003, que autoriz&#xF3; a PESQUERA ITATA S.A., para desarrollar actividades pesqueras extractivas con la nave &quot;Caupolic&#xE1;n&quot;, en la forma y condiciones que la misma resoluci&#xF3;n indica, en el sentido de incorporar la operaci&#xF3;n en el &#xE1;rea mar&#xED;tima de la VIII Regi&#xF3;n, con arte de cerco, por fuera del &#xE1;rea de resera artesanal, sobre el recurso hidrobiol&#xF3;gico Sardina com&#xFA;n.</div><br></div>", "i": 6470426}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de marzo de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6470427}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "812 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-812 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-03-16", "fecha_derogacion": "2004-10-22", "doble_articulado": false, "id_norma": "222831", "numero_fuente": "37817", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-03-22", "vigencias": [{"desde": "2004-10-22", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-03-22", "hasta": "2004-10-21", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inic