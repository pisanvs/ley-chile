{"html": [{"t": "<div><div class=\"p\">MODIFICA COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10375919}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.717, de fecha 19 de octubre de 2022, de la Directora Nacional de Aduanas, se reemplaza el quinto p&#xE1;rrafo del numeral 8.10 del Anexo 18 del <a href=\"https://www.leychile.cl/Navegar?idNorma=248540&amp;idParte=&amp;idVersion=\">Compendio de Normas Aduaneras</a>, respecto a las instrucciones para la tramitaci&#xF3;n de declaraciones anticipadas de mercanc&#xED;as sujetas a derechos espec&#xED;ficos amparadas en un MIC/DTA.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp;  La resoluci&#xF3;n comenzar&#xE1; a regir desde la publicaci&#xF3;n del presente extracto en el Diario Oficial.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10375920}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de octubre de 2022.- Alejandra Arriaza Loeb, Directora Nacional de Aduanas.</div><br></div>", "i": 10375921}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2717 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2717 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2208877", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-10-19", "doble_articulado": false, "id_norma": "1183610", "nume