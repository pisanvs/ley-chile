{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6147014}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 1.317 de 03 de.08.88, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a Sector Excluido y Sector Expropiado predio &quot;Fundo Coihueco&quot; de la comuna de Coihueco, Octava Regi&#xF3;n y Derechos Aprovechamiento Aguas que corresponde a parcelas N&#xB0;s. 1 a la 6 y sitios Nos. 1 al 6 del Proyecto de Parcelaci&#xF3;n &quot;Campo Nuevo&quot; formado por predio se&#xF1;alado. Los Derechos de Agua se extraen del Embalse Coihueco; Derrames Miradores; canal El Cabro o Vertiente Cabrito; Vertiente Campo Nuevo y canal EI Llano del estero Paso Ancho. Publicaci&#xF3;n hecha conforme Art. 13 Ley No.</div><div class=\"p\">18.377.-</div><br></div>", "i": 6147015}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6147016}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1317 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1317 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-03", "doble_articulado": false, "id_norma": "129441", "numero_fuente": "33150", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-08-16", "vigencias": [{"desde": "1988-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-08-16", "fin_vigencia": ""}, "vig