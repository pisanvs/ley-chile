{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7299611}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 897, de 30 de abril de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA AQUAPURO S.A. para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluciones N&#xBA; 1.154 de 1994&nbsp; y&nbsp; N&#xBA; 2.248 de 2002, ambas de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Industriales N&#xBA; 665, Huechuraba, Santiago, en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Fresco-Enfriado, Fresco-Refrigerado y Congelado: Corvina y Turbot. </div></div>", "i": 7299612}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de abril de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7299613}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "897", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-897"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-04-30", "doble_articulado": false, "id_norma": "210477", "numero_fuente": "37563", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-05-20", "vigencias": [{"desde": "2003-05-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-05-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-05-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vin