{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.634 EXENTA, DE 1999 </div><br></div>", "i": 6211901}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta del Ministerio de Transportes y Telecomunicaciones N&#xBA; 1.634 de 17.11.1999, se ha modificado el art&#xED;culo 12 de las bases generales para el otorgamiento de concesiones de radiodifusi&#xF3;n sonora en frecuencia modulada, amplitud modulada y m&#xED;nima cobertura, correspondiente al concurso p&#xFA;blico del tercer cuatrimestre de 1999, en el sentido de reemplazar la fecha de recepci&#xF3;n de las solicitudes para el d&#xED;a lunes 27 de diciembre de 1999. El lugar y horario de recepci&#xF3;n de las solicitudes se mantienen inalterables. La presente publicaci&#xF3;n se har&#xE1; nuevamente el d&#xED;a 15 de diciembre de 1999.-</div><br></div>", "i": 6211902}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Subsecretaria de Telecomunicaciones.</div><br></div>", "i": 6211903}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1634 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1634 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TELECOMUNICACIONES"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.634 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-11-17", "doble_articulado": false, "id_norma": "149330", "numero_fuente": "36539", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-12-15", "vigencias": [{"desde": "1999-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-12-15"