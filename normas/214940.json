{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6440638}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 74, del Ministerio de</div><div class=\"p\">Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, rech&#xE1;zase el recurso</div><div class=\"p\">jer&#xE1;rquico interpuesto por ALIMENTOS SAN ANTONIO S.A. y</div><div class=\"p\">por PACIFIC SALMON S.A. en contra de la resoluci&#xF3;n N&#xBA;</div><div class=\"p\">1.902, de 2002, de la Subsecretar&#xED;a de Pesca, en virtud</div><div class=\"p\">de haber sido dictadas sentencias definitivas que</div><div class=\"p\">rechazaron las acciones judiciales destinadas a obtener</div><div class=\"p\">la declaraci&#xF3;n de la nulidad del acto administrativo</div><div class=\"p\">citado, ello de conformidad con lo dispuesto en los</div><div class=\"p\">art&#xED;culos 6&#xBA; y 74 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica.</div><br></div>", "i": 6440639}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de septiembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6440640}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "74 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-74 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-09-01", "doble_articulado": false, "id_norma": "214940", "numero_fuente": "37665", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-22", "vigencias": [{"desde": "2003-09-22", "hasta