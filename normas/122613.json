{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8332800}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.020, de 24 de julio de 1998, de esta Subsecretar&#xED;a, autor&#xED;zase a PROCESADORA DE PRODUCTOS DEL MAR S.A. para ampliar actividades pesqueras autorizadas por resoluciones N&#xBA; 943, de 1992, N&#xBA; 85, de 1993,&nbsp; y N&#xBA; 488, de 1996, de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Los Talleres N&#xBA; 1955, Barrio Industrial, Coquimbo, IV Regi&#xF3;n, la l&#xED;nea de elaboraci&#xF3;n que se indica, el siguiente recurso hidrobiol&#xF3;gico: Congelado: Langostino colorado.</div><br><div class=\"p\">&nbsp; &nbsp;  El recurso Langostino colorado deber&#xE1; provenir de agentes autorizados por permiso extraordinario de la Subsecretar&#xED;a.</div><br></div>", "i": 8332801}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de julio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8332802}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1020", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1020"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PROCESADORA DE PRODUCTOS DELMAR S.A.", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-24", "doble_articulado": false, "id_norma": "122613", "numero_fuente": "36130", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-08-03", "vigencias": [{"desde": "1998-08-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ú