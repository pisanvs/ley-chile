{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6149004}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xB0;2.086, de 30 de octubre de 1998, se expropiaron los lotes de terreno N&#xB0;s 23, 29, 31, 32 y 44, superficies 350, 500, 100, 88 y 180 m2., respectivamente, roles de aval&#xFA;o 1234-23, 1240-5 y 1253-9 comuna de Ancud, para la obra Camino Ancud-Quetalmahue, Rol W-20 y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Arturo Oyarzo C&#xE1;rcamo, Santos Astorga Astorga y Horacio Vel&#xE1;squez Ampuero, ascendentes a las cantidades de $415.960.- para el lote 23, $596.073.- para los lotes 29, 31 y 32 y $853.558.- para el lote 44.-</div><br></div>", "i": 6149005}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6149006}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2086", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2086"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-10-30", "doble_articulado": false, "id_norma": "130055", "numero_fuente": "36264", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-01-15", "vigencias": [{"desde": "1999-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "1999-01-18", "fecha_vers