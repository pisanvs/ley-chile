{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DECLARA INCLUIDO EN LOS BENEFICIOS DEL ARTICULO 1.&#xB0; DE LA LEY N.&#xB0; 7,717 A DON ARMANDO URZUA L.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5965512}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1.&#xB0; Decl&#xE1;rase inclu&#xED;do en beneficios del</div><div class=\"p\">art&#xED;culo 1.&#xB0; de la ley N.&#xB0; 7,717, de 29 de Octubre de 1943, al Capit&#xE1;n don Armando Urz&#xFA;a Lavin.</div><br></div>", "i": 5965513}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2.&#xB0; Esta ley regir&#xE1; desde su publicaci&#xF3;n en el Diario Oficial&quot;.</div><br></div>", "i": 5965514}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica. Santiago, veintisiete de Octubre de mil novecientos cuarenta y cuatro.- ALFONSO QUINTANA BURGOS.- A. Carrasco C.</div><br></div>", "i": 5965515}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "7997", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-7997"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL"], "titulo_norma": "DECLARA INCLUIDO EN LOS BENEFICIOS DEL ARTICULO 1.°\nDE LA LEY N.° 7,717 A DON ARMANDO URZUA L.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1944-10-27", "doble_articulado": false, "id_norma": "25716", "numero_fuente": "20009", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1944-11-17", "vigencias":