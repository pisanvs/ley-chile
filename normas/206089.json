{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7296196}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.867, de 11 de diciembre de 2002, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 972 de 1987, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a&nbsp; CIDEF S.A. para desarrollar actividades con la nave Pablo, en el &#xE1;rea mar&#xED;tima de la II Regi&#xF3;n, y sobre Sardina espa&#xF1;ola, en el &#xE1;rea mar&#xED;tima de las III y IV regiones en virtud de lo dispuesto en la letra b) del art&#xED;culo 143 de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7296197}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de diciembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7296198}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2867", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2867"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-11", "doble_articulado": false, "id_norma": "206089", "numero_fuente": "37439", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-20", "vigencias": [{"desde": "2002-12-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-12-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-12-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MO