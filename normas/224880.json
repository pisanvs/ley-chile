{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6743538}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. N&#xBA; 734, de 30 de noviembre de 1995, se expropiaron los lotes de terreno N&#xBA;s. 27, 57 y 60, superficies 8.497 m2., 1.500 m2., y 8.310 m2., roles de aval&#xFA;o 1035-111, 301-82 y 301-42, comunas de Maip&#xFA; y Pe&#xF1;aflor, para la obra Camino Autopista Santiago - San Antonio, sector Empalme I. Riquelme - Bif. Malloco y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Ernesto Sanhueza Araya, Luis Alberto Ortiz Ruz y Eduardo S&#xE1;ez Barrios, ascendente a las cantidades de $ 37.018.065.- $12.376.151.- y 41.982,635.-</div><div class=\"p\">respectivamente.</div><br></div>", "i": 6743539}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6743540}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "734", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-734"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-11-30", "doble_articulado": false, "id_norma": "224880", "numero_fuente": "35381", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-02-01", "vigencias": [{"desde": "1996-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ing