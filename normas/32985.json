{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6005595}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 88 de 31 de Marzo de 1993, del Serviu V Regi&#xF3;n de Valpara&#xED;so, se dispuso expropiaci&#xF3;n conforme art&#xED;culo 87 Ley 8.946 de Pavimentaci&#xF3;n Comunal y D.L. N&#xB0; 2.186, de 1978, de parte de lote 542 de calle Catemu, comuna Vi&#xF1;a del Mar, inscrito fs. 5.902 vta. N&#xB0; 6.683 Registro Propiedad a&#xF1;o 1971 Conservador Bienes Ra&#xED;ces Valpara&#xED;so, de dominio de Blanca Corina Torrej&#xF3;n Carvajal. Comisi&#xF3;n Tasadora integrada por arquitecto Edmundo Bravo Ubilla y constructores civiles Alvaro Verdejo Vidal y Pablo Caria Giurici, seg&#xFA;n informe de fecha 3 Marzo de 1993, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 810.000, la que se pagar&#xE1; de contado.-</div><br></div>", "i": 6005596}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director Serviu V Regi&#xF3;n.</div><br></div>", "i": 6005597}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "88", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-88"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "DECRETO EXPROPIATORIO", "BIEN RAIZ", "BIEN INMUEBLE", "VI A DEL MAR", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-03-31", "doble_articulado": false, "id_norma": "32985", "numero_fuente": "34541", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-04-15", "vigencias": [{"desde": "1993-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-04-15", "f