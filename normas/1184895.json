{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10382419}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xBA; 4.970, de 15 de noviembre de 2022, del Instituto de Salud P&#xFA;blica de Chile, que clasifica el Ingrediente Vegetal Palo Negro (Leptocarpha rivularis DC) y los productos que lo contengan, como Producto Farmac&#xE9;utico.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, en el siguiente link: http://www.ispch.cl/resoluciones.- </div><div class=\"p\">&nbsp; </div></div>", "i": 10382420}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Heriberto Garc&#xED;a Escorza, Director (S), Instituto de Salud P&#xFA;blica de Chile.</div><div class=\"p\"> </div><br></div>", "i": 10382421}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4970 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4970 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2223509", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-11-15", "doble_articulado": false, "id_norma": "1184895", "numero_fuente": "43412", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-11-28", "vigencias": [{"desde": "2022-11-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2022-11-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2022-11-28", "fin_vigencia": "", "tipo_version": "3"}], "evento