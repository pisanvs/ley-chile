{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 645 EXENTO, DE 1995 </div></div>", "i": 5945698}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 645 de 27 de noviembre de 1995, se ha aprobado al Colegio Polivalente &quot;San Rafael&quot; de Lo Barnechea, un plan y programas especiales de estudio para la educaci&#xF3;n b&#xE1;sica y educaci&#xF3;n media, que se aplicar&#xE1;n a partir del a&#xF1;o escolar 1996.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio en las asignaturas que se indican en el presente decreto. </div></div>", "i": 5945699}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 6 de Diciembre de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5945700}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "645 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-645 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 645 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO POLIVALENTE SAN RAFAEL", "LO BARNECHEA", "PROGRAMAS ESTUDIO", "PLANES ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-11-27", "doble_articulado": false, "id_norma": "21629", "numero_fuente": "35344", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-12-18", "vigencias": [{"desde": "1995-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-12-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-12-18", "fin_vigencia": "", "tipo_version":