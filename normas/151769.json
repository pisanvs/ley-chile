{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6220725}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 293 del 23 de Julio de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la I Regi&#xF3;n, se autoriza a Ferm&#xED;n Medalla Rojas, para efectuar el servicio taxi colectivo urbano de pasajeros L&#xED;nea No. 11 de Iquique, cuyo trazado fue autorizado por resoluci&#xF3;n No. 113 del 24 de Julio de 1984, de esta Secretar&#xED;a Regional.-</div><br></div>", "i": 6220726}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Eliecer Aedo Rivera, Secretario Regional Ministerial Transportes y Telecomunicaciones I Regi&#xF3;n Tarapac&#xE1;. </div></div>", "i": 6220727}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "293 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-293 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-23", "doble_articulado": false, "id_norma": "151769", "numero_fuente": "32836", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-03", "vigencias": [{"desde": "1987-08-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-08-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-08-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresad