{"html": [{"t": "<div><div class=\"p\">APRUEBA MANUAL OPERATIVO CONTROL PASAVANTES DEL SERVICIO NACIONAL DE ADUANAS</div></div>", "i": 10229810}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 1.205, de 12 de mayo de 2021, del Director Nacional de Aduanas, se aprueba el Manual Operativo de Control Pasavantes del Servicio Nacional de Aduanas, estandarizando procesos de Control de esta Admisi&#xF3;n Temporal, que rige de conformidad a lo establecido en el <a href=\"https://www.leychile.cl/Navegar?idNorma=17622&amp;idParte=9098405&amp;idVersion=\">art&#xED;culo 43&#xBA;</a> del <a href=\"https://www.leychile.cl/Navegar?idNorma=17622&amp;idParte=&amp;idVersion=\">decreto supremo N&#xBA; 1.355, de 1976, del Ministerio de Hacienda</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10229811}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de mayo de 2021.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><div class=\"p\"> </div><br></div>", "i": 10229812}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1205 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1205 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "APRUEBA MANUAL OPERATIVO CONTROL PASAVANTES DEL SERVICIO NACIONAL DE ADUANAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1950022", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-05-12", "