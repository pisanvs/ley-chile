{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6498908}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 117, de 27 de agosto de 2004, Serviu Regi&#xF3;n Valpara&#xED;so dispuso expropiaci&#xF3;n parcial, conforme art&#xED;culo 87 ley 8.946 y decreto ley 2.186, de 1978, de inmueble ubicado en calle Camino al Cementerio, hoy Baden Powell N&#xBA; 92, rol aval&#xFA;o 3359-3, comuna de Quilpu&#xE9;, de dominio de Ana Isabel Rodr&#xED;guez. Comisi&#xF3;n Tasadora integrada por Sres. Osvaldo Mu&#xF1;oz Quintana, arquitecto, Alvaro Verdejo Vidal, ingeniero constructor, y Pablo Caria Giurici, constructor civil, seg&#xFA;n informe de fecha 25 de junio de 2004 fij&#xF3; monto provisional indemnizaci&#xF3;n en $6.516.720.- que ser&#xE1; pagada al contado.-</div><br></div>", "i": 6498909}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n Valpara&#xED;so.</div><br></div>", "i": 6498910}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "117", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-117"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAISO"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-08-27", "doble_articulado": false, "id_norma": "230813", "numero_fuente": "37975", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-10-01", "vigencias": [{"desde": "2004-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-10-01", "f