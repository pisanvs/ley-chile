{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION N&#xB0; 119 DE 17 DE JUNIO DE 1985 </div></div>", "i": 6263167}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado Planes y Programas Especiales de Estudio para Segundo Ciclo de la Educaci&#xF3;n Media T&#xE9;cnico-Profesional, a contar del a&#xF1;o escolar 1985 y hasta el a&#xF1;o escolar 1990, inclusive, para el Liceo Comercial York, de Pe&#xF1;alol&#xE9;n.</div><br><div class=\"p\">ESPECIALIDADES:</div><div class=\"p\">1.- Contabilidad.</div><div class=\"p\">2.- Ventas y Publicidad.3.- Secretariado Administrativo.</div><div class=\"p\">4.- Programaci&#xF3;n en Computaci&#xF3;n.</div><div class=\"p\">5.- Electr&#xF3;nica con Menci&#xF3;n en Sistemas de Sonido A.M., F.M. y Video.</div><div class=\"p\">6. - Atenci&#xF3;n de P&#xE1;rvulos.</div><br></div>", "i": 6263168}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  28 de Junio de 1985.- Ra&#xFA;l Mohr Aray.-</div><div class=\"p\">Subsecretario de Educaci&#xF3;n P&#xFA;blica Subrogante. </div></div>", "i": 6263169}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "119 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-119 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION N°119 DE 17 DE JUNIO DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-17", "doble_articulado": false, "id_norma": "164959", "numero_fuente": "32305", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-10-25", "vigencias": [{"desde": "1985-10-25", "hasta": "", "ti