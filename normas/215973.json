{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6443934}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.360, de 7 de octubre de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA; 980, de 2002, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA SAN JOSE S.A. para realizar actividades pesqueras extractivas con la nave &quot;Alejandr&#xED;a I&quot;, en el sentido de indicar que el peticionario podr&#xE1; realizar actividades pesqueras extractivas con la nave antes individualizada sobre el recurso Jibia Dosidicus gigas, por fuera del &#xE1;rea de reserva artesanal, con cerco, en el &#xE1;rea mar&#xED;tima comprendida entre la III y X Regiones.</div><br></div>", "i": 6443935}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de octubre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6443936}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2360 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2360 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-10-07", "fecha_derogacion": "2011-05-20", "doble_articulado": false, "id_norma": "215973", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-10-16", "vigencias": [{"desde": "2011-05-20", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-10-16", "hasta": "2011-05-19", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inic