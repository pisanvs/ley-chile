{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 379, DE 1991, EN LO RELACIONADO CON EL DEPARTAMENTO SUBDIRECCI&#xD3;N DE INFORM&#xC1;TICA</div></div>", "i": 9407764}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 20, del 10 de febrero de 2014, que establece:</div><div class=\"p\">&nbsp; &nbsp;  Modifica la <a href=\"https://www.leychile.cl/Navegar?idNorma=38824&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 379, de 4 de diciembre de 1991</a>, fijando los Departamentos y Oficinas que conforman el Departamento Subdirecci&#xF3;n de Inform&#xE1;tica, y estableciendo las funciones que competen a cada uno de estos estamentos.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de febrero de 2014.</div></div>", "i": 9407765}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "20 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-20 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCIÓN N° 379, DE 1991, EN LO RELACIONADO CON EL DEPARTAMENTO SUBDIRECCIÓN DE INFORMÁTICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-02-10", "doble_articulado": false, "id_norma": "1059456", "numero_fuente": "40783", "tipo_version": "3", "tipo_version_s": "