{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO No. 11, DE 1990. </div></div>", "i": 7220001}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 11 de 12 de enero de 1990 se ha complementado el decreto supremo exento de Educaci&#xF3;n No. 75, de 1987, que aprob&#xF3; plan y programas especiales de estudio de orientaci&#xF3;n laboral para alumnos deficientes mentales al Centro de Capacitaci&#xF3;n Laboral &quot;Esperanza&quot; de Antofagasta, incorporando en el Plan Diferenciado la Especialidad Agropecuaria que considerar&#xE1; Horticultura, Cunicultura y Lombricultura con sus objetivos correspondientes.</div><br></div>", "i": 7220002}, {"t": "<div><div class=\"p\">Santiago, 23 de Enero de 1990.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 7220003}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "11 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-11 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO No. 11, DE 1990.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-12", "doble_articulado": false, "id_norma": "84903", "numero_fuente": "33600", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-19", "vigencias": [{"desde": "1990-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-19", "fin_vigencia": "", "tipo_version": "3"