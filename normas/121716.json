{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;667 EXENTO, DE 1998</div><br><br><br></div>", "i": 6120770}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 667, de 10 de junio de 1998, se ha aprobado al Colegio &apos;&apos;Pucar&#xE1; de Los Andes&apos;&apos; de Las Condes, Regi&#xF3;n Metropolitana, un Programa de Lat&#xED;n para los cursos de 7&#xBA; y 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 1998, con 2 horas de clases semanales en cada curso.</div><br></div>", "i": 6120771}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de junio de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6120772}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "667 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-667 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº667 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PROGRAMA DE ESTUDIO", "COLEGIO PUCARA DE LOS ANDES", "IDIOMA LATIN", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-06-10", "doble_articulado": false, "id_norma": "121716", "numero_fuente": "36120", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-07-22", "vigencias": [{"desde": "1998-07-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-07-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-07-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingr