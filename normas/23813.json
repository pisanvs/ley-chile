{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza la ereccion de un monumento a don Jos&#xE9; Victorino Lastarria</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,210.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8276067}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Se autoriza la ereccion, por suscricion popular, de un monumento destinado a honrar la memoria de don Jos&#xE9; Victorino Lastarria, en la ciudad de Santiago.</div><br></div>", "i": 8276068}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 22 de Enero de 1917.- JUAN LUIS SANFUENTES.- Enrique Za&#xF1;artu P.</div><br></div>", "i": 8276069}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3210", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3210"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Autoriza la ereccion de un monumento a don José;Victorino Lastarria", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SANTIAGO", "JOSE VICTORINO LASTARRIA", "MONUMENTO", "ERECCION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1917-01-22", "doble_articulado": false, "id_norma": "23813", "numero_fuente": "11687", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1917-01-31", "vigencias": [{"desde": "1917-01-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia":