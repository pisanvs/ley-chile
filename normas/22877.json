{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Declara libre de derechos de internacion al carburo de calcio.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1722.- Santiago, a 30 de Diciembre de 1904.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente:</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5951074}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Incl&#xFA;yese el carburo de calcio entre los art&#xED;culos libres de derechos de internacion que enumera la lei n&#xFA;mero 980, de 23 de Diciembre de I897, en su art&#xED;culo 7.&#xB0; </div></div>", "i": 5951075}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 29 de Diciembre de 1904.- JERMAN RIESCO.- Ernesto A. H&#xFC;bner.</div><br></div>", "i": 5951076}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1722", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1722"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DECLARA LIBRE DE DERECHOS DE INTERNACION AL CARBURO DE CALCIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CARBURO CALCIO", "DERECHOS INTERNACION", "EXCENCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-12-30", "doble_