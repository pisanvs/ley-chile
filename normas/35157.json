{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293239}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 586, de 14 de Junio de 1994, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por un a&#xF1;o, a contar</div><div class=\"p\">del 12 de julio de 1994, el plazo para reiniciar las</div><div class=\"p\">operaciones, autorizadas a PACIFIC FISHERIES S.A.,</div><div class=\"p\">R.U.T. N&#xB0; 96.543.140-3, por Resoluci&#xF3;n N&#xB0; 1036, de 1989,</div><div class=\"p\">de esta Subsecretar&#xED;a, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143, letra b), del D.S. N&#xB0; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, en raz&#xF3;n de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor.-</div><br></div>", "i": 8293240}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 14 de Junio de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293241}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "586", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-586"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PACIFIC FISHERIES S.A.", "AMPLIACION", "PLAZO", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-06-14", "fecha_derogacion": "1995-05-16", "doble_articulado": false, "id_norma": "35157", "numero_fuente": "34899", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion"