{"html": [{"t": "<div><div class=\"p\">CERTIFICA CALIDAD DE AGENTE RETENEDOR DEL I.V.A. A AGUA FRIA S.A.</div><br></div>", "i": 6102966}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La IV Direcci&#xF3;n Regional La Serena, del Servicio de Impuestos Internos, por&nbsp; resoluci&#xF3;n Ex. N&#xBA; 99 de 31 de diciembre de 1997, certifica que a contar del 1&#xBA; del mes siguiente a esta publicaci&#xF3;n y hasta el 30 de junio de 1998, Agua Fr&#xED;a S.A., R.U.T. N&#xBA; 78.535.800-7, tiene la calidad de Agente Retenedor del Impuesto al Valor Agregado, por las compras de especies hidrobiol&#xF3;gicas por cuanto cumple los requisitos establecidos en la resoluci&#xF3;n Ex. N&#xBA; 3.173 del 27.06.1997.-</div><br></div>", "i": 6102967}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Mu&#xF1;oz Arratia, Director Regional.</div><br></div>", "i": 6102968}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "99 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-99 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO ORIENTE"], "titulo_norma": "CERTIFICA CALIDAD DE AGENTE RETENEDOR DEL I.V.A. A AGUA FRIA S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "AGUA FRIA S.A.", "ESPECIES HIDROBIOLOGICAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-31", "doble_articulado": false, "id_norma": "96424", "numero_fuente": "35991", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-02-14", "vigencias": [{"desde": "1998-02-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenc