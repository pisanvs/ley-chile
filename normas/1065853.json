{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">REEMPLAZA PLANO DE PRECIOS DE LA COMUNA DE MELIPILLA CONTENIDO RESOLUCI&#xD3;N N&#xBA; 132 EXENTA, DE 2012</div></div>", "i": 9500161}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 85, del 22 de agosto de 2014, que dispone: </div><div class=\"p\">&nbsp; &nbsp;  Reempl&#xE1;cese el plano de precios de terrenos de la comuna de Melipilla, contenido en la <a href=\"https://www.leychile.cl/Navegar?idNorma=1047831&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n Ex. SII N&#xBA; 132, de 31.12.2012</a>, y publ&#xED;quese en el portal del reaval&#xFA;o no agr&#xED;cola no habitacional en Internet, www.sii.cl.&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos internos en Internet, www.sii.cl, y aparecer&#xE1; en el Bolet&#xED;n del SII, en el mes de agosto de 2014.</div></div>", "i": 9500162}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "85 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-85 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "REEMPLAZA PLANO DE PRECIOS DE LA COMUNA DE MELIPILLA CONTENIDO RESOLUCIÓN Nº 132 EXENTA, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-08-22", "doble_articulado": false, "id_norma": "1065853", "numero_fuente": "40943", "tipo_version":