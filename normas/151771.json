{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6220731}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 40, de 30 de Julio de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se autoriza al Sr. Carlos Francisco Latorre Flores, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del Territorio Nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de Locomoci&#xF3;n Colectiva de pasajeros. </div></div>", "i": 6220732}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Rancagua, 30 de Julio de 1987.- Rigoberto G&#xF3;mez Lav&#xED;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n.</div><br></div>", "i": 6220733}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "40 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-40 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES", "SECRETARíA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O´HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-30", "doble_articulado": false, "id_norma": "151771", "numero_fuente": "32836", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-03", "vigencias": [{"desde": "1987-08-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-08-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-08-03", "fin_vigencia"