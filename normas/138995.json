{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobacion a los siguientes</div><br><div class=\"p\">PROYECTOS DE LEI:</div><br><div class=\"p\">N&#xFA;m. 3,159 </div></div>", "i": 6177224}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Lucrecia Ram&#xED;rez, hermana del soldado del rejimiento de cazadores de Caballo, Rafael 2.&#xBA; Ram&#xED;rez, una pension anual de ciento ochenta pesos ($ 180), de que disfrutar&#xE1; en conformidad a la lei de montep&#xED;o militar.</div><br></div>", "i": 6177225}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlos y sancionarlos; por tanto, prom&#xFA;lguese y ll&#xE9;vense a efecto como leyes de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a treinta de diciembre de mil novecientos dieciseis.- Juan Luis Sanfuentes.- Oscar Urz&#xFA;a. </div></div>", "i": 6177226}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3159", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3159"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-12-30", "doble_articulado": false, "id_norma": "138995", "numero_fuente": "11661", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-12-30", "vigencias": [{"desde": "1916-12-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1916-12-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1916-12-30", "fin_vigencia": "", "tipo