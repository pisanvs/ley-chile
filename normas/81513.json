{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 11, DE 1985</div><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">N&#xFA;m. 128.- Santiago, 26 de Octubre de 1990.- Visto: Lo dispuesto en el art&#xED;culo 56 de la Ley No. 18.290, de Tr&#xE1;nsito,</div><br><div class=\"p\">Resuelvo:</div><br><br></div>", "i": 7216525}, {"t": "<div><div class=\"p\">Agr&#xE9;gase al final de la letra a) del numeral 1&#xB0; de la Resoluci&#xF3;n No. 11 de 1985, del Ministerio de Transportes y Telecomunicaciones Subsecretar&#xED;a de Transportes, la siguiente frase:</div><div class=\"p\">&quot;No obstante, en el caso de los buses que efect&#xFA;en locomoci&#xF3;n colectiva urbana, el ancho m&#xE1;ximo exterior ser&#xE1; 2.600 mm.&quot;.</div><br></div>", "i": 7216526}, {"t": "<div><div class=\"p\">An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- V&#xED;ctor Germ&#xE1;n Correa D&#xED;az, Ministro de Transportes y Telecomunicaciones. Lo que transcribo para su conocimiento.- Saluda a Ud.- Patricia Mu&#xF1;oz Villela, Jefe Depto. Administrativo. </div></div>", "i": 7216527}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "128", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-128"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "MODIFICA RESOLUCION No. 11, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-10-26", "doble_articulado": false, "id_norma": "81513", "numero_fuente": "33820", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-11-16", "vigencias": [{"desde": "1990-11-16", "hasta": "", "tipo_version":