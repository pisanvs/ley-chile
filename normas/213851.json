{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6436356}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.812, de 6 de agosto de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de la resoluci&#xF3;n N&#xBA; 1.706 de 2003, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Determinaci&#xF3;n de la Distribuci&#xF3;n Espacial de Jurel entre la V y X Regiones, Invierno 2003&quot;, en el sentido de se&#xF1;alar que el &#xE1;rea de estudio se extender&#xE1; hasta las 450 millas n&#xE1;uticas de la costa.</div><br></div>", "i": 6436357}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6436358}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1812 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1812 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-06", "doble_articulado": false, "id_norma": "213851", "numero_fuente": "37641", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-08-22", "vigencias": [{"desde": "2003-08-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-08-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-08-22", "fin_v