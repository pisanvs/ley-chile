{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 250&nbsp; EXENTO, DE 2000 </div></div>", "i": 6297121}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 250, de fecha 4 de julio de 2000, del Ministerio de Educaci&#xF3;n, se aprueban las modificaciones introducidas al plan y programas de estudios del Centro de Formaci&#xF3;n T&#xE9;cnica Escuela Superior de Administraci&#xF3;n de Negocios del Norte - Esane del Norte, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar del a&#xF1;o 2000, en la Sede Central de Antofagasta, con la siguiente denominaci&#xF3;n:</div><br><div class=\"p\">Carrera&nbsp; &nbsp;  :&nbsp; &nbsp;  Interpretariado Ingl&#xE9;s-Alem&#xE1;n</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; &nbsp; :&nbsp; &nbsp;  T&#xE9;cnico de Nivel Superior de Int&#xE9;rprete</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Ingl&#xE9;s-Alem&#xE1;n con menci&#xF3;n en Gu&#xED;a de</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Turismo.</div><br></div>", "i": 6297122}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de julio de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6297123}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "250 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-250 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 250 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-07-04", "fecha_derogacion": "2020-12-16", "doble_arti