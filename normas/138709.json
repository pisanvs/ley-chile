{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6176237}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP No. 1.006, de 29 de abril de 1999, se expropiaron los lotes de terreno No. s.11 y 12, superficie 292 y 4.492 M2., roles de aval&#xFA;o en tr&#xE1;mite, comuna de Constituci&#xF3;n, para la obra Camino Ruta M-40, Santa Olga -Empedrado, Sector Santa Olga- Los Pellines y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Ejinaldo Ren&#xE9; Jaque Acevedo y Eric Antonio Pereira G&#xF3;mez, ascendente a las cantidades de $ 169.697 y $ 3.360.991, respectivamente.- </div></div>", "i": 6176238}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6176239}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1006", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1006"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-04-29", "doble_articulado": false, "id_norma": "138709", "numero_fuente": "36401", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-07-01", "vigencias": [{"desde": "1999-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-07-09", "fecha_version": "1999-07-01", "fecha_actualizacion_texto": "1999-07-01", "tipo_tratado": ""},