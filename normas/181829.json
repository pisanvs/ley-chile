{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6322592}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 618, de 29 de febrero de 2000, se orden&#xF3; la expropiaci&#xF3;n y aprob&#xF3; el plano y cuadro de expropiaci&#xF3;n del lote de terreno N&#xBA; 20, y por decreto MOP exento N&#xBA; 277, de 29 de diciembre de 2000, se autoriz&#xF3; el valor de la consignaci&#xF3;n provisional de la expropiaci&#xF3;n por la v&#xED;a judicial, en la cantidad de $991.600.- necesario para la ejecuci&#xF3;n de la obra &apos;&apos;Mejoramiento Ruta H-577, Sector Rengo-Rinconada de Malambo, Km. 0.000 a Km. 1.914,565&apos;&apos;, el pago de la indemnizaci&#xF3;n se efectuar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.</div><br></div>", "i": 6322593}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6322594}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "618", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-618"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-12-29", "doble_articulado": false, "id_norma": "181829", "numero_fuente": "36889", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-02-15", "vigencias": [{"desde": "2001-02-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-02-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-02