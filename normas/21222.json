{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 425, DE 1993 </div><br></div>", "i": 8667369}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 425 de 11</div><div class=\"p\">de agosto de 1993 se ha aclarado lo dispuesto en el</div><div class=\"p\">decreto supremo exento de Educaci&#xF3;n N&#xB0; 56 de 1992,</div><div class=\"p\">art&#xED;culo 1&#xB0;, Plan de estudio de Quinto a Octavo A&#xF1;o de Educaci&#xF3;n B&#xE1;sica que aplica el Instituto Hebreo Dr. Chaim Weizmann-Ort de Santiago, en el sentido que la asignatura Tecnolog&#xED;a - Computaci&#xF3;n se impartir&#xE1; evaluada y con incidencia en la promoci&#xF3;n, en 1992 en 7&#xB0; a&#xF1;o y que, en 1993 se impartir&#xE1;, en las mismas condiciones en 7&#xB0; y 8&#xB0; a&#xF1;o b&#xE1;sico.</div><br></div>", "i": 8667370}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 9 de septiembre de 1993. Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8667371}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "425 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-425 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 425, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "EDUCACION BASICA", "INSTITUTO HEBREO", "DR. CHAIM WEIZMANN-ORT", "SANTIAGO", "REGION METROPOLITANA", "TECNOLOGIA COMPUTACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-08-11", "doble_articulado": false, "id_norma": "21222", "numero_fuente": "34676", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-09-