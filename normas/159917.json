{"html": [{"t": "<div><div class=\"p\">&quot;PARTIDO POR LA DEMOCRACIA&quot; </div></div>", "i": 6246961}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Erich Schnake Silva y Sergio Bitar Chacra, Presidente y Secretario General del &quot;Partido Por la Democracia&quot;, respectivamente, han informado la actual composici&#xF3;n del Tribunal Supremo del Partido. Publicaci&#xF3;n que se ha dispuesto por resoluci&#xF3;n exenta No. 0-1.290 de fecha 15 de Noviembre de 1990.</div><div class=\"p\">&nbsp; &nbsp;  Tribunal Supremo: Presidente: Francisco Geisse Graepp; vicepresidente: Francisco Estevez Valencia; secretario: Jorge Mario Saavedra Canales; vocales: Oscar Ruiz Bourgeois, Mar&#xED;a Alejandra Sep&#xFA;lveda Toro, An&#xED;bal Scarella Calandroni, Jorge Andr&#xE9;s Richards Rojas. </div></div>", "i": 6246962}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de Noviembre de 1990.- Andr&#xE9;s Merino Espi&#xF1;eira, Director Subrogante, Servicio Electoral. </div></div>", "i": 6246963}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "AVI-S/N"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO POR LA DEMOCRACIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-11-25", "doble_articulado": false, "id_norma": "159917", "numero_fuente": "33863", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-01-09", "vigencias": [{"desde": "1991-01-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-01-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-01-0