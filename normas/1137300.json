{"html": [{"t": "<div><br><div class=\"p\">NOMBRAMIENTO DE JUEZ DE POLIC&#xCD;A.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Enero 28 de 1824.</div></div>", "i": 10062756}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Habiendo resultado vacante el cargo de Juez de polic&#xED;a urbana que servia el Senador D. Francisco Ruiz Tagle; usando de las facultades que me concede la lei he venido en nombrar para este destino a D. Vicente Ovalle. Comun&#xED;quesele este decreto, e ins&#xE9;rtese en el Boletin.</div></div>", "i": 10062757}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  ERRAZURIZ.</div><br><div class=\"p\">&nbsp; &nbsp;  Ega&#xF1;a.</div></div>", "i": 10062758}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["DEPARTAMENTO DE GOBIERNO Y RELACIONES EXTERIORES"], "titulo_norma": "DEPARTAMENTO DE GOBIERNO Y RELACIONES EXTERIORES", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-01-28", "doble_articulado": false, "id_norma": "1137300", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-01-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-01-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-01-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2019-10-17", "fecha_version": "1824-01-28", "fecha_actualizacion_texto": "2019-10-17", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estru