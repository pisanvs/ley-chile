{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,487, que concede derecho a jubilar a don Heriberto Alvarez.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,487.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 5955985}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia al Fiscal de la Corte de Apelaciones de Talca, don Heriberto Alvarez, el derecho a jubilar con una pension anual de quince mil pesos ($ 15,000).</div><br></div>", "i": 5955986}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a cinco de Febrero de mil novecientos diecinueve.- JUAN LUIS SANFUENTES.- Luis Orrego Luco. </div></div>", "i": 5955987}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3487", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3487"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "LEI NUM. 3,487, QUE CONCEDE DERECHO A JUBILAR A DON HERIBERTO ALVAREZ.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["HERIBERTO ALVAREZ", "PODER JUDICIAL", "JUBILACION POR", "GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1919-02-05", "doble_articulado": false, "id_norma": "24009", "numero_fuente": "12291", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1919-02-07", "vigencias": [{"desde": "1919-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_v