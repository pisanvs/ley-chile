{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;4.080 EXENTA, DE 1999 </div><br></div>", "i": 6175428}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;4.080 de 6 de mayo de 1999, se ha aprobado al Colegio La Dehesa de Santiago, un plan de estudio para primer a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 1999.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para primer a&#xF1;o de ense&#xF1;anza media de los subsectores que se indican en la presente resoluci&#xF3;n.</div><br></div>", "i": 6175429}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de junio de 1999.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6175430}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4080", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4080"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº4.080 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-06-22", "doble_articulado": false, "id_norma": "138452", "numero_fuente": "36403", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-07-03", "vigencias": [{"desde": "1999-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-07-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-07-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ing