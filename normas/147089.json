{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6203132}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 64, de 09.04.87, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de. la XII Regi&#xF3;n, Magallanes y Ant&#xE1;rtica Chilena, se autoriza a Secundino Nicol&#xE1;s Fern&#xE1;ndez G&#xF3;mez para efectuar todo tipo de servicios de transporte de pesajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos de locomoci&#xF3;n colectiva urbana de pasajeros. </div></div>", "i": 6203133}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Urbano Peralta, Secretario Regional Ministerial XII Regi&#xF3;n.</div><br></div>", "i": 6203134}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "64 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-64 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XII REGIÓN DE MAGALLANES Y ANTÁRTICA CHILENA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-04-09", "doble_articulado": false, "id_norma": "147089", "numero_fuente": "32755", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-04-25", "vigencias": [{"desde": "1987-04-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-04-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-04-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": []