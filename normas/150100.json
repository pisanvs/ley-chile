{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION O-N&#xBA; 1.627, DE 1999</div><br><br></div>", "i": 6215132}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n O-N&#xBA; 1.627 de esta fecha del Servicio Electoral, se ha dispuesto que las caracter&#xED;sticas de impresi&#xF3;n de la c&#xE9;dula oficial que se utilizar&#xE1; en la segunda votaci&#xF3;n de la elecci&#xF3;n de Presidente de la Rep&#xFA;blica que se realizar&#xE1; el domingo 16 de enero del 2000, ser&#xE1;n las establecidas en la resoluci&#xF3;n N&#xBA; O-1.281 de fecha 9 de septiembre de 1999, publicada en extracto en el Diario Oficial de 15 del mismo mes y a&#xF1;o, con excepci&#xF3;n del guarismo &apos;&apos;1999&apos;&apos; que ser&#xE1; sustituido por el guarismo &apos;&apos;2000&apos;&apos;.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se hace en virtud de lo contemplado en el art&#xED;culo 27 de la ley N&#xBA; 18.700.</div><br></div>", "i": 6215133}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de diciembre de 1999.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6215134}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1627", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1627"}, {"tipo": "3", "numero": "O-1627", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-1627"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "EXTRACTO DE RESOLUCION O-Nº 1.627, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-28", "doble_articulado": false, "id_norma": "150100", "numero_fuente": "36552", "tipo_version": "3", "tipo_version_s": "Única", "