{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION&nbsp; N&#xBA; 785 EXENTA, DE 2003 </div></div>", "i": 6696363}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modifica Quinto proceso de selecci&#xF3;n a&#xF1;o 2002.</div><div class=\"p\">&nbsp; &nbsp;  Modifica el Quinto proceso de postulaci&#xF3;n del a&#xF1;o 2002 en la Regi&#xF3;n Metropolitana, en el sentido de disminuir la cantidad de viviendas disponibles en la oferta N&#xFA;mero Uno, a un total de 180 viviendas, lo que equivale a 25.200 UF.</div><br></div>", "i": 6696364}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- V&#xED;ctor Manuel Gonz&#xE1;lez C., Secretario Ministerial Metropolitano de Vivienda y Urbanismo.</div><br></div>", "i": 6696365}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "785 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-785 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SECRETARÍA REGIONAL MINISTERIAL REGIÓN METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 785 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "211999", "numero_fuente": "37599", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-03", "vigencias": [{"desde": "2003-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-07-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-07-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fe