{"html": [{"t": "<div><div class=\"p\">AUMENTA, POR GRACIA, LA PENSI&#xD3;N DE QUE DISFRUTA DON EDUARDO SOLIS VERGARA</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6441451}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Aum&#xE9;ntase, por gracia, la pensi&#xF3;n de que disfruta don Eduardo Sol&#xED;s Vergara a la suma de $ 30.000 mensuales.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande esta ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda. </div></div>", "i": 6441452}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a diez de Octubre de mil novecientos cincuenta y ocho.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Eduardo Urz&#xFA;a Merino.</div><br></div>", "i": 6441453}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13088", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13088"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "AUMENTA, POR GRACIA, LA PENSION DE QUE DISFRUTA DON\nEDUARDO SOLIS VERGARA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1958-10-10", "doble_articulado": false, "id_norma": "215186", "numero_fuente": "24175", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1958-10-22", "vigencias": [{"desde": "1958-10-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"