{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6327380}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por R.M. (Ex) N&#xBA; 18, de 15 de marzo de 2001, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ac&#xF3;gese parcialmente el recurso de reclamaci&#xF3;n interpuesto por PESQUERA YELCHO S.A., en contra de las resoluciones N&#xBA; 167 y N&#xBA; 173, ambas de 2001, de la Subsecretar&#xED;a de Pesca. Consid&#xE9;rese en la determinaci&#xF3;n de su l&#xED;mite m&#xE1;ximo de captura en la unidad de pesquer&#xED;a Merluza de tres aletas, la siguiente captura total de la embarcaci&#xF3;n en construcci&#xF3;n autorizada por resoluci&#xF3;n N&#xBA; 2.420 de 2000, en el mes de junio de 2000: 0,100 toneladas.-</div><br></div>", "i": 6327381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; de Gregorio Rebeco, Ministro de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6327382}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "18 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-18 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-15", "doble_articulado": false, "id_norma": "183110", "numero_fuente": "36919", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-22", "vigencias": [{"desde": "2001-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-03-22", "fin_vige