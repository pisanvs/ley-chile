{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0;336 EXENTO, DE 1993 </div></div>", "i": 5943888}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 336 de fecha 01 de Julio de 1993 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a la Sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica Escuela Superior de Administraci&#xF3;n de Negocios del Norte - Esane del Norte, para impartir plan y programas de estudio aprobado para la instituci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se se&#xF1;ala a partir del a&#xF1;o 1993.</div><div class=\"p\"> - Sede N&#xB0; 3 - Calama</div><br><div class=\"p\"> Carrera: Secretariado Ejecutivo Biling&#xFC;e (Decreto</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Exento N&#xB0; 178 de 1991).</div><br><div class=\"p\"> T&#xED;tulo:&nbsp;  Secretario (a) Ejecutivo (a) Biling&#xFC;e.</div><br></div>", "i": 5943889}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 8 de Noviembre de 1993.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943890}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "336", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-336"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N°336 EXENTO, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "ESCUELA SUPERIOR ADMINISTRACION NEGOCIOS NORTE", "SECRETARIADO EJECUTIVO BILINGUE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1993-07-01", "fecha_derogacion": "2020-12-16", "doble_articulado": false, "id_norma": "21022", "numero