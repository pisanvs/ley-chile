{"html": [{"t": "<div><div class=\"p\">DISPONE EXPROPIACION PARCIAL DE INMUEBLE QUE INDICA </div></div>", "i": 9069367}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Decreto Secc. 2da. N&#xBA; 250, de 28-04-97, Alcalde Municipalidad Santiago dispone expropiaci&#xF3;n parcial, conforme art. 85 Decreto 458 Ministerio de Vivienda y Urbanismo, inmueble San Pablo N&#xBA; 2045, Rol N&#xBA; 166-4, comuna Santiago, dominio aparente Rodrigo Mu&#xF1;oz P&#xE9;rez y otro, superficie aproximada 36,90 metros cuadrados. Deslindes: Norte, 16,40 metros resto predio; Sur, 16,40 metros calle San Pablo; Oriente, 2,25 metros otro propietario y Poniente 2,25 metros terreno uso p&#xFA;blico. Indemnizaci&#xF3;n $9.081.550.- pagadera contado.- </div></div>", "i": 9069368}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jaime Ravinet de la Fuente, Alcalde de Santiago. </div></div>", "i": 9069369}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "250", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-250"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "DISPONE EXPROPIACION PARCIAL DE INMUEBLE QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-28", "doble_articulado": false, "id_norma": "71300", "numero_fuente": "35766", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-15", "vigencias": [{"desde": "1997-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-05-15", "fin_vigencia": ""