{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 43 EXENTA, DE 2020</div></div>", "i": 10116721}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 43 del 20 de abril de 2020, que regula el ejercicio de opci&#xF3;n de contribuyentes que tributan en renta presunta para tributar en base a renta efectiva por las rentas obtenidas en el ejercicio comercial 2019 conforme al <a href=\"https://www.leychile.cl/Navegar?idNorma=1144442&amp;idParte=&amp;idVersion=\">decreto supremo N&#xBA; 553, del Ministerio de Hacienda</a>, publicado en el Diario Oficial el d&#xED;a 18 de abril de 2020 que modifica el decreto supremo N&#xBA; 420, del Ministerio de Hacienda.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento est&#xE1; publicado en &quot;www.sii.cl&quot;.</div><div class=\"p\"> </div><br></div>", "i": 10116722}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "43 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-43 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 43 EXENTA, DE 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": ["CORONAVIRUS COVID-19", "CORONAVIRUS", "COVID-19"], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1754168; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-04-20", "doble_articulado": false, "id_norma": "1144625", "numero_fuente": "42640", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-04-25", "vigencias": [{"desde": "2020-04-25", "hasta": "", "tipo_version": "3", "tipo