{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 30, DE 1990 </div></div>", "i": 6069357}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 30, de 19 de enero de 1990, se ha aprobado a la Escuela Especial &quot;Constituci&#xF3;n&quot; de Chill&#xE1;n, VIII Regi&#xF3;n del B&#xED;o-B&#xED;o, un plan de estudio especial de orientaci&#xF3;n laboral para alumnos discapacitados que se aplicar&#xE1; por un per&#xED;odo de 6 a&#xF1;os, a contar desde 1990.-</div><br></div>", "i": 6069358}, {"t": "<div><div class=\"p\">Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6069359}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "30 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-30 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 30, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-19", "doble_articulado": false, "id_norma": "85014", "numero_fuente": "33604", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-23", "vigencias": [{"desde": "1990-02-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MNV", "fecha_ingreso": "1998-01-15", "fecha_version": "1990-02-23", "fecha_actualizacion_texto": "1990-02-23", "tipo_tratado":