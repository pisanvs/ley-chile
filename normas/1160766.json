{"html": [{"t": "<div><div class=\"p\">NOMBRAMIENTO DE SUS MIEMBROS.</div><br><div class=\"p\">&nbsp; &nbsp;  EL PRESIDENTE DE LA REP&#xDA;BLICA &amp;c.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Abril 7 de 1832.</div></div>", "i": 10254470}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  A consecuencia del decreto de creacion de la junta de beneficencia y salud p&#xFA;blica, he venido en nombrar y nombro para miembros de ella a los ciudadanos.-D. Manuel Blanco Encalada, presidente-Diego Antonio Barros, vice-presidente-Antonio J. Vial-Ignacio Reyes-Antonio Vidal-Presb&#xED;tero, Jos&#xE9; Miguel Aristegui-Pedro Urriola-Estanislao Portales-Rafael Valdivieso-Javier Riezco-Guillermo Blest-Manuel Carvallo.</div></div>", "i": 10254471}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Transcr&#xED;base a los nombrados e impr&#xED;mase.</div><br><div class=\"p\">&nbsp; &nbsp;  PRIETO.&nbsp; &nbsp;  Err&#xE1;zuriz.</div></div>", "i": 10254472}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "NOMBRAMIENTO DE SUS MIEMBROS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-04-07", "doble_articulado": false, "id_norma": "1160766", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-04-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-04-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-04-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [],