{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 341 EXENTA, DE 13 DE ENERO DE 2015</div></div>", "i": 9553380}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta se han complementado las resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=185583&amp;idParte=&amp;idVersion=\">Nos 4.398, de 2001</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=203280&amp;idParte=0&amp;idVersion=\">5.037, de 2002</a>, ambas del Ministerio de Educaci&#xF3;n, que aprobaron planes y programas especiales de estudio de 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Colegio San Ignacio, Alonso Ovalle, de la comuna y provincia de Santiago, Regi&#xF3;n Metropolitana, perteneciente a la Congregaci&#xF3;n Compa&#xF1;&#xED;a de Jes&#xFA;s.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio del Sector de Composici&#xF3;n Musical, en Otros, del Plan de Formaci&#xF3;n Diferenciada de 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, que se indica en la presente resoluci&#xF3;n exenta.</div></div>", "i": 9553381}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de enero de 2015.- Gonzalo Mu&#xF1;oz Stuardo, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 9553382}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "341 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-341 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 341 EXENTA, DE 13 DE ENERO DE 2015", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promul