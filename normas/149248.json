{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 729, DE 1985</div><br><br></div>", "i": 8354570}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 508 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica, por cambio de raz&#xF3;n social, la resoluci&#xF3;n No. 729, de 1985, de esta Subsecretar&#xED;a, y se autoriza a Pesquera Constituci&#xF3;n S.A., domiciliaria en Santiago, para incluir entre los recursos que puede elaborar los siguientes: loco y langostino colorado.</div><br></div>", "i": 8354571}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de Mayo de 1987.- Jorge Valenzuela Dur&#xE1;n, Coronel de Ej&#xE9;rcito, Subsecretario de Pesca (S). </div></div>", "i": 8354572}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "508", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-508"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 729, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1987-05-20", "fecha_derogacion": "1989-06-09", "doble_articulado": false, "id_norma": "149248", "numero_fuente": "32779", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1987-05-26", "vigencias": [{"desde": "1989-06-09", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1987-05-26", "hasta": "1989-06-08", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1989-06-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vige