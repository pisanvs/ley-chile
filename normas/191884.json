{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6358343}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n n&#xFA;mero 2.340 de 15 de noviembre de 2001 de esta Subsecretar&#xED;a, modif&#xED;case el numeral 5&#xBA; de la resoluci&#xF3;n N&#xBA;2.255 de 2001, de esta Subsecretar&#xED;a que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Prospecci&#xF3;n de &#xE1;reas de reclutamiento del Jurel entre la III y X Regiones&quot;, en el sentido de reemplazar la nave &quot;Mack&quot; por la nave &quot;Cobra&quot;, ambas de propiedad de Pesquera El Golfo S.A., de la n&#xF3;mina de naves participantes en la se&#xF1;alada pesca de investigaci&#xF3;n.</div><br></div>", "i": 6358344}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de noviembre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6358345}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2340", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2340"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-15", "doble_articulado": false, "id_norma": "191884", "numero_fuente": "37116", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-21", "vigencias": [{"desde": "2001-11-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-11-21", "fin_vigencia": ""}, "