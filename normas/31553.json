{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTOS DE RESOLUCIONES </div></div>", "i": 8288730}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 596, de 22 de Mayo de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se caducan los numerales 2&#xB0; y 3&#xB0; de la Resoluci&#xF3;n N&#xB0; 947, de 1988, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESCA CISNE S.A., para operar las naves &quot;Cisne Azul&quot;, &quot;Cisne Rojo&quot;, &quot;Cisne Gris&quot;, &quot;Cisne Dorado&quot;, en el litoral de la XII Regi&#xF3;n, en la extracci&#xF3;n de especies demersales, en raz&#xF3;n de lo dispuesto en el Art&#xED;culo 7&#xB0; del D.S. N&#xB0; 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8288731}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 22 de Mayo de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8288732}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "596", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-596"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "EXTRACTOS DE RESOLUCIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA CISNE S.A.", "PESCA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-05-22", "doble_articulado": false, "id_norma": "31553", "numero_fuente": "33983", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-06-04", "vigencias": [{"desde": "1991-06-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-06-04", "fin_