{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXENCION TRIBUTARIA PARA LOS ESPECTACULOS QUE INDICA Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley </div></div>", "i": 5978313}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Los espect&#xE1;culos musicales y teatrales extranjeros gozar&#xE1;n de las mismas exenciones tributarias que los expect&#xE1;culos teatrales y musicales nacionales.</div><br></div>", "i": 5978314}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a diecis&#xE9;is de Enero de mil novecientos sesenta y siete.- EDUARDO FREI MONTALVA.- Sergio Molina S.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a U. para su conocimiento.- Dios guarde a U.- Andr&#xE9;s Zald&#xED;var L., Subsecretario de Hacienda.</div><br></div>", "i": 5978315}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "16614", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-16614"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "EXENCION TRIBUTARIA PARA LOS ESPECTACULOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXENCION TRIBUTARIA", "IMPUESTO", "ESPECTACULOS", "MUSICA", "TEATRO", "NACIONAL", "EXTRANJERO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1967-01-16", "doble_articulado": false, "id_norma": "28577", "numero_fuente": "26660", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1967-02-04", "vigencias": [{"desde": "1967-02-04", "hasta": "", "tipo_version"