{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 3,897.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6191389}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir de rentas jenerales hasta la suma de seiscientos mil pesos ($ 600,000) en la prosecucion de los trabajos de construccion del edificio destinado a varios servicios p&#xFA;blicos en la ciudad de Antofagasta. </div></div>", "i": 6191390}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, trece de noviembre de mil novecientos veintidos.- Arturo Alessandri.- M. Letelier.</div><br></div>", "i": 6191391}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3897", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3897"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1922-11-13", "doble_articulado": false, "id_norma": "143465", "numero_fuente": "13443", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1922-12-02", "vigencias": [{"desde": "1922-12-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1922-12-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1922-12-02", "fin_vigencia": "", "tipo_version