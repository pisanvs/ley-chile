{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  CONSUL BRITANICO EN COQUIMBO.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Junio 21 de 1825.</div><br><div class=\"p\">&nbsp; &nbsp;  En virtud de las credenciales presentadas al Gobierno por el Sr. Mateo Carter de Consul del Gobierno de S. M. B. residente en la ciudad de Coquimbo, vengo en decretar:</div></div>", "i": 10119909}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1&#xB0; Queda reconocido el expresado Sr. Mateo Carter, en el car&#xE1;cter que aquellas le confieren, de Consul del Gobierno de S. M. B. residente en la ciudad de Coquimbo.</div><br><div class=\"p\">&nbsp; &nbsp;  2&#xB0; Se le declara el goce de todas las prerogativas y esenciones que, como a tal Consul, le pertenecen por derecho p&#xFA;blico.</div><br><div class=\"p\">&nbsp; &nbsp;  3&#xB0; Publ&#xED;quese en el Boletin, y trascr&#xED;base a quien corresponde, registr&#xE1;ndose la patente manifestada en la Chanciller&#xED;a de Relaciones Exteriores.</div><br></div>", "i": 10119910}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Vial.</div><br></div>", "i": 10119911}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES"], "titulo_norma": "CONSUL BRITANICO EN COQUIMBO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-06-21", "doble_articulado": false, "id_norma": "1142983", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-06-21", "hasta": ""