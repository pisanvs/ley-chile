{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; LIBERA DE DERECHOS LA INTERNACION DEL MONUMENTO A LOS HERMANOS AMUNATEGUI.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1761.- Santiago, a 6 de Setiembre de 1905.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5951143}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.-Se concede liberacion de derechos de aduana para la internacion del grupo escult&#xF3;rico destinado al monumento Amun&#xE1;tegui.</div><br></div>", "i": 5951144}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JERMAN RIESCO.-A. Subercaseaux P&#xE9;rez.</div><br></div>", "i": 5951145}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1761", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1761"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LIBERA DE DERECHOS LA INTERNACION DEL MONUMENTO A LOS HERMANOS AMUNATEGUI.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MONUMENTO HERMANOS AMUNATEGUI", "DERECHOS INTERNACION", "EXENCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-09-06", "doble_articulado": false, "id_norma": "22901", "numero_fuente": "8303", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-09-07", "vigencias": [{"desde": "1905-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1905-09-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio