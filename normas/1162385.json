{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10249576}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xBA; 616 de 9 junio 2021, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos con peso superior a dieciocho (18) toneladas en puente colgante desag&#xFC;e lago General Carrera desde el 02-06-2021 hasta el 07-06-2021. Autoriz&#xF3; la interrupci&#xF3;n del tr&#xE1;nsito en puente colgante El Desag&#xFC;e durante el d&#xED;a 07-06-2021.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10249577}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Margarita Ossa Rojas, Intendente, Ejecutivo Gobierno Regional de Ays&#xE9;n.- Ximena Guti&#xE9;rrez Jaramillo, Asesora Jur&#xED;dica.</div><br></div>", "i": 10249578}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "616 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-616 EXENTA"}], "organismos": ["MINISTERIO DEL INTERIOR Y SEGURIDAD PÚBLICA", "GOBIERNO REGIONAL DE AYSÉN"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1973878", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-06-09", "doble_articulado": false, "id_norma": "1162385", "numero_fuente": "42998", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-07-09", "vigencias": [{"desde": "2021-07-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2021-07-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2021-07-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795