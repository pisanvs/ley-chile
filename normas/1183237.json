{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 872 EXENTA, DE 17 DE OCTUBRE DE 2022</div></div>", "i": 10374104}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 872, del 17 de octubre del a&#xF1;o 2022, del Gobierno Regional de &#xD1;uble, se indica: 1.- Rectif&#xED;quese la <a href=\"https://www.leychile.cl/Navegar?idNorma=1182644&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta 809, de fecha 3 de octubre de 2022</a>, en el sentido que el corte de tr&#xE1;nsito vehicular solo ser&#xE1; por media calzada y no calzada completa como se indic&#xF3;. 2.- Mant&#xE9;ngase en todo lo dem&#xE1;s plenamente vigente la resoluci&#xF3;n antes singularizada, siendo la presente resoluci&#xF3;n parte integrante de la resoluci&#xF3;n que en este acto se modifica.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><br></div>", "i": 10374105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese y publ&#xED;quese.- &#xD3;scar Cris&#xF3;stomo Llanos, Gobernador Regional, Gobierno Regional de &#xD1;uble.</div><br></div>", "i": 10374106}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "872 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-872 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE ÑUBLE"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 872 EXENTA, DE 17 DE OCTUBRE DE 2022", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2203549", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-10-17", "doble_articulado": false, "id_norma": "1183237", "numero_fuente": "43381", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-10-20", "vigencias": [{"