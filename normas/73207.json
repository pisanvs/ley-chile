{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8303487}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 708, de 22 de mayo de 1997, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura N&#xBA; 93103185, presentada por</div><div class=\"p\">PEDRO DOMINGO MARTINEZ BARRIA, para un centro de cultivo</div><div class=\"p\">ubicado en Isla Aul&#xED;n, Comuna de Quemchi, Provincia de</div><div class=\"p\">Chilo&#xE9;, X Regi&#xF3;n, en virtud de lo dispuesto en los</div><div class=\"p\">art&#xED;culos 78&#xBA; y 87&#xBA; de la Ley General de Pesca y Acuicultura y 14&#xBA; del D.S. N&#xBA; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8303488}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de mayo de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8303489}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "708", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-708"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION DE ACUICULTURA", "PEDRO DOMINGO MARTINEZ BARRIA", "QUEMCHI", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-05-22", "doble_articulado": false, "id_norma": "73207", "numero_fuente": "35780", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-06-03", "vigencias":