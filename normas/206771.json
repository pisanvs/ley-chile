{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6410382}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA; 1.721, de 17 de diciembre<span class=\"n\" id=\"n_0\">RECTIFICACION<br>D.O. 01.02.2003</span> de 2002, se rectific&#xF3; el decreto exento MOP N&#xBA;2.021 de 28 de diciembre de 2001, que orden&#xF3; la expropiaci&#xF3;n del lote de terreno N&#xBA;50 para la obra: &quot;Red Vial Litoral Central. Sector 1: Nuevo Camino Costero. Acceso a El Tabo. Km. 1.560,00 al Km. 2.400,00&quot;, Quinta Regi&#xF3;n, que figura a nombre de G&#xF3;mez Adela, rol de aval&#xFA;o 680-273, comuna de El Tabo. En el siguiente sentido: Que la obra se encuentra ubicada entre el Km. 1.560,00 al Km.</div><div class=\"p\">2.400,00, y no como en &#xE9;l se indica.</div><br></div>", "i": 6410383}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6410384}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "2", "numero": "1721 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1721 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-17", "doble_articulado": false, "id_norma": "206771", "numero_fuente": "37459", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-01-15", "vigencias": [{"desde": "2003-02-01", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-01-15", "hasta": "2003-01-31", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2003-02-01"