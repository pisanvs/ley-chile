{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 966 EXENTO, DE 2004</div><br><br></div>", "i": 6519479}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 996, de 11 de noviembre de 2004, se ha aprobado un plan de estudio especial biling&#xFC;e para los cursos de 1&#xBA; a 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica al Colegio &quot;Trebulco&quot;, de la comuna de Talagante, provincia de Santiago, Regi&#xF3;n Metropolitana, el que se aplicar&#xE1; a contar del a&#xF1;o escolar 2005.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s se aprueban programas de estudio para los subsectores que se indican en el presente decreto. </div></div>", "i": 6519480}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de marzo de 2005.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6519481}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "996 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-996 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 966 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-11", "doble_articulado": false, "id_norma": "236404", "numero_fuente": "38113", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-03-17", "vigencias": [{"desde": "2005-03-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-03-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-03-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": []