{"html": [{"t": "<div><div class=\"p\">COMPLEMENTA RES. EX. N&#xB0; 119 DE 2020</div></div>", "i": 10200726}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta SII N&#xB0; 11, de 4 de febrero de 2021, complementa <a href=\"https://www.leychile.cl/Navegar?idNorma=1150286&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta 119, de 2020</a>, que establece la obligaci&#xF3;n de presentar declaraci&#xF3;n jurada sobre enajenaci&#xF3;n de entidades extranjeras con activos subyacentes en Chile, formulario 1921.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl).</div><div class=\"p\"> </div><br></div>", "i": 10200727}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "11 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-11 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "COMPLEMENTA RES. EX. N° 119 DE 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1892686", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-02-04", "doble_articulado": false, "id_norma": "1155726", "numero_fuente": "42876", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-02-09", "vigencias": [{"desde": "2021-02-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2021-02-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2021-02-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p