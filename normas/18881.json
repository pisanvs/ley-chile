{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 2,166.- Santiago, 28 de Abril de 1930.- Vistas las facultades que me confiere la ley N.o 4,795, Decreto:</div><br></div>", "i": 5934711}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; 1.o Decl&#xE1;rase que, para los efectos del art&#xED;culo 25 de la ley N.o 4,228, el presidente del Consejo de Defensa Fiscal, ser&#xE1; considerado como funcionario de Oficina de Hacienda;</div><div class=\"p\">&nbsp; &nbsp; 2.o N&#xF3;mbrase a don Pedro Aguirre Cerda para que, como presidente del Consejo de Defensa Fiscal, forme parte del Directorio de la Caja Reaseguradora de Chile, por renuncia de la persona que desempe&#xF1;aba dicho cargo. </div></div>", "i": 5934712}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.-</div><div class=\"p\">C.IBA&#xD1;EZ C.- R. Jaramillo.</div><br></div>", "i": 5934713}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2166", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2166"}, {"tipo": "13", "numero": "2166", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-2166"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAJA REASEGURADORA CHILE", "ADMINISTRACION", "DIRECTORIO", "INTEGRANTES", "CONSEJO DEFENSA FISCAL", "PRESIDENTE", "NOMBRAMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-04-28", "doble_articulado": false, "id_norma": "18881", "numero_fuente": "15663", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-05-02", "vigencias": [{"desde": "1930-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni