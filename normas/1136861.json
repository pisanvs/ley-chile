{"html": [{"t": "<div><div class=\"p\">MONTEPIOS MILITARES</div><br><div class=\"p\">&nbsp; &nbsp;  EL DIRECTOR SUPREMO DEL ESTADO DE CHILE &amp;c.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el soberano Congreso Constituyente ha decretado lo siguiente:</div></div>", "i": 10060367}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  &quot;D&#xE9;se montep&#xED;o a las viudas y familias de los militares que fallecieron &#xE1;ntes de la revolucion en servicio del Rei cat&#xF3;lico, conforme a lo preceptuado en el reglamento del monte, pag&#xE1;ndose de la masa jeneral destinada a este objeto&quot;.</div></div>", "i": 10060368}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por tanto ordeno se publique por lei insert&#xE1;ndose en el Boletin. Dado en el Palacio Directorial en Santiago de Chile a 4 de Setiembre de 1823.</div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Fern&#xE1;ndez. </div></div>", "i": 10060369}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "33", "numero": "S/N", "abreviacion": "LEI", "descripcion": "Lei", "compuesto": "Lei-S/N"}], "organismos": ["DEPARTAMENTO DE GUERRA Y MARINA"], "titulo_norma": "MONTEPIOS MILITARES", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-09-04", "doble_articulado": false, "id_norma": "1136861", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-09-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-09-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-09-04", "fin_vigencia