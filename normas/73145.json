{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8303418}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 564, de 21 de abril de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a EMPRESA PESQUERA EPERVA S.A., para ampliar actividades pesqueras extractivas autorizadas mediante Resoluci&#xF3;n N&#xBA; 614, de 1993, de esta Subsecretar&#xED;a de Pesca, en orden a operar la nave &quot;Eperva 64&quot;, matr&#xED;cula N&#xBA; 2798, en el litoral de la X Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; extraer con red de Cerco, los siguientes recursos hidrobiol&#xF3;gicos: Anchoveta, Jurel, Merluza de cola, Sardina com&#xFA;n.</div><br></div>", "i": 8303419}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de abril de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8303420}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "564", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-564"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "EMPRESA PESQUERA EPERVA S.A.", "AMPLIACION", "PESCA", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-21", "doble_articulado": false, "id_norma": "73145", "numero_fuente": "35758", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-06", "vigencias": [{"desde": "1997-05-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "19