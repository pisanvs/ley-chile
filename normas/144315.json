{"html": [{"t": "<div><div class=\"p\">EXTRACTO&nbsp; DE&nbsp; DECRETO&nbsp; N&#xBA; 170 EXENTO,&nbsp; DE 1999</div><br></div>", "i": 7254070}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 170, de fecha 5 de julio de</div><div class=\"p\">1999 del Ministerio de Educaci&#xF3;n, se modific&#xF3; el</div><div class=\"p\">art&#xED;culo 1&#xBA; del decreto exento N&#xBA; 73 del 1&#xBA; de marzo de 1990, que autoriza el funcionamiento del Centro de Formaci&#xF3;n T&#xE9;cnica Florencia, en el sentido de reemplazar la raz&#xF3;n social de &apos;&apos;Sociedad Educacional Florencia Limitada&apos;&apos; o &apos;&apos;C.F.T. Florencia Ltda.&apos;&apos; y cambiar la denominaci&#xF3;n de la instituci&#xF3;n, por la siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  Organizador: Sociedad Educacional Florencia Limitada o C.F.T. FIRENZE Ltda.</div><div class=\"p\">Nombre de la Instituci&#xF3;n: Centro de Formaci&#xF3;n T&#xE9;cnica FIRENZE.</div><br></div>", "i": 7254071}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de agosto de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7254072}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "170 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-170 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 170 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-07-05", "doble_articulado": false, "id_norma": "144315", "numero_fuente": "36475", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-28", "vigencias": [{"de