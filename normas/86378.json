{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8317969}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n 1.848, de 31 de diciembre de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento&nbsp; y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud presentada por EMPRESA NACIONAL DE PESCA S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Toyita&quot; en el litoral de la X regi&#xF3;n, sobre el recurso Jurel, en virtud de encontrarse dicha pesquer&#xED;a declarada en plena explotaci&#xF3;n en conformidad a lo dispuesto en el art&#xED;culo 19 Letra a) de la Ley N&#xBA; 18.892 de 1989, en relaci&#xF3;n con el D.S. N&#xBA; 548, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n se&#xF1;alado en Vistos.</div><br></div>", "i": 8317970}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de diciembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8317971}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1848", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1848"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "EMPRESA NACIONAL DE PESCA S.A.", "AMPLIACION", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-12-31", "fecha_derogacion": "1998-02-12", "doble_articulado": false, "id_norma": "86378", "numero_fuente": "35963", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-01-13", "vigencias": [{"desde": "1998-02-12", "hasta": "", "tipo_version": "2",