{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aumenta en un 50 por ciento los derechos consulares Lei n&#xFA;m. 3,184.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7166408}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Aum&#xE9;ntase en cincuenta por ciento los derechos consulares establecidos por la lei n&#xFA;mero 2,208, de 21 de Setiembre de 1909.</div><br></div>", "i": 7166409, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 8 de Enero de 1917.- JUAN LUIS SANFUENTES.- A. Huidobro.</div><br></div>", "i": 7166410}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3184", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3184"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "AUMENTA EN UN 50 POR CIENTO LOS DERECHOS CONSULARES", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": ["DERECHOS CONSULARES", "REAJUSTE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1917-01-08", "fecha_derogacion": "1920-09-01", "doble_articulado": false, "id_norma": "23790", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1917-01-09", "vigencias": [{"desde": "1920-09-01", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1917-01-09", "hasta": "1920-08-31", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"