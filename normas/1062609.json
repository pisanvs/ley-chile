{"html": [{"t": "<div><br><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A EXPORTADORA XFRU CINCO LIMITADA</div></div>", "i": 9463389}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  La VI Direcci&#xF3;n Regional Rancagua del SII, por resoluci&#xF3;n Ex. N&#xBA; 1.443 de fecha 28.03.2013, otorga la calidad de Agente Retenedor del Impuesto al Valor Agregado en la venta de berries, a Exportadora Xfru Cinco Limitada, RUT N&#xBA; 76.083.269-3. Dicho acto de autoridad regir&#xE1; a contar del d&#xED;a primero del mes siguiente al de esta publicaci&#xF3;n, de acuerdo a lo establecido en la resoluci&#xF3;n exenta SII N&#xBA; 55 del 02.06.2005, de la Direcci&#xF3;n Nacional.</div></div>", "i": 9463390}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Luis Aguirre P&#xE9;rez, Director Regional.</div></div>", "i": 9463391}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1443 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1443 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VI DIRECCIÓN REGIONAL RANCAGUA"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A EXPORTADORA XFRU CINCO LIMITADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-03-28", "doble_articulado": false, "id_norma": "1062609", "numero_fuente": "40864", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-05-24", "vigencias": [{"desde": "2014-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-06-01", "fin_vigencia": ""