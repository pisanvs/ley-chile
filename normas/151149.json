{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 142, DE 1986 </div></div>", "i": 8356458}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 630, de 22 de Junio de 1987, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica resoluci&#xF3;n No. 142, de 17 de Febrero de 1986, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Pesquera Auro S.A. para operar embarcaci&#xF3;n Auro en construcci&#xF3;n y extraer recursos hidrobiol&#xF3;gicos se&#xF1;alados en el numeral 5&#xB0; de dicha resoluci&#xF3;n en el litoral de la VIII Regi&#xF3;n, en orden a se&#xF1;alar que las caracter&#xED;sticas de la citada embarcaci&#xF3;n son: Nombre: Auro. Eslora: 39,00 Mts. Manga: 9,2 Mts. Puntal: 4,40 Tons. T.R.G.: 362 Tons. T.R.N.: 132 Tons. Manteni&#xE9;ndose capacidad de bodega y sistema de pesca.-</div><br></div>", "i": 8356459}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Roberto Cabezas Bello, Subsecretario de Pesca. </div></div>", "i": 8356460}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "630", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-630"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 142, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-22", "doble_articulado": false, "id_norma": "151149", "numero_fuente": "32817", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-11", "vigencias": [{"desde": "1987-07-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "198