{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;550 EXENTO, DE 2002 </div></div>", "i": 6395306}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;550 de fecha 26 de junio de 2002 del Ministerio de Educaci&#xF3;n, se aprueban las modificaciones introducidas al plan y programas de estudios del Centro de Formaci&#xF3;n T&#xE9;cnica Iprosec, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar del a&#xF1;o 2002, en la Casa Central de Osorno, con la siguiente denominaci&#xF3;n:</div><br><br><div class=\"p\">Carrera&nbsp; : Secretariado Ejecutivo con menci&#xF3;n en</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Computaci&#xF3;n, cambia por:</div><br><div class=\"p\">Carrera&nbsp; : Secretariado Ejecutivo Computacional.</div><div class=\"p\">T&#xED;tulo&nbsp;  : Secretario (a) Ejecutivo (a) Computacional.</div><br></div>", "i": 6395307}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de agosto de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6395308}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "550 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-550 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº550 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-26", "doble_articulado": false, "id_norma": "202285", "numero_fuente": "37351", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-09-04", "vigencias": [{"desde": "2002-09-04", "hasta": "", "tipo_version": "3", "tipo_