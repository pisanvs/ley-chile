{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 4.128 EXENTA, DE 2013</div></div>", "i": 9360741}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 4.128, de 3 de junio de 2013, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Servicios de Capacitaci&#xF3;n Impacto Limitada (Impacto Limitada)&quot;, RUT 76.091.253-0, contenida en la resoluci&#xF3;n exenta N&#xBA; 5.778 de fecha 16 de junio de 2010, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2 del Art. 21 de la ley 19.518.-</div></div>", "i": 9360742}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (S).</div></div>", "i": 9360743}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4128 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4128 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 4.128 EXENTA, DE 2013", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2013-06-03", "fecha_derogacion": "2013-11-27", "doble_articulado": false, "id_norma": "1052121", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2013-06-21", "vigencias": [{"desde": "2013-11-27", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2013-06-21", "hasta": "2013-11-26", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2013-11-27", "fin_vigencia": ""}, "vigencias_versio