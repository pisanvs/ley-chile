{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 8.069 EXENTA, DE 1999 </div></div>", "i": 7267180}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 8.069 de 2 de septiembre de 1999, se ha aprobado al Colegio &apos;&apos;Andr&#xE9;e English School&apos;&apos;, comuna de La Reina, de Santiago, un plan especial de estudio para segundo a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2000. Adem&#xE1;s, se aprueban programas de estudio para segundo a&#xF1;o de ense&#xF1;anza media de los subsectores que se indican en la presente resoluci&#xF3;n exenta.</div><br></div>", "i": 7267181}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de septiembre de 1999.- Juan Eduardo Garc&#xED;a - Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 7267182}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8069 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8069 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 8.069 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-09-02", "doble_articulado": false, "id_norma": "164764", "numero_fuente": "36636", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-10", "vigencias": [{"desde": "2000-04-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-04-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-04-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pend