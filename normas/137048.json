{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,442.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170722}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- El&#xE9;vase, por gracia, a trescientos pesos ($ 300) anuales la pension de que actualmente disfruta do&#xF1;a Dolores Bueno, v. de Garc&#xED;a, como hija del servidor de la Independencia don Francisco Bueno. </div></div>", "i": 6170723}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, treinta i uno de diciembre de mil novecientos diez.- Ram&#xF3;n Barros Luco.- A. Pinto Concha. </div></div>", "i": 6170724}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2442", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2442"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-12-31", "doble_articulado": false, "id_norma": "137048", "numero_fuente": "9873", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-01-05", "vigencias": [{"desde": "1911-01-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-01-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-01-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "I