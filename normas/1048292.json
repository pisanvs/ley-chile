{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 234 EXENTA, DE 2013</div></div>", "i": 9328716}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 234, de 11 de enero de 2013, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Instituto Chileno de la Lengua Limitada (Ichil Ltda.)&quot;, RUT 77.100.660-4 contenida en la resoluci&#xF3;n exenta N&#xBA; 3.633 de 2 de noviembre de 2006, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.- </div></div>", "i": 9328717}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (PT).</div></div>", "i": 9328718}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "234 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-234 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 234 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-01-11", "doble_articulado": false, "id_norma": "1048292", "numero_fuente": "40463", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-01-19", "vigencias": [{"desde": "2013-01-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-01-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-01-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacione