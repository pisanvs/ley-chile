{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MEDIDAS HIJIENICAS Lei n&#xFA;m. 259.-Santiago, a 2 de Febrero de 1895.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273864}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de cincuenta mil pesos ($ 50,000) en la adopcion de medidas que tiendan a prevenir la propagacion de enfermedades infecciosas i en el sostenimiento de lazaretos.</div><br><br></div>", "i": 8273865}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORJE MONTT.-</div><div class=\"p\">R. Barros Luco.</div><br></div>", "i": 8273866}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "259", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-259"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MEDIDAS HIJIENICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LAZARETOS", "FINANCIAMIENTO", "ENFERMEDADES INFECCIOSAS", "PREVENCION", "MEDIDAS HIGIENICAS", "INVERSION FONDOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-02-02", "doble_articulado": false, "id_norma": "22113", "numero_fuente": "5030", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-02-02", "vigencias": [{"desde": "1895-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-02-02", "fin_vigencia": ""}, "vigencias_versi