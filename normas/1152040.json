{"html": [{"t": "<div><br><div class=\"p\">COMISOS.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Febrero 16 de 1826 </div></div>", "i": 10221680}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Decl&#xE1;rase, que cuando en una misma causa de comiso conozcan dos fiscales debe partirse entre ambos por iguales partes la cuota asignada a la fiscal&#xED;a en decreto de 26 de noviembre de 1825. Trascr&#xED;base a quienes corresponda, t&#xF3;mese razon en las oficinas de hacienda y arch&#xED;vese.</div></div>", "i": 10221681}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  INFANTE.</div><br><div class=\"p\">&nbsp; &nbsp;  Gandarillas.</div></div>", "i": 10221682}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "COMISOS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1826-02-16", "doble_articulado": false, "id_norma": "1152040", "numero_fuente": "1826", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1826-02-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1826-02-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1826-02-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2021-04-21", "fecha_version": "1826-02-16", "fecha_actualizacion_texto": "2021-04-21", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10221680}, {"n": "Artículo", "i": 1022