{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294427}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 833, de 20 de Julio de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a SOCIEDAD BAQUEDANO LTDA., R.U.T. N&#xB0; 79.700.600-9, para ampliar actividades pesqueras, en orden a incorporar la planta ubicada en Camino al Fuerte N&#xB0; 42, Coquimbo, en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Congelado: Pepino de mar, Turbot; Seco-salado: Jibia, Calamar, Pepino de mar.</div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 20 de Julio de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294428}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 21 de Julio de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294429}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "833", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-833"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD BAQUEDANO LIMITADA", "PESCA", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-07-20", "doble_articulado": false, "id_norma": "35663", "numero_fuente": "35236", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-08-05", "vigencias": [{"desde": "1995-08-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-08-05", "fin_vigencia": ""}, "vigencias_ver