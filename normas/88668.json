{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 2.066 EXENTA, DE 1997 </div></div>", "i": 6080089}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta N&#xBA; 2.066 de fecha 24 de noviembre de 1997, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriz&#xF3; complementariamente a la empresa de origen boliviano Trans-Salvador S.R.L., para efectuar transporte internacional terrestre de pasajeros entre Oruro (Bolivia) y Arica (Chile), y viceversa, con (4) cuatro frecuencias semanales, de ida y vuelta, utilizando el paso fronterizo de Tambo Quemado.- </div></div>", "i": 6080090}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Andr&#xE9;s Wallis Garc&#xE9;s, Subsecretario de Transportes.</div><br></div>", "i": 6080091}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2066 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2066 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 2.066 EXENTA, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TRANSPORTE TERRESTRE INTERNACIONAL", "TRANSPORTE DE PASAJEROS", "TRANS-SALVADOR S.R.L.", "CHILE", "BOLIVIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-11-24", "doble_articulado": false, "id_norma": "88668", "numero_fuente": "35971", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-22", "vigencias": [{"desde": "1998-01-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici