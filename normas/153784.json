{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6227001}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 1.905 de 09.09.87, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a parcelas N&#xB0;s. 1 y 2 y sitios N&#xB0;s. 1 y 2 del Proyecto de Parcelaci&#xF3;n &quot;El Porvenir&quot;, de las comuna de El Carmen, formado por predio &quot;Hijuela N&#xFA;mero Uno de San Vicente, denominada Michay&quot;. Los Derechos de Agua se extraen del c&#xE1;nal La M&#xE9;dica derivado del Estero Rucalemu y de tranque en Hijuela Dos Paso Colorado, aguas derivadas del Estero San Vicente.</div><div class=\"p\">Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.- </div></div>", "i": 6227002}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6227003}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1905 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1905 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-09", "doble_articulado": false, "id_norma": "153784", "numero_fuente": "32871", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-15", "vigencias": [{"desde": "1987-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09-15", "fin_vigen