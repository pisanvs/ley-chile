{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">DEJA SIN EFECTO CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD DE INVERSIONES ARANJUEZ LIMITADA</div></div>", "i": 9375676}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  La V Direcci&#xF3;n Regional del Servicio de Impuestos Internos, por Res. Ex. N&#xBA; 7.418, de 24 de octubre de 2012, deja sin efecto la calidad de Agente Retenedor del IVA a contar de la fecha de su publicaci&#xF3;n en el Diario Oficial, a la Sociedad de Inversiones Aranjuez Limitada RUT N&#xBA; 89.595.700-3, en los contratos de instalaci&#xF3;n o confecci&#xF3;n de especialidades que contraten con terceros para la ejecuci&#xF3;n de este tipo de obras, conforme a lo establecido en la <a href=\"https://www.leychile.cl/Navegar?idNorma=245598&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n Ex. N&#xBA; 142, del 26 de diciembre de 2005, del Servicio de Impuestos Internos</a>.</div></div>", "i": 9375677}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  &#xC9;rika Morales Lartiga, Directora Regional.</div></div>", "i": 9375678}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7418 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-7418 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL VALPARAÍSO"], "titulo_norma": "DEJA SIN EFECTO CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD DE INVERSIONES ARANJUEZ LIMITADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-10-24", "doble_articulado": false, "id_norma": "1054553", "numero