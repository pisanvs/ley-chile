{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO LA CALIDAD DE AGENTE RETENEDOR DEL IVA, SEG&#xDA;N AVISO DE FECHA 02.09.1998 </div></div>", "i": 6644863}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La V Direcci&#xF3;n Regional del Servicio de Impuestos Internos, por Res. Ex. N&#xBA; 5.152, del 4 de julio de 2007, deja sin efecto la calidad de Agente Retenedor del IVA a contar del d&#xED;a 1&#xBA; del mes siguiente de la fecha en que se publique en extracto en el Diario Oficial, de la sociedad Matadero Frigor&#xED;fico Zencar Limitada, RUT N&#xBA; 78.545.420-0, en la venta de ganado vivo, conforme a lo establecido en la resoluci&#xF3;n Ex. N&#xBA; 3.721, del 28.07.2000, de la Direcci&#xF3;n Nacional.</div><br></div>", "i": 6644864}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Aguirre P&#xE9;rez, Director Regional (S). </div></div>", "i": 6644865}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5152 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5152 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL DE VALPARAÍSO"], "titulo_norma": "DEJA SIN EFECTO LA CALIDAD DE AGENTE RETENEDOR DEL IVA,\nSEGÚN AVISO DE FECHA 02.09.1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-07-04", "doble_articulado": false, "id_norma": "270527", "numero_fuente": "39038", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-04-16", "vigencias": [{"desde": "2008-04-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-04-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vige