{"html": [{"t": "<div><div class=\"p\">RECTIFICA RESOLUCIONES N&#xBA; 1.491 Y 2.601, AMBAS DE 2012</div></div>", "i": 9321735}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 3.295, de 14 de diciembre de 2012, de esta Subsecretar&#xED;a, rect&#xED;ficanse las resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=1040877&amp;idParte=0&amp;idVersion=\">N&#xBA; 1.491</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1044515&amp;idParte=0&amp;idVersion=\">N&#xBA; 2.601</a>, ambas de 2012 y de esta Subsecretar&#xED;a de Pesca, que estableci&#xF3; la n&#xF3;mina definitiva de armadores artesanales y sus embarcaciones, que participaron de las pescas de investigaci&#xF3;n a que se refiere el art&#xED;culo 3&#xBA; de la ley N&#xBA;20.560, en el sentido de modificar sus numerales 1.- y 12.- de conformidad a lo indicado en resoluci&#xF3;n extractada.</div></div>", "i": 9321736}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de diciembre de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9321737}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3295 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-3295 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "RECTIFICA RESOLUCIONES Nº 1.491 Y 2.601, AMBAS DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-12-14", "doble_articulado": false, "id_norma": "1047413", "numero_fuente": "40441", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-12-2