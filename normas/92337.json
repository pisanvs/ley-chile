{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.408, DE 1989 </div><br><br></div>", "i": 6091272}, {"t": "<div><br><div class=\"p\">Por Resoluci&#xF3;n Exenta No. 1.408 de fecha 11 de mayo de 1989 de la Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica, se reemplazaron las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica Agr&#xED;cola SNA de Paine, aprobadas por Resoluci&#xF3;n Exenta de Educaci&#xF3;n No. 3.437 de 1988, las que podr&#xE1;n aplicarse a contar del a&#xF1;o acad&#xE9;mico 1989.</div><br></div>", "i": 6091273}, {"t": "<div><div class=\"p\">&#xBA;Santiago, 09 de Junio de 1989.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. Ministerio de Justicia </div></div>", "i": 6091274}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1408 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1408 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.408, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1989-05-11", "fecha_derogacion": "2003-01-22", "doble_articulado": false, "id_norma": "92337", "numero_fuente": "33408", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1989-06-27", "vigencias": [{"desde": "2003-01-22", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1989-06-27", "hasta": "2003-01-21", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2003-01-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic