{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 167, DE 1984 </div></div>", "i": 6248741}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 167, de 14 de Septiembre de 1984, se ha procedido a aprobar a contar desde el a&#xF1;o 1985, planes y programas especiales de estudio para el 2&#xB0; ciclo de Educaci&#xF3;n General B&#xE1;sica y para Educaci&#xF3;n Media Human&#xED;stico Cient&#xED;fica a la Escuela Experimental de M&#xFA;sica de La Serena.</div><div class=\"p\">&nbsp; &nbsp;  La evaluaci&#xF3;n y promoci&#xF3;n de los alumnos se regir&#xE1; por las normas vigentes sobre la materia.- Marta </div></div>", "i": 6248742}, {"t": "<div><div class=\"p\">Stefanowsky Bandyra, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante.</div><br></div>", "i": 6248743}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "167", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-167"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 167, DE 1984", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-09-14", "doble_articulado": false, "id_norma": "160419", "numero_fuente": "32141", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-04-09", "vigencias": [{"desde": "1985-04-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-04-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-04-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "