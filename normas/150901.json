{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6217711}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 324 de 11 de Junio de 1987, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se autoriza a don Luis H. Aravena Suazo, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6217712}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lucia M. Leiva Madariaga, Secretario Regional Ministerial Transportes y Telecomunicaciones VIII Regi&#xF3;n Subrogante.</div><br></div>", "i": 6217713}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "324 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-324 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-11", "doble_articulado": false, "id_norma": "150901", "numero_fuente": "32801", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-22", "vigencias": [{"desde": "1987-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-06-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes"