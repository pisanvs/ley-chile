{"html": [{"t": "<div><br><div class=\"p\">SUSTITUYE MODELO DE DECLARACI&#xD3;N JURADA FORMULARIO N&#xBA; 1879</div></div>", "i": 9268403}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 70 del 19 de junio de 2012, que dispone:</div><div class=\"p\">&nbsp; &nbsp;  Sustit&#xFA;yese el Modelo de Declaraci&#xF3;n Jurada Formulario N&#xBA; 1879 a que se refiere la <a href=\"https://www.leychile.cl/Navegar?idNorma=40426&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 4.085, de fecha 24.12.1990</a>, y sus modificaciones posteriores, por el que se adjunta como Anexo N&#xBA; 1 a la presente resoluci&#xF3;n, con vigencia a partir del A&#xF1;o Tributario 2013.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII de junio de 2012.</div><br></div>", "i": 9268404}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "70 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-70 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "SUSTITUYE MODELO DE DECLARACIÓN JURADA FORMULARIO Nº 1879", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-19", "doble_articulado": false, "id_norma": "1041205", "numero_fuente": "40294", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-22", "vigencias": [{"desde": "2012-06-22", "has