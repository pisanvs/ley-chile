{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6200798}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1 del Compendio de Normas Financieras certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables de 90 a 365 d&#xED;as, correspondiente a la primera quincena de julio de 1987, fue de 4.30% anual.</div><br></div>", "i": 6200799}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de julio de 1987.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6200800}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-16", "doble_articulado": false, "id_norma": "146378", "numero_fuente": "32822", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-17", "vigencias": [{"desde": "1987-07-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-07-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-11-02", "fecha_version": "1987-07-17", "fecha_actualizacion_texto": "1987-07-17", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6200798}, {"n": "Artículo", "i": 6200