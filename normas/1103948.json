{"html": [{"t": "<div><div class=\"p\">EXTRACTO RESOLUCI&#xD3;N N&#xB0; 2.326 EXENTA, DE 31 DE MAYO DE 2017</div></div>", "i": 9805364}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 2.326, de 31 de mayo de 2017, del Servicio Nacional de Capacitaci&#xF3;n y Empleo, se extiende periodo de uso en forma simult&#xE1;nea, de libro de clases f&#xED;sico y &quot;Nuevo Libro de Clases Electr&#xF3;nico (LCE)&quot;, por las razones que indica.</div></div>", "i": 9805365}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de mayo de 2017.- Pedro Goic Boroevic, Director Nacional, Servicio Nacional de Capacitaci&#xF3;n y Empleo.</div></div>", "i": 9805366}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2326 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2326 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARÍA DEL TRABAJO", "SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO RESOLUCIÓN N° 2.326 EXENTA, DE 31 DE MAYO DE 2017", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; CVE 1227142"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-05-31", "doble_articulado": false, "id_norma": "1103948", "numero_fuente": "41783", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-06-14", "vigencias": [{"desde": "2017-06-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-06-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2017-06-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "conco