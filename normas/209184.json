{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 263 EXENTO, DE 2002</div><br><br></div>", "i": 7299081}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 263, de 1 de abril de 2002, se ha aprobado al Colegio Orchard College de Curic&#xF3; el siguiente plan de estudio para los cursos de 7&#xBA; y 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 7299082}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de abril de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7299083}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "263 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-263 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 263 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-01", "doble_articulado": false, "id_norma": "209184", "numero_fuente": "37533", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-04-11", "vigencias": [{"desde": "2003-04-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-04-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-04-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}