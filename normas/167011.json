{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6269848}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 941, de fecha 03 de Agosto de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a don Carlos Orlando Mart&#xED;nez Romero para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6269849}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de Agosto de 1987.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6269850}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "941 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-941 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-03", "doble_articulado": false, "id_norma": "167011", "numero_fuente": "32895", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-10-16", "vigencias": [{"desde": "1987-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-10-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-10-16", "fin_vigencia": "", "tip