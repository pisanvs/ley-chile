{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6271898}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 697, de 02.07.87 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones VII Regi&#xF3;n, se autoriza a do&#xF1;a Mina Eufracia G&#xE1;lvez Alegr&#xED;a para efectuar, todo tipo de servicio de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6271899}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mariano Varas Hern&#xE1;ndez, Secretario Regional Ministerial (S) de Transportes y Telecomunicaciones de la Regi&#xF3;n del Maule.</div><br></div>", "i": 6271900}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "697 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-697 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-02", "doble_articulado": false, "id_norma": "167633", "numero_fuente": "32940", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-09", "vigencias": [{"desde": "1987-12-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v