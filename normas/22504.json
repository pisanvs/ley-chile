{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Jardin del Congreso Lei n&#xFA;m. 1,251.- Santiago, a 28 de Agosto de 1899.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese un suplemento de mil pesos al &#xED;tem 5 de la partida 3.a del Presupuesto del Ministerio del Interior para conservacion del Jardin de la plazuela del Congreso.</div><br><br></div>", "i": 8274220}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- Federico Err&#xE1;zuriz.- R. Silva Cruz.</div><br></div>", "i": 8274221}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1251", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1251"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "JARDIN DEL CONGRESO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONGRESO NACIONAL", "JARDIN", "CONSERVACION", "FONDOS", "PRESUPUESTO A O 1899", "MODIFICACION", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-08-28", "doble_articulado": false, "id_norma": "22504", "numero_fuente": "6385", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-08-28", "vigencias": [{"desde": "1899-08-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-08-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-08-28", "fin_vigencia": "",