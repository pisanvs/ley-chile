{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 11 EXENTA, DE 27 DE FEBRERO DE 2002 </div></div>", "i": 6371145}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modifica resoluci&#xF3;n N&#xBA; Ex. 05 del 28.01.2002 que estableci&#xF3; la obligaci&#xF3;n de las sociedades Administradoras de Fondos Mutuos de informar al SII las inversiones efectuadas por los part&#xED;cipes en dichos fondos y el mayor o menor valor obtenido en el rescate de cuotas y de certificar a los beneficiarios de dichas rentas.</div><br><br><div class=\"p\">&nbsp; &nbsp;  1.- Modifica resoluci&#xF3;n N&#xBA; Ex. 05 del 28.01.2002 reemplazando su resolutivo N&#xBA; 8.</div><div class=\"p\">&nbsp; &nbsp;  2.- La presente resoluci&#xF3;n regir&#xE1; a contar de la fecha de su publicaci&#xF3;n en el Diario Oficial. </div></div>", "i": 6371146}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Benjam&#xED;n Schutz Garc&#xED;a, Director (S). </div></div>", "i": 6371147}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "11 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-11 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 11 EXENTA, DE 27 DE FEBRERO DE\n2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-27", "doble_articulado": false, "id_norma": "195063", "numero_fuente": "37201", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-03-04", "vigencias": [{"desde": "2002-03-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-03-04", "fi