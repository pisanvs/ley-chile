{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DEROGA LEY N&#xB0; 15.740 Teniendo presente que el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; P r o y e c t o d e l e y:</div><br></div>", "i": 8859558}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Der&#xF3;gase la Ley N&#xB0; 15.740, publicada en el Diario Oficial de 27 de octubre de 1964.&quot;.</div><br></div>", "i": 8859559}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 24 de enero de 1996.- EDUARDO FREI RUIZ-TAGLE, Presidente de la Rep&#xFA;blica.- Carlos Figueroa Serrano, Ministro del Interior.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud., para su conocimiento.- Saluda a Ud., Belisario Velasco Baraona, Subsecretario del Interior.</div><br></div>", "i": 8859560}], "proyectos": [{"categoria": "Proyecto original", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=1678-06", "informacion": "Deroga la ley Nº 15740, y cambia la denominación \\\"Yugoslavia\\\" por \\\"Croacia\\\" a calle de la ciudad de Punta Arenas", "nroBoletin": "1678-06"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "19445", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-19445"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DEROGA LEY N° 15.740", "fuente": "Diario Oficial", "resumenes": [], "materias": ["Nombre de Calle en Punta Arenas", "Ley no. 19.445"], "terminos_libres": ["CALLE YUGOESLAVIA", "DEROGACION", "PUNTA ARENAS", "DECIMOSEGUNDA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tac