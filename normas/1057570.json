{"html": [{"t": "<div><br><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESI&#xD3;N N&#xBA; 1794</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile, en su Sesi&#xF3;n Ordinaria N&#xBA; 1794, celebrada el 19 de diciembre de 2013, adopt&#xF3; el siguiente Acuerdo:</div></div>", "i": 9394162}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  1794-05-131219 - Tasa de inter&#xE9;s para pago diferido de derechos de aduana.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  En conformidad con lo establecido en la letra c) del art&#xED;culo 10 de la ley N&#xBA; 18.634, la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de derechos de aduana durante el semestre que concluye el 30 de junio de 2014, ser&#xE1; de 5,9% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.</div></div>", "i": 9394163}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de diciembre de 2013.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div></div>", "i": 9394164}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1794", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1794"}, {"tipo": "5", "numero": "1794-05", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1794-05"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESIÓN Nº 1794", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-12-19", "doble_articulado": false, "id_norma": "1057570", "num