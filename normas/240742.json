{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6535268}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto MOP (exento) N&#xBA; 606 de fecha 30 de junio de 2005, se expropiaron los lotes de terrenos N&#xBA;s 111 y 112, superficie 1.917 y 1.544 m2, Rol N&#xBA; 238-21, comuna de Tolt&#xE9;n, IX Regi&#xF3;n para la obra &quot;Camino Ruta S-790, sector Nueva Tolt&#xE9;n-L&#xED;mite Regional (Queule), tramo Km.</div><div class=\"p\">87,50000 a Km. 103,33500, correspondiente al Sub-Tramo III. Km 87,50000 a Km. 92,33000&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Pedro &#xD1;ancu&#xE1;n, ascendente a la cantidad de $1.707.154.- para los lotes N&#xBA; s 111 y 112.-</div><br></div>", "i": 6535269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6535270}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "606 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-606 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-30", "doble_articulado": false, "id_norma": "240742", "numero_fuente": "38225", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-08-01", "vigencias": [{"desde": "2005-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fe