{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza la ereccion de un monumento a Lord Cochrane Lei n&#xFA;m. 3,098.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275936}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Se autoriza la ereccion en el puerto de Corral de un monumento que perpet&#xFA;e la memoria del Ilustre Marino Lord Thomas Cochrane.</div><br></div>", "i": 8275937}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 29 de Abril de 1916.- JUAN LUIS SANFUENTES.- Maximiliano Ib&#xE1;&#xF1;ez.</div><br></div>", "i": 8275938}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3098", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3098"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA LA ERECCIÓN DE UN MONUMENTO A LORD COCHRANE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["THOMAS COCHRANE", "MONUMENTO", "ERECCION", "AUTORIZACION", "CORRAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-04-29", "doble_articulado": false, "id_norma": "23734", "numero_fuente": "11466", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-05-08", "vigencias": [{"desde": "1916-05-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1916-05-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1916-05-08", "fin