{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;19 EXENTO, DE 2003</div><br><br></div>", "i": 6412775}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;19 de fecha 9 de enero de 2003 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a la Sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica Santo Tom&#xE1;s para impartir plan y programas de estudios aprobados para la instituci&#xF3;n de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se se&#xF1;ala, a partir del a&#xF1;o 2003:</div><br><div class=\"p\">Sede N&#xBA;24-Talca Carrera: Asistente Ejecutivo Titulo : T&#xE9;cnico Asistente Ejecutivo de Nivel Superior (Dec. Ex. N&#xBA;572 de 27.08.01) </div></div>", "i": 6412776}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de enero de 2003.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6412777}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "19 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-19 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº19 EXENTO, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-09", "doble_articulado": false, "id_norma": "207374", "numero_fuente": "37478", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-02-06", "vigencias": [{"desde": "2003-02-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-02-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-02-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe