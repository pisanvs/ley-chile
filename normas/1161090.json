{"html": [{"t": "<div><div class=\"p\">NOMBRAMIENTO. </div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Mayo 17 de 1832.</div></div>", "i": 10263207}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Hall&#xE1;ndose vacante el destino de Ministro de Estado en los departamentos del Interior y Relaciones Exteriores, por dimision del ciudadano que los serv&#xED;a, vengo en nombrar para su desempe&#xF1;o a Joaquin Tocornal, de cuya probidad, luces y amor p&#xFA;blico estoy plenamente satisfecho. </div><br><br></div>", "i": 10263208}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon y comun&#xED;quese.</div><br><div class=\"p\">&nbsp; &nbsp;  PRIETO.&nbsp; &nbsp;  De orden de S. E.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Manuel Carvallo. </div></div>", "i": 10263209}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "NOMBRAMIENTO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-05-17", "doble_articulado": false, "id_norma": "1161090", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-05-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-05-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-05-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-08-26", "fecha_version": "1832-05-17", "fecha_actualizacion_texto":