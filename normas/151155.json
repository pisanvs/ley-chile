{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6218721}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 687 de 30 de Junio de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se autoriza a don Clemente Urrutia Gonz&#xE1;lez. para efectuar las revisiones t&#xE9;cnicas de los veh&#xED;culos de transporte de personas de m&#xE1;s de nueve (9) asientos, incluido el del conductor; de veh&#xED;culos motorizados de carga con capacidad para transportar m&#xE1;s de 1.850 kilos, sus remolques y semirremolques y los taxis, en el establecimiento ubicado en calle Miraflores No. 1493 de la ciudad de San Javier.- </div></div>", "i": 6218722}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Manuel Coloma Amaro, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n del Maule.</div><br></div>", "i": 6218723}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "687 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-687 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-30", "doble_articulado": false, "id_norma": "151155", "numero_fuente": "32817", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-11", "vigencias": [{"desde": "1987-07-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-11", "f