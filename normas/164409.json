{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xB0; 3, DE 1985</div><br><br></div>", "i": 7266973}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 83, de 05 de Febrero de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n N&#xB0; 3, de 04 de Enero de 1985, de la misma Subsecretar&#xED;a, que autoriz&#xF3; a la Sociedad Procesadora de Productos Marinos Limitada, domiciliada en Arica, para elaborar recursos hidrobiol&#xF3;gicos en la planta ubicada en Caut&#xED;n 4448, de Antofagasta, en orden a sustituir en su numeral 2&#xB0; el domicilio de la planta triplicada por &quot;calle Pedro Aguirre Cerda N&#xB0; 7747, Antofagasta&quot;.</div><br></div>", "i": 7266974}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 05 de Febrero de 1985.- Jorge Valenzuela Dur&#xE1;n, Coronel de Ej&#xE9;rcito, Subsecretario de Pesca subrogante.</div><br></div>", "i": 7266975}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "83", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-83"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION N° 3, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1985-02-05", "fecha_derogacion": "1986-08-14", "doble_articulado": false, "id_norma": "164409", "numero_fuente": "32092", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1985-02-08", "vigencias": [{"desde": "1986-08-14", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1985-