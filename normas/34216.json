{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291670}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 296, de 12 de febrero de 1996, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por SALMAR SOCIEDAD ANONIMA, para un centro de cultivo ubicado en Punta Apab&#xF3;n, Comuna de Puqueld&#xF3;n, Provincia de Chilo&#xE9;, X Regi&#xF3;n, por no dar cumplimiento el respectivo proyecto t&#xE9;cnico a lo dispuesto en el art&#xED;culo 87&#xB0; de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8291671}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 12 de febrero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8291672}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "296", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-296"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "SALMAR SOCIEDAD ANONIMA", "PUQUELDON", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-02-12", "doble_articulado": false, "id_norma": "34216", "numero_fuente": "35396", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-02-19", "vigencias": [{"desde": "1996-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-02-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-02-19", "fin_vigencia": "", "tipo_version": "