{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6543503}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.045, de 13 de septiembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA EDEN LIMITADA, para ampliar las actividades pesqueras de transformaci&#xF3;n autorizadas por las resoluciones citadas en Visto, en orden a incorporar a la planta ubicada en Hijuela Industrial N&#xBA; 286-B, Km. 3.5 Norte, comuna de Puerto Natales, XII Regi&#xF3;n, en las l&#xED;neas de proceso de Cocido, Congelado y Conserva, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6543504}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de septiembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6543505}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3045 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3045 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-13", "doble_articulado": false, "id_norma": "242831", "numero_fuente": "38286", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-10-14", "vigencias": [{"desde": "2005-10-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-10-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-10-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingres