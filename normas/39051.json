{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; COMPLEMENTA RESOLUCION N&#xB0; 1.213 EXENTA, DE 1992 N&#xFA;m. 501 exenta.- Santiago, 19 de abril de 1994.- Visto: El Decreto Ley N&#xB0; 2.136 de 1978 en su texto fijado por el art&#xED;culo 83 de la Ley N&#xB0; 18.768.</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br><br><br></div>", "i": 7201577}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Complem&#xE9;ntase la Resoluci&#xF3;n Exenta N&#xB0; 1.213/92, de la Subsecretar&#xED;a de Transportes, en el sentido de agregar la siguiente letra g) a su numeral 1.-:</div><div class=\"p\"> &quot;g) Distintivos autoadhesivos para</div><div class=\"p\">&nbsp; &nbsp;  veh&#xED;culos de servicios licitados&nbsp;  $ 1.800&quot;. </div></div>", "i": 7201578}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Claudio Hohmann Barrientos, Subsecretario de Transportes.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Saluda a Ud.- Patricia Mu&#xF1;oz Villela, Jefe Dpto. Administrativo. </div></div>", "i": 7201579}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "501 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-501 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "COMPLEMENTA RESOLUCION N° 1.213 EXENTA, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TARIFAS", "DISTINTIVO", "LOGOTIPO", "VEHICULOS", "MOTORIZADOS", "SERVICIO PUBLICO TRANSPORTE PASAJEROS", "LICITACION PUBLICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-04-19", "fecha_derogacion": "1998-05-27", "doble_articulado": false, "id_norma": "39051", "numero_fuente": "34847", "tipo