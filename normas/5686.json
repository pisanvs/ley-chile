{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Modifica el decreto-ley n&#xFA;mero 24</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 35.- Santiago, 30 de Junio de 1932.- La Junta de Gobierno ha acordado y dicta el siguiente</div><div class=\"p\">&nbsp; &nbsp; Decreto-ley:</div><br></div>", "i": 5871371}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Modif&#xED;case el decreto ley n&#xFA;mero 24, de fecha 14 del presente, en cuanto dispone que las Cajas de Previsi&#xF3;n dependan del Ministerio de Hacienda y se declara que la Caja de Seguro Obligatorio pasar&#xE1; a depender, en todas sus partes, del Ministerio de Salubridad P&#xFA;blica.</div><br></div>", "i": 5871372}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- CARLOS DAVILA.- Nolasco C&#xE1;rdenas.- J. E. Pe&#xF1;a Villal&#xF3;n.- Dr. A. Quijano.</div><br></div>", "i": 5871373}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "35", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-35"}], "organismos": ["MINISTERIO DE SALUBRIDAD PÚBLICA"], "titulo_norma": "MODIFICA EL DECRETO-LEY NUMERO 24", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAJAS PREVISION", "CAJA SEGURO OBLIGATORIO", "DEPENDENCIA", "MINISTERIO SALUBRIDAD PUBLICA", "MINISTERIO HACIENDA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-06-30", "doble_articulado": false, "id_norma": "5686", "numero_fuente": "16341", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-08-04", "vigencias": [{"desde": "1932-08-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}