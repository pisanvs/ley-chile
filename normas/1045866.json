{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO ALCALDICIO N&#xB0; 2.304 EXENTO, DE 2012</div></div>", "i": 9312874}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por decreto alcaldicio ex. N&#xBA; 2.304, de 9 de noviembre de 2012, se fija el Texto Refundido y Sistematizado de la Ordenanza N&#xB0;22, de 28 de diciembre de 2001, y sus modificaciones &quot;Ordenanza Local Sobre Derechos Municipales&quot; que regir&#xE1; en el a&#xF1;o 2013.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo se encuentra en la p&#xE1;gina web municipal, Transparencia Activa en Carpeta Marco Normativo Aplicable/Ordenanzas/Derecho/Sobre Derechos Municipales.- </div></div>", "i": 9312875}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  El Alcalde.</div></div>", "i": 9312876}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2304 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2304 EXENTO"}], "organismos": ["MUNICIPALIDAD DE PROVIDENCIA"], "titulo_norma": "EXTRACTO DE DECRETO ALCALDICIO N° 2.304 EXENTO, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-11-09", "doble_articulado": false, "id_norma": "1045866", "numero_fuente": "40413", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-11-19", "vigencias": [{"desde": "2012-11-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-11-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-11-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "