{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7353953}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (Exento) N&#xBA; 467 de fecha 30 de agosto de 2007, se expropiaron los lotes de terreno N&#xBA;s 15-B y 17-B, superficies 225,48 y 532 m2, respectivamente, rol N&#xBA; 557-200, comuna de Linares, para la obra &quot;Camino Conservaci&#xF3;n Ruta L-45, Sector Escuela Llepo - Puente Los Hualles, Tramo Km. 13,14700 a Km.</div><div class=\"p\">36,446&quot;, VII Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Gustavo Leopoldo Cerda Valenzuela, ascendente a la cantidad de $1.786.584. </div></div>", "i": 7353954}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 7353955}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "467 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-467 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-08-30", "doble_articulado": false, "id_norma": "264878", "numero_fuente": "38865", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-09-15", "vigencias": [{"desde": "2007-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2007-09-20", "fecha_version": "2007-09-15", "fecha_act