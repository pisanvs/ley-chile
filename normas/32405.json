{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7194302}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 032 de 31 de Mayo de 1993, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la V Regi&#xF3;n, se adjudic&#xF3; a Automotora Villa Alemana Ltda., la concesi&#xF3;n para operar, hasta el 09/08/97, un establecimiento ubicado en calle Los Morenos N&#xB0; 792 de Los Andes, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de emisi&#xF3;n de contaminantes de todo tipo de veh&#xED;culos motorizados, sus remolques y semirremolques, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba. </div></div>", "i": 7194303}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Adolfo Tannenbaum Ram&#xED;rez, Secretario Regional Ministerial de Transportes y Telecomunicaciones V Regi&#xF3;n.</div><br></div>", "i": 7194304}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "32", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-32"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL V REGIÓN DE VALPARAÍSO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION REVISION TECNICA", "PLANTA REVISION TECNICA", "VEHICULOS MOTORIZADOS", "QUINTA REGION", "ANDES", "AUTOMOTORA", "VILLA ALEMANA LTDA."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-05-31", "doble_articulado": false, "id_norma": "32405", "numero_fuente": "34692", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-10-16", "vigencias": [{"desde": "1993-10-16", "hasta": "", "tipo_version": "3", "tipo_version_