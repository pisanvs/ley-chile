{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL BANCO CENTRAL DE CHILE EN SU SESION N&#xBA; 393</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 393, celebrada el 7 de Diciembre de 1994, celebr&#xF3; los siguientes acuerdos:</div><br><div class=\"p\">393-04-941207 - Modifica caracter&#xED;sticas de los billetes de $10.000.-</div><br></div>", "i": 7329658}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; modificar el Acuerdo del Comit&#xE9; Ejecutivo N&#xBA; 1942-03-890621, que fij&#xF3; las caracter&#xED;sticas de los billetes de $10.000, reemplazando la frase referida a pie de imprenta, en el p&#xE1;rrafo correspondiente a Anverso, por la siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;Bajo el borde inferior, tiene el pie de imprenta &quot;CASA DE MONEDA DE CHILE&quot; o bien est&#xE1; en blanco&quot;. </div></div>", "i": 7329659}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de Diciembre de 1994.- Jorge Carrasco V&#xE1;squez, Ministro de Fe (S).</div><br></div>", "i": 7329660}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "393", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-393"}, {"tipo": "5", "numero": "393-04", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-393-04"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL BANCO CENTRAL DE CHILE EN SU\nSESION Nº 393", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-12-07", "doble_articulado": false, "id_norma": "249481", "numero_fuente": "35038", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publica