{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 279, DE 1990 </div></div>", "i": 6060951}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 279 de 25 de octubre de 1990 se han aprobado, a contar del a&#xF1;o escolar 1991, a la Escuela Diferencial E No. 497, dependiente de la Corporaci&#xF3;n Municipal de San Miguel, de la Regi&#xF3;n Metropolitana, programas de estudio para el ciclo 1 del nivel pre - b&#xE1;sico y para el nivel laboral.</div><div class=\"p\">Adem&#xE1;s, se aprueban los objetivos generales y espec&#xED;ficos de las Areas de Formaci&#xF3;n General y de los diversos cursos de los distintos talleres y especialidades.</div><br></div>", "i": 6060952}, {"t": "<div><div class=\"p\">Santiago, 29 de Noviembre de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6060953}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "279", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-279"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 279, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-10-25", "doble_articulado": false, "id_norma": "81879", "numero_fuente": "33837", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-12-06", "vigencias": [{"desde": "1990-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-12-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-12-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": []