{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8300987}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 108, de 22 de enero de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad parcial de la Resoluci&#xF3;n N&#xBA; 251, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a COMPA&#xD1;IA PESQUERA CABO AUSTRAL S.A., para desarrollar actividades pesqueras extractivas con la nave &quot;Gendarme I&quot;, s&#xF3;lo en lo relativo a la especie Langostino amarillo Cervimunida johni, por haberse configurado la causal prevista en el art&#xED;culo 143 letra b) de la Ley N&#xBA; 18.892 y sus modificaciones. </div></div>", "i": 8300988}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de enero de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8300989}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "108", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-108"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMPA IA PESQUERA CABO AUSTRAL S.A.", "PESCA", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-01-22", "doble_articulado": false, "id_norma": "60594", "numero_fuente": "35680", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-01-31", "vigencias": [{"desde": "1997-01-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-01-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"ini