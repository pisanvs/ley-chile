{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO N&#xBA; 1.973 EXENTO, DE 2005 </div></div>", "i": 6552547}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Ilustre Municipalidad de Rancagua modific&#xF3; mediante decreto exento N&#xBA;2.403, de fecha 22 de noviembre de 2005, el decreto exento 1.973, de fecha 4 de octubre de 2005, que aprob&#xF3; la modificaci&#xF3;n a la &quot;Ordenanza Municipal para determinar tarifas de aseo, cobro y exenciones parciales o totales de &#xE9;stas&quot;, quedando en el siguiente sentido:</div><br><div class=\"p\">Donde dice:</div><br><div class=\"p\">Incorp&#xF3;rase el siguiente Art&#xED;culo Transitorio:</div><br><div class=\"p\">&quot;Art&#xED;culo Transitorio:.....hasta el 30 de diciembre de</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  2006.&quot;</div><br><div class=\"p\">Debe decir:</div><div class=\"p\">Incorp&#xF3;rase el siguiente Art&#xED;culo Transitorio:</div><br><div class=\"p\">&quot;Art&#xED;culo Transitorio:.....hasta el 30 de diciembre de</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  2005.&quot;</div><br><br></div>", "i": 6552548}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Aliro Osvaldo Pontigo Donoso, Administrador Municipal.- Carlos Morales Lara, Secretario Municipal. </div></div>", "i": 6552549}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2403 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2403 EXENTO"}], "organismos": ["MUNICIPALIDAD DE RANCAGUA"], "titulo_norma": "MODIFICA DECRETO Nº 1.973 EXENTO, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": []