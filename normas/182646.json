{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6325580}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 287, de 21 de febrero de 2001, de esta Subsecretar&#xED;a, autor&#xED;zase a CONSTRUCCIONES Y CARPINTERIA NAVAL CONCAR S.A. para realizar operaciones pesqueras, a contar de la fecha de la presente resoluci&#xF3;n y hasta el 31 de diciembre del a&#xF1;o 2001, ambas fechas inclusive, con el barco f&#xE1;brica denominado &apos;&apos;Mar&#xED;a Tamara&apos;&apos;, en aguas interiores, al sur del paralelo 47&#xBA; L.S., respecto de los recursos y con las obligaciones, establecidas en sus respectivas resoluciones.</div><br></div>", "i": 6325581}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de febrero de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6325582}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "287", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-287"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-21", "doble_articulado": false, "id_norma": "182646", "numero_fuente": "36906", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-07", "vigencias": [{"desde": "2001-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-03-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "i