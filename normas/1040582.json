{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9262128}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. Exento N&#xBA;777, de 30 de abril de 2012, y de conformidad a lo dispuesto en el art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;52A, superficie 1.370 m2., Rol N&#xBA;2410-51 en tr&#xE1;mite, para ta obra &quot;MEJORAMIENTO RUTA T-35, LOS LAGOS -VALDIVIA, SECTOR ANTILHUE - VALDIVIA TRAMO 2&quot;, comuna de Valdivia, Regi&#xF3;n de Los R&#xED;os. La comisi&#xF3;n de peritos integrada por Sonia Catalina Gallegos Blanch, Patricio Fernando Casagrande Ulloa y Norman Calder&#xF3;n Pontiggia, fij&#xF3; el valor de tasaci&#xF3;n con fecha 10 de diciembre de 2010, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietaria JEANNETTE ABIGAIL CATAL&#xC1;N REYES, en la cantidad de $2.449.754.- suma que se pagar&#xE1; al contado.</div></div>", "i": 9262129}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9262130}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "777 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-777 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-04-30", "doble_articulado": false, "id_norma": "1040582", "numero_fuente": "40276", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-01", "vigencias": [{"desde": "2012-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-06-01", "fin_vigencia": ""},