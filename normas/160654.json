{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6249497}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 98 de 18 de Marzo de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se autoriza a S&#xE1;ez y Compa&#xF1;&#xED;a Limitada, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro de territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6249498}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco Navarro Ruiz, Secretario Regional Ministerial Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6249499}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "98 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-98 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-03-18", "doble_articulado": false, "id_norma": "160654", "numero_fuente": "32438", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-04-04", "vigencias": [{"desde": "1986-04-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-04-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-04-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient