{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 5.414 EXENTA, DE 13.08.2012</div></div>", "i": 9289944}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta que se indica, del Ministerio de Educaci&#xF3;n, se elimina del Libro de Registro de Institutos Profesionales en que se encuentra inscrito el Instituto Profesional Instituto de Ciencias Linus Pauling (en formaci&#xF3;n), con el N&#xBA; 136, de fecha 23 de agosto de 2011, organizado por la Sociedad Educacional Paulsen Limitada o Instituto de Ciencias Linus Pauling o ILPA, ubicado en calle Del Arzobispo N&#xBA;0621, de la ciudad de Santiago.</div></div>", "i": 9289945}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de agosto de 2012.- Fernando Rojas Ochagav&#xED;a, Subsecretario de Educaci&#xF3;n.</div></div>", "i": 9289946}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5414 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5414 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 5.414 EXENTA, DE 13.08.2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-08-13", "doble_articulado": false, "id_norma": "1043069", "numero_fuente": "40340", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-08-18", "vigencias": [{"desde": "2012-08-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-08-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-08-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion