{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6381685}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;577, de fecha 28 de marzo de 2002, se expropi&#xF3; el lote de terreno N&#xBA;3, superficie 2.582 m2.; rol de aval&#xFA;o 511-21, comuna de Carahue, IX Regi&#xF3;n, para la obra &quot;Camino Ruta S-36, Sector Tranapuente - Nehuent&#xFA;e; Tramo Km.</div><div class=\"p\">0,000 al 9,997062, correspondiente al Subtramo I, Km. 0,000 al 4,230&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria do&#xF1;a Ana Rosa Pinto M&#xE9;ndez, ascendente a la cantidad de $2.845.315.-</div><br></div>", "i": 6381686}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6381687}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "577", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-577"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-28", "doble_articulado": false, "id_norma": "198197", "numero_fuente": "37259", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-15", "vigencias": [{"desde": "2002-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MAS", "fecha_ingreso": "2002-05-15", "fecha_version": "2002-05-15", "fecha_actualizacion_texto":