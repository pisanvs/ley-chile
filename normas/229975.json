{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6495731}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.367, de 27 de agosto de</div><div class=\"p\">2004, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad</div><div class=\"p\">parcial de la resoluci&#xF3;n N&#xBA; 1.850 de 2000, de esta</div><div class=\"p\">Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a MARCELINO</div><div class=\"p\">SEGUNDO GONZALEZ SILVA para ampliar las actividades</div><div class=\"p\">extractivas con la nave &quot;Berta&quot;, entre la V Regi&#xF3;n y el</div><div class=\"p\">paralelo 41&#xB0;28,6&apos; L.S., con red de arrastre, sobre el</div><div class=\"p\">recurso Alfonsino, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 6495732}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de agosto de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6495733}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2367 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2367 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-08-27", "doble_articulado": false, "id_norma": "229975", "numero_fuente": "37954", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-09-04", "vigencias": [{"desde": "2004-09-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigen