{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5844896}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de septiembre de 1996, fue de 7,02% anual.</div><br></div>", "i": 5844897}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, septiembre 16 de 1996.- Jorge Carrasco V&#xE1;squez, Ministro de Fe.</div><br></div>", "i": 5844898}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "9999", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-9999"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA INTERES PROMEDIO", "OPERACIONES CREDITO DINERO", "VALOR TIP"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-09-16", "doble_articulado": false, "id_norma": "1698", "numero_fuente": "35572", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-09-23", "vigencias": [{"desde": "1996-09-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-09-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-09-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1996-09-23", "fecha_actualizacion_texto": "1996-09-23", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 5844896}, {"n": "Artículo 1", "i": 5