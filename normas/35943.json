{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295015}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 966 de 26 de Noviembre de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, cad&#xFA;canse las Resoluciones N&#xB0; 353, de 1984 y N&#xB0; 329, de 1986, ambas de esta Subsecretar&#xED;a, que autorizaron a SOCIEDAD INDUSTRIAL PESQUERA DE CHILE LTDA., R.U.T. N&#xB0; 85.682.900-6, para operar las naves &quot;Sipec I&quot; y &quot;Sipec II&quot;, en virtud de lo prescrito en el art&#xED;culo 143 letra b) del D.S. N&#xB0; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8295016}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 26 de Noviembre de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8295017}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "966", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-966"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD INDUSTRIAL PESQUERA CHILE LTDA", "CADUCIDAD", "AUTORIZACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-11-26", "doble_articulado": false, "id_norma": "35943", "numero_fuente": "34735", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-12-07", "vigencias": [{"desde": "1993-12-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-12-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-1