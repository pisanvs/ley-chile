{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8329124}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA;428, de 6 de abril de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA;554, de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a MARIO EDULIO FLORES DIEDRICH, para instalar y operar un centro de cultivo ubicado en R&#xED;o Quenuir, comuna de Maull&#xED;n, X Regi&#xF3;n, por haberse derogado el respectivo decreto de concesi&#xF3;n de acuicultura.</div><br></div>", "i": 8329125}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8329126}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "428", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-428"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "MAULLIN", "MARIO EDULIO FLORES DIEDRICH", "DECIMA REGION", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-06", "doble_articulado": false, "id_norma": "97891", "numero_fuente": "36038", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-04-13", "vigencias": [{"desde": "1998-04-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-04-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-04-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendien