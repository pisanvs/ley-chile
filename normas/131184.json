{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6152352}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP N&#xBA; 2.542, de 30 de noviembre de 1998, se rectific&#xF3; el decreto MOP N&#xBA; 882, de fecha 30 de junio de 1998, que autoriz&#xF3; la expropiaci&#xF3;n del lote de terreno N&#xBA; 6, para la obra Camino Ruta 5 Sur, Sector Acceso Norte a Curic&#xF3;; en lo que respecta a la superficie de dicho lote que es 281 M2. y a la aprobaci&#xF3;n de un nuevo Convenio Directo de precio con do&#xF1;a Mar&#xED;a Elena Avenda&#xF1;o Puebla, ascendente a $ 25.726.204.</div><br></div>", "i": 6152353}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6152354}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2542", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2542"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-30", "doble_articulado": false, "id_norma": "131184", "numero_fuente": "36278", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-02-01", "vigencias": [{"desde": "1999-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-02-03", "fecha_version": "1999-02-01", "fecha_actualizacion_texto": "1999-02-01", "tipo_tratado": ""}, "alertas