{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; COMPLEMENTA LA LEY N.o 5,867, QUE CREA LA CORTE DE APELACIONES DE CHILLAN</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 8860889}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Agr&#xE9;ganse las palabras &quot;un</div><div class=\"p\">Secretario&quot;, despu&#xE9;s de la palabra &quot;Relator&quot;, en el</div><div class=\"p\">art&#xED;culo 1.o de la Ley n&#xFA;mero 5,867, de 8 de Agosto de 1936, y supr&#xED;mese el inciso tercero del mismo art&#xED;culo.</div><div class=\"p\">&nbsp; &nbsp; Esta Ley empezar&#xE1; a regir el 1.o de Enero de 1938&quot;. </div></div>", "i": 8860890}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintid&#xF3;s de Diciembre de mil novecientos treinta y siete.- ARTURO ALESSANDRI.- G. Correa F. </div></div>", "i": 8860891}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "6147", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-6147"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "COMPLEMENTA LA LEY N.o 5,867, QUE CREA LA CORTE DE\nAPELACIONES DE CHILLAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CHILLAN", "CORTE APELACIONES", "SECRETARIO", "ESCALAFON", "AGREGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1937-12-22", "doble_articulado": false, "id_norma": "25296", "numero_fuente": "17951", "tipo_version": "3", "tipo_version_s": "Úni