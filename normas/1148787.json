{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 3.883 EXENTA, DE 2019, DE ESTA SUBSECRETAR&#xCD;A</div></div>", "i": 10154097}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.848, de 25 de agosto de 2020, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1.- de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1140800&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.883 de 2019</a>, en el sentido de se&#xF1;alar que la distribuci&#xF3;n de las fracciones artesanales de las cuotas anuales de captura, por regi&#xF3;n, de las pesquer&#xED;as artesanales de Anchoveta y Sardina com&#xFA;n, en el &#xE1;rea mar&#xED;tima comprendida desde la Regi&#xF3;n de Valpara&#xED;so a la Regi&#xF3;n de Los Lagos, a&#xF1;o 2020, ser&#xE1; la siguiente:</div><div class=\"p\"> </div><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/112525.jpg\"></div><div class=\"p\"> </div><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/112526.jpg\"></div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10154098}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de agosto de 2020.- Rom&#xE1;n Zelaya R&#xED;os, Subsecretario de Pesca y Acuicultura.</div><div class=\"p\"> </div><br></div>", "i": 10154099}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1848 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-1848 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 3.883 EXENTA, DE 2019, DE ESTA SUBSECRETARÍA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1807044; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-08-25", "doble_articulado": false, "id_norma": "1148787", "numero_fuente": "42742", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-08-28", "vigencias": [{"desde": "2020-08-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2020-08-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2020-08-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "1795", "fecha_ingreso": "2020-08-28", "fecha_version": "2020-08-28", "fecha_actualizacion_texto": "2020-08-28", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10154097}, {"n": "Artículo", "i": 10154098, "t": 6}, {"n": "Promulgación", "i": 10154099}]}