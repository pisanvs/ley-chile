{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6093500}, {"t": "<div><div class=\"p\">El Banco Central de Chile, en conformidad a lo dispuesto en el No. 5 del Capitulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondientes a la primera quincena de diciembre de 1989, fue de 8,44% anual.</div><br></div>", "i": 6093501}, {"t": "<div><div class=\"p\">Santiago, 27 de diciembre de 1989.- Mar&#xED;a Eliana Torres Contreras, Secretario General subrogante.</div><br></div>", "i": 6093502}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-12-27", "doble_articulado": false, "id_norma": "93164", "numero_fuente": "33556", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-12-28", "vigencias": [{"desde": "1989-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-12-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-12-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1998-03-03", "fecha_version": "1989-12-28", "fecha_actualizacion_texto": "1989-12-28", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6093500}, {"n": "Artículo", "i": 6093501, "t": 6}, {"n": "Prom