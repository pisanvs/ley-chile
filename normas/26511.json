{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N.o 9,717, QUE CONCEDIO FONDOS A LA MUNICIPALIDAD DE SAN ROSENDO.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8279149}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Ampl&#xED;ase en dos a&#xF1;os el plazo establecido en el art&#xED;culo 2.o de la ley N.o 9,717, de 22 de Noviembre de 1950, que concedi&#xF3; fondos a la Municipalidad de San Rosendo para la construcci&#xF3;n de un Estadio en esa comuna&quot;.</div><br></div>", "i": 8279150}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a treinta de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Carlos Torres H.</div><br></div>", "i": 8279151}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10993", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10993"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA LA LEY N.o 9,717, QUE CONCEDIO FONDOS A LA\nMUNICIPALIDAD DE SAN ROSENDO.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "LEY 9717", "PLAZO", "CONSTRUCCION", "ESTADIO", "SAN ROSENDO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-30", "doble_articulado": false, "id_norma": "26511", "numero_fuente": "22411", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-11-28", "vigencias": [{"desde": "1952-11-28", "hasta": "", "tipo_v