{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7366248}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 661, de 7 de marzo de 2008, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 5.- de la resoluci&#xF3;n N&#xBA; 470 de 2008, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Caracterizaci&#xF3;n y cuantificaci&#xF3;n de la fauna acompa&#xF1;ante en las capturas de cerco, regi&#xF3;n Arica - Parinacota, Tarapac&#xE1; y Antofagasta 2008&quot;, en el sentido de incorporar a la embarcaci&#xF3;n artesanal &quot;Mary Paz II&quot;. </div></div>", "i": 7366249}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de marzo de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7366250}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "661 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-661 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-03-07", "doble_articulado": false, "id_norma": "269990", "numero_fuente": "39015", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-03-18", "vigencias": [{"desde": "2008-03-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-03-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia":