{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6395381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;1.791, de 21 de agosto de 2002,</div><div class=\"p\">de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA</div><div class=\"p\">QUINTERO LIMITADA, RUT N&#xBA;78.577.670-4, para ampliar las</div><div class=\"p\">actividades pesqueras extractivas con la nave &quot;Elbe&quot;,</div><div class=\"p\">autorizada por resoluciones citadas en visto, en orden</div><div class=\"p\">a realizar actividades pesqueras con la nave se&#xF1;alada</div><div class=\"p\">precedentemente, en el &#xE1;rea mar&#xED;tima comprendida entre</div><div class=\"p\">la V y VII Regiones, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, con arte de arrastre, sobre el recurso hidrobiol&#xF3;gico Raya Raja spp.</div><br></div>", "i": 6395382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de agosto de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6395383}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1791", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1791"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-08-21", "doble_articulado": false, "id_norma": "202310", "numero_fuente": "37352", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-09-05", "vigencias": [{"desde": "2002-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia