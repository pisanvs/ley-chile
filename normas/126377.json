{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 758 EXENTO, DE 1998</div><br><br><br></div>", "i": 6136711}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 758, de fecha 17 de julio de 1998, del Ministerio de Educaci&#xF3;n, se aprobaron las adecuaciones al plan y programas de estudios de la carrera de Asistente T&#xE9;cnico del Educador Diferencial con menci&#xF3;n en Dificultades del Aprendizaje y Deficiencia Mental, del Centro de Formaci&#xF3;n T&#xE9;cnica Celler, modific&#xE1;ndose en consecuencia la resoluci&#xF3;n exenta del Ministerio de Educaci&#xF3;n N&#xBA; 2.463, del 28 de octubre de 1982. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1998.</div><br></div>", "i": 6136712}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 2 de octubre de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6136713}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "758 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-758 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 758 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "CENTRO DE FORMACION TECNICA CELLER", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-17", "doble_articulado": false, "id_norma": "126377", "numero_fuente": "36197", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-10-26", "vigencias": [{"desde": "1998-10-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-10-26", "fin_vigencia": ""}