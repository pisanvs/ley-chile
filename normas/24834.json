{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n de gracia a don Ricardo San Mart&#xED;n, ex-ayudante del Senado</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 8277599}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia y a contar desde el d&#xED;a 1.o de Enero de 1930, al ex-ayudante del Senado, don Ricardo San Mart&#xED;n, una pensi&#xF3;n de jubilaci&#xF3;n de ciento cincuenta pesos mensuales&quot;. </div></div>", "i": 8277600}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecinueve de Noviembre de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Enrique Berm&#xFA;dez. </div></div>", "i": 8277601}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4691", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4691"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE PENSION DE GRACIAS A DON RICARDO SAN MARTIN, EX-AYUDANTE DEL SENADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RICARDO SAN MARTIN", "PENSION POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-11-19", "doble_articulado": false, "id_norma": "24834", "numero_fuente": "15529", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-11-22", "vigencias": [{"desde": "1929-11-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia"