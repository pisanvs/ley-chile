{"html": [{"t": "<div><div class=\"p\">DECLARA &#xC1;REA DE PLAGA Y DE RIESGO DE PLAGA QUE INDICA EN CUERPOS DE AGUA QUE SE&#xD1;ALA</div></div>", "i": 10368091}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.854, de 2 de septiembre de 2022, de esta Subsecretar&#xED;a, declara, por el plazo de dos a&#xF1;os, &#xE1;rea de plaga y riesgo de plaga de la especie Didymosphenia geminata, en los sectores de cuerpos de agua terrestres que se indican en la resoluci&#xF3;n extractada y publicada &#xED;ntegramente en la p&#xE1;gina web www.subpesca.cl.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10368092}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de septiembre de 2022.- Paulo Sep&#xFA;lveda Sep&#xFA;lveda, Subsecretario de Pesca y Acuicultura (S).</div><br></div>", "i": 10368093}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1854 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1854 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DECLARA ÁREA DE PLAGA Y DE RIESGO DE PLAGA QUE INDICA EN CUERPOS DE AGUA QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2191360", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-09-02", "doble_articulado": false, "id_norma": "1181885", "numero_fuente": "43360", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-09-24", "vigencias": [{"desde": "2022-09-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2022-09-24", "fin_vigen