{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,421.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 9050981}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de cien mil pesos ($ 100,000), en la reconstruccion del puete sobre el rio Bueno y habilitacion provisional de las comunicaciones entre La Union y Puerto Montt&quot;.</div><br></div>", "i": 9050982}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, doce de setiembre de mil novecientos dieciocho.- Juan Luis Sanfuentes.- Francisco Landa Z. </div></div>", "i": 9050983}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3421", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3421"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1918-09-12", "doble_articulado": false, "id_norma": "141358", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1918-09-29", "vigencias": [{"desde": "1918-09-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1918-09-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1918-09-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vi