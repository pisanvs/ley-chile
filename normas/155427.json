{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6231991}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 620, de 12 de Septiembre de 1986, de la Secretar&#xED;a Regional Ministerial de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se autoriza a don H&#xE9;ctor Hern&#xE1;n Ulloa Sanhueza para efectuar todo tipo de servicios de transporte de pasajeros, por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6231992}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco Navarro Ruiz, Secretario Regional Ministerial de Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o. </div></div>", "i": 6231993}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "620 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-620 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-09-12", "doble_articulado": false, "id_norma": "155427", "numero_fuente": "32.577", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-09-22", "vigencias": [{"desde": "1986-09-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-09-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-09-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente