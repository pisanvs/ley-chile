{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297451}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.463, de 6 de agosto de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a INVERSIONES</div><div class=\"p\">MARINAS S.A., para iniciar actividades pesqueras</div><div class=\"p\">extractivas, con la nave &quot;Daslav&quot;, en el litoral de</div><div class=\"p\">las III y IV Regiones, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; extraer con cerco, los siguientes recursos hidrobiol&#xF3;gicos: Anchoveta, Caballa, Cojinoba del norte, Jurel, Machuelo o Tritre, Sardina espa&#xF1;ola y Sardina com&#xFA;n.</div><div class=\"p\">&nbsp; &nbsp; La presente autorizaci&#xF3;n es sin perjuicio de las que corresponda conferir a otras autoridades, de acuerdo a las disposiciones legales y reglamentarias vigentes o que se establezcan.</div><br><br></div>", "i": 8297452}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 6 de agosto de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297453}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1463", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1463"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "INVERSIONES MARINAS S.A.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-08-06", "fecha_derogacion": "2002-02-23", "doble_articulado": false, "id_nor