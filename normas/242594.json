{"html": [{"t": "<div><div class=\"p\">MODIFICA DISE&#xD1;O DEL FORMULARIO 50</div><br><br></div>", "i": 6542381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 94, del 23-09-2005, que resuelve modificar el dise&#xF1;o del Formulario 50, sobre declaraci&#xF3;n mensual y pago simult&#xE1;neo de impuestos a partir del per&#xED;odo tributario de octubre de 2005, sujet&#xE1;ndose a sus instrucciones de llenado que forman parte integrante de la resoluci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de septiembre de 2005.</div><br><br><br></div>", "i": 6542382}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "94 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-94 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA DISEÑO DEL FORMULARIO 50", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FORMULARIO 50", "DISEÑO", "MODIFCA", "DECLARACION MENSUAL PAGO SIMULTANEO IMPUESTOS", "PERIODO 2005 PERIODO TRIBUTARIO DE OCTUBRE DE 2005"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-23", "doble_articulado": false, "id_norma": "242594", "numero_fuente": "38278", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-10-04", "vigencias": [{"desde": "2005-10-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2