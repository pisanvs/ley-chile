{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8333157}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.139, de 5 de agosto de 1998, de esta Subsecretar&#xED;a, d&#xE9;jase parcialmente sin efecto la resoluci&#xF3;n N&#xBA; 963, de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a RAMON ROBERTO CARDENAS BORQUEZ, s&#xF3;lo en lo que respecta a la instalaci&#xF3;n y operaci&#xF3;n del centro de cultivo correspondiente al Sector 1, ubicado en R&#xED;o Maull&#xED;n, sector Chanhu&#xE9;, comuna de Maull&#xED;n, provincia de Llanquihue, X Regi&#xF3;n.</div><div class=\"p\">D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1.719, de 1995, de esta Subsecretar&#xED;a, que autoriz&#xF3; al peticionario, ya individualizado, para realizar actividades de acuicultura en el centro de cultivo se&#xF1;alado precedentemente.</div><br></div>", "i": 8333158}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de agosto de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8333159}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1139", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1139"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "MAULLIN", "RAMON ROBERTO CARDENAS BORQUEZ", "DECIMA REGION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-05", "doble_articulado": false, "id_norma": "122999", "numero_fuente": "36139", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-08-13", "vigencias": [{"d