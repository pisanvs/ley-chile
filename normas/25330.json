{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; INTERCALA LAS PALABRAS QUE SE INDICAN EN EL INCISO FINAL DEL ARTICULO 3.o TRANSITORIO DE LA LEY 6,020 Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5962842}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Interc&#xE1;lase a continuaci&#xF3;n de la</div><div class=\"p\">palabra &quot;Antofagasta&quot; que figura en el inciso final del</div><div class=\"p\">art&#xED;culo 3.o transitorio de la ley 6,020, de 5 de Febrero de 1937, las siguientes: &quot;Magallanes y Ays&#xE9;n&quot;. </div></div>", "i": 5962843}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y, por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, catorce de Septiembre de mil novecientos treinta y ocho.- ARTURO ALESSANDRI.- Juan J. Hidalgo. </div></div>", "i": 5962844}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "6257", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-6257"}], "organismos": ["MINISTERIO DEL TRABAJO"], "titulo_norma": "INTERCALA LAS PALABRAS QUE SE INDICAN EN EL INCISO\nFINAL DEL ARTICULO 3.o TRANSITORIO DE LA LEY 6,020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MAGALLANES", "AYSEN", "EMPLEADOS PARTICULARES", "REMUNERACIONES", "AUMENTA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1938-09-14", "doble_articulado": false, "id_norma": "25330", "numero_fuente": "18174", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1938-09-24", "vigencias": [{"desde": "1938-09-24"