{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Extracto</div><br></div>", "i": 6461104}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.493 de fecha 28 de noviembre del a&#xF1;o 2003, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriz&#xF3; complementariamente a la empresa boliviana &quot;Litoral&quot; S.R.L., para efectuar servicio internacional de transporte terrestre de pasajeros entre la Paz (Bolivia) y Arica (Chile), con siete (7) frecuencias semanales de ida y vuelta, utilizando los pasos fronterizos de Tambo Quemado y Cerrito Prieto. </div></div>", "i": 6461105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Claudio Navea N&#xFA;&#xF1;ez, Jefe Divisi&#xF3;n Administraci&#xF3;n y Finanzas, Subsecretar&#xED;a de Transportes.</div><br></div>", "i": 6461106}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1493 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1493 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-11-28", "doble_articulado": false, "id_norma": "220543", "numero_fuente": "37770", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-01-27", "vigencias": [{"desde": "2004-01-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-01-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-01-27", "fin_vigencia": "", "tipo_version": "3"}], "