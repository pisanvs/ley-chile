{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Sociedad Alemana de Canto &quot;Frohsinn&quot; Lei n&#xFA;m. 1,386.- Santiago, a 22 de Noviembre de 1900.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949038}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese a la Sociedad Alemana de Canto &quot;Frohsinn&quot; el permiso requerido por el art&#xED;culo 556 del C&#xF3;digo Civil para que pueda conservar por treinta a&#xF1;os, la propiedad del sitio i casa n&#xFA;mero 13, antigua numeraci&#xF3;n que posee en la calle de Nataniel de esta ciudad.</div><br></div>", "i": 5949039}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ E.- Francisco J. Herboso.</div><br></div>", "i": 5949040}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1386", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1386"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "SOCIEDAD ALEMANA DE CANTO FROHSINN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD ALEMANA CANTO FROHSINN", "POSESION", "BIEN", "RAIZ", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-11-22", "doble_articulado": false, "id_norma": "22607", "numero_fuente": "6753", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-11-27", "vigencias": [{"desde": "1900-11-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900