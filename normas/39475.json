{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA RESOLUCION N&#xB0; 2.739 EXENTA, DE 1992 </div><br></div>", "i": 8958923}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n exenta Nro. 1.042 de fecha 16 de Agosto de 1995 el Director Regional de la I. Direcci&#xF3;n Regional Iquique modific&#xF3; la Resoluci&#xF3;n Exenta Nro.</div><div class=\"p\">2.739 de 10 de Agosto de 1992, publicada en el Diario Oficial del 26 de Septiembre del mismo a&#xF1;o sobre delegaci&#xF3;n de facultades al Jefe del Departamento Regional Jur&#xED;dico, conforme a lo instruido en el Oficio Circular Nro. 2820 de 1993 del Sr. Director del Servicio, modificando la calificaci&#xF3;n de &quot;grave&quot; por &quot;compleja&quot; respecto de la p&#xE9;rdida de documentos sancionada en el Nro. 16&#xB0; del Art&#xED;culo 97&#xB0; del C&#xF3;digo Tributario.-</div><br></div>", "i": 8958924}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Echavarr&#xED;a Cornejo, Director Regional.- Elsa Fern&#xE1;ndez Gallardo, Secretaria Regional.</div><br></div>", "i": 8958925}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1042 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1042 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "MODIFICA RESOLUCION N° 2.739 EXENTA, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DELEGACION", "FACULTAD", "JEFE", "DEPARTAMENTO JURIDICO", "DIRECCION REGIONAL", "SERVICIO IMPUESTOS INTERNOS", "PRIMERA", "REGION", "IQUIQUE", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-08-16", "doble_articulado": false, "id_norma": "39