{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 297 EXENTO, DE 1998 </div></div>", "i": 6103668}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 297 de 20 de enero de 1998, se ha autorizado al Colegio &quot;San Adri&#xE1;n&quot; de la comuna de Quilicura, Regi&#xF3;n Metropolitana, para que a partir del a&#xF1;o escolar 1998, redistribuya, en el plan de estudio del 7&#xBA; y 8&#xBA; a&#xF1;o b&#xE1;sico las clases de la asignatura de Franc&#xE9;s, a la asignatura de Ingl&#xE9;s, quedando esta &#xFA;ltima con una carga horaria de 4 horas de clases semanales.</div><br></div>", "i": 6103669}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de febrero de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6103670}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "297 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-297 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 297 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIO SAN ADRIAN", "QUILICURA", "REGION METROPOLITANA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-01-20", "doble_articulado": false, "id_norma": "96644", "numero_fuente": "35993", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-02-17", "vigencias": [{"desde": "1998-02-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-02-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-02-17", "fin_