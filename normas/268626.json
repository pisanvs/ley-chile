{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7362314}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.595, de 19 de diciembre de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA BERTA ELENA LIMITADA para realizar actividades extractivas en alta mar con la nave &quot;Genoveva&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">&nbsp; &nbsp;  Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; CB-2813</div><div class=\"p\">&nbsp; &nbsp;  Puerto de matr&#xED;cula&nbsp; &nbsp;  Valpara&#xED;so</div><div class=\"p\">&nbsp; &nbsp;  Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  2427</div><div class=\"p\">&nbsp; &nbsp;  Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; 27,74 m.</div><div class=\"p\">&nbsp; &nbsp;  T.R.G. (Internacional)&nbsp; 154,44</div><div class=\"p\">&nbsp; &nbsp;  Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  7,95 m.</div><div class=\"p\">&nbsp; &nbsp;  Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 3,87 m.</div><br></div>", "i": 7362315}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de diciembre de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7362316}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3595 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3595 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2007-12-19", "fecha_derogacion": "2011-09-12", "doble_