{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0;3/2009 </div></div>", "i": 7078052}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0;3, de 9 de enero de 2009, de la Subsecretar&#xED;a de Transportes, se resolvi&#xF3;:</div><br><div class=\"p\">&nbsp; &nbsp;  1.-) P&#xF3;nese t&#xE9;rmino a la Concesi&#xF3;n de la Unidad de Negocio Alimentadora N&#xBA;5, a cargo de Buses Gran Santiago S.A., en atenci&#xF3;n a que la sanci&#xF3;n de Caducidad aplicada por resoluci&#xF3;n exenta N&#xBA; 2.739, de 23 de diciembre de 2008, se encuentra administrativamente ejecutoriada.</div><div class=\"p\">&nbsp; &nbsp;  2.-) Notif&#xED;quese la presente resoluci&#xF3;n al Administrador Financiero de Transantiago S.A.</div><div class=\"p\">&nbsp; &nbsp;  3.-) Notif&#xED;quese al concesionario de la Unidad de Negocio Alimentadora N&#xBA; 5, Buses Gran Santiago S.A.-</div><br><br></div>", "i": 7078053}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Erazo Torricelli, Subsecretario de Transportes.</div><br><br></div>", "i": 7078054}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N°3/2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-01-09", "doble_articulado": false, "id_norma": "287215", "numero_fuente": "39287", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-02-13", "vigencias": [{"desde": "2009-02-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ú