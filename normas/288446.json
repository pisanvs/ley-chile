{"html": [{"t": "<div><div class=\"p\">&amp;#160;</div></div>", "i": 8461085}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 908, de 13 de marzo de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a ANTARTIC SEAFOOD S.A. para iniciar actividades pesqueras de transformaci&#xF3;n, para operar una planta ubicada en Ger&#xF3;nimo M&#xE9;ndez N&#xBA; 1610, Lote N&#xBA; 16-B, Barrio Industrial de Alto Pe&#xF1;uelas, Coquimbo, IV Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco-enfriado, Fresco-refrigerado, Congelado, Harina y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 381, de 2001, de esta Subsecretar&#xED;a.</div><br></div>", "i": 8461086}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de marzo de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 8461087}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "908 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-908 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-03-13", "doble_articulado": false, "id_norma": "288446", "numero_fuente": "39324", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-03-28", "vigencias": [{"desde": "2009-03-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009