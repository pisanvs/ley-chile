{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 254 EXENTO, DE 2006 </div></div>", "i": 6572526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 254 de fecha 7 de marzo de 2006, se declara que la carrera profesional de Orientaci&#xF3;n Familiar impartida por el Instituto Profesional de Enac, ha cumplido con los requisitos necesarios para la liberaci&#xF3;n de &#xE9;sta, seg&#xFA;n lo certifica la Pontificia Universidad Cat&#xF3;lica de Chile, quien actu&#xF3; como entidad examinadora de dicha carrera.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, de conformidad con el art&#xED;culo anterior, el Instituto Profesional de Enac queda en condiciones de otorgar independientemente el t&#xED;tulo profesional de Orientador Familiar, a contar del a&#xF1;o 2006.</div><br></div>", "i": 6572527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de marzo de 2006.- Pedro Montt Leiva, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6572528}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "254 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-254 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 254 EXENTO, DE 2006", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2006-03-07", "fecha_derogacion": "2018-11-07", "doble_articulado": false, "id_norma": "250404", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2006-06-13", "vigencias": [{"desde": "2018-11-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2006-06-13", "hasta": "2018-11-06", "tipo_version": "0", "tipo_version_s": "Texto