{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7284215}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.146, de 12 de junio de 2001, de esta Subsecretar&#xED;a, autor&#xED;zase a MARIO GAJARDO VENEGAS, para ampliar las actividades pesqueras extractivas con la nave &quot;Noel I&quot;, matr&#xED;cula 2800, en el &#xE1;rea mar&#xED;tima que a continuaci&#xF3;n se indica, donde podr&#xE1; capturar con trampas, por fuera del &#xE1;rea de reserva artesanal, los siguientes recursos hidrobiol&#xF3;gicos: a) En el &#xE1;rea mar&#xED;tima de la I Regi&#xF3;n: Camar&#xF3;n nailon. b) En el &#xE1;rea mar&#xED;tima de las Regiones I a IV: Gamba y Langosta enana.</div><div class=\"p\">c) En el &#xE1;rea mar&#xED;tima de la I y II Regiones: Langostino amarillo.</div><br></div>", "i": 7284216}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de junio de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7284217}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1146", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1146"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-06-12", "fecha_derogacion": "2007-04-28", "doble_articulado": false, "id_norma": "187401", "numero_fuente": "37006", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2001-07-09", "vigencias": [{"desde": "2007-04-28", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-10-17", "hasta