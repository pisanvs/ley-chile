{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ACLARA EL ITEM QUE SE&#xD1;ALA DE LA LEY DE PRESUPUESTOS DE 1955</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5970994}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Acl&#xE1;rase que el aporte contemplado en la Ley de Presupuestos de 1955, &#xED;tem 12/01/08, letra h)-1 &quot;Corporaci&#xF3;n de la Vivienda&quot;, se refiere a &quot;Casa Consistorial y Sala de Actos de Chanco&quot;.</div><br></div>", "i": 5970995}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a diecis&#xE9;is de Julio de mil novecientos cincuenta y seis.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Oscar Herrera Palacios.</div><br></div>", "i": 5970996}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "12076", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-12076"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ACLARA EL ITEM QUE SEÑALA DE LA LEY DE PRESUPUESTOS\nDE 1955", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1955", "ACLARACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1956-07-16", "doble_articulado": false, "id_norma": "27028", "numero_fuente": "23507", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1956-07-25", "vigencias": [{"desde": "1956-07-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia":