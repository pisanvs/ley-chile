{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ORDENA EXPROPIACIONES PARCIALES DE LOTES QUE INDICA </div></div>", "i": 5853873}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Alcaldicio N&#xB0; 1.443 de fecha 23.08.96 Alcalde Municipalidad de La Granja ordena expropiaci&#xF3;n parcial de lote calle Santa Ana N&#xB0; 0181, propietario Heinrich Awner Scheiner, superficie aproximada 398.54 m2. Deslindes: Norte, 30,40 mts. con calle Santa Ana; Sur, 30,40 mts. resto propiedad expropiado; Poniente, 13,02 mts. Parcela Siete, hoy propiedad Fisco, Ministerio Obras P&#xFA;blicas; Oriente, 13,20 mts. propiedad de Mar&#xED;a Arenas Moraga. Indemnizaci&#xF3;n provisional $11.200.000.- pagadera contado.</div><br></div>", "i": 5853874}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Claudio Arriagada Macaya, Alcalde de La Granja. </div></div>", "i": 5853875}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1443", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1443"}], "organismos": ["MUNICIPALIDAD DE LA GRANJA"], "titulo_norma": "ORDENA EXPROPIACIONES PARCIALES DE LOTES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "LA GRANJA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-08-23", "doble_articulado": false, "id_norma": "2740", "numero_fuente": "35557-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-09-02", "vigencias": [{"desde": "1996-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-09-02", "fin_vigencia": "", "tipo_version": "