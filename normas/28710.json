{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DENOMINA &quot;EL OVEJERO&quot; A LA ACTUAL CALLE &quot;MATADERO&quot; DE LA CIUDAD DE PUNTA ARENAS</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8283504}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Denom&#xED;nase &quot;El Ovejero&quot; a la actual calle &quot;Matadero&quot; de la ciudad de Punta Arenas. </div></div>", "i": 8283505}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, tres de Septiembre de mil novecientos sesenta y ocho.- EDUARDO FREI MONTALVA.- Edmundo P&#xE9;rez Z.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a U. para su conocimiento.- Dios gue. a U.- Enrique Krauss Rusque, Subsecretario del Interior.</div><br></div>", "i": 8283506}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "16932", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-16932"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DENOMINA \"EL OVEJERO\" A LA ACTUAL CALLE \"MATADERO\" DE LA CIUDAD DE PUNTA ARENAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "EL OVEJERO", "MATADERO", "CALLE", "PUNTA ARENAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1968-09-03", "doble_articulado": false, "id_norma": "28710", "numero_fuente": "27143", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1968-09-12", "vigencias": [{"desde": "1968-09-12", "hast