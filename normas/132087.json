{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xBA; 1, DE 1995</div><br><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 1.- Santiago, 22 de enero de 1999.- Visto: Lo dispuesto en los art&#xED;culos 56&#xBA; y 57&#xBA; de la ley N&#xBA; 18.290, de Tr&#xE1;nsito,</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br><br></div>", "i": 6155308}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sustit&#xFA;yese, en la letra b) del art&#xED;culo 1&#xBA; de la resoluci&#xF3;n N&#xBA; 1 de 1995, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, el alto m&#xE1;ximo, que se especifica en el primer p&#xE1;rrafo, de 4,12 m. por &apos;&apos;4,20 m&apos;&apos;.</div><br></div>", "i": 6155309}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- Claudio Hohmann Barrientos, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo para su conocimiento.- Saluda a Ud., Luis Silva Moya, Jefe Administrativo Subrogante. </div></div>", "i": 6155310}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "MODIFICA RESOLUCION Nº 1, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-01-22", "doble_articulado": false, "id_norma": "132087", "numero_fuente": "36296", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-02-22", "vigencias": [{"desde": "1999-02-22", "