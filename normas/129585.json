{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8338692}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 830, de 08 de Agosto de 1988, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 2&#xB0; de la resoluci&#xF3;n No. 548, de 1988, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Agrotrade Pesca S.A. domiciliada en Santiago, a operar una planta industrial en la XII Regi&#xF3;n, ubicada en sector R&#xED;o Seco, Km. 13 Norte, Punta Arenas, en orden a reemplazar la expresi&#xF3;n &quot;donde procesar&#xE1; en las l&#xED;neas de elaboraci&#xF3;n de fresco y congelado&quot; por &quot;donde procesar&#xE1; en las l&#xED;neas de elaboraci&#xF3;n de fresco, congelado y conservas&quot;. </div></div>", "i": 8338693}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 08 de Agosto de 1988.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8338694}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "830", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-830"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-08", "doble_articulado": false, "id_norma": "129585", "numero_fuente": "33148", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-08-17", "vigencias": [{"desde": "1988-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-08-17", "f