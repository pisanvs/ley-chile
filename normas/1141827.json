{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 145 EXENTA, DE 2019</div></div>", "i": 10097085}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 13, del 24 de enero de 2020, que modifica la resoluci&#xF3;n exenta N&#xBA; 145, de 2019.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Se modifica la <a href=\"https://www.leychile.cl/Navegar?idNorma=1140746&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 145, de 2019</a>, que fija valores de terrenos y construcciones para el reaval&#xFA;o de los bienes ra&#xED;ces no agr&#xED;colas correspondientes a sitios no edificados, propiedades abandonadas o pozos lastreros ubicados en las &#xE1;reas urbanas, reemplaz&#xE1;ndose el valor unitario de terreno, respecto de las &#xC1;reas Homog&#xE9;neas correspondientes a las comunas que se indican.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento est&#xE1; publicado en &quot;www.sii.cl&quot;.</div><br></div>", "i": 10097086}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "13 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-13 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 145 EXENTA, DE 2019", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1719812", "EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-01-24", "doble_articulado": false, "id_norma": "1141827", "numero_fuente": "42567", "tipo_ver