{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292753}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 488 de 28 de Abril de 1995 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por VICTOR JOSE MIGUEL SHARP VLADILO, para un sector ubicado en Bah&#xED;a Coru&#xF1;a, Puerto Natales, provincia de Ultima Esperanza, XII Regi&#xF3;n, por no dar cumplimiento el respectivo proyecto t&#xE9;cnico a los art&#xED;culos 87&#xB0; y 88&#xB0; de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8292754}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 28 de Abril de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292755}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "488", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-488"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VICTOR SHARP VLADILO", "CONCESION ACUICULTURA", "DENEGACION", "DECIMOSEGUNDA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-04-28", "doble_articulado": false, "id_norma": "34947", "numero_fuente": "35160", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-05-06", "vigencias": [{"desde": "1995-05-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-05-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-05-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pend