{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6492683}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 524 de fecha 30 de junio de 2004, se expropi&#xF3; el lote de terreno N&#xBA; 27, superficie 9.054 M2, Rol N&#xBA; 327-16, comuna de Laja, VIII Regi&#xF3;n para la obra &quot;Camino Ruta Q-34, Candelaria-La Laja Sector Millant&#xFA;-La Laja, Km. 20,00000 al 35,88380&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Nivaldo Rodolfo Ch&#xE1;vez Valdebenito y otros, ascendente a la cantidad de $7.729.046.- para el lote N&#xBA; 27. </div></div>", "i": 6492684}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6492685}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "524", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-524"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-06-30", "doble_articulado": false, "id_norma": "229179", "numero_fuente": "37937", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-08-16", "vigencias": [{"desde": "2004-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JRC", "fecha_ingreso": "2004-08-17", "fecha_version": "2004-08-16", "fecha_actualizacion_tex