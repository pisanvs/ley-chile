{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6600937}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 289, de 31 de enero de 2007 de esta Subsecretar&#xED;a, modif&#xED;case la resoluci&#xF3;n N&#xBA; 2.604 de 2006, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n en los t&#xE9;rminos en ella indicados, en el siguiente sentido:</div><br><div class=\"p\">a)&nbsp;  Modificar el numeral 4.-, en el sentido de incorporar a las embarcaciones artesanales &quot;Karina&quot; y &quot;Blanca Estela&quot;.</div><div class=\"p\">b)&nbsp;  Modificar el numeral 7.- letra e), en el sentido de incorporar a la caleta Carelmapu como lugar de desembarque autorizado.</div><br></div>", "i": 6600938}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de enero de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6600939}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "289 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-289 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-01-31", "doble_articulado": false, "id_norma": "258208", "numero_fuente": "38684", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-02-08", "vigencias": [{"desde": "2007-02-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-02-08", "fin_vigencia": ""}, "vigencias_version_norma":