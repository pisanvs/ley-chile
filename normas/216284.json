{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6445142}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.426, de 9 de octubre de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a LUIS HERNAN MU&#xD1;OZ MELGAREJO para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en San Mart&#xED;n 344, Loncoche, IX Regi&#xF3;n, donde podr&#xE1; procesar, en las l&#xED;neas de proceso que se indican, los siguientes recursos hidrobiol&#xF3;gicos:</div><div class=\"p\">Fresco-refrigerado: Trucha arcoiris, Salm&#xF3;n del atl&#xE1;ntico y Salm&#xF3;n plateado; Congelado: Trucha arcoiris, Salm&#xF3;n del Atl&#xE1;ntico, Salm&#xF3;n plateado, Merluza del sur o austral, Congrio dorado y Corvina; Ahumado: Trucha arcoiris, Salm&#xF3;n del Atl&#xE1;ntico y Salm&#xF3;n plateado. </div></div>", "i": 6445143}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de octubre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6445144}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2426 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2426 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-09", "doble_articulado": false, "id_norma": "216284", "numero_fuente": "37693", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-10-24", "vigencias": [{"desde": "2003-10-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"