{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 922 EXENTO, DE 2003 </div></div>", "i": 6457819}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 922 de fecha 17 de noviembre de 2003, de Educaci&#xF3;n, se declara aprobada a la Universidad de Rancagua, la siguiente carrera y grado acad&#xE9;mico que se indica:</div><br><div class=\"p\">Carrera:&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Pedagog&#xED;a B&#xE1;sica</div><div class=\"p\">Grado Acad&#xE9;mico:&nbsp; &nbsp; &nbsp;  Licenciado en Educaci&#xF3;n</div><div class=\"p\">T&#xED;tulo Profesional:&nbsp; &nbsp; Profesor de Educaci&#xF3;n B&#xE1;sica</div><br><div class=\"p\">&nbsp; &nbsp;  Dicha carrera podr&#xE1; ser impartida en jornada diurna en su Sede de la ciudad de Rancagua, a contar del primer semestre del a&#xF1;o 2004.</div><br></div>", "i": 6457820}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de diciembre de 2003.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6457821}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "922 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-922 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 922 EXENTO, DE 2003", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-11-17", "fecha_derogacion": "2010-07-09", "doble_articulado": false, "id_norma": "219849", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-01-07", "vigencias": [{"desde": "2010-07-09", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-01-07", "hasta": "2010-