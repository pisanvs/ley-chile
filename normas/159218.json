{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6244425}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;3.576, de 30 de noviembre de 1999, se expropiaron los lotes de terreno N&#xBA;s. 4, 5, 8, 11, 12-A, 15 y 15-A, superficies 133, 58, 34, 95, 392, 149 y 125 m&#xB2; respectivamente, roles de aval&#xFA;o 99-57, 99-62 y 341-179, comuna de La Ligua, V Regi&#xF3;n, para la obra Camino Ruta E-39 Sector Qu&#xED;nquimo-El Rayado y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Carlos Calder&#xF3;n Moraga y otros, Isaira P&#xE9;rez Salazar y Mar&#xED;a Cataldo Oyanedel, ascendente a las cantidades de $2.283.645, $1.655.262 y $2.027.538.</div><br></div>", "i": 6244426}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6244427}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3576", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3576"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-11-30", "doble_articulado": false, "id_norma": "159218", "numero_fuente": "36602", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-01", "vigencias": [{"desde": "2000-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAS", "fecha_ingreso": "2000-03-01", "fecha_version": "2