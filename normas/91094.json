{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  MODIFICA RESOLUCION QUE INDICA</div><br><br><br><br><br><br></div>", "i": 8319869}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 1.606, de 06 de Noviembre de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 3&#xB0;, de la Resoluci&#xF3;n No. 988, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Jos&#xE9; Enrique Esquivel Campa&#xF1;a, RUT No.</div><div class=\"p\">6.337.222-6; domiciliado en San Antonio, calle Jos&#xE9; Plaza No. 69, para iniciar actividades pesqueras, en el sentido de autorizar al solicitante para extraer el recurso Albacora o pez espada, (Xiphias gladius), en el litoral de las Regiones I a X, no obstante lo se&#xF1;alado en dicha Resoluci&#xF3;n, respecto de las zonas a operar.</div><br></div>", "i": 8319870}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 06 de Noviembre de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8319871}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1606", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1606"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1989-11-06", "fecha_derogacion": "1999-06-25", "doble_articulado": false, "id_norma": "91094", "numero_fuente": "33539", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1989-12-05", "vigencias": [{"desde": "1999-06-25", "hasta": "", "tipo_version": "2", "tipo_ver