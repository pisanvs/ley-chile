{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 202, de 1988 </div></div>", "i": 6096987}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 202 de 26 de diciembre de 1988 se ha aprobado un plan de estudio especial al Liceo Experimental A N&#xB0; 39 &quot;Lucila Godoy Alcayaga&quot;, de Concepci&#xF3;n, VIII Regi&#xF3;n del B&#xED;o-B&#xED;o, para la Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica, el que se aplicar&#xE1; a contar del a&#xF1;o escolar 1989 en los cursos de 1&#xB0;, 2&#xB0; y 3er. a&#xF1;o y en el a&#xF1;o escolar 1990 en el 4&#xB0; a&#xF1;o.</div><br></div>", "i": 6096988}, {"t": "<div><div class=\"p\">Santiago, 20 de Enero de 1989.- Paulina Dittborn Cordua, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6096989}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "202 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-202 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 202, de 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-26", "doble_articulado": false, "id_norma": "94404", "numero_fuente": "33295", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-02-10", "vigencias": [{"desde": "1989-02-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-02-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-02-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CQA", "fecha_ingreso": "1998-