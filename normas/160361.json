{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 97, DE 1985 </div></div>", "i": 6248582}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 97, de 16 de Enero de 1985, del Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante, se modific&#xF3; la resoluci&#xF3;n exenta de Educaci&#xF3;n No. 298 de 1983, del Centro de Formaci&#xF3;n T&#xE9;cnica INACAP, en el sentido de reemplazar la red secuencial de asignaturas de los planes y programas de estudio de la carrera Administraci&#xF3;n Hotelera con las modificaciones indicadas, a contar del a&#xF1;o 1984.-</div><br></div>", "i": 6248583}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6248584}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "97 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-97 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 97, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-16", "doble_articulado": false, "id_norma": "160361", "numero_fuente": "32136", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-04-01", "vigencias": [{"desde": "1985-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "