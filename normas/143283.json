{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8349940}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.652, de 31 de agosto de 1999, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA COLOSO S.A. para ampliar las actividades pesqueras extractivas con la nave &apos;&apos;Aventurero&apos;&apos;, en orden a que la interesada podr&#xE1; realizar actividades pesqueras con la nave se&#xF1;alada precedentemente, en el litoral de la I y II Regiones, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar con red de cerco el recurso hidrobiol&#xF3;gico Jurel fino y Sardina redonda. </div></div>", "i": 8349941}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de agosto de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8349942}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1652", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1652"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-08-31", "fecha_derogacion": "2000-03-11", "doble_articulado": false, "id_norma": "143283", "numero_fuente": "36464", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-09-14", "vigencias": [{"desde": "2000-03-11", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-09-14", "hasta": "2000-03-10", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2000-03-11", "fin_vigencia": ""}, "vigencias_v