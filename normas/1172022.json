{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10306310}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto (Exento) MOP. N&#xB0;5, de 06 de enero de 2022, se modific&#xF3; y desisti&#xF3; parcialmente de la expropiaci&#xF3;n del lote N&#xB0;139, realizada por <a href=\"https://www.leychile.cl/Navegar?idNorma=1039130&amp;idParte=&amp;idVersion=\">Decreto (Exento) MOP. N&#xB0;554, de 29 de marzo de 2012</a>, reduci&#xE9;ndose la superficie expropiada a 727 m2.; modificando el numeral primero y segundo de dicho Decreto, se&#xF1;alando como kilometraje de inicio y t&#xE9;rmino, Km. 17,89841 a Km. 18,02929; nuevo propietario MAC-LEAN HERRERA REINALDO RICARD y donde dice: Provincia de Valpara&#xED;so, debe decir: Provincia Marga Marga, de la comuna de Quilpu&#xE9;, expropiado para la ejecuci&#xF3;n de obra &quot;Mejoramiento Ruta F-50, Sector Lo Orozco - Quilpu&#xE9;, Tramo 3: Km. 17,57835 a Km. 29,49799&quot;. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en los art&#xED;culos 7&#xB0; y 32&#xB0; del Decreto Ley N&#xB0;2186, de 1978.</div></div>", "i": 10306311}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10306312}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "5 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-5 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2076910", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-01-06", "doble_arti