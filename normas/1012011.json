{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 673 EXENTO, DE 2010</div><br></div>", "i": 8902282}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento que se indica del Ministerio de Educaci&#xF3;n, se aprueban las adecuaciones al plan y programas estudios de la carrera de Int&#xE9;rprete e Instructor en Danza Espect&#xE1;culo del Centro de Formaci&#xF3;n T&#xE9;cnica Estudio Profesor Valero, que se encuentran anexas y forman parte del presente decreto. Modif&#xED;case, en consecuencia, el decreto exento N&#xBA; 2.741 del 9 de septiembre de 2008, en el sentido de incorporar dichas adecuaciones.</div><div class=\"p\">&nbsp; &nbsp;  Las adecuaciones que se aprueban mediante este decreto, podr&#xE1;n aplicarse a contar del a&#xF1;o 2010.</div><br></div>", "i": 8902283}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de marzo de 2010.- Cristi&#xE1;n Mart&#xED;nez Ahumada, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8902284}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "673 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-673 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 673 EXENTO, DE 2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2010-03-19", "fecha_derogacion": "2021-06-30", "doble_articulado": false, "id_norma": "1012011", "numero_fuente": "39620", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2010-03-25", "vigencias": [{"desde": "2021-06-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2010-03-25", "hasta": "2021-06-29",