{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 7169579}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Apru&#xE9;base el traspaso de la cantidad de treinta mil pesos ($ 30,000) del &#xED;tem 10|09|04|Sub. Dpto. Armas Submarinas|g, al &#xED;tem 10|10|04 Esc. de Torp. y Elect v&quot;.</div><br></div>", "i": 7169580}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, cuatro de Diciembre de mil novecientos veintinueve.- Carlos Ib&#xE1;&#xF1;ez C.- Carlos O. Frodden. </div></div>", "i": 7169581}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4709", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4709"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O", "1929", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-12-04", "doble_articulado": false, "id_norma": "24848", "numero_fuente": "15540", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-12-05", "vigencias": [{"desde": "1929-12-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-12-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1929-12-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_