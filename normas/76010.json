{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6046385}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xB0; 703 de 30 de julio de 1997, se expropiaron los lotes de terreno N&#xB0;s. 18, 20, 21, 25, 41, 42, y 43, superficies 82 m2, 48 m2, 112 m2, 31 m2, 2.000 m2, 300 m2 y 512 m2, roles de aval&#xFA;o 224-37, 226-1, 224-35, 224-2, 204-30 y 204-29, comuna de Santa Juana, para la obra Camino de la Madera sector Bifurcaci&#xF3;n Diuqu&#xED;n-Santa Juana y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Patricio Y&#xE1;&#xF1;ez Gonz&#xE1;lez, Mateo Y&#xE1;&#xF1;ez Gonz&#xE1;lez, Francisco Y&#xE1;&#xF1;ez Gonz&#xE1;lez, Fabiola Soto Barra, y Luis Neira Inostroza, ascendente a las cantidades de $64.514.- para el lote 18, $37.764.- para el lote 20, $88.116.- para el lote 21, $31.627.- para el lote 25 y $3.260.443.- para los lotes 41,42 y 43.-</div><br></div>", "i": 6046386}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas </div></div>", "i": 6046387}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "703", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-703"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SANTA JUANA", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-30", "doble_articulado": false, "id_norma": "76010", "numero_fuente": "35856", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-09-01", "vigencias": [{"desde": "1997-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"