{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N (M) N&#xB0; 574, DE 2009</div></div>", "i": 8960361}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n 705, de 10 de marzo de 2010, Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina, se resolvi&#xF3;:</div><br><div class=\"p\">&nbsp; &nbsp;  1.- Rectif&#xED;case el numeral 2 de la parte Resolutiva, de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1003951&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 574, de fecha 3 de marzo de 2009, del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina</a>, de la siguiente forma:</div><br><div class=\"p\">&nbsp; &nbsp;  Donde dice: con el objeto de amparar la instalaci&#xF3;n y operaci&#xF3;n de un cultivo de Cholga, Choro y Osti&#xF3;n del Norte, el que se debe desarrollar dentro del &#xE1;rea asignada.</div><br><div class=\"p\">&nbsp; &nbsp;  Debe decir: con el objeto de amparar la instalaci&#xF3;n y operaci&#xF3;n de un cultivo de Cholga, Chorito, Choro y Osti&#xF3;n del Norte, el que se debe desarrollar dentro del &#xE1;rea asignada.</div></div>", "i": 8960362}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de agosto de 2010.- Felipe Garc&#xED;a-Huidobro Correa, Subjefe (M).</div></div>", "i": 8960363}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "705", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-705"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "RECTIFICA RESOLUCIÓN (M) N° 574, DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-03-10", "doble_articulado": false, "i