{"html": [{"t": "<div><div class=\"p\">&#xFEFF;&nbsp; &nbsp;  TEATRO.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 14 de 1832. </div><br><div class=\"p\">&nbsp; &nbsp;  EL PRESIDENTE DE LA REP&#xDA;BLICA DE CHILE.</div><br><div class=\"p\">&nbsp; &nbsp;  Ha acordado y decreta: </div></div>", "i": 10262748}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Habr&#xE1; una junta compuesta de don Juan Ega&#xF1;a, don Agustin Vial Santelices y don Andres Bello, encargada de revisar las piezas dram&#xE1;ticas que hallan de exhibirse al p&#xFA;blico en esta capital; debiendo prohibir la representacion de aquellas que ofendan la reliji&#xF3;n y las buenas costumbres, o que tiendan a turbar el &#xF3;rden p&#xFA;blico, a m&#xE9;nos que est&#xE9;n previamente expurgadas. Comun&#xED;quese a quienes corresponda e impr&#xED;mase.</div></div>", "i": 10262749}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  PRIETO.</div><br><div class=\"p\">&nbsp; &nbsp;  Tocornal.</div></div>", "i": 10262750}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "TEATRO", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-07-14", "doble_articulado": false, "id_norma": "1161086", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-07-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-07-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-07-14", "fin_vigencia": "", "tipo_v