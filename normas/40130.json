{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PARTIDO &quot;UNION DEMOCRATA INDEPENDIENTE </div></div>", "i": 6025946}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Dittborn Cordua y Joaqu&#xED;n Lav&#xED;n Infante, en representaci&#xF3;n del Partido Uni&#xF3;n Dem&#xF3;crata Independiente, han solicitado la constituci&#xF3;n legal del Partido en la IX Regi&#xF3;n de la Araucan&#xED;a, acompa&#xF1;ando 2.216 fichas de afiliaciones.</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la Ley N&#xB0; 18.603. Por resoluci&#xF3;n Exenta N&#xB0; O-2268, de fecha 05 de Diciembre de 1991.</div><br></div>", "i": 6025947}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 05 de Diciembre de 1991.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6025948}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2268", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-2268"}, {"tipo": "3", "numero": "0-2268 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-0-2268 EXENTA"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO UNION DEMOCRATA INDEPENDIENTE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO UNION DEMOCRATA", "INDEPENDIENTE", "IX REGION", "CONSTITUCION LEGAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-12-05", "doble_articulado": false, "id_norma": "40130", "numero_fuente": "34140", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-12-12", "vigencias": [{"desde": "1991-12-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig