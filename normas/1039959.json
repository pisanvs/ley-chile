{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETO N&#xB0; 1.251 EXENTO, DE 2011</div></div>", "i": 9256005}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por <a href=\"https://www.leychile.cl/Navegar?idNorma=1035605&amp;idParte=0&amp;idVersion=\">decreto exento N&#xB0; 441, de 7 de mayo de 2012</a>, de este Ministerio, modif&#xED;case el art&#xED;culo 3&#xB0; del decreto exento N&#xB0; 1.251, de 2011, del Ministerio de Econom&#xED;a, Fomento y Turismo, que estableci&#xF3; la cuota global anual de captura de la unidad de pesquer&#xED;a de Anchoveta de la XV a II Regiones, en sentido de se&#xF1;alar que la fracci&#xF3;n artesanal de la se&#xF1;alada especie autorizada para XV y I Regiones, se dividir&#xE1; de la siguiente manera:</div><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/26021.jpg\"></div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y del Servicio Nacional de Pesca.</div><br><br></div>", "i": 9256006, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de mayo de 2012.- Edith Saa Collantes, Subsecretaria de Pesca (S).</div></div>", "i": 9256007}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "441 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-441 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA DECRETO N° 1.251 EXENTO, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-07", "doble_ar