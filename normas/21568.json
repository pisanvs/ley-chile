{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 615 EXENTO, DE 1994 </div></div>", "i": 5945518}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 615 de 15 de diciembre de 1994, se ha autorizado a la Escuela &quot;Uni&#xF3;n Nacional Arabe&quot; (Ex-Escuela D N&#xB0; 199) de Pe&#xF1;alol&#xE9;n, para suprimir en 7&#xB0; y 8&#xB0; a&#xF1;o de ense&#xF1;anza b&#xE1;sica, la asignatura de Idioma Extranjero 2, Franc&#xE9;s, a contar del a&#xF1;o escolar 1995.</div><br></div>", "i": 5945519}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 29 de Diciembre de 1994.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5945520}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "615", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-615"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 615 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ESCUELA UNION NACIONAL ARABE", "PROGRAMAS ESTUDIO", "PLANES ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-12-15", "doble_articulado": false, "id_norma": "21568", "numero_fuente": "35061", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-01-07", "vigencias": [{"desde": "1995-01-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-01-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-01-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1995-01-07", "fecha_actualizacion_te