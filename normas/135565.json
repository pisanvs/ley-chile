{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8344208}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 546, de 9 de abril de 1999, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA COLOSO S.A., para ampliar las actividades pesqueras extractivas con la nave &apos;&apos;Costa Grande 5&apos;&apos;, en el litoral de la I y II Regiones, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar con red de cerco los recursos hidrobiol&#xF3;gicos Anchoa blanca y Vinciguerria.</div><br></div>", "i": 8344209}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de abril de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8344210}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "546", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-546"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-04-09", "fecha_derogacion": "1999-10-30", "doble_articulado": false, "id_norma": "135565", "numero_fuente": "36349", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-04-27", "vigencias": [{"desde": "1999-10-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-04-27", "hasta": "1999-10-29", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1999-10-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-04-27", "fin_vigencia": "1999-10-29", "tipo_version": "0"}, {"inicio_