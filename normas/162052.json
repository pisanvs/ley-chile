{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7265924}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;577, de 16 de marzo de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA;663, de 1995, de esta Subsecretar&#xED;a, en cuanto autoriz&#xF3; a ARTURO EDUARDO MOLINA FOCACCI, para realizar actividades pesqueras extractivas con la nave &apos;&apos;Ike II&apos;&apos; respecto de los recursos Anchoveta, Sardina espa&#xF1;ola, Sardina com&#xFA;n, Jurel, Agujilla, Ayanque, Bacaladillo o mote, Bonito, Caballa, Cabinza, Cabrilla, Cojinoba del norte, Corvina, Dorado, Machuelo, Palometa, Roncacho y Sierra, en el litoral de la III y IV Regiones, de conformidad con lo establecido en la letra b) del art&#xED;culo 143 del D.S. N&#xBA;430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 7265925}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de marzo de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7265926}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "577", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-577"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ARTURO EDUARDO MOLINA FOCACCI", "ACTIVIDADES PESQUERAS", "NAVE IKE II", "RECURSOS HIDROBIOLOGICOS", "CADUCA PARCIAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-03-16", "doble_articulado": false, "id_norma": "162052", "numero_fuente": "36620", "tipo_version": "3", "tipo_version_s": "Única", "fecha_p