{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9270787}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;1015, de 15 de junio de 2012, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA;, del <a href=\"https://www.leychile.cl/Navegar?idNorma=1030383&amp;idParte=0&amp;idVersion=\">Decreto Exento MOP. N&#xBA;2100, de 31 de agosto de 2011</a>, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote de terreno N&#xBA;61, expropiado con motivo de la obra &quot;Mejoramiento Ruta 5 W15 &#x2013; 175, Sector Ruta 5 &#x2013; Pumanzano, Camino Ruta 5 &#x2013; Pumanzano&quot;. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n fijado mediante tasaci&#xF3;n de 07 de marzo de 2008, complementada por acta de fecha 31 de mayo de 2010, en la suma de $336.500.- </div></div>", "i": 9270788}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9270789}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1015 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1015 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-15", "doble_articulado": false, "id_norma": "1041498", "numero_fuente": "40302", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-07-03", "vigencias": [{"desde": "2012-07-03", "hasta": "", "tipo_version": "3", "tipo_vers