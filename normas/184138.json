{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6330795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 291, de fecha 28 de febrero de 2001, se expropi&#xF3; el lote de terreno N&#xBA; 14-A, superficie 2.007 m2, rol de aval&#xFA;o 7021-213, comuna de Talcahuano, para la obra &quot;Mejoramiento Eje Gran Breta&#xF1;a, Sector Cuatro Esquinas - Rotonda Cap, Km. 0,00000 a Km.</div><div class=\"p\">2,74400&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Parque Empresarial del B&#xED;o B&#xED;o S.A., ascendente a la cantidad de $59.789.538.-</div><br></div>", "i": 6330796}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6330797}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "291", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-291"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-28", "doble_articulado": false, "id_norma": "184138", "numero_fuente": "36938", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-04-16", "vigencias": [{"desde": "2001-04-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-04-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-04-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2001-04-17", "fecha_version": "2001-04-16", "fecha_actualizacion_texto": "2001-04-16", "tipo_tratado": ""}, "ale