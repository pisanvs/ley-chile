{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE&nbsp; RESOLUCION N&#xB0;12.871 EXENTA, DE 1999 </div></div>", "i": 6262488}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xB0;12.871 de 29 de diciembre de 1999, se han aprobado a los establecimientos de ense&#xF1;anza media human&#xED;stico-cient&#xED;fica, administrados por la Corporaci&#xF3;n Educacional Iglesia Adventista del S&#xE9;ptimo D&#xED;a, en las regiones II, III, IV, VII, VIII, IX y Metropolitana, el plan y programas especiales de estudio para segundo a&#xF1;o medio, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2000. </div></div>", "i": 6262489}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de febrero de 2000.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General </div></div>", "i": 6262490}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "12871 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-12871 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION N°12.871 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-29", "doble_articulado": false, "id_norma": "164744", "numero_fuente": "36635", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-08", "vigencias": [{"desde": "2000-04-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-04-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-04-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [