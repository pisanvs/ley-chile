{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 8674212}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 2.153, de 04 de Diciembre de 1987, del Servicio Nacional de Capacitaci&#xF3;n y Empleo, se modifica el per&#xED;odo de vigencia de los cursos autorizados, cuyo extracto es el siguiente:</div><div class=\"p\">&nbsp; &nbsp;  1&#xB0;.- Prorr&#xF3;gase hasta el 31 de Diciembre de 1988, la vigencia de los cursos autorizados a la fecha, incluso los no demandados por las empresas durante el ejercicio del a&#xF1;o calendario 1986.</div><div class=\"p\">&nbsp; &nbsp;  2&#xB0;.- Lo anterior deja sin efecto lo dispuesto en el punto No. 3 de la resoluci&#xF3;n exenta No. 619 de 11 de Agosto de 1986, de esta Direcci&#xF3;n Nacional.-</div><br></div>", "i": 8674213}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ricardo Hepp Dubiau, Director Nacional, Servicio Nacional de Capacitaci&#xF3;n y Empleo.</div><br></div>", "i": 8674214}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2153 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2153 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARIA DE PREVISION SOCIAL"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-12-04", "doble_articulado": false, "id_norma": "143102", "numero_fuente": "32944", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-14", "vigencias": [{"desde": "1987-12-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-14", "fin_vigenc