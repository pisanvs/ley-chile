{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 2,756.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6173807}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para espropiar, con arreglo a la lei de 18 de junio de 1857, las propiedades particulares o municipales afectadas por las obras en proyecto para el mejoramiento de los cauces i quebradas de Valparaiso, en un ancho m&#xE1;ximum de sesenta metros.</div><br></div>", "i": 6173808}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiocho de enero de mil novecientos trece.- Ramon Barros Luco.- Manuel Rivas Vicu&#xF1;a. </div></div>", "i": 6173809}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2756", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2756"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1913-01-28", "doble_articulado": false, "id_norma": "137988", "numero_fuente": "10489", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1913-01-29", "vigencias": [{"desde": "1913-01-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1913-01-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1913-01-29", "fin_vigencia": "", "