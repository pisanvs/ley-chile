{"html": [{"t": "<div><div class=\"p\">EXTRACTO DECRETO No. 1.003, DE 1985, QUE APRUEBA MODIFICACION CONVENIO DE TRASPASO DE LA ESCUELA BASICA E-468, COMUNA DE NANCAGUA </div></div>", "i": 6241354}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto No. 1.003, de 1985, se aprob&#xF3; una modificaci&#xF3;n al convenio de traspaso de la Escuela B&#xE1;sica E-468, de Nancagua, aprobado por Decreto No. 5.461, de Educaci&#xF3;n, de 1981, que incide en la cl&#xE1;usula sexta, relativa al bien ra&#xED;z.</div><br></div>", "i": 6241355}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 08 de Mayo de 1986.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6241356}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1003", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1003"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DECRETO No. 1.003, DE 1985, QUE APRUEBA\nMODIFICACION CONVENIO DE TRASPASO DE LA ESCUELA BASICA\nE-468, COMUNA DE NANCAGUA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-05-08", "doble_articulado": false, "id_norma": "158265", "numero_fuente": "32472", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-05-16", "vigencias": [{"desde": "1986-05-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-05-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-05-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso