{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA EMISOR ELECTR&#xD3;NICO</div></div>", "i": 8591936}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 61 del 5 de mayo de 2009, que autoriza a contribuyente como emisor electr&#xF3;nico.</div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de documentos tributarios electr&#xF3;nicos a contribuyente RUT 76.695.950-4 a contar del mes de mayo de 2009. En la Oficina Virtual del SII en Internet se podr&#xE1;n consultar los documentos que el contribuyente est&#xE1; autorizado a emitir en forma electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio Web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en mayo de 2009.</div></div>", "i": 8591937}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "61 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-61 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISOR ELECTRÓNICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-05-05", "doble_articulado": false, "id_norma": "1002000", "numero_fuente": "39357", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-05-09", "vigencias": [{"desde": "2009-05-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-05-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-05-