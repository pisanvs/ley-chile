{"html": [{"t": "<div><div class=\"p\">REASUME MANDO DEL ESTADO</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de abril de 2001.- Hoy se decret&#xF3; lo que sigue:</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 388.- Visto: Lo dispuesto en los art&#xED;culos 29&#xBA; y 32&#xBA;, N&#xBA; 8 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile,</div><br><div class=\"p\">&nbsp; &nbsp;  D e c r e t o:</div><br><br></div>", "i": 8366132}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Con ocasi&#xF3;n de mi regreso al pa&#xED;s, a contar de esta fecha reasumo el mando del Estado.</div><br></div>", "i": 8366133}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- RICARDO LAGOS ESCOBAR, Presidente de la Rep&#xFA;blica.- Jos&#xE9; Miguel Insulza Salinas, Ministro del Interior.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud., Jorge Burgos Varela, Subsecretario del Interior.</div><br></div>", "i": 8366134}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "388", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-388"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARIA DEL INTERIOR"], "titulo_norma": "REASUME MANDO DEL ESTADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTE DE LA REPUBLICA", "RICARDO LAGOS ESCOBAR", "MANDO DE LA NACION", "REASUNCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-24", "doble_articulado": false, "id_norma": "185289", "numero_fuente": "36965", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-18", "vigencias": [{"desde": "2001-05-18", "hasta": "", "tipo_versio