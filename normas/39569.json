{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE RESOLUCION 1.167 EXENTA, DE 1993 </div></div>", "i": 6024352}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n Exenta N&#xB0; 1.167 de fecha 01.10.93, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriz&#xF3; complementariamente a la empresa de origen boliviano Litoral S.R.L., para efectuar servicio de transporte terrestre internacional de pasajeros entre La Paz (Bolivia) y Arica (Chile), viceversa, con (2) dos frecuencias semanales de ida y vuelta, utilizando el paso fronterizo de Tambo Quemado.-</div><br></div>", "i": 6024353}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Sergio Gonz&#xE1;lez Tagle, Subsecretario de Transportes. </div></div>", "i": 6024354}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1167", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1167"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "EXTRACTO DE RESOLUCION 1.167 EXENTA, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LITORAL SRL", "TRANSPORTE PASAJEROS", "TRANSPORTE INTERNACIONAL", "TRANSPORTE TERRESTRE", "BOLIVIA", "CHILE", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-10-01", "doble_articulado": false, "id_norma": "39569", "numero_fuente": "34738", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-12-13", "vigencias": [{"desde": "1993-12-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-12-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-12-13", "fin_vigencia": "", "tipo_version": "3"}