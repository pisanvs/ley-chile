{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7338177}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 700, de 26 de febrero de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a ESTANISLAO SEGUNDO SALAS DIAZ, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en km. 1, al norte de Caleta Paposo, comuna de Taltal, II Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Alga Seca, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 7338178}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de febrero de 2007.- Mar&#xED;a Angela Barbieri Bellolio, Subsecretaria de Pesca (S). </div></div>", "i": 7338179}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "700 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-700 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-02-26", "doble_articulado": false, "id_norma": "259371", "numero_fuente": "38723", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-03-26", "vigencias": [{"desde": "2007-03-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-03-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-03-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2007-03-26", "fecha_v