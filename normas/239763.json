{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6531638}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 546 de fecha 31 de mayo del 2005, se expropi&#xF3; el lote de terreno N&#xBA; 24-A, superficie 410,10 m2, rol N&#xBA; 271-440, comuna de Quintero, V Regi&#xF3;n, para la obra &quot;Camino Ruta F-190, sector Colmo - Puchuncav&#xED;, Km. 0,00000 a Km. 25,22591, comunas de Limache, Conc&#xF3;n, Quintero, Puchuncav&#xED; y Quillota, provincias de Valpara&#xED;so y Quillota, V Regi&#xF3;n&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Juan Francisco Antonio Salinas Sol&#xED;s, ascendente a la cantidad de $1.784.950.</div><br></div>", "i": 6531639}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6531640}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "546 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-546 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-05-31", "doble_articulado": false, "id_norma": "239763", "numero_fuente": "38199", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-01", "vigencias": [{"desde": "2005-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2005-07