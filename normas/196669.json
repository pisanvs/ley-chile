{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 38, DE 2002 </div></div>", "i": 7061875}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 15, de 27 de febrero de 2002, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la V Regi&#xF3;n, se adjudic&#xF3; a la Sociedad Automotora Villa Alemana Ltda., RUT 79.974.190-3, la concesi&#xF3;n para operar por el plazo de cinco a&#xF1;os cuatro meses, a contar de la fecha de publicaci&#xF3;n del presente extracto, una planta revisora clase AB ubicada en calle Los Morenos N&#xBA; 792, Sector Centenario, Los Andes, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba por resoluci&#xF3;n exenta N&#xBA; 38, de 22 marzo de 2002, de esta Secretar&#xED;a Regional Ministerial.-</div><br><br></div>", "i": 7061876}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Carlos Inostroza Bilbao, Secretario Regional Ministerial de Transportes y Telecomunicaciones V Regi&#xF3;n.</div><br></div>", "i": 7061877}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "38 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-38 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL V REGIÓN DE VALPARAÍSO"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 38, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-22", "doble_articulado": false, "id_norma": "196669", "numero_fuente": "37235", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-15", "vigencias": [{"desde": "2002-04-15"