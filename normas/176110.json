{"html": [{"t": "<div><div class=\"p\">INFORMA SOBRE NOMBRAMIENTO EN LA DIRECTIVA CENTRAL DEL PARTIDO SOCIALISTA DE CHILE </div></div>", "i": 6302631}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ricardo N&#xFA;&#xF1;ez&nbsp; Mu&#xF1;oz, Presidente del Partido Socialista de Chile, y Darko Homan Varljen, Presidente del Tribunal Supremo de la colectividad, han informado el nombramiento de do&#xF1;a Pamela Pereira Fern&#xE1;ndez, como Tesorero de la Directiva Central, en reemplazo de don Francisco Fern&#xE1;ndez Fredes.</div><br><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada en virtud de lo establecido en el Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por resoluci&#xF3;n O-N&#xBA; 758 de fecha 20 de septiembre de 2000.-</div><br></div>", "i": 6302632}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director. </div></div>", "i": 6302633}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "758", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-758"}, {"tipo": "3", "numero": "O-758", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-758"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "INFORMA SOBRE NOMBRAMIENTO EN LA DIRECTIVA CENTRAL DEL\nPARTIDO SOCIALISTA DE CHILE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO SOCIALISTA DE CHILE", "PAMELA PEREIRA FERNANDEZ", "TESORERA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-20", "doble_articulado": false, "id_norma": "176110", "numero_fuente": "36773", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-27", "vigencias": [{"desde": "2000-