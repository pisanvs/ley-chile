{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6156858}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;144 de 31 de agosto de 1998, de Serviu Regi&#xF3;n de Coquimbo, se orden&#xF3; expropiaci&#xF3;n, conforme art. 51&nbsp; ley 16.391 y D.L. 2.186 de 1978, de parte del inmueble ubicado en calle Amun&#xE1;tegui N&#xBA;341 presunto rol aval&#xFA;o 132-8 comuna La Serena, aparentemente dominio de don Severino Arancibia D&#xED;az, de una superficie aproximada de 156,00 metros cuadrados. Comisi&#xF3;n Peritos integrada por don Patricio Mena L&#xF3;pez, Alfredo Prieto Parra y do&#xF1;a Iris Marcich Moller, arquitectos, seg&#xFA;n informe de 30 de junio de 1998, fij&#xF3; monto provisional indemnizaci&#xF3;n en $14.057.086 pagadera al contado.</div><br></div>", "i": 6156859}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n Coquimbo.</div><br></div>", "i": 6156860}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "144", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-144"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN IV REGIÓN DE COQUIMBO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-31", "doble_articulado": false, "id_norma": "132679", "numero_fuente": "36302", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-03-01", "vigencias": [{"desde": "1999-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-03-01", "fin_v