{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6046214}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 718, de 31 de julio de 1997, se expropiaron los lotes de terreno N&#xBA;s. 42-B, 42-C, 42-D y 50 superficies 200, 210, 195 y 80 M2.</div><div class=\"p\">respectivamente, roles de aval&#xFA;o 47-90 y los restantes en tr&#xE1;mite, comuna de La Estrella, para la obra Camino L&#xED;mite Regional (Rapel) - Alcones I, Sector Litueche - La Rosa y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Juan Cifra Huerta, Marina Cifra Huerta, Natalia Cifra Huerta y Julia Cifra Huerta, ascendente a las cantidades de $624.000, $624.000, $871.000 y $333.700.-</div><br></div>", "i": 6046215}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6046216}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "718", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-718"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "LA ESTRELLA", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-31", "doble_articulado": false, "id_norma": "75949", "numero_fuente": "35867", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-09-15", "vigencias": [{"desde": "1997-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincula