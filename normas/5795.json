{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Complementa ley n&#xFA;mero 5,005</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 133.- Santiago, 4 de Julio de 1932.- La Junta de Gobierno ha acordado y</div><div class=\"p\">&nbsp; &nbsp; Decreta:</div><br></div>", "i": 8255815}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Agr&#xE9;guese al art&#xED;culo 6.o de la ley n&#xFA;mero 5,005 de 24 de Noviembre pr&#xF3;ximo pasado, la siguiente letra:</div><div class=\"p\">&nbsp; &nbsp; &quot;La de los empleados de la Direcci&#xF3;n General de los Servicios de Agua Potable y Alcantarillado, de la Direcci&#xF3;n de Agua Potable y Alcantarillado de la provincia de Santiago y personal del Servicio de Gobierno Interior&quot;.</div><br></div>", "i": 8255816}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de Leyes y Decretos del Gobierno.- CARLOS DAVILA.- Nolasco C&#xE1;rdenas.- J. E. Villal&#xF3;n.- J. Antonio R&#xED;os.</div><br></div>", "i": 8255817}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "133", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-133"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "COMPLEMENTA LEY NUMERO 5,005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ADMINISTRACION PUBLICA", "DIRECCION GENERAL SERVICIOS AGUA POTABLE Y ALCANTARILLADO", "VACANTES", "PERSONAL", "SERVICIO GOBIERNO INTERIOR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-07-04", "doble_articulado": false, "id_norma": "5795", "numero_fuente": "16317", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-07-07", "vigencias": [{"desde": "1932-07-07", "hast