{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6475422}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 951, de 6 de abril de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA PACIFIC STAR SOCIEDAD ANONIMA, para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Ruta 5 Sur, kil&#xF3;metro 1171, sector Piruquina, Castro, X Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de concentrado de&nbsp; prote&#xED;na soluble estabilizado obtenido de fracciones l&#xED;quidas parcialmente desgrasadas extra&#xED;das durante la elaboraci&#xF3;n de harina y aceite de pescado, los recursos hidrobiol&#xF3;gicos individualizados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6475423}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6475424}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "951 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-951 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-06", "doble_articulado": false, "id_norma": "224262", "numero_fuente": "37846", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-27", "vigencias": [{"desde": "2004-04-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-04-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2