{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;2.965 EXENTA, DE 2007 </div></div>", "i": 7342774}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA;2.965, de 10 de mayo de 2007, del Servicio Nacional de Capacitaci&#xF3;n y Empleo, se cancel&#xF3; del Registro de Organismos T&#xE9;cnicos Intermedios para Capacitaci&#xF3;n al &quot;Organismo T&#xE9;cnico Intermedio para Capacitaci&#xF3;n Integraci&#xF3;n Empresarial de Chile&quot;, RUT N&#xBA;65.184.410-K, y, por ende, qued&#xF3; sin efecto su correspondiente personalidad jur&#xED;dica, en virtud de lo dispuesto en los art&#xED;culos 78 letra c) y 79 de la ley N&#xBA;19.518.</div><br></div>", "i": 7342775}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fernando Rouliez Fleck, Director Nacional. </div></div>", "i": 7342776}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2965 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2965 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº2.965 EXENTA, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-05-10", "doble_articulado": false, "id_norma": "261142", "numero_fuente": "38772", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-05-26", "vigencias": [{"desde": "2007-05-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-05-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-05-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc