{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6428601}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.298, de 18 de junio de 2003, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2.950, de 2002, de esta Subsecretar&#xED;a, que declar&#xF3; la caducidad parcial de las resoluciones N&#xBA; 330, de 1982, N&#xBA; 198, de 1985, y N&#xBA; 460, de 1987, todas de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autorizaron a do&#xF1;a MARIA BAYCIC BAYCIC para operar la nave &quot;Don Mario&quot; entre la III y IV Regiones, con arrastre, sobre el recurso Langostino amarillo, en cumplimiento de la resoluci&#xF3;n exenta N&#xBA; 31, de fecha 24 de marzo de 2003, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6428602}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de junio de 2003.- Felipe&nbsp; Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6428603}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1298", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1298"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-18", "doble_articulado": false, "id_norma": "211622", "numero_fuente": "37592", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-25", "vigencias": [{"desde": "2003-06-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-06-25", "fin_vigencia": ""}, "vigencias_version_