{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; BOLETIN INTERNACIONAL DE TARIFAS ADUANERAS Lei n&#xFA;m. 161.-Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946964}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que invierta hasta la suma de trescientas ochenta libras esterlinas (L 380) en el pago de las cuotas con que el Gobierno de Chile ha debido contribuir hasta la fecha para la publicacion del &quot;Boletin Internacional de Tarifas Aduaneras.&quot;</div><br><br></div>", "i": 5946965}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 10 de Enero de 1894.-JORGE MONTT.-Alejandro Vial.</div><br></div>", "i": 5946966}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "161", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-161"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "BOLETIN INTERNACIONAL DE TARIFAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BOLETIN INTERNACIONAL TARIFAS ADUANERAS", "PRESIDENTE", "REPUBLICA", "INVERSION", "AUTORIZACION", "CONTRIBUCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-01-10", "doble_articulado": false, "id_norma": "22022", "numero_fuente": "4714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-01-11", "vigencias": [{"desde": "1894-01-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vig