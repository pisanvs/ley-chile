{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Crea el empleo de Jefe de la Seccion Consular.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1812.- Valpara&#xED;so, a 13 de Febrero de 1906.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7164451}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Cr&#xE9;ase en el Ministerio de Relaciones Esteriores el empleo de Jefe de la Seccion Consular, con el sueldo de tres mil pesos ($ 3 000) anuales.</div><br></div>", "i": 7164452}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto en todas sus partes como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- F. Puga Borne.</div><br></div>", "i": 7164453}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1812", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1812"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "CREA EL EMPLEO DE JEFE DE LA SECCIÓN CONSULAR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MINISTERIO RELACIONES EXTERIORES", "JEFE SECCION", "CONSULAR", "CARGO", "CREACION", "SUELDO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-02-13", "doble_articulado": false, "id_norma": "22934", "numero_fuente": "8444", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1906-03-05", "vigencias": [{"desde": "1906-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1906-03-05", "fin_vigencia": ""}, "