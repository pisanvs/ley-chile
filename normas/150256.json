{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 86, DE 1999</div><br><br></div>", "i": 8355469}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA;86, de fecha 10 de noviembre de 1999, se aprob&#xF3; la reforma parcial al estatuto de la Cooperativa de Ahorro y Cr&#xE9;dito Liberaci&#xF3;n Limitada, de sigla Credicoop; en los t&#xE9;rminos que da testimonio la escritura p&#xFA;blica suscrita con fecha 14 de octubre de 1999, ante el Notario P&#xFA;blico de la ciudad de Santiago, Ra&#xFA;l Iv&#xE1;n Perry Pefaur.</div><br></div>", "i": 8355470}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas.</div><br></div>", "i": 8355471}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "86", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-86"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 86, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-11-10", "doble_articulado": false, "id_norma": "150256", "numero_fuente": "36553", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-01-04", "vigencias": [{"desde": "2000-01-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-01-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-01-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendien