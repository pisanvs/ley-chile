{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A AGR&#xCD;COLA PRODUCTOS SILVESTRES LTDA.</div></div>", "i": 9938607}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La XV Direcci&#xF3;n Regional Metropolitana Santiago Oriente del SII, por resoluci&#xF3;n Ex. N&#xB0; 2.421, de fecha 27/07/2018, otorga a contar del 1&#xB0; del mes siguiente al de esta publicaci&#xF3;n, a Agr&#xED;cola Productos Silvestres Ltda., RUT N&#xB0; 79.933.330-9, la calidad de Agente Retenedor del Impuesto al Valor Agregado en las compras de productos silvestres que efect&#xFA;en a terceros vendedores, conforme la facultad establecida en la resoluci&#xF3;n exenta N&#xB0; 4.095, del 25.08.2000, de la Direcci&#xF3;n Nacional.- </div></div>", "i": 9938608}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Ingrid Herrera Mu&#xF1;oz, Directora Regional (S). Resoluci&#xF3;n Ex. RA N&#xB0; 246/530/2018, de 12/07/2018.</div></div>", "i": 9938609}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2421 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2421 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL SANTIAGO ORIENTE"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A AGRÍCOLA PRODUCTOS SILVESTRES LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1441593", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-07-27", "doble_articulado": false, "id_norma": "1121468", "numero_fuente": "42125", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2018-08-06", "vigencias": [{"desde": "2018-09-01", "hasta": "", "tipo_version": "2", "tipo_versio