{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6421109}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por R.M. (Ex.) N&#xBA; 13, del 24 de enero de 2003, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ac&#xF3;gese el recurso de reclamaci&#xF3;n interpuesto por ALIMENTOS MARINOS S.A. contra las resoluciones N&#xBA; 2.985 y N&#xBA; 2.997, ambas de 2002, de la Subsecretar&#xED;a de Pesca. En consecuencia, consid&#xE9;rese al recurrente y la nave &quot;Santa Irene&quot; en la determinaci&#xF3;n del l&#xED;mite m&#xE1;ximo de captura por armador correspondiente al a&#xF1;o 2003, en las unidades de pesquer&#xED;a Sardina com&#xFA;n y Anchoveta, V a X Regiones, y Merluza de cola, V a X Regiones.</div><br></div>", "i": 6421110}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de enero de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6421111}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "13 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-13 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-24", "doble_articulado": false, "id_norma": "209447", "numero_fuente": "37538", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-04-17", "vigencias": [{"desde": "2003-04-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-04-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-04-17", "fin_vigencia": "", "t