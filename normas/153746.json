{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 624, DE 1985</div><br><br></div>", "i": 7260220}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 585, de 06 de Agosto de 1986, de la Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n No. 624, de 03 de Octubre de 1985, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a don Jorge Mardones Reyes, para instalar y operar una planta elaboradora de congelado, deshidratado (seco-salado, alcohol, agridulce) y ahumado de recursos hidrobiol&#xF3;gicos, en la localidad de Curanue, Comuna de Quell&#xF3;n, Provincia de Chilo&#xE9;, X Regi&#xF3;n, en orden a incluir en el numeral 3&#xB0; entre las especies que dicha persona podr&#xE1; elaborar, los recurso loco y erizo. </div></div>", "i": 7260221}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valparaiso, 06 de Agosto de 1986.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 7260222}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "585", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-585"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 624, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-08-06", "fecha_derogacion": "1988-02-20", "doble_articulado": false, "id_norma": "153746", "numero_fuente": "32550", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-08-18", "vigencias": [{"desde": "1988-02-20", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"