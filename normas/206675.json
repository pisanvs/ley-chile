{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7296786}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 32, de 8 de enero de 2003, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 34 de 1997, s&#xF3;lo en cuanto autoriz&#xF3; a Sociedad Pesquera B&#xED;o B&#xED;o S.A., hoy PESQUERA BIO BIO S.A., para operar la nave &quot;Bonn&quot;, en la VIII y IX Regiones, con arrastre, sobre el recurso Raya, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7296787}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de enero de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7296788}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "32", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-32"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-08", "doble_articulado": false, "id_norma": "206675", "numero_fuente": "37458", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-01-14", "vigencias": [{"desde": "2003-01-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-01-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-01-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "IMH", "fecha_ingreso":