{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">ESTABLECE NORMAS DE SEGURIDAD Y OPERACI&#xD3;N PARA NAVES DEDICADAS AL TRANSPORTE DE PASAJEROS TRAMO CORRAL, ISLA MANCERA Y NIEBLA</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 9652055}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n C.P. COR Ord. N&#xBA; 12.000/9 Vrs., del 2 de febrero de 2011, &quot;Establece normas de seguridad y operaci&#xF3;n para naves dedicadas al transporte de pasajeros tramo Corral, Isla Mancera y Niebla&quot;.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta circular mar&#xED;tima local se encuentra publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl) - Usuario Mar&#xED;timo - Resoluciones Locales.</div><br></div>", "i": 9652056}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Capit&#xE1;n de Puerto Corral.</div></div>", "i": 9652057}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-9"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE", "GOBERNACIÓN MARÍTIMA DE VALDIVIA", "CAPITANÍA DE PUERTO CORRAL"], "titulo_norma": "ESTABLECE NORMAS DE SEGURIDAD Y OPERACIÓN PARA NAVES DEDICADAS AL TRANSPORTE DE PASAJEROS TRAMO CORRAL, ISLA MANCERA Y NIEBLA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; IdDO 970794"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-02-02", "doble_articulado": false, "id_norma": "1084384", "numero_fuente": "41318", "tipo_version": "3", "tipo_version_s": "Única