{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9146841}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.439, de 24 de mayo de 2011, de esta Subsecretar&#xED;a, rech&#xE1;zanse las solicitudes de concesi&#xF3;n de acuicultura N&#xBA; 208111170, 208111278, 208111300, 208111295, 208111294, 208103163 y 208121069, se&#xF1;aladas en la resoluci&#xF3;n extractada, y publicada &#xED;ntegramente en la p&#xE1;gina web www.subpesca.cl, en virtud de los art&#xED;culos 11 y 13 del DS N&#xBA; 320 de 2001, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div></div>", "i": 9146842}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de mayo de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9146843}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1439 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1439 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-05-24", "doble_articulado": false, "id_norma": "1026185", "numero_fuente": "39976", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-06-03", "vigencias": [{"desde": "2011-06-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-06-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-06-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "362", "fecha_ingreso": "2011-06