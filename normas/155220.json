{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 97, DE 1986 </div></div>", "i": 6231550}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 97, de 05 de junio de 1986 se ha modificado en la forma que se indica, a contar del presente a&#xF1;o escolar, el decreto supremo exento de Educaci&#xF3;n N&#xB0; 188, de 1982, que aprob&#xF3; el plan especial de estudio para la Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica al Colegio De Los Sagrados Corazones, de Talcahuano.</div><br></div>", "i": 6231551}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de Junio 1986.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6231552}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "97 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-97 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 97, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-10", "doble_articulado": false, "id_norma": "155220", "numero_fuente": "32509", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-06-30", "vigencias": [{"desde": "1986-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-06-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-06-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-02-09", "fecha_version": "1986-06