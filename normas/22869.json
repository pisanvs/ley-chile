{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Conc&#xE9;de 50 000 pesos para combatir las enfermedades infecciosas.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1713.- Santiago, a 30 de Noviembre de 1904.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274637}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la suma de cincuenta mil pesos ($ 50 000) en la adopcion de las medidas necesarias para combatir las enfermedades infecciosas i en el pago de vi&#xE1;ticos a vacunadores.</div><br></div>", "i": 8274638}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Emilio Bello C.</div><br></div>", "i": 8274639}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1713", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1713"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE 50 000 PESOS PARA COMBATIR LAS ENFERMEDADES INFECCIOSAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ENFERMEDADES INFECCIOSAS", "PREVENCION", "FONDOS", "INVERSION", "VACUNADORES", "VIATICOS", "PAGO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-11-30", "doble_articulado": false, "id_norma": "22869", "numero_fuente": "8072", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1904-12-01", "vigencias": [{"desde": "1904-12-01", "hasta": "", "tipo_version": "3", "ti