{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6171173}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;391, de 26 de febrero de 1999, se expropiaron los lotes de terrenos N&#xBA;s. 13 y 14, superficies 37 y 93 M2. respectivamente, roles de aval&#xFA;o 3198-16 y 3198-15, comuna de Chill&#xE1;n, para la obra Camino Ruta N-545 Chill&#xE1;n - Tanilvoro, Sector Chill&#xE1;n - Universidad Adventista y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Ram&#xF3;n P&#xE9;rez Zapata y Juan V&#xE1;squez Medina, ascendentes a las cantidades de $348.667.- para el lote 13 y $611.579.- para el lote 14. </div></div>", "i": 6171174}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6171175}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "391", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-391"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-02-26", "doble_articulado": false, "id_norma": "137209", "numero_fuente": "36377", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-06-01", "vigencias": [{"desde": "1999-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JRC", "fecha_ingreso": "1999-06-02", "fec