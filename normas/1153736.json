{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO RESOLUCI&#xD3;N EXENTA QUE INDICA</div></div>", "i": 10186626}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.713, de 14 de diciembre de 2020, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto la <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=263353&amp;idVersion=2020-12-17\">resoluci&#xF3;n exenta N&#xB0; 2.276 de 2007</a>, que autoriz&#xF3; a Corpesca S.A. para realizar actividades extractivas en alta mar, con la nave &quot;Eperva 50&quot; matr&#xED;cula N&#xB0; 2253, por configurarse la causal establecida en el art&#xED;culo 11.- letra a) del decreto supremo N&#xB0; 360 de 2005 del actual Ministerio de Econom&#xED;a, Fomento y Turismo.</div><br><br></div>", "i": 10186627, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de diciembre de 2020.- Rom&#xE1;n Zelaya R&#xED;os, Subsecretario de Pesca y Acuicultura.</div><div class=\"p\"> </div><br></div>", "i": 10186628}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2713 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2713 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DEJA SIN EFECTO RESOLUCIÓN EXENTA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1865784", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-12-14", "doble_articulado": false, "id_norma": "1153736", "numero_fuente": "42832", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-12-17", "vigencias": [{"desde": "2020-12-17", "hasta": "", "tipo_version": "3", "tipo_versi