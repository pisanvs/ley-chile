{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 3.073 EXENTO, DE 2008 </div></div>", "i": 7381776}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 3.073, de 10 de octubre de 2008, se ha modificado el decreto exento de Educaci&#xF3;n N&#xBA; 263 de 2002, que aprob&#xF3; planes y programas de estudio biling&#xFC;es para los cursos de 7&#xBA; y 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica al Colegio &quot;Orchard College&quot;, de Curic&#xF3;.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio del Subsector de Aprendizaje Tecnolog&#xED;as Inform&#xE1;ticas y Computacionales de Sistemas (TICS) del Sector de Matem&#xE1;tica para 7&#xBA; y 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica (NB.5 y NB.6).</div><br></div>", "i": 7381777}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de noviembre de 2008.- Cristi&#xE1;n Mart&#xED;nez Ahumada, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 7381778}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3073 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3073 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 3.073 EXENTO, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-10-10", "doble_articulado": false, "id_norma": "282962", "numero_fuente": "39233", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-12-10", "vigencias": [{"desde": "2008-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-12-10", "fin_vigencia": ""}, "vigencias_