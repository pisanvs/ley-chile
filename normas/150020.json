{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 158, DE 1987 </div></div>", "i": 6214579}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 158 de 22 de junio de 1987 se ha procedido a aprobar, a contar del a&#xF1;o lectivo 1987, planes y programas de estudio para el segundo ciclo de educaci&#xF3;n media human&#xED;stico-cient&#xED;fica para adultos al Liceo de Adultos San Luis, Ex-Escuela No. 426, de la Corporaci&#xF3;n Municipal de Educaci&#xF3;n de Pudahuel, provincia de Santiago, Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6214580}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Junio de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6214581}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "158 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-158 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 158, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-22", "doble_articulado": false, "id_norma": "150020", "numero_fuente": "32807", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-30", "vigencias": [{"desde": "1987-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-06-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-12-28