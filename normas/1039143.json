{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9249721}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP Exento N&#xBA;567 de 29 de marzo de 2012 y de conformidad a lo dispuesto en al art. 105 del DFL MOP N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;82, superficie 425 m2, rol de Aval&#xFA;o 249-263, comuna de Salamanca, para la obra &quot;MEJORAMIENTO CAMINO 64D825, SECTOR SALAMANCA - QUELEN BAJO&quot;, IV Regi&#xF3;n. La Comisi&#xF3;n de Peritos integrada por V&#xED;ctor Vargas Reyes, Juan Ib&#xE1;&#xF1;ez Palma y Elisa Tapia Fern&#xE1;ndez, fij&#xF3; el valor de tasaci&#xF3;n con fecha 5 de junio de 2011, acord&#xE1;ndose el valor de la indemnizaci&#xF3;n con su propietario, OSCAR RUB&#xC9;N CARVAJAL GALLARDO, en la cantidad de $2.014.390.-, suma que se pagar&#xE1; al contado.</div></div>", "i": 9249722}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9249723}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "567 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-567 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-03-29", "doble_articulado": false, "id_norma": "1039143", "numero_fuente": "40238", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-04-16", "vigencias": [{"desde": "2012-04-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-04-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "20