{"html": [{"t": "<div><div class=\"p\">COMPLEMENTA CLASIFICADOR PRESUPUESTARIO A&#xD1;O 1990 </div><div class=\"p\">N&#xFA;m. 546.- Santiago, 13 de Julio de 1990.- Vistos: Lo dispuesto en los art&#xED;culos 16 y 70 del DL No. 1.263, de 1975, el art&#xED;culo 21 de la ley No. 18.869 y el decreto de Hacienda No. 1.221, de 1989,</div><br><div class=\"p\">Decreto:</div><br></div>", "i": 7223858}, {"t": "<div><div class=\"p\">Modif&#xED;case el decreto de Hacienda No. 1.221, de 1989, en los t&#xE9;rminos que se indican:</div><br><div class=\"p\">En su No. 5</div><br><div class=\"p\">MUNICIPALIDADES CLASIFICADOR DE INGRESOS A&#xD1;O 1990</div><br><div class=\"p\">Agr&#xE9;gase en el &#xED;tem 82, del subt&#xED;tulo 08, la siguiente asignaci&#xF3;n:</div><div class=\"p\">&quot;003 Recursos Cr&#xE9;dito BID 577/OC-CH&quot;.</div><br></div>", "i": 7223859}, {"t": "<div><div class=\"p\">T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- Por orden del Presidente de la Rep&#xFA;blica, Alejandro Foxley Rioseco, Ministro de Hacienda.</div><div class=\"p\">Lo que transcribo a Ud. para su conocimiento.- Saluda Atte. a Ud.- Pablo Pi&#xF1;era Echenique, Subsecretario de Hacienda. </div></div>", "i": 7223860}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "546", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-546"}], "organismos": ["MINISTERIO DE HACIENDA", "SUBSECRETARÍA DE HACIENDA"], "titulo_norma": "COMPLEMENTA CLASIFICADOR PRESUPUESTARIO AÑO 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-07-13", "doble_articulado": false, "id_norma": "89083", "numero_fuente": "33738", "tipo_version": "3", "tipo_version_s": "Única"