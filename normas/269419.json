{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACI&#xD3;N DE EMISOR ELECTR&#xD3;NICO </div></div>", "i": 7364609}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 24, de 20 de febrero de 2008, que deroga autorizaci&#xF3;n otorgada a contribuyentes para operar como emisores electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  A petici&#xF3;n de los contribuyentes RUT N&#xBA; 78.934.220-2 y RUT 76.746.270-0 se deroga autorizaci&#xF3;n otorgada para operar como emisores de documentos tributarios electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de febrero de 2008.</div><br></div>", "i": 7364610}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "24 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-24 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-02-20", "doble_articulado": false, "id_norma": "269419", "numero_fuente": "38996", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-02-25", "vigencias": [{"desde": "2008-02-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-02-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-02-25", "fin_vigencia": "", "tipo