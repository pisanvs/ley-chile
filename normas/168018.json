{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6273221}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP No. 33, de 28 de febrero de 1991, se expropiaron los lotes No. s. 2, 3 y 8, superficies 1.170 m2., 905 m2. y 175 m2., roles de aval&#xFA;o 126-8 y 234-266, Comunas Malloa y Rengo, para la obra Mejoramiento Camino Rengo-Quinta de Tilcoco, Rol H-60 y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios don Jos&#xE9; Antonio Iriondo Arruti y Juan Bautista Reyes Thompson, ascendente a las cantidades de $ 951.003 y $ 128.156.-</div><br></div>", "i": 6273222}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6273223}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "33", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-33"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-02-28", "doble_articulado": false, "id_norma": "168018", "numero_fuente": "33931", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-01", "vigencias": [{"desde": "1991-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2000-05-05", "fecha_version": "1991-04-01", "fecha_actualizacion_texto": "1991-04-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "",