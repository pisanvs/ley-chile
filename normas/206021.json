{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION&nbsp; N&#xBA; 1.027 </div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 1.027, celebrada el 12 de diciembre de 2002, adopt&#xF3; el siguiente Acuerdo:</div><br><br></div>", "i": 6407270}, {"t": "<div><div class=\"p\">1027-02-021212 - Modifica el Anexo del Cap&#xED;tulo I del Compendio de Normas de Cambios Internacionales.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; modificar el Anexo del Cap&#xED;tulo I del Compendio de Normas de Cambios Internacionales, reemplazando la letra a) por la siguiente:</div><br><div class=\"p\">&quot;a) El valor de la CRM antes indicado se corregir&#xE1;, diariamente, en 0,008099% entre el 10 de enero de 2003 y el 9 de enero de 2004, ambas fechas incluidas&quot;.</div><br></div>", "i": 6407271}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de diciembre de 2002.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6407272}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1027", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1027"}, {"tipo": "5", "numero": "1027-02", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1027-02"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION Nº 1.027", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-13", "doble_articulado": false, "id_norma": "206021", "numero_fuente": "37437", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-18", "vigencias": [{"desde": "2002-12-18", "hast