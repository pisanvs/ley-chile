{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xBA; 2.443 EXENTA, DE 2007 </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 2.988 exenta.- Santiago, 27 de junio de 2007.- Vistos: La resoluci&#xF3;n exenta N&#xBA; 2.443, de 1 de junio de 2007, de la Divisi&#xF3;n de Protecci&#xF3;n Agr&#xED;cola; oficio ordinario CNE N&#xBA; 0944 de fecha 19 de junio de 2007 del Secretario Ejecutivo de Comisi&#xF3;n Nacional de Energ&#xED;a, lo dispuesto en el art&#xED;culo 4&#xBA;, letra e) de la ley N&#xBA; 18.455 que fija normas sobre producci&#xF3;n, elaboraci&#xF3;n y comercializaci&#xF3;n de alcoholes et&#xED;licos, bebidas alcoh&#xF3;licas y vinagres,</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 7347212}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case la resoluci&#xF3;n exenta N&#xBA; 2.443, de 1 de junio de 2007, de la Divisi&#xF3;n de Protecci&#xF3;n Agr&#xED;cola, reemplazando el t&#xE9;rmino &quot;Bencina&quot; por &quot;Gasolina&quot;. </div></div>", "i": 7347213}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, transcr&#xED;base, comun&#xED;quese y publ&#xED;quese.- Oscar Enrique Concha D&#xED;az, Director Nacional (S). </div></div>", "i": 7347214}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2988 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2988 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCION Nº 2.443 EXENTA, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-27", "doble_articulado": false, "id_norma": "262526", "numero_fuente": "388