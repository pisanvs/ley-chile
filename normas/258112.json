{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 246 EXENTA, DE 2007 </div></div>", "i": 6600346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 246, de 19 de enero de 2007, del Servicio Nacional de Capacitaci&#xF3;n y Empleo, se establece sectores de beneficiarios elegibles por las empresas hasta el 31 de diciembre de 2007, para los efectos de celebrar contratos de capacitaci&#xF3;n, en conformidad a lo establecido en el inciso sexto del Art. 33 de la ley N&#xBA; 19.518.</div><br></div>", "i": 6600347}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de enero de 2007.- Fernando Rouliez Fleck, Director Nacional Sence.</div><br></div>", "i": 6600348}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "246 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-246 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 246 EXENTA, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TRABAJADORES", "CONTRATO DE CAPACITACION LABORAL", "BENEFICIARIOS ELEGIBLES", "DISCAPACITADOS", "PERSONAS VULNERABLES", "ESTABLECE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-01-19", "doble_articulado": false, "id_norma": "258112", "numero_fuente": "38680", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-02-03", "vigencias": [{"desde": "2007-02-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-02-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-02-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci