{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8821847}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.439, 30 de diciembre de 2009 de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESCADORES S.A. para iniciar actividades pesqueras de transformaci&#xF3;n, para instalar y operar planta ubicada en calle Bernardo O&#x2019;Higgins, parcela 341, Placilla, Valpara&#xED;so, V Regi&#xF3;n, para elaborar en las l&#xED;neas de Cocido, Fresco-Enfriado, Congelado, Surimi, Seco-Salado, Salado H&#xFA;medo, Ahumado, Conservas, Agar-Agar, Alga Seca, Deshidratado, Alginato, Carragenina, Vivos y Harina, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div></div>", "i": 8821848}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de diciembre de 2009.- Germ&#xE1;n Loyola Bast&#xED;as, Subsecretario de Pesca (S).</div></div>", "i": 8821849}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4439 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4439 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-12-30", "doble_articulado": false, "id_norma": "1010119", "numero_fuente": "39560", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-01-14", "vigencias": [{"desde": "2010-01-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-01-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-01-14", "fin_vig