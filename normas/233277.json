{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6507881}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 3.433, de 1 de diciembre</div><div class=\"p\">de 2004, de esta Subsecretar&#xED;a, ampl&#xED;ase a contar del 23</div><div class=\"p\">de agosto de 2004, por 10 meses respecto del recurso</div><div class=\"p\">Alfonsino y por 6 meses respecto del recurso Besugo, el</div><div class=\"p\">plazo otorgado por el numeral 4.- de la resoluci&#xF3;n N&#xBA;</div><div class=\"p\">1.974 de 2003, de esta Subsecretar&#xED;a, a PESQUERA BIO BIO</div><div class=\"p\">S.A., para iniciar actividades pesqueras extractivas con</div><div class=\"p\">la nave &quot;Gardar&apos;&apos;, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, en el &#xE1;rea mar&#xED;tima correspondiente a la Isla de Pascua, Archipi&#xE9;lago de Juan Fern&#xE1;ndez, Islas Sala y G&#xF3;mez e Islas Desventuradas, con arrastre, y en el &#xE1;rea mar&#xED;tima de la III Regi&#xF3;n, con arrastre de media agua, en virtud de haberse acreditado la circunstancia de fuerza mayor invocada por la peticionaria.</div><br></div>", "i": 6507882}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de diciembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6507883}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3433 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3433 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion"