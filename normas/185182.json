{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6334521}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;293 de fecha 28&nbsp; de febrero de 2001, se expropi&#xF3; el lote de terreno N&#xBA;11-I, superficie 3.934 m2, Rol de aval&#xFA;o 4-1, comuna de Constituci&#xF3;n, para la obra &quot;Camino Ruta M-24-K, con Ruta M-50, Sector Accesos Puente Maule en Constituci&#xF3;n,&nbsp; Tramo Km.</div><div class=\"p\">47.920-Km. 53.820&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Marta Graciela C&#xE1;ceres Garrido y Otros, ascendente a la cantidad de $47.624.501. </div></div>", "i": 6334522}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6334523}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "293", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-293"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-28", "doble_articulado": false, "id_norma": "185182", "numero_fuente": "36962", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-15", "vigencias": [{"desde": "2001-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2001-05-16", "fecha_version": "2001-05-15", "fecha_actualizacion_texto": "2001-05-15", "tipo_t