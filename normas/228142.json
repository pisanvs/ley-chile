{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6489217}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.912, de 14 de julio de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA GALEB LIMITADA, para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada Huasco N&#xBA; 86, Barrio Industrial, Antofagasta, II Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n Cocido, fresco-refrigerado y congelado, los recursos hidrobiol&#xF3;gicos individualizados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6489218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de julio de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6489219}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1912 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1912 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-07-14", "doble_articulado": false, "id_norma": "228142", "numero_fuente": "37920", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-27", "vigencias": [{"desde": "2004-07-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-07-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-07-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2004-07-27", "fecha_v