{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; LEI NUM. 2,002 QUE TRASLADA A PUERTO VARAS LA CABECERA DE LA COMUNA DE FRUTILLAR DEL DEPARTAMENTO DE LLANQUIHUE.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,002.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274916}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Trasl&#xE1;dase a Puerto Varas la cabecera del territorio municipal de Frutillar, del departamento de Llanquihue.</div><br></div>", "i": 8274917}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 4 de setiembre de 1907.-PEDRO MONTT.-Luis A. Vergara.</div><br></div>", "i": 8274918}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2002", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2002"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 2,002 QUE TRASLADA A PUERTO VARAS LA CABECERA DE LA COMUNA DE FRUTILLAR DEL DEPARTAMENTO DE LLANQUIHUE.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PUERTO VARAS", "CABECERA COMUNA", "FRUTILLAR", "TRASLADO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-09-04", "doble_articulado": false, "id_norma": "23061", "numero_fuente": "8897", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-09-10", "vigencias": [{"desde": "1907-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inici