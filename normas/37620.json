{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8298735}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.984, de 28 de noviembre de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rese la caducidad parcial de la Resoluci&#xF3;n/N&#xB0; 1.046 de 1993, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD PESQUERA SAN ANTONIO S.A., para realizar actividades pesqueras extractivas con la nave &quot;Paniahue&quot;, en lo relativo a las especies autorizadas en el numeral 3 letra a) entre la III y IV Regi&#xF3;n, en virtud del art&#xED;culo 143 letra b) de la Ley N&#xB0; 18.892 y sus modificaciones.</div><br></div>", "i": 8298736}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 28 de noviembre de 1996.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8298737}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1984", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1984"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD PARCIAL", "SOCIEDAD PESQUERA SAN ANTONIO", "S.A.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-11-28", "doble_articulado": false, "id_norma": "37620", "numero_fuente": "35632", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-12-04", "vigencias": [{"desde": "1996-12-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-12-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio