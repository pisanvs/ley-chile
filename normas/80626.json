{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6057763}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 930 de 29 de Noviembre de 1991 de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL No. 2.186 de 1978, -parte inmueble- ubicado en Avenida Las Rejas esquina Nor - Poniente con Avenida Libertador Bernardo O&apos;Higgins, presunto rol de aval&#xFA;os No. 300-007 comuna Lo Prado, aparente dominio de don Hern&#xE1;n Aguirre Mac-Kay. Comisi&#xF3;n integrada por peritos Sres. Sergio Rojas Ib&#xE1;&#xF1;ez, ingeniero civil, Fernando Merino de la Cerda y Roberto Correa Bezanilla, arquitectos, seg&#xFA;n informe de 12 de Agosto de 1991, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 8.950.000.- pagadera al contado.</div><br></div>", "i": 6057764}, {"t": "<div><div class=\"p\">Directora SERVIU Metropolitano.</div><br></div>", "i": 6057765}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "930", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-930"}], "organismos": ["SERVICIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-11-29", "doble_articulado": false, "id_norma": "80626", "numero_fuente": "34143", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-12-16", "vigencias": [{"desde": "1991-12-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-12-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-12-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fe