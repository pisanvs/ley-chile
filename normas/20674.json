{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 211 EXENTO, DE 1995 </div></div>", "i": 7161159}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 211 de fecha 03 de Abril de 1995 del Ministerio de Educaci&#xF3;n, se ampli&#xF3; el Art&#xED;culo 1&#xB0; inciso 2&#xB0; del Decreto Exento de Educaci&#xF3;n N&#xB0; 94 de fecha 05 de Marzo de 1990, que autoriza el funcionamiento del Instituto Profesional Juan Bohon, en el sentido de que la Instituci&#xF3;n adem&#xE1;s impartir&#xE1; docencia en el &#xE1;rea Tecnol&#xF3;gica.</div><br><br></div>", "i": 7161160}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 06 de Abril de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161161}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "211 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-211 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 211 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO PROFESIONAL JUAN BOHON", "AUTORIZACION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-04-03", "doble_articulado": false, "id_norma": "20674", "numero_fuente": "35141", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-04-11", "vigencias": [{"desde": "1995-04-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-04-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-04-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION