{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DEL DECRETO N&#xBA; 1.582 EXENTO, DE 11.08.2009</div></div>", "i": 8768783}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento que se indica, del Ministerio de Educaci&#xF3;n, se revoca el reconocimiento oficial del Centro de Formaci&#xF3;n T&#xE9;cnica INCOR, de la ciudad de Rancagua, organizado por la Sociedad Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Comercial Rancagua Limitada o C.F.T. INCOR Ltda., representada legalmente por don Leonel Heraldo Villarroel Monsalva, ubicado en la calle Jos&#xE9; Francisco Gana N&#xBA; 504 de la ciudad de Rancagua y elim&#xED;nase a dicho Centro del Registro correspondiente en que se encuentra inscrito con el N&#xBA; 91.- </div></div>", "i": 8768784}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Cristi&#xE1;n Mart&#xED;nez Ahumada, Subsecretario de Educaci&#xF3;n</div></div>", "i": 8768785}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1582 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1582 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DEL DECRETO Nº 1.582 EXENTO, DE 11.08.2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-08-11", "doble_articulado": false, "id_norma": "1005083", "numero_fuente": "39438", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-08-17", "vigencias": [{"desde": "2009-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-08-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-08-17", "fin_vigencia": "", "tipo_vers