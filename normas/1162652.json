{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10252417}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA; 331, de 26 de mayo de 2021, se modific&#xF3; el numeral segundo del <a href=\"https://www.leychile.cl/Navegar?idNorma=1124089&amp;idParte=&amp;idVersion=\">Decreto Exento MOP. N&#xBA; 998</a>, de 31 de agosto de 2018 en la parte que se refiere al nombre del propietario y rol de aval&#xFA;o, quedando de la siguiente forma: lote N&#xBA; 50, ubicado en la comuna de Placilla, figura a nombre de BUSTAMANTE MOSCOSO MARIBEL, seg&#xFA;n rol de aval&#xFA;o 61-126, superficie 325 m2. Complem&#xE9;ntese el informe de tasaci&#xF3;n emitido el 09 de marzo de 2018, mediante acta de 10 de marzo de 2021 de la Jefe de Unidad de Expropiaciones (S) de la Direcci&#xF3;n de Vialidad Regi&#xF3;n del Libertador General Bernardo O&apos;Higgins. </div></div>", "i": 10252418, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10252419}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "331 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-331 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1975749", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-05-26", "doble_articulado": false, "id_norma": "1162652", "numero_fuente": "43003", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-07-15", "vigencias": [{"desde": "2021-07-15", "hasta": "", "tipo_version