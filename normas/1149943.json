{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10163037}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA; 643, de 05 de agosto de 2020, se desisti&#xF3; de la expropiaci&#xF3;n del lote N&#xBA;21, expropiado mediante <a href=\"https://www.leychile.cl/Navegar?idNorma=1072282&amp;idParte=&amp;idVersion=\">Decreto Exento MOP. N&#xBA;1243, de 02 de diciembre de 2014</a>, para la obra: &quot;Construcci&#xF3;n Puente Tunqu&#xE9;n, Sector Ruta F-818, Tramo: Km. 7,45000 a Km. 8,974502&quot;, Comuna de Algarrobo, Provincia de San Antonio, Regi&#xF3;n de Valpara&#xED;so&quot;, por cuanto, dicho lote fue eliminado por Resoluci&#xF3;n SRM. Regi&#xF3;n de Valpara&#xED;so (Exenta) N&#xBA;1666, de 29 de septiembre de 2015, por no ser necesaria la expropiaci&#xF3;n. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en los art&#xED;culos 7&#xBA; y 32&#xBA; del Decreto Ley N&#xBA;2186, de 1978. </div></div>", "i": 10163038, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10163039}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "643 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-643 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1823497", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-08-05", "doble_articulado": false, "id_norma": "1149943", "numero_fuente": "42769", "tipo_version": "3", "tipo_version_s": "Úni