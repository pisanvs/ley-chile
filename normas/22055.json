{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; NITRATO DE POTASA I CLORURO DE POTASIO</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 197 Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947120}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ART. 1.&#xBA; Se reduce a quince por ciento el derecho de importacion que pagan el nitrato de potasa i el cloruro de potasio.</div><br><br><br></div>", "i": 5947121}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ART. 2.&#xB0; Esta lei rejir&#xE1; en toda la Rep&#xFA;blica tres meses despues de su publicacion en el Diario Oficial. </div></div>", "i": 5947122}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, lo he aprobado i sancionado; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintiocho de Agosto de mil ochocientos noventa y cuatro.-JORGE MONTT.-C&#xE1;rlos Riesco.</div><br></div>", "i": 5947123}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "197", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-197"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "NITRATO DE POTASA I CLORURO DE POTASIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NITRATO POTASA", "CLORURO POTASIO", "DERECHO", "IMPORTACION", "REDUCCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-08-28", "dob