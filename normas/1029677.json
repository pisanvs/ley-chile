{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9184547}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (exento) N&#xB0; 1596 de fecha 29 de julio de 2011, se expropi&#xF3; el lote de terreno N&#xB0; 16-B, superficie 1.979 m2, rol N&#xB0; 540-45, comuna de Puerto Octay para la obra &quot;Camino Construcci&#xF3;n Ruta U-91, Sector R&#xED;o Correntoso &#x2013; Las Gaviotas, Tramo Km. 65,58046 al Km. 72,78493&quot;, Provincia de Osorno, X Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario RIGOBERTO HARRY C&#xC1;RCAMO BURGOS, ascendente a la cantidad de $6.031.097.- </div><br></div>", "i": 9184548}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9184549}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1596 EXENTA", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1596 EXENTA"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-07-29", "doble_articulado": false, "id_norma": "1029677", "numero_fuente": "40062", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-09-15", "vigencias": [{"desde": "2011-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "362", "fecha_ingreso": "2011-09-15", "fecha_version": "2011-09-15", "fecha_actual