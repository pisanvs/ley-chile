{"html": [{"t": "<div><div class=\"p\">AUTORIZA A SOCIEDAD PESQUERA CARACOL LTDA.</div><br></div>", "i": 7285482}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 21 de 25 de Enero de 1982 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Sociedad Pesquera Caracol Ltda., domiciliada en Iquique, para operar la embarcaci&#xF3;n denominada &quot;Caracol I&quot;, en el litoral comprendido entre la I y la II Regi&#xF3;n, en la extracci&#xF3;n de sardina espa&#xF1;ola, anchoveta, jurel, cojinoba, bonito y caballa.</div><br><br></div>", "i": 7285483}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br><br></div>", "i": 7285484}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "21", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-21"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A SOCIEDAD PESQUERA CARACOL LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1982-01-25", "doble_articulado": false, "id_norma": "188942", "numero_fuente": "31198", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1982-02-22", "vigencias": [{"desde": "1982-02-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1982-02-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1982-02-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_po