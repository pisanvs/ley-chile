{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7289611}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 306, de 5 de febrero de 2002, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de las resoluciones N&#xBA; 330 de 1982 y N&#xBA; 460 de 1987, ambas de esta Subsecretar&#xED;a, que autorizaron a MARIA BAYCIC BAYCIC, para operar la nave &quot;Don Mario&quot;, s&#xF3;lo en lo relativo al recurso Merluza com&#xFA;n Merluccius gayi, en el litoral comprendido entre la IV a IX Regiones, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7289612}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de febrero de 2002.- Edith Saa Collantes, Subsecretario de Pesca (S).</div><br></div>", "i": 7289613}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "306", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-306"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-05", "doble_articulado": false, "id_norma": "194515", "numero_fuente": "37182", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-02-09", "vigencias": [{"desde": "2002-02-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-02-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-02-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_p