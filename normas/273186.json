{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7373796}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA; 388 de fecha 30 de mayo del 2008, se expropi&#xF3; el lote de terreno N&#xBA; 11, superficie 65 m2, rol N&#xBA; 15-6, comuna de Victoria, IX Regi&#xF3;n para la obra Construcci&#xF3;n By - Pass Victoria, Comuna de Victoria, Provincia de Malleco, IX Regi&#xF3;n, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Hilda Rosa Vald&#xE9;s Romero, ascendente a la cantidad de $1.574.230.- para el lote N&#xBA; 11.</div><br></div>", "i": 7373797}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 7373798}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "388 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-388 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-05-30", "doble_articulado": false, "id_norma": "273186", "numero_fuente": "39101", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-07-01", "vigencias": [{"desde": "2008-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2008-07-01", "fecha_version": "2008-07-01", "fecha_actualizacion_texto": "2008-07-01", "tipo_tratado": ""}, "alertas": [], "a