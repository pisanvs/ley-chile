{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,835.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6173659}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a don Diego A. Rodr&#xED;guez, para los efectos de su jubilacion, el abono del tiempo que le falta para obtenerla con sueldo &#xED;ntegro, segun los t&#xE9;rminos de la lei n&#xFA;mero 1,146, de 28 de diciembre de 1898.</div><br></div>", "i": 6173660}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veinticuatro de diciembre de mil novecientos trece.- Ramon Barros Luco.- Ricardo Salas Edwards.</div><br></div>", "i": 6173661}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2835", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2835"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1913-12-24", "doble_articulado": false, "id_norma": "137943", "numero_fuente": "10760", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1913-12-29", "vigencias": [{"desde": "1913-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1913-12-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1913-12-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie