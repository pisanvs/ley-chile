{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 1, DE 1987 </div></div>", "i": 7253086}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 1 de 06 de enero de 1987 se ha modificado el decreto supremo exento de Educaci&#xF3;n No. 165 de 1983, que autoriz&#xF3; al Colegio Mariano de Santiago, para aplicar planes y programas de estudio de Educaci&#xF3;n General B&#xE1;sica y Media en el sentido que el Colegio aplicar&#xE1; las normas pertinentes del decreto supremo de Educaci&#xF3;n No. 4.002, de 1980, en la Educaci&#xF3;n General B&#xE1;sica.</div><br></div>", "i": 7253087}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 07 de Abril de 1987.- Mar&#xED;a Stefanowsky Bandyra, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 7253088}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 1, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-01-06", "doble_articulado": false, "id_norma": "142512", "numero_fuente": "32749", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-04-16", "vigencias": [{"desde": "1987-04-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-04-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-04-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV",