{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 5.936 EXENTA, DE 2002 </div></div>", "i": 6384715}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;5.936, de 24 de mayo del a&#xF1;o 2002, se ha aprobado al Instituto San Mart&#xED;n (Hermanos Maristas), de Curic&#xF3;, un plan de estudio para los cursos de 1&#xBA;, 2&#xBA;, 3er. y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, que se aplicar&#xE1;n a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 6384716}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de mayo de 2002.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6384717}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5936 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5936 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 5.936 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-24", "doble_articulado": false, "id_norma": "199118", "numero_fuente": "37283", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-14", "vigencias": [{"desde": "2002-06-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-06-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-06-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "