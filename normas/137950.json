{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,757.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6173687}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Mary Selmer, viuda del teniente-coronel asimilado, don V&#xED;ctor Lindholm, derecho a gozar de la pension de montep&#xED;o militar que la lei otorga a la familia de un teniente-coronel de Ej&#xE9;rcito.</div><br></div>", "i": 6173688}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, once de febrero de mil novecientos trece.- Ramon Barros Luco.- Jorje Matte.</div><br></div>", "i": 6173689}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2757", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2757"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1913-02-11", "doble_articulado": false, "id_norma": "137950", "numero_fuente": "10499", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1913-02-12", "vigencias": [{"desde": "1913-02-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1913-02-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1913-02-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacione