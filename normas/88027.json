{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8318648}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n&nbsp; N&#xBA; 1.847, de 31 de diciembre de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el n&#xFA;meral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 59, de 1995 de esta Subsecretar&#xED;a, que autoriz&#xF3; a EMPRESA NACIONAL DE PESCA S.A., a desarrollar actividades pesqueras con la nave &quot;Toyita&quot;, en el sentido de actualizar las caracter&#xED;sticas n&#xE1;uticas de esta &#xFA;ltima, en los t&#xE9;rminos que se indica:</div><br><div class=\"p\">Nombre:&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  &quot;Toyita&quot;</div><div class=\"p\">Matr&#xED;cula:&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2857</div><div class=\"p\">Eslora de arqueo:&nbsp; &nbsp; &nbsp;  58,94 m.</div><div class=\"p\">T.R.G. (Internacional): 1334 t.</div><div class=\"p\">Capacidad de bodega:&nbsp; &nbsp; 1500 m3.</div><div class=\"p\">Arte de pesca:&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; cerco.</div><br></div>", "i": 8318649}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de diciembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8318650}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1847", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1847"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "EMPRESA NACIONAL DE PESCA S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promul