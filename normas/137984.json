{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,647.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6173795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a la viuda e hijos menores de don Guillermo Pinto Ag&#xFC;ero, ex-Enviado Estraordinario i Ministro Plenipotenciario de Chile en Bolivia, una pension de tres mil pesos ($ 3,000) anuales, de que gozar&#xE1;n con arreglo a la lei de montep&#xED;o militar. </div></div>", "i": 6173796}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, dieciseis de febrero de mil novecientos doce.- Ramon Barros Luco.- Renato S&#xE1;nchez.</div><br></div>", "i": 6173797}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2647", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2647"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-02-16", "doble_articulado": false, "id_norma": "137984", "numero_fuente": "10212", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-02-24", "vigencias": [{"desde": "1912-02-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-02-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-02-24"