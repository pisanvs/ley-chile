{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 323 EXENTO, DE 1996 </div></div>", "i": 5943806}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 323, de fecha 12 de junio de 1996, del Ministerio de Educaci&#xF3;n, se aprob&#xF3; al Centro de Formaci&#xF3;n T&#xE9;cnica Centro Interamericano de Educaci&#xF3;n y Cultura Cidec, el plan y programas de estudios de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida en la Sede que se se&#xF1;ala, a contar del a&#xF1;o 1996:</div><div class=\"p\"> Sede N&#xB0; 2&nbsp; : La Serena</div><div class=\"p\"> Carrera&nbsp; &nbsp; : Secretariado Ejecutivo Biling&#xFC;e</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Computacional</div><div class=\"p\"> T&#xED;tulo&nbsp; &nbsp;  : Secretario (a) Ejecutivo (a) Biling&#xFC;e</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Computacional</div><br></div>", "i": 5943807}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 2 de julio de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943808}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "323", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-323"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 323 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO INTERAMERICANO EDUCACION CULTURA CIDEC", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "LA SERENA", "CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-06-12", "doble_articulado": false, "id_norma": "20996", "numero_fuente": "35540", "t