{"html": [{"t": "<div><div class=\"p\">REGULA SUBASTA ELECTR&#xD3;NICA DEL SERVICIO NACIONAL DE ADUANAS</div></div>", "i": 10313481}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 241, de 25 de enero de 2022, del Director Nacional de Aduanas, se sustituye la <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=1159583&amp;idVersion=2022-02-23\">resoluci&#xF3;n exenta N&#xB0; 1.170, de 10 de mayo de 2021</a> y sus modificaciones y, regula la Subasta Electr&#xF3;nica del Servicio Nacional de Aduanas, en aplicaci&#xF3;n de lo dispuesto en el <a href=\"https://www.leychile.cl/Navegar?idNorma=238919&amp;idParte=8666235\">art&#xED;culo 137</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=238919&amp;idParte=&amp;idVersion=\">Ordenanza de Aduanas</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><br></div>", "i": 10313482, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de enero de 2022.- Gustavo Poblete Morales, Director Nacional de Aduanas (S). </div><br></div>", "i": 10313483}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "241 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-241 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "REGULA SUBASTA ELECTRÓNICA DEL SERVICIO NACIONAL DE ADUANAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2089350", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-01-25", "doble_articulado": false, "id_norma": "11