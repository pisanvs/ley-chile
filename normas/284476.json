{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 8.418 EXENTA, DE 2008 </div></div>", "i": 7383418}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xB0; 8.418, de 26 de noviembre de 2008, se han complementado las resoluciones exentas de Educaci&#xF3;n N&#xB0;s. 12.862 de 1999, 5.926 de 2001 y 1.264 de 2002, que aprobaron planes y programas especiales de estudio de 1&#xB0; a 4&#xB0; a&#xF1;o de Ense&#xF1;anza Media, al Colegio Hispano Americano Padres Escolapios, comuna y provincia de Santiago, Regi&#xF3;n Metropolitana.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio del Subsector Cultura Religiosa: &#xC9;tica y Moral para todos los cursos de Ense&#xF1;anza Media.</div><br></div>", "i": 7383419}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de diciembre de 2008.- Jaime Veas S&#xE1;nchez, Jefe Divisi&#xF3;n de Educaci&#xF3;n General (S). </div></div>", "i": 7383420}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8418 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8418 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 8.418 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-11-26", "doble_articulado": false, "id_norma": "284476", "numero_fuente": "39253", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-01-05", "vigencias": [{"desde": "2009-01-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-01-05", "fin_vigencia": ""}, "vigencias_versi