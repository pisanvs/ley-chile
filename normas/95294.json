{"html": [{"t": "<div><div class=\"p\">DERECHOS DE APROVECHAMIENTO DE AGUAS EN COMUNA DE TALCA </div></div>", "i": 6099582}, {"t": "<div><div class=\"p\">Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No.1.365 de 9 de Agosto de 1989, conforme art.5&#xBA; transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a sitios 1 al 88 y Reservas SAG 1 y 2 del Proyecto de Subdivisi&#xF3;n de la &quot;Chacra Silvia&quot; formada por predio &quot;F&#xE1;brica del Culenar, hoy Chacra Silvia&quot; de la comuna de Talca, provincia de Talca, VII Regi&#xF3;n. Los Derechos de Agua se extraen del Canal Duao Zapata. Publicaci&#xF3;n hecha conforme art.13 Ley No.18.377. </div></div>", "i": 6099583}, {"t": "<div><div class=\"p\">Director Nacional.</div><br></div>", "i": 6099584}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1365 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1365 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DERECHOS DE APROVECHAMIENTO DE AGUAS EN COMUNA DE TALCA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-08-09", "doble_articulado": false, "id_norma": "95294", "numero_fuente": "33463", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-09-01", "vigencias": [{"desde": "1989-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac