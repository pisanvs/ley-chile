{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6417228}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;637, de 3 de marzo de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA EL GOLFO S.A. para realizar actividades extractivas en aguas internacionales con la nave &quot;Cobra&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2922</div><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CB-6027</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  58,70 m</div><div class=\"p\">T.R.G. (Internacional)&nbsp; &nbsp; &nbsp;  1315,00</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 1489,40 m3</div><div class=\"p\">Potencia motor principal&nbsp; &nbsp;  3590,00 Hp</div><div class=\"p\">Potencia motor auxiliar&nbsp; &nbsp; &nbsp; 1169,00 Hp</div><br></div>", "i": 6417229}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de marzo de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6417230}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "637", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-637"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-03-03", "doble_articulado": false, "id_norma": "208386", "numero_fuente": "37508", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003