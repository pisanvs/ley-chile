{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6315303}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;5.046 de 31 de octubre del 2000, se expropiaron los lotes de terrenos N&#xBA;s. 4 y 4-A, superficies 250 y 662 m&#xB2;. respectivamente, rol de aval&#xFA;o 195-1, comuna de Hualqui, para la obra Camino Ruta O-60, Sector Chiguayante-Hualqui (Paso Sup. F.F.C.C.), Km.</div><div class=\"p\">5.210.00 a Km. 5.876.00 y se acord&#xF3; precio de la indemnizaci&#xF3;n con su propietario Luis Arturo Gatica Moscoso, ascendente a la cantidad de $4.160.466. </div></div>", "i": 6315304}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6315305}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "5046", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-5046"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-31", "doble_articulado": false, "id_norma": "179817", "numero_fuente": "36851", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-02", "vigencias": [{"desde": "2001-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2001-01-05", "fecha_version": "2001-01-02", "fecha_actualizacion_texto": "2001-01-02", "tipo_tratado": ""}, "alertas": [], "al