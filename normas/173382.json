{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7275201}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.530, de 14 de julio de 2000, de esta Subsecretar&#xED;a, prorr&#xF3;gase por el t&#xE9;rmino de 8 meses, contados desde el 16 de enero del a&#xF1;o 2000, el plazo otorgado a PESQUERA OCEANICA DOS LIMITADA para continuar operaciones pesqueras con la nave &apos;&apos;Oce&#xE1;nica 3&apos;&apos;, autorizada por las resoluciones N&#xBA; 1.276 de 1994, N&#xBA; 1.458 de 1996, N&#xBA; 657 de 1998, modificada mediante resoluci&#xF3;n N&#xBA; 916 del 2000, todas de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor.</div><br></div>", "i": 7275202}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de julio de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7275203}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1530", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1530"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-07-14", "fecha_derogacion": "2005-11-10", "doble_articulado": false, "id_norma": "173382", "numero_fuente": "36722", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-07-25", "vigencias": [{"desde": "2005-11-10", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2000-07-25", "hasta": "2005-11-09", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "v