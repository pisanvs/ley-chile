{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6335179}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;399 de fecha 30 de marzo del 2001, se expropiaron los lotes de terreno N&#xBA;s. 11 y 13, superficie 837, 6.761 m2, respectivamente, rol de aval&#xFA;o 95-56, comuna de Pelarco, para la obra &quot;Camino Los Robles-Bajo Perqu&#xED;n, tramo Km. 46,140.00 a Km.</div><div class=\"p\">76,107.70&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Orguina Elcira del C. Salas Verdugo, ascendente a la cantidad de $2.338.592.</div><br></div>", "i": 6335180}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6335181}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "399", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-399"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-30", "doble_articulado": false, "id_norma": "185378", "numero_fuente": "36962", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-15", "vigencias": [{"desde": "2001-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2001-05-22", "fecha_version": "2001-05-15", "fecha_actualizacion_texto": "2001-05-15", "tipo_tratado": ""}, "alertas": [], "alerta_gl