{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,216.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 8343278}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- El&#xE9;vase a la categor&#xED;a de primera clase la plaza de taqu&#xED;grafo segundo del Senado, que sirve don Jos&#xE9; Ramon Ballesteros, i por el tiempo que dicho se&#xF1;or la desempe&#xF1;e.</div><br></div>", "i": 8343279}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, tres de julio de mil ochocientos noventa i nueve.- FEDERICO ERRAZURIZ.- R. Silva Cruz.</div><br></div>", "i": 8343280}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1216", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1216"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-07-03", "doble_articulado": false, "id_norma": "134555", "numero_fuente": "6339", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-07-04", "vigencias": [{"desde": "1899-07-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-07-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-07-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingres