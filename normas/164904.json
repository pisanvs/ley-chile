{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6263004}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta N&#xB0; 237 del 25 de Septiembre de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n se autoriza a Ren&#xE9; Carrasco Candia y Alejandra de la Cruz R&#xED;os R&#xED;os, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.- </div></div>", "i": 6263005}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan W. Flaquer Hern&#xE1;ndez, Secretario Regional Ministerial Transportes y Telecomunicaciones I Regi&#xF3;n Tarapac .</div><br></div>", "i": 6263006}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "237 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-237 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-09-25", "doble_articulado": false, "id_norma": "164904", "numero_fuente": "32301", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-10-21", "vigencias": [{"desde": "1985-10-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-10-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-10-21", "fin_vigencia": "", "tipo_version": "