{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8302541}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 550 de 17 de abril de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n; decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xBA; 86, de 1993 de esta Subsecretar&#xED;a, que autoriz&#xF3; a AGROPESCA S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Blue&quot;, por haberse configurado la causal prevista en el art&#xED;culo 143 letra b) de la Ley N&#xBA; 18.892 y sus modificaciones. </div></div>", "i": 8302542}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de abril de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8302543}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "550", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-550"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "AGROPESCA S.A.", "AUTORIZACION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-17", "doble_articulado": false, "id_norma": "70830", "numero_fuente": "35748", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-23", "vigencias": [{"desde": "1997-04-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-04-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-04-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresa