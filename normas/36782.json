{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297007}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.357, de 18 de julio de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por la ILUSTRE</div><div class=\"p\">MUNICIPALIDAD DE QUINCHAO, para un sector ubicado en</div><div class=\"p\">Estero Quinchao, Comuna de Quinchao, Provincia de</div><div class=\"p\">Chilo&#xE9;, X Regi&#xF3;n, en virtud de lo dispuesto en los</div><div class=\"p\">art&#xED;culos 76&#xB0;, 77&#xB0;, 78&#xB0; y 5&#xB0; transitorio, inciso 6&#xB0;, de la Ley General de Pesca y Acuicultura y el art&#xED;culo 14&#xB0; del D.S. N&#xB0; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 278, de 1984, de esta Subsecretar&#xED;a, en virtud de lo se&#xF1;alado precedentemente.</div><br></div>", "i": 8297008}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 18 de julio de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297009}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1357", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1357"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDAD QUINCHAO", "CONCESION ACUICULTURA", "DECIMA REGION", "QUINCHAO", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha