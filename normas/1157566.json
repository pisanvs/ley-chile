{"html": [{"t": "<div><div class=\"p\">JUNTA DE HACIENDA</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Febrero 15 de 1823.</div></div>", "i": 10238043}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se restablece de acuerdo con el Congreso la Junta contenciosa superior de Hacienda al estado que le dio el art 14 cap. 1.&#xB0; tit. 4&#xB0; de la Constituci&#xF3;n Provisoria de 1818 y para salvar el inconveniente que presenta el n&#xFA;mero par de sus vocales se nombra Juez nato para dirimir las discordancias al ministro menos antiguo de la C&#xE1;mara de Justicia.</div></div>", "i": 10238044}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n e impr&#xED;mase.-Eyzaguirre.-Infante.-Errazuriz.-Vial.</div></div>", "i": 10238045}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["DEPARTAMENTO DE HACIENDA"], "titulo_norma": "JUNTA DE HACIENDA", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-02-15", "doble_articulado": false, "id_norma": "1157566", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-02-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-02-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-02-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-06-06", "fecha_version": "1823-02-15", "fecha_actualizacion_texto": "2021-06-06", "tipo_tratado": ""}, "alertas": [], "alerta_glo