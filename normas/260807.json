{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 7341790}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 331, de 10 de abril de 2007, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme D.L. N&#xBA; 2.186 de 1978, del Lote N&#xBA; 67, correspondiente a parte del inmueble ubicado en Lira 320, Rol de Aval&#xFA;o N&#xBA; 520-30, Comuna de Santiago, aparente dominio de Acuna Bustos Hern&#xE1;n Roberto. Comisi&#xF3;n integrada por peritos se&#xF1;ores N&#xE9;stor Abello Rodr&#xED;guez, Ingeniero Civil; M&#xE1;ximo Cort&#xE9;s Evaristi, Constructor Civil y Ver&#xF3;nica Olivier Valdebenito, Arquitecto. Seg&#xFA;n informe de 22 de febrero de 2007, fij&#xF3; monto provisional indemnizaci&#xF3;n en $19.586.780, pagadera al contado.</div><br></div>", "i": 7341791}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 7341792}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "331", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-331"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES PARCIALES DE INMUEBLES QUE INDICA; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-04-10", "doble_articulado": false, "id_norma": "260807", "numero_fuente": "38763", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-05-15", "vigencias": [{"desde": "2007-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ú