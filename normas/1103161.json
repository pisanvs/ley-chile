{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE DECLARA &#xC1;REA DE PLAGA QUE INDICA</div></div>", "i": 9798656}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.547, de 15 de mayo de 2017, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1077854&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 1.346, de 2015</a>, de esta Subsecretar&#xED;a, que declar&#xF3; &#xE1;rea de plaga de especie de macroalga verde pertenecientes al g&#xE9;nero Rhizoclonium spp., en cuerpos de agua de la ribera norte del R&#xED;o Maull&#xED;n, X Regi&#xF3;n, en el sentido de ampliar su vigencia hasta el 30 de octubre de 2017.</div></div>", "i": 9798657}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de mayo de 2017.- Pablo Berazaluce Maturana, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9798658}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1547 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1547 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE DECLARA ÁREA DE PLAGA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1217692; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-05-15", "doble_articulado": false, "id_norma": "1103161", "numero_fuente": "41764", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-05-23", "vigencias": [{"desde": "2017-05-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-05-23", "fin_vigencia": ""}, "vig