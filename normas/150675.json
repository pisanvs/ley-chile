{"html": [{"t": "<div><div class=\"p\">AUTORIZA A SOCIEDAD ALGAS SAN JUAN S.A. PARA DESARROLLAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 8355876}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 458, de 12 de Mayo de 1987, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Sociedad Algas San Juan S.A., domiciliada en Valdivia, para instalar y operar un establecimiento de cultivo de algas del g&#xE9;nero Gracilaria, en un sector de Ensenada San Juan, Comuna de Corral, Provincia de Valdivia, X Regi&#xF3;n, en un &#xE1;rea de 100.762 m2 de fondo de mar.</div><br></div>", "i": 8355877}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de Mayo de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8355878}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "458", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-458"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A SOCIEDAD ALGAS SAN JUAN S.A. PARA DESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1987-05-12", "fecha_derogacion": "1990-07-05", "doble_articulado": false, "id_norma": "150675", "numero_fuente": "32793", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1987-06-11", "vigencias": [{"desde": "1990-07-05", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1987-06-11", "hasta": "1990-07-04", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"ini