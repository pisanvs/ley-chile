{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10192690}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xB0; 1456, de 16 de diciembre de 2020, se modific&#xF3; y desisti&#xF3; parcialmente de la expropiaci&#xF3;n del lote N&#xB0; 113, realizada por <a href=\"https://www.leychile.cl/Navegar?idNorma=1132206&amp;idParte=&amp;idVersion=\">Decreto Exento MOP N&#xB0; 323, de 14 de mayo de 2019</a>, reduci&#xE9;ndose la superficie expropiada a 134 m2. y modificando el numeral primero y segundo de dicho Decreto, se&#xF1;alando como nuevo rol de aval&#xFA;o 74-3 y kilometraje de inicio y t&#xE9;rmino, debe decir: Km. 47,96800 al Km. 48,02030, de la comuna de Puyehue, expropiado para la ejecuci&#xF3;n de obra &quot;Reposici&#xF3;n Pavimento Ruta 215-CH, Sector: Las Lumas - Entrelagos, Comuna de Puyehue, Regi&#xF3;n de Los Lagos. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en los art&#xED;culos 7&#xB0; y 32&#xB0; del Decreto Ley N&#xB0; 2186, de 1978.</div></div>", "i": 10192691}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10192692}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1456 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1456 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1876099", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-12-16", "doble_articulado": false, "id_norma": "1154645", "numero_fuente": "42855"