{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6571453}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA; 212 de fecha 28 de abril del 2006, se expropi&#xF3; el lote de terreno N&#xBA;15-A, superficie 4.026 m&#xB2;, Rol 144-40, comuna de Huasco, III Regi&#xF3;n, para la obra &quot;Construcci&#xF3;n Camino Costero, Tramo Huasco - Carrizal, provincia de Huasco, Regi&#xF3;n de Atacama, Etapa II&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario don Santiago Israel Rojas Gonz&#xE1;lez, ascendente a la cantidad de $360.910. </div></div>", "i": 6571454}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6571455}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "212 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-212 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-04-28", "doble_articulado": false, "id_norma": "250065", "numero_fuente": "38478", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-06-01", "vigencias": [{"desde": "2006-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2006-06-01", "fecha_version": "2006-06-01", "fecha_actualizacion_texto": "2006-06-01", "tipo_tratado": ""}, "a