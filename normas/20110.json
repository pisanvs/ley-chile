{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 90 EXENTO, DE 1994 </div></div>", "i": 7160455}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 90 de fecha 4 de Marzo de 1994 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Diego Portales, las adecuaciones introducidas al plan y programas de estudios de la carrera de Secretariado Ejecutivo en Computaci&#xF3;n, las que se insertaron en la Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xB0; 3.348 de 1986. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1994.</div><br></div>", "i": 7160456}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160457}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "90 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-90 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 90 EXENTO, DE 1994", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA DIEGO PORTALES", "PLANES", "ESTUDIOS", "PROGRAMAS ESTUDIOS", "SECRETARIADO EJECUTIVO", "COMPUTACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-03-04", "fecha_derogacion": "2015-06-25", "doble_articulado": false, "id_norma": "20110", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-06-04", "vigencias": [{"desde": "2015-06-25", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1994-06-04", "hasta": "2015-06-24", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2015-06-25", "fin_vigencia": ""}, "vigenc