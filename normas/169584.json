{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7270420}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 906, de&nbsp; 18 de mayo de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA EL GOLFO S.A., para ampliar actividades pesqueras extractivas con la nave &apos;&apos;Saint John&apos;&apos;, autorizadas por resoluciones N&#xB0; 1.133 de 1992, N&#xB0; 472 de 1993 y N&#xB0; 588 de 1996, de esta Subsecretar&#xED;a, en el litoral de la V Regi&#xF3;n, al paralelo 41&#xB0;28,6&apos; L.S., por fuera del &#xE1;rea de reserva artesanal, donde corresponda, en la captura con red de arrastre, de los siguientes recursos hidrobiol&#xF3;gicos: Anguila, Gamba, Cojinoba del sur, R&#xF3;balo, Tollo de cachos, Merluza del sur y Reineta.</div><br></div>", "i": 7270421}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de mayo de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7270422}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "906", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-906"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-05-18", "fecha_derogacion": "2012-03-28", "doble_articulado": false, "id_norma": "169584", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-05-29", "vigencias": [{"desde": "2012-03-28", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2000-05-29", "hasta": "2012-03-27", "tipo_version": "0", "tipo_version_s": "Texto Original"}]