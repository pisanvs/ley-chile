{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7351745}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.458 de 20 de agosto de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BIO BIO S.A., para realizar actividades extractivas en alta mar con la nave &quot;Duqueco&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">&nbsp; &nbsp;  Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp;  CB-5274</div><div class=\"p\">&nbsp; &nbsp;  Puerto de Matr&#xED;cula&nbsp; &nbsp; &nbsp; Valpara&#xED;so</div><div class=\"p\">&nbsp; &nbsp;  Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2819</div><div class=\"p\">&nbsp; &nbsp;  Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp;  51,50 m</div><div class=\"p\">&nbsp; &nbsp;  T.R.G. (Internacional)&nbsp;  886,00</div><div class=\"p\">&nbsp; &nbsp;  Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 10,00 m</div><div class=\"p\">&nbsp; &nbsp;  Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  5,60 m</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2.685 de 2006, de esta Subsecretar&#xED;a.</div><br></div>", "i": 7351746}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de agosto de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7351747}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2458 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2458 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observacio