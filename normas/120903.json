{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8331616}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 929, de 30 de junio de 1998 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la resoluci&#xF3;n N&#xBA; 16 de 1996, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA MARBELLA S.A., para ampliar actividades pesqueras extractivas con la nave &apos;&apos;Costa Grande 1&apos;&apos;, en la captura de la especie Raya volant&#xED;n, en el litoral comprendido entre el l&#xED;mite norte de la VIII Regi&#xF3;n y el paralelo 41 28,6&apos; L.S. </div></div>", "i": 8331617}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de junio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8331618}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "929", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-929"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA MARBELLA S.A.", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-06-30", "fecha_derogacion": "2001-01-26", "doble_articulado": false, "id_norma": "120903", "numero_fuente": "36108", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-07-08", "vigencias": [{"desde": "2001-01-26", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-07-08", "hasta": "2001-01-25", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inic