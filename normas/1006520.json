{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8785774}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.130, de 15 de septiembre de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA ISLA QUIHUA S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Terranova&quot;, en el &#xE1;rea mar&#xED;tima comprendida desde la V a IX Regiones, por fuera de la l&#xED;nea imaginaria trazada a una distancia de 60 millas marinas medidas desde las l&#xED;neas de base normales, con arrastre de media agua, sobre el recurso hidrobiol&#xF3;gico Jibia o Calamar rojo.</div></div>", "i": 8785775}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de septiembre de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8785776}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3130 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-3130 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-09-15", "doble_articulado": false, "id_norma": "1006520", "numero_fuente": "39471", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-09-26", "vigencias": [{"desde": "2009-09-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-09-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-09-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "