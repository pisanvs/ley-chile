{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6231994}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 196, del 12 de Septiembre de 1986, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n, se autoriza a don Arturo Quintana Cerda para efectuar toda clase de servicios de transporte de pasajeros, por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios urbanos de locomoci&#xF3;n colectiva, de acuerdo al DS 163/84. </div></div>", "i": 6231995}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Temuco, 12 de Septiembre de 1986.- Eduardo Zepeda Hauy&#xF3;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n subrogante.</div><br></div>", "i": 6231996}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "196", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-196"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-09-12", "doble_articulado": false, "id_norma": "155428", "numero_fuente": "32.577", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-09-22", "vigencias": [{"desde": "1986-09-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-09-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-09-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "