{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6449302}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.441&nbsp; de 10 de octubre de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD EXTRACTORA Y COMERCIALIZADORA DE PRODUCTOS DEL MAR, AGROP. Y FORESTALES LTDA., para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Arica N&#xBA; 2478, Valdivia, X Regi&#xF3;n, en la l&#xED;nea de elaboraci&#xF3;n de Cocido, Alga Seca y Deshidratado, los siguientes recursos hidrobiol&#xF3;gicos: Huiro, Lechuga de mar, Carola, Cochayuyo, Cotoni, Chasca, Chasc&#xF3;n, Chicorea de mar, Luche, Luga-Luga Mazaella membranacea, Pelillo y Luga-Luga Sarcothalia crispata.</div><br></div>", "i": 6449303}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de octubre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6449304}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2441", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2441"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-10", "doble_articulado": false, "id_norma": "217496", "numero_fuente": "37714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-11-19", "vigencias": [{"desde": "2003-11-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-11-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-11-19", "fin