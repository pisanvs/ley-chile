{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESI&#xD3;N N&#xBA; 1.380 </div></div>", "i": 6633624}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile, en su Sesi&#xF3;n Ordinaria N&#xBA; 1.380, celebrada el 13 de diciembre de 2007, adopt&#xF3; el siguiente acuerdo:</div><br><div class=\"p\">1380-01-071213 - Tasa de Inter&#xE9;s para Pago Diferido de Derechos de Aduana</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3;, en conformidad con lo establecido en la letra c) del art&#xED;culo 10 de la ley N&#xBA; 18.634, que la Tasa de Inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de Derechos de Aduana durante el semestre que expira el 30 de junio de 2008, ser&#xE1; de 6,4% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.</div><br></div>", "i": 6633625}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de diciembre de 2007.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de fe.</div><br></div>", "i": 6633626}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1380", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1380"}, {"tipo": "5", "numero": "1380-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1380-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESIÓN Nº 1.380", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-12-13", "doble_articulado": false, "id_norma": "267708", "numero_fuente": "38939", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-18", "vigencias": [{"desde": "2007-12-18", "hasta": "", "tipo_versi