{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8303159}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 695, de 13 de mayo de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n; decl&#xE1;rase la caducidad parcial de la Resoluci&#xF3;n N&#xBA; 1.866, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a EXOSUR S.A., para operar la nave &quot;Le Crabe Tambour&quot;, s&#xF3;lo en lo relativo a las especies Cojinoba del norte, Cojinoba del sur, Corvina, Anchoa, Jurel, Sardina espa&#xF1;ola, y Sierra, en el litoral comprendido entre la V y la VII Regiones, por haberse configurado la causal prevista en el art&#xED;culo 143 letra b) de la Ley N&#xBA; 18.892 y sus modificaciones. </div></div>", "i": 8303160}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de mayo de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8303161}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "695", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-695"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "EXOSUR S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-05-13", "doble_articulado": false, "id_norma": "71506", "numero_fuente": "35771", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-22", "vigencias": [{"desde": "1997-05-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-22", "fin_vigencia": ""}, "vigenc