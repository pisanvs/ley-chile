{"html": [{"t": "<div><div class=\"p\">AUTORIZA A PESQUERA AURO S.A. PARA AMPLIAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 7266465}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 343 de 17 de Junio de 1985 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Pesquera Auro S.A., domiciliada en la ciudad de Iquique, para operar una embarcaci&#xF3;n actualmente en construcci&#xF3;n, en el litoral de la I, II y VIII Regi&#xF3;n, en labores extractivas de los siguientes recursos, destinados a la l&#xED;nea de reducci&#xF3;n: anchoa, jurel, caballa y sardina espa&#xF1;ola y de agujilla, cojinova del Norte, cachurreta y bonito, destinado a l&#xED;neas de congelado o conserva para consumo humaN&#xBA; </div></div>", "i": 7266466}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de Junio de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7266467}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "343", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-343"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA AURO S.A. PARA AMPLIAR ACTIVIDADES\nPESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1985-06-17", "fecha_derogacion": "1994-02-10", "doble_articulado": false, "id_norma": "163365", "numero_fuente": "32207", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1985-06-27", "vigencias": [{"desde": "1994-02-10", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"des