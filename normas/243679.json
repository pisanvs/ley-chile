{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6547043}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.098, de 15 de septiembre de 2005 de esta Subsecretar&#xED;a, autor&#xED;zase a MARGARITA DEL CARMEN CHIGUAY CHIGUAY, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Costanera s/n, Puerto Melinka, Guaitecas, XI Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco Enfriado, Fresco Refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6547044}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de septiembre de 2005.- Edith Saa Collantes, Subsecretario de Pesca (S).</div><br></div>", "i": 6547045}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3098 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3098 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-15", "doble_articulado": false, "id_norma": "243679", "numero_fuente": "38303", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-11-04", "vigencias": [{"desde": "2005-11-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-11-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-11-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "J