{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6325243}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 5.497, de 29 de diciembre de 2000, se expropi&#xF3; el lote de terreno N&#xBA; 108, superficie 379 m2., rol de aval&#xFA;o 601-112, comuna de Mulch&#xE9;n, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: Chill&#xE1;n Collipulli. Sector Kms. 534.180,00 al 544.020,00, Octava Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Orfelia del Carmen Cisternas V&#xE9;liz, ascendente a la cantidad de $10.263.248.-.</div><br></div>", "i": 6325244}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6325245}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "5497", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-5497"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-12-29", "doble_articulado": false, "id_norma": "182489", "numero_fuente": "36901", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-01", "vigencias": [{"desde": "2001-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-03-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2001-03-05", "fecha_version": "2001-03-01", "fecha_actualizacion_texto": "2001-03-01", "tipo_tratado": ""}, "alertas": [], "al