{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8342516}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 375, de 11 de marzo de 1999, de esta Subsecretar&#xED;a, rectif&#xED;canse las resoluciones N&#xBA; 1.946, N&#xBA; 1.947, N&#xBA; 1.948, N&#xBA; 1.949, N&#xBA; 1.950 y N&#xBA; 1.951, todas de 1998, de esta Subsecretar&#xED;a, que otorgaron permisos extraordinarios de pesca para la unidad de pesquer&#xED;a del recurso Orange roughy en el sentido de se&#xF1;alar que la raz&#xF3;n social de la titular de los citados permisos corresponde a PESQUERA FRIOSUR S.A. </div></div>", "i": 8342517}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de marzo de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8342518}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "375", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-375"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-03-11", "doble_articulado": false, "id_norma": "133844", "numero_fuente": "36317", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-03-18", "vigencias": [{"desde": "1999-03-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-03-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-03-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_po