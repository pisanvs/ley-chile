{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 23, DE 1986 </div></div>", "i": 6241558}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 384, de 08 de Mayo de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n No. 23, de 08 de Enero de 1986, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a don Luis Rafael Ibarra Pozo, para instalar y operar lana planta elaboradora de recursos hidrobiol&#xF3;gicos en la l&#xED;nea de congelado, en calle Cardonal s/n., Puerto Montt, en orden a incluir en el numeral 3&#xB0;, entre los recursos que el interesado puede emplear como materia prima en dicha planta, el denominado loco.</div><br></div>", "i": 6241559}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 08 de mayo de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6241560}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "384", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-384"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 23, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-05-08", "doble_articulado": false, "id_norma": "158337", "numero_fuente": "32476", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-05-22", "vigencias": [{"desde": "1986-05-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-05-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1