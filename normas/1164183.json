{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 54A</div></div>", "i": 10263246}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.355, de 20 de agosto de 2021, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1156823&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 639, de 2021</a>, y de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 54A, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para el centro de cultivo que indica en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10263247}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de agosto de 2021.- Cristian Espinoza Montenegro, Subsecretario de Pesca y Acuicultura (S).</div><div class=\"p\"> </div><br></div>", "i": 10263248}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2355 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2355 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 54A", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1999122", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-08-20", "doble_articulado": false, "id_norma": "1164183", "numero_fuente": "43038", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-08-26", "vigencias":