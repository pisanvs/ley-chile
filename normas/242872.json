{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO RECEPTOR JUDICIAL A EDUARDO RENE BARRIOS AGUILERA</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 249.- Santiago, 22 de septiembre de 2005.- Vistos: Lo dispuesto en el Art. 11 del decreto ley N&#xBA; 2.974 de 1979.</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 6543622}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del decreto ley citado, VIII Regi&#xF3;n, al siguiente funcionario:</div><br><div class=\"p\">- Eduardo Ren&#xE9; Barrios Aguilera RUT 4.127.292-9. </div></div>", "i": 6543623}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Arturo S&#xE1;ez Chatterton, Director Nacional.</div><br></div>", "i": 6543624}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "249", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-249"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A EDUARDO RENE BARRIOS\nAGUILERA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-22", "doble_articulado": false, "id_norma": "242872", "numero_fuente": "38287", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-10-15", "vigencias": [{"desde": "2005-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia