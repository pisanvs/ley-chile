{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292534}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 451, de 27 de Abril de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2&#xB0; de la Resoluci&#xF3;n N&#xB0; 113, de 1985, de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a SOCIEDAD PESQUERA LANGEVELD LTDA., R.U.T. N&#xB0; 89.237.900-9, para operar la nave &quot;Chacabuco III&quot;, en el sentido de se&#xF1;alar que su capacidad de bodega es 454,534 m3, y no la que all&#xED; se indica. </div></div>", "i": 8292535}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 27 de Abril de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292536}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "451", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-451"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "AUTORIZACION", "PESCA", "SOCIEDAD PESQUERA", "LANGEVELD LTDA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1995-04-27", "fecha_derogacion": "2000-09-20", "doble_articulado": false, "id_norma": "34841", "numero_fuente": "35178", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1995-05-27", "vigencias": [{"desde": "2000-09-20", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1995-05-27", "hasta": "2000-09-19", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2000-09-20", "fin_vigencia": ""},