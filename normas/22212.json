{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CASA DE ESPOSITOS DE SANTIAGO Lei n&#xFA;m. 362.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273951}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se concede a la Casa de Esp&#xF3;sitos de Santiago cinco mil cuatrocientas sesenta i una una hect&#xE1;reas de terreno de las que se han reservado en la subasta de tierras fiscales al norte de Cautin, entre el rio i el Quillen.</div><br><br></div>", "i": 8273952}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 24 de Julio de 1896.- JORJE MONTT.- O. Renjifo.</div><br></div>", "i": 8273953}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "362", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-362"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CASA DE ESPOSITOS DE SANTIAGO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CASA ESPOSITOS SANTIAGO", "TERRENOS", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-07-24", "doble_articulado": false, "id_norma": "22212", "numero_fuente": "5464", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1896-07-24", "vigencias": [{"desde": "1896-07-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1896-07-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1896-07-24", "fin_vigencia": "", "tipo_version"