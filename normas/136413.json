{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,157.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6168742}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de cinco mil pesos en contratar, por el t&#xE9;rmino que sea necesario, el personal ausiliar indispensable para hacer los escrutinios de la estad&#xED;stica agr&#xED;cola, correspondiente al a&#xF1;o de 1908. </div></div>", "i": 6168743}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, catorce de diciembre de mil novecientos ocho.- Pedro Montt.- Guillermo Echavarr&#xED;a.</div><br></div>", "i": 6168744}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2157", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2157"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1908-11-14", "doble_articulado": false, "id_norma": "136413", "numero_fuente": "9266", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1908-11-17", "vigencias": [{"desde": "1908-11-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1908-11-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1908-11-17", "fin_vigencia"