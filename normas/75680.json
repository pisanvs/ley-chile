{"html": [{"t": "<div><div class=\"p\">ACLARA RESOLUCION EXENTA N&#xBA; 58, DE 1997</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 90 exenta.- Punta Arenas, 27 de agosto de 1997.- Visto: Los art&#xED;culos 45 y 47 del D.S.</div><div class=\"p\">N&#xBA; 212 de 1992, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes;</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br><br><br></div>", "i": 7210666}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Acl&#xE1;rase la Resoluci&#xF3;n exenta N&#xBA; 58, de 1997, de esta Secretar&#xED;a Regional, en orden a establecer que su normativa es aplicable s&#xF3;lo a los servicios que no se han acogido o no han podido acogerse por cualquier causa a la excepci&#xF3;n del art&#xED;culo 47&#xBA; del D.S. citado en Visto.</div><br></div>", "i": 7210667}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Dante Fern&#xE1;ndez Barr&#xED;a, Secretario Regional Ministerial Transportes y Telecomunicaciones XII Regi&#xF3;n.</div><br></div>", "i": 7210668}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "90 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-90 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XII REGIÓN DE MAGALLANES Y ANTÁRTICA CHILENA"], "titulo_norma": "ACLARA RESOLUCION EXENTA Nº 58, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TAXIS COLECTIVOS", "CIRCULACION VEHICULAR", "TERMINAL DE BUSES", "PUNTA ARENAS", "DECIMOSEGUNDA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-08-27", "fecha_derogacion": "2002-06-28", "