{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,431.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 7249036}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Aum&#xE9;ntase la planta de oficiales jenerales i oficiales superiores del Ej&#xE9;rcito en dos jenerales de division, dos jenerales de brigada, cuatro coroneles, cinco tenientes-coroneles i diez sarjentos-mayores, que se proveer&#xE1;n en conformidad i de acuerdo con la lei de ascensos vijente.</div><br></div>", "i": 7249037, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, doce de diciembre de mil novecientos diez.- Emiliano Figueroa.- C&#xE1;rlos Larrain Claro. </div></div>", "i": 7249038}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2431", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2431"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-12-12", "doble_articulado": false, "id_norma": "137046", "numero_fuente": "9860", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-12-21", "vigencias": [{"desde": "1910-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-12-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1910-12-21",