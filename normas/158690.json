{"html": [{"t": "<div><div class=\"p\">AUTORIZA A PESQUERA YADRAN SOCIEDAD LIMITADA PARA AMPLIAR SUS ACTIVIDADES PESQUERAS </div></div>", "i": 6242598}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 430, de 19 de Mayo de 1986, de la Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Pesquera Yadr&#xE1;n Sociedad Limitada, domiciliada en Santiago, para instalar y operar un establecimiento de cultivo de osti&#xF3;n del norte, en la Bah&#xED;a de Guanaqueros, IV Regi&#xF3;n, en una superficie de 70.000 m2.</div><br></div>", "i": 6242599}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de Mayo de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca </div></div>", "i": 6242600}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "430", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-430"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA YADRAN SOCIEDAD LIMITADA PARA\nAMPLIAR SUS ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-05-19", "doble_articulado": false, "id_norma": "158690", "numero_fuente": "32482", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-05-29", "vigencias": [{"desde": "1986-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-05-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-05-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por":