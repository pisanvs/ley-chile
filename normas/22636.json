{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Declara a Perquenco cabecera de la comuna de Quillen Lei n&#xFA;m. 1,424.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274320}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se declara que el pueblo de Perquenco es la cabecera de la comuna de Quillen, del departamento de Traiguen.</div><br></div>", "i": 8274321}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 23 de Enero de 1901.- FEDERICO ERRAZURIZ E.- Juan Antonio Orrego.</div><br></div>", "i": 8274322}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1424", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1424"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DECLARA A PERQUENCO CABECERA DE LA COMUNA DE QUILLEN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PERQUENCO", "CABECERA COMUNA QUILLEN", "DECLARACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-01-23", "doble_articulado": false, "id_norma": "22636", "numero_fuente": "6799", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-01-23", "vigencias": [{"desde": "1901-01-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1901-01-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1901-01-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen