{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 104, DE 1986 </div></div>", "i": 6230918}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 104, de 11 de junio de 1986, se han aprobado para el Liceo Industrial La Cisterna N&#xB0; 1, de La Cisterna, Regi&#xF3;n Metropolitana, planes y programas especiales de estudio para la Educaci&#xF3;n Med&#xED;a, Modalidad T&#xE9;cnico - Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar 1986 y hasta el a&#xF1;o escolar de 1991, en las especialidades de Mec&#xE1;nica de Combusti&#xF3;n Interna y Automotriz y Electr&#xF3;nica Industrial.</div><br></div>", "i": 6230919}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Junio de 1986.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6230920}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "104 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-104 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 104, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-26", "doble_articulado": false, "id_norma": "155035", "numero_fuente": "32508", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-06-28", "vigencias": [{"desde": "1986-06-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-06-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-06-28", "fin_vigencia": "", "tipo_version"