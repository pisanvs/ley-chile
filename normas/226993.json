{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6485419}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 274 de 19 de mayo de 2004 de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL N&#xBA; 2.186 de 1978, del lote N&#xBA; 120 correspondiente a parte del inmueble ubicado en Santa Rosa 4344, presunto rol de aval&#xFA;o N&#xBA;4138-61, comuna de San Joaqu&#xED;n, aparente dominio de Vald&#xE9;s D&#xED;az Marta. Comisi&#xF3;n integrada por Peritos Miguel Ortiz Bobadilla, Constructor Civil; Jimena Asenjo Burgos, Arquitecto y Pedro Almonacid Colin, Ingeniero Civil. Seg&#xFA;n informe de 22 de septiembre de 2003, fij&#xF3; monto provisional indemnizaci&#xF3;n en $3.651.480 pagadera al contado.</div><br></div>", "i": 6485420}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 6485421}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "274", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-274"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES DE INMUEBLES QUE INDICAN NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-19", "doble_articulado": false, "id_norma": "226993", "numero_fuente": "37898", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-01", "vigencias": [{"desde": "2004-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-07-01", "fin_vig