{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9218324}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  De conformidad a lo dispuesto en el Art. 105 del DFL. MOP. N&#xBA;850 de 1997, Por Decreto MOP. (Exento) N&#xBA;4457, de 29 de noviembre de 2011, se expropiaron los lotes de terreno N&#xB0;s. 13, 15 y 18, superficies 389, 80 y 317 m2., Rol N&#xBA;1129-13, para la obra &quot;MEJORAMIENTO RUTA 5 - W15 - 175, SECTOR RUTA 5 - PUMANZANO, CAMINO RUTA 5 - PUMANZANO&quot;, Comuna de Ancud, X Regi&#xF3;n, tasado con fecha 15 de noviembre de 2007, por la Comisi&#xF3;n de Peritos designada mediante Resoluci&#xF3;n SRM. (Exenta) X Regi&#xF3;n N&#xBA;1859, de 23 de octubre de 2007, acord&#xE1;ndose el valor de indemnizaci&#xF3;n con sus propietarios SUCESI&#xD3;N ELIAS LAUBSCHER HAASE, en la cantidad de $629.239, suma que se pagar&#xE1; al contado. </div><br></div>", "i": 9218325}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9218326}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "4457 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-4457 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-11-29", "doble_articulado": false, "id_norma": "1035103", "numero_fuente": "40135", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-12-15", "vigencias": [{"desde": "2011-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-12-15", "fin_vigencia": ""}, "vigencias_version_no