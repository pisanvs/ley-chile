{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 8.497 EXENTA, DE 03.12.2009</div></div>", "i": 8815714}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente se han aprobado planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, a la Scuola Italiana Arturo Dell&#x2019;Oro de Valpara&#xED;so.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio de los Sectores de Italiano del Plan de Formaci&#xF3;n General de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media; de Visi&#xF3;n del Mundo Actual y de M&#xE9;todo Cient&#xED;fico, regulaci&#xF3;n g&#xE9;nica e integraci&#xF3;n celular del Plan de Formaci&#xF3;n Diferenciada para 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, que se se&#xF1;alan en la presente resoluci&#xF3;n.</div></div>", "i": 8815715}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de diciembre de 2009.- Jaime Veas S&#xE1;nchez, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 8815716}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8497 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-8497 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 8.497 EXENTA, DE 03.12.2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-12-03", "doble_articulado": false, "id_norma": "1009454", "numero_fuente": "39541", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-12-21", "vigencias": [{"desde": "2009-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s":