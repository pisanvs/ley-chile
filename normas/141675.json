{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 45,DE 1987 </div></div>", "i": 6186030}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 45 de 11 de marzo de 1987 se ha aprobado, a contar del a&#xF1;o 1987 con car&#xE1;cter experimental a la Fundaci&#xF3;n DUOC, el siguiente Plan de Estudio para la Educaci&#xF3;n de adultos, que se desarrollar&#xE1; en cuatro semestres equivalentes a los 4 a&#xF1;os de la Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica. Se incluyen normas especiales sobre evaluaci&#xF3;n y promoci&#xF3;n de los alumnos y sobre requisitos de ingreso. </div></div>", "i": 6186031}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de Marzo de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6186032}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "45 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-45 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 45, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-03-11", "doble_articulado": false, "id_norma": "141675", "numero_fuente": "32732", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-03-26", "vigencias": [{"desde": "1987-03-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-03-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-03-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc