{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8328925}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;131 de fecha 22 de diciembre de 1997, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se ha rechazado el recurso de reclamaci&#xF3;n interpuesto por la Sociedad Pesquera San Antonio S.A., Rut: 87.992.600-9 y confirmada la resoluci&#xF3;n N&#xBA; 1.984, de 1996, de la Subsecretar&#xED;a de Pesca, que declar&#xF3; la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.046, de 1993, de esa Subsecretar&#xED;a, que autoriz&#xF3; a la reclamante para desarrollar actividades pesqueras con la nave &quot;Paniahue&quot;.-</div><br></div>", "i": 8328926}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Oscar Landerretche Gacit&#xFA;a, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8328927}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "131 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-131 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECURSO DE RECLAMACION", "SOCIEDAD PESQUERA SAN ANTONIO S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-22", "doble_articulado": false, "id_norma": "97576", "numero_fuente": "36013", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-03-12", "vigencias": [{"desde": "1998-03-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-03-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"ini