{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7293281}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.497, de 24 de julio de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA ITATA S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluciones N&#xBA; 984 de 1986, N&#xBA; 671 de 1992 y N&#xBA; 1.136 de 1999, todas de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Avenida Pedro Montt N&#xBA; 704, San Vicente, Talcahuano, VIII Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de Harina y Aceite, los siguientes recursos hidrobiol&#xF3;gicos: Merluza de cola, Merluza de tres aletas, Bacaladillo o mote, Jurel fino, Machuelo o tritre, Anchoveta blanca, Sardina redonda, Vinciguerria.</div><br></div>", "i": 7293282}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de julio de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7293283}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1497", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1497"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-07-24", "doble_articulado": false, "id_norma": "201080", "numero_fuente": "37324", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-08-02", "vigencias": [{"desde": "2002-08-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-08-02", "fin_vigencia": ""}, "vigencias_version_norma":