{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6326491}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA;24, de 31 de enero de 2001, se expropi&#xF3; el lote de terreno N&#xBA;3-B, superficie 643 m2., rol de aval&#xFA;o 1503-106, comuna de Los Angeles, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: Chill&#xE1;n-Collipulli. By Pass Los Angeles, Octava Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Armando Zenteno Arias, ascendente a la cantidad de $1.322.370.</div><br></div>", "i": 6326492}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6326493}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "24 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-24 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-01-31", "doble_articulado": false, "id_norma": "182857", "numero_fuente": "36913", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-15", "vigencias": [{"desde": "2001-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2001-03-19", "fecha_version": "2001-03-15", "fecha_actualizacion_texto": "2001-03-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructur