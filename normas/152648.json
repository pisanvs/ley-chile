{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br></div>", "i": 6223767}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 18, de 16 de Abril de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se autoriza a don Luis Alberto Tobar Brito para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6223768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rancagua, 16 de Abril de 1986.- Juan Latife Saadi, Secretario Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n (S).</div><br></div>", "i": 6223769}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "18 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-18 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-04-16", "doble_articulado": false, "id_norma": "152648", "numero_fuente": "32519", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-07-11", "vigencias": [{"desde": "1986-07-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-07-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-07-11", "fin_vigencia": "", "