{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10224572}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 46, de fecha 3 de mayo de 2021, que &quot;Individualiza a las personas que, en raz&#xF3;n de su funci&#xF3;n o cargo, tengan atribuciones decisorias relevantes o influyan decisivamente en quienes tengan dichas atribuciones, conforme lo dispuesto en el Art. 3&#xB0; inciso 2&#xB0; de la Ley N&#xB0; 20.730, que Regula el Lobby y las Gestiones que representen Intereses Particulares ante las autoridades y funcionarios y revoca <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=1145121&amp;idVersion=2021-05-06\">resoluci&#xF3;n exenta SII N&#xB0; 50, de 2020</a>.&quot;.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl).</div><br><br></div>", "i": 10224573, "v": ["MODIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "46 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-46 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1938622", "EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2021-05-03", "fecha_derogacion": "2022-05-06", "doble_articulado": false, "id_norma": "1159208", "numero_fuente": "42947", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2021-05-06", "vigencias": [{"desde": "2022-05-06",