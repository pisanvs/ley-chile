{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 493 EXENTO DE 2000 </div></div>", "i": 6315721}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 493 de fecha 8 de noviembre de 2000 se autoriz&#xF3; a la Universidad de Aconcagua para impartir las carreras t&#xE9;cnicas que se se&#xF1;alan, a contar del a&#xF1;o 2000, en la sede de Santiago en la direcci&#xF3;n que se indica:</div><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; : Comunicaci&#xF3;n Gr&#xE1;fica Publicitaria</div><div class=\"p\">T&#xED;tulo t&#xE9;cnico : T&#xE9;cnico de Nivel Superior en</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Comunicaci&#xF3;n Gr&#xE1;fica Publicitaria</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  (Av. Francisco Bilbao N&#xBA; 1135).</div><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; : Comunicaci&#xF3;n Publicitaria.</div><div class=\"p\">T&#xED;tulo t&#xE9;cnico : T&#xE9;cnico de Nivel Superior en</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Comunicaci&#xF3;n Publicitaria.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  (Av. Francisco Bilbao N&#xBA; 1135).</div><br></div>", "i": 6315722}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de diciembre de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6315723}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "493 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-493 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 493 EXENTO DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "ob