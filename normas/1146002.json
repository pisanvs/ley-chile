{"html": [{"t": "<div><div class=\"p\">INSTRUYE SOBRE CUMPLIMIENTO DE OBLIGACIONES TRIBUTARIAS QUE INDICA</div></div>", "i": 10124710}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 56, de fecha 26 de mayo de 2020, que instruye sobre cumplimiento de obligaciones tributarias accesorias respecto de hechos gravados beneficiados con la disminuci&#xF3;n transitoria a 0% de las tasas establecidas en los art&#xED;culos <a href=\"https://www.leychile.cl/Navegar?idNorma=7137&amp;idParte=8449406&amp;idVersion=\">1&#xBA;</a> numeral 3), <a href=\"https://www.leychile.cl/Navegar?idNorma=7137&amp;idParte=8449408&amp;idVersion=\">2&#xBA;</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=7137&amp;idParte=8449409&amp;idVersion=\">3&#xBA;</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=7137&amp;idParte=&amp;idVersion=\">Ley sobre Impuesto de Timbres y Estampillas</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento est&#xE1; publicado en &quot;www.sii.cl&quot;.</div><br></div>", "i": 10124711}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "56 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-56 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "INSTRUYE SOBRE CUMPLIMIENTO DE OBLIGACIONES TRIBUTARIAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1767206; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-05-26", "doble_articulado": false, "id_norma": "1146002", "numero_fuente": "42668", "tipo_v