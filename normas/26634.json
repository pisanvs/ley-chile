{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DEROGA EL ARTICULO 5.o DE LA LEY 6,196 Por cuanto el H. Congreso Nacional ha dado aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8279436}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Der&#xF3;gase el art&#xED;culo 5.o de la ley N.o 6,196, publicada en el &quot;Diario Oficial&quot; de fecha 1.o de Marzo del a&#xF1;o 1938&quot;.</div><br></div>", "i": 8279437}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, primero de Octubre de mil novecientos cincuenta y tres.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Osvaldo Koch.</div><br></div>", "i": 8279438}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11278", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11278"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DEROGA EL ARTICULO 5.o DE LA LEY 6,196", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ZONA SECA", "ANDACOLLO", "TERRITORIO", "DECLARACION", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1953-10-01", "doble_articulado": false, "id_norma": "26634", "numero_fuente": "22672", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1953-10-15", "vigencias": [{"desde": "1953-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1953-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1953-10-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie