{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6112892}, {"t": "<div><div class=\"p\">Por decreto MOP. No. 546, de 29 de abril de 1998, se expropi&#xF3; el lote de terreno No. 35, superficie 1.655 m2., rol de aval&#xFA;o 219-60, comuna de Santa Juana, para la obra Camino de la Madera, sector Bifurcaci&#xF3;n Diuqu&#xED;n-Santa Juana, y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Carmen Audolina Valenzuela Neira y otros, ascendente a la cantidad de $ 592.916.</div><br></div>", "i": 6112893}, {"t": "<div><div class=\"p\">- Fiscal del Ministerio de Obras P&#xFA;blicas.</div><div class=\"p\">(1&#xB0;) </div></div>", "i": 6112894}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "546", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-546"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SANTA JUANA", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-29", "doble_articulado": false, "id_norma": "99989", "numero_fuente": "36078", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-06-01", "vigencias": [{"desde": "1998-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1998-06-18", "fecha_version": "1998-06-01", "fecha_actualizacion_texto": "1998-06-01", "tipo_tratado": ""}, "alertas": [], "alerta_g