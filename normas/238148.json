{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6526707}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.370 de 5 de mayo de 2005 de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 1.256 de 2000, de esta Subsecretar&#xED;a, que autoriz&#xF3; a COMPA&#xD1;IA PESQUERA CAMANCHACA S.A., para sustituir las naves &quot;Buenaventura&quot;, &quot;La Chimba&quot;, &quot;Valencia&quot; y una nave en construcci&#xF3;n por la nave &quot;Atacama II&quot;, en el sentido de actualizar las siguientes caracter&#xED;sticas n&#xE1;utica de la nave:</div><br><div class=\"p\">&nbsp; &nbsp;  Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp;  34.74&nbsp; &nbsp;  m.</div><div class=\"p\">&nbsp; &nbsp;  TRG (Nacional)&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  244.79</div><div class=\"p\">&nbsp; &nbsp;  Capacidad de Bodega&nbsp; &nbsp; &nbsp; 382.24&nbsp; &nbsp; m3.</div><br></div>", "i": 6526708}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de mayo de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6526709}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1370 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1370 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-05-05", "fecha_derogacion": "2008-03-29", "doble_articulado": false, "id_norma": "238148", "numero_fuente": "38165", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-05-19", "vigenc