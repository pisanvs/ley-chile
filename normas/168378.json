{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6274467}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1, de fecha 06 de Mayo de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la II Regi&#xF3;n, se autoriza a don Guibaldo Ernesto Ormaz&#xE1;bal Flores para efectuar las revisiones t&#xE9;cnicas de los veh&#xED;culos de transporte de personas de m&#xE1;s de nueve (9) asientos incluido el del conductor; de veh&#xED;culos motorizados de carga con capacidad para transportar m&#xE1;s de 1.750 kilos, sus remolques y semirremolques y los taxis, en el establecimiento ubicade en calle Iquique N&#xBA; 3890, de la ciudad de Antofagasta.-</div><br></div>", "i": 6274468}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Guido M. Ram&#xED;rez Maturana, Secretario Regional Ministerial de Transportes y Telecomunicaciones. II Regi&#xF3;n.</div><br></div>", "i": 6274469}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL II REGIÓN DE ANTOFAGASTA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-06", "doble_articulado": false, "id_norma": "168378", "numero_fuente": "32182", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-05-29", "vigencias": [{"desde": "1985-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-05-29", "fin_vigencia