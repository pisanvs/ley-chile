{"html": [{"t": "<div><div class=\"p\">PRORROGA ENTRADA EN VIGENCIA DE RESOLUCI&#xD3;N N&#xBA; 2.128, DE 08.09.2021</div></div>", "i": 10350064}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 1.893, de 12 de julio de 2022, del Director Nacional de Aduanas, se reemplazan los anexos N&#xBA; 1 y N&#xBA; 2, de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1165325&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n 2.128, de 2021</a>, que fijan el Programa de Macroactividades con cada una de las sociedades administradoras para la implementaci&#xF3;n del nuevo Manual de Zona Franca.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).- </div><br></div>", "i": 10350065}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; Gustavo Poblete Morales, Director Nacional de Aduanas (S).</div><div class=\"p\"> </div></div>", "i": 10350066}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1893 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1893 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "PRORROGA ENTRADA EN VIGENCIA DE RESOLUCIÓN Nº 2.128, DE 08.09.2021", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2159121", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-07-12", "doble_articulado": false, "id_norma": "1178927", "numero_fuente": "43307", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-07-21", "vigencias": [{"desde": "2022-07-21", "hasta": "", "tipo