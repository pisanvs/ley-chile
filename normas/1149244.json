{"html": [{"t": "<div><div class=\"p\">MODIFICA FECHA DE ENTRADA EN VIGENCIA DE RESOLUCI&#xD3;N N&#xBA; 74, DE 2020</div></div>", "i": 10157006}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 104, de fecha 2 de septiembre de 2020, que modifica fecha de entrada en vigencia de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1147269&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n Ex. SII N&#xBA; 74, de fecha 2 de julio de 2020</a>, que instruye procedimiento para emitir boletas electr&#xF3;nicas y boletas no afectas y exentas electr&#xF3;nicas de ventas y servicios.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento est&#xE1; publicado en &quot;www.sii.cl&quot;.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10157007}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fernando Javier Barraza Luengo, Director Nacional.</div><div class=\"p\"> </div><br></div>", "i": 10157008}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "104 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-104 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA FECHA DE ENTRADA EN VIGENCIA DE RESOLUCIÓN Nº 74, DE 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1812703", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-09-02", "doble_articulado": false, "id_norma": "1149244", "numero_fuente": "42751", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-09-08", "vigencias": [{"desde": "2020-09-08", "hasta