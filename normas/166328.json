{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIA QUE INDICA </div><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 62.- Santiago, 24 de marzo de 2000. Vistos: Lo dispuesto en el art. 11 del decreto ley N&#xBA;2.974 de 1979.</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br></div>", "i": 6267661}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del decreto ley citado, X Regi&#xF3;n a la siguiente funcionaria:</div><br><div class=\"p\">- Olga Rosa Rogel Canio </div></div>", "i": 6267662}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Maximiliano Cox B., Director Nacional.</div><br></div>", "i": 6267663}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "62", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-62"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-03-24", "doble_articulado": false, "id_norma": "166328", "numero_fuente": "36644", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-19", "vigencias": [{"desde": "2000-04-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenc