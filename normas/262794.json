{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 7347909}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 464 de 17 de abril de 2007 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n parcial, conforme DL N&#xBA; 2.186 de 1978, del inmueble ubicado en Las Industrias N&#xBA; 5047, E. de la Cruz, presunto rol de aval&#xFA;o N&#xBA; 4.912-7, comuna de San Joaqu&#xED;n, de aparente dominio de Rodolfo S. Alfaro Sep&#xFA;lveda; correspondiente al Lote N&#xBA; 250, Tramo 4, del Proyecto Vial &quot;Habilitaci&#xF3;n Corredor de Transporte P&#xFA;blico Avda. Las Industrias&quot;. Comisi&#xF3;n integrada por Ver&#xF3;nica Olivier Valdebenito, arquitecto; Samantha Aldunce Dastres, ingeniero civil y Marcos C&#xE1;ceres Aravena, constructor civil, seg&#xFA;n informe de 11 de diciembre de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $41.933.300.- pagadera al contado.- </div></div>", "i": 7347910}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 7347911}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "464", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-464"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIVIENDA Y URBANIZACIÓN REGION METROPOLITANA"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-04-17", "doble_articulado": false, "id_norma": "262794", "numero_fuente": "38814", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-07-17", "vigencias": [{"desde": "20