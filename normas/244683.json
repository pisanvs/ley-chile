{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 15.042</div><br><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DO&#xD1;A AGUSTINA DE LAS MERCEDES NAVIA RIVEROS</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6551362}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Agustina de las Mercedes Navia Riveros una pensi&#xF3;n de E&#xBA; 50,- mensuales.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande esta ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda. </div></div>", "i": 6551363}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintid&#xF3;s de Noviembre de mil novecientos sesenta y dos.- JORGE ALESSANDRI RODRIGUEZ.- Luis Mackenna S.</div><br></div>", "i": 6551364}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "15042", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-15042"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DOÑA AGUSTINA DE LAS\nMERCEDES NAVIA RIVEROS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1962-11-22", "doble_articulado": false, "id_norma": "244683", "numero_fuente": "25413", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1962-12-10", "vigencias": [{"desde": "1962-12-10", "hasta": "", "tipo_version"