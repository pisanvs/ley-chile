{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 2,126.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6168736}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se concede, por gracia, a la se&#xF1;ora do&#xF1;a Fresia Prado, viuda del Ministro de la Corte de Apelaciones de Santiago, don C&#xE1;rlos E. Olivos, una asignacion, por una sola vez, equivalente a un a&#xF1;o de sueldo de que gozaba su esposo.</div><br></div>", "i": 6168737}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, cinco de setiembre de mil novecientos ocho.- Pedro Montt.- Eduardo Su&#xE1;rez Mujica.</div><br></div>", "i": 6168738}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2126", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2126"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1908-09-05", "doble_articulado": false, "id_norma": "136408", "numero_fuente": "9189", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1908-09-16", "vigencias": [{"desde": "1908-09-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1908-09-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1908-09-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul