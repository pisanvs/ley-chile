{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,929.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 7247965}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Los sueldos consultados en las partidas 2.&#xAA;, 3.&#xAA;, 4.&#xAA;, 5.&#xAA; i 8.&#xAA; del presupuesto del Ministerio de Hacienda, se pagar&#xE1;n durante el a&#xF1;o 1907, con un aumento o sobresueldo de cincuenta por ciento, siempre que no se hubieren modificado por lei especial en los dos &#xFA;ltimos a&#xF1;os.</div><br></div>", "i": 7247966}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, ocho de febrero de mil novecientos siete.- Pedro Montt.- R. Sotomayor.</div><br></div>", "i": 7247967}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1929", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1929"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-02-08", "doble_articulado": false, "id_norma": "135558", "numero_fuente": "8723", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-02-09", "vigencias": [{"desde": "1907-02-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-02-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1907-02-09", "fin_vigen