{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6294558}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.340, de 30 de mayo del 2000, se expropi&#xF3; el lote de terreno N&#xBA;132, superficie 180 m2, rol de aval&#xFA;o 5356-23, comuna de La Granja, para la obra Concesi&#xF3;n Inernacional Ruta 5, Tramo: Santiago-Talca. Sector A: Acceso Sur a Santiago, Regi&#xF3;n Metropolitana y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Carlos Enrique Jim&#xE9;nez Guti&#xE9;rrez, ascendente a la cantidad de $19.637.433.</div><br></div>", "i": 6294559}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6294560}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2340", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2340"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-30", "doble_articulado": false, "id_norma": "173700", "numero_fuente": "36728", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-01", "vigencias": [{"desde": "2000-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CAL", "fecha_ingreso": "2000-08-01", "fecha_version": "2000-08-01", "fecha_actualizacion_texto": "2000-08-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "",