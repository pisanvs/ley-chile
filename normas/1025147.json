{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA MODIFICACI&#xD3;N DE ESTATUTOS A &quot;SECURITIZADORA INTERAMERICANA S.A.&quot;</div></div>", "i": 9138129}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Certifico: Que por resoluci&#xF3;n exenta N&#xBA; 235, de fecha 14 de abril de 2011, de esta Superintendencia de Valores y Seguros, se autoriz&#xF3; la modificaci&#xF3;n de estatutos de &quot;Securitizadora Interamericana S.A.&quot;, acordada en la Junta Extraordinaria de Accionistas celebrada el 3 de diciembre de 2010, y reducida a escritura p&#xFA;blica el 6 de diciembre de 2010, en la 45&#xBA; notar&#xED;a de Santiago de don Ren&#xE9; Benavente Cash, consistente en cambiar el nombre a &quot;Securitizadora Sudamericana S.A.&quot;</div></div>", "i": 9138130}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de abril de 2011.- Carmen Undurraga Mart&#xED;nez, Secretario General.</div></div>", "i": 9138131}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "235 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-235 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "AUTORIZA MODIFICACIÓN DE ESTATUTOS A \"SECURITIZADORA INTERAMERICANA S.A.\"", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-04-14", "doble_articulado": false, "id_norma": "1025147", "numero_fuente": "39954", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-05-07", "vigencias": [{"desde": "2011-05-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-05-07", "fin_vigencia": ""}, "vig