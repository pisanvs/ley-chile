{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DELEGACI&#xD3;N DE FACULTADES</div><br></div>", "i": 9238155}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Delega facultades de otorgar certificados que se&#xF1;ala en funcionarios que indica.</div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta N&#xBA; 815, de 6 de febrero de 2012, de la XVI Direcci&#xF3;n Regional Metropolitana Santiago Sur, mediante la cual la Directora Regional de dicha unidad, delega en los funcionarios que indica la facultad de otorgar certificados que se&#xF1;ala, en materias de Impuesto a las Herencias, Asignaciones y Donaciones.</div><div class=\"p\">&nbsp; &nbsp;  Deroga, adem&#xE1;s, <a href=\"https://www.leychile.cl/Navegar?idNorma=1015788&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n Ex. N&#xBA; 4.029, de 15 de julio de 2010</a>, de la misma Direcci&#xF3;n Regional.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl).</div><br></div>", "i": 9238156, "v": ["MODIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "815 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-815 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "XVI DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO SUR"], "titulo_norma": "EXTRACTO DELEGACIÓN DE FACULTADES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO. NORMA SIN PROMULGACIÓN."], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-02-06", "doble_articulado": false, "id_norma": "1037406", "numero_fuente": "40191", "tipo_version": "3", "tipo_version_s": "