{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 429, DE 1993 </div></div>", "i": 5944503}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 429 de 16 de agosto de 1993 se ha aprobado un plan especial de estudio para la Educaci&#xF3;n B&#xE1;sica y Media Human&#xED;stico-Cient&#xED;fica, al Colegio Saint Paul&apos;s de Vi&#xF1;a del Mar, a partir del a&#xF1;o escolar 1993.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudios para las asignaturas que se indican del plan de estudios para la Educaci&#xF3;n B&#xE1;sica y programas de estudios para las asignaturas del Plan Com&#xFA;n y del Plan Electivo, Areas Human&#xED;stica y Cient&#xED;fica.</div><br></div>", "i": 5944504}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 9 de septiembre de 1993.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5944505}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "429", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-429"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 429, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "COLEGIO SAINT PAUL'S", "VI A DEL MAR", "QUINTA REGION", "PROGRAMAS ESTUDIOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-08-16", "doble_articulado": false, "id_norma": "21228", "numero_fuente": "34688", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-10-11", "vigencias": [{"desde": "1993-10-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-10-