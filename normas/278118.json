{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 840 EXENTA, DE 2005 </div></div>", "i": 6660178}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 813, de 06.10.2006, se modific&#xF3; la resoluci&#xF3;n exenta N&#xBA; 840/2005, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n, que otorg&#xF3; reconocimiento oficial a la Escuela de Conductores Profesionales denominada &quot;San Crist&#xF3;bal Ltda.&quot;, en el sentido de dejar establecido que el lugar donde impartir&#xE1; los cursos conducentes a la obtenci&#xF3;n de licencias profesionales ser&#xE1; en calle Galvarino Riveros N&#xBA; 1060, y la dictaci&#xF3;n de las clases de mec&#xE1;nica en calle Pablo Neruda sin n&#xFA;mero, en la comuna de Castro.</div><br></div>", "i": 6660179}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &#xC1;ngela Villarroel Mansilla, Secretaria Regional Ministerial Transportes y Telecomunicaciones Regi&#xF3;n de Los Lagos.</div><br></div>", "i": 6660180}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "813 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-813 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 840 EXENTA, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-10-06", "doble_articulado": false, "id_norma": "278118", "numero_fuente": "39168", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-09-22", "vigencias": [{"desde": "2008-09-2