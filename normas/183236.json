{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 743 EXENTA, DE 2001 </div><br></div>", "i": 6327760}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 743, de 1 de febrero del a&#xF1;o 2001, se ha aprobado al Colegio Coyancura, comuna de Las Condes, Regi&#xF3;n Metropolitana, un plan de estudio para Tercero y Cuarto a&#xF1;o de Ense&#xF1;anza Media Human&#xED;stico-Cient&#xED;fica, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se se&#xF1;alan en la presente resoluci&#xF3;n. </div></div>", "i": 6327761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de febrero de 2001.- Gabriel Ar&#xE1;nguiz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General (S). </div></div>", "i": 6327762}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "743 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-743 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 743 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-01", "doble_articulado": false, "id_norma": "183236", "numero_fuente": "36921", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-24", "vigencias": [{"desde": "2001-03-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-03-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": []