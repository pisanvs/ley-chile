{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8960160}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.217, de 19 de julio de 2010, de esta Subsecretar&#xED;a, autor&#xED;zase a la FEDERACI&#xD3;N PROVINCIAL DE PESCADORES ARTESANALES, BUZOS MARISCADORES, ALGUEROS Y ACTIVIDADES SIMILARES DEL SUR para iniciar actividades pesqueras de transformaci&#xF3;n, instalar y operar planta en Ruta T-350, Terminal Pesquero de Niebla, XIV Regi&#xF3;n, para elaborar en las l&#xED;neas de Cocido, Fresco-Enfriado, Congelado, Salado H&#xFA;medo, Ahumado, Conservas, Alga Seca y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div></div>", "i": 8960161}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de julio de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 8960162}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2217 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2217 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-07-19", "doble_articulado": false, "id_norma": "1016068", "numero_fuente": "39731", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-08-09", "vigencias": [{"desde": "2010-08-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-08-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-08-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_