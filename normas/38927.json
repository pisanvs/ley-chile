{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PRORROGA FUNCIONAMIENTO DE JUNTAS INSCRIPTORAS QUE SE INDICAN</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. O-439 exenta.- Visto: 1&#xB0; Que por resoluciones exentas del Servicio Electoral N&#xB0;s. 1.402, 1.649, 2.271 y 2.272, todas de 1991, y 33 de 1992, se crearon Juntas Inscriptoras de car&#xE1;cter temporal en diversas localidades, que es necesario mantener en funcionamiento; y</div><div class=\"p\">&nbsp; &nbsp; 2&#xB0; Lo dispuesto en los art&#xED;culos 13,22 y 93 letras i) y k) de la Ley N&#xB0; 18.556.</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 8929722}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Prorr&#xF3;gase el funcionamiento de las Juntas Inscriptoras de Tena&#xFA;n, Hueyusca, La Huerta, Huiscapi y La Pintana, hasta el cierre del per&#xED;odo de inscripciones electorales que sea procedente.</div><br></div>", "i": 8929723}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 8929724}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "439 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-439 EXENTA"}, {"tipo": "3", "numero": "O-439 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-O-439 EXENTA"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PRORROGA FUNCIONAMIENTO DE JUNTAS INSCRIPTORAS QUE SE INDICAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRORROGA", "JUNTA INSCRIPTORA", "COMUNA TENAUN", "COMUNA", "HUEYUSCA", "COMUNA HUERTA", "COMUNA HUISCAPI", "COMUNA PINTANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": fals