{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 10.818 EXENTA, DE 2005 </div></div>", "i": 6563621}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 10.818 de 30 de diciembre de 2005,se ha modificado la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 15.258, de 2004, que aprob&#xF3; planes y programas especiales de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media T&#xE9;cnico-Profesional al Liceo Polit&#xE9;cnico de Castro, provincia de Chilo&#xE9;, Regi&#xF3;n de Los Lagos.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los m&#xF3;dulos de &quot;Aplicaciones Inform&#xE1;ticas&quot; y &quot;Gesti&#xF3;n en Aprovisionamiento&quot; para 3er. a&#xF1;o de Ense&#xF1;anza Media e &quot;Investigaci&#xF3;n de Mercado&quot; para 4to. a&#xF1;o de Ense&#xF1;anza Media.</div><br></div>", "i": 6563622}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Santiago, 7 de marzo de 2006.- Xavier Vanni Cucurella, Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6563623}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10818 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-10818 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 10.818 EXENTA, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-30", "doble_articulado": false, "id_norma": "247892", "numero_fuente": "38411", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-11", "vigencias": [{"desde": "2006-03-11", "hasta": "", "tipo_version": "3