{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9287020}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.104, de 27 de julio de 2012, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xB0; 2.574 de 2011, de esta Subsecretar&#xED;a, correspondiente al &#xE1;rea de manejo Islas Huichas, Sector F, XI Regi&#xF3;n, del SINDICATO DE TRABAJADORES INDEPENDIENTE DE LA PESCA ARTESANAL NUEVO HORIZONTE DE PUERTO AGUIRRE, en virtud del art&#xED;culo 21 del DS N&#xB0; 355 de 1995, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n y lo dispuesto en la resoluci&#xF3;n extractada, cuyo texto &#xED;ntegro se encuentra publicado en la p&#xE1;gina web www.subpesca.cl.</div></div>", "i": 9287021}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de julio de 2012.- Felipe Palacio Rives, Subsecretario de Pesca (S).</div></div>", "i": 9287022}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2104 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2104 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-27", "doble_articulado": false, "id_norma": "1042643", "numero_fuente": "40329", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-08-04", "vigencias": [{"desde": "2012-08-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-08-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-08-04", "fin_vige