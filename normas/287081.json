{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 7077821}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 8,91% anual durante el mes de enero de 2009.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad con lo dispuesto en el N&#xBA;5 del Cap&#xED;tulo IV.B.8.1 del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de enero de 2009, fue de 8,69% anual. </div></div>", "i": 7077822}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de febrero de 2009.- Juan Esteban Laval Zald&#xED;var, Ministro de Fe (S).</div><br></div>", "i": 7077823}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-02-04", "doble_articulado": false, "id_norma": "287081", "numero_fuente": "39282", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-02-07", "vigencias": [{"desde": "2009-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-02-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV"