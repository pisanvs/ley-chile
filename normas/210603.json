{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6424663}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 979, de 14 de mayo de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; ALIMENTOS MARINOS S.A. para ampliar las actividades pesqueras extractivas con la nave &quot;Cacique I&quot;, por fuera de las 60 millas n&#xE1;uticas contadas desde las l&#xED;neas de base,&nbsp; con arrastre de media agua, sobre los siguientes recursos hidrobiol&#xF3;gicos: a) En la V a VII, y en la IX y X Regiones: Anchoveta, Caballa, Jurel, Sardina com&#xFA;n, Merluza de cola; b) En la V a VII y IX Regiones: Agujilla, Sardina espa&#xF1;ola; c) En la X Regi&#xF3;n: Cojinoba del norte.</div><br></div>", "i": 6424664}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de mayo de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6424665}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "979", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-979"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-05-14", "fecha_derogacion": "2013-01-19", "doble_articulado": false, "id_norma": "210603", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-05-26", "vigencias": [{"desde": "2013-01-19", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-05-26", "hasta": "2013-01-18", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2013-01-19", "fin_vigencia": ""}, "vig