{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10054300}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento&nbsp; MOP. N&#xBA; 793, de 26 de agosto de 2019,&nbsp; se dej&#xF3; sin efecto los numerales&nbsp; 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA;, del <a href=\"https://www.leychile.cl/Navegar?idNorma=1121187&amp;idParte=&amp;idVersion=\">Decreto Exento MOP. N&#xBA;562, de 28 de junio de 2018</a>, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n de los lotes de terreno N&#xBA;s 1 y 2, expropiados con motivo de la obra: &quot;Reposici&#xF3;n Puente G&#xF3;mez N&#xB0;3 en Ruta V-86 Comuna de Puerto Montt&quot;, Regi&#xF3;n de Los Lagos. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n fijada mediante tasaci&#xF3;n de 10 de agosto de 2015,&nbsp; ascendente a las cantidades $170.800, para el lote N&#xB0;1 y $90.000, para el lote N&#xB0;2.</div><br></div>", "i": 10054301}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "793 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-793 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1651460", "NORMA SIN PROMULGACIÓN", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-08-26", "doble_articulado": false, "id_norma": "1136185", "numero_fuente": "42456", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-09-16", "vigencias