{"html": [{"t": "<div><div class=\"p\">LEY NUM. 20.127</div><br><div class=\"p\">CONCEDE LA NACIONALIDAD CHILENA A DON HORST PAULMANN </div><div class=\"p\">&nbsp; &nbsp;  Teniendo presente que el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 8374548}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese la nacionalidad chilena por especial gracia al empresario alem&#xE1;n don Horst Paulmann Kemna.</div><br></div>", "i": 8374549}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de octubre de 2006.- MICHELLE BACHELET JERIA, Presidenta de la Rep&#xFA;blica.- Belisario Velasco Baraona, Ministro del Interior.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda Atte. a Ud., Felipe Harboe Bascu&#xF1;&#xE1;n, Subsecretario del Interior.</div><br><br><br></div>", "i": 8374550}], "proyectos": [{"categoria": "Proyecto original", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=4093-17", "informacion": "Concede la nacionalidad chilena a don Horst Paulmann", "nroBoletin": "4093-17"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "20127", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-20127"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARIA DEL INTERIOR"], "titulo_norma": "CONCEDE LA NACIONALIDAD CHILENA A DON HORST PAULMANN", "fuente": "Diario Oficial", "resumenes": [], "materias": ["Nacionalidad", "Horst Paulmann", "Ley no. 20.127"], "terminos_libres": ["NACIONALIDAD CHILENA", "HORST PAULMANN"], "categorias_norma": [], "nombres_uso_comun": [], "paises_t