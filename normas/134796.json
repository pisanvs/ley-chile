{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,382.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6163473}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se concede una subvencion estraordinaria de diez mil pesos a la Sociedad Agr&#xED;cola del Sur para la realizacion de una Esposicion Agr&#xED;cola que deber&#xE1; llevarse a efecto en el mes de diciembre pr&#xF3;ximo. </div></div>", "i": 6163474}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de noviembre de 1900.- FEDERICO ERRAZURIZ.- M. A. Covarrubias.</div><br></div>", "i": 6163475}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1382", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1382"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-11-16", "doble_articulado": false, "id_norma": "134796", "numero_fuente": "6747", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-11-20", "vigencias": [{"desde": "1900-11-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-11-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1900-11-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "I