{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6445853}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.367, de 8 de octubre de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; PESQUERA EL GOLFO S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Mait&#xE9;n&quot;, en el Archipi&#xE9;lago de Juan Fern&#xE1;ndez, Isla de Pascua, Islas Sala y G&#xF3;mez e Islas Desventuradas, por fuera del &#xE1;rea de reserva artesanal, con palangre, donde podr&#xE1; capturar los recursos que a continuaci&#xF3;n se se&#xF1;alan: At&#xFA;n aleta amarilla, At&#xFA;n aleta larga, At&#xFA;n ojos grandes, Bonito, Marrajo o tibur&#xF3;n, Tollo, At&#xFA;n chauchera, Marlin rayado, At&#xFA;n aleta azul, Azulejo, Marlin trompa corta, Marlin negro, Marlin azul o zuncho.</div><br></div>", "i": 6445854}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de octubre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6445855}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2367", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2367"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-10-08", "fecha_derogacion": "2004-11-30", "doble_articulado": false, "id_norma": "216436", "numero_fuente": "37698", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-10-30", "vigencias": [{"desde": "2004-11-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-1