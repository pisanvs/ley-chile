{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6339852}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.212, de 14 de junio de 2001, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BIO BIO S.A. para ampliar las actividades pesqueras extractivas con la nave &quot;Biomar IV&quot;, en el &#xE1;rea mar&#xED;tima que se indica, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar con arrastre los siguientes recursos hidrobiol&#xF3;gicos: a) En el &#xE1;rea mar&#xED;tima comprendida entre el l&#xED;mite Norte de la IV Regi&#xF3;n y el paralelo 41&#xB0;28,6&apos; L.S.: Br&#xF3;tula, Cojinoba del norte y Palometa;</div><div class=\"p\">b) En el &#xE1;rea mar&#xED;tima comprendida entre el l&#xED;mite Norte de la IX Regi&#xF3;n y el paralelo 41&#xB0;28,6&apos; L.S.: Camar&#xF3;n nailon, Langostino amarillo y Langostino colorado.</div><br></div>", "i": 6339853}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de junio de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6339854}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1212", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1212"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-06-14", "fecha_derogacion": "2016-11-23", "doble_articulado": false, "id_norma": "186830", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2001-06-23", "vigencias": [{"desde": "2016-11-23", "hasta": "", "tipo_version": "2", "tipo_version_s"