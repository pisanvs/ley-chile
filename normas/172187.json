{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 161, DE 1987 </div></div>", "i": 8930623}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se ha procedido a aprobar un plan especial de estudio para adultos al Instituto Nacional de Capacitaci&#xF3;n Profesional (INACAP).</div><div class=\"p\">&nbsp; &nbsp;  El plan aprobado se desarrollar&#xE1; en cuatro per&#xED;odos lectivos, denominados semestres.</div><div class=\"p\">&nbsp; &nbsp;  Los requisitos de ingreso, normas de evaluaci&#xF3;n y promoci&#xF3;n se se&#xF1;alan en el decreto.</div><br></div>", "i": 8930624}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 8930625}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "161 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-161 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 161, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO. SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "172187", "numero_fuente": "32824", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-20", "vigencias": [{"desde": "1987-07-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-07-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresado_por": "CAL", "