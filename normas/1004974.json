{"html": [{"t": "<div><br><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A V&#xCD;CTOR REICHERT SCHLEYER</div><br></div>", "i": 8765961}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional del SII, por resoluci&#xF3;n ex. N&#xBA;305, de 30 de junio de 2009, deja sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=122045&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n ex. N&#xBA;278 de fecha 07.07.1998</a>, que excepcion&#xF3; del r&#xE9;gimen de cambio de sujeto de derecho del Impuesto al Valor Agregado en las operaciones de venta de ganado vivo, a contar del primero del mes siguiente a la fecha de esta publicaci&#xF3;n al contribuyente V&#xED;ctor Reichert Schleyer, RUT N&#xBA;1.514.272-3, conforme a lo establecido en la res. ex. N&#xBA;3.721 de fecha 28.07.2000, de la Direcci&#xF3;n Nacional del Servicio, publicada en el Diario Oficial del d&#xED;a 01.08.2000.- </div><br></div>", "i": 8765962, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Cornejo C&#xE1;ceres, Director Regional.</div><br></div>", "i": 8765963}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "305 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-305 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A VÍCTOR REICHERT SCHLEYER", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-06-30", "doble_articulado": false, "id_norma": "1004974", "numero_fuente": "39434", "tipo_version": "3", "tipo_version_s": "Única", "fecha_pu