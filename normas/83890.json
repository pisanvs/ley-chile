{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8315675}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.643, de 1 de diciembre de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case las Resoluciones N&#xBA; 3, de 1986 y N&#xBA; 961 de 1991, ambas de esta Subsecretar&#xED;a, que autorizaron a Pesquera Mar Profundo Ltda., hoy&nbsp; PESQUERA MAR PROFUNDO S.A., a desarrollar actividades pesqueras con la nave &quot;G&#xE9;nesis&quot;, en el sentido de actualizar las caracter&#xED;sticas n&#xE1;uticas de esta &#xFA;ltima, en los t&#xE9;rminos que se indican:</div><br><div class=\"p\">Nombre&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  &quot;G&#xE9;nesis&quot;</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2454</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp;  32,5 m.</div><div class=\"p\">T.R.G. (Internacional)&nbsp;  378 t.</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; 470,2 m3.</div><div class=\"p\">Arte de pesca&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Cerco</div><br></div>", "i": 8315676}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de diciembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8315677}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1643", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1643"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA MAR PROFUNDO S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["E