{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6483067}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 60 de 20 de mayo de 2004, Serviu</div><div class=\"p\">Regi&#xF3;n Valpara&#xED;so dispuso expropiaci&#xF3;n parcial, conforme</div><div class=\"p\">art&#xED;culo 87 Ley 8.946 y decreto ley 2.186, de 1978, de inmueble ubicado en calle Limache 1796, rol aval&#xFA;o 690-007, comuna de Vi&#xF1;a del Mar, de dominio de Carlos Oliva Zamora. Comisi&#xF3;n Tasadora integrada por Sres. Osvaldo Mu&#xF1;oz Quintana, arquitecto, Alvaro Verdejo Vidal ingeniero constructor, y Pablo Caria Giurici, constructor civil, seg&#xFA;n informe de fecha 10 de octubre de 2003 fij&#xF3; monto provisional indemnizaci&#xF3;n en $2.470.000.- que ser&#xE1; pagada al contado.-</div><br></div>", "i": 6483068}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Director Serviu Regi&#xF3;n Valpara&#xED;so.</div><br></div>", "i": 6483069}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "60", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-60"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAISO"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-20", "doble_articulado": false, "id_norma": "226323", "numero_fuente": "37885", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-15", "vigencias": [{"desde": "2004-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-06