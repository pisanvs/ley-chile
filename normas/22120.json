{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PENSION Lei n&#xFA;m. 266.-Santiago, a 4 de Febrero de 1895.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se declara que la familia de don Timoleon Lorca, muerto al servicio del pais, est&#xE1; comprendida en las leyes de 22 de Diciembre de 1881 i de 9 de Enero de 1892, consider&#xE1;ndose a don Timoleon Lorca como capitan de Ej&#xE9;rcito muerto en accion de guerra.</div><br><br></div>", "i": 5947347}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORJE MONTT:_ C&#xE1;rlos Rivera Jofr&#xE9;.</div><br></div>", "i": 5947348}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "266", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-266"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TIMOLEON LORCA", "FAMILIA", "BENEFICIOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-02-04", "doble_articulado": false, "id_norma": "22120", "numero_fuente": "5034", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-02-07", "vigencias": [{"desde": "1895-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1895-02-07", "fin_vigencia": "", "tipo_version": "3"