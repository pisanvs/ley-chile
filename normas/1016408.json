{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.511 EXENTA, DE 2010</div></div>", "i": 8967776}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta que se indica del Ministerio de Educaci&#xF3;n, se registra a contar del a&#xF1;o 2010, el cambio de nombre de la Universidad Mar&#xED;tima de Chile por Universidad Los Leones.</div><div class=\"p\">&nbsp; &nbsp;  Se declara, que para todos los efectos legales la Universidad Los Leones es la continuadora legal de la Universidad Mar&#xED;tima de Chile.</div></div>", "i": 8967777}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de agosto de 2010.- Fernando Rojas Ochagav&#xED;a, Subsecretario de Educaci&#xF3;n.</div></div>", "i": 8967778}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3511 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3511 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.511 EXENTA, DE 2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-08-16", "doble_articulado": false, "id_norma": "1016408", "numero_fuente": "39741", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-08-20", "vigencias": [{"desde": "2010-08-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-08-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-08-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2010-08-20", "fecha_version": "2010-08-20", "actualizado_por