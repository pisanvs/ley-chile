{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; MODIFICA RESOLUCION QUE INDICA</div><br></div>", "i": 8340015}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 876, de 23 de Agosto de 1988, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 4&#xB0; de la resoluci&#xF3;n No. 543, de 1988, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Pesquera Loa Norte S.A., domiciliada en Santiago, para desarrollar actividades pesqueras extractivas y de transformaci&#xF3;n, en orden a excluir el recurso Cojinoba del procesamiento en las l&#xED;neas de elaboraci&#xF3;n de harina y aceite de pescado, de conformidad al DS No. 316, de 1985, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8340016}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de Agosto de 1988.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8340017}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "876", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-876"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-23", "doble_articulado": false, "id_norma": "130965", "numero_fuente": "33166", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-09-07", "vigencias": [{"desde": "1988-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-09-07", "fin_vig