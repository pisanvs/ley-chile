{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 598 EXENTO, DE 2008</div></div>", "i": 8527328}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 598 de 10 de marzo de 2008, se ha modificado el decreto exento de Educaci&#xF3;n N&#xBA; 403, de 1999, que aprob&#xF3; planes y programas de estudio biling&#xFC;es para los cursos de 1&#xBA; a 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica al Colegio &quot;Anglo American International School&quot;, comuna de Lo Barnechea, de Santiago, en el sentido de sustituir sus planes de estudio por los que se indican en el presente decreto.</div></div>", "i": 8527329}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de abril de 2008.- Cristi&#xE1;n Mart&#xED;nez Ahumada, Subsecretario de Educaci&#xF3;n.</div></div>", "i": 8527330}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "598 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-598 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 598 EXENTO, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-03-10", "doble_articulado": false, "id_norma": "1001110", "numero_fuente": "39335", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-04-13", "vigencias": [{"desde": "2009-04-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-04-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-04-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICA