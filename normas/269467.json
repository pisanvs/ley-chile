{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7364946}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 472, de 15 de febrero de 2008 de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD COMERCIAL EXPROMAR LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, para operar una planta ubicada en Elena Vera Mu&#xF1;oz N&#xBA; 644, Ancud, Chilo&#xE9;, para elaborar en l&#xED;neas de proceso fresco refrigerado y congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1544 de 2006, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 7364947}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de febrero de 2008.- Mar&#xED;a Angela Barbieri Bellolio, Subsecretaria de Pesca (S). </div></div>", "i": 7364948}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "472 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-472 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2008-02-15", "fecha_derogacion": "2009-04-06", "doble_articulado": false, "id_norma": "269467", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2008-02-26", "vigencias": [{"desde": "2009-04-06", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2008-02-26", "hasta": "2009-04-05", "tipo_version": "0", "tipo_version_s": "Texto Ori