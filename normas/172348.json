{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 1.815</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Comit&#xE9; Ejecutivo de este Banco Central de Chile en su Sesi&#xF3;n No. 1.815, celebrada el 26 de agosto de 1987, adopt&#xF3; el siguiente acuerdo:</div><br></div>", "i": 6287245}, {"t": "<div><div class=\"p\">1815-08-870826 - Modifica Cap&#xED;tulo III.F.4 del Compendio de Normas Financieras.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; reemplazar la letra a) del n&#xFA;mero 5 del Cap&#xED;tulo III.F.4 &quot;Inversiones de los Fondos de Pensiones&quot; del Compendio de Normas Financieras, por la siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;a) Cero coma ocho (0,8),&quot; </div></div>", "i": 6287246}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de agosto de 1987.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6287247}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1815", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1815"}, {"tipo": "5", "numero": "1815-08", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1815-08"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDO ADOPTADO POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 1.815", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-26", "doble_articulado": false, "id_norma": "172348", "numero_fuente": "32857", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-28", "vigencias": [{"desde": "1987-08-28", "hasta": "", "t