{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7430045}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta No. 175 de 09 de marzo de 1990 del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriz&#xF3; al se&#xF1;or Arnoldo Vivar Carrasco, para efectuar servicio internacional de transporte terrestre de pasajeros entre Futaleuf&#xFA; (Chile) y Esquel (Argentina) por el Paso R&#xED;o Futaleuf&#xFA; con una frecuencia semanal, de ida y vuelta.</div><br></div>", "i": 7430046}, {"t": "<div><div class=\"p\">- Sergio Gonz&#xE1;lez Tagle, Subsecretario de Transportes. </div></div>", "i": 7430047}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "175 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-175 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-09", "doble_articulado": false, "id_norma": "81634", "numero_fuente": "33800", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-10-23", "vigencias": [{"desde": "1990-10-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-10-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-10-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1997-12-29", "fecha_version": "1990-10-23", "fecha_actualizacion_texto": "1990-10-23", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura