{"html": [{"t": "<div><br><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA</div></div>", "i": 9728563}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional de Temuco del SII, por resoluci&#xF3;n Ex N&#xBA; 77316062683, de fecha 25/08/2016, deja sin efecto la resoluci&#xF3;n que otorga la calidad de agente retenedor de cambio de sujeto de derecho del Impuesto al Valor Agregado en las operaciones de venta de trigo, a contar de la fecha de la publicaci&#xF3;n de su extracto en el Diario Oficial al contribuyente Jos&#xE9; Emiliano Torres Careaga, RUT N&#xBA; 6.632.013-8, conforme a lo establecido en la <a href=\"https://www.leychile.cl/Navegar?idNorma=1021618&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n Ex. N&#xBA; 192, de fecha 24.12.2010</a>, de la Direcci&#xF3;n Nacional del Servicio de Impuestos Internos.-</div><br><br></div>", "i": 9728564, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Carlos Fuentes Salvo, Director Regional (S).</div></div>", "i": 9728565}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "77316062683 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-77316062683 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1110478; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-08-25", "doble_articulado": false, "id_norma": "1094635", "numero_fuente": "41556", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-09-10", "vigencias": [{"desde": "2016-09-10", "hasta": "", "tip