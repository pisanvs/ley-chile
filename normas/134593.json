{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,280.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 8343305}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese al jefe de la oficina telegr&#xE1;fica de Peumo, don Jos&#xE9; Manuel Galaf&#xE9;, el derecho de jubilar con el sueldo &#xED;ntegro asignado a su empleo, en compensacion de la cesion que hace al Estado de su invento del aparato denominado &quot;Traslador autom&#xE1;tico.&quot; </div></div>", "i": 8343306}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-</div><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de diciembre de 1899.- FEDERICO ERRAZURIZ.- El&#xED;as Fern&#xE1;ndez A.</div><br></div>", "i": 8343307}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1280", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1280"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-12-15", "doble_articulado": false, "id_norma": "134593", "numero_fuente": "6473", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-12-15", "vigencias": [{"desde": "1899-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-12-15", "fin_vigencia": "", "tipo_version": "3"}], "even