{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6282508}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.456, de 17 de abril del 2000, se expropiaron los lotes de terreno N&#xBA;s. 3, 22, 25, 35 y 37, superficies 1.068, 430, 48, 22 y 532 M2., respectivamente, roles de aval&#xFA;os 39-1, 234-2, 230-13, 230-12 y 234-20, comuna de Monte Patria, para la obra Camino Ruta D-597, Monte Patria - Car&#xE9;n, sector Juntas-Car&#xE9;n, Tramo Km. 8.260,00 a Km. 30.065,19 y se acord&#xF3; precio de las indemnizaciones con sus propietarios Luis Alberto Tapia Ordenes, Manuel Jes&#xFA;s Alucema L&#xF3;pez, Mery del Rosario Vega Vega y Gonzalo del Carmen Carmona Jopia, ascendentes a las cantidades de $1.551.538, lote N&#xBA;3; $1.603.846, lotes N&#xBA;s 22 y 25;</div><div class=\"p\">$290.926, lote N&#xBA;35, y $976.146, lote N&#xBA;37.- </div></div>", "i": 6282509}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6282510}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1456", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1456"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-17", "doble_articulado": false, "id_norma": "171073", "numero_fuente": "36690", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-15", "vigencias": [{"desde": "2000-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig