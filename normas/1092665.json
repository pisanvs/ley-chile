{"html": [{"t": "<div><br><div class=\"p\">TRIBUTACI&#xD3;N INTERNACIONAL</div></div>", "i": 9715720}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de Circular del Servicio de Impuestos Internos N&#xBA; 48, de fecha 12 de julio de 2016, que imparte instrucciones sobre los art&#xED;culos 41 A, 41 B y 41 C de la Ley sobre Impuesto a la Renta, de acuerdo a lo dispuesto en las leyes N&#xBA;s 20.780 y N&#xBA; 20.899.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta circular est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en el mes de julio de 2016.</div></div>", "i": 9715721}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "48", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-48"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "TRIBUTACIÓN INTERNACIONAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1043226; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-07-12", "doble_articulado": false, "id_norma": "1092665", "numero_fuente": "41511", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-07-19", "vigencias": [{"desde": "2016-07-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2016-07-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2016-07-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "1795", "fec