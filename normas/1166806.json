{"html": [{"t": "<div><div class=\"p\">DISPONE SUSPENSI&#xD3;N DE LA EJECUCI&#xD3;N DE RESOLUCIONES EXENTAS QUE INDICA</div></div>", "i": 10277518}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.775, de 13 de octubre de 2021, de esta Subsecretar&#xED;a, se dispone la suspensi&#xF3;n de la ejecuci&#xF3;n de las resoluciones exentas N&#xBA; 2.504 de 2020, N&#xBA; 1.181 y N&#xBA; E-2021-316, ambas de 2021, todas de la Subsecretar&#xED;a de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10277519}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de octubre de 2021.- M&#xF3;nica Orellana Vald&#xE9;s, Subsecretaria de Pesca y Acuicultura (S).</div><br></div>", "i": 10277520}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2775 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2775 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DISPONE SUSPENSIÓN DE LA EJECUCIÓN DE RESOLUCIONES EXENTAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2026493", "EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2021-10-13", "fecha_derogacion": "2023-01-27", "doble_articulado": false, "id_norma": "1166806", "numero_fuente": "43082", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2021-10-20", "vigencias": [{"de