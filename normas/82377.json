{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8313574}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 1.044, de 27 de Agosto de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n No. 1493, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a do&#xF1;a Sandra Inzunza Betanzo, R.U.T. No. 7.701.858-1, domiciliada en la localidad de Nal, Sector Rural, Comuna de Ancud, Provincia de Chilo&#xE9;, para iniciar actividades, en el sentido de se&#xF1;alar que el establecimiento de cultivo del recurso alga Gracilaria, se encuentra ubicado en el sector Nal, Pen&#xED;nsula de Lacuy, Comuna de Ancud, Provincia de Chilo&#xE9;, X Regi&#xF3;n.- </div></div>", "i": 8313575}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 27 de Agosto de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8313576}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1044", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1044"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-08-27", "doble_articulado": false, "id_norma": "82377", "numero_fuente": "33760", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-09-01", "vigencias": [{"desde": "1990-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_