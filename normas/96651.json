{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.201 EXENTO, DE 1997 </div><br><br></div>", "i": 7231147}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.201 de fecha 19 de diciembre de 1997 del Ministerio de Educaci&#xF3;n, se reemplazar&#xE1;n a contar del a&#xF1;o 1998 las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica Centro de Estudios Navieros Concepci&#xF3;n, que fueran aprobadas por decreto exento de Educaci&#xF3;n N&#xBA; 2.368 de fecha 30 de agosto de 1989. </div></div>", "i": 7231148}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de enero de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7231149}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1201 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1201 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.201 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO DE FORMACION TECNICA CENTRO DE ESTUDIOS NAVIEROS CONCEPCION", "EVALUACION", "PROMOCION", "TITULACION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-12-19", "fecha_derogacion": "2004-04-13", "doble_articulado": false, "id_norma": "96651", "numero_fuente": "35993", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-02-17", "vigencias": [{"desde": "2004-04-13", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-02-17", "hasta": "2004-04-12", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia":