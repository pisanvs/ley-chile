{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;833 EXENTO, DE 2005 </div></div>", "i": 6533260}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;833 de fecha 23 de junio de 2005, de Educaci&#xF3;n, se modifica Certificado N&#xBA;06/0590 de 20 de mayo de 1991 mediante el cual el Ministerio de Educaci&#xF3;n autoriz&#xF3; la carrera de Ingenier&#xED;a de Ejecuci&#xF3;n en Inform&#xE1;tica examinada por la Universidad de Santiago de Chile para ser impartida por el Instituto Profesional de Ciencias de la Computaci&#xF3;n Acuario Data. La denominaci&#xF3;n correcta es Ingenier&#xED;a de Ejecuci&#xF3;n en Computaci&#xF3;n e Inform&#xE1;tica.</div><br></div>", "i": 6533261}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de julio de 2005.- Pedro Montt Leiva, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6533262}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "833 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-833 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº833 EXENTO, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-23", "doble_articulado": false, "id_norma": "240179", "numero_fuente": "38213", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-18", "vigencias": [{"desde": "2005-07-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-07-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":