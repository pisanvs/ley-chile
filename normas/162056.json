{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;456 EXENTO, DE 1999</div><br><br></div>", "i": 6254164}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA;456, de 29 de diciembre de 1999, se ha aprobado al Colegio Alem&#xE1;n de Valpara&#xED;so, las adecuaciones de Planes y Programas Especiales de Estudio aprobados para 6&#xBA;, 7&#xBA; y 8&#xBA; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica, las que ser&#xE1;n aplicadas conforme a la gradualidad establecida en el decreto supremo N&#xBA;40 de 1996 y sus modificaciones.</div><br></div>", "i": 6254165}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de marzo de 2000.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6254166}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "456 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-456 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº456 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-29", "doble_articulado": false, "id_norma": "162056", "numero_fuente": "36620", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-22", "vigencias": [{"desde": "2000-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JCT", "fecha_ing