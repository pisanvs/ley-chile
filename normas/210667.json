{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7299771}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.028, de 20 de mayo de 2003, de</div><div class=\"p\">esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la</div><div class=\"p\">resoluci&#xF3;n N&#xBA; 1.600, de 1997, de esta Subsecretar&#xED;a,</div><div class=\"p\">s&#xF3;lo en cuanto autoriz&#xF3; a LUIS HUMBERTO NOVOA SANCHEZ</div><div class=\"p\">para realizar actividades pesqueras extractivas con la</div><div class=\"p\">nave &quot;Estarka I&quot;, respecto del recurso Bacalao de</div><div class=\"p\">profundidad en el &#xE1;rea mar&#xED;tima comprendida entre la V</div><div class=\"p\">Regi&#xF3;n (Punta Liles) y el paralelo 47&#xBA; L.S., por</div><div class=\"p\">incurrir en causal de caducidad establecida en el</div><div class=\"p\">art&#xED;culo 143 letra b), de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7299772}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de mayo de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7299773}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1028", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1028"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-05-20", "doble_articulado": false, "id_norma": "210667", "numero_fuente": "37569", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-05-28", "vigencias": [{"desde": "2003-05-28", "hasta": "", "tipo_ve