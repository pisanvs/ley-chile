{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6359858}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA;54, de 25 de febrero de 1993, se orden&#xF3; la expropiaci&#xF3;n y aprob&#xF3; el plano y cuadro de expropiaci&#xF3;n del lote de terreno N&#xBA;26, y por decreto MOP N&#xBA;1588, de 12 de octubre de 2001, se autoriz&#xF3; el valor de la consignaci&#xF3;n provisional de la expropiaci&#xF3;n por la v&#xED;a judicial, en la cantidad de $237.500 necesario para la ejecuci&#xF3;n de la obra &quot;Camino Olivar-Coinco Curepto, Km. 3.460.00 a Km. 17.715.00&quot;. El pago de la indemnizaci&#xF3;n se efectuar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA;2186, de 1978.- </div></div>", "i": 6359859}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6359860}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "54 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-54 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-02-25", "doble_articulado": false, "id_norma": "192184", "numero_fuente": "37125", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-12-01", "vigencias": [{"desde": "2001-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-12-01", "fin_vigencia": "", "tipo_ve