{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; El D.F.L. que llevaba este n&#xFA;mero fu&#xE9; publicado en el &quot;Diario Oficial&quot; N&#xB0; 22.603, de 22 de julio de 1953. No obstante, su publicaci&#xF3;n y, por lo tanto, el D.F.L. mismo, carece de valor legal por cuanto se public&#xF3; sin que se hubiera tomado raz&#xF3;n por la Contralor&#xED;a General. (V&#xE9;anse: Oficios 53.643, de 28 de octubre de 1953, y 56.269, de 7 de noviembre de 1953, dirigidos por el se&#xF1;or Contralor General a los se&#xF1;ores Ministro de Hacienda y Presidente de la C&#xE1;mara de Diputados, respectivamente, y &quot;Diario Oficial&quot; N&#xB0; 22.697, de 13 de noviembre de 1953).</div><br><div class=\"np\" id=\"np0\"><a href=\"#rnp0\">NOTA:&nbsp;  1</a> <br>&nbsp; &nbsp;  Ver t&#xED;tulo de este DFL.<br></div></div>", "i": 9033152}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "13", "numero": "121", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-121"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "4686", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1953-07-22", "vigencias": [{"desde": "1984-10-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1984-10-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1984-10-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "fecha_version": "1984-10-27", "fecha_actualizacion_texto": "1984-10-27", "tipo_tratado": ""}, "alertas": [], "alerta_global": ""