{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO No. 66 EXENTO, DE 1988 </div></div>", "i": 7246200}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 66, de 04 de abril de 1988 se ha aprobado para el Liceo B No.</div><div class=\"p\">2, de la comuna de Diego de Almagro, -provincia de Cha&#xF1;aral, III Regi&#xF3;n de Atacama, planes y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico - Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar de 1988 y hasta el a&#xF1;o escolar de 1989, en la Rama Industrial, Especialidades de: Instalaciones Sanitarias, Minas con Menci&#xF3;n en Fundici&#xF3;n y Minas con Menci&#xF3;n en Mineralurgia.</div><br></div>", "i": 7246201}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de Abril de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7246202}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "66 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-66 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO No. 66 EXENTO, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-04-04", "doble_articulado": false, "id_norma": "132592", "numero_fuente": "33056", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-04-27", "vigencias": [{"desde": "1988-04-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-04-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-04