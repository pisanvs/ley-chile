{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6250676}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;289, de 31 de enero del 2000, se expropi&#xF3; el lote de terreno N&#xBA;43, superficie 810,0 m2., rol de aval&#xFA;o 3213-441, comuna de Padre Las Casas, para la obra Concesi&#xF3;n Internacional Ruta 5, Tramo Collipulli-Temuco, Novena Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Vicariato Apost&#xF3;lico de la Araucan&#xED;a, ascendente a la cantidad de $13.727.529. </div></div>", "i": 6250677}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6250678}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "289", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-289"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-31", "doble_articulado": false, "id_norma": "160991", "numero_fuente": "36614", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-15", "vigencias": [{"desde": "2000-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-03-15", "fecha_version": "2000-03-15", "fecha_actualizacion_texto": "2000-03-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabez