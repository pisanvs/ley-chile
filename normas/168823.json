{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 654, DE 1990 </div></div>", "i": 6275777}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 0654 de fecha 26.12.90, la Secretar&#xED;a Ministerial de Educaci&#xF3;n de la Regi&#xF3;n de Antofagasta, ha aprobado Plan y Programa de Estudio de 3&#xB0; a 4&#xB0; a&#xF1;o de la Educaci&#xF3;n Media T&#xE9;cnico Profesional, para el Liceo Polit&#xE9;cnico C-3 Diego Portales Palazuelos de Tocopilla.</div><div class=\"p\">&nbsp; &nbsp;  En la especialidad de Atenci&#xF3;n de P&#xE1;rvulos.</div><div class=\"p\">&nbsp; &nbsp;  El Plan y Programa aprobado tendr&#xE1; vigencia a contar del a&#xF1;o 1991 y hasta el a&#xF1;o 1992.</div><br></div>", "i": 6275778}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Antofagasta, diciembre de 1990.- Guillermo Mu&#xF1;oz Cruz, Secretario Ministerial Educaci&#xF3;n Regi&#xF3;n de Antofagasta. </div></div>", "i": 6275779}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "654 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-654 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SECRETARÍA REGIONAL MINISTERIAL II REGIÓN DE ANTOFAGASTA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 654, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-26", "doble_articulado": false, "id_norma": "168823", "numero_fuente": "33948", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-20", "vigencias": [{"desde": "1991-04-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-04-20", "fin_vigencia": ""}, "vigenc