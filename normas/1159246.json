{"html": [{"t": "<div><div class=\"p\">COLEJIO DE SANTIAGO.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Marzo 23 de 1829.</div></div>", "i": 10253093}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Atendiendo a las reiteradas instancias de los empresarios del Colejio de Santiago porque el Gobierno provea los cinco lugares de alumnos que oficiosa y gratuitamente le han cedido, vengo en nombrar para que los ocupen, a los j&#xF3;venes-D. Domingo Villarreal, D. Jos&#xE9; Mar&#xED;a Alvarez, D. Cosme Barrios, D. Vicente Gaete y D. Jos&#xE9; Agustin Verdugo.</div></div>", "i": 10253094}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Comun&#xED;quese a quienes corresponda.</div><div class=\"p\">&nbsp; &nbsp;  R&#xFA;brica de S.E.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Rodr&#xED;guez</div></div>", "i": 10253095}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "COLEJIO DE SANTIAGO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1829-03-23", "doble_articulado": false, "id_norma": "1159246", "numero_fuente": "1829", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1829-03-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1829-03-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1829-03-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-07-19", "fecha_version": "182