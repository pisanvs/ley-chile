{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA N&#xB0; 3.430, DE 1988 </div><br><br></div>", "i": 9050029}, {"t": "<div><div class=\"p\">Extracto de la resoluci&#xF3;n exenta N&#xB0; 3.430 de fecha 21 de diciembre de 1988, de la Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica, se insert&#xF3; en la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xB0; 1.746 de 1988 del Centro de Formaci&#xF3;n T&#xE9;cnica CREP de Quilpu&#xE9;, las adecuaciones introducidas a las carreras de Asistente de Educador de P&#xE1;rvulos, Programaci&#xF3;n de Computadores y Secretariado Ejecutivo con menci&#xF3;n Computaci&#xF3;n, las que podr&#xE1;n aplicarse a contar del a&#xF1;o 1988.-</div><br></div>", "i": 9050030}, {"t": "<div><div class=\"p\">Santiago, 15 de Febrero de 1989.- Paulina Dittborn Cordua, Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 9050031}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3430 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3430 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N° 3.430, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1989-12-21", "fecha_derogacion": "2002-08-03", "doble_articulado": false, "id_norma": "95451", "numero_fuente": "33310", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1989-02-28", "vigencias": [{"desde": "2002-08-03", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1989-02-28", "hasta": "2002-08-02", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_v