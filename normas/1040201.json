{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9258048}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.243, de 11 de mayo de 2012, de esta Subsecretar&#xED;a, rectif&#xED;quese el extracto de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1039910&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 1.121, de 2012</a>, que otorg&#xF3; a CAMANCHACA PESCA SUR S.A. un permiso extraordinario de pesca para la unidad de pesquer&#xED;a del recurso hidrobiol&#xF3;gico Langostino amarillo, en el sentido de reemplazar su frase final por la siguiente: &quot;D&#xE9;jase sin efecto resoluci&#xF3;n exenta N&#xB0; 1.254, de 2011, de esta Subsecretar&#xED;a de Pesca&quot;.</div><br></div>", "i": 9258049, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de mayo de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9258050}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1243 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1243 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-11", "doble_articulado": false, "id_norma": "1040201", "numero_fuente": "40265", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-05-18", "vigencias": [{"desde": "2012-05-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-05-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-05-1