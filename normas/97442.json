{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 394 EXENTO, DE 1998 </div></div>", "i": 6106226}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA;394 de 12 de marzo de 1998, se ha aprobado al Colegio &quot;The Wessex School&quot; de Concepci&#xF3;n, un plan de estudio biling&#xFC;e para los cursos de 5&#xBA; a 8&#xBA; a&#xF1;o (NB.3 a NB.6) de Ense&#xF1;anza B&#xE1;sica, que se aplicar&#xE1; de acuerdo al cronograma establecido en el decreto supremo de Educaci&#xF3;n N&#xBA;40 de 1996 y sus modificaciones.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio biling&#xFC;es, para los subsectores que se indican, la mayor&#xED;a de los cuales se impartir&#xE1;n cumpliendo la norma del decreto supremo de Educaci&#xF3;n N&#xBA;520 de 1996, en idioma ingl&#xE9;s. </div></div>", "i": 6106227}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de marzo de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6106228}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "394 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-394 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 394 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIO THE WESSEX SCHOOL", "CONCEPCION", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-03-12", "doble_articulado": false, "id_norma": "97442", "numero_fuente": "36028", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-03-30", "vigencias": [{"de