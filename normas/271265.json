{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A EXPORTADORA BELLATERRA S.A.</div><br></div>", "i": 7370147}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La XV Direcci&#xF3;n Regional Metropolitana Santiago Oriente del SII, por resoluci&#xF3;n Ex. N&#xBA; 1.993 de fecha 14 de marzo de 2008, otorga a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, a Exportadora Bellaterra S.A., RUT: 76.664.820-7, la calidad de Agente Retenedor del Impuesto al Valor Agregado que afecta en la venta de Berries, conforme Res. Ex. N&#xBA; 55 de 02.06.2005 de la Direcci&#xF3;n Nacional.</div><br></div>", "i": 7370148}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Hugo Horta Barahona, Director Regional.</div><br></div>", "i": 7370149}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1993 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1993 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "XIV DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO ORIENTE"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A EXPORTADORA\nBELLATERRA S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-03-14", "doble_articulado": false, "id_norma": "271265", "numero_fuente": "39064", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-05-17", "vigencias": [{"desde": "2008-05-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-05-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-05-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes":