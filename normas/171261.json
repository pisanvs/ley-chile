{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6283124}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.070, de 15 de junio de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.380 de 1998, de esta Subsecretar&#xED;a, que autoriz&#xF3; a&nbsp; PESQUERA ISABELLA LIMITADA, para operar la nave &apos;&apos;Ocean&#xED;a&apos;&apos;, s&#xF3;lo en lo relativo al recurso hidrobiol&#xF3;gico Albacora, en el &#xE1;rea mar&#xED;tima comprendida entre la I y la X Regiones, en virtud de lo se&#xF1;alado en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 6283125}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de junio de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6283126}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1070", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1070"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-06-15", "doble_articulado": false, "id_norma": "171261", "numero_fuente": "36694", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-21", "vigencias": [{"desde": "2000-06-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-06-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":