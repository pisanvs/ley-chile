{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD AGROMIR FERIAS S.A.</div><br></div>", "i": 7365342}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/N&#xBA;Ex-1815, de fecha 21-02-2008, otorga a Sociedad Agromir Ferias S.A. RUT</div><div class=\"p\">N&#xBA;76.006.012-7, la calidad de agente retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las ventas de ganado vivo, establecido en la resoluci&#xF3;n N&#xBA; Ex-3721 de 28-07-2000 de la Direcci&#xF3;n Nacional. La presente autorizaci&#xF3;n surtir&#xE1; efecto a partir del d&#xED;a primero del mes siguiente a la fecha de publicaci&#xF3;n de este extracto en el Diario Oficial y tendr&#xE1; vigencia indefinida.</div><br></div>", "i": 7365343}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 21 de febrero de 2008.- Ram&#xF3;n Concha Velis, Director Regional (S).</div><br></div>", "i": 7365344}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1815 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1815 EXENTA"}, {"tipo": "3", "numero": "DRE-08-1815 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-1815 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD\nAGROMIR FERIAS S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-02-21", "doble_articulado": false, "id_norma": "269638", "numero_fuente": "39004", "tipo_version": "3",