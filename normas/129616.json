{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6147474}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.162 de 11 de agosto de 1988 del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriza a la Sucesi&#xF3;n Manuel Ahumada Ponce, para efectuar servicio internacional de transporte terrestre de pasajeros entre Vi&#xF1;a del Mar - Santiago (Chile) y Buenos Aires (Argentina), por Paso Caracoles (T&#xFA;nel Cristo Redentor), el que se atender&#xE1; con una frecuencia semanal.-</div><br></div>", "i": 6147475}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Manuel G&#xE1;rate Meneses, Coronel, Subsecretario de Transportes.</div><br></div>", "i": 6147476}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1162 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1162 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-11", "doble_articulado": false, "id_norma": "129616", "numero_fuente": "33153", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-08-23", "vigencias": [{"desde": "1988-08-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-08-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-08-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-01-13", "fecha_version": "1988-08-2