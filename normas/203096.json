{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6398052}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA;1.329 de fecha 30 de agosto de 2002, se expropi&#xF3; el lote de terreno N&#xBA;54, superficie 450 m2, rol de Aval&#xFA;o N&#xBA;302-392, comuna de Cunco, para la obra &apos;&apos;Camino Ruta S-16, Sector Cunco - Melipeuco, Tramo Km.</div><div class=\"p\">55,000 al Km. 87,46783, correspondiente al sub-tramo II Km.</div><div class=\"p\">62,784 al Km. 76,043, provincia de Caut&#xED;n, comuna de Cunco, Melipeuco&apos;&apos;, IX Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietaria Orfelina del Carmen Mariqueo Marifil, ascendente a la cantidad de $489.246.- </div></div>", "i": 6398053}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6398054}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1329 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1329 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-08-30", "doble_articulado": false, "id_norma": "203096", "numero_fuente": "37372", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-10-01", "vigencias": [{"desde": "2002-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-10-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresad