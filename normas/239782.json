{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A ICM S.A. </div></div>", "i": 6531695}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La V Direcci&#xF3;n Regional del Servicio de Impuestos Internos, por resoluci&#xF3;n Ex. N&#xBA; 59, de 6 de mayo de 2005, otorga, a contar del 1&#xBA; mes siguiente al de esta publicaci&#xF3;n y hasta el 31 de diciembre de 2005, a la sociedad ICM S.A., RUT N&#xBA; 96.733.970-9, la calidad de Agente Retenedor del Impuesto al Valor Agregado en los contratos de instalaci&#xF3;n o confecci&#xF3;n de especialidades que contraten, establecido en la Res. Ex. N&#xBA;115/2004 de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del 5.01.2005.</div><br></div>", "i": 6531696}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Luis Aguirre P&#xE9;rez, Director Regional (S). </div></div>", "i": 6531697}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "59 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-59 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL DE VALPARAÍSO"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A ICM S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-05-06", "doble_articulado": false, "id_norma": "239782", "numero_fuente": "38201", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-04", "vigencias": [{"desde": "2005-07-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-07-04", "fin_v