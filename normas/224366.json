{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6475823}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 938, de 6 de abril de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BIO BIO S.A para ampliar actividades pesqueras extractivas con la nave &quot;Loa 24&quot;, en las &#xE1;reas mar&#xED;timas que se indican, donde podr&#xE1; capturar el recurso Jibia: a) Entre la V a VII Regiones, en la IX y X Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, con cerco; b) Entre la V a VII Regiones, en la IX y X Regi&#xF3;n, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua. </div></div>", "i": 6475824}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6475825}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "938 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-938 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-04-06", "fecha_derogacion": "2006-11-23", "doble_articulado": false, "id_norma": "224366", "numero_fuente": "37849", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-04-30", "vigencias": [{"desde": "2006-11-23", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-04-30", "hasta": "2006-11-22", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2006-11-23", "fin_vigencia": ""}, "v