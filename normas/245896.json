{"html": [{"t": "<div><div class=\"p\">AUTORIZA EMISORES DE BOLETAS ELECTRONICAS </div></div>", "i": 6555914}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 147, del 29-12-2005, que autoriza a contribuyentes como emisores de boletas electr&#xF3;nicas.</div><br><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisores de boletas electr&#xF3;nicas a los contribuyentes RUT 97.036.000-K, RUT 97.030.000-7, RUT 97.032.000-8, RUT 97.006.000-6, RUT 97.004.000-5 y RUT 97.051.000-1 a contar del mes de enero de 2006. El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de diciembre de 2005.</div><br></div>", "i": 6555915}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "147 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-147 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISORES DE BOLETAS ELECTRONICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONTRIBUYENTES", "EMISORES DE BOLETAS ELECTRONICAS", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN FECHA PROMULGACION", "NORMA SIN PROMULGACION."], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-29", "doble_articulado": false, "id_norma": "245896", "numero_fuente": "38354", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-01-04", "vigencias": [{"desde": "2006-01-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-01-04", "fin_