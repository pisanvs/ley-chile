{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 14,331</div><br><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DON ABRAHAM LECKIE ALLEN </div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6580052}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, al ex diputado don Abraham Leckie Allen, una pensi&#xF3;n de E&#xBA; 100 mensuales.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande esta ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda. </div></div>", "i": 6580053}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a diecis&#xE9;is de Noviembre de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- Eduardo Figueroa G.</div><br></div>", "i": 6580054}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14331", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14331"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DON ABRAHAM LECKIE ALLEN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-11-16", "doble_articulado": false, "id_norma": "252455", "numero_fuente": "24812", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-12-06", "vigencias": [{"desde": "1960-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigen