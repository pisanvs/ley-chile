{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N</div></div>", "i": 9955053}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La VI Direcci&#xF3;n Regional Rancagua del SII, por resoluci&#xF3;n Ex. N&#xB0; 77318088537, de fecha 05/10/2018, except&#xFA;a del cambio de sujeto del IVA en las ventas de Berries y se le apliquen las reglas generales del IVA, y otorga la calidad de Agente Retenedor del Impuesto al Valor Agregado en la venta de Berries, a Agr&#xED;cola La Ensenada Limitada, RUT N&#xB0; 76.384.102-2. Dicho acto de autoridad regir&#xE1; a contar del d&#xED;a primero del mes siguiente al de esta publicaci&#xF3;n, de acuerdo a lo establecido en la resoluci&#xF3;n exenta SII N&#xB0; 55, del 2 de junio de 2005, de la Direcci&#xF3;n Nacional del Servicio de Impuestos Internos, publicada en el Diario Oficial el 2 de junio de 2005.- </div></div>", "i": 9955054}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mario Gonz&#xE1;lez Z&#xFA;&#xF1;iga, Director Regional. </div></div>", "i": 9955055}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "77318088537 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-77318088537 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL RANCAGUA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1477426; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-10-05", "doble_articulado": false, "id_norma": "1123938", "numero_fuente": "42180", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-10-13", "vigencias": [{"desde": "2018-11-01", "hasta": "", "tipo_version": "3", "tipo