{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7330207}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.286, de 10 de mayo de 2006 de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA DEEP SEA FOOD LIMITADA, para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Costanera s/n, Puerto Chacabuco, XI Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco Enfriado, Fresco Refrigerado, Congelado, Seco Salado, y Conserva, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 522 de 1993, de esta Subsecretar&#xED;a, en virtud de la carta renuncia citada en Visto y del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 7330208}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de mayo de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7330209}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1286 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1286 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-05-10", "doble_articulado": false, "id_norma": "250256", "numero_fuente": "38483", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-06-07", "vigencias": [{"desde": "2006-06-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inici