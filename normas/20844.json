{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 268 EXENTO, DE 1995 </div></div>", "i": 7161422}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 268, de fecha 02 de mayo de 1995, del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica de ENAC, las adecuaciones introducidas a los planes y programas de estudios de las carreras de Turismo, de Contabilidad, de Secretariado Ejecutivo, de T&#xE9;cnico Asistencial de Menores, de T&#xE9;cnico Asistente Social y de Asistente del Educador de P&#xE1;rvulos, las que se insertaron en el Decreto Exento del Ministerio de Educaci&#xF3;n N&#xB0; 120 de 1992. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1995. </div></div>", "i": 7161423}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 25 de Mayo de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161424}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "268 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-268 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 268 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA ENAC", "PROGRAMAS ESTUDIO", "PLANES ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-02", "doble_articulado": false, "id_norma": "20844", "numero_fuente": "35186", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-06-06", "vigencias": [{"desde": "1995-06-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-06-06", "fin