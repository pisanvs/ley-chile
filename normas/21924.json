{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Agua potable de Melipilla Lei n&#xFA;m. 51.- Santiago, a 1.&#xB0; de Agosto de 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 9072102}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Susp&#xE9;ndense los efectos de la lei de 12 de Setiembre de 1887 para que la Municipalidad de Melipilla pueda comprar una vertiente que existe en el fundo del C&#xE1;rmen con el objeto de proveer de agua potable a la ciudad.</div><br><br></div>", "i": 9072103}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Pedro Montt.</div><br></div>", "i": 9072104}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "51", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-51"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AGUA POTABLE DE MELIPILLA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MELIPILLA", "AGUA POTABLE", "MUNICIPALIDAD", "TERRENOS", "COMPRA", "SUSPENDE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-08-01", "doble_articulado": false, "id_norma": "21924", "numero_fuente": "4584", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-08-01", "vigencias": [{"desde": "1893-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-08-01", "fin_vigencia": "", "ti