{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7358070}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.110, de 29 de octubre de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a BRACPESCA S.A. para iniciar actividades pesqueras transformaci&#xF3;n, para operar planta ubicada Regimiento Coquimbo N&#xBA; 230, Coquimbo, para elaborar en l&#xED;neas proceso cocido, fresco enfriado, fresco refrigerado, congelado, seco salado, ahumado, conserva, harina, deshidratado y harina de desechos de crust&#xE1;ceos, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1.987 de 2006, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 7358071}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de octubre de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7358072}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3110 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3110 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-10-29", "doble_articulado": false, "id_norma": "266410", "numero_fuente": "38910", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-11-13", "vigencias": [{"desde": "2007-11-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-11-13", "fin_vige