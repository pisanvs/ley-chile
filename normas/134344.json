{"html": [{"t": "<div><div class=\"p\">DISPONE EXPROPIACION PARCIAL DE INMUEBLE</div><br><br></div>", "i": 6162005}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Decreto Secc. 2&#xAA; N&#xBA; 173 marzo 15 de 1999, Alcalde Municipalidad de Santiago dispone expropiaci&#xF3;n parcial conforme art&#xED;culo 85, decreto N&#xBA; 458 Vivienda y Urbanismo inmueble Par&#xED;s N&#xBA; 888-898 Rol 373-029 Comuna Santiago, dominio aparente Inmobiliaria Mares del Sur S.A., superficie aproximada 40,90 m&#xB2;. Deslindes: Norte, 4,80 mts. l&#xED;nea quebrada calle Par&#xED;s; Sur, 3,30 mts. otro propietario; Oriente, 11 mts. l&#xED;nea quebrada con mismo propietario y Poniente, 11 mts. calle Serrano. Indemnizaci&#xF3;n $5.235.200 se pagar&#xE1; mediante compensaci&#xF3;n derechos edificaci&#xF3;n.</div><br></div>", "i": 6162006}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jaime Ravinet de la Fuente, Alcalde.</div><br></div>", "i": 6162007}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "173", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-173"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "DISPONE EXPROPIACION PARCIAL DE INMUEBLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-03-15", "doble_articulado": false, "id_norma": "134344", "numero_fuente": "36329", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-04-01", "vigencias": [{"desde": "1999-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-04-01", "fin_vigencia": "", "tipo_version": "