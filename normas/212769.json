{"html": [{"t": "<div><div class=\"p\">CERTIFICADO</div><br><br></div>", "i": 6432639}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile en conformidad con lo dispuesto en el N&#xBA;5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de julio de 2003, fue de 1,69% anual. </div></div>", "i": 6432640}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, julio 17 de 2003.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6432641}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-07-17", "doble_articulado": false, "id_norma": "212769", "numero_fuente": "37613", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-19", "vigencias": [{"desde": "2003-07-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-07-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-07-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2003-07-21", "fecha_version": "2003-07-19", "fecha_actualizacion_texto": "2003-07-19", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6432639}, {"n": "Artículo", "i": 643