{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6376576}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA; 112, de fecha 30 de noviembre del a&#xF1;o 2001, se autoriz&#xF3; la existencia y se aprob&#xF3; el estatuto de la Cooperativa de Trabajo Cooperativismo para la Danza Contempor&#xE1;nea Independiente, de nombre de fantas&#xED;a &quot;Compa&#xF1;&#xED;a Movimiento de Danza Contempor&#xE1;nea&quot;, de Santiago, Regi&#xF3;n Metropolitana, en los t&#xE9;rminos que da testimonio el instrumento protocolizado con fecha 22 de octubre del a&#xF1;o 2001, ante el Notario de Santiago, don Ra&#xFA;l Perry Pefaur, con el n&#xFA;mero 189.</div><br></div>", "i": 6376577}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Sr. Subsecretario.- Carlos Rubio Estay, Jefe Departamento de Cooperativas Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6376578}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "112", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-112"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-30", "doble_articulado": false, "id_norma": "196633", "numero_fuente": "37233", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-12", "vigencias": [{"desde": "2002-04-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-04-12", "fin_vigencia": ""}, "vigencia