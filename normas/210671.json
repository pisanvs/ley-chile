{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;5.702 EXENTA, DE 2003 </div><br></div>", "i": 6424917}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;5.702, de 29 de abril del a&#xF1;o 2003, se ha aprobado al Colegio &quot;The British School&quot;, de Punta Arenas, XII Regi&#xF3;n de Magallanes y la Ant&#xE1;rtica Chilena, un plan de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, que se aplicar&#xE1; a partir del a&#xF1;o escolar 2003.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en la presente resoluci&#xF3;n para todos los cursos de la Ense&#xF1;anza Media. </div></div>", "i": 6424918}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de mayo de 2003.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6424919}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5702 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5702 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 5.702 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-04-29", "doble_articulado": false, "id_norma": "210671", "numero_fuente": "37569", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-05-28", "vigencias": [{"desde": "2003-05-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-05-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-05-28", "fin_vigencia": "", "