{"html": [{"t": "<div><br><div class=\"p\">DERECHOS.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Agosto 23 de 1832.</div></div>", "i": 10257011}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Se declara que el decreto de ocho del actual, en que se manda que los art&#xED;culos de provisi&#xF3;n que tomen a su bordo, desde tierra, los buques de guerra franceses sean libres de derechos de importaci&#xF3;n &amp;c, es estensivo, en todas sus partes, a los buques de guerra de las dem&#xE1;s naciones amigas, surtos en los puertos de la Rep&#xFA;blica; y para su cumplimiento e intelijencia de los funcionarios a quienes compete, impr&#xED;mase el presente decreto, y el anterior citado, transcribi&#xE9;ndose previamente al Gobernador de Valpara&#xED;so. </div></div>", "i": 10257012}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  PRIETO.&nbsp; Joaquin Tocornal.</div></div>", "i": 10257013}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DERECHOS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-08-23", "doble_articulado": false, "id_norma": "1161547", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-08-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-08-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-08-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_i