{"html": [{"t": "<div><br><div class=\"p\">MEDICOS</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Setiembre 2 de 1823.</div></div>", "i": 10229423}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  133 Conforme a lo expuesto por el Protom&#xE9;dico, y Cabildo de esta capital, se declara: que los m&#xE9;dicos existentes en ella, y que est&#xE1;n autorizados para ejercer la facultad, no deben exijir por sus visitas a los enfermos, mas que cuatro reales en cada una de ellas, en atencion a que este ha sido en todos tiempos el salario que han percibido los facultativos por arancel. Para el cumplimiento de esta providencia ins&#xE9;rtese en el Bolet&#xED;n.</div><br></div>", "i": 10229424}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  R&#xFA;brica de S.E. </div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp;  Ega&#xF1;a. </div></div>", "i": 10229425}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTRO", "descripcion": "Otro", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "MEDICOS", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-09-02", "doble_articulado": false, "id_norma": "1158123", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-09-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2021-05-25", "fecha_version": "1823-09-02",