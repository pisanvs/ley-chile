{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 389 EXENTO, DE 2002 </div></div>", "i": 6397171}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 389, de fecha 8 de mayo de 2002, del Ministerio de Educaci&#xF3;n, se declara aprobada a la Universidad Santo Tom&#xE1;s la modificaci&#xF3;n al Plan y a los Programas de Estudio de la carrera de Contador Auditor.</div><br><div class=\"p\">&nbsp; &nbsp;  Dicha carrera se imparte en jornada diurna y vespertina en su sede de la ciudad de Santiago.</div><br><div class=\"p\">&nbsp; &nbsp;  Asimismo, las modificaciones se har&#xE1;n efectivas a contar del primer semestre del a&#xF1;o 2002.</div><br><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase presente para todos los efectos legales y administrativos.</div><br></div>", "i": 6397172}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de mayo de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6397173}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "389 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-389 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 389 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-08", "doble_articulado": false, "id_norma": "202859", "numero_fuente": "37364", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-09-21", "vigencias": [{"desde": "2002-09-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-09-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"i