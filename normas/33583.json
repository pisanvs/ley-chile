{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8290881}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 176 de 28 de febrero de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a SONIA MYRTA VELASQUEZ MU&#xD1;OZ, R.U.T. N&#xB0; 6.015.397-3, para iniciar actividades pesqueras, en orden a instalar y operar una planta ubicada en R&#xED;o de los Ciervos N&#xB0; 4737, Punta Arenas, en las l&#xED;neas de elaboraci&#xF3;n de fresco, enfriado, cocido, desgranado y conservas, los siguientes recursos hidrobiol&#xF3;gicos: Congrio dorado, Merluza del sur, Salm&#xF3;n plateado, Trucha arcoiris, Caracol picuyo, Caracol piquilhue, Caracol trophon, Centolla, Centoll&#xF3;n, Cholga, Chorito, Erizo, Lapa.</div><br></div>", "i": 8290882}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 28 de febrero de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8290883}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "176", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-176"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SONIA VELASQUEZ MU OZ", "INDUSTRIA PESQUERA", "PUNTA", "ARENAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1995-02-28", "fecha_derogacion": "1997-02-13", "doble_articulado": false, "id_norma": "33583", "numero_fuente": "35118-1", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1995-03-15", "vigencias": [{"desde": "1997-02-13", "hasta": "", "tipo_version": "2", "tipo_