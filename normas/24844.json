{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><br></div>", "i": 8277652}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que traspase y suplemente el &#xED;tem 4|7|2/e/6 del Presupuesto vigente en la cantidad de treinta mil novecientos veinte pesos ($ 30,920), deduci&#xE9;ndola del &#xED;tem 04|07|01 del mismo Presupuesto. </div></div>", "i": 8277653}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, dos de Diciembre de mil novecientos veintinueve.- Carlos Iba&#xF1;ez C.- Enrique Berm&#xFA;dez. </div></div>", "i": 8277654}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4704", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4704"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O", "1929", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-12-02", "doble_articulado": false, "id_norma": "24844", "numero_fuente": "15540", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-12-05", "vigencias": [{"desde": "1929-12-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-12-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1929-12-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos