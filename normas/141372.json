{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,347.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 9051002}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- El&#xE9;vese a siete mil doscientos pesos ($ 7,200), la pension anual de que disfruta la viuda e hijos del capitan de nav&#xED;o don Manuel Thompson&quot;.</div><br></div>", "i": 9051003}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintiocho de diciembre de mil novecientos diecisiete.- Juan Luis Sanfuentes.- Oscar Viel. </div></div>", "i": 9051004}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3347", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3347"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1917-12-28", "doble_articulado": false, "id_norma": "141372", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1918-01-08", "vigencias": [{"desde": "1918-01-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1918-01-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1918-01-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-08-26", "fecha_version": "1918-01-08", "fecha_act