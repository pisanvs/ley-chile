{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6179976}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.267, de 31 de mayo de 1999, se expropiaron los lotes de terreno N&#xBA;s.11, 16, 23 y 24, superficies 478, 584, 2.818 y 433 m2., roles de aval&#xFA;o 58-21, 54-18, 57-4 y 57-3, comuna de San Esteban, obra Camino Ruta E-755, Sector San Esteban-Lo Calvo, y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Bruno Gioia Gobbi, Flor Andrea Gonz&#xE1;lez Pizarro y otro, Edelmira de las Mercedes Sazo Yanca y Hugo Domingo Henr&#xED;quez Briones, ascendente a la cantidad de $2.111.590, lote 11;</div><div class=\"p\">$13.843.434, lote 16; $4.959.848, lote 23, y $6.402.614, lote 24.-</div><br></div>", "i": 6179977}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6179978}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1267", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1267"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-05-31", "doble_articulado": false, "id_norma": "139862", "numero_fuente": "36428", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-08-02", "vigencias": [{"desde": "1999-08-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-08-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-08-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "M