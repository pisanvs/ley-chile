{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7286035}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.971, de 20 de septiembre de</div><div class=\"p\">2001, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad</div><div class=\"p\">parcial de la resoluci&#xF3;n N&#xBA; 293, de 1987, de esta</div><div class=\"p\">Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a MARIO MOROZIN</div><div class=\"p\">YURESIC para operar con la nave &quot;Cuca&#xF1;a&quot;, respecto del</div><div class=\"p\">recurso Merluza com&#xFA;n, en el &#xE1;rea mar&#xED;tima comprendida</div><div class=\"p\">entre el l&#xED;mite norte de la IV Regi&#xF3;n y el paralelo 40&#xBA;</div><div class=\"p\">LS, de conformidad con lo establecido en la letra b) del</div><div class=\"p\">art&#xED;culo 143 de la Ley General de Pesca y Acuicultura. </div></div>", "i": 7286036}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de septiembre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7286037}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1971", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1971"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-09-20", "doble_articulado": false, "id_norma": "189911", "numero_fuente": "37072", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-09-28", "vigencias": [{"desde": "2001-09-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic