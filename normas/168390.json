{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6274503}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 333, de fecha 29 de Abril de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a don Sergio Carrasco Sobejano, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6274504}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 02 de Mayo de 1985.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6274505}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "333 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-333 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-04-29", "doble_articulado": false, "id_norma": "168390", "numero_fuente": "32183", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-05-30", "vigencias": [{"desde": "1985-05-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-05-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-05-30", "fin_vigencia": "", "tipo_version": "3"}], "