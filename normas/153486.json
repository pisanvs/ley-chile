{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br></div>", "i": 6226140}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 423, del 28 de Julio de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la 1ra. Regi&#xF3;n, se autoriza a Sr. Ernesto Arancibia Venegas, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6226141}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Eliecer Aedo Rivera, Secretario Regional Ministerial Transportes y Telecomunicaciones 1ra. Regi&#xF3;n Tarapac&#xE1;.</div><br></div>", "i": 6226142}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "423 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-423 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-07-28", "doble_articulado": false, "id_norma": "153486", "numero_fuente": "32545", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-08-11", "vigencias": [{"desde": "1986-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-08-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-08-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "