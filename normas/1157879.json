{"html": [{"t": "<div><div class=\"p\">MODIFICA EL ANEXO 51-7, DEL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10214764}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Mediante la resoluci&#xF3;n exenta N&#xB0; 802, de 31.03.2021, del Director Nacional de Aduanas, fue modificado el Anexo 51-7, del <a href=\"https://www.leychile.cl/Navegar?idNorma=248540&amp;idParte=&amp;idVersion=\">Compendio de Normas Aduaneras</a>, relativo a los &quot;Operadores&quot;, en el sentido de incorporar a la empresa Servicios A&#xE9;reos y Terrestres Aviasur S.A., en el listado de las compa&#xF1;&#xED;as a&#xE9;reas bajo el c&#xF3;digo M70 y como proveedor de naves bajo el c&#xF3;digo PF1 para operar en todas las aduanas del pa&#xED;s, conforme a la normativa vigente.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10214765}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de marzo de 2021.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><div class=\"p\"> </div><br></div>", "i": 10214766}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "802 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-802 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA EL ANEXO 51-7, DEL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1922385", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-03-31", "doble_articulado": false, "id_norma"