{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,163.- Por cuanto el Congreso Nacional ha aprobado el siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6177203}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a la viuda e hijos del fogonero primero de la Armada, don Juan Francisco Mansilla, se&#xF1;ora Eudocia Mancilla Herrera, el derecho a gozar una pension de quince pesos ($ 15) que disfrutar&#xE1; conforme a la lei de montep&#xED;o militar.</div><br></div>", "i": 6177204}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintidos de diciembre de mil novecientos dieciseis.- Juan Luis Sanfuentes.- Oscar Urz&#xFA;a. </div></div>", "i": 6177205}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3163", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3163"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-12-22", "doble_articulado": false, "id_norma": "138988", "numero_fuente": "11660", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-12-29", "vigencias": [{"desde": "1916-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1916-12-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1916-12-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "