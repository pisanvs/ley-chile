{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xB0; 271, DE 1986 </div></div>", "i": 8351163}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 152, de 13 de Febrero de 1987 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n N&#xB0; 271, de 1986, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a la Sociedad Industrial, Comercial y Pesquera Pudeto Limitada, para cultivar adem&#xE1;s los recursos ostra y osti&#xF3;n del norte, en el establecimiento de cultivo autorizado por la resoluci&#xF3;n N&#xB0; 97, de 1985, de esta Subsecretar&#xED;a en orden a dejar establecido que el sistema de cultivo a emplear para las especies se&#xF1;aladas ser&#xE1; el de &quot;suspendido desde balsas&quot;.</div><br></div>", "i": 8351164}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de Febrero de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8351165}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "152", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-152"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION N° 271, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-13", "doble_articulado": false, "id_norma": "144887", "numero_fuente": "32707", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-02-25", "vigencias": [{"desde": "1987-02-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-02-25",