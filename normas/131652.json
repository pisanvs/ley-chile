{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8340834}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 271, de 3 de febrero de 1999, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.226, de 1992, de esta Subsecretar&#xED;a, que autoriz&#xF3; a&nbsp; PESCA CHILE S.A., para ampliar las actividades pesqueras extractivas con la nave &apos;&apos;Betanzos&apos;&apos;, s&#xF3;lo en lo relativo a la especie Alfonsino, en el &#xE1;rea de pesca autorizada en la citada resoluci&#xF3;n.</div><br></div>", "i": 8340835}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de febrero de 1999.- Edith Saa Collantes, Subsecretario de Pesca Subrogante. </div></div>", "i": 8340836}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "271", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-271"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-02-03", "doble_articulado": false, "id_norma": "131652", "numero_fuente": "36289", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-02-13", "vigencias": [{"desde": "1999-02-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-02-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-02-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JCT", "fecha_ingreso": "1999-02