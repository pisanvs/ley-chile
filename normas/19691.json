{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 20 EXENTO, DE 1995 </div></div>", "i": 5939622}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 20 de 6 de Enero de 1995, se ha aprobado al Liceo &quot;Javiera Carrera&quot; (A N&#xB0; 1) de Santiago, un plan especial de estudio para Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, el cual se aplicar&#xE1; en 1er. y 3er. a&#xF1;o a partir del a&#xF1;o escolar 1995, y en 2do. y 4to. a&#xF1;o a partir del a&#xF1;o escolar 1996.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio para educaci&#xF3;n media de las asignaturas que se indican en el presente decreto.</div><br></div>", "i": 5939623}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 23 de Enero de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5939624}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "20", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-20"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 20 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LICEO JAVIERA CARRERA SANTIAGO", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-01-06", "doble_articulado": false, "id_norma": "19691", "numero_fuente": "35080", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-01-30", "vigencias": [{"desde": "1995-01-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-01-30", "fin_vigencia": ""}, "vigencias_version_n