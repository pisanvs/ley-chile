{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6371139}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 311, de 5 de febrero de 2002, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 6&#xBA; de la resoluci&#xF3;n N&#xBA; 37 de 2002, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Distribuci&#xF3;n espacio temporal de las capturas de Jurel en la I y II Regi&#xF3;n (Primera Etapa, 2002)&quot;, en el sentido de reemplazar las naves &quot;Angamos 2&quot; y &quot;Eperva 50&quot; por las naves &quot;Angamos 4&quot; y &quot;Livilcar&quot;, todas de propiedad de Corpesca S.A., de la n&#xF3;mina de naves participantes en la se&#xF1;alada pesca de investigaci&#xF3;n.</div><br></div>", "i": 6371140}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de febrero de 2002.- Edith Saa Collantes, Subsecretario de Pesca Subrogante. </div></div>", "i": 6371141}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "311", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-311"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-05", "doble_articulado": false, "id_norma": "195061", "numero_fuente": "37200", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-03-02", "vigencias": [{"desde": "2002-03-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia"