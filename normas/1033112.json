{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9206917}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.846 de 28 de octubre de 2011, de esta Subsecretar&#xED;a, autor&#xED;zase a la UNIVERSIDAD DE CONCEPCI&#xD3;N para capturar, en las cuencas de los r&#xED;os Itata y Biob&#xED;o, VIII Regi&#xF3;n del Biob&#xED;o, en el plazo de 12 meses contados desde la fecha de la presente resoluci&#xF3;n, ejemplares de especies de la fauna &#xED;ctica, en la forma y condiciones se&#xF1;aladas en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  El solicitante designa como persona responsable de esta autorizaci&#xF3;n a don Sergio Lavanchy Merino.</div></div>", "i": 9206918}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de octubre de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9206919}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2846", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2846"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-10-28", "doble_articulado": false, "id_norma": "1033112", "numero_fuente": "40119", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-11-25", "vigencias": [{"desde": "2011-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-11-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-11-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie