{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7194011}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 15 de 14 Septiembre de 1993, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se adjudic&#xF3; a Dn Tom&#xE1;s Patricio Krinfokai C, la concesi&#xF3;n para operar, por un plazo de cinco a&#xF1;os a contar de la publicaci&#xF3;n del presente extracto, un establecimiento ubicado en calle San Mart&#xED;n N&#xB0; 751 de la comuna de Rengo, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de contaminantes de todo tipo de veh&#xED;culos motorizados, sus remolques y semirremolques, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 7194012}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Luis D&#xED;az Sol&#xED;s, Secretario Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n.</div><br></div>", "i": 7194013}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "15", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-15"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION REVISION TECNICA", "PLANTA REVISION TECNICA", "VEHICULOS MOTORIZADOS", "SEXTA REGION", "TOMAS PATRICIO", "KRINFOKAI", "RENGO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-09-14", "doble_articulado": false, "id_norma": "32134", "numero_fuente": "34714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-11-12", "vigencias": [{"desde": "1993-11-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"