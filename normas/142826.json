{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8349519}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.649, de 31 de agosto de 1999, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1.268 de 1991, de esta Subsecretar&#xED;a, que autoriz&#xF3; a FLOR MARIA ALBORNOZ TOBAR, para instalar y operar el establecimiento de cultivo correspondiente al sector 2 del centro ubicado en Puerto P&#xE9;rez, Isla Grupo Cinco Hermanos, comuna y provincia de Ays&#xE9;n, XI Regi&#xF3;n, por haberse denegado la respectiva solicitud de concesi&#xF3;n de acuicultura.</div><br></div>", "i": 8349520}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de agosto de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8349521}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1649", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1649"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-08-31", "doble_articulado": false, "id_norma": "142826", "numero_fuente": "36460", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-09", "vigencias": [{"desde": "1999-09-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-09-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modifica