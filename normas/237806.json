{"html": [{"t": "<div><div class=\"p\">DECRETO-LEY NUM. 311</div><br><div class=\"p\">&nbsp; &nbsp;  Deroga diversos decretos-leyes</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 311.- Santiago, 27 de Julio de 1932.- He acordado y dicto el siguiente,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto-ley:</div><br></div>", "i": 7320059}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo 1.o Se derogan en todas sus partes los decretos-leyes n&#xFA;meros 12, 39 y 189, de 9 y 16 de Junio y 13 de Julio de 1932 respectivamente.</div><br></div>", "i": 7320060, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. 2.o Restabl&#xE9;cese la vigencia de las disposiciones de la ley n&#xFA;mero 5,107, de 19 de Abril de 1932, en cuanto hab&#xED;an sido derogadas por los decretos-leyes a que se refiere el art&#xED;culo anterior. </div></div>", "i": 7320061, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. 3.o El presente decreto-ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br><br></div>", "i": 7320062}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  CARLOS DAVILA.- Enrique Za&#xF1;artu P.</div><br><br><br></div>", "i": 7320063}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "311", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-311"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DEROGA DIVERSOS DECRETOS LEYES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-07-27", "doble_articulado": false, "id_norma": "237806", "numero_fuente": "16335", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-07-28", "vigenc