{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6240898}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 84, del 23 de Abril de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Atacama, se autoriza a Guillermo Edifio P&#xE9;rez Araya, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del territorio Nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6240899}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Copiap&#xF3;, 23 de Abril de 1986.- Sergio Antonio Acevedo Oyarce, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de Atacama.</div><br></div>", "i": 6240900}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "84 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-84 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-04-23", "doble_articulado": false, "id_norma": "158125", "numero_fuente": "32462", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-05-05", "vigencias": [{"desde": "1986-05-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-05-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-05-05", "fin_vigencia": "", "tipo_versio