{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 271, DE 1987 </div></div>", "i": 6196258}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta No. 271 de fecha 11 de Febrero de 1987, del Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante, se modific&#xF3; el art&#xED;culo 1&#xB0; de la Resoluci&#xF3;n Exenta de Educaci&#xF3;n No. 2.463 de 1982, del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Celler, en el sentido de insertar nueva red secuencial de asignaturas en la carrera de Turismo, a partir del a&#xF1;o 1986.</div><br></div>", "i": 6196259}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6196260}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "271 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-271 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 271, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-11", "doble_articulado": false, "id_norma": "145041", "numero_fuente": "32735", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-03-30", "vigencias": [{"desde": "1987-03-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-03-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-03-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAS", "fecha_ingreso": "1999-10-11", "fecha_vers