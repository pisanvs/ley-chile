{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A AGRICOLA CORINTO S.A.</div><br><br><br></div>", "i": 6120725}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VII Direcci&#xF3;n Regional Talca del SII, por resoluci&#xF3;n N&#xBA; 1.001 exenta de 14 de julio de 1998 otorga, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n y hasta el 31 de julio de 1999 a Agr&#xED;cola Corinto S.A., RUT N&#xBA; 79.736.000-7, la calidad de agente retenedor del Impuesto al Valor Agregado en las operaciones de ganado vivo, establecido en la Res. N&#xBA; Ex. 2.379/98 de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del d&#xED;a 24.04.98, modificada por Res.</div><div class=\"p\">N&#xBA; Ex. 3.785/98 publicada en el Diario Oficial del 30.06.98. </div></div>", "i": 6120726}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jos&#xE9; A. Moretti Soto, Director Regional. </div></div>", "i": 6120727}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1001 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1001 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VII DIRECCIÓN REGIONAL DE TALCA"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A AGRICOLA CORINTO S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "AGRICOLA CORINTO S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-14", "doble_articulado": false, "id_norma": "121698", "numero_fuente": "36120", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-07-22", "vigencias": [{"desde": "1998-07-22", "hasta": "", "tipo_version": "3", "t