{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br><br></div>", "i": 6223437}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 28 de 30 de Junio de 1986 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se autoriza a don V&#xED;ctor Manuel L&#xF3;pez Escobar, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6223438}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rancagua, 30 de Junio de 1986.- Rigoberto G&#xF3;mez Lav&#xED;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n.</div><br></div>", "i": 6223439}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "28 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-28 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-30", "doble_articulado": false, "id_norma": "152525", "numero_fuente": "32512", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-07-03", "vigencias": [{"desde": "1986-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-07-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-07-