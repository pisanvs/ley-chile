{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 11.841 EXENTA, DE 2003 </div></div>", "i": 6444162}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 11.841, de 25 de septiembre de 2003, del Servicio Nacional de Capacitaci&#xF3;n y Empleo, se revoc&#xF3; la autorizaci&#xF3;n otorgada al organismo t&#xE9;cnico de capacitaci&#xF3;n &quot;Patronato Nacional de Educaci&#xF3;n y Capacitaci&#xF3;n S.A.&quot;, RUT N&#xBA;96.949.440-K, cancel&#xE1;ndose su inscripci&#xF3;n en el Registro Nacional correspondiente, atendido lo dispuesto en el art&#xED;culo 77, letras b) y f) de la ley N&#xBA; 19.518. </div></div>", "i": 6444163}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Eduardo Rodr&#xED;guez Olivares, Jefe Departamento de Capacitaci&#xF3;n en Empresas.</div><br></div>", "i": 6444164}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "11841 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-11841 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 11.841 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-09-25", "doble_articulado": false, "id_norma": "216026", "numero_fuente": "37687", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-10-17", "vigencias": [{"desde": "2003-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-10-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-10-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones"