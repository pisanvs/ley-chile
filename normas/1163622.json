{"html": [{"t": "<div><div class=\"p\">MODIFICA COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10259972}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 1.859, de fecha 05.08.2021, del Director Nacional de Aduanas, se modifica el Compendio de Normas Aduaneras, en sus Anexos 51-7 y 51-15, en el sentido de agregar y modificar el c&#xF3;digo de la EEER Mara&#xF1;&#xF3;n Infantas Ltda. en las tablas de Correo R&#xE1;pido (Couriers) y Almacenistas respectivamente.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div></div>", "i": 10259973}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de agosto de 2021.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div></div>", "i": 10259974}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1859 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1859 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1992593", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-08-05", "doble_articulado": false, "id_norma": "1163622", "numero_fuente": "43027", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-08-13", "vigencias": [{"desde": "2021-08-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2021-08-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2021-08-13