{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUA EN COMUNA DE MELIPILLA </div></div>", "i": 6563891}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n</div><div class=\"p\">exenta N&#xBA; 1073, del 28 de febrero de 2006, conforme</div><div class=\"p\">art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, aprob&#xF3; distribuci&#xF3;n de derechos de aprovechamiento de aguas del predio &quot;Hijuela Primera de Popeta&quot;, de la comuna de Melipilla, provincia de Melipilla, Regi&#xF3;n Metropolitana, en el sentido de establecer que los derechos de aprovechamiento de aguas se extraen del pozo profundo N&#xBA; 4 y tienen la equivalencia que se indica, expresada en unidad de vol&#xFA;men por unidad de tiempo, son consuntivos, de jercicio permanente y continuo.</div><div class=\"p\">Publicaci&#xF3;n hecha conforme art&#xED;culo 13 ley N&#xBA; 18.377.- </div></div>", "i": 6563892}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Director Nacional.</div><br></div>", "i": 6563893}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1073 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1073 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUA EN COMUNA DE MELIPILLA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHOS DE APROVECHAMIENTO DE AGUAS", "MELIPILLA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-02-28", "doble_articulado": false, "id_norma": "247976", "numero_fuente": "38414", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-15", "vigencias