{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUAS EN COMUNA DE ARICA </div></div>", "i": 6095388}, {"t": "<div><div class=\"p\">Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xB0; 32 de 06 de Enero de 1989, conforme art&#xED;culo 5&#xB0;, transitorio C&#xF3;digo Aguas, determin&#xF3; derechos aprovechamiento aguas que corresponden a las parcelas N&#xB0;s. 1 a la 17; sitios N&#xB0;s. 3, 4, 5, 8 al 15, 16 y 17; Reservas CORA N&#xB0;s. 1 y 2 y Bienes Comunes N&#xB0;s. 1 y 2 del Proyecto de Parcelaci&#xF3;n &quot;Alberto Jordan&quot; de la comuna de Arica, I Regi&#xF3;n, formado por parte del predio Hacienda Rosario. Los derechos de aguas se extraen del r&#xED;o Lluta por canales Chacabuco, El Muro y Beyz&#xE1;n-CORA. Publicaci&#xF3;n hecha conforme Art. 13 Ley N&#xB0; 18.377.</div><br></div>", "i": 6095389}, {"t": "<div><div class=\"p\">Director Ejecutivo.</div><br></div>", "i": 6095390}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "32 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-32 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DERECHOS DE AGUAS EN COMUNA DE ARICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-01-06", "doble_articulado": false, "id_norma": "93822", "numero_fuente": "33273", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-01-16", "vigencias": [{"desde": "1989-01-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-01-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-01-16", "fin_vigencia": "