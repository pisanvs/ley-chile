{"html": [{"t": "<div><div class=\"p\">APRUEBA REFORMA DE ESTATUTOS DE</div><div class=\"p\">&quot;ASOCIACION DE AGENTES DE VALORES DE CHILE&quot; </div></div>", "i": 6271943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico: Que por resoluci&#xF3;n No. 163 de 27.11.87, se aprob&#xF3; reforma de estatutos corporaci&#xF3;n de derecho privado &quot;Asociaci&#xF3;n de Agentes de Valores de Chile&quot;, que consta de la escritura p&#xFA;blica de 11.11.87 otorgada en la Notar&#xED;a de Santiago de don Patricio Raby Benavente.</div><div class=\"p\">La reforma consiste en modificar los l&#xED;mites m&#xE1;ximos y m&#xED;nimos de la cuota de incorporaci&#xF3;n a la entidad. </div></div>", "i": 6271944}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27.11.87.- Jorge Luis Silva Brinck, Secretario General.</div><br></div>", "i": 6271945}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "163", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-163"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "APRUEBA REFORMA DE ESTATUTOS DE ASOCIACION DE AGENTES DE VALORES DE CHILE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-27", "doble_articulado": false, "id_norma": "167649", "numero_fuente": "32942", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-11", "vigencias": [{"desde": "1987-12-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendien