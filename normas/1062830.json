{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.112 EXENTA, DE 2014</div></div>", "i": 9476909}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta se ha modificado la r<a href=\"https://www.leychile.cl/Navegar?idNorma=1017805&amp;idParte=&amp;idVersion=\">esoluci&#xF3;n exenta N&#xBA; 7.179, de 2009, del Ministerio de Educaci&#xF3;n</a>, que aprobaron planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Colegio San Agust&#xED;n, comuna de &#xD1;u&#xF1;oa, provincia de Santiago, Regi&#xF3;n Metropolitana.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas especiales de estudio de los Sectores de Filosof&#xED;a (1&#xBA; y 2&#xBA; a&#xF1;o) y de Antropolog&#xED;a y Moral (1&#xBA; a 4&#xBA; a&#xF1;o) de Educaci&#xF3;n Media.</div></div>", "i": 9476910}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de mayo de 2014.- Gonzalo Mu&#xF1;oz Stuardo, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 9476911}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3112 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3112 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.112 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-05-23", "doble_articulado": false, "id_norma": "1062830", "numero_fuente": "40869", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-05-30", "vigencias": [{"de