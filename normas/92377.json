{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION QUE INDICA </div></div>", "i": 8561208}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.949, de 12 de diciembre de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, der&#xF3;gase la Resoluci&#xF3;n No. 453, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don Carlos Ignacio Kuschel Silva, R.U.T. No. 6.545.536-6, domiciliado en Vista Hermosa No. 25, Llanquihue, para desarrollar actividades pesqueras de cultivo, por renuncia de su titular.</div><br></div>", "i": 8561209}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 12 de Diciembre de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8561210}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1949", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1949"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "DEROGA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-12-12", "doble_articulado": false, "id_norma": "92377", "numero_fuente": "33555", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-12-27", "vigencias": [{"desde": "1989-12-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-12-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-12-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1998-02-27", "fecha_version": "1989-12-27", "fec