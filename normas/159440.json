{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 42, DE 2000</div><br><br></div>", "i": 6245060}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA;42, de 27 de enero de 2000, se ha aprobado el convenio de fecha 30 de diciembre de 1999, celebrado entre el Ministerio de Educaci&#xF3;n y la I. Municipalidad de Panguipulli, que rectifica el convenio de traspaso de la Escuela B&#xE1;sica G N&#xBA;1137 de Panguipulli, traspasada a dicha Corporaci&#xF3;n por convenio aprobado por decreto supremo de Educaci&#xF3;n N&#xBA;2.127, de 20 de abril de 1981.</div><br></div>", "i": 6245061}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de febrero de 2000.- Juan Eduardo Garc&#xED;a-Huidobro Saavedra, Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 6245062}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "42", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-42"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 42, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-27", "doble_articulado": false, "id_norma": "159440", "numero_fuente": "36603", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-02", "vigencias": [{"desde": "2000-03-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "2000-03-02", "fecha_ve