{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6588813}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.734 de 25 de septiembre de 2006 de esta Subsecretar&#xED;a, autor&#xED;zase a JORGE WASHINGTON ROJAS PE&#xD1;A, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Las Ca&#xF1;as Sur, comuna de Illapel, IV Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Alga Seca y Alga Picada los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA;2.027 de 2006, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6588814}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de septiembre de 2006.- Mar&#xED;a Ang&#xE9;lica Barbieri Bellolio, Subsecretaria de Pesca (S). </div></div>", "i": 6588815}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2734 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2734 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-09-25", "doble_articulado": false, "id_norma": "254997", "numero_fuente": "38610", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-11-10", "vigencias": [{"desde": "2006-11-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-11-10", "fin_vigencia": ""}, "vigenc