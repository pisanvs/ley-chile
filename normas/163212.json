{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6257719}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 5, de 31 de Octubre de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n, se autoriza a don Ren&#xE9; Emilio Puig Echavarri para efectuar las revisiones t&#xE9;cnicas de los veh&#xED;culos de transporte de personas de m&#xE1;s de nueve (9) asientos, incluido el del conductor; de los veh&#xED;culos motorizados de carga con capacidad para transportar m&#xE1;s de 1.750 kilos, sus remolques y semirremolques y los taxis, en el establecimiento ubicado en calle Rancagua No. 1659, de la ciudad de Temuco.</div><br></div>", "i": 6257720}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Temuco, 31 de Octubre de 1985.- Oscar C&#xF3;rdova Jim&#xE9;nez, Secretario Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n.</div><br></div>", "i": 6257721}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-10-31", "doble_articulado": false, "id_norma": "163212", "numero_fuente": "32318", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-11-11", "vigencias": [{"desde": "1985-11-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-11