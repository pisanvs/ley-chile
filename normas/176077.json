{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA </div></div>", "i": 6302530}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n ministerial N&#xBA; 75, de fecha 4 de agosto de 2000, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la Personalidad Jur&#xED;dica de la &apos;&apos;Asociaci&#xF3;n Gremial de Taxis Colectivos N&#xBA; 85 La Florida Trinidad Plaza Bulnes San Mart&#xED;n&apos;&apos;, inscrita bajo el N&#xBA; 1.764 del Registro que para tal efecto lleva este Ministerio, por haberse configurado respecto de ella la causal de cancelaci&#xF3;n contemplada en el art&#xED;culo 18 N&#xBA; 2, letra d), del D.L. N&#xBA; 2.757, de 1979. </div></div>", "i": 6302531}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de agosto de 2000.- Alvaro D&#xED;az P&#xE9;rez, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 6302532}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "75", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-75"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-08-04", "doble_articulado": false, "id_norma": "176077", "numero_fuente": "36772", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-26", "vigencias": [{"desde": "2000-09-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-26", "fin_vigenci