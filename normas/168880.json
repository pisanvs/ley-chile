{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 119 EXENTO, DE 2000</div><br><br></div>", "i": 6275940}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 119, de fecha 10 de abril de 2000 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; el funcionamiento de una nueva carrera t&#xE9;cnica de nivel superior en el Instituto Profesional Ecacec, a contar del a&#xF1;o 1999 en la sede Central de Santiago:</div><div class=\"p\"> </div><div class=\"p\">Carrera : Contador General con menci&#xF3;n en Tributaria,</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; conducente al t&#xED;tulo de T&#xE9;cnico de Nivel Superior</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; de Contador General con menci&#xF3;n en Tributaria</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; (Ordinario N&#xBA;06/1057 del 28.04.99).</div><br></div>", "i": 6275941}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de mayo de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6275942}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "119 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-119 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 119 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-10", "doble_articulado": false, "id_norma": "168880", "numero_fuente": "36666", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-18", "vigencias": [{"desde": "2000-05-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"ini