{"html": [{"t": "<div><br><div class=\"p\">DECLARA CADUCIDAD TOTAL DE RESOLUCI&#xD3;N QUE SE&#xD1;ALA</div></div>", "i": 9708761}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.821, de 9 de junio de 2016, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad total de la <a href=\"https://www.leychile.cl/Navegar?idNorma=222683&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 556, de 2004</a>, que autoriz&#xF3; a Corpesca S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Cami&#xF1;a&quot;, respecto del recurso hidrobiol&#xF3;gico Jibia, en el &#xE1;rea mar&#xED;tima comprendida entre la XV a II Regiones y XIV a X Regiones, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 9708762, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de junio de 2016.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9708763}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1821 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1821 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DECLARA CADUCIDAD TOTAL DE RESOLUCIÓN QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1034411; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-06-09", "doble_articulado": false, "id_norma": "1091669", "numero_fuente": "41485", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-06-16", "vigencias": [{"desde": "2016-06-16", "hasta": "", "tipo_v