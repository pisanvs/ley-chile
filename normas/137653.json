{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,665.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6172798}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Emilia Leal v. de Letelier, madre del teniente de Ej&#xE9;rcito don Miguel Emilio Letelier, muerto a consecuencia de heridas que recibi&#xF3; en la batalla de Miraflores, derecho a disfrutar de la correspondiente pension de montep&#xED;o militar. </div></div>", "i": 6172799}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, veintidos de julio de mil novecientos doce.- Ramon Barros Luco.- Luis Devoto.</div><br></div>", "i": 6172800}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2665", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2665"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-07-22", "doble_articulado": false, "id_norma": "137653", "numero_fuente": "10334", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-07-23", "vigencias": [{"desde": "1912-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-07-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-07-23", "fin_vigencia": "", "tipo_version": "3"}], "evento