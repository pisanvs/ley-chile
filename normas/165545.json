{"html": [{"t": "<div><div class=\"p\">AUTORIZA A SALMONES ANTARTICA LTDA., PARA AMPLIAR ACTIVIDADES PESQUERAS </div></div>", "i": 7267620}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 633,de 31 de Diciembre de 1984, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Salmones Ant&#xE1;rtica Ltda., para instalar y operar un establecimiento de cultivo de salm&#xF3;n coho, en Chauquitad, Isla de Quinchao, X Regi&#xF3;n. en porciones de agua para dos m&#xF3;dulos de 24 balsas-jaula cada uno, los que ser&#xE1;n fondeados en el lugar correspondiente a las siguientes coordenadas: L. 42&#xB0;25&apos;15&apos;&apos; S., G. 73&#xB0;38&apos;7&quot; W. </div></div>", "i": 7267621}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de Diciembre de 1984.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7267622}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "633", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-633"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A SALMONES ANTARTICA LTDA., PARA AMPLIAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-12-31", "doble_articulado": false, "id_norma": "165545", "numero_fuente": "32066", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-01-09", "vigencias": [{"desde": "1985-01-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-01-09", "fin_vigencia": ""}, "vigencias_version_norma":