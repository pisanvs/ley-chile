{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 952 EXENTO, DE 1997</div><br><br><br></div>", "i": 6047432}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 952 de fecha 3 de septiembre de 1997 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; al Centro de Formaci&#xF3;n T&#xE9;cnica ACES, el plan y programas de estudios de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida en la sede central de Limache, a contar del a&#xF1;o 1997:</div><div class=\"p\">&nbsp; &nbsp;  Carrera: Administraci&#xF3;n de Empresas.</div><div class=\"p\">&nbsp; &nbsp;  T&#xED;tulo: T&#xE9;cnico de Nivel Superior en Administraci&#xF3;n de Empresas.</div><div class=\"p\">&nbsp; &nbsp;  La carrera antes mencionada pasar&#xE1; a formar parte del proyecto institucional del Centro de Formaci&#xF3;n T&#xE9;cnica ACES, correspondiendo al Ministerio de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo. </div></div>", "i": 6047433}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de octubre de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6047434}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "952 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-952 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 952 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO DE FORMACION TECNICA", "ACES", "PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "LIMACHE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-09-03", "fecha_derogacion": "2002-02-04", "doble_articulado": false, "id_norma": "763