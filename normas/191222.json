{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6355579}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.439, de 28 de septiembre de 2001, se expropiaron los lotes de terreno N&#xBA;s. 112, 114, 115, 117, 118, 119 y 120, superficies 3.315,45 m2, 3.675,03 m2, 3.685,89 m2, 40.860,37 m2, 1.575,52 m2, 24.249,53 m2 y 2.246,88 m2, respectivamente, roles de aval&#xFA;o 1238-6, 1238-1, 1238-11 y en tr&#xE1;mite, comuna de Pichilemu, VI Regi&#xF3;n, para la obra &quot;Camino Costero Pichilemu-Iloca, sector Puente Cahui y Accesos&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Liliana Ester N&#xFA;&#xF1;ez Henr&#xED;quez, Mar&#xED;a Soledad Araneda N&#xFA;&#xF1;ez, Ricardo Antonio Araneda N&#xFA;&#xF1;ez e Inmobiliaria San Pedro de Alc&#xE1;ntara S.A., ascendente a la cantidad de $509.423.816.-</div><br></div>", "i": 6355580}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6355581}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1439", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1439"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-09-28", "doble_articulado": false, "id_norma": "191222", "numero_fuente": "37100", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-02", "vigencias": [{"desde": "2001-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia":