{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6481608}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 324, de 27 de abril de 2004, se rectific&#xF3; el numeral 6&#xBA; , del decreto MOP N&#xBA; 143, de 27 de febrero de 2004, en lo que respecta a la suma total del valor imputado para los lotes expropiados N&#xBA; 46, 47, 60, 61 y 81-A, que es Cincuenta y Siete Millones Doscientos Doce Mil Seiscientos Setenta y Cuatro Pesos ($57.212.674). La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 21. </div></div>", "i": 6481609}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "324", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-324"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-27", "doble_articulado": false, "id_norma": "225892", "numero_fuente": "37874", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-01", "vigencias": [{"desde": "2004-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JRC", "fecha_ingreso": "2004-06-01", "fecha_version": "2004-06-01", "fecha_actualizacion_texto": "2004-06-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura":