{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6437572}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 679 de fecha 30 de junio del 2003, se expropi&#xF3; el lote de terreno N&#xBA; 86, superficie 1.951 m&#xB2;, rol N&#xBA; 277-202, comuna de Pelluhue, VII Regi&#xF3;n para la obra &quot;Camino Chovellen - Cobquecura, Sector Chovellen - L&#xED;mite Regional, Tramo Km. 18,260.00 a Km.</div><div class=\"p\">35,158.60&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Leopoldo V&#xE1;squez Pav&#xE9;s, ascendente a la cantidad de $11.986.371.</div><br></div>", "i": 6437573}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6437574}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "679", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-679"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-30", "doble_articulado": false, "id_norma": "214153", "numero_fuente": "37649", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-01", "vigencias": [{"desde": "2003-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2003-09-01", "fecha_version": "2003-09-01", "fecha_actualizacion_texto": "2003-09-01", "tipo_tratado": ""}, "al