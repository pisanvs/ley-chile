{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO No. 880/87 </div></div>", "i": 8677213}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Alcaldicio No. 1131 de 10 de Septiembre de 1987 se modifica el Decreto No. 880 de 03.08.87 que ordeno la expropiaci&#xF3;n, por causa de utilidad p&#xFA;blica, de los terrenos necesarios para la apertura y/o ensanche de la calle Manuel Rodr&#xED;guez, en la forma que a continuaci&#xF3;n se indica:</div><div class=\"p\">&nbsp; &nbsp;  Al final del punto No. 2 se reemplaza: &quot;1.500 m2 de terreno&quot; por &quot;615 m2 de terreno&quot;.</div><br></div>", "i": 8677214}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  ALCALDE </div></div>", "i": 8677215}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1131", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1131"}], "organismos": ["MUNICIPALIDAD DE RENCA"], "titulo_norma": "MODIFICA DECRETO No. 880/87", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-10", "doble_articulado": false, "id_norma": "151962", "numero_fuente": "32871", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-15", "vigencias": [{"desde": "1987-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-01-24", "fecha_version": "1987-09-15", "fecha_actualizacion_texto": "1987-09-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estr