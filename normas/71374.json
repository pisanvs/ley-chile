{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6036813}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 320, de 31 de marzo de 1997, se expropiaron los lotes de terreno N&#xBA;s 83, 91 y 117, superficies 4.514 m2., 3.766 m2. y 8.379 m2., roles de aval&#xFA;o 2224-534, 2224-222 y 2236-127, comuna de Chill&#xE1;n, para la obra Camino Acceso Norte a Concepci&#xF3;n, y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Mario S&#xE1;nchez Robles y Amanda Puentes Inostroza y otra, ascendente a las cantidades de $8.911.992.- para los lotes N&#xBA;s 83 y 91, y $6.154.327.- para el lote N&#xBA; 117.- </div></div>", "i": 6036814}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6036815}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "320", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-320"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "CHILLAN", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-31", "doble_articulado": false, "id_norma": "71374", "numero_fuente": "35766", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-15", "vigencias": [{"desde": "1997-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "GMR", "fecha_ingreso": "1