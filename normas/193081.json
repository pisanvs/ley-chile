{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6363140}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.543, de 20 de diciembre de 2001, de esta Subsecretar&#xED;a, modif&#xED;case la resoluci&#xF3;n N&#xBA;2.019 de 2001, de esta Subsecretar&#xED;a, que autoriz&#xF3; a BUENA PESCA S.A. para iniciar actividades extractivas con una embarcaci&#xF3;n en construcci&#xF3;n, en el sentido de se&#xF1;alar que las caracter&#xED;sticas n&#xE1;uticas de la nave autorizada son las siguientes:</div><br><div class=\"p\">Nombre&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Nicomar</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  3028</div><div class=\"p\">TRG (Nacional)&nbsp; &nbsp; &nbsp; 66,00</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; 13,4 m</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  7,31 m</div><div class=\"p\">Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 3,05 m</div><div class=\"p\">Arte de pesca&nbsp; &nbsp; &nbsp;  Espinel, arrastre y trampas.</div><br></div>", "i": 6363141}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de diciembre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6363142}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2543", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2543"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-12-20", "fecha_derogacion": "2006-12-02", "doble_articulado": false, "id_norma": "19