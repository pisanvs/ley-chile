{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO NUMERO 525 EXENTO, DE 1997 </div></div>", "i": 6039173}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 525 de</div><div class=\"p\">13 de mayo de 1997, se ha aprobado, a contar del a&#xF1;o</div><div class=\"p\">escolar 1997, un plan de estudio para 3&#xBA; y 4&#xBA; a&#xF1;o de</div><div class=\"p\">Ense&#xF1;anza Media Human&#xED;stico-Cient&#xED;fica al Colegio</div><div class=\"p\">&quot;Tabancura&quot; de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio de las</div><div class=\"p\">asignaturas del Plan Com&#xFA;n: Historia Universal,</div><div class=\"p\">Doctrinas Sociales y las del Plan Electivo: Geograf&#xED;a</div><div class=\"p\">General, Historia General, Cultura Cl&#xE1;sica, Historia del</div><div class=\"p\">Arte, Redacci&#xF3;n y Literatura, Matem&#xE1;tica Espec&#xED;fica, Biolog&#xED;a Espec&#xED;fica, F&#xED;sica Matem&#xE1;tica y Matem&#xE1;tica Comercial.</div><br></div>", "i": 6039174}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de mayo de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6039175}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "525 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-525 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO NUMERO 525 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIO TABANCURA", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-05-13",