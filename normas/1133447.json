{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  PROFESIONES RELIJIOSAS.</div><br><br><div class=\"p\">&nbsp; &nbsp;  EL DIRECTOR SUPREMO DEL ESTADO &amp;c.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto de acuerdo con el Senado Conservador, he decretado:</div></div>", "i": 10037618}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Que ningun habitante de Chile subdito del Gobierno pueda hacer profesion solemne de perpetuo monaquismo antes de haber cumplido 25 a&#xF1;os de edad.</div></div>", "i": 10037619}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por tanto ordeno que se publique por lei insert&#xE1;ndose en el Boletin. Dado en el Palacio Directorial de Santiago a 21 de Julio de 1823.</div><br><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Mariano de Ega&#xF1;a.</div></div>", "i": 10037620}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["DEPARTAMENTO DE GOBIERNO Y RELACIONES EXTERIORES"], "titulo_norma": "PROFESIONES RELIJIOSAS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-07-24", "doble_articulado": false, "id_norma": "1133447", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-07-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-07-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-07-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "201