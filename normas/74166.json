{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8304493}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 934, de 1&#xBA; de julio de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad parcial de la Resoluci&#xF3;n N&#xBA; 771, de 1993 de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA CORONEL S.A., para desarrollar actividades pesqueras extractivas con la nave &quot;Antarctic&quot;, en lo relativo a las especies: Anchoveta, Caballa, Cojinoba del norte, Cojinoba del sur, Corvina, Jurel, Sardina com&#xFA;n y Sardina espa&#xF1;ola.</div><br></div>", "i": 8304494}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1&#xBA; de julio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8304495}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "934", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-934"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD PARCIAL", "AUTORIZACION", "PESQUERA CORONEL S.A.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-01", "doble_articulado": false, "id_norma": "74166", "numero_fuente": "35812", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-07-10", "vigencias": [{"desde": "1997-07-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-07-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-07-10", "fin_vigencia": "", "