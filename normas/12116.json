{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5906044}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto M.O.P. N&#xB0;300, de 23 de septiembre de 1993, se expropiaron los lotes de terreno N&#xB0;s. 10, 11, 33, 34, 50 y 59, superficies 54 M2., 500 M2., 1.750 M2., 2.440 M2., 230 M2. y 380 M2., respectivamente, roles de aval&#xFA;os en tr&#xE1;mite, 149-50, 35-20, 36-35 y 37-30, Comunas de Nancagua y Ch&#xE9;pica, para la obra Camino Nancagua Puquillay-Ch&#xE9;pica, y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Luis Albornoz Godoy, Jos&#xE9; Albornoz Parraguez, Mar&#xED;a Auger Saavedra y otros, Alicia Arru&#xE9; Ram&#xED;rez y Luis Valenzuela Fredes, ascendente a las cantidades de $496.742, $662.400, $2.136.960, $188.928 y $355.968.</div><br></div>", "i": 5906045}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 5906046}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "300", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-300"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BIEN INMUEBLE", "EXPROPIACION", "NANCAGUA", "CHEPICA", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-09-23", "doble_articulado": false, "id_norma": "12116", "numero_fuente": "34705-2", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-11-02", "vigencias": [{"desde": "1993-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-11-02", "fin_vigencia