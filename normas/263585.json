{"html": [{"t": "<div><div class=\"p\">SUPRIME EL IMPUESTO QUE SE&#xD1;ALA</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 12,061.- Santiago, 7 de Agosto de 1959.- Vistos: el oficio N.o 1,476, de 14 de Julio en curso, del Ministerio de Econom&#xED;a, y lo preceptuado en el inciso primero del art&#xED;culo 163 de la ley N.o 13,305, </div><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 7350241}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Susp&#xE9;ndese, a contar desde esta fecha y hasta el 31 de Diciembre de 1959, el impuesto de 3% establecido en el art&#xED;culo 2.o del decreto de Hacienda N.o 2,772, de 1943, que fij&#xF3; el texto refundido de la ley 6,915, modificado por las leyes 8,040 y 8,918, que afecta a la carne de vacuno congelada, oreada y/o enfriada que se afora por la partida 184 del Arancel Aduanero. </div></div>", "i": 7350242}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- J. ALESSANDRI R.- R. Vergara H.</div><br></div>", "i": 7350243}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "24437", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-24437"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "SUPRIME EL IMPUESTO QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1959-08-07", "doble_articulado": false, "id_norma": "263585", "numero_fuente": "23507", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1959-09-07", "vigencias": [{"desde": "1959-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1959-09-07", "fin_vigencia": ""}, "vigencias_ver