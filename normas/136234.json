{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,466.- Santiago, 21 de junio de 1901.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 7248462}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Agr&#xE9;gase a los art&#xED;culos declarados libres de derechos de internacion por el art&#xED;culo 7&#xBA; de la lei n&#xFA;mero 980, de 23 de diciembre de 1897, el esplosivo denominado &quot;Dinamita&quot;.</div><br></div>", "i": 7248463}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- ANIBAL ZA&#xD1;ARTU.- Juan Luis Sanfuentes.</div><br></div>", "i": 7248464}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1466", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1466"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-06-21", "doble_articulado": false, "id_norma": "136234", "numero_fuente": "6924", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-06-27", "vigencias": [{"desde": "1901-06-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1901-0