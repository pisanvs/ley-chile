{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO NUMERO 149 EXENTO, DE 1994 </div><br></div>", "i": 8969050}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Supremo Exento de Educaci&#xF3;n N&#xB0; 149 de 5 de Abril de 1994, se ha aprobado, a contar del a&#xF1;o escolar 1994, planes y programas especiales de estudio para los Colegios que se indican en el presente decreto, que los aplicar&#xE1;n a partir del a&#xF1;o escolar que se se&#xF1;ala, petenecientes a la Congregaci&#xF3;n de las Hermanas de la Caridad Cristiana, Hijas de la Bienaventurada Virgen Mar&#xED;a de la Inmaculada Concepci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio de las asignaturas contempladas en el plan de estudio aprobados por los art&#xED;culos 2&#xB0; y 3&#xB0; del citado decreto.</div><br><br></div>", "i": 8969051}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 19 de Abril de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8969052}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "149 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-149 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO NUMERO 149 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "ESTABLECIMIENTOS EDUCACIONALES", "CONGREGACION HERMANAS", "CARIDAD CRISTIANA", "HIJAS BIENAVENTURADA VIRGEN MARIA", "INMACULADA CONCEPCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-04-05", "doble_articulado": false, "id_norma": "20425", "numero_fuente": "34850", "tipo_version": "3", "tipo_version_s": "Únic