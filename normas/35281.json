{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293497}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 641, de 10 de abril de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por treinta d&#xED;as corridos, a contar de la fecha de publicaci&#xF3;n de la presente Resoluci&#xF3;n, el plazo otorgado a PESQUERA LOA NORTE S.A., para continuar desarrollando actividades pesqueras extractivas autorizadas mediante Resoluci&#xF3;n N&#xB0; 543, de 1988, de esta Subsecretar&#xED;a, s&#xF3;lo en lo relativo a las naves &quot;Loa 2&quot;, &quot;Loa 3&quot;, &quot;Loa 4&quot; y &quot;Loa 5&quot;, por haberse acreditado la existencia de fuerza mayor. </div></div>", "i": 8293498}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 10 de abril de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293499}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "641", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-641"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA LOA NORTE S.A.", "PESCA", "AMPLIACION", "PLAZO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-04-10", "fecha_derogacion": "2002-11-07", "doble_articulado": false, "id_norma": "35281", "numero_fuente": "35461", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-05-08", "vigencias": [{"desde": "2002-11-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1996-05-08", "hasta": "2002-11-06", "t