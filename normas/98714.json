{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 338 EXENTO, DE 1998</div><br><br></div>", "i": 7232721}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA;338, de 2 de febrero de 1998, se ha aprobado al Colegio &quot;The Mackay School&quot; de Vi&#xF1;a del Mar, un plan de estudio biling&#xFC;e para los cursos de 5&#xBA;, 6&#xBA;, 7&#xBA; y 8&#xBA; a&#xF1;o (NB.3, NB.4, NB.5 y NB.6) de Ense&#xF1;anza B&#xE1;sica, que se aplicar&#xE1; de acuerdo con lo se&#xF1;alado en el decreto supremo de Educaci&#xF3;n N&#xBA;40 de 1996 y sus modificaciones.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican, cuya ense&#xF1;anza se impartir&#xE1; en idioma ingl&#xE9;s, con la excepci&#xF3;n de las asignaturas de Castellano e Historia y Geograf&#xED;a de Chile.</div><br></div>", "i": 7232722}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de febrero de 1998.- Juan Eduardo Garc&#xED;a-Huidobro S., Subsecretario de Educaci&#xF3;n (S). </div></div>", "i": 7232723}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "338 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-338 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 338 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIO THE MACKAY SCHOOL", "VI A DEL MAR", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-02-02", "doble_articulado": false, "id_norma": "98714", "numero_fuente": "36057", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicac