{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6464064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 301, de 28 de enero de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA LOTA VEDDE LIMITADA ARIES Y COMPA&#xD1;&#xCD;A C.P.A., para ampliar actividades pesqueras extractivas con la nave &quot;La Ni&#xF1;a I&quot;, por fuera del &#xE1;rea de reserva artesanal, en el &#xE1;rea mar&#xED;tima correspondiente al litoral de la V a VII y IX a X Regiones, donde podr&#xE1; capturar, con cerco, los recursos hidrobiol&#xF3;gicos Cojinoba del sur y Jibia. </div></div>", "i": 6464065}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de enero de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6464066}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "301", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-301"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-01-28", "fecha_derogacion": "2005-02-21", "doble_articulado": false, "id_norma": "221111", "numero_fuente": "37784", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-02-12", "vigencias": [{"desde": "2005-02-21", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-02-12", "hasta": "2005-02-20", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2005-02-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-02-12", "fin_v