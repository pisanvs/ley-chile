{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6220698}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 1.304 de 29 de Julio de 1987, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos de Aprovechamiento Aguas proporcionales que corresponden a Sector Excluido y Sector expropiado Predio &quot;Kilmen&quot;, de la comuna de San Nicol&#xE1;s, VIII Regi&#xF3;n; y Derechos Aprovechamiento Aguas que corresponden a parcelas N&#xB0;s 1 a la 7 y sitios N&#xB0;s 1 al 10 del Proyecto de Parcelaci&#xF3;n &quot;Kilmen&quot;, formado por predio se&#xF1;alado. Los Derechos de Agua se extraen de los canales Fundo Lur&#xED;n, Santa Rosa y Monte Blanco, todos derivados del r&#xED;o &#xD1;uble.</div><div class=\"p\">Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.-</div><br></div>", "i": 6220699}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6220700}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1304 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1304 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-29", "doble_articulado": false, "id_norma": "151760", "numero_fuente": "32835", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-01", "vigencias": [{"desde": "1987-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única