{"html": [{"t": "<div><br><div class=\"p\">DERECHOS DE AGUA EN COMUNA DE TIL-TIL</div></div>", "i": 9609563}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xBA; 2.910, del 24 de abril de 2015, conforme art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, complement&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1074443&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 9.220</a>, de 16 de diciembre de 2014, que determin&#xF3; que los derechos de aprovechamiento de agua de los sectores efectivamente expropiado y reconocido como Reserva, del predio denominado &quot;Resto del Fundo San Manuel&quot; de la comuna de Til-Til, Regi&#xF3;n Metropolitana, son de car&#xE1;cter permanente.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13&#xBA; ley N&#xBA; 18.377.</div></div>", "i": 9609564}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director Nacional.</div></div>", "i": 9609565}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2910 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2910 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUA EN COMUNA DE TIL-TIL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-04-24", "doble_articulado": false, "id_norma": "1078481", "numero_fuente": "41183", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-06-15", "vigencias": [{"desde": "2015-06-15", "hasta": "", "tipo_version": "3", "tipo_ve