{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8811675}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (exento) N&#xBA;1903 de fecha 30 de octubre de 2009, se expropiaron los lotes de terreno N&#xBA;s 130-H y 132-D superficies 70 y 81 m2 respectivamente, rol N&#xBA;3400-34, comuna de Puerto Montt, para la obra &quot;Mejoramiento Ruta 7, Sector Quillaipe - La Arena, tramo Km. 15,84700 a Km. 40,41746&quot;, Provincia de Llanquihue, X Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario LUCIA DEL CARMEN MILLAR SOTO, ascendente a la cantidad de $791.597.- </div><br></div>", "i": 8811676}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 8811677}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1903 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1903 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-10-30", "doble_articulado": false, "id_norma": "1008625", "numero_fuente": "39525", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-12-01", "vigencias": [{"desde": "2009-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "3721", "fecha_ingreso": "2009-12-02", "fecha_version": "2009-12-01", "actualizado_por": "3721", "fe