{"html": [{"t": "<div><div class=\"p\">&#xA0;</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 283.- Santiago, 21 de marzo de 1918.- Vistos estos antecedentes,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 7375931}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  1.&#xB0; Conc&#xE9;dece personalidad jur&#xED;dica a&nbsp; la corporacion denominada &quot;Mutualidad de Carabineros, del departamento de Santiago.</div><br><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; Apru&#xE9;banse los estatutos por que ha de regirse dicha corporacion que constan de la escritura p&#xFA;blica que se acompa&#xF1;a, otorgada en Santiago el 12 diciembre de 1917, ante el notario p&#xFA;blico, Don Pedro N. Cruz.</div><br><br></div>", "i": 9852265}, {"t": "<div><br><br><br><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, comun&#xED;quese publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- Sanfuentes.- Pedro Aguirre Cerda.</div><br><br></div>", "i": 9852266}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "283", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-283"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1918-03-21", "doble_articulado": false, "id_norma": "274481", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1918-03-25", "vigencias": [{"desde": "1918-03-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1918-03-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1918-03-25", "fin_vigencia": "", "tipo_version": "3