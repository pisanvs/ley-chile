{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ACU&#xD1;ACION DE MONEDA DE VELLON Lei n&#xFA;m. 319.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947509}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para acu&#xF1;ar hasta la cantidad de cien mil pesos ($ 100,000) en moneda de vellon de dos i medio centavos i hasta cincuenta mil pesos ($ 50,000) en moneda de vellon de un centavo, i para adquirir las pastas necesarias.</div><br><br></div>", "i": 5947510}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 13 de Diciembre de 1895.-JORJE MONTT.-</div><div class=\"p\">H. P&#xE9;rez de Arce.</div><br></div>", "i": 5947511}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "319", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-319"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ACUÑACION DE MONEDA DE VELLON", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MONEDA VELLON", "ACU ACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-12-13", "doble_articulado": false, "id_norma": "22170", "numero_fuente": "5285", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-12-14", "vigencias": [{"desde": "1895-12-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-12-14", "fin_vigencia": ""}, "vigencias_vers