{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7269844}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 450, de 12 de Abril de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 3&#xB0; de la Resoluci&#xF3;n No. 1331, de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a AGRICOLA Y FORESTAL Y PESQUERA IBAR Y ABAD, RUT No.</div><div class=\"p\">79.504.690-9, domiciliada en Constituci&#xF3;n, para iniciar actividades pesqueras, en el sentido de incluir la autorizaci&#xF3;n para extraer con la nave &quot;Brisa&quot; el recurso Albacora o pez espada (Xiphias gladius), en el litoral de las Regiones I a X, con el arte de pesca enmalle. </div></div>", "i": 7269845}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de Abril de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 7269846}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "450", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-450"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-04-12", "fecha_derogacion": "2002-03-08", "doble_articulado": false, "id_norma": "168840", "numero_fuente": "33951", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-04-24", "vigencias": [{"desde": "2002-03-08", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1991-04-24", "hasta": "2002-03-07", "tipo_version": "0", "tipo_version_s": "