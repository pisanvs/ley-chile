{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DELEGA EN FUNCIONARIOS QUE INDICA FACULTAD QUE SE&#xD1;ALA </div></div>", "i": 6024292}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Mediante Resoluci&#xF3;n Ex. N&#xB0; 1.139 de 20 de Abril de 1995, el suscrito deleg&#xF3; en funcionarios que en la ya citada Resoluci&#xF3;n se individualizan, la facultad de autorizar las disminuciones de capital solicitadas por las Sociedades, de conformidad a lo dispuesto en el inciso final del art&#xED;culo 69&#xB0; del C&#xF3;digo Tributario, todo ello, de acuerdo a Resoluci&#xF3;n Ex. N&#xB0; 394 de 23 de Enero de 1995 del se&#xF1;or Director del Servicio, que autoriza a delegar en los funcionarios que se&#xF1;ala dicha facultad.-</div><br></div>", "i": 6024293}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Carlos Elgueda V&#xE1;squez, Director Regional (S). </div></div>", "i": 6024294}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1139", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1139"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DELEGA EN FUNCIONARIOS QUE INDICA FACULTAD QUE\nSEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DELEGACION", "FACULTAD", "SERVICIO IMPUESTOS INTERNOS", "DIRECCION REGIONAL", "SEGUNDA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-04-20", "doble_articulado": false, "id_norma": "39553", "numero_fuente": "35157", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-05-03", "vigencias": [{"desde": "1995-05-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-05-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "19