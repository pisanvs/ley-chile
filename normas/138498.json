{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,097.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6175567}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados por el teniente don Alfredo Valdes, muerto en la batalla de Chorrillos, se concede a su hermana do&#xF1;a Delia Valdes v. de Garc&#xED;a el derecho de gozar de una pension de trescientos sesenta pesos ($ 360), de la cual disfrutar&#xE1; con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6175568}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a diez de mayo de mil novecientos dieciseis.- Juan Luis Sanfuentes.- Cornelio Saavedra.</div><br></div>", "i": 6175569}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3097", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3097"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-05-10", "doble_articulado": false, "id_norma": "138498", "numero_fuente": "11469", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-05-11", "vigencias": [{"desde": "1916-05-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1916-05-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1916-05-1