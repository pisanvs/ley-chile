{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Publicaciones Universitarias Lei n&#xFA;m. 1,314.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 9042104}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que invierta hasta la suma de diez mil pesos en la impresion de los Anales de la Universidad i demas publicaciones universitarias.</div><br><br></div>", "i": 9042105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 30 de Diciembre de 1899.- FEDERICO ERRAZURIZ.- Francisco J. Herboso.</div><br></div>", "i": 9042106}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1314", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1314"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "PUBLICACIONES UNIVERSITARIAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ANALES DE LA UNIVERSIDAD", "IMPRESION", "INVERSION", "AUTORIZACION", "PRESIDENTE REPUBLICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-12-30", "doble_articulado": false, "id_norma": "22550", "numero_fuente": "6487", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-01-03", "vigencias": [{"desde": "1899-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-01-03", "fin_vigencia": ""}, "vigencias_vers