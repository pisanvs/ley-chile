{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE DECLARA AREA DE PLAGA QUE INDICA</div></div>", "i": 9664614}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.709, 31 de diciembre de 2015, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1075544&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 659, de 2015</a>, de esta Subsecretar&#xED;a, que declar&#xF3; &#xE1;reas de plaga y de riesgo de plaga de la especie Didymosphenia geminata, en los sectores de cuerpos de aguas, ampli&#xE1;ndolos a nuevas cuencas en la IX, XIV, X, XI y XII regiones, en la forma que se indica en la resoluci&#xF3;n extractada, y publicada &#xED;ntegramente en la p&#xE1;gina web www.subpesca.cl.</div></div>", "i": 9664615, "v": ["MODIFICACION"]}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de diciembre de 2015.- Paolo Trejo Carmona, Subsecretario de Pesca y Agricultura (S).</div></div>", "i": 9664616}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3709 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3709 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE DECLARA AREA DE PLAGA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; IdDO 985051"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-12-31", "doble_articulado": false, "id_norma": "1086275", "numero_fuente": "41352", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-01-09", "vigencias": [{"desde": "2016-01-09", "hasta": "", "tipo_version": "3", "