{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10257447}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xBA; 1.466, de 30 de julio de 2021, modifica la <a href=\"https://www.leychile.cl/Navegar?idNorma=1160858&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 988</a>, de fecha 28 de mayo de 2021, que determin&#xF3; el listado de prestaciones del Instituto de Salud P&#xFA;blica de Chile que se mantendr&#xE1;n suspendidas mientras dure la alerta sanitaria por la pandemia del virus Sars CoV-2.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10257448}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Heriberto Garc&#xED;a Escorza, Director (S) Instituto de Salud P&#xFA;blica de Chile.</div><div class=\"p\"> </div><br></div>", "i": 10257449}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1466 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1466 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": ["CORONAVIRUS COVID-19", "CORONAVIRUS", "COVID-19"], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1989320", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-07-30", "doble_articulado": false, "id_norma": "1163396", "numero_fuente": "43021", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-08-06", "vigencias": [{"desde": "2021-08-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "