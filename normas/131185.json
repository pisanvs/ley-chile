{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6152355}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 2.546, de 30 de noviembre de 1998, se expropiaron los lotes de terreno N&#xBA;s 11 y 12, superficies 473 y 319 m2, roles de aval&#xFA;o 436-6 y 436-7, comuna de Concepci&#xF3;n, Obra Mejoramiento Autopista Concepci&#xF3;n - Talcahuano, Sector Rotonda Bonilla y Campus San Andr&#xE9;s y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Alejandro Paredes y otros y Armando Faustino Tagle Far&#xED;as, ascendente a las cantidades de $ 48.819.085.- lote 11 y $ 23.768.552.- lote 12. </div></div>", "i": 6152356}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6152357}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2546", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2546"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-30", "doble_articulado": false, "id_norma": "131185", "numero_fuente": "36278", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-02-01", "vigencias": [{"desde": "1999-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-02-03", "fecha_version": "1999-02-01", "fecha_actualizacion_texto": "1999