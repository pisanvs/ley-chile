{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Permite la resistencia de los cuerpos del Ej&#xE9;rcito en el lugar de las sesiones del Congreso Nacional Lei n&#xFA;m. 3,169.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7166399}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Perm&#xED;tese, por el t&#xE9;rmino de un a&#xF1;o, la residencia del los Cuerpos del Ej&#xE9;rcito permanente, en el lugar de las sesiones del Congreso Nacional i en diez leguas a su circunferencia. </div></div>", "i": 7166400}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 29 de Diciembre de 1916.- JUAN LUIS SANFUENTES.- Oscar Urz&#xFA;a.</div><br></div>", "i": 7166401}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3169", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3169"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PERMITE LA RESISTENCIA DE LOS CUERPOS DEL EJERCITO EN EL LUGAR DE LAS SESIONES DEL CONGRESO NACIONAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONGRESO NACIONAL", "EJERCITO", "LUGAR SESIONES", "RESIDENCIA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-12-29", "doble_articulado": false, "id_norma": "23780", "numero_fuente": "11660", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-12-29", "vigencias": [{"desde": "1916-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1916-12-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1916-12-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-02-23", "fecha_version": "1916-12-29", "fecha_actualizacion_texto": "1916-12-29", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 7166399}, {"n": "Artículo UNICO", "i": 7166400, "t": 6}, {"n": "Promulgación", "i": 7166401}]}