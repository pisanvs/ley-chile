{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6276729}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 359 del 28 de Octubre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Primera Regi&#xF3;n, se autoriza a don Luis Alfredo Tapia Torres para efectuar el servicio de taxi colectivo urbano de pasajeros L&#xED;nea N&#xB0; 2 de Iquique, cuyo trazado fue autorizado por resoluci&#xF3;n N&#xB0; 101 del 06 de Julio de 1984, de esta Secretar&#xED;a Regional.</div><br></div>", "i": 6276730}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Eliecer Aedo Rivera, Secretario Regional Ministerial Transportes y Telecomunicaciones I Regi&#xF3;n Tarapac&#xE1;. </div></div>", "i": 6276731}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "359 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-359 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-10-28", "doble_articulado": false, "id_norma": "169136", "numero_fuente": "32913", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-06", "vigencias": [{"desde": "1987-11-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-11-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci