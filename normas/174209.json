{"html": [{"t": "<div><div class=\"p\">EXTRACTO </div></div>", "i": 6296479}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA; 47, de fecha 5 de mayo del a&#xF1;o 2000, se autoriz&#xF3; la existencia y se aprobaron los estatutos de la Cooperativa de Trabajo en Turismo Rural Ruta Huasa Limitada, en los t&#xE9;rminos que dan testimonio los instrumentos protocolizados con fecha 28 de septiembre de 1999, ante el Notario de Santiago, don Ra&#xFA;l Perry Pefaur; con fecha 4 de enero del a&#xF1;o 2000, ante el Notario de Santiago, don Alberto Moz&#xF3; Aguilar; y con fecha 4 de abril del a&#xF1;o 2000, ante el Notario de San Vicente de Tagua Tagua, don Andr&#xE9;s Sabal Tuma.</div><br></div>", "i": 6296480}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Sr. Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas.</div><br></div>", "i": 6296481}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "47", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-47"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-05", "doble_articulado": false, "id_norma": "174209", "numero_fuente": "36739", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-14", "vigencias": [{"desde": "2000-08-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig