{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 440 EXENTO, DE 1999</div><br><br></div>", "i": 6275657}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 440, de fecha 27 de diciembre de 1999, del Ministerio de Educaci&#xF3;n, se declar&#xF3; aprobado, a la Universidad Alberto Hurtado, el plan y los programas de estudios de la carrera de Derecho, conducente al grado acad&#xE9;mico de Licenciado en Ciencias Jur&#xED;dicas, para ser impartida en jornada diurna, en su sede de la ciudad de Santiago, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6275658}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de febrero de 2000.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6275659}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "440 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-440 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 440 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-27", "doble_articulado": false, "id_norma": "168784", "numero_fuente": "36664", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-16", "vigencias": [{"desde": "2000-05-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "J