{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><br></div>", "i": 7168595}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1.o Agr&#xE9;gase al Presupuesto de Gastos Fijos del Ministerio de Hacienda para 1928, el &#xED;tem siguiente</div><div class=\"p\"> &quot;Para sueldos del personal y dem&#xE1;s gastos</div><div class=\"p\"> que demande el funcionamiento de la</div><div class=\"p\"> Superintendencia de las Compa&#xF1;&#xED;as de</div><div class=\"p\"> Seguros__________________________________&nbsp;  $&nbsp; 585,000&quot;</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  ___________</div><div class=\"p\">&nbsp; &nbsp; Esta suma ser&#xE1; cubierta con la cuota con que deber&#xE1;n contribuir las Compa&#xF1;&#xED;as de Seguros y la Caja Reaseguradora de Chile, en conformidad a lo dispuesto en el art&#xED;culo 3.o de la ley n&#xFA;mero 4,228, de 20 de Diciembre de 1927.</div><br></div>", "i": 7168596}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 2.o Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial.&quot; </div></div>", "i": 7168597}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintisiete de Febrero de mil novecientos veintiocho.- Carlos Ib&#xE1;&#xF1;ez del Campo.- Pablo Ram&#xED;rez.</div><br></div>", "i": 7168598}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4316", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4316"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O", "1928", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-02-27", "doble_articulado": false, "id_norma": "24655", "numero_fuente": "15011", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-02-28", "vigencias": [{"desde": "1928-02-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-02-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1928-02-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JAM", "fecha_ingreso": "1999-03-09", "fecha_version": "1928-02-28", "fecha_actualizacion_texto": "1928-02-28", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 7168595}, {"n": "Artículo 1", "i": 7168596, "t": 6}, {"n": "Artículo 2", "i": 7168597, "t": 6}, {"n": "Promulgación", "i": 7168598}]}