{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 73.- Santiago, a 8 de Agosto de 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946676}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de un millon de pesos ($ 1.000,000) al &#xED;tem 1 de la partida 33 del Presupuesto del Ministerio de Marina, para la construccion del Dique de Talcahuano, autorizada por la lei de 1.&#xB0; de Febrero de 1888.</div><br><br></div>", "i": 5946677}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Vicente D&#xE1;vila Larrain.</div><br></div>", "i": 5946678}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "73", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-73"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1893", "MODIFICACION", "MINISTERIO", "MARINA", "DIQUE TALCAHUANO", "CONSTRUCCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-08-08", "doble_articulado": false, "id_norma": "21944", "numero_fuente": "4591", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-08-09", "vigencias": [{"desde": "1893-08-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-08-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-08-09", "