{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6229859}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la IX Regi&#xF3;n, por resoluci&#xF3;n No. 182, de 29 de Agosto de 1986, ha autorizado a don Osvaldo Alberto Jouannet Massicot para efectuar toda clase de servicios de transporte de pasajeros, por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos de locomoci&#xF3;n colectiva urbana, de acuerdo a lo dispuesto en el DS 163/84.</div><br></div>", "i": 6229860}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Temuco, 29 de Agosto de 1986.- Eduardo Zepeda Hauy&#xF3;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n subrogante.</div><br></div>", "i": 6229861}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "182", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-182"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-08-29", "doble_articulado": false, "id_norma": "154720", "numero_fuente": "32.570", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-09-10", "vigencias": [{"desde": "1986-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-09-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-09-10", "fin_vigencia": "", "ti