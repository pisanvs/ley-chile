{"html": [{"t": "<div><div class=\"p\">EMBARCO DE MOTORISTAS DE PESCA EN NAVES DE LA MARINA MERCANTE NACIONAL</div></div>", "i": 10209161}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n DGTM y MM Ordinario N&#xB0; 12600/01/189 Vrs., del 17 de febrero de 2021, autoriza el embarco de motoristas de pesca en naves de la marina mercante nacional.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.c1).</div><br><br><br></div>", "i": 10209162}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de marzo de 2021.- Por orden de Sr. Director General, Mauricio Arenas Menares, Capit&#xE1;n de Nav&#xED;o, Subdirector.- Cristi&#xE1;n Pfeifer Rojas, Capit&#xE1;n de Nav&#xED;o JT, Jefe Depto. Jur&#xED;dico.</div></div>", "i": 10271949}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "189", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-189"}, {"tipo": "3", "numero": "12600/01/189", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-12600/01/189"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "EMBARCO DE MOTORISTAS DE PESCA EN NAVES DE LA MARINA MERCANTE NACIONAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1908668", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-02-17", "doble_articulado": false, "id_norma": "1156873", "numero_f