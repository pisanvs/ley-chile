{"html": [{"t": "<div><div class=\"p\">AUTORIZA A DON JUAN ABELARDO GONZALEZ SANCHEZ PARA DESARROLLAR ACTIVIDADES PESQUERAS </div></div>", "i": 6259534}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 486, de 09 de Agosto de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a don Juan Abelardo Gonz&#xE1;lez S&#xE1;nchez, R.U.T. N&#xB0; 8.019.233-9, domiciliado en Cardenal N&#xB0; 39, Puerto Montt, para instalar y operar una planta de secado artificial de algas en el domicilio se&#xF1;alado. Las algas que utilizar&#xE1; como materia prima son: pelillo, luga, huiro y cochayuyo.</div><br></div>", "i": 6259535}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 09 de Agosto de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6259536}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "486", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-486"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A DON JUAN ABELARDO GONZALEZ SANCHEZ PARA\nDESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-08-09", "doble_articulado": false, "id_norma": "163809", "numero_fuente": "32253", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-08-21", "vigencias": [{"desde": "1985-08-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-08-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-08-21", "fin_v