{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7348245}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.957, de 3 de julio de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a YANET SOLEDAD TABILO TABILO, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Salala s/n&#xBA;, Ovalle, IV Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Fresco-Enfriado, Fresco-Refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 7348246}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de julio de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7348247}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1957 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1957 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-07-03", "doble_articulado": false, "id_norma": "262911", "numero_fuente": "38818", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-07-21", "vigencias": [{"desde": "2007-07-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-07-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-07-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2007-07-23", "fecha_