{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 134 EXENTA, DE 1997 </div></div>", "i": 8319190}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n ministerial exenta N&#xBA; 134 de fecha 26 de diciembre de 1997 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se ha dejado sin efecto la resoluci&#xF3;n ministerial exenta N&#xBA; 133, de fecha 11 de diciembre de 1996, publicada en el Diario Oficial de fecha 13 de enero de 1997, en virtud del fallo de la Exma. Corte&nbsp; Suprema dictado en el Recurso de Protecci&#xF3;n Rol 406-97.-</div><br></div>", "i": 8319191}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Oscar Landerretche Gacit&#xFA;a, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8319192}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "134 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-134 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 134 EXENTA, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECURSO DE PROTECCION", "PESQUERA COLOMBA S. A", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-26", "doble_articulado": false, "id_norma": "89583", "numero_fuente": "35974", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-26", "vigencias": [{"desde": "1998-01-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-01-26", "fin_vigencia": "", "tipo_ve