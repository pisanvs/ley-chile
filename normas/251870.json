{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6578084}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 359 de fecha 30 de junio del 2006, se expropi&#xF3; el lote de terreno N&#xBA; 103-B, superficie 268 m2, Rol N&#xBA; 305-238 comuna de Melipeuco, IX Regi&#xF3;n para la obra &quot;Camino Ruta S-61, sector: Cunco Melipeuco, tramo Km. 55,000 al Km. 87,46783, correspondiente al Sub-Tramo III Km. 76, 068 al Km.</div><div class=\"p\">87,443&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Jos&#xE9; Eleuterio Loncon S&#xE1;ez o Jos&#xE9; Eleuterio Loncon Saes, ascendente a la cantidad de $393.093.- para el lote N&#xBA;103-B.</div><br></div>", "i": 6578085}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras Publicas. </div></div>", "i": 6578086}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "359 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-359 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-30", "doble_articulado": false, "id_norma": "251870", "numero_fuente": "38528", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-08-01", "vigencias": [{"desde": "2006-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2006-08