{"html": [{"t": "<div><br><div class=\"p\">Contestacion</div><br></div>", "i": 9726147}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  S. E. ha recibido el oficio de US. que contiene la jenerosa oblacion de los escojidos vol&#xFA;menes que US. destina al enriquecimiento de la Biblioteca Nacional; por mi conducto da a US. S. E, las gracias orden&#xE1;ndome igualmente haga estampar en la Gaceta este rasgo recomendable i patri&#xF3;tico de US. para que el p&#xFA;blico le reconozca por uno de sus principales cooperadores a la ilustracion jeneral del Reino.</div><br></div>", "i": 9726148}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  De &#xF3;rden de S. E. lo comunico a US. para su inteligencia. Dios guarde a US. muchos a&#xF1;os. - Santiago, 2 de Abril de 1817.- Miguel Za&#xF1;artu, Ministro de Estado.-Se&#xF1;or Coronel don Antonio Bellina Fliupeski.</div></div>", "i": 9726149}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTRO", "descripcion": "Otro", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Contestacion", "fuente": "Otro", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1817-04-02", "doble_articulado": false, "id_norma": "1093394", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1817-04-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1817-04-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1817-04-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "362", "fecha_ingreso": "2016-09-01", "fecha_version": "1817-04-02", "fecha_actualizacion_texto