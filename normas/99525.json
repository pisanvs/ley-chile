{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8330270}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 713, de 25 de mayo de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la autorizaci&#xF3;n solicitada por SOCIEDAD PESQUERA COLOSO S.A., para continuar desarrollando actividades pesqueras, con la nave &apos;&apos;Isla L&#xF3;pez&apos;&apos;, Matr&#xED;cula 1.869, por haber caducado por falta de operaci&#xF3;n oportuna la resoluci&#xF3;n N&#xBA; 925 de 1995, de esta Subsecretar&#xED;a, que autorizaba a dicha nave, de conformidad con lo dispuesto en el Art&#xED;culo 143 letra b), en relaci&#xF3;n con el art&#xED;culo 41, sobre inscripci&#xF3;n en el Registro Pesquero Industrial, del decreto supremo N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8330271}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de mayo de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8330272}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "713", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-713"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "SOCIEDAD PESQUERA COLOSO S.A.", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-05-25", "fecha_derogacion": "1999-05-08", "doble_articulado": false, "id_norma": "99525", "numero_fuente": "36078", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1