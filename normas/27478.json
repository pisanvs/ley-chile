{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY NUMERO 11,595, DE 1954 Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7175346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Substituyese la palabra &quot;Enfermeras&quot; contempladas en las letras I, J, K, L, M y N de la letra c) del art&#xED;culo 5&#xB0;, de la ley 11.595, de 3 de septiembre de 1954, por &quot;Practicantes femeninos&quot;. </div></div>", "i": 7175347, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica. Santiago, veintid&#xF3;s de Septiembre de mil novecientos cincuenta y nueve.- JORGE ALESSANDRI RODRIGUEZ.- Carlos Vial Infante.</div><br></div>", "i": 7175348}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13458", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13458"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL"], "titulo_norma": "MODIFICA LA LEY NUMERO 11,595, DE 1954", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1959-09-22", "doble_articulado": false, "id_norma": "27478", "numero_fuente": "24462", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1959-10-08", "vigencias": [{"desde": "1959-10-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1959-10-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1959-10-08", "fin_vigencia": "", "tipo_version": "3"}], "e