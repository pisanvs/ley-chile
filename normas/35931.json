{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294991}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 959, de 18 de Octubre de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 3&#xB0; de la Resoluci&#xF3;n N&#xB0; 25, de 1994, de esta Subsecretar&#xED;a por la cual se autoriz&#xF3; a PESQUERA ANDACOLLO S.A. R.U.T.</div><div class=\"p\">N&#xB0; 79.697.400-1, para operar la nave &quot;Dubrovnik&quot; en el sentido de agregar el siguiente inciso:</div><div class=\"p\">&nbsp; &nbsp; &quot;Adem&#xE1;s la interesada podr&#xE1; capturar en el litoral de la IV Regi&#xF3;n, con red de arrastre, los siguientes recursos hidrobiol&#xF3;gicos: Camar&#xF3;n nailon y Langostino amarillo&quot;.</div><br><br></div>", "i": 8294992}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 18 de Octubre de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294993}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "959", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-959"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA ANDACOLLO S.A.", "PESCA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-10-18", "fecha_derogacion": "2002-01-08", "doble_articulado": false, "id_norma": "35931", "numero_fuente": "35002", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-10-28", "vigencias": [{"desde": "2002-01-08", "hasta": "", "tipo_version": "2", "tipo_version_s