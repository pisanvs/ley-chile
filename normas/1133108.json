{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10033529}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.004, de 13 de mayo de 2019, de este Servicio, se delega ejercicio de las atribuciones y facultades propias que indica y deja sin efecto resoluciones que se&#xF1;ala.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n indicada, se encuentra publicado con esta fecha en el sitio de dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y de la Subsecretar&#xED;a de Pesca y Acuicultura.</div></div>", "i": 10033530}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En Valpara&#xED;so, a 13 de mayo de 2019.- Alicia Gallardo Lagno, Directora Nacional, Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 10033531}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2004 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2004 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1611182", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-05-13", "doble_articulado": false, "id_norma": "1133108", "numero_fuente": "42389", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-06-26", "vigencias": [{"desde": "2019-06-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-06-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2019-06-26", "fin_vigencia":