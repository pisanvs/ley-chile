{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8577487}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 1.405, de 06 de Octubre de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 3&#xB0; de la Resoluci&#xF3;n No. 1.237 y No. 1.238 de 1988, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; a don Charles Terence Cook Cooper, R.U.T. No.</div><div class=\"p\">6.089.259-8,domiciliado en Santiago, calle Las Luci&#xE9;rnagas No. 5753, La Reina, para iniciar y ampliar actividades pesqueras de cultivo respectivamente, en orden a sustituir en cada una de ellas. La cantidad de &quot;350 balsas-jaulas&quot; por &quot;35 balsas-jaulas&quot;.</div><br></div>", "i": 8577488}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 06 de Octubre de 1989.</div><div class=\"p\">Roberto Cabezas Bello, Subsecretario de Pesca. </div></div>", "i": 8577489}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1405", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1405"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-10-06", "doble_articulado": false, "id_norma": "90493", "numero_fuente": "33513", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-11-04", "vigencias": [{"desde": "1989-11-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-11-04", "fin_vigencia": ""}, "vigencias_version_norma":