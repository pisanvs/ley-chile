{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8334187}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.180, de 12 de agosto de 1998, de esta Subsecretar&#xED;a, autor&#xED;zase a ALIMENTOS LEBU S.A. para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Bocalebu Sur, Lote 25, comuna de Lebu, VIII Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Congelado y Fresco-Refrigerado: Albacora o pez espada y Bacalao de profundidad. </div></div>", "i": 8334188}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de agosto de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8334189}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1180", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1180"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "ALIMENTOS LEBU S.A.", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-12", "doble_articulado": false, "id_norma": "124000", "numero_fuente": "36161", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-09-09", "vigencias": [{"desde": "1998-09-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-09-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-09-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingre