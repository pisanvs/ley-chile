{"html": [{"t": "<div><div class=\"p\">MODIFICA DESIGNACION DE RECEPTORES JUDICIALES (Resoluci&#xF3;n)</div><br><div class=\"p\">N&#xFA;m. 133.- Santiago, 08 de Agosto de 1990.- Vistos: Lo dispuesto en el Art. 11 del DL No. 2.974 de 1979, </div><div class=\"p\">Resuelvo:</div><br></div>", "i": 6080728}, {"t": "<div><div class=\"p\">Modif&#xED;case la resoluci&#xF3;n No. 53 de 17 de Marzo de 1981, que designa Receptores judiciales, en la forma siguiente: Regi&#xF3;n Metropolitana, se eliminan a los siguientes funcionarios:</div><div class=\"p\">- Pedro Gajardo Fontecilla - Ronald Walker Riesle Se designa nuevo Receptor Judicial al se&#xF1;or Alfredo Boris G&#xE1;lvez Chamaco.</div><br></div>", "i": 6080729}, {"t": "<div><div class=\"p\">T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hugo Ortega Tello, Director Nacional. </div></div>", "i": 6080730}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "133", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-133"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "MODIFICA DESIGNACION DE RECEPTORES JUDICIALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-08-08", "doble_articulado": false, "id_norma": "88825", "numero_fuente": "33767", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-09-10", "vigencias": [{"desde": "1990-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-09-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-09-10", "fin_vigencia": "", "tipo_vers