{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 363 EXENTO, DE 1994 </div></div>", "i": 7161681}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 363 de 17 de agosto de 1994, se ha aprobado, a contar del 1&#xB0; de agosto de 1994, al Centro Integral de Educaci&#xF3;n de Talca &quot;C.I.E.T.&quot;, VII Regi&#xF3;n del Maule, un plan de estudio especial para la Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica de Adultos.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio de las asignaturas que conforman el Area de Educaci&#xF3;n T&#xE9;cnica:</div><div class=\"p\"> - Mec&#xE1;nica de Autom&#xF3;viles.</div><div class=\"p\"> - Reparaci&#xF3;n de Electrodom&#xE9;sticos.</div><div class=\"p\"> - Instalaciones El&#xE9;ctricas Domiciliarias.</div><div class=\"p\"> - Corretaje de Propiedades.</div><div class=\"p\"> - Venta de Intangibles.</div><br></div>", "i": 7161682}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 26 de Septiembre de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 7161683}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "363 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-363 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 363 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO INTEGRAL EDUCACION TALCA", "PLANES ESTUDIO", "PROGRAMAS ESTUDIOS", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-08-17", "doble_articulado": false, "id_norma": "21068", "numero_fuente": "34984", "tipo_version": "3", "ti