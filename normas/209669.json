{"html": [{"t": "<div><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DO&#xD1;A MARIA ROMERO VIUDA DE LIZANA</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6421834}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a do&#xF1;a Mar&#xED;a Romero Romero viuda de Lizana, una pensi&#xF3;n de $ 20.000 mensuales.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande la aplicaci&#xF3;n de esta ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda.</div><br></div>", "i": 6421835}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a treinta y uno de Octubre de mil novecientos cincuenta y nueve.- JORGE ALESSANDRI RODRIGUEZ.- Roberto Vergara H.</div><br></div>", "i": 6421836}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13715", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13715"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DOÑA MARIA ROMERO VIUDA\nDE LIZANA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1959-10-31", "doble_articulado": false, "id_norma": "209669", "numero_fuente": "24497", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1959-11-19", "vigencias": [{"desde": "1959-11-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vige