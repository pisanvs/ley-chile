{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;4, DE 2003 </div></div>", "i": 6411253}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 4 de 20 de enero de 2003, de esta Direcci&#xF3;n Nacional, se fijan tablas de valores corrientes en plaza, de trolebuses, microbuses, taxis, taxis colectivos, taxibuses, autom&#xF3;viles, stations wagons, furgones, camionetas, incluyendo el de sus acoplados o carros de arrastre, para los fines de lo dispuesto en el art&#xED;culo 34 bis de la Ley sobre Impuesto a la Renta.</div><br><div class=\"p\">&nbsp; &nbsp;  Publ&#xED;quese el listado anexo de esta resoluci&#xF3;n en el diario El Mercurio, el d&#xED;a 29 de enero de 2003. Este listado se publicar&#xE1; adicionalmente en la p&#xE1;gina web del SII.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se publicar&#xE1; en la edici&#xF3;n del Bolet&#xED;n del Servicio del mes de enero, y en la p&#xE1;gina web del SII, cuya direcci&#xF3;n es www.sii.cl.-</div><br></div>", "i": 6411254}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mariela N&#xFA;&#xF1;ez Zeballos, Secretaria General (S). </div></div>", "i": 6411255}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº4, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-20", "doble_articulado": false, "id_norma": "207012", "numero_fuente": "37467", "tipo_version": "3", "tipo_version_s": "Única"