{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7314403}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.368, de 27 de agosto de 2004, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.255 de 1994, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA BIO BIO LIMITADA, hoy Pesquera B&#xED;o B&#xED;o S.A. para realizar actividades pesqueras extractivas con la nave &quot;Biomar V&quot;, sobre el recurso Raya, en el &#xE1;rea mar&#xED;tima comprendida entre el l&#xED;mite Norte de la VIII Regi&#xF3;n y el 41&#xBA;28,6&apos; L.S., todo ello por presentar una laguna operacional superior a 12 meses consecutivos, incurriendo en la causal de caducidad establecida en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7314404}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de agosto de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7314405}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2368", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2368"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-08-27", "doble_articulado": false, "id_norma": "229970", "numero_fuente": "37954", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-09-04", "vigencias": [{"desde": "2004-09-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-09-04", "fin_vigencia": ""}, "vige