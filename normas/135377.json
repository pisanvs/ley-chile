{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  EXTRACTO DE DECRETO No. 70 EXENTO, DE 1988 </div></div>", "i": 6165224}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 70, de 07 de abril de 1988, se ha aprobado para el Liceo Mar&#xED;timo de Valpara&#xED;so, Comuna de Valpara&#xED;so, Provincia de Valpara&#xED;so, V Regi&#xF3;n de Valpara&#xED;so, planes y programas especiales de estudio para la Educaci&#xF3;n Media. Modalidad T&#xE9;cnico - Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar de 1988 y hasta el a&#xF1;o escolar de 1989, en las Especialidades de: Extracci&#xF3;n Pesquera, Mec&#xE1;nica de Motores Marinos, y Manejo y Control de Alimentos Pesqueros.</div><br></div>", "i": 6165225}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 21 de Abril de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6165226}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "70 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-70 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO No. 70 EXENTO, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-04-07", "doble_articulado": false, "id_norma": "135377", "numero_fuente": "33062", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-05-04", "vigencias": [{"desde": "1988-05-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-05-04", "fin_vigencia": ""}, "vigencias_version_norm