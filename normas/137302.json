{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 2,308.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6171503}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico. En atenci&#xF3;n a los servicios prestados durante la &#xE9;poca de la Independencia por el capit&#xE1;n de Ej&#xE9;rcito don Manuel Pizarro, conc&#xE9;dese por gracia, a sus nietas, do&#xF1;a Aurora i do&#xF1;a Herminia Pizarro, la pension que la lei de 22 de setiembre de 1890 asigna al empleo de teniente, de la cual disfrutar&#xE1; con arreglo a la lei de montep&#xED;o militar&quot;.</div><br></div>", "i": 6171504}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I, por cuanto, oido el Consejo de Estado, he tenido a bien aprobarle i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiocho de junio de mil novecientos diez.- Pedro Montt.- C&#xE1;rlos Larrain Claro&quot;.</div><br></div>", "i": 6171505}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2308", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2308"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-06-28", "doble_articulado": false, "id_norma": "137302", "numero_fuente": "9738", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-07-09", "vigencias": [{"desde": "1910-07-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-07-09", "fin_v