{"html": [{"t": "<div><div class=\"p\">CANONJIAS.</div></div>", "i": 10245473}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso nacional con fecha 3 del corriente ha sancionado lo que sigue:</div><div class=\"p\">&nbsp; &nbsp;  El Poder Ejecutivo por s&#xED; solo, y sin necesidad de consulta har&#xE1; en adelante la provisi&#xF3;n de canonjias.</div><div class=\"p\">&nbsp; &nbsp;  Por tanto ordeno que se ejecute, se tome razon donde corresponda y se publique en el Bolet&#xED;n.</div></div>", "i": 10245474}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Dado en la Sala de Gobierno en Santiago de Chile a 10 de enero de 1829.</div><br><div class=\"p\">&nbsp; &nbsp;  R&#xFA;brica de S.E.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Rodr&#xED;guez.</div></div>", "i": 10245475}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "CANONJIAS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1829-01-10", "doble_articulado": false, "id_norma": "1158934", "numero_fuente": "1829", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1829-01-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1829-01-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1829-01-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-06-23", "fecha_version": "1829-01-10",