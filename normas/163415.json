{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6258343}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 64 de 21 de Junio de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la I Regi&#xF3;n, se autoriza a Sociedad Hermanos D&#xED;az y C&#xED;a. Ltda. para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6258344}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan W. Flaquer Hern&#xE1;ndez, Secretario Regional Ministerial Transportes y Telecomunicaciones 1ra. Regi&#xF3;n Tarapac&#xE1;.</div><br></div>", "i": 6258345}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "64 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-64 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-21", "doble_articulado": false, "id_norma": "163415", "numero_fuente": "32209", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-29", "vigencias": [{"desde": "1985-06-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-06-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-06-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [