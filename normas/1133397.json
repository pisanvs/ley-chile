{"html": [{"t": "<div><br><div class=\"p\">DEJA SIN EFECTO RESOLUCI&#xD3;N N&#xB0; 52 EXENTA, DE 2019</div></div>", "i": 10035138}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n Ex. del Servicio de Impuestos Internos, N&#xBA; 80 del 28 de junio de 2019, deja sin efecto <a href=\"https://www.leychile.cl/Navegar?idNorma=1131203&amp;idParte=&amp;idVersion=\">Res. Ex. SII N&#xBA; 52, de 30.04.2019</a>. Establece procedimiento de identificaci&#xF3;n como contribuyente catalogado como exportador de servicios prestados y utilizados totalmente en el extranjero.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de junio de 2019.</div><br></div>", "i": 10035139, "v": ["MODIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "80 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-80 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEJA SIN EFECTO RESOLUCIÓN N° 52 EXENTA, DE 2019", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1616033", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-06-28", "doble_articulado": false, "id_norma": "1133397", "numero_fuente": "42395", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-07-04", "vigencias": [{"desde": "2019-07-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-0