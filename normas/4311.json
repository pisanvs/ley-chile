{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA EN LA FORMA QUE INDICA EL PRESUPUESTO EN VIGOR</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 53.- Santiago, 22 de Abril de 1953.- Vistas las facultades que me confiere el art&#xED;culo 1.o de la ley N.o 11,151, de 5 de Febrero de 1953, dicto el siguiente, Decreto con fuerza de ley:</div><br></div>", "i": 5862775}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.o Supr&#xED;mese el n&#xFA;mero 1) de la letra a) del &#xED;tem 06/01/04 del Presupuesto vigente.</div><br></div>", "i": 5862776}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2.o Cr&#xE9;ase el siguiente cargo en la letra a) del &#xED;tem 06/01/04 del Presupuesto vigente:</div><div class=\"p\">&nbsp; &nbsp; &quot;1) Para contratar un Oficial de Secretar&#xED;a, grado 7.o, con $ 143.400 anuales&quot;.</div><br></div>", "i": 5862777}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Juan B. Rossetti.</div><br></div>", "i": 5862778}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "53", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-53"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA EN LA FORMA QUE INDICA EL PRESUPUESTO EN\nVIGOR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1953", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1953-04-22", "doble_articulado": false, "id_norma": "4311", "numero_fuente": "22542", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1953-05-07", "vigencias": [{"desde": "1953-05-07", "hasta": "", "tipo_version": "3