{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6352865}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.091 de 2 de octubre de 2001 de esta Subsecretar&#xED;a, prorr&#xF3;gase el plazo otorgado a PACIFIC FISHERIES S.A. para reanudar operaciones con la nave &quot;Ligrunn&quot;, por el t&#xE9;rmino de ocho meses contados desde el t&#xE9;rmino de la vigencia de su autorizaci&#xF3;n en las unidades de pesquer&#xED;a&nbsp; autorizadas, en virtud de haberse acreditado una causa de fuerza mayor. En consecuencia, deber&#xE1; empezar a operar antes del 31 de agosto de 2002, trat&#xE1;ndose de Anchoveta y Sardina com&#xFA;n, y antes del 31 de diciembre de 2002, trat&#xE1;ndose de Jurel, Merluza de cola y dem&#xE1;s especies autorizadas. </div></div>", "i": 6352866}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de octubre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6352867}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2091", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2091"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-10-02", "fecha_derogacion": "2012-04-17", "doble_articulado": false, "id_norma": "190436", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2001-10-12", "vigencias": [{"desde": "2012-04-17", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2001-10-12", "hasta": "2012-04-16", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vi