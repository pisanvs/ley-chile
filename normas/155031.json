{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6230906}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 655, de fecha 20 de Junio de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la V Regi&#xF3;n, se autoriza a Ram&#xF3;n Far&#xED;as G&#xE1;rate para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6230907}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de Junio de 1986.- Hern&#xE1;n V&#xE1;squez Wacquez, Capit&#xE1;n de Nav&#xED;o, Secretario Regional Ministerial de Transportes y Telecomunicaciones V Regi&#xF3;n.</div><br></div>", "i": 6230908}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "655 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-655 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL V REGIÓN DE VALPARAÍSO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-20", "doble_articulado": false, "id_norma": "155031", "numero_fuente": "32507", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-06-27", "vigencias": [{"desde": "1986-06-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-06-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-06-27", "