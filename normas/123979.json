{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 247, DE 1987 </div></div>", "i": 7238459}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 247 de 04 de diciembre de 1987 se ha aprobado, a contar del 01 de marzo de 1988, un plan especial de estudio de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica para Adultos, a la Corporaci&#xF3;n de Educaci&#xF3;n, La Araucana, perteneciente a La Araucana CC A.F., que se desarrollar&#xE1; en cuatro per&#xED;odos lectivos.</div><div class=\"p\">Se dan normas de evaluaci&#xF3;n y promoci&#xF3;n.</div><br></div>", "i": 7238460}, {"t": "<div><div class=\"p\">&nbsp;  Santiago, 18 de Diciembre de 1987.- Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 7238461}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "247 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-247 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 247, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-12-04", "doble_articulado": false, "id_norma": "123979", "numero_fuente": "32954", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-26", "vigencias": [{"desde": "1987-12-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION