{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m 2,271, que aumenta el sueldo del Inspector Jeneral de Instruccion Primaria</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,271.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5953186}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. F&#xED;jase en nueve mil pesos el sueldo anual del Inspector Jeneral de Instruccion Primaria. </div></div>", "i": 5953187}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-</div><div class=\"p\">&nbsp; &nbsp; Santiago, 15 de Febrero de 1910.- Pedro Mont.- Emiliano Figueroa.</div><br></div>", "i": 5953188}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2271", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2271"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "LEI NUM 2,271, QUE AUMENTA EL SUELDO DEL INSPECTOR JENERAL DE INSTRUCCIÓN PRIMARIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSPECTOR GENERAL INSTRUCCION PRIMARIA", "SUELDO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-02-15", "doble_articulado": false, "id_norma": "23236", "numero_fuente": "9622", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-02-21", "vigencias": [{"desde": "1910-02-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-02-21", "fin_vigencia": ""}, "vigencias_versio