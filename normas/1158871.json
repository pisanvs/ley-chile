{"html": [{"t": "<div><div class=\"p\">CONTADURIAS DE DIEZMOS</div><br><div class=\"p\">&nbsp; &nbsp;  71 Por cuanto el Congreso nacional con fecha 9 del presente mes ha sancionado lo siguiente:</div></div>", "i": 10246413}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. 1&#xB0; Quedan suprimidas la contadur&#xED;as de diezmos.</div></div>", "i": 10246414}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; Sus funciones ser&#xE1;n desempe&#xF1;adas por las Tesorer&#xED;as respectivas.</div></div>", "i": 10246415}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por tanto ordeno que se cumpla, tome razon, se comunique a quienes corresponde, y se publique, insert&#xE1;ndose en el Boletin. Dado en la Sala de Gobierno en Santiago de Chile a 10 de Diciembre de 1828.</div><br><div class=\"p\">&nbsp; &nbsp;  PINTO</div><div class=\"p\">&nbsp; &nbsp;  Rodr&#xED;guez.</div></div>", "i": 10246416}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONTADURIAS DE DIEZMOS", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1828-12-10", "doble_articulado": false, "id_norma": "1158871", "numero_fuente": "1828", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1828-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1828-12-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1828-12-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "906", "f