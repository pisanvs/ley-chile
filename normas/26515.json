{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESIGNA CON EL NOMBRE DE &quot;JUAN MADRID&quot; LA ESCUELA NORMAL RURAL DE CHILLAN.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5968836}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Des&#xED;gnase con el nombre de &quot;Juan Madrid&quot; la Escuela Normal Rural de Chill&#xE1;n&quot;. </div></div>", "i": 5968837}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a treinta de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Luis D. Cruz Ocampo.-</div><br></div>", "i": 5968838}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11036", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11036"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "DESIGNA CON EL NOMBRE DE JUAN MADRID LA ESCUELA NORMAL RURAL DE CHILLAN.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMBRE", "ESCUELA NORMAL RURAL \"JUAN MADRID\"", "CHILLAN."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-30", "doble_articulado": false, "id_norma": "26515", "numero_fuente": "22414", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-11-29", "vigencias": [{"desde": "1952-11-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1952-11-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia"