{"html": [{"t": "<div><div class=\"p\">AUTORIZACION, PESQUERA OCEANICA LTDA., PESCA, MODIFICACION</div><br><br></div>", "i": 8293389}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 612, de 16 de Agosto de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n modif&#xED;case el numeral 2&#xB0; de la resoluci&#xF3;n N&#xB0; 184, de 1992, por la cual se autoriz&#xF3; a PESQUERA OCEANICA LTDA., R.U.T. N&#xB0; 82.957.700-3, para ejercer el derecho que le reconoce el art&#xED;culo 3&#xB0; transitorio, incisos 3&#xB0; y 4&#xB0; del D.S. N&#xB0; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, respecto de la nave &quot;San Antonio 8&quot;, en el sentido de se&#xF1;alar sus actuales caracter&#xED;sticas n&#xE1;uticas.</div><br><br></div>", "i": 8293390}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 16 de Agosto de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8293391}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "612", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-612"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZACION, PESQUERA OCEANICA LTDA., PESCA,;MODIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1993-08-16", "fecha_derogacion": "1995-01-18", "doble_articulado": false, "id_norma": "35214", "numero_fuente": "34667-2", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1993-09-15", "vigencias": [{"desde": "1995-01-18", "hasta": "", "tipo_version":