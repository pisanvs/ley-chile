{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xB0; 970</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xB0; 970 celebrada el 28 de febrero de 2002, adopt&#xF3; los siguientes Acuerdos:</div><br><div class=\"p\">970-02-020228 - Modifica el Cap&#xED;tulo IV.B.6 del Compendio de Normas Financieras.</div><br></div>", "i": 6371118}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; modificar el Cap&#xED;tulo IV.B.6 del Compendio de Normas Financieras, reemplazando el N&#xB0; 2 por el siguiente:</div><br><div class=\"p\">&quot;2.- El plazo de vencimiento de estos t&#xED;tulos ser&#xE1; hasta 5 a&#xF1;os contados desde su fecha de emisi&#xF3;n&quot;. </div></div>", "i": 6371119}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de febrero de 2002.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6371120}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "970", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-970"}, {"tipo": "5", "numero": "970-02", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-970-02"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION N° 970", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-28", "doble_articulado": false, "id_norma": "195054", "numero_fuente": "37200", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-03-02", "vigencias": [{"desde": "2002-03-02", "hasta": "", "tipo_version": "3", "tipo_version_s"