{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9262605}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;898, de 16 de mayo de 2012, se dej&#xF3; sin efecto los numerales 3&#xB0;, 4&#xB0;, 5&#xB0; y 6&#xB0;, del <a href=\"https://www.leychile.cl/Navegar?idNorma=1030389&amp;idParte=&amp;idVersion=\">Decreto Exento MOP. N&#xB0;2109, de 31 de agosto de 2011</a>, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote de terreno N&#xB0;2, expropiado con motivo de la obra &quot;Camino Ruta 7, Sector Lenca - Chaica, Tramo Km. 27,89372 a Km. 33,17100&quot;, Comuna de Puerto Montt, Provincia de Llanquihue, X Regi&#xF3;n. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n fijado mediante tasaci&#xF3;n de 09 de marzo de 2010, en la suma de $2.100.000.-</div><br></div>", "i": 9262606}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9262607}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "898 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-898 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-16", "doble_articulado": false, "id_norma": "1040651", "numero_fuente": "40276", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-01", "vigencias": [{"desde": "2012-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vi