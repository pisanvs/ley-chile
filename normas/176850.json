{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO N&#xBA; 211, DE 1991</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 189.- Santiago, 1 de septiembre de 2000.- Visto: El decreto supremo N&#xBA; 211, de 1991, del Ministerio de Transportes y Telecomunicaciones, </div><div class=\"p\">&nbsp; &nbsp;  D e c r e t o:</div><br><br></div>", "i": 6305690}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico: Modif&#xED;case el inciso primero del art&#xED;culo 6&#xBA; del decreto supremo N&#xBA; 211, de 1991, del Ministerio de Transportes y Telecomunicaciones, elimin&#xE1;ndose la expresi&#xF3;n &apos;&apos;de modelos de los a&#xF1;os 1992 y siguientes,&apos;&apos;.</div><br></div>", "i": 6305691, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- JOSE MIGUEL INSULZA SALINAS, Vicepresidente de la Rep&#xFA;blica.- Carlos Cruz Lorenzen, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp;  Lo que trascribo para su conocimiento.- Saluda a Ud., Patricia Mu&#xF1;oz Villela, Jefe Depto. Administrativo. </div></div>", "i": 6305692}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "189", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-189"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "MODIFICA DECRETO Nº 211, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VEHICULOS MOTORIZADOS LIVIANOS", "EMISION DE GASES", "AUTOADEHESIVO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-01", "doble_articulado": false, "id_norma": "176850", "numero_fuente": "36793", "tipo_version": "3", "ti