{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6415954}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 470, de 14 de febrero de 2003, de esta Subsecretar&#xED;a, ampl&#xED;ase por un a&#xF1;o, a contar del 13 de febrero de 2003, el plazo otorgado por el numeral 6&#xBA; de la resoluci&#xF3;n N&#xBA; 384, modificada por resoluci&#xF3;n N&#xBA; 391, ambas de 2002, ambas de esta Subsecretar&#xED;a, a PESQUERA BURCA LIMITADA para ampliar actividades pesqueras de transformaci&#xF3;n en la planta ubicada en Caica&#xE9;n, kil&#xF3;metro 5,5, Calbuco, X Regi&#xF3;n, en virtud de haberse acreditado una circunstancia de fuerza mayor. </div></div>", "i": 6415955}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de febrero de 2003.- Jessica Fuentes Olmos, Subsecretaria de Pesca (S).</div><br></div>", "i": 6415956}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "470", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-470"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-02-14", "fecha_derogacion": "2006-09-05", "doble_articulado": false, "id_norma": "208096", "numero_fuente": "37498", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-03-01", "vigencias": [{"desde": "2006-09-05", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2005-07-20", "hasta": "2006-09-04", "tipo_version": "1", "tipo_version_s": "Intermedio"}, {"desde": "2004-06-23", "hasta": "2005-07-19", "tipo_version": "1",