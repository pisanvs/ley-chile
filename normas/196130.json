{"html": [{"t": "<div><div class=\"p\">DISPONE EXPROPIACIONES QUE INDICA </div></div>", "i": 6374707}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 3.368 de 13 de diciembre de 2001, Serviu V Regi&#xF3;n Valpara&#xED;so dispuso expropiaci&#xF3;n parcial conforme art&#xED;culo 87 ley 8.946 y decreto ley 2.186, de 1978, de inmueble ubicado Avda. Santa Cruz N&#xBA; 199, rol aval&#xFA;o 128-12, comuna La Cruz, de dominio de Herbert Fhankrog Reinhold. Comisi&#xF3;n Tasadora integrada por Sres. Osvaldo Mu&#xF1;oz Quintana (arquitecto), Alvaro Verdejo Vidal (ingeniero constructor), y Pablo Caria Giurici (constructor civil), seg&#xFA;n Informe fecha 4 de octubre 2001, fij&#xF3; monto provisional indemnizaci&#xF3;n en $645.825.- que ser&#xE1; pagada de contado.</div><br></div>", "i": 6374708}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alberto Ram&#xED;rez Urz&#xFA;a, Director Serviu Regi&#xF3;n Valpara&#xED;so.</div><br></div>", "i": 6374709}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3368", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3368"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAISO"], "titulo_norma": "DISPONE EXPROPIACIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-13", "doble_articulado": false, "id_norma": "196130", "numero_fuente": "37223", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-01", "vigencias": [{"desde": "2002-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-04-01", "fin_vigencia"