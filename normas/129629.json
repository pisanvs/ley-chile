{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 883, DE 1988 </div></div>", "i": 7243828}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 883 de fecha 13 de abril de 1988, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se aprobaron las adecuaciones introducidas a la carrera de Turismo con menci&#xF3;n Tr&#xE1;fico A&#xE9;reo de Pasajeros y Carga del Centro de Formaci&#xF3;n T&#xE9;cnica Escuela de Ciencias Tur&#xED;sticas e Idiomas EDECTI de Santiago, para aplicarse a contar del a&#xF1;o 1988. Por este mismo cuerpo legal se modificaron las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica mencionado, las que podr&#xE1;n aplicarse a contar del a&#xF1;o 1988.</div><br></div>", "i": 7243829}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de Mayo de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7243830}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "883 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-883 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 883, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-13", "doble_articulado": false, "id_norma": "129629", "numero_fuente": "33156", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-08-26", "vigencias": [{"desde": "1988-08-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-08-26", "f