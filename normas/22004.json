{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pension Lei n&#xFA;m. 142.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto del Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946903}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese por gracia al conductor del ferrocarril de Pisagua, don Ignacio S&#xE1;nchez, herido en el combate de Compa&#xF1;&#xED;a, una pension anual vitalicia de doscientos cuarenta pesos.</div><br><br></div>", "i": 5946904}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 28 de Diciembre de 1893.- JORJE MONTT.-</div><div class=\"p\">V. D&#xE1;vila Larra&#xED;n.</div><br></div>", "i": 5946905}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "142", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-142"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["IGNACIO SANCHEZ", "PENSION VITALICIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-12-28", "doble_articulado": false, "id_norma": "22004", "numero_fuente": "4705", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-12-29", "vigencias": [{"desde": "1893-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-12-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-12-29", "fin_vigencia": "", "tipo_