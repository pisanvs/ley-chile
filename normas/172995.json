{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6292050}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;1.545, de 14 de julio de 2000, de</div><div class=\"p\">esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las</div><div class=\"p\">resoluciones N&#xBA;1.014 de 1989, N&#xBA;836 de 1991, N&#xBA;1.293 y</div><div class=\"p\">N&#xBA;1.294, ambas de 1996, y N&#xBA;977 de 1997, todas de esta</div><div class=\"p\">Subsecretar&#xED;a, que autorizaron a SOCIEDAD PESQUERA REYES</div><div class=\"p\">DEL MAR LTDA. para operar las naves &apos;&apos;Galleguita II&apos;&apos; y</div><div class=\"p\">&apos;&apos;Galleguita III&apos;&apos;, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra d) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 6292051}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de julio de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6292052}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1545", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1545"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-07-14", "doble_articulado": false, "id_norma": "172995", "numero_fuente": "36717", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-19", "vigencias": [{"desde": "2000-07-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-19", "fin_vigencia": ""}, "vigenc