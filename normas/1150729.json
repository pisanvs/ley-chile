{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 382 EXENTA, DE 15 DE ENERO DE 2020</div></div>", "i": 10167892}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por la presente, se han modificado, a contar del a&#xF1;o escolar 2020, las resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=182653&amp;idParte=&amp;idVersion=\">N&#xBA; 592</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=194934&amp;idParte=&amp;idVersion=\">N&#xBA; 16.277</a>, ambas de 2001, y del Ministerio de Educaci&#xF3;n, que aprobaron planes y programas especiales de estudio de 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al establecimiento educacional Colegio Cordillera de Las Condes, RBD 8902-8, comuna de Las Condes, Regi&#xF3;n Metropolitana, en el sentido de sustituir el plan de estudio de 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10167893}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de enero de 2020.- Ra&#xFA;l Figueroa Salas, Subsecretario de Educaci&#xF3;n.</div><div class=\"p\"> </div><br></div>", "i": 10167894}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "382 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-382 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 382 EXENTA, DE 15 DE ENERO DE 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1831010", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-01-15", "doble_articulado": false, "id_norma": "1150729", "numero_fuente": "42783", "tipo_version": "3", "tipo