{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; COMPLEMENTA ORDENANZA N&#xB0; 1, DE 1994</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 4.- Quilpu&#xE9;, 25 de Agosto de 1995.- Vistos: El ord. N&#xB0; 114, de 1995, del se&#xF1;or Director (S) de Obras Municipales; la necesidad de complementar la Ordenanza Local de Derechos Municipales N&#xB0; 1 de 1994; la aprobaci&#xF3;n del Concejo Municipal, en sesi&#xF3;n ordinaria del d&#xED;a 8 de agosto de 1995, y teniendo presente: La resoluci&#xF3;n N&#xB0; 55, de 1992, de la Contralor&#xED;a General de la Rep&#xFA;blica y la Ley N&#xB0; 18.695 Ley Org&#xE1;nica Constitucional de Municipalidades.</div><div class=\"p\">&nbsp; &nbsp; O r d e n a n z a:</div><br></div>", "i": 5999003}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Complem&#xE9;ntase la Ordenanza N&#xB0; 1, de 1994, de este Municipio, como sigue:</div><div class=\"p\">&nbsp; &nbsp; Agr&#xE9;gase al art&#xED;culo 2&#xB0;, el ac&#xE1;pite 26 PLANO TIPO 1 U.F.</div><br></div>", "i": 5999004}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Iv&#xE1;n Manr&#xED;quez Cuevas, Alcalde.- Joaqu&#xED;n Ma&#xF1;es Aladro, Secretario Municipal.</div><br></div>", "i": 5999005}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "4", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "ORZ-4"}], "organismos": ["MUNICIPALIDAD DE QUILPUÉ"], "titulo_norma": "COMPLEMENTA ORDENANZA N° 1, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ORDENANZA MUNICIPAL", "MODIFICACION", "DERECHOS MUNICIPALES", "MUNICIPALIDAD QUILPUE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-08-25", "doble_articulado": false, "id_norma": "30981", "numero_fuent