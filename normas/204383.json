{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;3.390 EXENTA, DE 2002 </div></div>", "i": 7295054}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 3.390, de 22 de marzo de 2002, se ha aprobado al Colegio Calasanz, de Santiago, un plan de estudio para 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media Human&#xED;stico-Cient&#xED;fica, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para el sector Orientaci&#xF3;n, subsector Orientaci&#xF3;n, y para la Formaci&#xF3;n Diferenciada a los Subsectores que se indican en la presente resoluci&#xF3;n.</div><br></div>", "i": 7295055}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de abril de 2002.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 7295056}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3390 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3390 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº3.390 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-22", "doble_articulado": false, "id_norma": "204383", "numero_fuente": "37405", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-11-11", "vigencias": [{"desde": "2002-11-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-11-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-11-11", "fin_vigencia": "", "tipo_version": "3"}], "