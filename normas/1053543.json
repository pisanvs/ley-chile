{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.306 EXENTA, DE 2013</div></div>", "i": 9369324}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.306, de fecha 2 de agosto de 2013, de Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se modifican resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=1027854&amp;idParte=0&amp;idVersion=\">N&#xBA; 1.728</a> y N&#xBA; 3.743, citadas en Vistos, en sentido de aprobar cambio de nombre de la Escuela por &quot;Virginia Andrea Vald&#xE9;s Gonz&#xE1;lez Escuela de Conductores Empresa Individual de Responsabilidad Limitada&quot;, nombre de fantas&#xED;a &quot;Escuela de Conductores Virval E.I.R.L.&quot;, RUT N&#xBA; 76.256.493-9, representada legalmente por Virginia Andrea Vald&#xE9;s Gonz&#xE1;lez, RUT N&#xBA; 13.903.654-9.- </div></div>", "i": 9369325}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Sergio Stephan Orellana, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div></div>", "i": 9369326}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3306 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3306 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL REGIÓN METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.306 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-08-02", "doble_articulado": false, "id_norma": "1053543", "numero_fuente": "40631", "t