{"html": [{"t": "<div><div class=\"p\">CADUCA RESOLUCION QUE INDICA </div></div>", "i": 8313925}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 900, de 19 de Julio de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad conforme al art&#xED;culo 7&#xB0;, del Decreto No. 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, de la Resoluci&#xF3;n No. 969, de 1987, de esta Subsecretar&#xED;a, que auoriz&#xF3; a don Krunoslav Iv&#xE1;n Papic Garc&#xED;a, R.U.T. No. 7.439.523-6, domiciliado en Valdivia, calle Pedro Aguirre Cerda No. 2280, casa No. 47, para desarrollar actividades pesqueras de cultivo.</div><br></div>", "i": 8313926}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 19 de Julio de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8313927}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "900", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-900"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "CADUCA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-07-19", "doble_articulado": false, "id_norma": "82606", "numero_fuente": "33728", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-07-25", "vigencias": [{"desde": "1990-07-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-07-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-07-25", "fin_vigencia": "", "tipo_version": "