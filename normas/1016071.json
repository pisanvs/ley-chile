{"html": [{"t": "<div><br><div class=\"p\">RESUMEN EXTRACTO DE RESOLUCIONES</div></div>", "i": 8960122}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La XVII Direcci&#xF3;n Regional Valdivia deroga la Calidad de Agente Retenedor del Impuesto al Valor Agregado en las Ventas y Servicios a los siguientes contribuyentes:</div><br><div class=\"p\">RUT&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Nombre&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Producto&nbsp; Derogaci&#xF3;n&nbsp; &nbsp; &nbsp; Fecha</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Resoluci&#xF3;n N&#xB0;</div><div class=\"p\">03.898.732-1&nbsp;  Cecilia Jenoveva </div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Junemann Klagges&nbsp; &nbsp; Ganado&nbsp;  1888&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  27/07/2010</div><div class=\"p\">03.212.649-9&nbsp;  Roberto Werner </div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Simon Neef&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Ganado&nbsp;  1889&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  27/07/2010</div><div class=\"p\">02.941.057-7&nbsp;  Regina Schilling </div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Mohr&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Ganado</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; /Trigo&nbsp; &nbsp; 1890&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  27/07/2010</div><br><div class=\"p\">04.302.270-9&nbsp;  Reemberto Zapata </div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Bustos&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Ganado&nbsp; &nbsp; 1891&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  27/07/2010</div><br><div class=\"p\">&nbsp; &nbsp;  A contar de la fecha de publicaci&#xF3;n de este extracto en el Diario Oficial, de acuerdo a lo establecido en la Res. Ex N&#xB0; 5.281, de 30.11.2000, y Res.Ex. N&#xB0; 3.721, del 28.07.2000, ambas emanadas de la Direcci&#xF3;n Nacional de este Servicio.</div><div class=\"p\">&nbsp; &nbsp;  El texto de estas resoluciones ser&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos en Internet www.sii.cl.</div></div>", "i": 8960123}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1888", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1888"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "XVII DIRECCIÓN REGIONAL DE VALDIVIA"], "titulo_norma": "RESUMEN EXTRACTO DE RESOLUCIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-07-27", "doble_articulado": false, "id_norma": "1016071", "numero_fuente": "39731", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-08-09", "vigencias": [{"desde": "2010-08-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-08-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-08-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "118", "fecha_ingreso": "2010-08-09", "fecha_version": "2010-08-09", "actualizado_por": "118", "fecha_actualizacion_texto": "2010-08-09", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8960122}, {"n": "Artículo", "i": 8960123, "t": 6}]}