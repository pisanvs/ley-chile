{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N.o 6,402, QUE CREA LA COMUNA-SUBDELEGACION DE PURRANQUE</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 8278161}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. El plazo a que se refiere el inciso 1.o del art&#xED;culo 3.o de la ley n&#xFA;mero 6,402, de 31 de Agosto pr&#xF3;ximo pasado, comenzar&#xE1; a regir desde el 15 de Enero de 1940 y podr&#xE1; ser prorrogado por treinta d&#xED;as. </div></div>", "i": 8278162}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veinte de Enero de mil novecientos cuarenta.- PEDRO AGUIRRE CERDA.- G. Labarca H. </div></div>", "i": 8278163}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "6507", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-6507"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA LA LEY N.o 6,402, QUE CREA LA\nCOMUNA-SUBDELEGACION DE PURRANQUE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PURRANQUE", "COMUNA SUBDELEGACION", "INSCRIPCIONES ELECTORALES", "PRESIDENTE REPUBLICA", "AUTORIZACION", "PROVIDENCIAS", "DICTACION", "PLAZO", "AMPLIACION", "SERVICIOS", "TESORERIA", "CARABINEROS", "ESTABLECIMIENTOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1940-01-20", "doble_articulado": false, "id_norma": "25362", "numero_fuente": "18578", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion