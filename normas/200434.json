{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6388923}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA;872 de fecha 31 de mayo</div><div class=\"p\">del 2002, se expropi&#xF3; el lote de terreno N&#xBA;96,</div><div class=\"p\">superficie 37 m2, Rol en Tr&#xE1;mite, comuna de Rancagua, VI</div><div class=\"p\">Regi&#xF3;n para la obra &apos;&apos;Mejoramiento Camino Ruta H-240,</div><div class=\"p\">Sector Rancagua-San Ram&#xF3;n, Km. 0,0000 al 5,0000 y se</div><div class=\"p\">acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Luis</div><div class=\"p\">Arturo Osorio Arauco, ascendente a la cantidad de $548.150.</div><br></div>", "i": 6388924}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6388925}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "872 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-872 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-31", "doble_articulado": false, "id_norma": "200434", "numero_fuente": "37308", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-15", "vigencias": [{"desde": "2002-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MAS", "fecha_ingreso": "2002-07-15", "fecha_ver