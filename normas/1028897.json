{"html": [{"t": "<div><br><div class=\"p\">DESIGNA COMO MINISTROS DE FE A FUNCIONARIOS QUE INDICA</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 90.641 exenta.- Santiago, 11 de agosto de 2011.- Vistos: Lo dispuesto en el art. 4&#xBA; del decreto ley N&#xBA; 2.974 de 1979.</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div></div>", "i": 9170077}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnanse como Ministros de Fe para actuar en las localidades ubicadas en la Regi&#xF3;n de Arica y Parinacota, en que no haya Notarios ni Oficiales del Registro Civil, a los siguientes funcionarios:</div><br><div class=\"p\">- Juan Arturo Pacha Larrea RUT N&#xBA; 14.102.382-9</div><div class=\"p\">- Jos&#xE9; Mar&#xED;a Araya Saines RUT N&#xBA; 6.412.172-3</div><br></div>", "i": 9170078}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Ricardo Arizt&#xED;a de Castro, Director Nacional.</div></div>", "i": 9170079}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "90641 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-90641 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESIGNA COMO MINISTROS DE FE A FUNCIONARIOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-08-11", "doble_articulado": false, "id_norma": "1028897", "numero_fuente": "40044", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-08-25", "vigencias": [{"desde": "2011-08-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia