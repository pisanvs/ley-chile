{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6546573}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 528 de fecha 30 de junio de 2005, modificado por decreto MOP N&#xBA; 759 de 31 de agosto de 2005, se expropi&#xF3; la construcci&#xF3;n edificada de propiedad de don Carlos Francisco Mendoza C&#xE1;rdenas, signada como lote N&#xBA; 3 de una superficie de 65 m&#xB2; para la obra &quot;Camino Ruta U-40, Sector Puaucho-Bah&#xED;a Mansa, Tramo Km 53,574 a Km. 58,7296&quot; X&#xAA; Regi&#xF3;n y se acord&#xF3; como valor de indemnizaci&#xF3;n la cantidad de $15.872.160. </div></div>", "i": 6546574}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6546575}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "528", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-528"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-30", "doble_articulado": false, "id_norma": "243530", "numero_fuente": "38301", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-11-02", "vigencias": [{"desde": "2005-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-11-02", "fecha_version": "2005-11-02", "fecha_actualizacion_texto": "2005-11-02", "tipo_tratado": ""