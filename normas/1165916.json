{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10272968}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 601, de 16 de septiembre de 2021, de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n parcial, conforme art&#xED;culo 51 ley 16.391, de inmueble ubicado en Sta. Olga, St. 288, Santa Olga, Rol Aval&#xFA;o N&#xBA; 606-5, comuna de Constituci&#xF3;n, superficie 28,64 m2, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Eliacer Cea Lavoz. Comisi&#xF3;n integrada por peritos Patricio Ulises Dur&#xE1;n Marcos, Arquitecto; Rodrigo Antonio Silva Lazo, Constructor Civil y Pedro Pablo Cruz Weston, Arquitecto, seg&#xFA;n informe de fecha 21 diciembre de 2020, tas&#xF3; lote en $859.200.-, se pagar&#xE1; de contado indemnizaci&#xF3;n provisional debidamente reajustada conforme art&#xED;culo 5 DL 2.186, siendo su valor la suma de $889.272.- </div></div>", "i": 10272969}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Claudio Daneck Mu&#xF1;oz, Director (S) Serviu Regi&#xF3;n del Maule.</div><br></div>", "i": 10272970}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "601 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-601 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2013008", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-09-16", "doble_articulado": false, "id_norma": "1165916", "numero_fuente": "43067", "tipo_version": "3", "tipo_