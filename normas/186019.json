{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6337116}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 599, de 30 de marzo de 2001, se expropiaron los lotes de terreno N&#xBA;s. 31-A y 31-B, superficies 37.282 m&#xB2; y 953 m&#xB2;, rol de aval&#xFA;o 1566-48, comuna de Los Angeles, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: Chill&#xE1;n-Collipulli. By Pass Los Angeles, Octava Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Coordinadora de Comit&#xE9;s de Allegados Comuna de Los Angeles, ascendente a la cantidad total de $68.046.301.-</div><br></div>", "i": 6337117}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6337118}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "599", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-599"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-30", "doble_articulado": false, "id_norma": "186019", "numero_fuente": "36976", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-06-01", "vigencias": [{"desde": "2001-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2001-06-01", "fecha_version": "2001-06-01", "fecha_actualizacion_texto": "2001-06-01", "tip