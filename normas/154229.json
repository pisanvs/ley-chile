{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6228355}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 61, de 10 de Diciembre de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se autoriza al Sr. Juan de Dios Briones Campos para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6228356}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rancagua, 10 de Diciembre de 1986.- Rigoberto G&#xF3;mez Lav&#xED;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n.</div><br></div>", "i": 6228357}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "61 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-61 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-12-10", "doble_articulado": false, "id_norma": "154229", "numero_fuente": "32650", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-12-18", "vigencias": [{"desde": "1986-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-12-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-12-18", "fin_vigenci