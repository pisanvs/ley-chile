{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6187728}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.769, de 30 de junio de 1999, se expropiaron los lotes de terreno N&#xBA;s 8-A y 13, superficies 223 y 315 m&#xB2;, respectivamente, roles de aval&#xFA;o en tr&#xE1;mite y 172-4, comuna de Yerbas Buenas, para la obra Camino Ruta L-25, sector Lisonjera-Yerbas Buenas y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Zoila Bustos Reyes y Thusnelda Torres Tapia, ascendente a las cantidades de $5.152.680 y $2.492.360.</div><br></div>", "i": 6187729}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6187730}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1769", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1769"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-06-30", "doble_articulado": false, "id_norma": "142239", "numero_fuente": "36454", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-01", "vigencias": [{"desde": "1999-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1999-09-02", "fecha_version": "1999-09-01", "fecha_actualizacion_texto": "1999-09-01", "tipo_tratado": ""}, "alertas": [], "alerta_glob