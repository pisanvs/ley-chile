{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8318239}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.775, de 30 de diciembre de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, rech&#xE1;zase la solicitud de certificado de transferencia y de cambio de titular de la nave &quot;La Portada&quot;, por haberse declarado la caducidad de la autorizaci&#xF3;n otorgada a la nave por resoluci&#xF3;n N&#xBA; 730 de 1995, en virtud de la resoluci&#xF3;n N&#xBA; 1.774, de 1997, ambas de esta Subsecretar&#xED;a. </div></div>", "i": 8318240}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de diciembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8318241}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1775", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1775"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NEGACION", "CERTIFICADO DE TRANSFERENCIA", "CAMBIO DE TITULAR", "CADUCIDAD", "LA PORTADA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-30", "doble_articulado": false, "id_norma": "86895", "numero_fuente": "35961", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-10", "vigencias": [{"desde": "1998-01-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-01-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendien