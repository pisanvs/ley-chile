{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; INSTALACION PROVISORIA DE LA CAMARA DE DIPUTADOS Lei n&#xFA;m. 282.- Santiago, a 5 de Julio de 1895.-Por cuanto el Congreso Nacional ha aprobado el siguiente PROYECTO DE LEI:</div><br></div>", "i": 8273884}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Dest&#xED;nase la cantidad de veinte mil pesos ($ 20,000) a cubrir los gastos de instalacion provisoria de la C&#xE1;mara de Diputados.</div><br><br></div>", "i": 8273885}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-Jorje Montt.- Ramon Barros Luco.</div><br></div>", "i": 8273886}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "282", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-282"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "INSTALACION PROVISORIA DE LA CAMARA DE DIPUTADOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMARA DIPUTADOS", "GASTOS", "INSTALACION", "FONDOS", "DESTINACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-07-05", "doble_articulado": false, "id_norma": "22135", "numero_fuente": "5152", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-07-05", "vigencias": [{"desde": "1895-07-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-07-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1895-07-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-01-25", "fecha