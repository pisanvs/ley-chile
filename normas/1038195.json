{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9243366}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 555, de 14 de marzo de 2012, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n exenta N&#xBA; 3.593 de 2009, que autoriz&#xF3; a MARCELINO GONZ&#xC1;LEZ RIVERA, para realizar actividades pesqueras extractivas con la nave &quot;Surmar I&quot;, respecto del recurso hidrobiol&#xF3;gico Alfonsino, en el &#xE1;rea mar&#xED;tima comprendida entre la IV a la IX Regiones, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante memoranda t&#xE9;cnicos citados en Visto de la resoluci&#xF3;n extractada.</div><br></div>", "i": 9243368}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de marzo de 2012.- Maximiliano Alarma Carrasco, Subsecretario de Pesca (S).</div></div>", "i": 9243370}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "555 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-555 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-03-14", "doble_articulado": false, "id_norma": "1038195", "numero_fuente": "40218", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-03-21", "vigencias": [{"desde": "2012-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-03-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia"