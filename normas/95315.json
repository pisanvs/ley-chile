{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6099640}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No.735 de 08 de agosto de 1989 de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L.2.186 de 1978, inmueble ubicado en Avenida Vicu&#xF1;a Mackenna No.501 al 512, tambi&#xE9;n signado por calle Santa Isabel con Nos.1 al 3, presunto rol aval&#xFA;os No.918-31 comuna Providencia, aparentemente dominio de do&#xF1;a Mar&#xED;a Pi&#xF1;a Campos, Comisi&#xF3;n integrada por peritos. Sres. Teresa Sancho Pernas y Ren&#xE9; Ureta Koster, arquitectos, y Jos&#xE9; Miguel Haltenhoff Aenishanslin, seg&#xFA;n informe de 19 de junio de 1989, fij&#xF3; monto provisional indemnizaci&#xF3;n en $11.150.000.- pagadera al contado.</div><br></div>", "i": 6099641}, {"t": "<div><div class=\"p\">Director SERVIU Metropolitano.</div><br></div>", "i": 6099642}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "735", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-735"}], "organismos": ["SERVICIO DE VIVIENDA Y URBANIZACIÓN REGIÓN METROPOLITANA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-08-08", "doble_articulado": false, "id_norma": "95315", "numero_fuente": "33463", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-09-01", "vigencias": [{"desde": "1989-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "