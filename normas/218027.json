{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6451285}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 919 de fecha 26 de agosto de 2003, se expropi&#xF3; el lote de terreno N&#xBA; 1-B, superficie 2.250 m&#xB2;, rol N&#xBA; 27-40, comuna de Paredones, para la obra &quot;Camino Mejoramiento Ruta I-72, sector Paredones - Bucalemu, tramo Km. 27,400 a Km. 43,100&quot;, VI Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Germ&#xE1;n Nicol&#xE1;s Gonz&#xE1;lez Pavez, ascendente a la cantidad de $5.907.200.</div><br></div>", "i": 6451286}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6451287}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "919", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-919"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-26", "doble_articulado": false, "id_norma": "218027", "numero_fuente": "37724", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-01", "vigencias": [{"desde": "2003-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2003-12-01", "fecha_version": "2003-12-01", "fecha_actualizacion_texto": "2003-12-01", "tipo_tratado": ""}, "alertas": [], "alerta_global