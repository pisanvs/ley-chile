{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293743}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 694, de 12 de abril de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por SALMONES</div><div class=\"p\">ANTARTICA S.A., para un centro de cultivo ubicado en</div><div class=\"p\">Sector Chulequehue, Canal Dalcahue, Comuna de Dalcahue,</div><div class=\"p\">Provincia de Chilo&#xE9;, X Regi&#xF3;n, por no dar cumplimiento</div><div class=\"p\">el respectivo proyecto t&#xE9;cnico a lo dispuesto en los</div><div class=\"p\">art&#xED;culos 78&#xB0; y 87&#xB0; de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8293744}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 12 de abril de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293745}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "694", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-694"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SALMONES ANTARTICA S.A", "CONCESION ACUICULTURA", "DALCAHUE", "DECIMA REGION", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-04-12", "doble_articulado": false, "id_norma": "35391", "numero_fuente": "35447", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-04-20", "vigencias": [{"desde": "1996-04-20", "hasta": "", "tipo_version": "3", "