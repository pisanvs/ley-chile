{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6276892}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 329 del 13 de Octubre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la I Regi&#xF3;n, se autoriza a Luis Osvaldo V&#xE1;squez Alarc&#xF3;n y Nancy del Carmen Franco G&#xF3;ngora, para efectuar el servicio de taxi colectivo urbano de pasajeros &quot;L&#xED;nea N&#xB0; 3 de Arica&quot;, cuyo trazado fue autorizado por resoluci&#xF3;n N&#xB0; 70 del 21 de Junio de 1984, de esta Secretar&#xED;a Regional.</div><br></div>", "i": 6276893}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Eliecer Aedo Rivera, Secretario Regional Ministerial Transportes y Telecomunicaciones I Regi&#xF3;n Tarapac&#xE1;. </div></div>", "i": 6276894}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "329 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-329 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-10-13", "doble_articulado": false, "id_norma": "169195", "numero_fuente": "32917", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-11", "vigencias": [{"desde": "1987-11-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-11-11", "fin_vigencia": "", "tipo_v