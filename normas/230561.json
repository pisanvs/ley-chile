{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6497902}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 2.643 de 16 de septiembre de 2004 de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 1.517 de 2004, que prorrog&#xF3; el plazo otorgado a PESQUERA PACIFICO SUR S.A. para reanudar actividades pesqueras extractivas con la nave &quot;Don Enrique&quot;, en el Mar Territorial y Zona Econ&#xF3;mica Exclusiva de la Isla de Pascua, Archipi&#xE9;lago de Juan Fern&#xE1;ndez, Islas Sala y G&#xF3;mez e Islas Desventuradas, por fuera del &#xE1;rea de reserva artesanal, con arrastre, sobre el recurso hidrobiol&#xF3;gico Alfonsino, en el sentido de indicar que el plazo de un mes otorgado por la citada resoluci&#xF3;n para reiniciar actividades pesqueras extractivas correr&#xE1; desde la fecha de la presente resoluci&#xF3;n.</div><br></div>", "i": 6497903}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de septiembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6497904}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2643 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2643 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-09-16", "fecha_derogacion": "2015-12-31", "doble_articulado": false, "id_norma": "230561", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-09-23", "vigencias": [{"desde": "2015-12-31", "hasta": "", "tipo_versi