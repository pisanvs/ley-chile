{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 469 EXENTA, DE 16 DE ENERO DE 2020</div></div>", "i": 10105393}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por la presente, se han modificado, a contar del a&#xF1;o escolar 2020, las resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=154467&amp;idParte=&amp;idVersion=\">N&#xBA; 12.857, de 1999</a>, y <a href=\"https://www.leychile.cl/Navegar?idNorma=182737&amp;idParte=&amp;idVersion=\">N&#xBA; 783, de 2001</a>, ambas del Ministerio de Educaci&#xF3;n, que aprobaron planes y programas especiales de estudio de 1&#xBA; a 3&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al establecimiento educacional Colegio Villa Mar&#xED;a Academy, RBD 8873-0, comuna de Las Condes, Regi&#xF3;n Metropolitana, en el sentido de sustituir el plan de estudio de 1&#xBA;, 2&#xBA; y 3&#xBA; a&#xF1;o de Educaci&#xF3;n Media.- </div><br></div>", "i": 10105394}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Figueroa Salas, Subsecretario de Educaci&#xF3;n.</div><div class=\"p\"> </div><br></div>", "i": 10105395}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "469 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-469 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 469 EXENTA, DE 16 DE ENERO DE 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1734642", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-01-16", "doble_articulado": false, "id_norma": "1143055", "numero_fuente": "42595", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-03-0