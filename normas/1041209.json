{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETO N&#xB0; 103 EXENTO, DE 2012</div></div>", "i": 9268482}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xB0; 595, de 14 de junio de 2012, de este Ministerio, modif&#xED;case el art&#xED;culo 3&#xBA; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1036796&amp;idParte=0&amp;idVersion=\">decreto exento N&#xBA; 103, de 2012, del Ministerio de Econom&#xED;a, Fomento y Turismo</a>, que estableci&#xF3; una veda extractiva para el recurso Raya volant&#xED;n, en el &#xE1;rea mar&#xED;tima comprendida entre paralelo 41&#xBA;28,6&apos; LS y el l&#xED;mite sur de la XII Regi&#xF3;n, en el sentido de reemplazar su letra b) por la siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  b) En la pesca artesanal dirigida a Merluza del Sur y Congrio dorado, con espinel, hasta un 20% medido en peso en relaci&#xF3;n a la especie objetivo, por viaje de pesca, con un l&#xED;mite de 60 toneladas de Raya volant&#xED;n al a&#xF1;o.</div><br></div>", "i": 9268483}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de junio de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9268484}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "595 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-595 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA DECRETO N° 103 EXENTO, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-14", "doble_articulado": false, "id_norma": "1041209", "numero_fuente": "40294", "tipo_version": "3", "tipo