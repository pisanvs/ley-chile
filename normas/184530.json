{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6332014}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;580, de 9 de abril de 2001, de esta Subsecretar&#xED;a, ampl&#xED;ase por un a&#xF1;o a contar del 4 de diciembre de 2000, el plazo otorgado por resoluci&#xF3;n N&#xBA; 494 de 2000, de esta Subsecretar&#xED;a, a PESQUERA BURCA LTDA., para continuar actividades pesqueras de transformaci&#xF3;n en su planta ubicada en sector sur de Punta Caica&#xE9;n, comuna de Calbuco, provincia de Llanquihue X Regi&#xF3;n, en virtud de haberse acreditado una circunstancia de fuerza mayor.</div><br></div>", "i": 6332015}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de abril de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6332016}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "580", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-580"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-04-09", "fecha_derogacion": "2002-03-05", "doble_articulado": false, "id_norma": "184530", "numero_fuente": "36945", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2001-04-24", "vigencias": [{"desde": "2002-03-05", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2001-04-24", "hasta": "2002-03-04", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2002-03-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vi