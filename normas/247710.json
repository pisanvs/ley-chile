{"html": [{"t": "<div><div class=\"p\">DEROGA LA CALIDAD DE AGENTE RETENEDOR DEL IVA A VIAL TRADING S.A.</div><br></div>", "i": 6562921}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VI Direcci&#xF3;n Regional de Rancagua del SII, por resoluci&#xF3;n Ex. DRE06.01 N&#xBA; 276, de 22 de febrero de 2006, deroga a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n a Vial Trading S.A., RUT: 96.577.720-2, la calidad de agente retenedor del Impuesto al Valor Agregado en las ventas de trigo, establecido en la Res.</div><div class=\"p\">N&#xBA; Ex. 5.281, del 30.11.2000, de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial el d&#xED;a 4.12.2000. </div></div>", "i": 6562922}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jorge Levet Hern&#xE1;ndez, Director Regional (S). </div></div>", "i": 6562923}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "276 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-276 EXENTA"}, {"tipo": "3", "numero": "DRE-06-01-276 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-06-01-276 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VI DIRECCIÓN REGIONAL DE RANCAGUA"], "titulo_norma": "DEROGA LA CALIDAD DE AGENTE RETENEDOR DEL IVA A VIAL\nTRADING S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-02-22", "doble_articulado": false, "id_norma": "247710", "numero_fuente": "38403", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-02", "vigencias": [{"desde": "2006-03-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenc