{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8319721}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 56, de 20 de enero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, t&#xE9;ngase por cumplido lo ordenado por la sentencia de la Excma. Corte Suprema de 2 de septiembre de 1997, rol N&#xBA; 1573 N&#xBA; 97; en el sentido de haberse acreditado por PESQUERA MAR DEL SUR S.A., que el valor t&#xE9;cnico actualizado de sus activos fijos en tierra es superior al valor t&#xE9;cnico actualizado de su flota pesquera de barcos f&#xE1;brica seg&#xFA;n las exigencias del inciso 5 del art. 12 transitorio de la Ley de Pesca y Acuicultura.</div><br></div>", "i": 8319722}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de enero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8319723}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "56", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-56"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA MAR DEL SUR S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-01-20", "doble_articulado": false, "id_norma": "90921", "numero_fuente": "35978", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-30", "vigencias": [{"desde": "1998-01-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998