{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.003 EXENTO, DE 2005 </div><br></div>", "i": 6541975}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.003, de fecha 22 de julio de 2005, del Ministerio de Educaci&#xF3;n, se aprueba el plan y programas de estudios al Centro de Formaci&#xF3;n T&#xE9;cnica ICADE de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartido a contar del a&#xF1;o 2005:</div><br><div class=\"p\">Carrera&nbsp; &nbsp; :&nbsp; T&#xE9;cnico Jur&#xED;dico</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp;  :&nbsp; T&#xE9;cnico Jur&#xED;dico de Nivel Superior</div><br><div class=\"p\">&nbsp; &nbsp;  El nuevo plan y programas de estudios que se aprueba mediante este decreto pasar&#xE1; a formar parte del proyecto institucional del Centro de Formaci&#xF3;n T&#xE9;cnica ICADE, correspondiendo al Ministerio de Educaci&#xF3;n la verificaci&#xF3;n de su desarrollo.</div><br></div>", "i": 6541976}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de septiembre de 2005.- Pedro Montt Leiva, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6541977}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1003 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1003 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.003 EXENTO, DE 2005", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-07-22", "fecha_derogacion": "2009-09-05", "doble_articulado": false, "id_norma": "242456", "numero_fuente": "38275", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-09-30