{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div><br><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA; 39.367 de 22 de mayo de 2009, se public&#xF3; decreto N&#xBA; 75, que modifica decreto N&#xBA;408, de 1986, con el error que se salva a continuaci&#xF3;n: p&#xE1;gina diez, segunda columna, en el punto 2.-, donde dice &quot;... , con redes cuya altura sea igual o superior a 15 brazas y cuya relinga inferior est&#xE9; aparejada ...&quot; debe decir &quot;... , con redes cuya altura sea igual o menor a 15 brazas y cuya relinga inferior est&#xE9; aparejada ...&quot;.</div><br></div>", "i": 8622586}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "S/N", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-S/N"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1002703", "numero_fuente": "39371", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-05-27", "vigencias": [{"desde": "2009-05-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-05-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-05-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "RECTIFICACION", "url_part": "rectificacion"}], "ingresado_por": "362", "fecha_ingreso": "2009-05-27", "fecha_version": "2009-05-27", "actualizado_por": "362", "fecha_actualizacion_texto": "2009-05-27", "tipo_tratado": ""}, "alertas": [], "alerta_gl