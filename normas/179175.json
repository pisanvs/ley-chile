{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6312882}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;4.574 de fecha 29 de septiembre del 2000, se expropi&#xF3; el lote de terreno N&#xBA;10, superficie 412 m&#xB2;, rol de aval&#xFA;o 1103-49, comuna de Pichidegua, para la obra &apos;&apos;Camino Pichidegua-Marchig&#xFC;e, Sector Marchig&#xFC;e-La Esperanza, Tramo Km. 43.600 a Km.</div><div class=\"p\">69.237,91&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario An&#xED;bal del Carmen Tobar Cer&#xF3;n, ascendente a la cantidad de $2.418.726.-</div><br></div>", "i": 6312883}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6312884}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "4574", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-4574"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-29", "doble_articulado": false, "id_norma": "179175", "numero_fuente": "36838", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-12-15", "vigencias": [{"desde": "2000-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-12-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2000-12-19", "fecha_version": "2000-12-15", "fecha_actualizacion_texto": "2000-12-15", "tipo_tratad