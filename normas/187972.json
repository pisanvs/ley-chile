{"html": [{"t": "<div><div class=\"p\">CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A PISCICULTURA YADRAN S.A.</div><br></div>", "i": 6344011}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional Santiago Poniente del SII por resoluci&#xF3;n N&#xBA; Ex. 1.090, de 29 de junio de 2001, concede la calidad de Agente Retenedor del Impuesto al Valor Agregado en la adquisici&#xF3;n de especies hidrobiol&#xF3;gicas a Piscicultura Yadr&#xE1;n S.A., RUT 96.640.500-7 con vigencia a contar del d&#xED;a 1&#xBA; del mes siguiente al de su publicaci&#xF3;n en el Diario Oficial, y en forma indefinida, mientras se mantenga el fiel cumplimiento de la resoluci&#xF3;n N&#xBA; Ex. 3.311, (D.O.</div><div class=\"p\">03.07.2000).-</div><br></div>", "i": 6344012}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jorge A. de Calisto Bravo, Director Regional. </div></div>", "i": 6344013}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1090 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1090 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO PONIENTE"], "titulo_norma": "CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A PISCICULTURA YADRAN S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-06-29", "doble_articulado": false, "id_norma": "187972", "numero_fuente": "37020", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-07-25", "vigencias": [{"desde": "2001-07-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-07-25", "fin_vigencia": ""}, "vigencias_versi