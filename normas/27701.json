{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DENOMINA &quot;ANDRES BELLO&quot; AL LICEO DE HOMBRES N&#xB0; 6 DE SANTIAGO</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7175474}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Denom&#xED;nase &quot;Andres Bello&quot; al Liceo de Hombres N&#xB0; 6 de Santiago&quot;.</div><br></div>", "i": 7175475}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, siete de Octubre de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- Eduardo Moore Montero.</div><br></div>", "i": 7175476}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14131", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14131"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "DENOMINA ANDRES BELLO AL LICEO DE HOMBRES N° 6 DE SANTIAGO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "LICEO HOMBRES ANDRES BELLO", "SANTIAGO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-10-07", "doble_articulado": false, "id_norma": "27701", "numero_fuente": "24774", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-10-21", "vigencias": [{"desde": "1960-10-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1960-10-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1960-10-21", "fin_vigencia": "", "tipo_ve