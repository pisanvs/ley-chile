{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6434058}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 633 de fecha 30 de junio de 2003, se deja sin efecto el decreto MOP N&#xBA; 1989, de fecha 31 de octubre de 2002, por cuanto la expropiaci&#xF3;n del lote de terreno N&#xBA; 29, de la Obra &quot;Camino: Ruta L-45, Sector: Linares - Llepo, Tramo: Km. 2,750.2 a Km.</div><div class=\"p\">13,147, comuna de Linares, provincia de Linares&quot;, VII Regi&#xF3;n, no es necesario para los requerimientos de la obra.</div><br></div>", "i": 6434059}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6434060}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "633", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-633"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-30", "doble_articulado": false, "id_norma": "213208", "numero_fuente": "37624", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-08-01", "vigencias": [{"desde": "2003-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2003-08-01", "fecha_version": "2003-08-01", "fecha_actualizacion_texto": "2003-08-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n":