{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297511}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.492, de 9 de agosto de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a COMERCIAL Y PESQUERA SOUTH WIND S.A., para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una plante ubicada en Ureta Cox 113, San Joaqu&#xED;n, Santiago, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n que a continuaci&#xF3;n se indican, los siguientes recursos hidrobiol&#xF3;gicos: Semi-Conserva:</div><div class=\"p\"> Salm&#xF3;n</div><div class=\"p\"> _______________________________________________________</div><div class=\"p\"> | NOTA: VER DIARIO OFICIAL N&#xB0; 35.548 DEL DIA JUEVES&nbsp;  |</div><div class=\"p\"> |&nbsp; &nbsp; &nbsp;  22 DE AGOSTO DE 1996, PAGINA 17&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  |</div><div class=\"p\"> |_____________________________________________________|</div><br></div>", "i": 8297512}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 9 de agosto de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297513}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1492", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1492"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMERCIAL PESQUERA SOUTH WIND S.A.", "PESCA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-08-09", "fecha_derogacion": "2001-10-06", "do