{"html": [{"t": "<div><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N N&#xBA; 4.014 EXENTA, DE 2019</div></div>", "i": 10093541}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 26, de 9 de enero de 2020, de esta Subsecretar&#xED;a, rectif&#xED;quese el resuelvo 1&#xBA; de la resoluci&#xF3;n exenta N&#xBA; 4.014, de 2019, de esta Subsecretar&#xED;a, que estableci&#xF3; las toneladas que podr&#xE1;n capturar durante el a&#xF1;o 2020 los titulares de licencias transables de pesca clase B, en el sentido de incorporar la siguiente tabla al recurso Anchoveta en la unidad de pesquer&#xED;a de las Regiones XV a II:</div><div class=\"p\"> </div><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/103783.jpg\"></div></div>", "i": 10093542}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de enero de 2020.- Rom&#xE1;n Zelaya R&#xED;os, Subsecretario de Pesca y Acuicultura.</div><br></div>", "i": 10093543}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "26 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-26 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "RECTIFICA RESOLUCIÓN Nº 4.014 EXENTA, DE 2019", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1712311; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-01-09", "doble_articulado": false, "id_norma": "1141314", "numero_fuente": "42555", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-01-17", "vigencias": [{"desde": "2020-01-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia":