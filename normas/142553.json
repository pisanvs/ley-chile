{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 327, DE 1986 </div></div>", "i": 6188675}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 327 de 22 de diciembre de 1986 se ha modificado, a contar del a&#xF1;o escolar 1987, el decreto supremo exento de Educaci&#xF3;n No. 69 de 1982, modificado por decreto supremo exento de Educaci&#xF3;n No. 169 de 1983, que aprob&#xF3; planes y programas especiales de estudio para la Educaci&#xF3;n General B&#xE1;sica y Educaci&#xF3;n Media Human&#xED;stico Cient&#xED;fica al Colegio Universitario Ingl&#xE9;s, de Santiago.</div><br></div>", "i": 6188676}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de Abril de 1987.- Ren&#xE9; Salam&#xE9; Mart&#xED;n, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6188677}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "327", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-327"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 327, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-12-22", "doble_articulado": false, "id_norma": "142553", "numero_fuente": "32755", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-04-25", "vigencias": [{"desde": "1987-04-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-04-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-04-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "i