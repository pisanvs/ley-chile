{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,528, que suplementa el Presupuesto de Marina.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,528.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 7166757}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese un suplemento de cuatrocientos mil pesos ($400,000) al &#xED;tem 546 del Presupuesto de Marina vijente.</div><div class=\"p\">&nbsp; &nbsp; D&#xE9;jase sin invertir igual cantidad del &#xED;tem 778 del indicado Presupuesto.</div><br></div>", "i": 7166758}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a nueve de Agosto de mil novecientos diecinueve.- JUAN LUIS SANFUENTES.- Enrique Berm&#xFA;dez. </div></div>", "i": 7166759}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3528", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3528"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "LEI NÚM. 3,528, QUE SUPLEMENTA EL PRESUPUESTO DE MARINA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1919", "MODIFICACION", "MINISTERIO", "MARINA", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1919-08-09", "doble_articulado": false, "id_norma": "24041", "numero_fuente": "12446", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1919-08-12", "vigencias": [{"desde": "1919-08-12", "hasta": "", "tipo_version": "3", "tipo_version