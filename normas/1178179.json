{"html": [{"t": "<div><div class=\"p\">OT&#xD3;RGASE CALIDAD DE AGENTE RETENEDOR DE IVA</div></div>", "i": 10346113}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del SII, por resoluci&#xF3;n Ex. N&#xBA; 77322113905, de fecha 3 de junio de 2022, otorga al contribuyente Compra Venta de Metales y Pl&#xE1;sticos Mario Jara Escobar E.I.R.L., RUT 76.937.559-7, a partir del d&#xED;a 1&#xBA; del mes siguiente de esta publicaci&#xF3;n en Diario Oficial, la calidad de Agente Retenedor del Impuesto al Valor Agregado en ventas de Chatarra, conforme a lo establecido en la resoluci&#xF3;n Ex. N&#xBA; 86 de fecha 24.08.2016 de la Direcci&#xF3;n Nacional del Servicio de Impuestos Internos.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10346114}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Cristian Alberto G&#xF3;mez Castillo, Director Regional Concepci&#xF3;n.</div><div class=\"p\"> </div><br></div>", "i": 10346115}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "77322113905 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-77322113905 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL CONCEPCIÓN"], "titulo_norma": "OTÓRGASE CALIDAD DE AGENTE RETENEDOR DE IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2150436", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-06-03", "doble_articulado": false, "id_norma": "1178179", "numero_fuente": "43292", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-07-02", "vigencias": [{"desde": "2022-07-02", "hasta": "", "tipo_version": "3", "tipo_ve