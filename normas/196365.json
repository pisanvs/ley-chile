{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6375431}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 5,45% anual durante el mes de febrero de 1989.</div><br><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad a lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1 del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables de 90 a 365 d&#xED;as, correspondiente a la segunda quincena de febrero de 1989, fue de 5,51% anual.</div><br></div>", "i": 6375432}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 02 de marzo de 1989.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6375433}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-03-02", "doble_articulado": false, "id_norma": "196365", "numero_fuente": "33313", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-03-03", "vigencias": [{"desde": "1989-03-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-03-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-03-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_