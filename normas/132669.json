{"html": [{"t": "<div><div class=\"p\">ORDENA&nbsp; EXPROPIACION&nbsp; DE&nbsp; INMUEBLE</div><br></div>", "i": 6156840}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 696 de 21 de diciembre de 1998, de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xBA; 2.186 de 1978, parte inmueble ubicado en Nueva Costanera N&#xBA; 4270- Lote 4-A, presunto rol de aval&#xFA;o&nbsp; N&#xBA; 589-1 parte, comuna de Vitacura, de aparente dominio de Fisco-Instituto Nacional.&nbsp;  Comisi&#xF3;n integrada por peritos Ren&#xE9; Ureta Koster, Nancy S&#xE1;nchez Sep&#xFA;lveda, arquitectos y Miguel Ortiz Bobadilla, constructor civil seg&#xFA;n informe de 30 de octubre de 1998 fij&#xF3; monto provisional de indemnizaci&#xF3;n en $130.920.000.- pagadera al contado.-</div><br></div>", "i": 6156841}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 6156842}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "696", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-696"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACION DE INMUEBLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-12-21", "doble_articulado": false, "id_norma": "132669", "numero_fuente": "36302", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-03-01", "vigencias": [{"desde": "1999-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"in