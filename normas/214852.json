{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CERTIFICADO</div><br></div>", "i": 6440369}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  EL Subsecretario de Educaci&#xF3;n, quien suscribe, certifica que la carrera de Educaci&#xF3;n Media en Historia y Geograf&#xED;a que ofrece el Instituto Profesional Advestista, autorizado seg&#xFA;n Certificado N&#xBA; 420 de 13 de Junio de 1983, ha cumplido con los requisitos establecidos en el Art&#xED;culo 14&#xBA; del DFL. N&#xBA; 5 de 1981 del Ministerio de Educaci&#xF3;n, seg&#xFA;n lo certifica la Universidad de Concepci&#xF3;n, quien actu&#xF3; como entidad examinadora de los alumnos de dicha carrera.</div><div class=\"p\">&nbsp; &nbsp;  El Instituto Profesional Anventista est&#xE1; en condiciones de otorgar independientemente el t&#xED;tulo correspondiente a la carrera de Educaci&#xF3;n Media en Historia y Geograf&#xED;a, a contar del a&#xF1;o 1991. </div></div>", "i": 6440370}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 21 de Agosto de 1991.</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  RAUL ALLARD NEUMANN</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Subsecretario de Educaci&#xF3;n</div><br></div>", "i": 6440371}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-08-21", "doble_articulado": false, "id_norma": "214