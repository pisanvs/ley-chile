{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6322613}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 2.875, de 30 de septiembre de 1999, se orden&#xF3; la expropiaci&#xF3;n y aprob&#xF3; el plano y cuadro de expropiaci&#xF3;n del lote de terreno N&#xBA; 10-B, y por decreto MOP N&#xBA; 4.813, de 31 de octubre de 2000, se autoriz&#xF3; el valor de la consignaci&#xF3;n provisional de la expropiaci&#xF3;n por la v&#xED;a judicial, en la cantidad de $724.000.- necesario para la ejecuci&#xF3;n de la obra &apos;&apos;Camino Ruta H-455, Sector Sta. Amalia-Pimpinela Tramo Km. 0.000,00 a Km. 12.282,94&apos;&apos;, el pago de la indemnizaci&#xF3;n se efectuar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.</div><br></div>", "i": 6322614}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6322615}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2875", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2875"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-30", "doble_articulado": false, "id_norma": "181836", "numero_fuente": "36889", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-02-15", "vigencias": [{"desde": "2001-02-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-02-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-02-