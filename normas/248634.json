{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7328765}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 917, de 27 de marzo de 2006, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 572 de 1996, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a Sociedad Pesquera Viento Sur Limitada, hoy SOCIEDAD PESQUERA VIENTO SUR S.A., para realizar actividades pesqueras extractivas con la nave &quot;Sunnan II&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre la VIII Regi&#xF3;n y el paralelo 41&#xB0;28,6&apos; L.S., sobre el recurso hidrobiol&#xF3;gico Raya, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7328766}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de marzo de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7328767}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "917 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-917 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-03-27", "doble_articulado": false, "id_norma": "248634", "numero_fuente": "38430", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-04-03", "vigencias": [{"desde": "2006-04-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-04-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc