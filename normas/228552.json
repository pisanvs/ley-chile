{"html": [{"t": "<div><div class=\"p\">EXTRACTO&nbsp; DE DECRETO N&#xBA; 401 EXENTO, DE 2004 </div></div>", "i": 6490563}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 401 de fecha 14 de junio de 2004 del Ministerio de Educaci&#xF3;n, se aprueba el plan y programas de estudios al Centro de Formaci&#xF3;n T&#xE9;cnica Colchagua, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartido a contar del a&#xF1;o 2004:</div><br><div class=\"p\">Carrera :&nbsp; Gastronom&#xED;a</div><div class=\"p\">T&#xED;tulo:&nbsp;  T&#xE9;cnico en Gastronom&#xED;a de Nivel Superior </div><div class=\"p\">&nbsp; &nbsp; El nuevo plan y programas de estudios que se aprueba, pasar&#xE1; a formar parte del proyecto institucional del Centro de Formaci&#xF3;n T&#xE9;cnica Colchagua, correspondiendo al Ministerio de Educaci&#xF3;n la verificaci&#xF3;n de su desarrollo.</div><br></div>", "i": 6490564}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de julio de 2004.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6490565}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "401 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-401 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 401 EXENTO, DE 2004", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-06-14", "fecha_derogacion": "2009-09-05", "doble_articulado": false, "id_norma": "228552", "numero_fuente": "37927", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-08-04", "vigencias": [{"desde": "2009-09-05", "