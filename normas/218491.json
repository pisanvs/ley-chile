{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 943 EXENTO, DE 2003 </div></div>", "i": 6452857}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 943 de fecha 24 de noviembre de 2003, de Educaci&#xF3;n, se autoriza al Instituto Profesional Los Leones la creaci&#xF3;n de la sede ubicada en calle Arturo Prat N&#xBA;269 de la comuna de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, se autoriza para impartir en dicha sede la carrera de Dise&#xF1;o Gr&#xE1;fico Publicitario conducente al t&#xED;tulo profesional de Dise&#xF1;ador Gr&#xE1;fico Publicitario, con salida intermedia al t&#xED;tulo de T&#xE9;cnico de Nivel Superior en Dise&#xF1;o Gr&#xE1;fico Publicitario.</div><br></div>", "i": 6452858}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de diciembre de 2003.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6452859}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "943 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-943 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 943 EXENTO, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-11-24", "doble_articulado": false, "id_norma": "218491", "numero_fuente": "37732", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-11", "vigencias": [{"desde": "2003-12-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-12-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-12-11", "fin_vigencia": "", "tipo