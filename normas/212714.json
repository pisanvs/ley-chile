{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6432508}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.451, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de la resoluci&#xF3;n N&#xBA; 317 de 2003, modificada mediante resoluci&#xF3;n N&#xBA; 656 de 2003, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; a la UNIVERSIDAD CATOLICA DEL NORTE, Sede Coquimbo para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Distribuci&#xF3;n espacio-temporal de las agregaciones de Jurel (Trachurus murphyi) en la III Regi&#xF3;n, temporada 2003&quot;, en el sentido de se&#xF1;alar que la pesca de investigaci&#xF3;n se extender&#xE1; hasta el 31 de diciembre de 2003.</div><br></div>", "i": 6432509}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de junio de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6432510}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1451 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1451 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-30", "doble_articulado": false, "id_norma": "212714", "numero_fuente": "37612", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-18", "vigencias": [{"desde": "2003-07-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-07-18", "fin_vigencia": ""}