{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 4 EXENTO DE 1994 </div></div>", "i": 7159896}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto exento N&#xB0; 4, de fecha 11 de Enero de 1994 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica INACAP las adecuaciones introducidas al plan y programas de estudio de la carrera de Electr&#xF3;nica, las que se insertaron en la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xB0; 418 de 1990. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1994. </div></div>", "i": 7159897}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 30 de Marzo de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7159898}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "4 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-4 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 4 EXENTO DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "CENTRO FORMACION TECNICA", "INACAP", "ELECTRONICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-01-11", "doble_articulado": false, "id_norma": "19540", "numero_fuente": "34853", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-04-30", "vigencias": [{"desde": "1994-04-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-04-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-04-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text