{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION EXCEPCION CAMBIO PARCIAL SUJETO IVA </div></div>", "i": 7348211}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del SII, por resoluci&#xF3;n DRE08/N&#xBA; Ex. 3.313, de fecha 2 de abril de 2007, deja sin efecto, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 14 de la Res. N&#xBA; Ex 3.721/2000, Res. DRE.08. Ex. N&#xBA; 1.037, de 07-10-1998, de esta Direcci&#xF3;n Regional en la que se excepciona a Inmobiliaria e Inversiones Paracadute Ltda., RUT N&#xBA; 79.842.470-K, del cambio parcial de sujeto del Impuesto al Valor Agregado en las ventas de ganado vivo, a partir del d&#xED;a 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n en el Diario Oficial, por cuenta de la peticionaria. </div></div>", "i": 7348212}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Sergio Flores Guti&#xE9;rrez, Director Regional. </div></div>", "i": 7348213}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3313 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-3313 EXENTA"}, {"tipo": "3", "numero": "DRE-08-3313 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-3313 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "DEROGA RESOLUCION EXCEPCION CAMBIO PARCIAL SUJETO IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-04-02", "doble_articulado": false, "id_norma": "262901", "numero_fuente": "38819", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-07-23", "