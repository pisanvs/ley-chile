{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8336721}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xBA; 1.560, de 13 de noviembre de 1998, de esta&nbsp; Subsecretar&#xED;a, modif&#xED;case&nbsp; la&nbsp; resoluci&#xF3;n N&#xBA; 1.032 de 1998, de esta Subsecretar&#xED;a, que autoriz&#xF3; a JORGE ENRIQUE ROJO ACU&#xD1;A, para iniciar actividades pesqueras de transformaci&#xF3;n, en el sentido de agregar el siguiente numeral:</div><br><div class=\"p\">&apos;&apos;12.- D&#xE9;janse sin efecto las resoluciones N&#xBA; 944, de 1988, N&#xBA; 1.101, de 1991 y N&#xBA; 471, de 1996, de esta Subsecretar&#xED;a, que autorizaron a Pesquera Vamar Limitada para operar la planta a que se refiere esta autorizaci&#xF3;n, por renuncia de su titular.&apos;&apos;.</div><br></div>", "i": 8336722}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de noviembre de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8336723}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1560", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1560"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "ROJO ACU A JORGE ENRIQUE", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-11-13", "fecha_derogacion": "2000-09-11", "doble_articulado": false, "id_norma": "127327", "numero_fuente": "36218", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-11-19", "vigencias": [{"desde": "2000-09-11", "hasta": "", "tipo_version": "2", "tipo_version_s": "Últi