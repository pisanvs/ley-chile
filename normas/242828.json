{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6543497}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.937, de 7 de septiembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PITIPALENA LIMITADA, para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en Sitio 2, Manzana 43 Pto. Ra&#xFA;l Mar&#xED;n Balmaceda, Comuna Cisnes, XI Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Fresco Refrigerado, Congelado y Conserva, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br><br></div>", "i": 6543498}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de septiembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6543499}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2937 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2937 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-07", "doble_articulado": false, "id_norma": "242828", "numero_fuente": "38286", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-10-14", "vigencias": [{"desde": "2005-10-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-10-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-10-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC