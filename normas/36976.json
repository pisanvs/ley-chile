{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PARTIDO COMUNISTA DE CHILE </div></div>", "i": 6016724}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Gladys Mar&#xED;n Millie y Lautaro Carmona Soto, Presidente y Secretario General, respectivamente, en representaci&#xF3;n del &quot;Partido Comunista de Chile&quot;, han solicitado la constituci&#xF3;n legal del partido en las Regiones VI del Libertador General Bernardo O&apos;Higgins y VII del Maule, acompa&#xF1;ando las siguientes cantidades de afiliaciones.</div><div class=\"p\"> VI Regi&#xF3;n&nbsp; &nbsp; &nbsp; &nbsp;  2.273</div><div class=\"p\"> VII Regi&#xF3;n&nbsp; &nbsp; &nbsp; &nbsp; 2.594</div><div class=\"p\">&nbsp; &nbsp; P&#xFA;blicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la Ley N&#xB0; 18.603, por Resoluci&#xF3;n O-N&#xB0; 1.438, de fecha 6 de Diciembre de 1995.</div><br></div>", "i": 6016725}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 6 de diciembre de 1995.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6016726}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1438", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1438"}, {"tipo": "3", "numero": "O-1438", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-1438"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO COMUNISTA DE CHILE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDO COMUNISTA CHILE", "CONSTITUCION LEGAL", "PARTIDOS POLITICOS", "SEXTA REGION", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-12-06", "doble_articulado": false, "id_norma": "36976", "numero_fuente": "35346", "tipo_version": "3"