{"html": [{"t": "<div><div class=\"p\">APRUEBA REFORMA DE ESTATUTOS DE &apos;&apos;RGA REINSURANCE COMPANY CHILE S.A.&apos;&apos; </div></div>", "i": 6280637}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico: Que por resoluci&#xF3;n exenta N&#xBA; 124 de 25 de mayo de 2000, se aprob&#xF3; reforma de estatutos de la sociedad an&#xF3;nima &apos;&apos;RGA Reinsurance Company Chile S.A.&apos;&apos;, acordada en junta extraordinaria de accionistas de 29 de abril de 2000, cuya acta consta de la escritura p&#xFA;blica de 2 de mayo de 2000, otorgada ante el Notario de Santiago don Pedro Ricardo Reveco Hormaz&#xE1;bal.</div><div class=\"p\">&nbsp; &nbsp;  La reforma consiste en cambiar el nombre por el de &apos;&apos;Ohio National Reaseguros S.A.&apos;&apos;.</div><br></div>", "i": 6280638}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de mayo de 2000.- Gonzalo Quiroga Riobo, Secretario General Suplente.</div><br></div>", "i": 6280639}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "124 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-124 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "APRUEBA REFORMA DE ESTATUTOS DE ''RGA REINSURANCE COMPANY CHILE S.A.''", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-25", "doble_articulado": false, "id_norma": "170464", "numero_fuente": "36685", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-09", "vigencias": [{"desde": "2000-06-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-09", "fin_vigencia": ""}, "vig