{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8924576}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.004, de 11 de julio de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la petici&#xF3;n para el cultivo de salm&#xF3;nidos se&#xF1;alados en la solicitud N&#xBA; 96103055, presentada por ORLANDO BAHAMONDE VELASQUEZ, para la concesi&#xF3;n de acuicultura otorgada por Resoluci&#xF3;n N&#xBA; 1.155, de 1995, de la Subsecretar&#xED;a de Marina, ubicada en Punta Cal&#xE9;n, Sector San Juan, comuna de Dalcahue, provincia de Chilo&#xE9;, X Regi&#xF3;n, conforme lo dispuesto en los art&#xED;culos 78&#xBA; y 87&#xBA; de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8924577}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de julio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8924578}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1004", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1004"}], "organismos": ["MINISTERIO DE ECONOMÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CULTIVO DE SALMONIDOS", "ORLANDO BAHAMONDE VELASQUEZ", "CONCESION DE ACUICULTURA", "DALCAHUE", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-07-11", "fecha_derogacion": "1999-10-04", "doble_articulado": false, "id_norma": "74350", "numero_fuente": "35820", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-07-19", "vigencias": [{"desde": "1999-10-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última