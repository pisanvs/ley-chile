{"html": [{"t": "<div><br><div class=\"p\">SE POSTERGA ENTRADA EN VIGENCIA DE LA RESOLUCI&#xD3;N N&#xBA; 3.077 EXENTA, DE 2013, DE LA DIRECCI&#xD3;N REGIONAL SANTIAGO ORIENTE</div></div>", "i": 9357067}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n de Grandes Contribuyentes del SII, por resoluci&#xF3;n exenta N&#xBA; 54, de mayo de 2013, postergaci&#xF3;n de entrada en vigencia de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1051633&amp;idParte=0&amp;idVersion=\">Res. Ex. N&#xBA; 3.077, de fecha 12 de abril de 2013</a>, de la Direcci&#xF3;n Regional Santiago Oriente, que otorga excepci&#xF3;n de cambio de sujeto de derecho de IVA conforme a Res. Ex. SII N&#xBA;119, de 08.11.2012, aplazando su entrada en vigencia hasta el d&#xED;a 1 de agosto de 2013.- </div><br></div>", "i": 9357068}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  R&#xF3;mulo G&#xF3;mez Sep&#xFA;lveda, Director de Grandes Contribuyentes.</div></div>", "i": 9357069}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "54 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-54 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN DE GRANDES CONTRIBUYENTES"], "titulo_norma": "SE POSTERGA ENTRADA EN VIGENCIA DE LA RESOLUCIÓN Nº 3.077 EXENTA, DE 2013, DE LA DIRECCIÓN REGIONAL SANTIAGO ORIENTE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN FECHA DE PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1051633", "numero_fuente": "40576", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-06-05", "vigencias": [{"desde": "2013-06-05", "hasta": "", "tipo_version