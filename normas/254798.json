{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6588164}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xB0; 591 de fecha 31 de agosto del 2006, se expropiaron los lotes de terreno N&#xB0;s. 107 y 109, superficies 163 y 631 m2, Rol N&#xB0; 259-124, comuna de Carahue, IX Regi&#xF3;n para la obra &quot;Camino Reposici&#xF3;n Ruta S-40, sector Nueva Imperial Carahue, Tramo Km. 0,00000 al Km. 21,58295, correspondiente al Subtramo III Km. 12,86300 al Km.</div><div class=\"p\">21,58295&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Rosa Colip&#xED; Toro, ascendente a la cantidad de $864.527.- para los lotes N&#xB0;s. 107 y 109. </div></div>", "i": 6588165}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6588166}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "591 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-591 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-08-31", "doble_articulado": false, "id_norma": "254798", "numero_fuente": "38603", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-11-02", "vigencias": [{"desde": "2006-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2006-11