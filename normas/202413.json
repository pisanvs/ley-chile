{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6395821}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;1.799, de 23 de agosto de 2002, modif&#xED;case el n&#xFA;meral 4&#xBA; de la resoluci&#xF3;n N&#xBA;1.312, de 2002, de esta Subsecretar&#xED;a que autoriz&#xF3; al INSTITUTO DE INVESTIGACION PESQUERA OCTAVA REGION (INPESCA), para efectuar una pesca de investigaci&#xF3;n de conformidad con los t&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Delimitaci&#xF3;n y caracterizaci&#xF3;n de la estructura de las agregaciones de Jurel entre la III y X Regiones&quot;, en el sentido de se&#xF1;alar que la pesca de investigaci&#xF3;n se realizar&#xE1; entre el 25 de junio y el 4 de septiembre de 2002, ambas fechas inclusive. </div></div>", "i": 6395822}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de agosto de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6395823}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1799", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1799"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-08-23", "doble_articulado": false, "id_norma": "202413", "numero_fuente": "37354", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-09-07", "vigencias": [{"desde": "2002-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-09-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_