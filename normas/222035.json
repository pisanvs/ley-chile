{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6467593}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 377, de 9 de febrero de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a REGINA DEL CARMEN VALENZUELA PACHECO, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Pasaje Subercaseaux N&#xBA; 175, Poblaci&#xF3;n Cornelio Saavedra, Lebu, VIII Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco-Enfriado, Fresco-Refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6467594}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de febrero de 2004.- Jessica Fuentes Olmos, Subsecretaria de Pesca (S).</div><br></div>", "i": 6467595}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "377 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-377 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-09", "doble_articulado": false, "id_norma": "222035", "numero_fuente": "37803", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-05", "vigencias": [{"desde": "2004-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-03-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-03-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci