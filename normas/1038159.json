{"html": [{"t": "<div><br><div class=\"p\">ESTABLECE CUOTA ANUAL DE CAPTURA DE ALGAS PARDAS EN &#xC1;REA QUE INDICA</div><br></div>", "i": 9242861}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 250, de 9 de marzo de 2012 de este Ministerio, f&#xED;jase para el a&#xF1;o 2012 una cuota anual de captura de 10.955,06 toneladas para el recurso Huiro negro, de 9.657,62 toneladas para el recurso Huiro palo y de 2.622,85 toneladas para el recurso Huiro macro, a ser extra&#xED;das en el &#xE1;rea mar&#xED;tima de la IV Regi&#xF3;n de Coquimbo, fraccionada temporal y geogr&#xE1;ficamente de la siguiente forma:</div><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/25024.jpg\">.</div><div class=\"p\"> </div></div>", "i": 9242862}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de marzo de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9242863}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "250 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-250 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "ESTABLECE CUOTA ANUAL DE CAPTURA DE ALGAS PARDAS EN ÁREA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-03-09", "doble_articulado": false, "id_norma": "1038159", "numero_fuente": "40217", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-03-20", "vigencias": [{"desde": "2012-03-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-03-20", "fin_vigenci