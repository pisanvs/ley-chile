{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6558918}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 196, de 18 de enero de 2006, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de las resoluciones que se se&#xF1;alan, s&#xF3;lo en cuanto autorizaron a PESQUERA BIO-BIO S.A. para operar con las naves que se indican sobre el recurso hidrobiol&#xF3;gico Besugo, respecto del &#xE1;rea mar&#xED;tima correspondiente a la III Regi&#xF3;n, con arrastre de media agua, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura:</div><br><div class=\"p\">Nave&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Resoluci&#xF3;n</div><div class=\"p\">Gardar&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  N&#xBA; 1.974 de 2003</div><div class=\"p\">Galletu&#xE9;&nbsp; &nbsp; &nbsp; &nbsp;  N&#xBA; 1.983 de 2003</div><div class=\"p\">Duqueco&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; N&#xBA; 1.977 de 2003</div><div class=\"p\">Don Roberto I&nbsp; &nbsp; N&#xBA; 1.965 de 2003.</div><br></div>", "i": 6558919}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de enero de 2006.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6558920}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "196 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-196 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2006-01-18", "fecha_derogacion": "2012-09-06", "doble_articulado": false, "id_norma": "246729", "tipo_version": "2", "tipo_ve