{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7314746}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.506, de 3 de septiembre</div><div class=\"p\">de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a BRACPESCA</div><div class=\"p\">S.A. para ampliar actividades pesqueras extractivas con</div><div class=\"p\">la nave &quot;Punta Talca&quot; en las &#xE1;reas mar&#xED;timas que en cada</div><div class=\"p\">caso se indican, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; capturar los recursos hidrobiol&#xF3;gicos que a continuaci&#xF3;n se se&#xF1;alan: a) En la I Regi&#xF3;n, con arrastre: Camar&#xF3;n nailon; b) Entre la I y II Regiones, con arrastre: Langostino amarillo; c) Entre la I y III Regiones, con arrastre: Merluza com&#xFA;n, Cojinoba del Sur Seriolella caerulea; d) Entre la I y VII Regiones, con arrastre: Gamba, Congrio dorado, Raya;</div><div class=\"p\">e) Entre la I y XI Regiones, con trampas: Centolla, Centoll&#xF3;n; f) Entre la I y III Regiones, con espinel: Jibia.</div><br></div>", "i": 7314747}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de septiembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7314748}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2506 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2506 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-09-03", "fecha_derogacion": "2005-07-29", "doble_arti