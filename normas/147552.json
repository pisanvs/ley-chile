{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 1.824</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Comit&#xE9; Ejecutivo de este Banco Central de Chile en su Sesi&#xF3;n No. 1.824, celebrada el 14 de octubre de 1987, adopt&#xF3; los siguientes acuerdos: </div></div>", "i": 6204808}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1824-09-871014 - Modifica Anexo No. 1 del Cap&#xED;tulo XIX del Compendio de Normas de Cambios Internacionales.</div><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; sustituir, en el inciso segundo de la letra b) del n&#xFA;mero 1 del Anexo No. 1 &quot;Inversiones con T&#xED;tulos de Deuda Externa suscritos, como deudor directo por el Banco Central de Chile&quot; del Cap&#xED;tulo XIX del Compendio de Normas de Cambios Internacionales, el porcentaje &quot;1,1%&quot; por &quot;1,65 %&quot;.</div><br></div>", "i": 6204809}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de octubre de 1987.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6204810}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1824", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1824"}, {"tipo": "5", "numero": "1824-09", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1824-09"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDO BANCO CENTRAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-10-16", "doble_articulado": false, "id_norma": "147552", "numero_fuente": "32896", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-10-17",