{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5844972}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 6,18% anual durante el mes de enero de 1993.</div><div class=\"p\">&nbsp; &nbsp; Asimismo, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de enero de 1993, fue de 6,19% anual. </div></div>", "i": 5844973}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, febrero 4 de 1993.- Jorge Carrasco V&#xE1;squez, Ministro de Fe (I).</div><br></div>", "i": 5844974}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA INTERES PROMEDIO", "VALOR TIP", "OPERACIONES CREDITO DINERO REAJUSTABLES ENE - 1993"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-02-04", "doble_articulado": false, "id_norma": "1724", "numero_fuente": "34484", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-02-05", "vigencias": [{"desde": "1993-02-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-02-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-02-05", "fin_vigencia": "", "tipo_version": "3"}], "event