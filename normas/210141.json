{"html": [{"t": "<div><div class=\"p\">EXTRACTO </div></div>", "i": 6423386}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial exenta N&#xBA; 30, del 21 de marzo del a&#xF1;o 2003, se autoriz&#xF3; la existencia y aprob&#xF3; el estatuto de la Cooperativa de Ahorro y Cr&#xE9;dito de los Funcionarios del Departamento de Educaci&#xF3;n de Vilc&#xFA;n, de sigla Coopevil, de la ciudad de Vilc&#xFA;n; en los t&#xE9;rminos que da testimonio el acta constitutiva reducida a escritura p&#xFA;blica con fecha 2 de agosto del a&#xF1;o 2002, ante el Notario de Temuco, don Humberto Toro Mart&#xED;nez-Conde.</div><br></div>", "i": 6423387}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Ra&#xFA;l Oliva Camadro, Jefe Departamento de Cooperativas, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6423388}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "30 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-30 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-03-21", "doble_articulado": false, "id_norma": "210141", "numero_fuente": "37554", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-05-09", "vigencias": [{"desde": "2003-05-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-05-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vi