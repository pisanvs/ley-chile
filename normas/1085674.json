{"html": [{"t": "<div><br><div class=\"p\">ANDHA CHILE, EN FORMACI&#xD3;N</div></div>", "i": 9658801}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Do&#xF1;a N&#xE9;lida Victoria Torres Salazar, Presidenta de la Directiva Central provisional del partido Andha Chile, en formaci&#xF3;n, y las se&#xF1;oras Nancy del Carmen Far&#xED;as Guerrero y Mar&#xED;a Alicia Valenzuela Greiz, Presidenta y Secretaria, respectivamente, del Tribunal Supremo provisional de la entidad, en que informan la designaci&#xF3;n como Secretaria General subrogante de do&#xF1;a Roxana del Pilar Miranda Meneses, en reemplazo de don &#xD3;scar Fabi&#xE1;n Bustamante Y&#xE1;&#xF1;ez.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada en virtud de lo dispuesto en el <a href=\"https://www.leychile.cl/Navegar?idNorma=29951&amp;idParte=8638369&amp;idVersion=\">art&#xED;culo 68</a> letras h) y k) de la <a href=\"https://www.leychile.cl/Navegar?idNorma=29951&amp;idParte=0&amp;idVersion=\">ley N&#xBA; 18.556</a> y Auto Acordado de fecha 27 de junio de 1988, del Tribunal Calificador de Elecciones, por Resoluci&#xF3;n O-N&#xBA;251, de fecha 9 de diciembre de 2015.</div><br></div>", "i": 9658802}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Elizabeth Cabrera Burgos, Directora (S).</div></div>", "i": 9658803}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "251", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-251"}, {"tipo": "3", "numero": "O-251", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-251"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "ANDHA CHILE, EN FORMACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 979121; EXTRA