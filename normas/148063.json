{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br></div>", "i": 6206699}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 59, de fecha 09 de Enero de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a don Jesus Antonio Mart&#xED;nez Garc&#xED;a para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6206700}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de Enero de 1987.- Ramiro Camero Weir, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana, subrogante. </div></div>", "i": 6206701}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "59 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-59 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-01-09", "doble_articulado": false, "id_norma": "148063", "numero_fuente": "32770", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-05-14", "vigencias": [{"desde": "1987-05-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-05-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-05-14", "fin_vigencia