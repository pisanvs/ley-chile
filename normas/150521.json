{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 91, DE 1999</div><br><br></div>", "i": 8355721}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA; 91 de fecha 26 de noviembre de 1999, se autoriz&#xF3; la existencia y se aprob&#xF3; el estatuto de la Cooperativa de Ahorro y Cr&#xE9;dito de los Trabajadores Portuarios de Chile, en los t&#xE9;rminos que da testimonio la escritura p&#xFA;blica suscrita con fecha 10 de noviembre de 1999, ante el Notario de Santiago, don Ra&#xFA;l Iv&#xE1;n Perry Pefaur.</div><br></div>", "i": 8355722}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Sr. Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8355723}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "91", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-91"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 91, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-11-26", "doble_articulado": false, "id_norma": "150521", "numero_fuente": "36555", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-01-06", "vigencias": [{"desde": "2000-01-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-01-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-01-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie