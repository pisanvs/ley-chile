{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N DE DELEGACI&#xD3;N DE FACULTADES</div></div>", "i": 9949455}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  La D&#xE9;cima S&#xE9;ptima Direcci&#xF3;n Regional Valdivia, del Servicio de Impuestos Internos, por resoluci&#xF3;n exenta N&#xBA; 2.025, de fecha 4 de septiembre de 2018, delega en los funcionarios que indica la facultad de otorgar certificados de aval&#xFA;os de bienes ra&#xED;ces, certificados que dan cuenta de resoluciones en tr&#xE1;mite, certificados de aval&#xFA;o proporcional en parte del terreno y/o construcci&#xF3;n y efectuar modificaciones a los archivos de datos de los bienes ra&#xED;ces en los casos que indica.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento est&#xE1; publicado en &quot;www.sii.cl&quot;.- </div></div>", "i": 9949456}, {"t": "<div><div class=\"p\">Jimena Castillo Bascu&#xF1;&#xE1;n, Directora Regional XVII Direcci&#xF3;n Regional Valdivia.</div></div>", "i": 9949457}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2025 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2025 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL VALDIVIA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN DE DELEGACIÓN DE FACULTADES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1464669", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-09-04", "doble_articulado": false, "id_norma": "1123081", "numero_fuente": "42160", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-09-20", "vigencias": [{"desde": "2018-09