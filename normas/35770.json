{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294664}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 874, de 8 de mayo de 1996, de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, cad&#xFA;canse las Resoluciones N&#xB0;</div><div class=\"p\">1448, de 1990 y N&#xB0; 307, de 1992, ambas de esta</div><div class=\"p\">Subsecretar&#xED;a, que autorizaron a PESQUERA PETERSEO</div><div class=\"p\">LIMITADA Y PESQUERA PETERSEO S.A., respectivamente, para</div><div class=\"p\">realizar actividades pesqueras con las naves &quot;Peterseo</div><div class=\"p\">I&quot; y &quot;Peterseo II&quot;, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143, letra b) del D.S. N&#xB0; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8294665}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 8 de mayo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294666}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "874", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-874"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "PESCA", "PESQUERA PETERSEO LIMITADA", "PESQUERA PETERSEO S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-08", "doble_articulado": false, "id_norma": "35770", "numero_fuente": "35468", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-05-16", "vigencias": [{"desde": "1996-05-16"