{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; FIJA FECHA PARA LA ELECCION DE REGIDORES DE LA COMUNA SUBDELEGACION DE COYHAIQUE</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Honorable Congreso Nacional ha tenido a bien prestar su aprobaci&#xF3;n al siguiente,</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8278500}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1&#xB0;.- La elecci&#xF3;n de regidores de la comuna subdelegaci&#xF3;n de Coyhaique, creada por ley N&#xB0; 8,750, se verificar&#xE1; el 21 de Noviembre de 1948.</div><br></div>", "i": 8278501}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2&#xB0;.- Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 8278502}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta de Septiembre de mil novecientos cuarenta y ocho.- GABRIEL GONZALEZ VIDELA.- I. Holger T. </div></div>", "i": 8278503}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "9100", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-9100"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "FIJA FECHA PARA LA ELECCION DE REGIDORES DE LA\nCOMUNA SUBDELEGACION DE COYHAIQUE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ELECCION REGIDOR", "COMUNA SUBDELEGACION COYHAIQUE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1948-09-30", "doble_articulado": false, "id_norma": "25916", "numero_fuente": "21173", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion"