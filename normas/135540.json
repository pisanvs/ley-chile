{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,632.- Santiago, 26 de diciembre de 1903.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6165743}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atenci&#xF3;n a los servicios prestados durante la guerra contra el Per&#xFA; i Bolivia por la cantinera Mercedes Bebia, conc&#xE9;desele, por gracia, una pension anual vitalicia, de ciento ochenta pesos. </div></div>", "i": 6165744}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo, por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Luis Barros M&#xE9;ndez.</div><br></div>", "i": 6165745}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1632", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1632"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1903-12-26", "doble_articulado": false, "id_norma": "135540", "numero_fuente": "7788", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1903-12-26", "vigencias": [{"desde": "1903-12-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1903-12-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1903-12-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-04-27", "fecha_version": "1903-12-26", "fecha