{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div><br><br></div>", "i": 6405336}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA; 94, de 8 de octubre del a&#xF1;o 2002, se autoriz&#xF3; la existencia y aprob&#xF3; el estatuto de la &quot;Cooperativa de Trabajo Duatao&quot; de Ancud, en los t&#xE9;rminos que da testimonio el acta constitutiva protocolizada ante la Notario de Ancud Martita Worner Tapia, Repertorio N&#xBA;633-2002, agregada al final del registro bajo el N&#xBA;498 de fecha 12 de junio del a&#xF1;o 2002, complementada por el acta protocolizada ante la misma Notario, Repertorio N&#xBA;979-2002, agregada al final del registro bajo el N&#xBA;749 de fecha 10 de septiembre del a&#xF1;o 2002.</div><br></div>", "i": 6405337}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Ra&#xFA;l Oliva Camadro, Jefe Departamento de Cooperativas.</div><br></div>", "i": 6405338}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "94", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-94"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-10-08", "doble_articulado": false, "id_norma": "205377", "numero_fuente": "37428", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-07", "vigencias": [{"desde": "2002-12-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia