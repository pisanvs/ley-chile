{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6405113}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.722, de 22 de noviembre de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA DEL CABO S.A., para realizar actividades extractivas en aguas internacionales con la nave &quot;Zonace I&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2771</div><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp;  CB-4143</div><div class=\"p\">Eslora arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 53,30 m</div><div class=\"p\">T.R.G. (Internacional)&nbsp;  646,00</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; 860,00 m3</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1.941 de 2001, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6405114}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de noviembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6405115}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2722", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2722"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-11-22", "doble_articulado": false, "id_norma": "205316", "numero_fuente": "37426", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-1