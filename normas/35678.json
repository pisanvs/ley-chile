{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ORDENA EXPROPIACIONES QUE SE&#xD1;ALA </div></div>", "i": 6012952}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 837 de 13 de Septiembre de 1994 de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xB0; 2.186 de 1978, del inmueble ubicado Avda. Marathon N&#xB0; 1673, presunto rol de aval&#xFA;os N&#xB0; 6315-55 comuna de &#xD1;u&#xF1;oa, aparente dominio de don V&#xED;ctor Valenzuela Pardo. Comisi&#xF3;n integrada por peritos Sres. Roberto Correa Bezanilla y Jorge Felipe C&#xE1;diz Bouch, arquitectos y Luis Rojas Quezada, constructor civil, seg&#xFA;n informe de 10 de Junio de 1994, fij&#xF3; monto provisional indemnizaci&#xF3;n en $8.206.000.- pagadera al contado.-</div><br></div>", "i": 6012953}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director SERVIU Metropolitano.</div><br></div>", "i": 6012954}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "837", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-837"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "ORDENA EXPROPIACIONES QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "BIEN RAIZ", "U OA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-09-13", "doble_articulado": false, "id_norma": "35678", "numero_fuente": "34991-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-10-15", "vigencias": [{"desde": "1994-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "199