{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO DE EXENCION DE DERECHOS MUNICIPALES </div><div class=\"p\">&nbsp; &nbsp;  Rancagua, Julio 13 de 1987.- Con esta fecha la Alcald&#xED;a decret&#xF3; lo siguiente:</div><br></div>", "i": 6200087}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 601 exento.- Elim&#xED;nase el derecho municipal por suministro de agua potable para los sectores rurales de la Comuna previsto en el No. 6 del Art&#xED;culo 12 del Decreto Exento No. 890, de 1985, Ordenanza Local de Derechos Municipales por Servicios, Concesiones y Permisos de la Municipalidad de Rancagua.</div><br></div>", "i": 6200088}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese. publ&#xED;quese y arch&#xED;vese.- Ricardo Sandoval Hern&#xE1;ndez, Secretario Municipal.</div><br></div>", "i": 6200089}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "601 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-601 EXENTO"}], "organismos": ["MUNICIPALIDAD DE RANCAGUA"], "titulo_norma": "EXTRACTO DE DECRETO DE EXENCION DE DERECHOS MUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-13", "doble_articulado": false, "id_norma": "146198", "numero_fuente": "32826", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-22", "vigencias": [{"desde": "1987-07-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-07-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresad