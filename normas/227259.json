{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6743767}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. No. 259, de 30 de octubre de 1987, se expropiaron los lotes N&#xB0;s. 1, 1-A, 1-B y 2, superficies 105 M2., 68 M2., 145 M2. y 660 M2., roles de aval&#xFA;os 231-38 y 231-66, Comuna de Rengo, obra: Camino Tipaume Fundo El Sauce, sector Puente El Sauce y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios do&#xF1;a Mar&#xED;a Lucrecia Abarca Henr&#xED;quez y don Jaime Mauricio Cuevas Gil, ascendente a las sumas de $ 85.881 y $ 159.592.</div><br></div>", "i": 6743768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6743769}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "259", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-259"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-10-30", "doble_articulado": false, "id_norma": "227259", "numero_fuente": "32934", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-01", "vigencias": [{"desde": "1987-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2004-07-06", "fecha_version": "1987-12-01", "fecha_actualizacion_texto": "1987-12-01", "tipo_tratado": ""}, "alertas": [], "a