{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 1.844</div><br><div class=\"p\">Certifico que el Comit&#xE9; Ejecutivo de este Banco Central de Chile en su Sesi&#xF3;n No. 1.844, celebrada el 27 de Enero de 1988, adopt&#xF3; los siguientes acuerdos:</div><br></div>", "i": 6183544}, {"t": "<div><div class=\"p\">1844-04-880127- Modifica Acuerdo No. 1555-07-840209. Se acord&#xF3; reemplazar la actual letra d) del n&#xFA;meral 6.4 del Acuerdo No. 155507-840209, por la siguiente:</div><br><div class=\"p\">&quot;d) Los certificados llevar&#xE1;n la firma manuscrita del Gerente de Instituciones Financieras y del Jefe del Departamento de Normalizaci&#xF3;n.&quot; </div></div>", "i": 6183545}, {"t": "<div><br><div class=\"p\">Santiago, 29 de Enero de 1988.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6183546}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1844", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1844"}, {"tipo": "5", "numero": "1844-04", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1844-04"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 1.844", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-27", "doble_articulado": false, "id_norma": "140847", "numero_fuente": "32984", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-01", "vigencias": [{"desde": "1988-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio