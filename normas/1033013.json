{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Decreto-Lei</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 270.- Santiago, 24 de febrero de 1925.-La Junta de Gobierno, de acuerdo con el Consejo de Secretarios de Estado, dicta el siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  DECRETO-LEI:</div></div>", "i": 9207664}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Las peluquer&#xED;as no quedar&#xE1;n comprendidas entre las industrias esceptuadas del descanso dominical, aun cuando sean atendidas por sus propios due&#xF1;os.</div><div class=\"p\">&nbsp; &nbsp;  Este decreto-lei comenzar&#xE1; a rejir desde su publicacion en el Diario Oficial.</div></div>", "i": 9207665}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Boletin de las Leyes y Decretos del Gobierno.- Emilio Bello C. -C. A. Ward.- Pedro P. Dartnell E.- J. S. Salas.</div></div>", "i": 9207666}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "270", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "Decreto Ley-270"}], "organismos": ["MINISTERIO DE HIJIENE, ASISTENCIA, PREVISIÓN SOCIAL Y TRABAJO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1925-02-24", "doble_articulado": false, "id_norma": "1033013", "numero_fuente": "14119", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1925-02-24", "vigencias": [{"desde": "1925-02-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1925-02-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1925-02-24", "fin_vigenci