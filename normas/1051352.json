{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 979 EXENTA, DE 2013</div></div>", "i": 9355019}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.299, de 23 de mayo de 2013, de esta Subsecretar&#xED;a, modif&#xED;case el inciso 1&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1050222&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 979, de 2013</a>, de esta Subsecretar&#xED;a, en el sentido de se&#xF1;alar que la distribuci&#xF3;n de la cuota de captura artesanal de Congrio dorado en la X Regi&#xF3;n de Los Lagos, per&#xED;odo abril-diciembre, se efectuar&#xE1; por flota o tama&#xF1;o de embarcaci&#xF3;n de la siguiente manera:</div><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/33039.jpg\"> </div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9355020}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de mayo de 2013.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9355021}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1299 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1299 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 979 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "