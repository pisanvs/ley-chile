{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7161765}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 394 de fecha 22 de Julio de 1993 del Ministerio de Educaci&#xF3;n, se modific&#xF3; el Decreto Exento de Educaci&#xF3;n N&#xB0; 246 de 1991 que reconoce oficialmente a la Universidad Blas Ca&#xF1;as, en lo relativo al nombre de la Instituci&#xF3;n la que pasa a denominarse &quot;Universidad Cat&#xF3;lica Blas Ca&#xF1;as&quot;.</div><div class=\"p\">&nbsp; &nbsp; Lo anterior deber&#xE1; anotarse en el Registro de Universidades C-N&#xB0; 46 de la Divisi&#xF3;n de Educaci&#xF3;n Superior del Ministerio de Educaci&#xF3;n.-</div><br></div>", "i": 7161766}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n. + </div></div>", "i": 7161767}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "394 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-394 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["UNIVERSIDAD CATOLICA BLAS CA AS", "NOMBRE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-07-22", "doble_articulado": false, "id_norma": "21132", "numero_fuente": "34678", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-09-29", "vigencias": [{"desde": "1993-09-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-09-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-09-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part":