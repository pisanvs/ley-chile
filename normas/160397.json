{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 55, DE 1985 </div></div>", "i": 6248678}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 55, de 13 de Marzo de 1985 se ha autorizado al Liceo C.R.E.P. de Vi&#xF1;a del Mar para aplicar el decreto supremo exento de Educaci&#xF3;n No. 132, de 1983, que aprob&#xF3; planes y programas especiales de estudio de Educaci&#xF3;n Media Human&#xED;stico Cient&#xED;fica para Adultos al Liceo C.R.E.P. de Quilpu&#xE9;.</div><br></div>", "i": 6248679}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de Marzo de 1985.- Ren&#xE9; Salam&#xE9; Martina, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6248680}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "55 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-55 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 55, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-03-13", "doble_articulado": false, "id_norma": "160397", "numero_fuente": "32138", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-04-03", "vigencias": [{"desde": "1985-04-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-04-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-04-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-03-10", "fecha_version": "1985-04-03", "fecha_actualizaci