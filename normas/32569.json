{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESIGNA COMO MINISTRO DE FE A FUNCIONARIO QUE INDICA N&#xFA;m. 45.- Santiago, 4 de Marzo de 1994.- Vistos: Lo dispuesto en el Art. 4&#xB0; del decreto ley N&#xB0; 2.974, de 1979.</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 6004344}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Des&#xED;gnase como Ministro de Fe para actuar en las localidades ubicadas en la X Regi&#xF3;n, en que no hayan Notarios ni Oficiales del Registro Civil, al siguiente funcionario:</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; - Jos&#xE9; Luis Sergio Lozano.</div><br></div>", "i": 6004345}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hugo Ortega Tello, Director Nacional.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Encargada Oficina de Partes.</div><br></div>", "i": 6004346}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "45", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-45"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "DESIGNA COMO MINISTRO DE FE A FUNCIONARIO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MINISTRO FE", "DECIMA REGION", "JOSE LUIS SERGIO LOZANO", "NOMBRAMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-04", "doble_articulado": false, "id_norma": "32569", "numero_fuente": "34825", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-03-26", "vigencias": [{"desde": "1994-03-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-03-26", "fin_vi