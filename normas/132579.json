{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 71, DE 1988 </div></div>", "i": 6156587}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 71 de 07 de abril de 1988 se ha aprobado para el liceo Polit&#xE9;cnico C-40 de Coltauco, Provincia de Cachapoal, VI Regi&#xF3;n del Libertador General Bernardo O&apos;Higgins, un plan y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico - Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar de 1988 y hasta el a&#xF1;o escolar de 1989, en la Rama Comercial, Especialidad Administraci&#xF3;n.</div><br></div>", "i": 6156588}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de Abril de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6156589}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "71", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-71"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 71, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-04-07", "doble_articulado": false, "id_norma": "132579", "numero_fuente": "33054", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-04-25", "vigencias": [{"desde": "1988-04-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-04-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-04-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vin