{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 1.814</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Comit&#xE9; Ejecutivo de este Banco Central de Chile en su Sesi&#xF3;n No. 1.814, celebrada el 19 de agosto de 1987, adopt&#xF3; los siguientes acuerdos:</div><br></div>", "i": 6286020}, {"t": "<div><div class=\"p\">1814-04-870819 - Modifica Cap&#xED;tulo IV.B.7 del Compendio de Normas Financieras.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; reemplazar en el n&#xFA;mero 2 del Cap&#xED;tulo IV.B.7 &quot;Pagar&#xE9;s Reajustables del Banco Central de Chile&quot; del Compendio de Normas Financieras, el guarismo &quot;70&quot; por &quot;100&quot;. </div></div>", "i": 6286021}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de agosto de 1987.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6286022}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1814", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1814"}, {"tipo": "5", "numero": "1814-04", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1814-04"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 1.814", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-19", "doble_articulado": false, "id_norma": "171997", "numero_fuente": "32851", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-21", "vigencias": [{"desde": "1987-08-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ú