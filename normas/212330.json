{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6431056}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.447, de 27 de junio de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de la resoluci&#xF3;n N&#xBA; 3.102 de 2002, modificada mediante resoluci&#xF3;n N&#xBA; 354 de 2003, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto denominado &quot;Pesca de Investigaci&#xF3;n de Merluza del sur en la Regi&#xF3;n de Magallanes-Fase II, 2003&quot; en el sentido de se&#xF1;alar que las actividades de investigaci&#xF3;n correspondientes al mes de julio de 2003, se realizar&#xE1;n entre el 1 y 31 de julio, ambas fechas inclusive. </div></div>", "i": 6431057}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so,&nbsp; 27 de junio de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6431058}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1447 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1447 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-27", "doble_articulado": false, "id_norma": "212330", "numero_fuente": "37606", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-11", "vigencias": [{"desde": "2003-07-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic