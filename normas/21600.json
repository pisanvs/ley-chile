{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 631 EXENTO, DE 1995 </div></div>", "i": 5945609}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Supremo Exento de Educaci&#xF3;n N&#xB0; 631, de 15 de noviembre de 1995, se ha aprobado al Colegio &quot;Andacollo&quot; de Santiago, un plan y programa especial de estudio para 7&#xB0; y 8&#xB0; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica y para 1&#xB0; a 4&#xB0; a&#xF1;o de Ense&#xF1;anza Media Human&#xED;stico-Cient&#xED;fica, que se comenzar&#xE1;n a aplicar a partir del a&#xF1;o escolar 1996. </div></div>", "i": 5945610}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 24 de noviembre de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5945611}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "631 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-631 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 631 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGION ANDACOLLO", "SANTIAGO", "REGION METROPOLITANA", "PLANES ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-11-24", "doble_articulado": false, "id_norma": "21600", "numero_fuente": "35329", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-11-29", "vigencias": [{"desde": "1995-11-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-11-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-11-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_ver