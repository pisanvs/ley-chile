{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293908}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 731, de 20 de Junio de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xB0; 1.334, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD JIMENEZ Y CIA. LIMITADA, R.U.T. N&#xB0; 79.554.370-8, para ampliar actividades pesqueras extractivas con la nave &quot;La Portada&quot;, por haberse configurado la causal prevista en el art&#xED;culo 143, letra b) de la Ley N&#xB0; 18.892, citada en Visto.</div><br></div>", "i": 8293909}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 20 de Junio de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293910}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "731", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-731"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD JIMENEZ CIA LIMITADA", "PESCA", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-06-20", "doble_articulado": false, "id_norma": "35452", "numero_fuente": "35202", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-06-26", "vigencias": [{"desde": "1995-06-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-06-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-06-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe