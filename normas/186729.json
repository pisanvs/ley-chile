{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6339781}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.129, de 7 de junio de 2001, de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; PESQUERA LA PENINSULA S.A., para ampliar las actividades pesqueras extractivas con la nave &quot;Loa 5&quot;, matr&#xED;cula 2340, en orden a realizar actividades pesqueras con la nave se&#xF1;alada precedentemente, en el litoral de la I a la IV Regiones, por fuera del &#xE1;rea de reserva artesanal, sobre el recurso hidrobiol&#xF3;gico Merluza de cola, con red de cerco.</div><br></div>", "i": 6339782}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de junio de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6339783}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1129", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1129"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-06-07", "fecha_derogacion": "2002-11-07", "doble_articulado": false, "id_norma": "186729", "numero_fuente": "36993", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2001-06-22", "vigencias": [{"desde": "2002-11-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2001-06-22", "hasta": "2002-11-06", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2002-11-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-06-