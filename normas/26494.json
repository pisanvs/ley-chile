{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AUTORIZA A LA MUNICIPALIDAD DE PROVIDENCIA PARA CAMBIAR NOMBRE A LA &quot;AVENIDA INVENCIBLE ARMADA&quot;.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8279120}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Autor&#xED;zase a la Municipalidad de Providencia para que d&#xE9; el nombre de &quot;Avenida Carlos Ant&#xFA;nez&quot; a la &quot;Avenida Invencible Armada&quot;.</div><br></div>", "i": 8279121}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintiuno de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Carlos Torres H.</div><br></div>", "i": 8279122}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10836", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10836"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA A LA MUNICIPALIDAD DE PROVIDENCIA PARA CAMBIAR NOMBRE A LA AVENIDA INVENCIBLE ARMADA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "MUNICIPALIDAD PROVIDENCIA", "AVENIDA CARLOS ANTUNEZ", "FACULTAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-21", "doble_articulado": false, "id_norma": "26494", "numero_fuente": "22402", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-11-18", "vigencias": [{"desde": "1952-11-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Únic