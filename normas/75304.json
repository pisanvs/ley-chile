{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6044415}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xB0;618, de 30 de junio de 1997, se expropiaron los lotes de terreno N&#xB0;s. 26, 33, 42 y 45-A, superficies 70, 55, 205 y 80 m2. respectivamente, roles de avalu&#xF3; 47-7 y los restantes en tr&#xE1;mite, comuna de la Estrella, para la obra Camino L&#xED;mite Regional (Rapel)-Alcones I, Sector Litueche-La Rosa y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Norma Rosa de las Mercedes Huerta Cornejo, Juan Alberto Fuentes Flores, Manuel Valeriano Riveros Valenzuela, Mariano del Carmen Huerta Cornejo, ascendente a las cantidades de $471.835, $389.690, $4.916.936, $497.760.</div><br></div>", "i": 6044416}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6044417}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "618", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-618"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "LA ESTRELLA", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-06-30", "doble_articulado": false, "id_norma": "75304", "numero_fuente": "35843", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-08-16", "vigencias": [{"desde": "1997-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-08-16", "fin_vigencia": "", "tipo_version": "3"}], "event