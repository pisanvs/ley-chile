{"html": [{"t": "<div><br><div class=\"p\">CONSTITUCION.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago Diciembre 20 de 1832.</div><br><div class=\"p\">&nbsp; &nbsp;  A S. E. el Presidente de la Rep&#xFA;blica.</div></div>", "i": 9493697}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la reforma que hasta ahora ha hecho la Gran Convencion ha variado los art&#xED;culos 7.&#xB0;, 25, 26, 27, 28, 29, 30 y 31, de la Constitucion de 1828; y resultando de todo una alteracion notable en la Base de elecciones, ha acordado ponerlo en noticia de V. E. para los efectos que hubiere lugar.</div></div>", "i": 9493698}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Dios guardo &#xE1; V. E.-SANTIAGO DE ECHEVERZ.- Vice Presidente. -Juan Francisco Meneses.-Secretario.</div></div>", "i": 9493699}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": [], "titulo_norma": "CONSTITUCION.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-12-20", "doble_articulado": false, "id_norma": "1063900", "numero_fuente": "(1828-1832)", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-12-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-12-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-12-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "362", "fecha_ingreso": "2014-08-04", "fecha_version": "1832-12-20", "fecha_actualizacion_texto": "2014-08-04", "tipo_tratado": ""}, "aler