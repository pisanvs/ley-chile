{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 263&nbsp; EXENTO, DE 1997 </div></div>", "i": 6032812}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 263 de 5 de marzo de 1997, se ha aprobado, un programa de estudio para la asignatura Religi&#xF3;n (Subsector de Aprendizaje: Religi&#xF3;n) a la Uni&#xF3;n Chilena de la Iglesia Adventista del S&#xE9;ptimo D&#xED;a para los cursos de 1&#xBA; a 4&#xBA; a&#xF1;o (NB.1 y NB.2) de ense&#xF1;anza b&#xE1;sica, el que se aplicar&#xE1; conforme a la gradualidad establecida en el art&#xED;culo 4&#xBA; del Decreto Supremo de Educaci&#xF3;n N&#xBA; 40 de 1996.</div><br></div>", "i": 6032813}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de marzo de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6032814}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "263 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-263 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 263 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PROGRAMAS DE ESTUDIO", "PLANES DE ESTUDIO", "UNION CHILENA DE LA IGLESIA ADVENTISTA DEL SEPTIMO DIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-05", "doble_articulado": false, "id_norma": "70092", "numero_fuente": "35723", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-03-22", "vigencias": [{"desde": "1997-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-03-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc