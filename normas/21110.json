{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTOS DE DECRETO EXENTO N&#xB0; 381, DE 1990 </div></div>", "i": 8617424}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; por decreto supremo exento de Educaci&#xF3;n N&#xB0; 381, de 28 de diciembre de 1990 se ha aprobado al Colegio Bradford de Santiago, un plan de estudio especial para ser aplicado de 1&#xB0; a 8&#xB0; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica y de 1&#xB0; a 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, a partir del a&#xF1;o escolar 1991, simult&#xE1;neamente en todos los cursos.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio especiales de las asignaturas de Deportes y de Taller de Ingl&#xE9;s, para Educaci&#xF3;n B&#xE1;sica.</div><br></div>", "i": 8617425}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 14 de Junio de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8617426}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "381", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-381"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTOS DE DECRETO EXENTO N° 381, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO BRADFORD", "SANTIAGO", "PLAN ESTUDIO", "PROGRAMA ESTUDIO", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-28", "doble_articulado": false, "id_norma": "21110", "numero_fuente": "34003", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-06-27", "vigencias": [{"desde": "1991-06-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-06-27", "fin_vigencia":