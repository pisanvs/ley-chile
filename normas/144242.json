{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Naconal ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;mero 3,954 </div></div>", "i": 6193622}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Adela Latorre, viuda del teniente-coronel graduado de Ej&#xE9;rcito, don Amador Larenas, y a sus hijos menores, el derecho de disfrutar de la pension de montep&#xED;o correspondiente al empleo de teniente-coronel efectivo, con relacion al tiempo que el indicado jefe sirvi&#xF3; en el Ej&#xE9;rcito.&quot; </div></div>", "i": 6193623}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veinte de julio de mil novecientos veintitres.-&nbsp; Arturo Alessandri.-&nbsp; Luis Altamirano.</div><br></div>", "i": 6193624}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3954", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3954"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1923-07-20", "doble_articulado": false, "id_norma": "144242", "numero_fuente": "13657", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1923-08-21", "vigencias": [{"desde": "1923-08-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1923-08-21", "f