{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO MINISTRO DE FE A FUNCIONARIA QUE INDICA </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 27.- Santiago, 31 de enero de 2007.- Vistos: Lo dispuesto en el art. 4&#xBA; del decreto ley N&#xBA; 2.974 de 1979.</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 6604036}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Ministro de Fe para actuar en las localidades ubicadas en la XI Regi&#xF3;n, en que no hayan Notarios ni Oficiales del Registro Civil, a la siguiente funcionaria:</div><br><div class=\"p\">- Mar&#xED;a Carolina M&#xE1;rquez Godait&nbsp;  - Rut 6.001.171-0</div><br></div>", "i": 6604037}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hern&#xE1;n Rojas Olavarr&#xED;a, Director Nacional.</div><br></div>", "i": 6604038}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "27", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-27"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO MINISTRO DE FE A FUNCIONARIA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO DE DESARROLLO AGROPECUARIO", "DECIMOPRIMERA REGION", "MINISTRO DE FE", "MARIA CAROLINA MARQUEZ GODAIT", "DESIGNACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-01-31", "doble_articulado": false, "id_norma": "259029", "numero_fuente": "38711", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-03-12", "vigencias": [{"desde": "2007-03-12", "hasta": "", "tipo_ver