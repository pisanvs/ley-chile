{"html": [{"t": "<div><div class=\"p\">AUTORIZA A EMISOR DE BOLETAS ELECTR&#xD3;NICAS</div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 106 de 8 de septiembre de 2008, que autoriza a contribuyente como emisor de boletas electr&#xF3;nicas.</div><br></div>", "i": 6659486}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisores de boletas electr&#xF3;nicas, a contar del mes de septiembre de 2008, a contribuyentes RUT 60.810.000-8 y RUT 60.810.001-6.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el bolet&#xED;n del SII del mes de septiembre de 2008.</div><br></div>", "i": 6659487}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "106 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-106 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A EMISOR DE BOLETAS ELECTRÓNICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-09-08", "doble_articulado": false, "id_norma": "277917", "numero_fuente": "39162", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-09-12", "vigencias": [{"desde": "2008-09-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-09-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-09-12", "fin_vigencia": "", "tipo_version": "3"}], "