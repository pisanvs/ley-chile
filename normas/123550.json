{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A AGRICOLA SANCHEZ ESPINOZA LIMITADA</div><br><br><br></div>", "i": 6127119}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VII Direcci&#xF3;n Regional Talca del SII, por resoluci&#xF3;n N&#xBA; Ex. 1.208 de 21 de agosto de 1998, otorga, a contar del 1 del mes siguiente al de esta publicaci&#xF3;n y hasta el 31 de julio de 1999 a Agr&#xED;cola S&#xE1;nchez Espinoza Limitada, Rut N&#xBA; 78.229.890-9, la calidad de agente retenedor del impuesto al valor agregado en las operaciones de ganado vivo, establecido en la Res. N&#xBA; Ex. 2.379/98 de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del d&#xED;a 24.04.98, modificada por Res. N&#xBA; Ex. 3.785/98 publicada en el Diario Oficial del 30.06.98.</div><br></div>", "i": 6127120}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jos&#xE9; A. Moretti Soto, Director Regional. </div></div>", "i": 6127121}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1208 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1208 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VII DIRECCIÓN REGIONAL DE TALCA"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A AGRICOLA SANCHEZ ESPINOZA LIMITADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "AGRICOLA SANCHEZ ESPINOZA LIMITADA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-21", "doble_articulado": false, "id_norma": "123550", "numero_fuente": "36153", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-08-31", "vigencias": [{"desde": "1998-08-31", "hast