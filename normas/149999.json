{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 146, DE 1987 </div></div>", "i": 6214516}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado planes y programas especiales de estudio para Segundo Ciclo de Educaci&#xF3;n Media T&#xE9;cnico - Profesional, a contar del a&#xF1;o escolar 1987 y hasta el a&#xF1;o escolar 1992, inclusive para el Liceo A No. 85, comuna de Cerro Navia, provincia de Santiago, Regi&#xF3;n Metropolitana.</div><div class=\"p\">ESPECIALIDADES:</div><div class=\"p\">- Contabilidad.</div><div class=\"p\">- Atenci&#xF3;n de P&#xE1;rvulos con menci&#xF3;n en Educaci&#xF3;n Diferencial. </div></div>", "i": 6214517}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de Junio de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6214518}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "146 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-146 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 146, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-25", "doble_articulado": false, "id_norma": "149999", "numero_fuente": "32806", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-27", "vigencias": [{"desde": "1987-06-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-06-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie