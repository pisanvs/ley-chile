{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 579 EXENTO, DE 1995 </div></div>", "i": 7162077}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 579, de 20 de octubre de 1995, se ha suprimido gradualmente, en el plan de estudio especial aprobado por decreto supremo exento de Educaci&#xF3;n N&#xB0; 151, de 1984, al Colegio Verbo Divino de la comuna de Las Condes, de Santiago, la asignatura de Idioma Extranjero Alem&#xE1;n desde 5&#xB0; a&#xF1;o b&#xE1;sico a 4&#xB0; a&#xF1;o medio, de la forma que se indica en el presente decreto.</div><br></div>", "i": 7162078, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 6 de noviembre de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7162079}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "579", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-579"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 579 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO VERBO DIVINO", "LAS CONDES", "PLANES ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-10-20", "doble_articulado": false, "id_norma": "21504", "numero_fuente": "35321", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-11-20", "vigencias": [{"desde": "1995-11-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-11-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-11-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient