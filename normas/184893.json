{"html": [{"t": "<div><div class=\"p\">APRUEBA REFORMA DE ESTATUTOS A &quot;CNA CHILE, COMPA&#xD1;&#xCD;A DE SEGUROS DE VIDA S.A.&quot; </div></div>", "i": 6333414}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que por resoluci&#xF3;n exenta N&#xBA; 141, de 12</div><div class=\"p\">de abril de 2001, se aprob&#xF3; reforma de estatutos de la</div><div class=\"p\">sociedad an&#xF3;nima &quot;CNA Chile, Compa&#xF1;&#xED;a de Seguros de Vida</div><div class=\"p\">S.A.&quot;, acordada en junta extraordinaria de accionistas,</div><div class=\"p\">de 14 de marzo de 2001, cuya acta consta de la escritura</div><div class=\"p\">p&#xFA;blica de 2 de abril de 2001, otorgada ante el Notario</div><div class=\"p\">de Santiago don Patricio Zald&#xED;var Mackenna.</div><div class=\"p\">&nbsp; &nbsp;  La reforma consiste en aumentar de 5 a 7 el n&#xFA;mero</div><div class=\"p\">de miembros del directorio, modificando al efecto el</div><div class=\"p\">art&#xED;culo 7&#xBA; del estatuto social.</div><br></div>", "i": 6333415}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de abril de 2001.- Carmen Undurraga Mart&#xED;nez, Secretario General </div></div>", "i": 6333416}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "141 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-141 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "APRUEBA REFORMA DE ESTATUTOS A \"CNA CHILE, COMPAÑÍA DE SEGUROS DE VIDA S.A.\"", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-12", "doble_articulado": false, "id_norma": "184893", "numero_fuente": "36955", "tipo_v