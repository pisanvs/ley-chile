{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 14,416</div><br><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DON MANUEL JESUS PINO YANEZ</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6558245}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a don Manuel Jes&#xFA;s Pino Y&#xE1;nez una pensi&#xF3;n mensual de treinta escudos.</div><div class=\"p\">&nbsp; &nbsp;  El mayor gasto que importe la aplicaci&#xF3;n de esta ley se imputar&#xE1; al &#xED;tem respectivo de Pensiones del Presupuesto del Ministerio de Hacienda.</div><br></div>", "i": 6558246}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veinticinco de Noviembre de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- Eduardo Figueroa G.</div><br></div>", "i": 6558247}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14416", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14416"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DON MANUEL JESUS PINO\nYANEZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-11-25", "doble_articulado": false, "id_norma": "246572", "numero_fuente": "24824", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-12-21", "vigencias": [{"desde": "1960-12-21", "hasta": "", "tipo_version": "3",