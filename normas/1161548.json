{"html": [{"t": "<div><br><div class=\"p\">DERECHOS.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Agosto 8 de 1832.</div></div>", "i": 10257014}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Se declara libre de derechos de importaci&#xF3;n los licores y otros cualesquiera art&#xED;culos extranjeros, puramente de provisi&#xF3;n que tengan necesidad de tomar a su bordo, de los almacenes francos del puerto de Valpara&#xED;so, los buques de guerra de S.M. el Rei de los franceses; pero dichos art&#xED;culos quedan sujetos a los derechos de tr&#xE1;nsito y almacenaje que pagan las mercader&#xED;as extranjeras depositadas en los espresados almacenes. Refrend&#xE1;ndose este decreto por el Ministro de Hacienda, se transcribir&#xE1; al Gobernador de Valpara&#xED;so para que cuide de su cumplimiento, y al Encargado de negocios que representa.</div></div>", "i": 10257015}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  PRIETO. Joaquin Tocornal.</div></div>", "i": 10257016}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DERECHOS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-08-08", "doble_articulado": false, "id_norma": "1161548", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-08-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-08-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-08-08", "fin_vigencia": "", "tipo_version": "3"