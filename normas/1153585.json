{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10185335}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta 2.560, 2 de diciembre de 2020, Serviu Regi&#xF3;n del Biob&#xED;o orden&#xF3; expropiaci&#xF3;n parcial de terreno y de edificaci&#xF3;n de un inmueble ubicado en El Molino, Rol de Aval&#xFA;o N&#xBA; 551-3, comuna de Tom&#xE9;, de aparente dominio de Forestal Arauco S.A., superficie afecta expropiaci&#xF3;n parcial de terreno de 1.085,69 m2 y de 0,0 m2 de edificaci&#xF3;n, seg&#xFA;n Plano S8R-39450-1, para la ejecuci&#xF3;n de las obras del proyecto &quot;Construcci&#xF3;n Espacio P&#xFA;blico Dichato - Vegas de Coliumo&quot;, comuna de Tom&#xE9;, conforme art&#xED;culo 51 ley N&#xBA; 16.391 y DL N&#xBA; 2.186. Comisi&#xF3;n Peritos integrada por arquitecto Leonardo Fasce Casanueva, constructor civil Juan Pablo Cuevas Castillo y arquitecto Eduardo Riquelme Illanes, seg&#xFA;n informe de fecha 06.11.2020, fij&#xF3; monto provisional indemnizaci&#xF3;n en $26.931.743.- </div></div>", "i": 10185336}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n del Biob&#xED;o.</div><br></div>", "i": 10185337}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2560 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2560 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1861421", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-12-02", "doble_articul