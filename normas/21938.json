{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pension Lei n&#xFA;m. 66.- Santiago, a 8 de Agosto de 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7162464}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese a cada una de las se&#xF1;oras do&#xF1;a Laura , do&#xF1;a Modesta i do&#xF1;a Carolina Salinas, una pension de quince pesos mensuales, que gozar&#xE1;n con arreglo a la lei de montep&#xED;o militar.</div><br><br></div>", "i": 7162465}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- V. D&#xE1;vila Larrain.</div><br></div>", "i": 7162466}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "66", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-66"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LAURA SALINAS", "MODESTA SALINAS", "CAROLINA SALINAS", "MONTEPIO MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-08-08", "doble_articulado": false, "id_norma": "21938", "numero_fuente": "4594", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-08-12", "vigencias": [{"desde": "1893-08-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-08-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-08-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc