{"html": [{"t": "<div><div class=\"p\">MODIFICA D.S. N&#xB0;210, DE 1998, MINISTERIO DE ECONOM&#xCD;A, FOMENTO Y TURISMO</div></div>", "i": 10271374}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xB0; 202100160, de 9 de septiembre de 2021, modif&#xED;case el <a href=\"https://www.leychile.cl/Navegar?idNorma=120264&amp;idParte=8331159&amp;idVersion=\">art&#xED;culo 1&#xB0;</a>, numeral 1.- del <a href=\"https://www.leychile.cl/Navegar?idNorma=120264&amp;idParte=&amp;idVersion=\">DS N&#xB0;210 de 1998</a>, de este Ministerio, que estableci&#xF3; el &#xE1;rea de manejo y explotaci&#xF3;n de recursos bent&#xF3;nicos Arica, en la Regi&#xF3;n de Arica y Parinacota, en el sentido de reducir y regularizar su cartograf&#xED;a en los t&#xE9;rminos indicados en el decreto extractado.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del decreto extractado se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10271375}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de septiembre de 2021.- Alicia Gallardo Lagno, Subsecretaria de Pesca y Acuicultura.</div><br></div>", "i": 10271376}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "202100160 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-202100160 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA D.S. N°210, DE 1998, MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2013698", "EXTRACTO"], "derog