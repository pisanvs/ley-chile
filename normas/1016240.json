{"html": [{"t": "<div><br><div class=\"p\">AMPL&#xCD;A PLAZO PARA INICIAR ACTIVIDADES DE ACUICULTURA</div></div>", "i": 8965778}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n N&#xBA; 2.464, de fecha 28 de diciembre de 2009, Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina, se resolvi&#xF3;:</div><br><div class=\"p\">&nbsp; &nbsp;  1. - Ampl&#xED;ase por cuatro a&#xF1;os, a contar del 9 de noviembre de 2007, d&#xED;a siguiente de cumplido el primer a&#xF1;o desde la fecha de entrega material de la concesi&#xF3;n de acuicultura, el plazo para iniciar actividades de acuicultura autorizadas mediante <a href=\"https://www.leychile.cl/Navegar?idNorma=242602&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 1.126, de fecha 21 de junio de 2005</a>, autorizada transferir por resoluci&#xF3;n N&#xBA; 1.424, de fecha 6 de julio de 2007, ambas del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina.</div><br></div>", "i": 8965779}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de julio de 2010.- Por el Sr. Subsecretario, Felipe Garc&#xED;a-Huidobro Correa, Subjefe (M).</div></div>", "i": 8965780}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2464", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2464"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "AMPLÍA PLAZO PARA INICIAR ACTIVIDADES DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-12-28", "doble_articulado": false, "id_norma": "1016240", "numero_fuente": "39736", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicac