{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 888 EXENTA, DE 2020</div></div>", "i": 10121471}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 888, de 21 de abril de 2020, se modific&#xF3; la <a href=\"https://www.leychile.cl/Navegar?idNorma=1144135&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 566, de 2020</a>, en el sentido de autorizar, de conformidad a lo dispuesto en el n&#xFA;mero 5&#xB0; de la resoluci&#xF3;n N&#xBA; 65, de 2000, del Ministerio de Transportes y Telecomunicaciones, al siguiente taller para adecuar veh&#xED;culos al uso de gas licuado de petr&#xF3;leo (GLP) y gas natural comprimido (GNC) como combustible:</div><div class=\"p\"> </div><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/108554.jpg\">.</div><div class=\"p\"> </div></div>", "i": 10121472}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Luis Dom&#xED;nguez Covarrubias, Subsecretario de Transportes.</div><div class=\"p\"> </div><br></div>", "i": 10121473}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "888 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-888 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 888 EXENTA, DE 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1761862", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-04-21", "doble_articulado": false, "id_norma": "1145417", "numero_fuente": "42657", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-05-16", "vigencias": [{"desde": "2020