{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N O N&#xBA; 17.580, DE 2009</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. O-17.907.- Santiago, 27 de mayo de 2009.- Vistos: La Resoluci&#xF3;n O N&#xBA; 17580 de fecha 7 de abril de 2009, publicada en el Diario Oficial de fecha 15 de abril del mismo mes y a&#xF1;o, lo dispuesto en el art&#xED;culo 12 transitorio de la ley 20.175 y lo se&#xF1;alado en el art&#xED;culo 93 letra i) de la ley 18.556,</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 8624627}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case la resoluci&#xF3;n O N&#xBA; 17.580 publicada en el Diario Oficial de fecha 15 de abril de 2009, en el sentido que, en la elecci&#xF3;n de SENADORES, Circunscripci&#xF3;n Senatorial Primera, donde dice I, debe decir, XV y I y donde dice 489, debe decir 903.</div><br></div>", "i": 8624628, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 8624629}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "17907", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolucion-17907"}, {"tipo": "3", "numero": "O-17907", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolucion-O-17907"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "MODIFICA RESOLUCIÓN O Nº 17.580, DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-05-27", "doble_articulado": false, "id_norma": "1002736", "numero_fuente": "39372", "tipo_version": "3", "tipo_version_s": "Única", "fecha