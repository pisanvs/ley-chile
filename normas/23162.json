{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,159, que concede la suma de $ 100,000 para auxiliar a los damnificados de Calabria i Sicilia Lei n&#xFA;m. 2,159.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275049}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la cantidad de cien mil pesos en ausiliar a los damnificados de Calabria i Sicilia.</div><br></div>", "i": 8275050}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 19 de Febrero de 1909.- PEDRO MONTT.- E. Charme.</div><br></div>", "i": 8275051}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2159", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2159"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 2,159, QUE CONCEDE LA SUMA DE $ 100,000 PARA AUXILIAR A LOS DAMNIFICADOS DE CALABRIA I SICILIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DAMNIFICADOS", "CALABRIA", "SICILIA", "AYUDA", "FONDOS", "INVERSION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1909-02-19", "doble_articulado": false, "id_norma": "23162", "numero_fuente": "9319", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1909-02-19", "vigencias": [{"desde": "1909-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "