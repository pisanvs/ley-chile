{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6498560}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 2.651, de 16 de septiembre de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA CHILE S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Puyuguapi&quot;, en las &#xE1;reas mar&#xED;timas que en cada caso se indican, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar el recurso hidrobiol&#xF3;gico que a continuaci&#xF3;n se se&#xF1;ala: a) Entre el paralelo 37&#xB0; LS y 57&#xB0; LS, con poteras: Jibia;</div><div class=\"p\">b) Entre el paralelo 41&#xB0;28,6&apos; LS y 47&#xB0; LS, con palangre: Jibia.</div><br></div>", "i": 6498561}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Valpara&#xED;so, 16 de septiembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6498562}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2651 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2651 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-09-16", "fecha_derogacion": "2005-12-29", "doble_articulado": false, "id_norma": "230707", "numero_fuente": "37973", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-09-29", "vigencias": [{"desde": "2005-12-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-09-29", "hasta": "2005-12-28", "tipo_version": "0", "tipo_version_s": "Texto Original"}