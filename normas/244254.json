{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6549779}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.571, de 25 de octubre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a MARCELA ANDREA RIVERA ARCE, para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por la resoluci&#xF3;n N&#xBA; 3.043 de 2005, de esta Subsecretar&#xED;a, en orden a incorporar a su planta ubicada en lote I, Parcela N&#xBA; 39, Los Suspiros s/n, camino a Punta Cort&#xE9;s, Rancagua, VI Regi&#xF3;n, en las l&#xED;neas de proceso de cocido, fresco enfriado, congelado, seco salado, ahumado, harina, alga seca y deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6549780}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de octubre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6549781}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3571 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3571 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-10-25", "doble_articulado": false, "id_norma": "244254", "numero_fuente": "38319", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-11-23", "vigencias": [{"desde": "2005-11-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-11-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-11