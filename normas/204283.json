{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6401934}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.395, de 31 de octubre de 2002, de esta Subsecretar&#xED;a, rectif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA;2.317 de 2002, de esta Subsecretar&#xED;a, que modific&#xF3; el numeral 4&#xBA; de la resoluci&#xF3;n N&#xBA; 2.177 de 2002, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO, para efectuar una pesca de investigaci&#xF3;n de conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del proyecto denominado &quot;Monitoreo de la pesquer&#xED;a artesanal de merluza com&#xFA;n en las caletas artesanales del sector norte de la VIII Regi&#xF3;n-segunda etapa&quot;, en el sentido de reemplazar la expresi&#xF3;n &quot;645,818 toneladas de merluza com&#xFA;n&quot; por la expresi&#xF3;n &quot;654,818 toneladas de merluza com&#xFA;n&quot;. </div></div>", "i": 6401935}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de octubre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6401936}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2395", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2395"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-10-31", "doble_articulado": false, "id_norma": "204283", "numero_fuente": "37402", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-11-07", "vigencias": [{"desde": "2002-11-07", "hasta":