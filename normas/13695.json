{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; NOMBRA SUBSECRETARIO DE JUSTICIA Santiago, marzo 11 de 1994.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 482.- Visto lo dispuesto en el art&#xED;culo 32 N&#xB0; 9 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica, Decreto:</div><br></div>", "i": 5914351}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; 1.-N&#xF3;mbrase a contar del 12 de marzo de 1994, a don Eduardo Jara Mirando (RUN N&#xB0; 3.087.577-K), en el cargo de Subsecretario de Justicia.</div><div class=\"p\">&nbsp; &nbsp; 2.- Por razones de buen servicio don Eduardo Jara Miranda, asumir&#xE1; de inmediato sus funciones. </div></div>", "i": 5914352}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- EDUARDO FREI RUIZ-TAGLE, Presidente de la Rep&#xFA;blica.- Mar&#xED;a Soledad Alvear Valenzuela, Ministro de Justicia.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Le saluda atentamente.- Mireya Carrizo Inostroza, Subsecretario de Justicia subrogante.</div><br></div>", "i": 5914353}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "482", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-482"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "NOMBRA SUBSECRETARIO DE JUSTICIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SUBSECRETARIO", "MINISTERIO JUSTICIA", "EDUARDO JARA MIRANDA", "NOMBRAMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-11", "doble_articulado": false, "id_norma": "13695", "numero_fuente": "34833", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-04-07", "vigencias": [{"des