{"html": [{"t": "<div><div class=\"p\">RECTOR DEL INSTITUTO: NOMBRAMIENTO</div><br><div class=\"p\">&nbsp; &nbsp;  Valparaiso, Marzo 5 de 1829.</div></div>", "i": 10253087}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Habiendo admitido por decreto de esta fecha el Dr. D. Juan Francisco Meneses, la renuncia que ha hecho del cargo de Rector que obtenia en el Instituto Nacional, vengo en nombrar interinamente, y con el sueldo que corresponde a este destino, al actual vice-Rector, presb&#xED;tero D. Blas Reyes, de cuya providad y zelo espera el Gobierno el mejor adelantamiento en la educacion de la juventud.</div></div>", "i": 10253088}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon y comuniquese.</div><br><div class=\"p\">&nbsp; &nbsp;  PINTO.&nbsp; &nbsp;  Rodr&#xED;guez.</div></div>", "i": 10253089}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "RECTOR DEL INSTITUTO: NOMBRAMIENTO", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1829-03-05", "doble_articulado": false, "id_norma": "1159247", "numero_fuente": "1829", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1829-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1829-03-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1829-03-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-07-19", "fecha_version": "1829-03-05", "f