{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9145840}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. (Exento) N&#xB0;862, de 24 de mayo de 2011, se dej&#xF3; sin efecto el Decreto MOP N&#xB0;822, de 24 d<span class=\"n\" id=\"n_0\"><a href=\"navegar?idNorma=1027333&amp;idParte=9155586&amp;idVersion=2011-07-01\">Aviso S/N, OBRAS P&#xDA;BLICAS<br>D.O. 01.07.2011</a></span>e junio de 2010, que orden&#xF3; la expropiaci&#xF3;n del lote B, por no ser necesaria para la construcci&#xF3;n de la obra p&#xFA;blica &quot;Colector Interceptor Mapocho Segunda Etapa&quot;, Regi&#xF3;n Metropolitana. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA; 2186, de 1978.</div><br></div>", "i": 9145841, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9145842}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "2", "numero": "862 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-862 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-05-24", "doble_articulado": false, "id_norma": "1026131", "numero_fuente": "39974", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2011-06-01", "vigencias": [{"desde": "2011-07-01", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2011-06-01", "hasta": "2011-06-30", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2011-07-01