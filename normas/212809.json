{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A HARAS SANTA ELADIA LIMITADA </div></div>", "i": 6432749}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional Santiago Poniente del SII, por resoluci&#xF3;n N&#xBA; Ex. 685 de 18 de junio de 2003, concede la calidad de Agente Retenedor en las compras de ganado vivo a la empresa Haras Santa Eladia Limitada, RUT N&#xBA; 77.796.270-1, la que entrar&#xE1; en vigencia a contar del d&#xED;a primero del mes siguiente de la fecha de su publicaci&#xF3;n en el Diario Oficial, por su cuenta y costo, y en forma indefinida.</div><br></div>", "i": 6432750}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jorge A. de Calisto Bravo, Director Regional. </div></div>", "i": 6432751}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "685 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-685 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO PONIENTE"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A HARAS SANTA\nELADIA LIMITADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-18", "doble_articulado": false, "id_norma": "212809", "numero_fuente": "37616", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-23", "vigencias": [{"desde": "2003-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-07-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-07-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincula