{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 217 EXENTO, DE 2004</div><br><br></div>", "i": 6474562}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 217 de fecha 1&#xBA; de abril de 2004, de Educaci&#xF3;n, se declara que la carrera profesional de Agronom&#xED;a impartida por la Universidad de Aconcagua, ha cumplido con los requisitos necesarios para la liberaci&#xF3;n de &#xE9;sta, seg&#xFA;n lo certifica la Universidad de La Serena, quien actu&#xF3; como entidad examinadora de dicha carrera.</div><div class=\"p\">&nbsp; &nbsp;  De conformidad con el art&#xED;culo anterior, la Universidad de Aconcagua est&#xE1; en condiciones de otorgar independientemente el t&#xED;tulo profesional de Ingeniero Agr&#xF3;nomo.</div><br></div>", "i": 6474563}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de abril de 2004.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6474564}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "217 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-217 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 217 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-01", "doble_articulado": false, "id_norma": "224019", "numero_fuente": "37840", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-20", "vigencias": [{"desde": "2004-04-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-04-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2