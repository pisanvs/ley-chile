{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 299.- Santiago, 29 de octubre de 1992. Vistos: Lo dispuesto en el art&#xED;culo 11 del Decreto Ley N&#xB0; 2.974 de 1979.</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 6009058}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del Decreto Ley citado y en la VIII Regi&#xF3;n a la funcionaria:</div><div class=\"p\">&nbsp; &nbsp; -Alba Sanhueza Seguel </div></div>", "i": 6009059}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hugo Ortega Tello, Director Nacional.</div><br></div>", "i": 6009060}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "299", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-299"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMBRAMIENTO", "RECEPTOR JUDICIAL", "OCTAVA REGION", "ALBA SANHUEZA SEGUEL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-10-29", "doble_articulado": false, "id_norma": "34227", "numero_fuente": "34425", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-11-25", "vigencias": [{"desde": "1992-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-11-25"