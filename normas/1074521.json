{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 222 EXENTA, DE 2015</div></div>", "i": 9559539}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 222, de 3 febrero de 2015 del Ministerio de Transportes y Telecomunicaciones, se modifica p&#xE1;rrafo segundo del punto 3.5 del numeral 1.- del Resuelvo de la resoluci&#xF3;n exenta N&#xBA;2.098, de 26 de septiembre de 2012, del Ministerio de Transportes y Telecomunicaciones; en el sentido de reemplazar la frase: &quot;a partir del primer d&#xED;a h&#xE1;bil&quot; por la siguiente: &quot;a partir del sexto d&#xED;a h&#xE1;bil&quot;, rigiendo desde el mes de febrero de 2015. Texto &#xED;ntegro de resoluci&#xF3;n extractada se encontrar&#xE1; disponible en sitio web www.mtt.gob.cl.</div></div>", "i": 9559540}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; Andr&#xE9;s G&#xF3;mez-Lobo Echenique, Ministro de Transportes y Telecomunicaciones.</div></div>", "i": 9559541}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "222 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-222 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 222 EXENTA, DE 2015", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-02-03", "doble_articulado": false, "id_norma": "1074521", "numero_fuente": "41075", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-02-05", "vigencias": [{"desde": "2015-02-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}