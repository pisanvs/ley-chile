{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede derecho a jubilar al Profesor don Miguel Luis Amun&#xE1;tegui Reyes</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,688.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7165966}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Conc&#xE9;dese, por gracia, al profesor de la Universidad de Chile i del Instituto Nacional don Miguel Luis Amun&#xE1;tegui Reyes, derecho de jubilar con la integridad del sueldo.</div><br></div>", "i": 7165967}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 30 de Agosto de 1912.- RAMON BARROS LUCO.-</div><div class=\"p\">E. Villegas E.</div><br></div>", "i": 7165968}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2688", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2688"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "CONCEDE DERECHO A JUBILAR AL PROFESOR DON MIGUEL LUIS AMUNÁTEGUI REYES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MIGUEL LUIS AMUNATEGUI", "JUBILACION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-08-30", "doble_articulado": false, "id_norma": "23427", "numero_fuente": "10369", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-09-03", "vigencias": [{"desde": "1912-09-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia