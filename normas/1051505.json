{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9356745}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;676, de 07 de mayo de 2013, se dej&#xF3; sin efecto los numerales 3&#xB0;, 4&#xB0;, 5&#xB0; y 6&#xB0;, del <a href=\"https://www.leychile.cl/Navegar?idNorma=1048114&amp;idParte=0&amp;idVersion=\">Decreto Exento MOP. N&#xB0;3251, de 27 de diciembre de 2012</a>, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote de terreno N&#xB0;89, expropiado con motivo de la obra: &quot;Mejoramiento Ruta V-815, Tramo: Bif. Ilque-Cruce Ruta V-85&quot;, Comuna de Calbuco, X Regi&#xF3;n de Los Lagos&quot;. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n fijada mediante tasaci&#xF3;n de 05 de febrero de 2012, en la suma de $706.900, para el lote N&#xB0;89. </div></div>", "i": 9356746}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9356747}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "676 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-676 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-05-07", "doble_articulado": false, "id_norma": "1051505", "numero_fuente": "40573", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-06-01", "vigencias": [{"desde": "2013-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni