{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACI&#xD3;N DE EMISORESELECTR&#xD3;NICOS </div></div>", "i": 8238555}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 32, de 6 de marzo de 2009, que deroga autorizaci&#xF3;n otorgada a contribuyentes para operar como emisor electr&#xF3;nico.</div><div class=\"p\">&nbsp; &nbsp;  A petici&#xF3;n de los contribuyentes RUT N&#xBA; 96.960.800-6 y RUT N&#xBA; 78.165.960-6, se derogan las autorizaciones otorgadas para operar como emisores de Documentos Tributarios Electr&#xF3;nicos.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de marzo de 2009.</div><br></div>", "i": 8238556}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "32 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-32 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEROGA AUTORIZACIÓN DE EMISORES ELECTRÓNICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-03-06", "doble_articulado": false, "id_norma": "288006", "numero_fuente": "39310", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-03-12", "vigencias": [{"desde": "2009-03-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-03-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vi