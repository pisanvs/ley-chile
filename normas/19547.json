{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 4 EXENTO, DE 1996 </div></div>", "i": 5939186}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 4 de fecha 9 de enero de 1996 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Tecnol&#xF3;gico de Computaci&#xF3;n, las adecuaciones introducidas al plan y programas de estudio de la carrera An&#xE1;lisis de Sistemas, las que se insertaron en el Decreto Exento del Ministerio de Educaci&#xF3;n N&#xB0; 310 de 1990. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1996.</div><br></div>", "i": 5939187}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 25 de enero de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5939188}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "4", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-4"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 4 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA", "MODIFICACION", "INSTITUTO TECNOLOGICO COMPUTACION", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-01-09", "doble_articulado": false, "id_norma": "19547", "numero_fuente": "35385", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-02-06", "vigencias": [{"desde": "1996-02-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-02-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-02-06", "fin_vigencia": "", "tipo_ve