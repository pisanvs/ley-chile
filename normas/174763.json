{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7276322}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n n&#xFA;mero 1.844 de 18 de agosto de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 855 de 1989, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a&nbsp; PESQUERA EL GOLFO S.A., para ampliar actividades pesqueras con la nave &apos;&apos;Pelikan&apos;&apos;, en el &#xE1;rea mar&#xED;tima comprendida entre la V Regi&#xF3;n y el paralelo 41&#xB0; L.S. sobre los recursos hidrobiol&#xF3;gicos Bonito, Cabinza, Cachurreta, Cochinilla, Cojinoba del norte, Lisa, Machuelo, Pejeperro, Pejerrey, Raya, Roncacho y Camar&#xF3;n nailon; y en el &#xE1;rea mar&#xED;tima comprendida entre la V y VII Regiones y entre la IX Regi&#xF3;n y el paralelo 41&#xB0; L.S. sobre los recursos Anchoveta, Caballa, Jurel, Sardina com&#xFA;n y Sardina espa&#xF1;ola.</div><br></div>", "i": 7276323}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de agosto de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7276324}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1844", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1844"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-08-18", "doble_articulado": false, "id_norma": "174763", "numero_fuente": "36753", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-31", "vigencias": [{"desde": "2000-08-31"