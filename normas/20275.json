{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 120 EXENTO, DE 1996</div><br><br></div>", "i": 5941479}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 120, de 19 de febrero de 1996, se ha aprobado, a partir del a&#xF1;o escolar 1996, al Liceo Cat&#xF3;lico Atacama de Copiap&#xF3;, un plan de estudio para los cursos de 1&#xB0; a 4&#xB0; a&#xF1;o de ense&#xF1;anza media human&#xED;stico-cient&#xED;fica.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa de estudio para la asignatura de Computaci&#xF3;n.</div><br></div>", "i": 5941480}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 12 de marzo de 1996.- Juan Eduardo Garc&#xED;a-Huidobro S., Subsecretario de Educaci&#xF3;n (S). </div></div>", "i": 5941481}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "120 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-120 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 120 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LICEO CATOLICO ATACAMA", "COPIAPO", "TERCERA REGION", "PLANES ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-02-19", "doble_articulado": false, "id_norma": "20275", "numero_fuente": "35422", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-03-20", "vigencias": [{"desde": "1996-03-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-03-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-03-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac