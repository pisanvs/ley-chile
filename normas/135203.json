{"html": [{"t": "<div><div class=\"p\">EXTRACTOS DE RESOLUCIONES N&#xBA;s. 463 Y 464 EXENTAS, DE 1999</div><br><br></div>", "i": 6164696}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluciones exentas N&#xBA; 463 y N&#xBA; 464 ambas de fecha 05/04/99, el Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, autoriz&#xF3; cambio de raz&#xF3;n social a la empresa F&#xE9;nix Pullman Norte Limitada a F&#xE9;nix Pullman Norte Internacional Limitada, en los servicios internacionales terrestres de pasajeros entre Santiago-Valpara&#xED;so-Vi&#xF1;a del Mar (Chile) y Mendoza (Argentina) y entre Vi&#xF1;a del Mar-Santiago (Chile) y Buenos Aires (Argentina). </div></div>", "i": 6164697}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andr&#xE9;s Wallis Garc&#xE9;s, Subsecretario&nbsp; de Transportes.</div><br></div>", "i": 6164698}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "464", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-464"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTOS DE RESOLUCIONES NºS. 463 Y 464 EXENTAS, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-04-05", "doble_articulado": false, "id_norma": "135203", "numero_fuente": "36342", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-04-19", "vigencias": [{"desde": "1999-04-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-04-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-04-19", "fin_vigencia": "", "tipo_version": "