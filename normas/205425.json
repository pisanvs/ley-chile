{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;14.126 EXENTA, DE 2002 </div><br></div>", "i": 6405642}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;14.126, de 27 de noviembre del a&#xF1;o 2002, se ha agregado un art&#xED;culo 8&#xBA; a la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;12.780 de 1998, que aprob&#xF3; un plan y programas especiales de estudio para primer ciclo de ense&#xF1;anza media t&#xE9;cnico-profesional para los establecimientos educacionales administrados por Codesser.</div><br></div>", "i": 6405643}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 5 de diciembre de 2002.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6405644}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "14126 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-14126 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº14.126 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-11-27", "doble_articulado": false, "id_norma": "205425", "numero_fuente": "37431", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-11", "vigencias": [{"desde": "2002-12-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-12-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-12-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "CNB", "fech