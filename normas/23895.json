{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,325, que concede derecho a jubilar a don Daniel Valenzuela P&#xE9;rez.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,325.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 8276183}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al Secretario de la C&#xE1;mara de Senadores, don Daniel Valenzuela P&#xE9;rez, el derecho a jubilar con una pension equivalente al sueldo &#xED;ntegro del empleo que actualmente desempe&#xF1;a.</div><br></div>", "i": 8276184}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a treinta de Noviembre de mil novecientos diecisiete.- JUAN LUIS SANFUENTES.- Eliodoro Y&#xE1;&#xF1;ez. </div></div>", "i": 8276185}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3325", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3325"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 3,325, QUE CONCEDE DERECHO A JUBILAR A DON DANIEL VALENZUELA PEREZ.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DANIEL VALENZUELA PEREZ", "SECRETARIO CAMARA", "SENADORES", "JUBILACION POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1917-11-30", "doble_articulado": false, "id_norma": "23895", "numero_fuente": "11940", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1917-12-06", "vigencias": [{"desde":