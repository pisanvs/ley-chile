{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;50 EXENTO, DE 1999</div><br><br></div>", "i": 6166794}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 50, de fecha 1 de marzo de 1999, del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica INACAP, las adecuaciones al plan y programas de estudios de la carrera de Matricer&#xED;a. En consecuencia, se modifica el decreto exento del Ministerio de Educaci&#xF3;n N&#xBA; 418, del 28 de diciembre de 1990, en el sentido de incorporar dichas adecuaciones, las que podr&#xE1;n aplicarse a contar del a&#xF1;o 1998, en las sedes que ya contaban con su autorizaci&#xF3;n. </div></div>", "i": 6166795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de marzo de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6166796}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "50 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-50 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº50 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-03-01", "doble_articulado": false, "id_norma": "135839", "numero_fuente": "36355", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-05-05", "vigencias": [{"desde": "1999-05-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-05-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-05-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc