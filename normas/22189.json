{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PENSION Lei n&#xFA;m. 338.- Santiago a 8 de Febrero de 1896.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br><br></div>", "i": 5947576}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Conc&#xE9;dese por gracia, a la viuda e hijas solteras del jeneral de division don Emilio Sotomayor, la pension de dos mil pesos, de la cual gozar&#xE1;n con arreglo a la lei de montep&#xED;o militar.</div><br><br></div>", "i": 5947577}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- Jorje Montt.- Luis Barros Borgo&#xF1;o.</div><br></div>", "i": 5947578}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "338", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-338"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EMILIO SITOMAYOR", "VIUDA", "HIJAS SOLTERAS", "MONTEPIO", "MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-02-08", "doble_articulado": false, "id_norma": "22189", "numero_fuente": "5337", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1896-02-19", "vigencias": [{"desde": "1896-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1896-02-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1896-02-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "