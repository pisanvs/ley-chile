{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,547.- Santiago, 18 de agosto de 1902.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6165701}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Mar&#xED;a Aurelia Gonz&#xE1;lez hermana lej&#xED;tima del sarjento primero del batallon Chacabuco, Felipe Gonz&#xE1;lez, muerto a consecuencia de heridas recibidas en la batalla Chorrillos, la pension de que gozaba su se&#xF1;ora madre do&#xF1;a Cecilia Rojas, de la que disfrutar&#xE1; con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6165702}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- V&#xED;ctor Manuel Lamas.</div><br></div>", "i": 6165703}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1547", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1547"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1902-08-18", "doble_articulado": false, "id_norma": "135530", "numero_fuente": "7328", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1902-08-19", "vigencias": [{"desde": "1902-08-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1902-08-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1902-08-19", "fin_vigencia"