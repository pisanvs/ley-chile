{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6155716}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 994 de 09.06.88, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a parcelas N&#xB0;s 1 a la 6, sitios N&#xB0;s 1 al 21 y 23 al 32 y Reservas Cora N&#xB0;s C, D-1, D-2, D-3, E y F, del Proyecto de Parcelaci&#xF3;n &quot;Cosmito&quot; de la comuna de Penco VIII Regi&#xF3;n, formado por parte del predio &quot;Granja Cosmito&quot; Los Derechos de Agua provienen de dos mercedes de agua de los Esteros Paso de Piedra y Sin Nombre conducidas por el desag&#xFC;e la Greda y de vertientes alimentadoras de un tranque. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.</div><br></div>", "i": 6155717}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Ejecutivo.</div><br></div>", "i": 6155718}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "994 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-994 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-06-09", "doble_articulado": false, "id_norma": "132255", "numero_fuente": "33096", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-06-15", "vigencias": [{"desde": "1988-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-06-15", "fin_vigencia": ""}, "vigenci