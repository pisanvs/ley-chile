{"html": [{"t": "<div><div class=\"p\">\t</div><div class=\"p\">EXTRACTO</div></div>", "i": 9880445}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA; 1779, de 22 de diciembre de 2017, se modific&#xF3; el numeral primero del <a href=\"https://www.leychile.cl/Navegar?idNorma=1109953&amp;idParte=0&amp;idVersion=\">Decreto (Exento) MOP. N&#xBA;1179, de 04 de noviembre de 2016</a>, a fin de individualizar correctamente el kilometraje del lote N&#xBA;9, donde dice &quot;10,08690&quot;, debe decir &quot;19,08690&quot;. </div></div>", "i": 9880446}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9880447}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1779 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1779 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1340348", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-12-22", "doble_articulado": false, "id_norma": "1114301", "numero_fuente": "41972", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-02-01", "vigencias": [{"desde": "2018-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2018-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2018-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "1289", "fecha_ingreso": "2018-02-