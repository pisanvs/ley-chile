{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7319416}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;1.008, de 6 de abril de 2005 de esta Subsecretar&#xED;a, autor&#xED;zase a EMPRESAS AQUACHILE S.A. para continuar desarrollando las actividades pesqueras de transformaci&#xF3;n en una planta ubicada en sector Cardonal, Lote B, Puerto Montt, autorizadas mediante las resoluciones N&#xBA;1.151 de 1994 y N&#xBA;2.122 de 2000, ambas de esta Subsecretar&#xED;a, a Salmones Pac&#xED;fico Sur S.A., del mismo RUT. y domicilio, en virtud de la escritura p&#xFA;blica citada en Visto y del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 7319417}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7319418}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1008 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1008 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-04-06", "doble_articulado": false, "id_norma": "237161", "numero_fuente": "38139", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-04-19", "vigencias": [{"desde": "2005-04-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-04-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-04-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc