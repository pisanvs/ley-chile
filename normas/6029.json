{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 371.- Santiago, 18 de marzo de 1925.-</div><div class=\"p\">&nbsp; &nbsp; La Junta de Gobierno acuerda y dicta el siguiente DECRETO-LEI:</div><br></div>", "i": 8256046}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Red&#xFA;cese en cincuenta mil pesos ($ 50,000) el &#xED;tem 1611, partida 5.a, del Presupuesto del Interior, para gastos jenerales de las polic&#xED;as fiscales, y aum&#xE9;ntase en igual cantidad el &#xED;tem 5644, partida 13 del indicado presupuesto, para imprevistos.- </div></div>", "i": 8256047}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Emilio Bello C.- C. A. Ward.- Pedro P. Dartnell E.- Armando Jaramillo.</div><br></div>", "i": 8256048}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "371", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-371"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GASTOS NACION", "A O", "1925", "MODIFICACION", "MINISTERIO INTERIOR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1925-03-18", "doble_articulado": false, "id_norma": "6029", "numero_fuente": "14135", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1925-03-25", "vigencias": [{"desde": "1925-03-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1925-03-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1925-03-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1925-03-25", "fecha_actualizacion_texto": "1925-03-25", "tipo_tratado": ""}, "alertas":