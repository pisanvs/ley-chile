{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6743154}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xB0; 639, de 30 de octubre de 1995, se expropiaron los lotes de terreno N&#xBA;s. 50, 52, 62, 64, 65, 10 y 109, superficies 8.734, 3.856, 630, 5.806, 2.536, 5.118 y 73 M2., respectivamente, roles de aval&#xFA;o N&#xBA;s. 315-23, 315-115, 317-68, Comuna de Quirihue para la obra Camino Cauquenes-L&#xED;mite Regional-Quirihue Sector Cuesta, y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Sucesi&#xF3;n Juan Candia C., Sucesi&#xF3;n C&#xE9;sar Castillo Molina y Sucesi&#xF3;n Waldo Placencia Mora, ascendente a las cantidades de $1.064.382.- $853.483 y $603.784.</div><br></div>", "i": 6743155}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6743156}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "639", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-639"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-10-30", "doble_articulado": false, "id_norma": "218629", "numero_fuente": "35331", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-12-01", "vigencias": [{"desde": "1995-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingres