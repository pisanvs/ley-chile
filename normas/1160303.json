{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  OBISPO DE CONCEPCION.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Octubre 18 de 1831.</div><br><div class=\"p\">&nbsp; &nbsp;  A S. E. EL PRESIDENTE DE LA REP&#xDA;BLICA.</div><br><div class=\"p\">&nbsp; &nbsp;  El Congreso nacional, a consecuencia de la nota en que S. E. el Presidente de la Rep&#xFA;blica pide se designe el sueldo que debe gozar el Obispo electo de Concepcion ha sancionado lo que sigue:</div></div>", "i": 10258075}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art. &#xFA;nico: El Obispo de R&#xE9;timo, electo de Concepcion, tendr&#xE1; una pension de seis mil pesos por toda renta sobre la masa decimal. - Dios guarde a S.E. - JOAQUIN TOCORNAL. - Manuel Camilo Vial. - Diputado Secretario.</div><br></div>", "i": 10258076}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  DECRETO.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Octubre 20 de 1831. </div><br><div class=\"p\">&nbsp; &nbsp;  C&#xFA;mplase, refr&#xE9;ndese, t&#xF3;mese razon, comun&#xED;quese, publ&#xED;quese y arch&#xED;vese. </div><br><div class=\"p\">&nbsp; &nbsp;  PRIETO.</div><div class=\"p\">&nbsp; &nbsp;  Errazuriz.</div></div>", "i": 10258077}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTRO", "descripcion": "Otro", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "OBISPO DE CONCEPCION.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1831-10-20", "doble_articulado": false, "id_norma": "1160303", "numero_fuente": "1831", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1831-10-20", "hasta