{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9289452}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;1405, de 27 de julio de 2012, se modific&#xF3; el <a href=\"https://www.leychile.cl/Navegar?idNorma=1040652&amp;idParte=0&amp;idVersion=\">Decreto MOP. N&#xBA;(E) 899, de 16 de mayo de 2012</a>, que orden&#xF3; la expropiaci&#xF3;n del lote de terreno N&#xBA;21L3, expropiado para la obra &quot;PROYECTO LINEA 3 LA REINA -HUECHURABA, SECTOR: AV. INDEPENDENCIA&quot;, en cuanto a que se rectific&#xF3; el numeral 3&#xB0;, en el sentido de que la comisi&#xF3;n de peritos con fecha 9 de marzo de 2012, fij&#xF3; el monto de la indemnizaci&#xF3;n provisional y no el mes que figura en el decreto primitivo. </div><br></div>", "i": 9289453}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9289454}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1405 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1405 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-27", "doble_articulado": false, "id_norma": "1042996", "numero_fuente": "40338", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-08-16", "vigencias": [{"desde": "2012-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [