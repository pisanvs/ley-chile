{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6558353}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.522, de 30 de diciembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA SUR AUSTRAL S.A. para realizar operaciones pesqueras a contar del 1 de enero del a&#xF1;o 2006 y hasta el 31 de diciembre del mismo a&#xF1;o, ambas fechas inclusive, con la nave f&#xE1;brica denominada &quot;Ocean Dawn&quot;, en aguas exteriores, por fuera de las l&#xED;neas de base recta, entre los paralelos 47&#xB0; L.S y 57&#xB0; L.S., respecto de los recursos y con las obligaciones establecidas en la resoluci&#xF3;n N&#xBA; 4.234, N&#xBA; 4.236 y N&#xBA; 4.237, todas de 2005, de esta Subsecretar&#xED;a.</div><br></div>", "i": 6558354}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de diciembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6558355}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4522 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4522 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-30", "doble_articulado": false, "id_norma": "246609", "numero_fuente": "38368", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-01-20", "vigencias": [{"desde": "2006-01-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-01-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "20