{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 3,514.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 8352558}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Aum&#xE9;ntase por gracia, a setecientos veinte pesos ($ 720) anuales la pension de jubilacion de cuatrocientos treinta y siete pesos cuarenta centavos ($ 437.40) que actualmente percibe el ex-mayordomo de la C&#xE1;mara de Diputados, don Benito Vera.</div><br></div>", "i": 8352559}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a treinta de junio de mil novecientos diecinueve.- Juan Luis Sanfuentes.- Anselmo Hevia R. </div></div>", "i": 8352560}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3514", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3514"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1919-06-30", "doble_articulado": false, "id_norma": "146399", "numero_fuente": "12416", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1919-07-08", "vigencias": [{"desde": "1919-07-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1919-07-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1919-07-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente