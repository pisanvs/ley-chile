{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCIONES N&#xBA; 45, DE 2003; N&#xBA; 86, DE 2005, Y N&#xBA; 93, DE 2006, EXENTAS, EN LO REFERENTE AL REQUISITO DE VERIFICACI&#xD3;N DE ACTIVIDADES</div></div>", "i": 9133242}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 49, de 8 de abril de 2011, que modifica resoluciones exentas SII N&#xBA; 45, de 2003; N&#xBA; 86, de 2005, y N&#xBA; 93, de 2006.</div><div class=\"p\">&nbsp; &nbsp;  Modifica resoluciones exentas SII <a href=\"https://www.leychile.cl/Navegar?idNorma=214432&amp;idParte=0&amp;idVersion=\">N&#xBA; 45, de 01.09.2003</a>; <a href=\"https://www.leychile.cl/Navegar?idNorma=241702&amp;idParte=0&amp;idVersion=\">N&#xBA; 86, de 01.09.2005</a>, y <a href=\"https://www.leychile.cl/Navegar?idNorma=251979&amp;idParte=0&amp;idVersion=\">N&#xBA; 93, del 02.08.2006</a>, en lo referente al requisito de verificaci&#xF3;n de actividades.</div><div class=\"p\">El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de abril de 2011.</div></div>", "i": 9133243}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "49 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-49 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCIONES Nº 45, DE 2003; Nº 86, DE 2005, Y Nº 93, DE 2006, EXENTAS, EN LO REFERENTE AL REQUISITO DE VERIFICACIÓN DE ACTIVIDADES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO, NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-04-08", "doble_articulado": false, "id_norma": "1024509", "numero_fuente": "39936", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-04-14", "vigencias": [{"desde": "2011-04-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-04-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-04-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "17616", "fecha_ingreso": "2011-04-14", "fecha_version": "2011-04-14", "actualizado_por": "17616", "fecha_actualizacion_texto": "2011-04-14", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9133242}, {"n": "Artículo", "i": 9133243, "t": 6}]}