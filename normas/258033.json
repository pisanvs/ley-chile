{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.906 EXENTO, DE 2006 </div></div>", "i": 6599865}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.906, de fecha 22 de noviembre de 2006, se declara aprobada a la Universidad Regional San Marcos la modificaci&#xF3;n mayor al plan y a los programas de estudios y grado acad&#xE9;mico que se indican a partir del primer semestre de 2007:</div><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :&nbsp; Odontolog&#xED;a</div><div class=\"p\">Grado Acad&#xE9;mico&nbsp; :&nbsp; Licenciado en Odontolog&#xED;a</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  :&nbsp; Cirujano Dentista</div><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :&nbsp; Educaci&#xF3;n B&#xE1;sica</div><div class=\"p\">Grado Acad&#xE9;mico&nbsp; :&nbsp; Licenciado en Educaci&#xF3;n</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  :&nbsp; Profesor de Educaci&#xF3;n B&#xE1;sica</div><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :&nbsp; Educaci&#xF3;n F&#xED;sica y Deportes</div><div class=\"p\">Grado Acad&#xE9;mico&nbsp; :&nbsp; Licenciado en Educaci&#xF3;n</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  :&nbsp; Profesor de Educaci&#xF3;n F&#xED;sica.</div><br></div>", "i": 6599866}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de enero de 2007.- Pilar Romaguera Gracia, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 6599867}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1906 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1906 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.906 EXENTO, DE 2006", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "pai