{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;169 EXENTO, DE 2001 </div></div>", "i": 6335828}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 169 de fecha 19 de abril de 2001 del Ministerio de Educaci&#xF3;n, se declaran aprobadas al Instituto Profesional EATRI las modificaciones al plan y a los programas de estudio de la carrera de Traductor e Int&#xE9;rprete de Enlace con menci&#xF3;n en Ingl&#xE9;s-Franc&#xE9;s que se imparte en jornada diurna. Dichas modificaciones tendr&#xE1;n vigencia a contar del primer semestre del a&#xF1;o 2001.</div><br></div>", "i": 6335829}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 2 de mayo de 2001.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6335830}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "169 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-169 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº169 EXENTO, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-19", "doble_articulado": false, "id_norma": "185581", "numero_fuente": "36968", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-23", "vigencias": [{"desde": "2001-05-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-05-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-05-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2001-05-23", "fecha_version": "2001-05-23