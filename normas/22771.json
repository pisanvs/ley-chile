{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que concede fondos para combatir la viruela en Tarapac&#xE1;, Antofagasta i Atacama</div><div class=\"p\">&nbsp; &nbsp; Valparaiso, a 20 de Febrero de 1903.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274460}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de diez mil pesos a fin de combatir la viruela en las provincias de Tarapac&#xE1;, Antofagasta i Atacama.</div><br></div>", "i": 8274461}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- El&#xED;as Fern&#xE1;ndez Albano </div></div>", "i": 8274462}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1590", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1590"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "QUE CONCEDE FONDO PARA COMBATIR LA VIRUELA EN TARAPACA, ANTOFAGASTA I ATACAMA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TARAPACA", "ANTOFAGASTA", "ATACAMA", "VIRUELA", "PROFILAXIS", "FONDOS", "DESTINACION", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1903-02-20", "doble_articulado": false, "id_norma": "22771", "numero_fuente": "7517", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1903-02-26", "vigencias": [{"desde": "1903-02-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni