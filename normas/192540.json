{"html": [{"t": "<div><div class=\"p\">DISPONE EXPROPIACIONES PARCIALES QUE INDICA</div><br><br></div>", "i": 6361261}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 3.210 de 28 de noviembre de 2001, Serviu Regi&#xF3;n Valpara&#xED;so dispuso expropiaci&#xF3;n parcial, conforme art&#xED;culo 87 ley 8.946 y decreto ley 2.186, de 1978, de lote 271 ubicado en Avenida Alejandro Navarrete s/n, rol aval&#xFA;o 1088-253, comuna Vi&#xF1;a del Mar, de presunto dominio de Jos&#xE9; Luis N&#xFA;&#xF1;ez Ayala. Comisi&#xF3;n tasadora integrada por Sres. Osvaldo Mu&#xF1;oz Quintana, arquitecto; Alvaro Verdejo Vidal, ingeniero constructor; y Pablo Caria Giurici, constructor civil, seg&#xFA;n informe de fecha 1 de octubre de 2001, fij&#xF3; monto provisional indemnizaci&#xF3;n en $248.880.- que ser&#xE1; pagada al contado.-</div><br></div>", "i": 6361262}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n Valpara&#xED;so.</div><br></div>", "i": 6361263}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3210", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3210"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAISO"], "titulo_norma": "DISPONE EXPROPIACIONES PARCIALES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-28", "doble_articulado": false, "id_norma": "192540", "numero_fuente": "37136", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-12-15", "vigencias": [{"desde": "2001-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vige