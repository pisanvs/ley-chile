{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Sociedad &quot;Union Evanj&#xE9;lica&quot; Lei n&#xFA;m. 114.- Santiago, a 14 de Noviembre de 1893.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273728}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese a la Sociedad &quot;Union Evanj&#xE9;lica&quot; el permiso requerido por el art. 556 del C&#xF3;digo Civil para conservar por el t&#xE9;rmino de treinta a&#xF1;os, la posesion de las propiedades raices que tiene adquiridas en la calle de Nataniel, esquina de la del Instituto, i en la Avenida Portales de esta capital, i en la calle de San Agustin de la ciudad de Valparaiso.</div><br><br></div>", "i": 8273729}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Pedro Montt.</div><br></div>", "i": 8273730}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "114", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-114"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "SOCIEDAD UNION EVANJELICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD UNION EVANGELICA", "BIENES RAICES", "PERMISO", "CONSERVACION", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-11-14", "doble_articulado": false, "id_norma": "21979", "numero_fuente": "4668", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-11-14", "vigencias": [{"desde": "1893-11-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "