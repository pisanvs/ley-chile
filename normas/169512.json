{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA; 1, DE 1988 </div></div>", "i": 6277928}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 1 de 07 de enero de 1988 se ha modificado el plan especial de estudio del Liceo Alem&#xE1;n, de Santiago, aprobado por decreto supremo exento de Educaci&#xF3;n N&#xBA; 94, de 1983, en que sustituye planes de estudio para 5&#xBA; y 6&#xBA;; 7&#xBA; y 8&#xBA; a&#xF1;o de Educaci&#xF3;n General B&#xE1;sica y para el 1er. y 2do. ciclo de la Educaci&#xF3;n Media Humanistico-Cientifica, por los que se indican en el presente decreto.</div><br></div>", "i": 6277929}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de Enero de 1988.- Mar&#xED;a Piedad Ruiz Ferreras, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 6277930}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº 1, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-07", "doble_articulado": false, "id_norma": "169512", "numero_fuente": "32980", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-01-27", "vigencias": [{"desde": "1988-01-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-01-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-01-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresad