{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6462427}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 244 de 21 de enero de 2004 de esta Subsecretar&#xED;a, decl&#xE1;rase que con fecha 28 de noviembre de 2003 ha quedado sin efecto la resoluci&#xF3;n N&#xBA; 2.988 de 2003, de esta Subsecretar&#xED;a, que autoriz&#xF3; a COMPA&#xD1;IA PESQUERA CAMANCHACA S.A. para desarrollar actividad extractiva con la nave &quot;Halc&#xF3;n&quot;, en virtud de lo dispuesto en el art&#xED;culo 9&#xBA; de la ley N&#xBA; 19.713. Dicha nave queda permanente e irrevocablemente excluida de la actividad pesquera extractiva, a menos que sustituya a otra u otras naves.</div><br></div>", "i": 6462428}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de enero de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6462429}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "244", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-244"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-21", "doble_articulado": false, "id_norma": "220899", "numero_fuente": "37778", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-05", "vigencias": [{"desde": "2004-02-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-02-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-02-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [],