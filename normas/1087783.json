{"html": [{"t": "<div><br><div class=\"p\">Ley n&#xFA;m. 4,978</div><br><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de Ley:</div><br></div>", "i": 9678918}, {"t": "<div><div class=\"p\">Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, y por el plazo de diez a&#xF1;os, a do&#xF1;a Mercedes Moncada, viuda del ex-electricista del Senado y de la C&#xE1;mara de Diputados, don Francisco Infante Y&#xE1;&#xF1;ez, y a su hija menor, do&#xF1;a Mar&#xED;a Teresa Infante Moncada, el goce de una pensi&#xF3;n de montep&#xED;o de doscientos pesos mensuales.</div><div class=\"p\">&nbsp; &nbsp;  Esta ley comenzar&#xE1; a regir desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div></div>", "i": 9678919}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  I por cuanto he tenido a bien aprobarlo y sancionarlo, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, cinco de Agosto de mil novecientos treinta y uno.- JUAN E. MONTERO.- Luis Guti&#xE9;rrez A.</div></div>", "i": 9678920}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4978", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "Ley-4978"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEY NÚM. 4,978", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-08-05", "doble_articulado": false, "id_norma": "1087783", "numero_fuente": "16046", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-08-12", "vigencias": [{"desde": "1931-08-12", "hasta": "", "tipo_version": "3", "tipo