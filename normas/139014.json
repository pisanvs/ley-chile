{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO DE EDUCACION N&#xB0; 3, DE 1988 </div></div>", "i": 7250548}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 3 de 12 de enero de 1988 se ha complementado, a contar del a&#xF1;o escolar 1988 los art&#xED;culos 1&#xB0; de los decretos supremos exentos de Educaci&#xF3;n No. s. 34 y 197 ambos de 1987 que aprobaron planes de estudio de segundo ciclo de Educaci&#xF3;n Media en la modalidad T&#xE9;cnico-Profesional para el Instituto Comercial &quot;Iquique English College&quot;, de Iquique.</div><br></div>", "i": 7250549}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mar&#xED;a Piedad Ruiz Ferreras, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante.</div><br></div>", "i": 7250550}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO DE EDUCACION N° 3, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-12", "doble_articulado": false, "id_norma": "139014", "numero_fuente": "32987", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-04", "vigencias": [{"desde": "1988-02-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-02-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "