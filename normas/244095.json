{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br><br></div>", "i": 8653313}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 282, de 14 de Agosto de 1985, la Subsecretar&#xED;a de Telecomunicaciones estableci&#xF3; las frecuencias radioel&#xE9;ctricas y las caracter&#xED;sticas t&#xE9;cnicas m&#xED;nimas asociadas a &#xE9;stas, para el empleo de radiocontroles de aeromodelos en el pa&#xED;s.</div><div class=\"p\">&nbsp; &nbsp;  La Subsecretar&#xED;a de Telecomunicaciones proporcionar&#xE1; ejemplares de la citada resoluci&#xF3;n a los organismos que tengan relaci&#xF3;n con la citada materia.- </div></div>", "i": 8653314}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Italo Seccatore G&#xF3;mez, Coronel de Ej&#xE9;rcito, Subsecretario de Telecomunicaciones.</div><br></div>", "i": 8653315}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "282 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-282 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TELECOMUNICACIONES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["WEBMEC", "WEBSUBTEL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-08-14", "doble_articulado": false, "id_norma": "244095", "numero_fuente": "32260", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-08-29", "vigencias": [{"desde": "1985-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-08-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-08-29", "fin_vigencia": "", "tipo_version": "