{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 15, DE 1989 </div></div>", "i": 7229074}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 15 de 27 de enero de 1989 se ha aprobado un plan especial de estudio para el Colegio Aconcagua, de Santiago, para 1&#xB0; y 2&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico -&nbsp; Cient&#xED;fica, el que se aplicar&#xE1; simult&#xE1;neamente a contar del a&#xF1;o 1989.- </div></div>", "i": 7229075}, {"t": "<div><div class=\"p\">Adelchi Colombo Breschi, Subsecretario de Educaci&#xF3;n P&#xFA;blica Subrogante.</div><br></div>", "i": 7229076}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "15 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-15 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 15, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-01-27", "doble_articulado": false, "id_norma": "94778", "numero_fuente": "33329", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-03-22", "vigencias": [{"desde": "1989-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-03-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-03-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "ALV", "fecha_ingreso": "1998-03-09", "fecha_version": "1989-03-22", "fecha_actualizacion_texto": "1989-03-22", "tipo_tratado": ""}, "alertas": [], "alerta_global