{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA N&#xB0; 246, DE 1986 </div></div>", "i": 6222959}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 246 de fecha 23 de enero de 1986 del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se modific&#xF3; la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xB0; 731 de 1983, que aprueba planes y programas de estudios de la carrera Contabilidad, entre otras, al Centro de Formaci&#xF3;n T&#xE9;cnica SOEDUC, Sede N&#xB0; 1 Vi&#xF1;a del Mar, para que se aplique por esta sola vez, plan especial de estudio, a fin de regularizar la situaci&#xF3;n acad&#xE9;mica al alumno Jorge R&#xED;os Mu&#xF1;oz, de la carrera mencionada, para que valide las asignaturas del 1&#xB0; y 2&#xB0; nivel de la carrera.-</div><br></div>", "i": 6222960}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6222961}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "246 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-246 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N° 246, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-01-23", "doble_articulado": false, "id_norma": "152379", "numero_fuente": "32.598", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-10-16", "vigencias": [{"desde": "1986-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-10-16", "fin_vigencia": "