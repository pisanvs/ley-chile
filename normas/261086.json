{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 10,867</div><br><div class=\"p\">CONCEDE A DON FROILAN RUIZ A. UNA PENSION MENSUAL CUYO MONTO SE&#xD1;ALA</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 7342630}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a don Froil&#xE1;n Ruiz Almonacid, una pensi&#xF3;n de un mil pesos ($ 1.000) mensuales.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande esta ley se imputar&#xE1; al &#xED;tem de pensiones del Presupuesto del Ministerio de Hacienda. </div></div>", "i": 7342631}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintid&#xF3;s de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Ignacio Lorca G.</div><br></div>", "i": 7342632}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10867", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10867"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE A DON FROILAN RUIZ A. UNA PENSION MENSUAL CUYO\nMONTO SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-22", "doble_articulado": false, "id_norma": "261086", "numero_fuente": "22404", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-11-20", "vigencias": [{"desde": "1952-11-20", "hasta": "", "tipo_version": "3", "tipo_version_s"