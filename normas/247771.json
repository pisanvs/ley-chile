{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6563148}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;340, de 31 de enero de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase al SINDICATO DE TRABAJADORES INDEPENDIENTES PESCADORES ARTESANALES, BUZOS MARISCADORES, EXTRACTORES DE MARISCOS CALETA LAS CONCHAS para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Avenida Costanera s/n, Caleta Las Conchas, Los Vilos, IV Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Cocido, Fresco Enfriado, Fresco Refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6563149}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de enero de 2006.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6563150}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "340 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-340 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-31", "doble_articulado": false, "id_norma": "247771", "numero_fuente": "38406", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-06", "vigencias": [{"desde": "2006-03-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-03-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-03-06", "fin_vigencia": "", "tipo_ver