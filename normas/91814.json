{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA</div><br><br></div>", "i": 8320766}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 368 de 27 de Marzo de 1989 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 2&#xB0; de la resoluci&#xF3;n No. 646, de 1988, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don Juan Sanzana D&#xED;az, RUT No. 4.181.467-5, domiciliado calle Los Carrera No. 441, Castro, para desarrollar actividades pesqueras de cultivo en el sector Molulco, Estero Compu, Comuna de Quell&#xF3;n, Provincia de Chilo&#xE9;, X Regi&#xF3;n, en orden a reemplazar la expresi&#xF3;n &quot;V&#xE9;rtice A Lat. 42&#xB0; 31&apos; 54,80&quot; S&quot; por &quot;V&#xE9;rtice A Lat. 42&#xB0; 51&apos; 54,80&quot; S&quot;.</div><br><br></div>", "i": 8320767}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 27 de Marzo de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8320768}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "368", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-368"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-03-27", "doble_articulado": false, "id_norma": "91814", "numero_fuente": "33342", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-04-08", "vigencias": [{"desde": "1989-04-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-04-08", "fin_vig