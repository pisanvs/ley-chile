{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6260485}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta N&#xB0; 555, de Agosto 14 de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana, se autoriza a don Sergio Hern ndez Arancibia, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6260486}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, Agosto 20 de 1985.- Carlos Rom&#xE1;n Toro, Secretario Regional M&#xED;nisterial Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6260487}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "555 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-555 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-08-14", "doble_articulado": false, "id_norma": "164091", "numero_fuente": "32262", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-08-31", "vigencias": [{"desde": "1985-08-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-08-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-08-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe