{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xB0; 4.365 EXENTA, DE 2018, DE ESTA SUBSECRETAR&#xCD;A</div></div>", "i": 10052270}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.986, de 3 de septiembre de 2019, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xB0; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1126986&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 4.365, de 2018</a>, en el sentido de asignar la cuota de imprevistos ascendente a 7.494 toneladas de Anchoveta a la Regi&#xF3;n de Arica y Parinacota, para el a&#xF1;o 2019.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\"> </div></div>", "i": 10052271}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de septiembre de 2019.- Jos&#xE9; Pedro N&#xFA;&#xF1;ez Barruel, Subsecretario de Pesca y Acuicultura (S).</div><br><br></div>", "i": 10052272}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2986 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2986 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN N° 4.365 EXENTA, DE 2018, DE ESTA SUBSECRETARÍA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1651269", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-09-03", "doble_articulado": false, "id_norma": "1135967", "numero_fuente": "42452", "