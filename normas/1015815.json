{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 492 EXENTA, DE 2010</div><br></div>", "i": 8954803}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 492, de 4 de junio de 2010, la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la III Regi&#xF3;n, modific&#xF3; la <a href=\"https://www.leychile.cl/Navegar?idNorma=261618&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 110/2007</a> y su extracto en el sentido de sustituir la frase &quot;categor&#xED;a A2&quot;, con una capacidad m&#xE1;xima de 136 Taxis Colectivos, por &quot;categor&#xED;a A4&quot;, con una capacidad m&#xE1;xima de 332 Taxis Colectivos.-</div></div>", "i": 8954804}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alberto Barrionuevo Pinto, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de Atacama.</div></div>", "i": 8954805}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "492 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-492 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 492 EXENTA, DE 2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-06-04", "doble_articulado": false, "id_norma": "1015815", "numero_fuente": "39724", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-07-31", "vigencias": [{"desde": "2010-07-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia":