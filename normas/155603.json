{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6232594}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 144 de 13 de febrero de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a don Hern&#xE1;n Rodrigo Zablah Chicago, para efectuar las revisiones t&#xE9;cnicas de los veh&#xED;culos de transporte de personas de m&#xE1;s de nueve (9) asientos, incluido el del conductor; de veh&#xED;culos motorizados de carga con capacidad para transportar m&#xE1;s de 1.750 kilos, sus remolques y semirremolques y los taxis, en el establecimientos ubicado en calle Lo L&#xF3;pez N&#xB0; 1446 comuna de Cerro Navia.</div><br></div>", "i": 6232595}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, Febrero 17 de 1986. Ramiro Camero Weir, Secretario Regional Ministerial Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana subrogante.</div><br></div>", "i": 6232596}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "144", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-144"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-02-13", "doble_articulado": false, "id_norma": "155603", "numero_fuente": "32404", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-02-21", "vigencias": [{"desde": "1986-02-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-02-21", "fin_vi