{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10282934}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xB0; 1.093, de 7 octubre 2021, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos relativas a Realizaci&#xF3;n de Feria de las Pulgas Zofracoy en la Ciudad de Coyhaique, y autoriz&#xF3; a Departamento de Finanzas y Rentas de la I. Municipalidad de Coyhaique para realizar intervenciones en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  -corte total de v&#xED;as en calle Francisco Bilbao entre calles Eusebio Lillo y Arturo Prat, y en calle Lord Cochrane entre calle Ram&#xF3;n Freire y Plaza de Armas, entre las 08:00 hrs. y las 15:00 hrs. del d&#xED;a s&#xE1;bado 09-10-2021.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10282935}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &#xD3;scar del Solar Navarrete, Gobernador Regional (S), Gobierno Regional de Ays&#xE9;n.- Ximena Guti&#xE9;rrez Jaramillo, Asesora Jur&#xED;dica, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10282936}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1093 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1093 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2038037", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-10-07", "doble_articulado": false, "id_norma": "1168052", "numero_fuente": "43099", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicaci