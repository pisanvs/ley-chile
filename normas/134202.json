{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,155.- Santiago, 29 de diciembre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6161619}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo primero.- Conc&#xE9;dese, por gracia, al capitan retirado de Ej&#xE9;rcito, don Jos&#xE9; Francisco Concha Vergara, derecho para percibir en el estranjero la pensi&#xF3;n de retiro que le conceden las leyes.</div><br></div>", "i": 6161620}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo segundo.- Conc&#xE9;dese tambi&#xE9;n derecho para percibir todas las pensiones devengadas hasta la vijencia de la presente lei.</div><br></div>", "i": 6161621}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Carlos Concha.</div><br></div>", "i": 6161622}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1155", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1155"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-12-29", "doble_articulado": false, "id_norma": "134202", "numero_fuente": "6190", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-12-31", "vigencias": [{"desde": "1898-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-12-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic