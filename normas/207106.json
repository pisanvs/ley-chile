{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6411836}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n, que suscribe, certifica que la Universidad La Rep&#xFA;blica inscrita bajo el n&#xFA;mero C-19, del Registro de Universidades del Ministerio de Educaci&#xF3;n, ha presentado los programas de estudios de la carrera de &quot;Ingenier&#xED;a de Ejecuci&#xF3;n en Computaci&#xF3;n e Inform&#xE1;tica&quot; conducente al t&#xED;tulo profesional de &quot;Ingeniero de Ejecuci&#xF3;n en Computaci&#xF3;n e Inform&#xE1;tica&quot; a la Universidad de Atacama, Instituci&#xF3;n que ha aprobado los planes y programas y se ha constituido en entidad examinadora.</div><div class=\"p\">&nbsp; &nbsp;  La carrera mencionada podr&#xE1; impartirse a contar desde 1991.</div><br></div>", "i": 6411837}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de Enero de 1991.</div><div class=\"p\">&nbsp; &nbsp;  RAUL ALLARD NEUMANN Subsecretario de Educaci&#xF3;n </div></div>", "i": 6411838}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-31", "doble_articulado": false, "id_norma": "207106", "numero_fuente": "33902", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-02-23", "vigencias": [{"desde": "1991-02-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-02-23", "fin_vigencia": ""}, "vige