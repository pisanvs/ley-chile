{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6202345}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 327 de 23 de Marzo de 1987, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a parcelas N&#xB0;s. 1 a la 24, Sitios N&#xB0;s. 1 al 27, 28 - A, - 28 - B, y 29 al 31; Bien Com&#xFA;n General No. 1 y Reservas Cora N&#xB0;s. 1 y 2 del Proyecto de Parcelaci&#xF3;n &quot;Valle Alegre&quot;, formado por predios &quot;Hacienda Valle Alegre&quot; y &quot;La Engorda&quot; de la Comuna de Quintero, Quinta Regi&#xF3;n. Los Derechos de Agua se extraen del Canal Mauco, derivado del R&#xED;o Aconcagua y merced del Estero Quintero.- Publicaci&#xF3;n hecha conforme Art. 13 Ley No.</div><div class=\"p\">18.377.</div><br></div>", "i": 6202346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6202347}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "327 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-327 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-03-23", "doble_articulado": false, "id_norma": "146832", "numero_fuente": "32737", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-04-01", "vigencias": [{"desde": "1987-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1