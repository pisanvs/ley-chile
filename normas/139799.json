{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,164.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6179743}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se autoriza al Presidente de la Rep&#xFA;blica para invertir estraordinariamente, de las entradas del ferrocarril de Puente Alto al Volcan, hasta la suma de sesenta y un mil quinientos pesos ($ 61,500) en su esplotacion para el resto del a&#xF1;o.</div><br></div>", "i": 6179744}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionado; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintiocho de diciembre de mil novecientos dieciseis.- Juan Luis Sanfuentes.- Oscar Urz&#xFA;a. </div></div>", "i": 6179745}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3164", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3164"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-12-28", "doble_articulado": false, "id_norma": "139799", "numero_fuente": "11664", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1917-01-04", "vigencias": [{"desde": "1917-01-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1917-01-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1917-01-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes":