{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 246, DE 2011</div></div>", "i": 9237975}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 246, de 15 de diciembre de 2011, del Ministerio de Transportes y Telecomunicaciones, se aprob&#xF3; el monto de indemnizaci&#xF3;n que indica, se pone t&#xE9;rmino anticipado al Contrato de Concesi&#xF3;n de Uso de V&#xED;as suscrito con la sociedad concesionaria Su Bus Chile S.A. y aprueba Contrato Ad-Refer&#xE9;ndum de Concesi&#xF3;n de Uso de V&#xED;as para la prestaci&#xF3;n de servicios de transporte p&#xFA;blico urbano remunerado de pasajeros mediante Buses de 13 de diciembre de 2011, suscrito entre Su Bus Chile S.A., concesionario de la Unidad de Negocio N&#xBA; 2 y el Ministerio de Transportes y Telecomunicaciones.- </div></div>", "i": 9237976}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Pedro Pablo Err&#xE1;zuriz Dom&#xED;nguez, Ministro de Transportes y Telecomunicaciones.</div></div>", "i": 9237977}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "246", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-246"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 246, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-12-15", "doble_articulado": false, "id_norma": "1037421", "numero_fuente": "40191", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-02-18", "vigencias": [{"desde": "2012-02-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inici