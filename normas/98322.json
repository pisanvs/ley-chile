{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8329328}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xBA; 544, de 8 de abril de 1998, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case la resoluci&#xF3;n N&#xBA; 245, de 1998, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA IQUIQUE GUANAYE S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, en su planta ubicada en Manuel Rodr&#xED;guez N&#xBA; 302, Talcahuano, VIII Regi&#xF3;n, en el sentido de incorporar los recuros Anchoveta y Machuelo o tritre, a los ya autorizados.</div><br></div>", "i": 8329329}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 8 de abril de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8329330}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "544", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-544"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA IQUIQUE GUANAYE S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-08", "doble_articulado": false, "id_norma": "98322", "numero_fuente": "36048", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-04-24", "vigencias": [{"desde": "2001-05-05", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-04-24", "hasta": "2001-05-04", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2001-05-05", "fin_vigencia": ""}, "vigencias_version_norm