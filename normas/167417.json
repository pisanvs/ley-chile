{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6271201}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 583, de 28 de febrero de 2000, se expropiaron los lotes de terreno N&#xBA; 2 y 3, superficies 926,4 m&#xB2; y 460,16 m&#xB2;, roles de aval&#xFA;o 485-86 y 485-88, comuna de Loncoche, Obra Camino Loncoche Calafqu&#xE9;n, Sector Puente Paya y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Inge Oberreuter Grollmus y Lucy Oberreuter Grollmus, ascendente a las cantidades de $342.520, para el lote N&#xBA; 2 y $244.330, para el lote N&#xBA; 3.</div><br></div>", "i": 6271202}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6271203}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "583", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-583"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-28", "doble_articulado": false, "id_norma": "167417", "numero_fuente": "36652", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-02", "vigencias": [{"desde": "2000-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2000-05-02", "fecha_version": "2000-05-02", "fecha_actualizacion_texto": "2000-05-02", "tipo_tratado": ""}, "alert