{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO</div></div>", "i": 9633218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. (EXENTO) N&#xBA;627 de 12 de agosto de 2015, se desisti&#xF3; de la expropiaci&#xF3;n del lote N&#xBA;1, ordenada por el <a href=\"https://www.leychile.cl/Navegar?idNorma=1057359&amp;idParte=&amp;idVersion=\">Decreto MOP (Exento) N&#xBA;2296 de 29 de noviembre de 2013</a>, en atenci&#xF3;n a que Aguas Manquehue S.A, lleg&#xF3; a un acuerdo con el propietario del predio, necesario para la obra &quot;Habilitaci&#xF3;n Sondaje Chamisero II&quot;, Comuna de Colina, Regi&#xF3;n Metropolitana de Santiago. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA; 2186, de 1978.</div><br></div>", "i": 9633219, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas (s).</div></div>", "i": 9633220}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "627 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-627 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 938697", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-08-12", "doble_articulado": false, "id_norma": "1081063", "numero_fuente": "41247", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-09-01", "vigencias": [{"desde": "2015-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2015-09-01", "fin_vigencia": ""}, "vigencias_v