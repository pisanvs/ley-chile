{"html": [{"t": "<div><div class=\"p\">AUTORIZA EMISORES ELECTRONICOS </div></div>", "i": 6471616}, {"t": "<div><div class=\"p\">Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 41 del 25 de marzo de 2004, que autoriza a contribuyentes como emisores electr&#xF3;nicos</div><br><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisores de documentos tributarios electr&#xF3;nicos al contribuyente RUT 96.953.410-K a contar del mes de marzo de 2004, y a los contribuyentes RUT 82.928.600-3 y RUT 96.557.910-9 a contar del mes de abril de 2004. En el sitio Web del SII se podr&#xE1; consultar los documentos que los contribuyentes est&#xE1;n autorizados a emitir en forma electr&#xF3;nica.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del SII (www.sii.cl) y, adem&#xE1;s aparecer&#xE1; en el Bolet&#xED;n del SII de marzo de 2004.</div><br></div>", "i": 6471617}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "41 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-41 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISORES ELECTRONICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-25", "doble_articulado": false, "id_norma": "223130", "numero_fuente": "37825", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-31", "vigencias": [{"desde": "2004-03-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-03-31", "fin_vig