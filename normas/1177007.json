{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10339395}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta RW N&#xB0; 10.266, de 21 de abril de 2022, del Instituto de Salud P&#xFA;blica de Chile, que clasifica el producto Toalla de Papel Nova Protect, como Producto de los Plaguicidas de Uso Sanitario y Dom&#xE9;stico (Desinfectante).</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, en el siguiente link: http://www.ispch.cl/resoluciones.- </div><br></div>", "i": 10339396}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Heriberto Garc&#xED;a Escorza, Director (S), Instituto de Salud P&#xFA;blica de Chile.</div><div class=\"p\"> </div></div>", "i": 10339397}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10266 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-10266 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2139287", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-04-21", "doble_articulado": false, "id_norma": "1177007", "numero_fuente": "43271", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-06-06", "vigencias": [{"desde": "2022-06-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2022-06-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2022-06-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por