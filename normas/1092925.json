{"html": [{"t": "<div><br><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA</div></div>", "i": 9718117}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional de Temuco del SII, por resoluci&#xF3;n Ex. N&#xB0; 77316060472, de fecha 12/07/2016, deja sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=274969&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n Ex. N&#xBA; 225, del 18/07/2008</a>, que otorga la calidad de agente retenedor de cambio de sujeto de derecho del Impuesto al Valor Agregado en las operaciones de contrato de instalaci&#xF3;n o confecci&#xF3;n de especialidades que contraten, a contar de la fecha de esta publicaci&#xF3;n, al contribuyente Sociedad de Proyectos y Montajes El&#xE9;ctricos Limitada, RUT N&#xBA; 78.832.020-5, conforme a lo establecido en la <a href=\"https://www.leychile.cl/Navegar?idNorma=245598&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n Ex. N&#xB0; 142, de fecha 26.12.2005</a>, de la Direcci&#xF3;n Nacional del Servicio, publicada en el Diario Oficial de fecha 29.12.2005.-</div><br></div>", "i": 9718118, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lidia del Carmen Castillo Alarc&#xF3;n, Directora Regional.</div></div>", "i": 9718119}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "77316060472 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-77316060472 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1045270; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2