{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7276592}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.976 de 7 de septiembre de 2000 de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 765, de 1985, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a SOCIEDAD PESCA MARINA LIMITADA para operar con la nave &apos;&apos;Polux&apos;&apos; sobre el recurso Langostino amarillo, en el litoral de la III y IV regiones, de conformidad con lo establecido en la letra b) del art&#xED;culo 143 del D.S. N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 7276593}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de septiembre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca. </div></div>", "i": 7276594}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1976", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1976"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-09-07", "fecha_derogacion": "2005-03-04", "doble_articulado": false, "id_norma": "175348", "numero_fuente": "36763", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-09-13", "vigencias": [{"desde": "2005-03-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2000-09-13", "hasta": "2005-03-03", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2005-03-04", "fi