{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; TRASPASA LA SUMA DE $ 2.500,000 DE 06/01/05/C A 04/06/04/i (2) DEL PRESUPUESTO VIGENTE</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5962291}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Trasp&#xE1;sase la suma de dos millones quinientos mil pesos ($2.500,000), de 06/01/05/c a 04/06/04/i (2) del Presupuesto vigente.</div><div class=\"p\">&nbsp; &nbsp; Esta ley regir&#xE1; desde su publicaci&#xF3;n en el Diario Oficial.</div><br><br></div>", "i": 5962292}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a tres de Octubre de mil novecientos treinta y cinco.- ARTURO ALESSANDRI.- Gustavo Ross. </div></div>", "i": 5962293}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "5727", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-5727"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "TRASPASA LA SUMA DE $ 2.500,000 DE 06/01/05/C A\n04/06/04/i (2) DEL PRESUPUESTO VIGENTE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1935", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1935-10-03", "doble_articulado": false, "id_norma": "25174", "numero_fuente": "17283", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1935-10-04", "vigencias": [{"desde": "1935-10-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "