{"html": [{"t": "<div><div class=\"p\">&nbsp; Art&#xED;culo cincuenta i cuatro de la Constituci&#xF3;n</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Santiago, 3 de enero de 1873.</div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha aprobado el siguiente</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 8919611}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Art&#xED;culo &#xFA;nico.</div><br><div class=\"p\">&nbsp; &nbsp;  Se declara reformable el art&#xED;culo cincuenta i cuatro de la Constituci&#xF3;n.</div><br></div>", "i": 8919612, "v": ["CONCORDANCIA"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Federico Err&#xE1;zuriz.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Eulojio Altamirano.</div><br></div>", "i": 8919613}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "S/N", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Artículo cincuenta i cuatro de la Constitución", "fuente": "Boletin de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1873-01-03", "doble_articulado": false, "id_norma": "131715", "numero_fuente": "LIBRO 41, 1, PAG. 9", "tipo_version": "3", "tipo_version_s": "Única", "