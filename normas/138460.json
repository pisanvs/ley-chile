{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,957.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6175449}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo 1.&#xBA; En atenci&#xF3;n&nbsp; a los servicios prestados al pais por don Aliro Parga, se concede a su viuda, do&#xF1;a Carmela Rios de Parga i a sus hijas solteras do&#xF1;a Eujenia i do&#xF1;a Mar&#xED;a Parga Rios, por el t&#xE9;rmino de diez a&#xF1;os, una pension anual de seis mil pesos ($ 6,000), de que disfrutar&#xE1;n por partes iguales i sin derecho de acrecer. </div></div>", "i": 6175450}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. 2.&#xBA; Esta lei rejir&#xE1; desde su publicacion en el Diario Oficial.</div><br></div>", "i": 6175451}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a doce de diciembre de mil novecientos catorce.- Ram&#xF3;n Barros Luco.- Alberto Edwards. </div></div>", "i": 6175452}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2957", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2957"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1914-12-12", "doble_articulado": false, "id_norma": "138460", "numero_fuente": "11048", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1914-12-18", "vigencias": [{"desde": "1914-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1914-12-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1914-12-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-07-05", "fecha_version": "1914-12-18", "fecha_actualizacion_texto": "1914-12-18", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6175449}, {"n": "Artículo 1", "i": 6175450, "t": 6}, {"n": "Artículo 2", "i": 6175451, "t": 6}, {"n": "Promulgación", "i": 6175452}]}