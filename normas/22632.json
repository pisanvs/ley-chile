{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 1,416.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949114}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de 9,000 pesos al &#xED;tem 22 de la partida 32 del presupuesto de Hacienda, para gastos de reconocimiento de salitreras i guaneras i levantamiento de planos i deslindes.</div><br><br></div>", "i": 5949115}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 26 de Diciembre de 1900.- FEDERICO ERRAZURIZ E.- Nicolas Gonz&#xE1;lez E.</div><br></div>", "i": 5949116}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1416", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1416"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1900", "MODIFICACION", "MINISTERIO", "HACIENDA", "SALITRERAS", "GUANERAS", "RECONOCIMIENTO", "LEVANTAMIENTO", "PLANOS", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-12-26", "doble_articulado": false, "id_norma": "22632", "numero_fuente": "6778", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-12-28", "vigencias": [{"desde": "1900-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-12-28", "fin_vigencia": ""}, "v