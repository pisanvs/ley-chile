{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION No. 144 DE 17 DE JUNIO DE 1985</div><br><br></div>", "i": 6255247}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado Planes y Programas Especiales de Estudio para Segundo Cielo de la Educaci&#xF3;n Media T&#xE9;cnico-Profesional, a contar del a&#xF1;o escolar 1985 y hasta el a&#xF1;o escolar 1990, inclusive, para el Liceo T&#xE9;cnico Bel&#xE9;n de Copiap&#xF3;.</div><div class=\"p\">&nbsp; &nbsp;  ESPECIALIDADES</div><div class=\"p\">&nbsp; &nbsp;  1.- Atenci&#xF3;n de P&#xE1;rvulos con Menci&#xF3;n en Educaci&#xF3;n Diferencial.</div><div class=\"p\">&nbsp; &nbsp;  2.- Tejido Industrial.</div><div class=\"p\">&nbsp; &nbsp;  3.- Vestuario Industrial.</div><br></div>", "i": 6255248}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica Subrogante.</div><br></div>", "i": 6255249}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "144 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-144 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION No. 144\nDE 17 DE JUNIO DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-17", "doble_articulado": false, "id_norma": "162403", "numero_fuente": "32281", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-09-26", "vigencias": [{"desde": "1985-09-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-09-26", "fin