{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6230723}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 146 de fecha 13 de Febrero de 1986, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones, de la Regi&#xF3;n Metropolitana, se autoriza a don Guillermo Humberto Jara Llanos, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6230724}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, Febrero 18 de 1986.- Ramiro Camero Weir, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana, subrogante. </div></div>", "i": 6230725}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "146 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-146 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-02-18", "doble_articulado": false, "id_norma": "155001", "numero_fuente": "32618", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-11-10", "vigencias": [{"desde": "1986-11-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-11-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-11-10", "fin_vigencia": "", "tipo_version":