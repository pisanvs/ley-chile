{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10302123}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;1.500, de 30 de diciembre 2021, de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n parcial, conforme art&#xED;culo 51 Ley 16.391, de inmueble denominado Fdo. La Granja El Culenar Maule, Rol Aval&#xFA;o N&#xBA; 167-17, Comuna de Maule, superficie 356,53 m2, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Reillan Canessa Aldo &#xC1;ngel y otros. Comisi&#xF3;n integrada por peritos Patricio Ulises Dur&#xE1;n Marcos, Arquitecto; Rodrigo Antonio Silva Lazo, Constructor Civil y Pedro Pablo Cruz Weston, Arquitecto, seg&#xFA;n informe de fecha 14 diciembre de 2020, tas&#xF3; lote en $6.417.540.-, se pagar&#xE1; de contado indemnizaci&#xF3;n provisional debidamente reajustada conforme art&#xED;culo 5 DL 2.186, siendo su valor la suma de $6.834.680.- </div></div>", "i": 10302124}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Claudio Daneck Mu&#xF1;oz, Director (S) Serviu Regi&#xF3;n del Maule.</div><br></div>", "i": 10302125}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1500 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1500 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2069800", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-12-30", "doble_articulado": false, "id_norma": "1171411", "numero_fuente": "43153", "tipo_versi