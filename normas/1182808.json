{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 4.316 EXENTA, DE 3 DE OCTUBRE DE 2022</div></div>", "i": 10372093}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 4.316, de 3 de octubre de 2022, del Ministerio de Transportes y Telecomunicaciones, se establece Per&#xED;metro de Exclusi&#xF3;n de <a href=\"https://www.leychile.cl/Navegar?idNorma=30078&amp;idParte=&amp;idVersion=\">ley N&#xB0; 18.696</a>, en &#xE1;rea geogr&#xE1;fica que indica, para servicios de taxi b&#xE1;sico, taxi ejecutivo y de turismo, aprueba condiciones de operaci&#xF3;n y utilizaci&#xF3;n de v&#xED;as y otras exigencias. Dicha resoluci&#xF3;n ser&#xE1; publicada &#xED;ntegramente en el sitio www.mtt.gob.cl.- </div><br></div>", "i": 10372094}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Carlos Mu&#xF1;oz Abogabir, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\"> </div><br></div>", "i": 10372095}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4316 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4316 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 4.316 EXENTA, DE 3 DE OCTUBRE DE 2022", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2201894", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-10-03", "doble_articulado": false, "id_norma": "1182808", "numero_fuente": "43376", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-10-14", "vigencias": [{"desde": "2022-10-14", "hasta": "", "tipo_version": "3", "ti