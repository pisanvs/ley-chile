{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8309771}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 307 de 06 de Abril de 1992 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a PESQUERA PETERSEO S.A., R.U.T.</div><div class=\"p\">No. 79.978.070-4, domiciliada en la ciudad de Santiago para continuar desarrollando las actividades pesqueras que por resoluci&#xF3;n No. 1.448 de 1990, de esta Subsecretar&#xED;a, ten&#xED;a autorizadas su antecesora legal, Pesquera Peterseo Limitada.-</div><br></div>", "i": 8309772}, {"t": "<div><div class=\"p\">Andr&#xE9;s Couve Rioseco. Subsecretario de Pesca. </div></div>", "i": 8309773}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "307", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-307"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1992-04-06", "fecha_derogacion": "1996-05-16", "doble_articulado": false, "id_norma": "79326", "numero_fuente": "34259", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1992-05-06", "vigencias": [{"desde": "1996-05-16", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1992-05-06", "hasta": "1996-05-15", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1996-05-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-05-06", "fin_vigencia": "1996-05-15", "tipo_version": "0"}, {"inicio_vigencia": "1996-05-16", "fin_