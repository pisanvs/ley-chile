{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6035616}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP N&#xBA; 287, de 31 de marzo de 1997, se expropiaron los lotes de terreno N&#xBA;s. 2, Entrega a Estero Huencheco; 1, Canal Pedregal y 1, Canal Pedregal-Ramal N&#xBA; 1, superficies 3.018, 1.344 y 600 m2., Roles de aval&#xFA;o 591-13 y 695-44, comuna de Yungay, para la obra Proyecto Laja-Diguill&#xED;n, Area de Riego Yungay y se acord&#xF3; precio de la indemnizaci&#xF3;n con sus propietarios, Olga Irene Ruiz Ram&#xED;rez y Eduardo Erices Fritz y otros, ascendentes a las cantidades de $1.993.053 y $488.414, respectivamente.-</div><br></div>", "i": 6035617}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6035618}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "287", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-287"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "INDEMNIZACION", "YUNGAY", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-31", "doble_articulado": false, "id_norma": "71168", "numero_fuente": "45755", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-02", "vigencias": [{"desde": "1997-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CA