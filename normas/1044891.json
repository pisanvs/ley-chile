{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9305737}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA;40.364 de 15 de septiembre de 2012, se public&#xF3; extracto de notificaci&#xF3;n del <a href=\"https://www.leychile.cl/Navegar?idNorma=1043786&amp;idParte=&amp;idVersion=\">Decreto exento MOP N&#xBA;1593</a>, con el error que se salva a continuaci&#xF3;n: II Cuerpo, p&#xE1;gina treinta y nueve, primera columna, donde dice &quot;MORENO VELASCO MARTA DE LA PAZ&quot; debe decir &quot;MORENO VELASCO MARIA DE LA PAZ&quot;. </div><br></div>", "i": 9305738, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9305739}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "Aviso-S/N"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN FECHA DE PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1044891", "numero_fuente": "40386", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-10-16", "vigencias": [{"desde": "2012-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-10-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-10-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "16291", "fecha_ingreso": "2012-10-16", "fecha_version": "2012-10-16", "fecha_actu