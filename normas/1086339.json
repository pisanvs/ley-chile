{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">SE APRUEBA TEXTO DENOMINADO &quot;PROCEDIMIENTO DE SOLICITUD, CONCESI&#xD3;N Y PAGO APORTE &#xDA;NICO REPARATORIO DE LA LEY N&#xBA; 20.874&quot;</div></div>", "i": 9664934}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 694, de 23 de diciembre de 2015, se aprueba el texto denominado &quot;Procedimiento de Solicitud, Concesi&#xF3;n y Pago Aporte &#xDA;nico Reparatorio de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1083194&amp;idParte=0&amp;idVersion=\">Ley N&#xBA; 20.874</a>&quot;, del Instituto de Previsi&#xF3;n Social, cuyo objetivo es entregar el procedimiento interno en relaci&#xF3;n con la administraci&#xF3;n del beneficio, a todas aquellas personas que cumplan con los requisitos establecidos por la ley.</div></div>", "i": 9664935}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 5 de enero de 2016.- Patricio Coronado Rojo, Director Nacional.</div></div>", "i": 9664936}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "694 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-694 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "INSTITUTO DE PREVISIÓN SOCIAL"], "titulo_norma": "SE APRUEBA TEXTO DENOMINADO \"PROCEDIMIENTO DE SOLICITUD, CONCESIÓN Y PAGO APORTE ÚNICO REPARATORIO DE LA LEY Nº 20.874\"", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 985283; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-12-23", "doble_articulado": false, "id_norma": "1086339", "numero_fuente": "41354", "tipo_version": "3", "tipo_version_s": "Única", "fecha_