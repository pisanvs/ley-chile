{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6501263}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.681, de 21 de septiembre de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a RICARDO ANGUIANO Y COMPA&#xD1;IA LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Phillipi N&#xBA; 325, Valpara&#xED;so, V Regi&#xF3;n, donde podr&#xE1; procesar, en las l&#xED;neas de elaboraci&#xF3;n de Cocido, fresco enfriado, fresco refrigerado y congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6501264}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de septiembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6501265}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2681 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2681 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-09-21", "fecha_derogacion": "2008-03-12", "doble_articulado": false, "id_norma": "231460", "numero_fuente": "37988", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-10-18", "vigencias": [{"desde": "2008-03-12", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-10-18", "hasta": "2008-03-11", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2008-03-12", "fin_vigencia": ""}, "vig