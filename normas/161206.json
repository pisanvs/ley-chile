{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6251401}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 32 de fecha 17 de Julio de 1985 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones XI Regi&#xF3;n, se autoriza al Sr. Julio Garrido B. para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6251402}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Coyhaique, 17 de Julio de 1985.- Eliecer Aedo Rivera, Secretario Regional Ministerial de Transportes y Telecomunicaciones XI Regi&#xF3;n.</div><br></div>", "i": 6251403}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "32", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-32"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XI REGIÓN DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-07-17", "doble_articulado": false, "id_norma": "161206", "numero_fuente": "32233", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-07-27", "vigencias": [{"desde": "1985-07-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-07-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-07-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por