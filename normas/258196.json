{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 2.332 EXENTA, DE 2006 </div></div>", "i": 6600900}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.332 de fecha 20 de diciembre del a&#xF1;o 2006, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriz&#xF3; complementariamente a la empresa de origen peruano Expreso Internacional Orme&#xF1;o S.A., para efectuar servicio internacional de transporte terrestre de pasajeros entre Lima (Per&#xFA;) y Buenos Aires (Argentina), con Tres (3) Frecuencias Semanales de ida y vuelta, utilizando los pasos fronterizos de Concordia, Jama (como alternativa los pasos fronterizos de Sico y/o Socompa).</div><br></div>", "i": 6600901}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Danilo N&#xFA;&#xF1;ez Izquierdo, Subsecretario de Transportes.</div><br></div>", "i": 6600902}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2332 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2332 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 2.332 EXENTA, DE 2006", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-12-20", "doble_articulado": false, "id_norma": "258196", "numero_fuente": "38683", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-02-07", "vigencias": [{"desde": "2007-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "