{"html": [{"t": "<div><br><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD FERIAS CASTILLO LIMITADA </div></div>", "i": 6140202}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional del SII, por resoluci&#xF3;n DRE 09.00 N&#xBA; Ex. 488, de fecha 12 de noviembre de 1998, otorga, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, a Sociedad Ferias Castillo Limitada, Rut N&#xBA; 77.213.740-0, la calidad de agente retenedor del Impuesto al Valor Agregado del cambio de sujeto en las operaciones de ganado vivo, estalecido en la resoluci&#xF3;n N&#xBA; Ex. 2.379/98 de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del d&#xED;a 24/04/98, modificada por resoluci&#xF3;n N&#xBA; Ex. 3.785 de 25/06/98, publicada en el Diario Oficial del 30/06/98.</div><br></div>", "i": 6140203}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Ren&#xE9; Cornejo C&#xE1;ceres, Director Regional. </div></div>", "i": 6140204}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "488 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-488 EXENTA"}, {"tipo": "3", "numero": "DRE-09-00-488 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-09-00-488 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD FERIAS CASTILLO LIMITADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "SOCIEDAD FERIAS CASTILLO LIMITADA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-12", "doble_articulado": false, "id_norma": "12