{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 334 EXENTA, DE 2011</div></div>", "i": 9136969}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 334, de 25 de febrero de 2011, modificada por la resoluci&#xF3;n N&#xBA; 597, de 30 de marzo 2011, ambas de este Instituto, se cre&#xF3; el Departamento Agencia Nacional de Medicamentos, determina su estructura interna y delega facultades y establece orden de subrogaci&#xF3;n que indica, atendido lo dispuesto en el art&#xED;culo 64&#xBA; del decreto con fuerza de ley N&#xBA; 1, de 2005, del Ministerio de Salud, cuyo texto refundido se encuentra en la resoluci&#xF3;n extractada.- </div></div>", "i": 9136970}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mar&#xED;a Teresa Valenzuela Bravo, Directora Instituto de Salud P&#xFA;blica de Chile.</div></div>", "i": 9136971}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "334 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-334 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "SUBSECRETARÍA DE SALUD PÚBLICA", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 334 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-02-25", "doble_articulado": false, "id_norma": "1025039", "numero_fuente": "39950", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-05-03", "vigencias": [{"desde": "2011-05-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-05-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-05-03",