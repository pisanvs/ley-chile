{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DEROGA LEY N&#xB0; 17.454 Teniendo presente que el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; P r o y e c t o d e l e y:</div><br></div>", "i": 8890589}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Der&#xF3;gase la Ley N&#xB0; 17.454, publicada en el Diario Oficial de 28 de julio de 1971.&quot;. </div></div>", "i": 8890590, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 24 de enero de 1996.- EDUARDO FREI RUIZ-TAGLE, Presidente de la Rep&#xFA;blica.- Carlos Figueroa Serrano, Ministro del Interior.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud., para su conocimiento.- Saluda a Ud., Belisario Velasco Baraona, Subsecretario del Interior.</div><br></div>", "i": 8890591}], "proyectos": [{"categoria": "Proyecto original", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=1716-06", "informacion": "Deroga la ley Nº 17454, y elimina la denominación plaza Yugoslavia a terreno de Punta Arenas", "nroBoletin": "1716-06"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "19444", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-19444"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DEROGA LEY N° 17.454", "fuente": "Diario Oficial", "resumenes": [], "materias": ["Plaza Yugoeslavia en Punta Arenas", "Ley no. 19.444"], "terminos_libres": ["PLAZA YUGOESLAVIA", "PUNTA ARENAS", "DEROGACION", "DECIMOSEGUNDA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "d