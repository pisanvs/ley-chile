{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ENTIENDE AUTORIZACION MINISTROS DE ESTADO N&#xFA;m. 42.- Santiago, 16 de Junio de 1932.- Con el objeto de facilitar la tramitacion del despacho de las diversas Secretar&#xED;as de Estado, la Junta de Gobierno ha acordado y</div><div class=\"p\">&nbsp; &nbsp; Decreta:</div><br></div>", "i": 8255710}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Autor&#xED;zase a los Ministros del Despacho para firmar con la f&#xF3;rmula: &quot;Por orden de la Junta de Gobierno&quot;, todos los decretos sobre las materias a que se refiere el decreto-ley N.o 455, de 16 de Julio de 1925, a excepci&#xF3;n de aquellos que signifiquen un gasto con cargo al Presupuesto de la Naci&#xF3;n.</div><br></div>", "i": 8255711}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese razon, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de Leyes y Decretos del Gobierno.- ARTURO PUGA.- Eugenio Matte.- Rolando Merino Reyes.- A. Ruiz M. </div></div>", "i": 8255712}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "42", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-42"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "ENTIENDE AUTORIZACION MINISTROS DE ESTADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTE REPUBLICA", "RESOLUCIONES", "DICTACION", "AUTORIZACION", "MINISTROS", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-06-16", "doble_articulado": false, "id_norma": "5691", "numero_fuente": "16305", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-06-22", "vigencias": [{"desde": "1932-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenc