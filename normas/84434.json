{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 02, DE 1990 </div></div>", "i": 6067832}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 02 de 04 de Enero de 1990 se ha aprobado, al Liceo Alem&#xE1;n Del Verbo Divino, de Los Angeles, un plan especial de estudio para la Educaci&#xF3;n Media Human&#xED;stico Cient&#xED;fica, que se aplicar&#xE1; en 1&#xB0; y 3&#xB0; a&#xF1;o en 1990 y desde 1&#xB0; hasta 4&#xB0; a&#xF1;o inclusive, en 1991.</div><br></div>", "i": 6067833}, {"t": "<div><div class=\"p\">Santiago, 16 de Enero de 1990.-</div><div class=\"p\">Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6067834}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 02, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-04", "doble_articulado": false, "id_norma": "84434", "numero_fuente": "33577", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-01-23", "vigencias": [{"desde": "1990-01-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-01-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-01-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "ALV", "fecha_ingreso": "1998-01-13", "fecha_version": "1990-01-23", "fecha_actualizacion_texto": "1