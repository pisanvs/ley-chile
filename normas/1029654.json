{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9183896}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (exento) N&#xBA;1570 de fecha 29 de julio de 2011, se expropi&#xF3; el lote de terreno N&#xBA;6, superficie 193 m2, rol N&#xBA;942-14, comuna de Los &#xC1;ngeles para la obra &quot;Reposici&#xF3;n Ex Ruta 5, Sector Pasada Saldo del Laja y Pasada por Los &#xC1;ngeles&quot;, Regi&#xF3;n del B&#xED;o B&#xED;o y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario PRODALAM S.A., ascendente a la cantidad de $18.377.758.- </div></div>", "i": 9183897}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9183898}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1570 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1570 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-07-29", "doble_articulado": false, "id_norma": "1029654", "numero_fuente": "40062", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-09-15", "vigencias": [{"desde": "2011-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "2932", "fecha_ingreso": "2011-09-15", "fecha_version": "2011-09-15", "fecha_actualizacion_texto": "2011-09-15", "tipo_tratado": ""}, "alertas"