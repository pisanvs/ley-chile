{"html": [{"t": "<div><div class=\"p\">RECTIFICA RESOLUCION N&#xBA;159 EXENTA, DE 2001</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 163 exenta.- Santiago, 28 de mayo de 2001.- Visto: Lo dispuesto en la resoluci&#xF3;n exenta N&#xBA;159/2001 de 22 de mayo de 2001, publicada en el Diario Oficial de 24 de mayo de 2001, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana.</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br></div>", "i": 6336453}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sustit&#xFA;yase el n&#xFA;mero 2 de la parte resolutiva de la resoluci&#xF3;n exenta N&#xBA;159 citada en el Visto, por el siguiente:</div><div class=\"p\">&nbsp; &nbsp;  &quot;Estas v&#xED;as exclusivas funcionar&#xE1;n en ambos sentidos entre las 7:30 AM y 10:00 AM (punta ma&#xF1;ana) y las 18:00 PM y 20:30 PM (punta tarde)&quot;.</div><br></div>", "i": 6336454}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese y publ&#xED;quese.- Guillermo D&#xED;az Silva, Secretario Regional Ministerial, Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6336455}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "163 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-163 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "RECTIFICA RESOLUCION Nº159 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-28", "doble_articulado": false, "id_norma": "185740", "numero_fuente": "36975", "t