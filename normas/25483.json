{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA EL D. F. L. N.o 178, DE 1931 (CODIGO DEL TRABAJO)</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n del siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5963591}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1.o Supr&#xED;mese la palabra &quot;serenos&quot;, que figura en el art&#xED;culo 25 del decreto con fuerza de ley n&#xFA;mero 178, de 13 de Mayo de 1931.</div><br></div>", "i": 5963592}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2.o Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial&quot;.</div><br></div>", "i": 5963593}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, dos de Octubre de mil novecientos cuarenta y dos.- JUAN ANTONIO RIOS M.- Leonidas Leyton L. </div></div>", "i": 5963594}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "7296", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-7296"}], "organismos": ["MINISTERIO DEL TRABAJO"], "titulo_norma": "MODIFICA EL D. F. L. N.o 178, DE 1931 (CODIGO DEL\nTRABAJO)", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CODIGO", "TRABAJO", "MODIFICACION", "DISPOSICIONES", "JORNADA TRABAJO", "SERENOS", "EXCLUSION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1942-10-02", "doble_articulado": false, "id_norma": "25483", "numero_fuente": "19382", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1942-10-14", "vigencias": [{"desde