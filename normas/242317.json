{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 890 EXENTO, DE 2005 </div></div>", "i": 7323307}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 890, de fecha 5 de julio de 2005, del Ministerio de Educaci&#xF3;n, se aprueban las modificaciones introducidas al plan y programas de estudios del Centro de Formaci&#xF3;n T&#xE9;cnica Pukar&#xE1;, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar del a&#xF1;o 2005, en la Sede Central de Arica, con la siguiente denominaci&#xF3;n: Carrera: Programaci&#xF3;n de Computadores, cambia por: Carrera: T&#xE9;cnico Superior en Inform&#xE1;tica</div><br><div class=\"p\">T&#xED;tulo: T&#xE9;cnico de Nivel Superior en Inform&#xE1;tica (R. Ex. N&#xBA; 1086 de 16.05.85) </div></div>", "i": 7323308}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de septiembre de 2005.- Pedro Montt Leiva, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7323309}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "890 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-890 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 890 EXENTO, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-07-05", "doble_articulado": false, "id_norma": "242317", "numero_fuente": "38269", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-09-23", "vigencias": [{"desde": "2005-09-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-09-23", "fin_vigencia": ""}, "vigencias_version_norma"