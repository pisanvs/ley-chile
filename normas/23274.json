{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Dispone que el monumento al Jeneral don Juan Gregorio Las Heras se erija en la ciudad de Talca Lei n&#xFA;m. 2,366.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275220}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- El monumento al Jeneral don Juan Gregorio Las Heras que dispone la lei n&#xFA;m. 2,335 de 25 de Julio de 1910, se erijir&#xE1; en la ciudad de Talca. </div></div>", "i": 8275221}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 29 de Agosto de 1910.- El&#xED;as Fern&#xE1;ndez Albano.- Luis Izquierdo.</div><br></div>", "i": 8275222}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2366", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2366"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Dispone que el monumento al Jeneral don Juan;Gregorio Las Heras se erija en la ciudad de Talca", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUAN GREGORIO LAS HERAS", "MONUMENTO", "TALCA", "ERECCION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-08-29", "doble_articulado": false, "id_norma": "23274", "numero_fuente": "9787", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-09-06", "vigencias": [{"desde": "1910-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "191