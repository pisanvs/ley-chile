{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N</div></div>", "i": 9991893}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  En virtud de lo dispuesto en la resoluci&#xF3;n N&#xBA; 5.170, de 22-11-2000, del Director del Servicio de Impuestos Internos, el suscrito ha dictado la resoluci&#xF3;n exenta N&#xBA; 240, de 16 de enero de 2019, por la cual deroga la <a href=\"https://www.leychile.cl/Navegar?idNorma=1006304&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 442, de fecha 7 de septiembre de 2009</a>, y <a href=\"https://www.leychile.cl/Navegar?idNorma=1078656&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.894, de fecha 12 de junio de 2015</a>, de la IX Direcci&#xF3;n Regional Temuco del Servicio de Impuestos Internos, y ha delegado en los Jefes de Grupos indicados en lo resolutivo de la facultad de citar a los contribuyentes conforme al art&#xED;culo 63, inciso 2, del C&#xF3;digo Tributario, y conceder pr&#xF3;rrogas que les soliciten hasta por un mes dentro del plazo referido en el inciso citado.- </div><br><br></div>", "i": 9991894, "v": ["MODIFICACION"]}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Claudio Ambiado Araya, Director Regional. </div></div>", "i": 9991895}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "240 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-240 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1534209", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-01-16", "doble_articulado": false,