{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 47, DE 2008 </div></div>", "i": 7370452}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 47, de 5 de febrero de 2008, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n del Maule, se autoriz&#xF3; la ampliaci&#xF3;n de capacidad, a tres (3) la cantidad de l&#xED;neas de revisi&#xF3;n tipo L, y a cuatro (4) la cantidad total de l&#xED;neas de la Planta de Revisi&#xF3;n T&#xE9;cnica AB0708, comuna de Talca, de la Concesionaria &quot;Revisiones Maule Ltda&quot;.</div><br></div>", "i": 7370453}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Pedro Orozco L&#xF3;pez, Secretario Regional Ministerial de Transportes y Telecomunicaciones (S) Regi&#xF3;n del Maule.</div><br></div>", "i": 7370454}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "47", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-47"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 47, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-02-05", "doble_articulado": false, "id_norma": "271374", "numero_fuente": "39067", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-05-22", "vigencias": [{"desde": "2008-05-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-05-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-05-22", "fin_vigencia": "", "tipo_vers