{"html": [{"t": "<div><div class=\"p\">PRORROGA EL PLAZO PARA PAGAR LOS IMPUESTOS QUE SE&#xD1;ALA </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 6,099.- Santiago, 12 de Abril de 1961.- Visto: el oficio N.o 2,052, de fecha 14 de Abril del a&#xF1;o en curso, de la Tesorer&#xED;a General de la Rep&#xFA;blica, y la facultad que me concede el inciso 2.o del art&#xED;culo 36.o del C&#xF3;digo Tributario,</div><br><div class=\"p\">&nbsp; &nbsp;  He acordado, y</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 7350275}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Prorr&#xF3;gase hasta el 29 de Abril en curso el plazo para pagar el impuesto a la compraventa, cifra de negocios, renta de 5a. categor&#xED;a y compraventa de agricultores, para toda la Rep&#xFA;blica.</div><br></div>", "i": 7350276}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- J. ALESSANDRI R.- Eduardo Figueroa G.</div><br></div>", "i": 7350277}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "6099", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-6099"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "PRORROGA EL PLAZO PARA PAGAR LOS IMPUESTOS QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1961-04-12", "doble_articulado": false, "id_norma": "263594", "numero_fuente": "24940", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1961-05-09", "vigencias": [{"desde": "1961-05-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1961-05-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vi