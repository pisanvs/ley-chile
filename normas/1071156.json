{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9535192}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.191, de 25 de&nbsp; noviembre de 2014, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la <a href=\"https://www.leychile.cl/Navegar?idNorma=226814&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.716, de 2004</a>, s&#xF3;lo en cuanto autoriz&#xF3; a PESCA CHILE S.A., para realizar actividades pesqueras extractivas con la nave &quot;Cabo de Hornos&quot;, respecto de los recursos hidrobiol&#xF3;gicos Merluza del sur y Congrio dorado, en el &#xE1;rea mar&#xED;tima comprendida entre el paralelo 44&#xBA;30&apos; L.S. y el paralelo 47&#xBA; L.S., en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum citado en visto de la resoluci&#xF3;n extractada.</div></div>", "i": 9535193}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de noviembre de 2014.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9535194}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3191 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3191 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2014-11-25", "fecha_derogacion": "2015-01-28", "doble_articulado": false, "id_norma": "1071156", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2014-12-02", "vigencias": [{"desde"