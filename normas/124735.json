{"html": [{"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 513.- Santiago, 18 de Enero de 1946.- Vistos estos antecedentes; lo dispuesto en el decreto reglamentario n&#xFA;mero 2,736, de 31 de Octubre de 1925, y con&nbsp; lo informado por el Consejo de Defensa Fiscal, </div><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 6131564}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1.&#xBA; Conc&#xE9;dese personalidad jur&#xED;dica a la corporaci&#xF3;n denominada &quot;Misi&#xF3;n Wesleyana Nacional&quot;, con domicilio en la ciudad de Lota;</div><div class=\"p\">&nbsp; &nbsp;  2.&#xBA; Apru&#xE9;banse los estatutos por los cuales ha de regirse dicha corporaci&#xF3;n, en los t&#xE9;rminos de que da testimonio la escritura p&#xFA;blica adjunta, otorgada ante el notario p&#xFA;blico de Coronel, don Rosendo Saavedra Sandoval, con fecha 27 de Agosto de 1945.</div><br></div>", "i": 6131565}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- A. DUHALDE V.- Enrique Arriagada Sald&#xED;as.</div><br></div>", "i": 6131566}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "513", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-513"}], "organismos": ["MINISTERIO DE JUSTICIA", "SUBSECRETARIA DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1946-01-18", "doble_articulado": false, "id_norma": "124735", "numero_fuente": "20373", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1946-02-06", "vigencias": [{"desde": "1946-02-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inici