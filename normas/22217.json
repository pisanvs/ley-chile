{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MUNICIPALIDAD DE TALCA Lei n&#xFA;m. 367.- Santiago, a 31 de Julio de 1896.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273954}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese a la Municipalidad de Talca un auxilio estraordinario de veintitres mil pesos, que invertir&#xE1; en el mantenimiento de la polic&#xED;a de seguridad durante los meses de Junio, Julio i Agosto del presente a&#xF1;o.</div><br><br></div>", "i": 8273955}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- O. Renjifo.</div><br></div>", "i": 8273956}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "367", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-367"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MUNICIPALIDAD DE TALCA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDAD TALCA", "POLICIA SEGURIDAD", "MANTENIMIENTO", "FONDOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-07-31", "doble_articulado": false, "id_norma": "22217", "numero_fuente": "5470", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1896-07-31", "vigencias": [{"desde": "1896-07-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1896-07-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1896-07-31", "fin_vigencia": "", "tipo_version": "3"