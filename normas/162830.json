{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.615, DE 1985 </div></div>", "i": 6256580}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.615, de fecha 28 de Junio de 1985, del Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante, se modific&#xF3; en su art. 2&#xB0; la resoluci&#xF3;n exenta de Educaci&#xF3;n No. 711, de 1983, correspondiente al Centro de Formaci&#xF3;n T&#xE9;cnica &quot;Instituto de Massachusetts Ltda.&quot;, sobre normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n a partir del a&#xF1;o 1985.</div><div class=\"p\">&nbsp; &nbsp;  Para optar al t&#xED;tulo correspondiente, los alumnos deber&#xE1;n aprobar todas las asignaturas del plan de estudio y cumplir con las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n aprobadas por resoluci&#xF3;n exenta No. 1.615, de 1985.-</div><br></div>", "i": 6256581}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Marta Stefanowsky Bandyra, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante.</div><br></div>", "i": 6256582}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1615 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1615 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_derogacion": "2024-01-31", "doble_articulado": false, "id_norma": "162830", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1985-07-31", "vigencias": [{"desde": "2024-01-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1985-07-31", "hasta": "2024-01-30", "