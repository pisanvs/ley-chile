{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA </div></div>", "i": 6582437}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n Ministerial T.R. N&#xBA; 50, de 14 de</div><div class=\"p\">julio de 2006, se cancel&#xF3; la personalidad jur&#xED;dica de la</div><div class=\"p\">&quot;Asociaci&#xF3;n Gremial de Due&#xF1;os de Camiones de Quilicura&quot;</div><div class=\"p\">inscrita bajo el N&#xBA; 3.331, por haberse configurado la</div><div class=\"p\">causal contemplada en la letra a), n&#xFA;mero 2, del</div><div class=\"p\">art&#xED;culo 18 del decreto ley N&#xBA; 2.757, de 1979. </div></div>", "i": 6582438}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Javiera Estrada Quezada, Jefe Unidad Asociaciones Gremiales y Martilleros.</div><br></div>", "i": 6582439}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "50", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-50"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-14", "doble_articulado": false, "id_norma": "253143", "numero_fuente": "38563", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-09-12", "vigencias": [{"desde": "2006-09-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-09-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-09-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendien