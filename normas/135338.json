{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,744.- Santiago, 21 de agosto de 1905.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165107}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados por el teniente-coronel de Ej&#xE9;rcito don Manuel Chacon, conc&#xE9;dese por gracia, a su viuda, do&#xF1;a Natalia Alarcon, derecho de disfrutar de la pension de montep&#xED;o militar que corresponde al empleo de coronel, en vez de la de teniente-coronel, que actualmente percibe&quot;.</div><br></div>", "i": 6165108}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.-</div><div class=\"p\">L. Uribe O.</div><br></div>", "i": 6165109}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1744", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1744"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-08-21", "doble_articulado": false, "id_norma": "135338", "numero_fuente": "8302", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-08-26", "vigencias": [{"desde": "1905-08-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1905-08-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1905-08-26", "fin_vigencia": "", "tipo_version