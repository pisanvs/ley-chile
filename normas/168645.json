{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6275249}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 619 de 29 de febrero de 2000, se expropiaron los lotes de terreno N&#xBA;s. 19 y 22, superficies 74 y 230 m&#xB2;, roles de aval&#xFA;o 31-477 y 31-465, comuna Requ&#xED;noa, para la obra Camino Ruta H-455, sector Sta. Amalia Pimpinela y se acord&#xF3; precio de indemnizaci&#xF3;n con su propietario Leonel Cristi&#xE1;n Silva Pich&#xFA;n y otros y Aliro Fernando Berr&#xED;os Pich&#xFA;n, ascendente a las cantidades de $622.193 el lote N&#xBA; 19 y $630.135 del lote N&#xBA; 22.</div><br></div>", "i": 6275250}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6275251}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "619", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-619"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-29", "doble_articulado": false, "id_norma": "168645", "numero_fuente": "36663", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-15", "vigencias": [{"desde": "2000-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-05-15", "fecha_version": "2000-05-15", "fecha_actualizacion_texto": "2000-05-15", "tipo