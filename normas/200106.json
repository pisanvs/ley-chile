{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA N&#xB0; 0-378, DE 1989 </div></div>", "i": 6387840}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta N&#xB0; 0-378 de fecha 16 de Marzo de 1989 el Servicio Electoral dispuso publicar el siguiente extracto de la solicitud de inscripci&#xF3;n en las Regiones VI, XI y XII, del Partido &quot;Los Verdes&quot;. Andr&#xE9;s Koryzma Z. y Mario Aguilar A. en representaci&#xF3;n del Partido &quot;Los Verdes&quot; solicitan la inscripci&#xF3;n del Partido en las Regiones VI, XI y XII, conforme al art&#xED;culo 17 de la Ley N&#xB0; 18.603. Declaran presentar en la Regi&#xF3;n VI, 2.264 afiliaciones, en la Regi&#xF3;n XI, 351 afiliaciones y en la Regi&#xF3;n XII, 465 afiliaciones. </div></div>", "i": 6387841}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago 16 de Marzo de 1989.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6387842}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "378", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-378"}, {"tipo": "3", "numero": "O-378", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-378"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N° 0-378, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-03-16", "doble_articulado": false, "id_norma": "200106", "numero_fuente": "33330", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-03-23", "vigencias": [{"desde": "1989-03-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-03-23"