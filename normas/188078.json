{"html": [{"t": "<div><div class=\"p\">AUTORIZA A LA SOCIEDAD &quot;E. SCHNEIDER TRADING CHILE LTDA.&quot; PARA AMPLIAR SUS ACTIVIDADES PESQUERAS </div><br></div>", "i": 6344308}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 209, del 6 de Agosto de 1982, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a la sociedad &quot;E. Schneider Trading Chile Ltda.&quot;, domiciliada en Santiago, para elaborar loco y caracol negro congelados, en el local de Frigor&#xED;fico La Granja, ubicado en Santa Rosa 9233, Santiago. Asimismo se deja constancia, que la resoluci&#xF3;n 160, de 1982, de la Subsecretar&#xED;a de Pesca, ha quedado sin efecto.</div><br><br></div>", "i": 6344309}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 6 de Agosto de 1982.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6344310}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "209", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-209"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A LA SOCIEDAD \"E. SCHNEIDER TRADING CHILE LTDA.\" PARA AMPLIAR SUS ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1982-08-06", "fecha_derogacion": "1989-05-04", "doble_articulado": false, "id_norma": "188078", "numero_fuente": "31340", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1982-08-12", "vigencias": [{"desde": "1989-05-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1982-08-12