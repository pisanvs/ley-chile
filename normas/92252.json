{"html": [{"t": "<div><div class=\"p\">DERECHO DE APROVECHAMIENTO DE AGUAS EN COMUNA DE LOS ANGELES </div><br></div>", "i": 6091017}, {"t": "<div><div class=\"p\">Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 497 de 07.04.89, conforme art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a las parcelas N&#xB0;s. 1 a la 14, sitios N&#xB0;s. 1 al 8 del proyecto de Parcelaci&#xF3;n &quot;Estrella de Rarinco&quot;, de la comuna de Los Angeles, VIII Regi&#xF3;n, formado por el predio &quot;Loteo Hijuela No. 6 del Plano de Divisi&#xF3;n del Fundo San Jos&#xE9; de Rarinco&quot;.</div><div class=\"p\">Los derechos de agua se extraen del Canal del Laja. Publicaci&#xF3;n hecha conforme art. 13 ley No. 18.377. </div></div>", "i": 6091018}, {"t": "<div><div class=\"p\">Director Nacional.</div><br></div>", "i": 6091019}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "497 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-497 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DERECHO DE APROVECHAMIENTO DE AGUAS EN COMUNA DE LOS ANGELES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-04-07", "doble_articulado": false, "id_norma": "92252", "numero_fuente": "33348", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-04-15", "vigencias": [{"desde": "1989-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-04