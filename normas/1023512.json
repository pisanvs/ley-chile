{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9118350}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 556 de 1 de marzo de 2011 de esta Subsecretar&#xED;a, rech&#xE1;zanse las solicitudes de modificaci&#xF3;n de concesi&#xF3;n de acuicultura n&#xFA;meros 206111205, 206111206, 206111221, 207111001, 207111010, 207111080, 207111252 y 208111112, se&#xF1;aladas en la resoluci&#xF3;n extractada, y publicada &#xED;ntegramente en la p&#xE1;gina web www.subpesca.cl, en virtud del art&#xED;culo 78 de la Ley General de Pesca y Acuicultura y art&#xED;culo 14 del D.S. N&#xBA; 290 de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div></div>", "i": 9118351}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de marzo de 2011.- Pablo Galilea Carrillo, Subecretario de Pesca.</div></div>", "i": 9118352}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "556 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-556 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-03-01", "doble_articulado": false, "id_norma": "1023512", "numero_fuente": "39903", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-03-07", "vigencias": [{"desde": "2011-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-03-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-03-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pend