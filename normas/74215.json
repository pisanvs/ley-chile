{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8304555}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 972, de 4 de julio de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de las Resoluciones N&#xBA; 1.043, de 1986 y N&#xBA; 1.170, de 1992, ambas de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autorizaron a Sociedad Comercial e Industrial Giordano Ltda. y Compa&#xF1;&#xED;a en Comandita por Acciones o Pesquera Isluga Ltda. -hoy&nbsp; PESQUERA ISLUGA S.A.- para desarrollar actividades pesqueras extractivas con la nave &quot;Nicol&#xE1;s I&quot;, por haberse configurado la causal prevista en el art&#xED;culo 143 letra b) de de la Ley N&#xBA; 18.892 y sus modificaciones.</div><br><br></div>", "i": 8304556}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de julio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8304557}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "972", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-972"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "PESQUERA ISLUGA S.A.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-04", "doble_articulado": false, "id_norma": "74215", "numero_fuente": "35814", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-07-12", "vigencias": [{"desde": "1997-07-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio