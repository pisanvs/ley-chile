{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6552452}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.929, de 18 de noviembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a JUAN CARLOS GONZALEZ NAIN para ampliar actividades pesqueras de transformaci&#xF3;n en orden a incorporar a la planta ubicada en Arturo Prat s/n, Llau-Llao, Castro, Chilo&#xE9;, X Regi&#xF3;n, en las l&#xED;neas de proceso de Cocido, Fresco enfriado, Fresco refrigerado, Congelado, Seco salado, Ahumado, Conserva, Alga seca y Deshidratado los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2.525 de 2005, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6552453}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de noviembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6552454}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3929 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3929 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-18", "doble_articulado": false, "id_norma": "244931", "numero_fuente": "38335", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-12-13", "vigencias": [{"desde": "2005-12-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005