{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA </div></div>", "i": 8289933}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n Ministerial N&#xB0;69 de fecha 14 de Junio de 1993 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la Personalidad Jur&#xED;dica de la Asociaci&#xF3;n de Peque&#xF1;os Artesanos de Putaendo Asociaci&#xF3;n Gremial inscrita bajo el N&#xB0; 2.190 del Registro que para tal efecto lleva este Ministerio, por haberse configurado respecto de ella, la causal de cancelaci&#xF3;n contemplada en el art&#xED;culo 18 N&#xB0; 2 letra d) del D.L. N&#xB0; 2.757, de 1979.</div><br></div>", "i": 8289934}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Alvaro Briones Ram&#xED;rez, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8289935}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "69", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-69"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PERSONALIDAD JURIDICA", "ASOCIACION PEQUE OS ARTESANOS", "PUTAENDO ASOCIACION GREMIAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-06-14", "doble_articulado": false, "id_norma": "32804", "numero_fuente": "34648", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-08-23", "vigencias": [{"desde": "1993-08-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-08-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"ini