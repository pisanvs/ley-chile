{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293083}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 551, de 23 de Julio de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modificase la Resoluci&#xF3;n N&#xB0; 780, de 1992, que modific&#xF3; la Resoluci&#xF3;n N&#xB0; 262, de 1982, que autoriz&#xF3; a SALMONES ANTARTICA S.A., R.U.T. N&#xB0; 86.100.500-3, para realizar actividades de cultivo, en orden a reemplazar en el nuevo numeral 4&#xB0; letra b) de la Resoluci&#xF3;n N&#xB0; 262, de 1982, la expresi&#xF3;n &quot;Comuna de Quemchi&quot;, por &quot;Comuna de Curaco de V&#xE9;lez&quot;.</div><div class=\"p\">&nbsp; &nbsp; D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 1.068, de 1992, de esta Subsecretar&#xED;a en virtud del prescrito en la presente Resoluci&#xF3;n.</div><br></div>", "i": 8293084}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 23 de Julio de 1993 de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8293085}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "551", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-551"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "SALMONES ANTARTICA S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-07-23", "doble_articulado": false, "id_norma": "35090", "numero_fuente": "34647", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-08-21", "vigencias": [{"desde": "1993-08-21", "hasta": "", "tipo_version": "3", "tip