{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10282937}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xBA; 1.159, de 19 octubre 2021, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos relativas a Operativo de Salud M&#xF3;vil de Caja de Compensaci&#xF3;n Los H&#xE9;roes, en la ciudad de Coyhaique, y autoriz&#xF3; a Caja de Compensaci&#xF3;n Los H&#xE9;roes en la ciudad de Coyhaique para realizar siguiente intervenci&#xF3;n en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  -corte total de v&#xED;a en calle Dussen entre calle Arturo Prat y Plaza de Armas, entre las 10:00 hrs. del d&#xED;a martes 19 de octubre y las 19:00 hrs. del d&#xED;a mi&#xE9;rcoles 20 de octubre de 2021.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10282938}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &#xD3;scar del Solar Navarrete, Gobernador Regional (S), Gobierno Regional de Ays&#xE9;n.-&nbsp; Ximena Guti&#xE9;rrez Jaramillo, Asesora Jur&#xED;dica, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10282939}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1159 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1159 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2038028", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-10-19", "doble_articulado": false, "id_norma": "1168062", "numero_fuente": "43099", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-