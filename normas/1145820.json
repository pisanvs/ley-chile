{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago 15 de enero de 1887.</div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha presentado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div></div>", "i": 10133017}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Autorizase al Presidente de la Rep&#xFA;blica para que se invierta hasta cuatrocientos cincuenta mil pesos en ausiliar a las municipalidades, a fin de que puedan adoptar las medidas necesarias para combatir la epidemia del c&#xF3;lera.</div><div class=\"p\">&nbsp; &nbsp;  Esta lei empezar&#xE1; a rejir desde el d&#xED;a de su publicacion en el Diario Oficial, i la autorizacion que en ella se concede durar&#xE1; por el t&#xE9;rmino de un a&#xF1;o.</div></div>", "i": 10133018}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, ha tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  JOS&#xC9; MANUEL BALMACEDA</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; C&#xC1;RLOS ANT&#xDA;NEZ.</div></div>", "i": 10133019}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "33", "numero": "S/N", "abreviacion": "LEI", "descripcion": "Lei", "compuesto": "Lei-S/N"}], "organismos": ["MINISTERIO DE LO INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1887-01-15", "doble_articulado": false, "id_norma": "1145820", "numero_fuente": "2909", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1887-01-17", "vigencias": [{"desde": "1887-01-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1887-01-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1887-01-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2020-07-02", "fecha_version": "1887-01-17", "fecha_actualizacion_texto": "2020-07-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10133017}, {"n": "Artículo ÚNICO", "i": 10133018, "t": 6}, {"n": "Promulgación", "i": 10133019}]}