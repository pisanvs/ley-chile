{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 492 EXENTO, DE 1993 </div></div>", "i": 5944888}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 492 de fecha 23 de Septiembre de 1993 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Fundaci&#xF3;n DUOC, las adecuaciones introducidas al Plan y Programas de Estudio de la carrera de Administrador Pr&#xE1;ctico en Acuicultura, las que se insertaron en la Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xB0; 1944 de 1989. Dichas adecuaciones podr&#xE1;n aplicarse a contar de agosto de 1993.-</div><br></div>", "i": 5944889}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5944890}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "492", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-492"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 492 EXENTO, DE 1993", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "ADMINISTRADOR PRACTICO ACUICULTURA", "CENTRO FORMACION TECNICA", "FUNDACION DUOC"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1993-09-23", "fecha_derogacion": "2018-12-31", "doble_articulado": false, "id_norma": "21351", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-04-23", "vigencias": [{"desde": "2018-12-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1994-04-23", "hasta": "2018-12-30", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2018-12-31", "fin_v