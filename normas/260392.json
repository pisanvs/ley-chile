{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A COMERCIAL BIO FRUT LTDA.</div><br></div>", "i": 6608378}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/N&#xBA; Ex-3563, de fecha 11 de abril de 2007, otorga a Comercial B&#xED;o Frut Ltda., RUT. N&#xBA; 76.183.340-5, la calidad de agente retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las ventas de berries, establecido en la resoluci&#xF3;n N&#xBA; Ex-55, de 02-06-2005 de la Direcci&#xF3;n Nacional. La presente autorizaci&#xF3;n surtir&#xE1; efecto a partir del d&#xED;a primero del mes siguiente a la fecha de publicaci&#xF3;n de este extracto en el Diario Oficial y tendr&#xE1; vigencia indefinida.</div><br></div>", "i": 6608379}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Sergio Flores Guti&#xE9;rrez, Director Regional. </div></div>", "i": 6608380}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3563 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-3563 EXENTA"}, {"tipo": "3", "numero": "DRE-08-3563 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-3563 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A COMERCIAL\nBIO FRUT LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-04-11", "doble_articulado": false, "id_norma": "260392", "numero_fuente": "38747", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-04-25",