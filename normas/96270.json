{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8327181}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 172 de 30 de enero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2&#xBA; de la Resoluci&#xF3;n N&#xBA; 172, de 1982, de esta Subsecretar&#xED;a, que autoriz&#xF3; a&nbsp; PESQUERA MARBELLA S.A., (ex Ltda.), a desarrollar actividades pesqueras extractivas con la nave &quot;Costa Grande&quot;, en el sentido de actualizar las caracter&#xED;sticas n&#xE1;uticas de esta &#xFA;ltima, en los t&#xE9;rminos que se indica:</div><br><div class=\"p\">Nombre&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  &quot;Costa Grande&quot;</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2272</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp;  33,5 m.</div><div class=\"p\">T.R.G.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  241,4 t.</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; 373,9 m3</div><div class=\"p\">Arte de pesca&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Cerco.</div><br></div>", "i": 8327182}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de enero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8327183}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "172", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-172"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA MARBELLA S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita"