{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6563652}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 509, de 14 de febrero de 2006, de</div><div class=\"p\">esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA; de la</div><div class=\"p\">resoluci&#xF3;n N&#xBA; 145 de 2006, de esta Subsecretar&#xED;a, que</div><div class=\"p\">autoriz&#xF3; a la UNIVERSIDAD CATOLICA DEL NORTE, SEDE</div><div class=\"p\">COQUIMBO, para efectuar una pesca de investigaci&#xF3;n de</div><div class=\"p\">conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del</div><div class=\"p\">proyecto denominado &quot;Distribuci&#xF3;n espacio temporal de</div><div class=\"p\">las agregaciones de jurel en la IV Regi&#xF3;n, temporada</div><div class=\"p\">2006&quot;, en el sentido de incorporar a la embarcaci&#xF3;n</div><div class=\"p\">artesanal &quot;Tsunami&quot; en el listado de naves autorizadas a operar en el marco de la citada pesca de investigaci&#xF3;n. </div></div>", "i": 6563653}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de febrero de 2006.- Jessica Fuentes Olmos, Subsecretario de Pesca (S).</div><br></div>", "i": 6563654}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "509", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-509"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-02-14", "doble_articulado": false, "id_norma": "247903", "numero_fuente": "38412", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "