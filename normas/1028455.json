{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 1.344 EXENTA, DE 2011</div><br></div>", "i": 9163954}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Res. ex. N&#xBA; 1.344, de 2011 autoriza al siguiente taller para adecuar veh&#xED;culos al uso de gas licuado de petr&#xF3;leo como combustible:</div><br><br><div class=\"p\">&nbsp; Empresa&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Nombre del Taller&nbsp; &nbsp; &nbsp; &nbsp;  Direcci&#xF3;n del Taller&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Ciudad</div><div class=\"p\">&nbsp; Habilitada </div><br><div class=\"p\">&nbsp; GLP Motor Ltda.&nbsp; &nbsp; Ren&#xE9; Collilef Pailallef&nbsp;  Calle Ren&#xE9; Schneider N&#xB0; 3620&nbsp;  Valdivia</div><br><div class=\"p\">&nbsp; &nbsp;  Autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.-</div></div>", "i": 9163955}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Gloria Hutt Hesse, Subsecretaria de Transportes.</div><br></div>", "i": 9163956}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1344 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1344 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 1.344 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO, NORMA SIN FECHA DE PROMULGACIÓN."], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1028455", "numero_fuente": "40029", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-08-06", "vigencias": [{"desde": "2011-08-06", "hasta": "", "tipo_version": "3", "tipo_version_s"