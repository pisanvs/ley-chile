{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,336.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6163446}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo unico.- Conc&#xE9;dese por una sola vez una subvencion de seis mil pesos al Centro Industrial i Agr&#xED;cola de Santiago.</div><br></div>", "i": 6163447}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Esta lo, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de enero de 1900.- FEDERICO ERRAZURIZ.-</div><div class=\"p\">J.F. Valdes C.</div><br></div>", "i": 6163448}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1336", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1336"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-01-25", "doble_articulado": false, "id_norma": "134787", "numero_fuente": "6508", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-01-29", "vigencias": [{"desde": "1900-01-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-01-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1900-01-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-04-13", "fecha_version": "1900-01-29", "fecha_actualizacion_