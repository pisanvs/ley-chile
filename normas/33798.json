{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; APRUEBA REFORMA DE ESTATUTOS DE COMPA&#xD1;IA DE REASEGUROS DE VIDA SOINCE-RE </div></div>", "i": 6007965}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Certifico: Que por Resoluci&#xF3;n N&#xB0;217, de fecha 18 de Octubre de 1993, se aprob&#xF3; reforma de estatutos de la sociedad an&#xF3;nima Compa&#xF1;&#xED;a de Reaseguros de Vida Soince-Re, que consta de la escritura p&#xFA;blica de fecha 15 de Septiembre de 1993, otorgada en la Notar&#xED;a de Santiago, de don Ra&#xFA;l Iv&#xE1;n Perry Pefaur.</div><div class=\"p\">&nbsp; &nbsp; La reforma consiste en:</div><div class=\"p\">&nbsp; &nbsp; Disminuir el n&#xFA;mero de directores, tanto titulares como suplentes, de 6 a 5.</div><br></div>", "i": 6007966}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 18 de Octubre de 1993.- Rodrigo O. Costa Aranda, Secretario General.</div><br></div>", "i": 6007967}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "217", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-217"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "APRUEBA REFORMA DE ESTATUTOS DE COMPAÑIA DE\nREASEGUROS DE VIDA SOINCE-RE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REFORMA ESTATUTARIA", "ESTATUTOS", "MODIFICACION", "COMPA IA REASEGUROS VIDA SOINCE-RE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-10-18", "doble_articulado": false, "id_norma": "33798", "numero_fuente": "34705-2", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-11-02", "vigencias": [{"desde": "1993-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-11-02", "fin_vigencia": ""}, "vige