{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6254246}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 370, de 29 de Agosto de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se autoriza a las personas que se individualizan, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro de territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6254247}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Francisco Navarro Ruiz, Secretario Regional Ministerial de Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br><br></div>", "i": 6254248}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "370 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-370 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-08-29", "doble_articulado": false, "id_norma": "162084", "numero_fuente": "32266", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-09-05", "vigencias": [{"desde": "1985-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-09-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-09-05", "fin_vigencia": "", "tipo_version