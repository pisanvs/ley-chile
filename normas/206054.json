{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;14.118 EXENTA, DE&nbsp; 2002 </div><br></div>", "i": 6407549}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;14.118 de 27 de noviembre del a&#xF1;o 2002, se ha modificado la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;638 de 2001, que aprob&#xF3; planes y programas de estudio para 3er. a&#xF1;o de Ense&#xF1;anza Media, al Liceo &quot;Luisa Saavedra de Gonz&#xE1;lez&quot; (N&#xBA;7) de Ni&#xF1;as, comuna de Providencia, de Santiago, a contar del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s se aprueban programas de estudio para 3er a&#xF1;o de Ense&#xF1;anza Media a los Subsectores de Formaci&#xF3;n Diferenciada que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 6407550}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de diciembre de 2002.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6407551}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "14118 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-14118 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº14.118 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-11-27", "doble_articulado": false, "id_norma": "206054", "numero_fuente": "37438", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-19", "vigencias": [{"desde": "2002-12-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-12-19", "fin_vigenc