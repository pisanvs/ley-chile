{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6004975}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 66 de 30 de Diciembre de 1992, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se adjudic&#xF3; a PEDRO PABLO VALLEJOS MENDEZ, la concesi&#xF3;n para operar, por un plazo de cinco a&#xF1;os a contar de la publicaci&#xF3;n del presente extracto, un establecimiento ubicado en calle Balmaceda N&#xB0; 920 de la comuna de Parral, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de contaminantes de todo tipo de veh&#xED;culos motorizados, sus remolques y semirremolques, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 6004976}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Carlos P&#xE9;rez Molina, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n del Maule.- </div></div>", "i": 6004977}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "66", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-66"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION REVISION TECNICA", "VEHICULOS MOTORIZADOS", "PLANTA REVISION TECNICA", "PEDRO PABLO VALLEJOS MENDEZ", "PARRAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-12-30", "doble_articulado": false, "id_norma": "32783", "numero_fuente": "34537", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-04-08", "vigencias": [{"desde": "1993-04-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia