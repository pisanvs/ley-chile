{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6374779}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA; 114, de fecha 25 de febrero de 2002, se expropi&#xF3; el lote de terreno N&#xBA; 2, superficie 228 m2, rol de aval&#xFA;o 2210-235, comuna de Chill&#xE1;n, para la obra &quot;Camino Ruta N-45, Sector Cruce Ruta N-49 (Chill&#xE1;n) - La Capilla - Tres Esquinas, Km.</div><div class=\"p\">6,26000 a Km. 28,54000&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Jos&#xE9; Alfonso Garrido Mora, ascendente a la cantidad de $1.537.500. </div></div>", "i": 6374780}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6374781}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "114 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-114 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-25", "doble_articulado": false, "id_norma": "196154", "numero_fuente": "37223", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-01", "vigencias": [{"desde": "2002-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2002-04-01", "fecha_version": "2002-04-01", "fecha_actualizacion_texto": "2002-04-01", "tipo_trat