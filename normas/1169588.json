{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10291540}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xB0;2.219, de 4 de noviembre de 2021, aprueba gu&#xED;a para la calibraci&#xF3;n y mantenimiento de la instrumentaci&#xF3;n ac&#xFA;stica utilizada en la medici&#xF3;n de ruido y deja sin efecto la resoluci&#xF3;n exenta N&#xB0;3.097, de fecha 29 de noviembre de 2018.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.-</div></div>", "i": 10291541}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Heriberto Garc&#xED;a Escorza, Director (S), Instituto de Salud P&#xFA;blica de Chile.</div></div>", "i": 10291542}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2219 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-2219 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2054638", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-11-04", "doble_articulado": false, "id_norma": "1169588", "numero_fuente": "43125", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-12-11", "vigencias": [{"desde": "2021-12-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2021-12-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2021-12-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por":