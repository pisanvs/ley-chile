{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA N&#xBA; 181, DE 1989 </div></div>", "i": 6090146}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n N&#xBA; 181 de fecha Mayo 30 de 1989, la Secretar&#xED;a Ministerial de Educaci&#xF3;n de la Regi&#xF3;n de Antofagasta ha aprobado Planes y Programas de Estudio correspondiente al 3&#xB0; y 4&#xB0; a&#xF1;o de la Educaci&#xF3;n Media T&#xE9;cnico Profesional, para el Liceo Polit&#xE9;cnico C-1 &quot;Julio Montt Salamanca&quot; de Pedro de Valdivia.</div><br><div class=\"p\">En la Especialidad de:</div><div class=\"p\">- Vestuario y - Electromec&#xE1;nica.</div><br><div class=\"p\">Los Planes y Programas aprobados tendr&#xE1;n vigencia a contar del a&#xF1;o escolar 1989 y hasta el a&#xF1;o 1990.</div><br></div>", "i": 6090147}, {"t": "<div><div class=\"p\">Mar&#xED;a Elena, Julio 14 de 1989.- Luis H. Alvear L&#xF3;pez, Secretario Ministerial Educaci&#xF3;n Regi&#xF3;n Antofagasta. </div></div>", "i": 6090148}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "181 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-181 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA Nº 181, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-30", "doble_articulado": false, "id_norma": "91905", "numero_fuente": "33487", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-10-03", "vigencias": [{"desde": "1989-10-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-10-03", "fin_vigencia": ""}, "vigencias_version_norma": [{