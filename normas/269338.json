{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7364319}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 387, de 7 de febrero de 2008, de esta Subsecretar&#xED;a, autor&#xED;zase a NIBALDO ENRIQUE GONZ&#xC1;LEZ ASTORGA para iniciar actividades pesqueras de transformaci&#xF3;n, para iniciar y operar planta ubicada en pasaje Playa Mansa N&#xBA; 1355, Caldera, para elaborar en las l&#xED;neas de proceso de cocido, fresco enfriado, fresco refrigerado, congelado, alga seca y maquilado, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada. </div></div>", "i": 7364320}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de febrero de 2008.- Mar&#xED;a &#xC1;ngela Barbieri Bellolio, Subsecretaria de Pesca (S). </div></div>", "i": 7364321}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "387 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-387 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-02-07", "doble_articulado": false, "id_norma": "269338", "numero_fuente": "38991", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-02-19", "vigencias": [{"desde": "2008-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-02-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-02-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingr