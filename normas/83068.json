{"html": [{"t": "<div><div class=\"p\">CADUCA RESOLUCION QUE INDICA </div></div>", "i": 8314658}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 641, 16 de Mayo de 1990 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n No. 1159, de 1988, de esta Subsecretar&#xED;a, que autoriz&#xF3; a do&#xF1;a Jacqueline Chauvaud Corbeaux, R.U.T. No. 4.381.903-8, domiciliada en San Crescente No. 113, Las Condes, Santiago, para iniciar actividades pesqueras de cultivo, conforme a lo establecido en el art&#xED;culo 7&#xB0; del Decreto Supremo No. 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8314659}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 16 de Mayo de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8314660}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "641", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-641"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "CADUCA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-05-16", "doble_articulado": false, "id_norma": "83068", "numero_fuente": "33680", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-05-28", "vigencias": [{"desde": "1990-05-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-05-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-05-28", "fin_vigencia": "", "tipo_version":