{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5898559}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto M.O.P. N&#xB0; 175, de 16 de Junio de 1993,</div><div class=\"p\">se modific&#xF3; el Decreto M.O.P. N&#xB0; 75, de fecha 8 de Marzo</div><div class=\"p\">de 1993, que en base a la facultad otorgada por el</div><div class=\"p\">art&#xED;culo 105 del Decreto M.O.P. N&#xB0; 294, de 1984, que fij&#xF3; el texto actualizado de la Ley N&#xB0; 15.840, expropi&#xF3; el lote de terreno N&#xB0; 1, para la ejecuci&#xF3;n de la obra Alcantarillado en la localidad de San Rafael de Pelarco, Proyecto Subsistema N&#xB0; 1, en el sentido de que dicho lote figura a nombre de Mercedes Segundo V&#xE9;liz Barrios y su Rol de aval&#xFA;o es 86-73, Comuna de Pelarco, superficie 1.746 M2. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xB0; del Decreto Ley N&#xB0; 2.186, de 1978.-</div><br></div>", "i": 5898560}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 5898561}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "175", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-175"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "DECRETO EXPROPIATORIO", "BIEN RAIZ", "BIEN INMUEBLE", "SAN RAFAEL", "PELARCO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-06-16", "doble_articulado": false, "id_norma": "10501", "numero_fuente": "34615-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-07-15", "vigencias": [{"desde": "1993-07-15", "hasta": "", "tipo_version":