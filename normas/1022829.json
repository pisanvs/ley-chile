{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9108138}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 273, de 27 de enero de 2011, de esta Subsecretar&#xED;a ampl&#xED;ase por 12 meses a contar 1&#xBA; de noviembre de 2010, el plazo otorgado en el numeral 4&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1007389&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.398 de 2009</a>, de esta Subsecretar&#xED;a de Pesca, a SOUTHPACIFIC KORP S.A. para iniciar actividades pesqueras extractivas con la nave &quot;Lonco&quot;, respecto de los recursos hidrobiol&#xF3;gicos Alfonsino y Besugo en el &#xE1;rea mar&#xED;tima comprendida entre la V a X Regiones, e Islas de Pascua, Salas y G&#xF3;mez, Desventuradas y Archipi&#xE9;lago de Juan Fern&#xE1;ndez.</div></div>", "i": 9108139}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de enero de 2011.- Felipe Palacio Rives, Subsecretario de Pesca (S).</div></div>", "i": 9108140}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "273 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-273 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-01-27", "doble_articulado": false, "id_norma": "1022829", "numero_fuente": "39879", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-02-07", "vigencias": [{"desde": "2011-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-02-07", "fin_vigencia