{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento al presupuesto de Hacienda Lei n&#xFA;m. 1,622.- Santiago, a 11 de Noviembre de 1903.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5950720}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se concede un suplemento de veinte mil pesos al &#xED;tem 11,137 de la partida 354 del Presupuesto de Hacienda, que consulta fondos para el reconocimiento de salitreras, levantamiento de planos i deslindes i para &#xFA;tiles de dibujo.</div><br></div>", "i": 5950721}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Manuel Salinas.</div><br></div>", "i": 5950722}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1622", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1622"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "SUPLEMENTO AL PRESUPUESTO DE HACIENDA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1903", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1903-11-11", "doble_articulado": false, "id_norma": "22797", "numero_fuente": "7753", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1903-11-13", "vigencias": [{"desde": "1903-11-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1903-11-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1903-