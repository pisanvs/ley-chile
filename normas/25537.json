{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DISPONE QUE LA COMUNA SUBDELEGACION DE NAVIDAD FORMARA PARTE DEL DEPARTAMENTO DE SAN ANTONIO Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8278310}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.o La comuna subdelegaci&#xF3;n de Navidad, creada por la ley N.o 5,935, de 23 de Septiembre de 1936, formar&#xE1; parte del departamento de San Antonio. </div></div>", "i": 8278311}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2.o Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 8278312}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y, ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintiocho de Diciembre de mil novecientos cuarenta y dos.- JUAN ANTONIO RIOS M.- A. Duhalde V. </div></div>", "i": 8278313}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "7394", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-7394"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DISPONE QUE LA COMUNA SUBDELEGACION DE NAVIDAD\nFORMARA PARTE DEL DEPARTAMENTO DE SAN ANTONIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SAN ANTONIO", "NAVIDAD", "COMUNA SUBDELEGACION", "DEPARTAMENTO", "INTEGRACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1942-12-28", "doble_articulado": false, "id_norma": "25537", "numero_fuente": "19447", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1942-12-31", "vigencias": [{