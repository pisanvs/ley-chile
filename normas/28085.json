{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; REINCORPORA EN EL CARGO QUE INDICA A DON JACINTO ROQUE QUEZADA AVILES.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 8282066}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Reincorp&#xF3;rase al se&#xF1;or Jacinto Roque Quezada Avil&#xE9;s a su cargo de bodeguero-recaudador de la Empresa de los Ferrocarriles del Estado&quot;. </div></div>", "i": 8282067}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, tres de julio de mil novecientos sesenta y tres.- JORGE ALESSANDRI RODRIGUEZ.- Luis Escobar. </div></div>", "i": 8282068}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "15210", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-15210"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "REINCORPORA EN EL CARGO QUE INDICA A DON JACINTO\nROQUE QUEZADA AVILES.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REINCORPORACION", "BODEGUERO RECAUDADOR", "EMPRESA FERROCARRILES ESTADO", "FUNCIONARIO", "EMPLEADO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1963-06-03", "doble_articulado": false, "id_norma": "28085", "numero_fuente": "25592", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1963-07-17", "vigencias": [{"desde": "1963-07-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "196