{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 235 EXENTO, DE 2000</div><br><br><br><br></div>", "i": 6300369}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 235, del 30 de junio de 2000, del Ministerio de Educaci&#xF3;n, se modifica el art&#xED;culo 1&#xBA; del decreto exento de Educaci&#xF3;n N&#xBA; 51 del 2 de marzo de 1999, que reconoce oficialmente al Centro de Formaci&#xF3;n T&#xE9;cnica Santa Teresa de Los Andes, en el sentido de reemplazar la raz&#xF3;n social del organizador y la actual denominaci&#xF3;n del Centro, por la siguiente:</div><br><br><div class=\"p\">Nombre de la Instituci&#xF3;n : Centro de Formaci&#xF3;n T&#xE9;cnica</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Soesta</div><div class=\"p\">Domicilio&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Los Andes</div><div class=\"p\">Organizador&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Sociedad de Educaci&#xF3;n Superior</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Soesta S.A.</div><br></div>", "i": 6300370}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 21 de julio de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6300371}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "235 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-235 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 235 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "