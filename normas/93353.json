{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 122, DE 1989 </div></div>", "i": 7227760}, {"t": "<div><div class=\"p\">Por Decreto Supremo Exento de Educaci&#xF3;n No. 122 de 27 de julio de 1989 se han aprobado, a contar del a&#xF1;o escolar 1989, al Liceo &quot;San Agust&#xED;n&quot; de Santiago, Regi&#xF3;n Metropolitana, planes especiales de estudio para los cursos de 7&#xB0; y 8&#xB0; A&#xF1;o de Educaci&#xF3;n General B&#xE1;sica y de 1&#xB0; a 4&#xB0; A&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica, que se aplicar&#xE1;n simult&#xE1;neamente en todos los cursos. </div></div>", "i": 7227761}, {"t": "<div><div class=\"p\">Santiago, 07 de Agosto de 1989.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 7227762}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "122 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-122 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 122, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-07-27", "doble_articulado": false, "id_norma": "93353", "numero_fuente": "33458", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-08-26", "vigencias": [{"desde": "1989-08-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-08-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-08-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACI