{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO No. 108 EXENTO, DE 1988 </div></div>", "i": 7245879}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 108 de 09 de junio de 1988 se ha complementado el dereto supremo exento de Educaci&#xF3;n No. 75 de 1987, que aprob&#xF3; el plan y los programas de estudio experimentales de orientaci&#xF3;n laboral para menores deficientes mentales al Centro de Capacitaci&#xF3;n Laboral de Antofagasta, en el sentido de incorporar en el Plan Diferenciado la especialidad de Zapater&#xED;a.</div><br></div>", "i": 7245880}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de Junio de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7245881}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "108 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-108 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO N° 108 EXENTO, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-06-09", "doble_articulado": false, "id_norma": "132007", "numero_fuente": "33108", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-06-30", "vigencias": [{"desde": "1988-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-06-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-06-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "