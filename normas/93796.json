{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA </div></div>", "i": 8323666}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 92, de fecha 27 de Junio de 1989, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la personalidad jur&#xED;dica de la Asociaci&#xF3;n Gremial de Agricultores del Valle de Curacav&#xED;, inscrita bajo el n&#xFA;mero 389, del registro que lleva este Ministerio por haberse configurado respecto de ella la causal de cancelaci&#xF3;n contemplada en el art&#xED;culo 18 No. 2 letra c del DL 2.757 de 1979.</div><br></div>", "i": 8323667}, {"t": "<div><div class=\"p\">Norman Bull de la Jara, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8323668}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "92", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-92"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA", "FOMENTO"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-06-27", "doble_articulado": false, "id_norma": "93796", "numero_fuente": "33440", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-08-04", "vigencias": [{"desde": "1989-08-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-08-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-08-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha