{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 681 EXENTA, DE 2009</div></div>", "i": 8735811}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 681 de fecha 2 de abril de 2009, el Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, autoriz&#xF3; complementariamente a la empresa argentina &quot;San Mart&#xED;n S.R.L.&quot;, para efectuar servicio de transporte terrestre internacional de pasajeros entre Argentina y Chile y viceversa, atendiendo el servicio San Mart&#xED;n de Los Andes (Argentina) / Temuco (Chile), utilizando los pasos fronterizos habilitados desde Pino Hachado al sur con tres (3) frecuencias semanales de ida y vuelta.- </div></div>", "i": 8735812}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Erazo Torricelli, Subsecretario de Transportes.</div><br></div>", "i": 8735813}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "681 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-681 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 681 EXENTA, DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-04-02", "doble_articulado": false, "id_norma": "1003957", "numero_fuente": "39402", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-07-03", "vigencias": [{"desde": "2009-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-07-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia":