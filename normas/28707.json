{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DENOMINA LICEO &quot;MAXIMILIANO SALAS MARCHANT&quot; AL LICEO DE HOMBRES DE LOS ANDES</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha tenido a bien prestar su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5979566}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Denom&#xED;nase Liceo &quot;Maximiliano Salas Marchant&quot; al Liceo de Hombres de Los Andes.</div><br></div>", "i": 5979567}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta de Agosto de mil novecientos sesenta y ocho.- EDUARDO FREI MONTALVA.- M&#xE1;ximo Pacheco G&#xF3;mez.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Patricio Rojas Saavedra, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 5979568}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "16928", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-16928"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "DENOMINA LICEO \"MAXIMILIANO SALAS MARCHANT\" AL LICEO\nDE HOMBRES DE LOS ANDES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "LICEO", "MAXIMILIANO SALAS MARCHANT", "LOS ANDES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1968-08-30", "doble_articulado": false, "id_norma": "28707", "numero_fuente": "27141", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1968-09-10", "vigencias": [{"des