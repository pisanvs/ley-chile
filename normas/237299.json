{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6523000}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xB0; 368, de 30 de mayo de 1996, se expropiaron los lotes de terrenos N&#xB0;s 17 y 28 superficies 40.684 M2, 489 M2, rol de aval&#xFA;o 694-34, 591- 36 comuna de Yungay, para la obra Proyecto Laja- Diguill&#xED;n, Canal Matriz, Sector Hu&#xE9;pil Trilaleo y se acord&#xF3; precio de indemnizaci&#xF3;n con los propietarios Gladys Mar&#xED;a Rivas Santander y Laura del Carmen Pinilla P&#xE9;rez ascendente a la cantidad de $8.865.806 para el lote N&#xB0; 17 y $735.653 para el lote N&#xB0; 28.</div><br><br></div>", "i": 6523001}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6523002}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "368", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-368"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-30", "doble_articulado": false, "id_norma": "237299", "numero_fuente": "35504", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-07-01", "vigencias": [{"desde": "1996-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-04-22", "fecha_version": "1996-07-01", "fecha_actualizacion_texto": "199