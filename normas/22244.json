{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pension de Gracia a las hijas solteras de don Francisco Fierro Talavera</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 895.- Santiago, a 15 de Enero de 1897.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7162704}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese a do&#xF1;a Matilde, do&#xF1;a Emilia, do&#xF1;a Mercedes i do&#xF1;a Teresa Fierro, hijas solteras de don Francisco Fierro Talavera, una pension de mil doscientos pesos anuales, de que gozar&#xE1;n conjuntamente i en conformidad a la lei de montep&#xED;o militar.</div><br><br></div>", "i": 7162705}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- El&#xED;as Fern&#xE1;ndez A.</div><br></div>", "i": 7162706}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "895", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-895"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION DE GRACIA A LAS HIJAS SOLTERAS DE DON FRANCISCO FIERRO TALAVERA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MATILDE FIERRO", "EMILIA FIERRO", "MERCEDES FIERRO", "TERESA FIERRO", "MONTEPIO MILITAR", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-01-15", "doble_articulado": false, "id_norma": "22244", "numero_fuente": "5605", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1897-01-15", "vigencias": [{"desde": "1897-01-15", "hasta": "", "tipo_v