{"html": [{"t": "<div><br><div class=\"p\">EXIME A CONTRIBUYENTE DEL TIMBRAJE DE PAGAR&#xC9;S Y FIJA REQUISITOS EN SU REEMPLAZO</div></div>", "i": 9482750}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 60, de 20 de junio de 2014, que establece;</div><div class=\"p\">&nbsp; &nbsp;  Exime a Compa&#xF1;&#xED;a Agropecuaria Copeval S.A. de la obligaci&#xF3;n de timbraje de pagar&#xE9;s establecida en el art. 17 inc. 2&#xBA; del DL N&#xBA; 3.475, de 1980, y fija requisitos en su reemplazo para resguardar el inter&#xE9;s fiscal.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de junio de 2014.</div></div>", "i": 9482751}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "60 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-60 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXIME A CONTRIBUYENTE DEL TIMBRAJE DE PAGARÉS Y FIJA REQUISITOS EN SU REEMPLAZO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-06-20", "doble_articulado": false, "id_norma": "1063723", "numero_fuente": "40893", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-06-27", "vigencias": [{"desde": "2014-06-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inici