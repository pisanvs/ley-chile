{"html": [{"t": "<div><div class=\"p\">MODIFICA LA FECHA DE ENTRADA EN VIGENCIA DE LA RES. EX. N&#xB0; 108, DE 2020</div></div>", "i": 10188059}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 165, de fecha 22 de diciembre de 2020, modifica fecha de entrada en vigencia de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1149388&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n Ex. SII N&#xB0; 108 de 2020</a>, que deja sin efecto las instrucciones relativas a vales en reemplazo de boletas y vales electr&#xF3;nicos en reemplazo de la boleta de ventas y servicios en la forma y condiciones que indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento est&#xE1; publicado en &quot;www.sii.cl&quot;.</div><div class=\"p\"> </div><br></div>", "i": 10188060}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "165 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-165 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA LA FECHA DE ENTRADA EN VIGENCIA DE LA RES. EX. N° 108, DE 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1872386", "EXTRACTO", "NORMA SIN FECHA DE PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-12-22", "doble_articulado": false, "id_norma": "1153961", "numero_fuente": "42840", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-12-28", "vigencias": [{"desde": "2020-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2020-12-28", "fin_vigenc