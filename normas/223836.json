{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6473946}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 461 de fecha 26 de marzo de 2004, se expropiaron los lotes de terreno N&#xBA; s. 32 y 33, superficies 776,0 y 120,0 m2, Rol N&#xBA; 156-17, comuna de Curarrehue, IX Regi&#xF3;n para la obra &quot;Camino Catripulli - Curarrehue, sector Km. 108,02 al Km. 114,80&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Nemecio Dur&#xE1;n M&#xE9;ndez, ascendente a la cantidad de $2.395.629.- para los lotes N&#xBA; s. 32 y 33. </div></div>", "i": 6473947}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6473948}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "461 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-461 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "EL PRESENTE DECRETO FUE NUEVAMENTE PUBLICADO EN EL DIARIO OFICIAL DE 15.04.2004."], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-26", "doble_articulado": false, "id_norma": "223836", "numero_fuente": "37836", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-15", "vigencias": [{"desde": "2004-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-04-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2004-04-15", "fecha_version":