{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DELEGA FACULTADES QUE SE&#xD1;ALA </div></div>", "i": 7202633}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Mediante Resoluci&#xF3;n Ex. N&#xB0; 2.550, de fecha 24.07.96, el Director Regional del Servicio de Impuestos Internos de la VII Direcci&#xF3;n Regional Talca, ha delegado en la forma y en el fondo el Jefe del Departamento de Resoluciones Regional, las facultadas que le fueron autorizadas de delegar por el Sr. Director del Servicio, en la Resoluci&#xF3;n Ex. N&#xB0; 2.242 del 16.04.93, publicada en el D.O. de fecha 23.04.93, y a su vez agrega nuevo dispositivo indicado en la Resoluci&#xF3;n Ex. N&#xB0; 3.311 de fecha 16.07.96, publicada en el D.O. el 22.07.96, emitida por la misma autoridad.-</div><br></div>", "i": 7202634}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Sergio Flores Guti&#xE9;rrez, Director Regional. </div></div>", "i": 7202635}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2550", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2550"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL VII REGIÓN DEL MAULE"], "titulo_norma": "DELEGA FACULTADES QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "DELEGACION", "FACULTAD", "DIRECTOR REGIONAL", "SERVICIO IMPUESTOS INTERNOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-07-24", "doble_articulado": false, "id_norma": "40211", "numero_fuente": "35534", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-08-05", "vigencias": [{"desde": "1996-08-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-08-05