{"html": [{"t": "<div><div class=\"p\">REVALIDA DECRETO ALCALDICIO N&#xBA; 2, DE 1983.</div><br><div class=\"p\">&nbsp; &nbsp;  Huala&#xF1;e 14 de Diciembre de 1984.- Esta Alcald&#xED;a decret&#xF3; hoy lo que sigue:</div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 65.- Visto y teniendo presente: 1.- Lo dispuesto en el Art. No.43 del DL No. 3.063/ 79 sobre Rentas Municipales y teniendo presente el DL 1.289 Org&#xE1;nico de las Municipalidades, he acordado y, </div><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 6263565}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Reval&#xED;dese el decreto N&#xBA; 2 de. 20 1.83 que dict&#xF3; la Ordenanza Local sobre Derechos Municipales por Concesi&#xF3;n y Servicios a contar del 1.1.85 al 31.12.85 publicado en el Diario Oficial No. 31.478 del 28.1.83 p&#xE1;g. No. 514. </div></div>", "i": 6263566}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese y publ&#xED;quese en el Diario Oficial de la Rep&#xFA;blica de Chile.- Alfred Welkner Mattenschn, Alcalde.- Oscar Eduardo Doussang Sani, Secretario Municipal.</div><br></div>", "i": 6263567}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "65", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-65"}], "organismos": ["MUNICIPALIDAD DE HUALAÑE"], "titulo_norma": "REVALIDA DECRETO ALCALDICIO Nº 2, DE 1983.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-12-14", "doble_articulado": false, "id_norma": "165064", "numero_fuente": "32097", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-02-14", "vigencias": [{"desde": "1985-02-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenc