{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5909790}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto M.O.P. N&#xB0;s 352, 371 y 374, de fechas 28 y 29 de Octubre de 1993, respectivamente, se expropiaron los lotes de terreno N&#xB0;s 4, 6, 1, 5, 2, 3 y 7, superficies 960 M2., 935 M2., 240 M2., 520 M2., 336 M2., 510 M2. y 2.285 M2., roles de aval&#xFA;os 123-018, 123-019 y 123-016, Comuna de Pencahue, para las obras Regad&#xED;o Pencahue, Canal del Tranque Planta y Derivado Uno y Canal del Tranque y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Sergio Rocco Bravo, Jaime Castro Castro y Julio Abaca Abaca y otros, ascendente a la cantidad de $116.769, $46.817 y $152.867.</div><br></div>", "i": 5909791}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 5909792}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "374", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-374"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "DECRETO EXPROPIATORIO", "BIEN RAIZ", "BIEN INMUEBLE", "PENCAHUE", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-10-29", "doble_articulado": false, "id_norma": "12824", "numero_fuente": "34730-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-12-01", "vigencias": [{"desde": "1993-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-12-01", "fin_vigencia": "", "tipo_version": "3"}], "even