{"html": [{"t": "<div><div class=\"p\">PONE T&#xC9;RMINO AL NOMBRAMIENTO COMO ALCALDE DE MAR AD-HONOREM</div></div>", "i": 10173900}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n D.G.T.M. y M.M. ordinario N&#xBA; 1.120/137 Vrs., del 22 de octubre de 2020, pone t&#xE9;rmino al nombramiento como Alcalde de Mar Ad-Honorem de la Caleta Paposo a la Srta. Yovany Morales Salas.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de estas resoluciones se encuentra publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl).</div></div>", "i": 10173901}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de octubre de 2020.- Por orden del Sr. Director General, Ren&#xE9; Rojas Cabrejos, Capit&#xE1;n de Nav&#xED;o, Subdirector.- Cristi&#xE1;n Pfeifer Rojas, Capit&#xE1;n de Nav&#xED;o JT, Jefe Depto., Jur&#xED;dico.</div></div>", "i": 10173902}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "137", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-137"}, {"tipo": "3", "numero": "1120/137", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1120/137"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "PONE TÉRMINO AL NOMBRAMIENTO COMO ALCALDE DE MAR AD-HONOREM", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1844626", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-10-22", "doble_articulado": false, "id_norma": "1151496", "numero_fuent