{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N.o 7,367, QUE AUTORIZA CONMEMORAR EL PRIMER CENTENARIO DE LA MUERTE DE DON BERNARDO O&apos;HIGGINS</div><div class=\"p\">&nbsp; &nbsp; El Congreso Nacional ha tenido a bien prestar su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5965163}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Substit&#xFA;yese, en el inciso tercero del art&#xED;culo 7.o de la Ley n&#xFA;mero 7,367, de 20 de Noviembre de 1942, la fecha &quot;1.o de Julio de 1944&quot;, por esta otra: &quot;31 de Diciembre de 1944&quot;.</div><div class=\"p\">&nbsp; &nbsp; Esta ley regir&#xE1; desde el 1.o de Julio de 1944&quot;. </div></div>", "i": 5965164, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, primero de Agosto de mil novecientos cuarenta y cuatro.- JUAN ANTONIO RIOS M.- Benjam&#xED;n Claro V.</div><br></div>", "i": 5965165}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "7803", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-7803"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "MODIFICA LA LEY N.o 7,367, QUE AUTORIZA CONMEMORAR\nEL PRIMER CENTENARIO DE LA MUERTE DE DON BERNARDO\nO'HIGGINS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BERNARDO O'HIGGINS", "PRIMER CENTENARIO", "MUERTE", "CONMEMORACION", "ESCRITORES CHILENOS", "BIOGRAFIA", "CONCURSO", "PLAZO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1944