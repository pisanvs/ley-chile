{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 102, DE 2002</div><br><br></div>", "i": 6405356}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA; 102, de 22 de marzo de 2002, se ha aprobado Convenio de fecha veintid&#xF3;s de enero de 2002, celebrado entre Ministerio de Educaci&#xF3;n y la I. Municipalidad de Los Vilos, que modifica el Convenio de Traspaso de 2 de marzo de 1981 del Liceo C N&#xBA; 17, traspasado a dicha Municipalidad, por Convenio aprobado por decreto supremo de Educaci&#xF3;n N&#xBA; 1.058 de 16 de marzo de 1981.</div><br></div>", "i": 6405357}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de diciembre de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6405358}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "102", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-102"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 102, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-22", "doble_articulado": false, "id_norma": "205381", "numero_fuente": "37428", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-07", "vigencias": [{"desde": "2002-12-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-12-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-12-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "CMV", "fecha_ingres