{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6566021}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 884, de 15 de marzo de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a CONSERVAS DALCAHUE S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Lautaro N&#xBA; 001, Dalcahue, Chilo&#xE9;, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de congelado y conserva, el recurso hidriobiol&#xF3;gico indicado en la resoluci&#xF3;n extractada.</div><div class=\"p\">D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 439 de 2006, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6566022}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de marzo de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6566023}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "884 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-884 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-03-15", "doble_articulado": false, "id_norma": "248632", "numero_fuente": "38430", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-04-03", "vigencias": [{"desde": "2006-04-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-04-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-04-03", "fin_