{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10284673}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n Ex. N&#xB0; 3.506 de fecha 05/11/2021, conforme al art&#xED;culo 51 Ley 16.391, DL 2.186/1978 y DS 1.128/2012 de Vivienda y Urbanismo, para destinarlo al Proyecto &quot;Mejoramiento calle Mollulco entre calles El Bosque y Complejo Deportivo Labranza, Temuco&quot;, Serviu Regi&#xF3;n de la Araucan&#xED;a orden&#xF3; la expropiaci&#xF3;n parcial del bien ra&#xED;z denominado &quot;Inmueble Rural ubicado en Labranza - Botrolhue&quot; Rol de aval&#xFA;o 3249-46, comuna de Temuco. La superficie total a expropiar aproximada es de 104,31 metros cuadrados, de aparente dominio de Guillermo Huaiquinao Marinao. Comisi&#xF3;n de Peritos integrada por &#xCD;talo Cort&#xE9;s Rocco, Eduardo Y&#xE1;&#xF1;ez Inzunza y Claudio Pezo Mu&#xF1;oz, fij&#xF3; monto de indemnizaci&#xF3;n provisional en $3.082.500 seg&#xFA;n informe N&#xB0; 04-0A de fecha 02/11/2021, pagadero contado.- </div></div>", "i": 10284674}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n la Araucan&#xED;a.</div><br></div>", "i": 10284675}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3506 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3506 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2038680", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-11-05", "doble_articulado": fals