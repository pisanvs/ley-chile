{"html": [{"t": "<div><div class=\"p\">CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A ATLAS EXPORTACIONES E IMPORTACIONES S.A.</div><br></div>", "i": 7372524}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La V Direcci&#xF3;n Regional del Servicio de Impuestos Internos, por resoluci&#xF3;n Ex. N&#xBA; 4.006, de 6 de junio de 2008, concede la calidad de Agente Retenedor del IVA, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, a la sociedad Atlas Exportaciones e Importaciones S.A., RUT N&#xBA;</div><div class=\"p\">84.372.700-K, en las adquisiciones de especies hidrobiol&#xF3;gicas, conforme a lo establecido en la resoluci&#xF3;n Ex. N&#xBA; 3.311 del 30.06.2000, la cual entr&#xF3; en vigencia el 1 de julio de 2000.</div><br></div>", "i": 7372525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Erica Morales Lartiga, Directora Regional. </div></div>", "i": 7372526}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4006 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4006 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL DE VALPARAÍSO"], "titulo_norma": "CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A ATLAS\nEXPORTACIONES E IMPORTACIONES S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-06-06", "doble_articulado": false, "id_norma": "272268", "numero_fuente": "39087", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-06-14", "vigencias": [{"desde": "2008-06-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-06-14", "fin_vigencia": ""}, "vigencias_ve