{"html": [{"t": "<div><div class=\"p\">MODIFICA EL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10166349}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.959, de 05.10.2020, del Director Nacional de Aduanas, se modifica el numeral 8.9 del Cap&#xED;tulo IV del <a href=\"https://www.leychile.cl/Navegar?idNorma=248540&amp;idParte=&amp;idVersion=\">Compendio de Normas Aduaneras</a>, en el sentido de eliminar la exigencia de poner los antecedentes de los DUS (AT) vencidos en conocimiento del Servicio de Impuestos Internos.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp;  La presente resoluci&#xF3;n entrar&#xE1; en vigencia a partir de la fecha de publicaci&#xF3;n en Diario Oficial.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10166350}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de octubre de 2020.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><br></div>", "i": 10166351}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2959 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2959 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA EL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1828358", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-10-05", "doble_articulado": false, "id_norma": "1150487", "numero_fuente": "42777", "tipo_version": "3", "tipo_version_s": "Ún