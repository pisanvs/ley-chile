{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,522.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6172191}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios que don Augusto Castelton prest&#xF3; durante la guerra del Pac&#xED;fico como capitan del trasporte nacional &quot;Mat&#xED;as Cousi&#xF1;o&quot;, conc&#xE9;dese, por gracia, a su viuda do&#xF1;a C&#xE1;rmen Andrews, una pension mensual de veinte pesos, de que disfrutar&#xE1; con arreglo a la lei de montep&#xED;o militar. </div></div>", "i": 6172192}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, dos de agosto de mil novecientos once.- Ramon Barros Luco.- An&#xED;bal Rodr&#xED;guez.</div><br></div>", "i": 6172193}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2522", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2522"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-08-02", "doble_articulado": false, "id_norma": "137464", "numero_fuente": "10053", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-08-10", "vigencias": [{"desde": "1911-08-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-08-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"