{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6175190}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 7, de 04 de Febrero de 1988, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se autoriza al Sr. Huvan Enrique Herrera Reyes para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6175191}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rancagua, 04 de Febrero de 1988.- Juan Latife Saadi, Seceretario Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n (S.).</div><br></div>", "i": 6175192}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-02-04", "doble_articulado": false, "id_norma": "138368", "numero_fuente": "32990", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-08", "vigencias": [{"desde": "1988-02-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-02-08", "fin_vigencia": "", "