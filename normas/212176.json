{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACION DE AGENTE RETENEDOR DEL IMPUESTO AL VALOR AGREGADO </div></div>", "i": 6430631}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VII Direcci&#xF3;n Regional Talca del S.I.I., por resoluci&#xF3;n DRE 07/exenta N&#xBA; 572, de fecha 23 de junio de 2003, deroga al contribuyente Soc. Agr&#xED;cola Soler Hermanos S.A. RUT N&#xBA; 79.855.170-1, a contar de la fecha de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado, en las ventas de ganado, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 18&#xBA; de la resoluci&#xF3;n ex. N&#xBA; 3.721/2000, de la Direcci&#xF3;n Nacional.</div><br></div>", "i": 6430632}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Talca, 23 de junio de 2003.- Emeric Fuentes Sep&#xFA;lveda, Director Regional (S).</div><br></div>", "i": 6430633}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "572 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-572 EXENTA"}, {"tipo": "3", "numero": "DRE-07-572 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-07-572 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VII DIRECCIÓN REGIONAL DE TALCA"], "titulo_norma": "DEROGA AUTORIZACION DE AGENTE RETENEDOR DEL IMPUESTO AL\nVALOR AGREGADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-23", "doble_articulado": false, "id_norma": "212176", "numero_fuente": "37604", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-09", "vigencias": [{"desde": "2003-07-09", "hasta": "", "tipo_version": "3", "tipo_vers