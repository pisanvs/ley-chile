{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO ALCALDICIO N&#xBA; 202, DE 2014</div></div>", "i": 9412818}, {"t": "<div><div class=\"p\">&nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Por decreto alcaldicio N&#xBA; 202, de fecha 11 de febrero de 2014, se procede a rebajar la tasa vigente a las patentes comerciales en un 2,5 del capital propio de cada contribuyente, de acuerdo a lo indicado en el art&#xED;culo 24 del decreto ley N&#xBA; 3.063, Rentas Municipales, para aquellas patentes que se emplacen al sur de Virginia Subercaseaux.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto completo se encuentra publicado en la p&#xE1;gina web municipal, Pirque transparente/actos y resoluciones/decretos alcaldicios.</div></div>", "i": 9412819}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El Alcalde.</div></div>", "i": 9412820}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "202", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-202"}], "organismos": ["MUNICIPALIDAD DE PIRQUE"], "titulo_norma": "EXTRACTO DE DECRETO ALCALDICIO Nº 202, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-02-11", "doble_articulado": false, "id_norma": "1060102", "numero_fuente": "40801", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-03-07", "vigencias": [{"desde": "2014-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-03-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014-03-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "i