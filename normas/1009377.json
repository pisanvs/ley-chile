{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 8423 EXENTA, DE 2009</div></div>", "i": 8814882}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente se han modificado las resoluciones exentas de Educaci&#xF3;n N&#xBA;s. <a href=\"https://www.leychile.cl/Navegar?idNorma=149153&amp;idParte=0&amp;idVersion=\">11355, de 1999</a>; <a href=\"https://www.leychile.cl/Navegar?idNorma=182486&amp;idParte=0&amp;idVersion=\">950, de 2001</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=197797&amp;idParte=0&amp;idVersion=\">4807, de 2002</a>, que aprobaron planes y programas especiales de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Instituto Nacional Jos&#xE9; Miguel Carrera, de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio del Sector de Idioma Extranjero: Chino Mandar&#xED;n para 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, que se aplicar&#xE1; gradualmente a partir del a&#xF1;o escolar 2010 en 1&#xBA; a&#xF1;o medio.</div></div>", "i": 8814883}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de diciembre de 2009.- Jaime Veas S&#xE1;nchez, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 8814884}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8423 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-8423 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 8423 EXENTA, DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-12-11", "doble_articulado": false, "id_norma": "100937