{"html": [{"t": "<div><div class=\"p\">MODIFICA EL ANEXO 51-3, RELATIVO A &quot;AGENTES DE ADUANA&quot;, DEL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10187026}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 3.520, de 10.12.2020, del Director Nacional de Aduanas, se modific&#xF3; el Anexo 51-3, relativo a &quot;Agentes de Aduana&quot;, en el siguiente sentido:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Elim&#xED;nese de la tabla del citado Anexo al Agente de Aduana Sr. Jorge Stephens Valenzuela, c&#xF3;digo C-29, a causa de su fallecimento.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10187027}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de diciembre de 2020.-&nbsp; Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><div class=\"p\"> </div><br></div>", "i": 10187028}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3520 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3520 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA EL ANEXO 51-3, RELATIVO A \"AGENTES DE ADUANA\", DEL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1867532", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-12-10", "doble_articulado": false, "id_norma": "1153770", "numero_fuente": "42834", "t