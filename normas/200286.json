{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;458 EXENTO, DE 2002 </div></div>", "i": 6388510}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xBA;458 de 24 de mayo de 2002, se ha aprobado un programa de Religi&#xF3;n Evang&#xE9;lica Protestante (Capellan&#xED;a Protestante de Chile), para todos los cursos de 1&#xBA; a 8&#xBA; a&#xF1;o de ense&#xF1;anza b&#xE1;sica y de 1&#xBA; a 4&#xBA; a&#xF1;o de ense&#xF1;anza media, los que se aplicar&#xE1;n simult&#xE1;neamente en todos los cursos a partir del a&#xF1;o escolar 2003, y seg&#xFA;n lo establecido en el decreto supremo de Educaci&#xF3;n N&#xBA;924, de 1983.</div><br></div>", "i": 6388511}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de junio de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6388512}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "458 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-458 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº458 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-24", "doble_articulado": false, "id_norma": "200286", "numero_fuente": "37306", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-12", "vigencias": [{"desde": "2002-07-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-07-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci