{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,361.- Santiago, 21 de setiembre de 1900.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br><br><br></div>", "i": 8343498}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados al pais por don Julio Ba&#xF1;ados Espinosa se concede a su viuda e hijas una pension de dos mil cuatrocientos pesos anuales, de la que gozar&#xE1;n con arreglo a la lei de montep&#xED;o militar. </div></div>", "i": 8343499}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- ELIAS FERNANDEZ A.- R. Err&#xE1;zuriz Urmeneta.</div><br></div>", "i": 8343500}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1361", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1361"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-09-21", "doble_articulado": false, "id_norma": "134795", "numero_fuente": "6697", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-09-21", "vigencias": [{"desde": "1900-09-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-09-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1900-09-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-0