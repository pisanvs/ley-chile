{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 64.- Santiago, 26 de febrero de 2003.- Vistos: Lo dispuesto en el art. 11 del decreto ley N&#xBA;2.974 de 1979.</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br><br></div>", "i": 6418695}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del decreto ley citado, al siguiente funcionario de la VIII Regi&#xF3;n:</div><br><div class=\"p\">&nbsp; &nbsp;  Domingo Enrique Daure Guerra, RUN N&#xBA;5.177.936-3. </div></div>", "i": 6418696}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Arturo S&#xE1;ez Chatterton, Director Nacional (S).</div><br></div>", "i": 6418697}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "64", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-64"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-02-26", "doble_articulado": false, "id_norma": "208794", "numero_fuente": "37520", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-03-27", "vigencias": [{"desde": "2003-03-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}],