{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6552572}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 608 de 25 de noviembre de 2005 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n parcial , conforme D.L. N&#xBA; 2.186 de 1978, inmueble ubicado en Avda. Larra&#xED;n N&#xBA; 7941 (Lote N&#xBA; 35), Rol de Aval&#xFA;o N&#xBA; 5000-3, comuna de La Reina, de dominio de Club A&#xE9;reo de Santiago. Comisi&#xF3;n integrada por peritos do&#xF1;a Mar&#xED;a Isabel R&#xED;os Marcuello, Arquitecta; Yolanda Ivanka Aliaga Jofre, Constructor Civil y Mar&#xED;a In&#xE9;s M&#xE1;rquez Guti&#xE9;rrez, Ingeniero Civil. Seg&#xFA;n informe de 14 de junio de 2005, fij&#xF3; monto provisional indemnizaci&#xF3;n en $90.099.975 y mediante acuerdo con expropiado de 2 de noviembre de 2005 se fij&#xF3; monto definitivo indemnizaci&#xF3;n en $97.028.700.-, pagadera al contado.-</div><br></div>", "i": 6552573}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Director Serviu Metropolitano.</div><br></div>", "i": 6552574}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "608", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-608"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "ORDENA EXPROPIACION DE INMUEBLES QUE SEÑALA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-25", "doble_articulado": false, "id_norma": "244975", "numero_fuente": "38337", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publica