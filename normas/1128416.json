{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 9996372}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (Exento) N&#xB0; 1826 de 31 de diciembre de 2018, se modific&#xF3; el numeral segundo del <a href=\"https://www.leychile.cl/Navegar?idNorma=1072229&amp;idParte=&amp;idVersion=\">Decreto MOP (Exento) N&#xB0; 1185 de 25 de noviembre de 2014</a>, que orden&#xF3; la expropiaci&#xF3;n del Lote N&#xB0; 27, en la parte que se refiere al rol de aval&#xFA;o, seg&#xFA;n certificado de aval&#xFA;o emitido por el Servicio de Impuestos Internos, quedando como a continuaci&#xF3;n se indica: LOTE 27, MORRISON ALARCON KAREM Y OTRAS, superficie 24,01 m2., rol de aval&#xFA;o 476-19, Comuna de TOME. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xB0; del Decreto Ley N&#xB0; 2186, de 1978.</div></div>", "i": 9996373}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1826 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1826 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1538107", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-12-31", "doble_articulado": false, "id_norma": "1128416", "numero_fuente": "42269", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-02-01", "vigencias": [{"desde": "2019-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2019-02