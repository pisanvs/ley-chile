{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6394150}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.768, de 20 de agosto de 2002, de esta Subsecretar&#xED;a, rectif&#xED;case el literal h) del numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA; 981 de 2002, que autoriz&#xF3; a PESQUERA SAN JOSE S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Don Nordlund&quot;, en el sentido de se&#xF1;alar que la interesada podr&#xE1; realizar actividades pesqueras con la nave individualizada precedentemente, en el &#xE1;rea mar&#xED;tima comprendida entre la I a X Regiones, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua, sobre el recurso Calamar o Pota del Atl&#xE1;ntico Ilex Atl&#xE1;nticus.</div><br></div>", "i": 6394151}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de agosto de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6394152}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1768", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1768"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-08-20", "doble_articulado": false, "id_norma": "201957", "numero_fuente": "37344", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-08-27", "vigencias": [{"desde": "2002-08-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-08-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2