{"html": [{"t": "<div><div class=\"p\">DISOLUCION DEL BATALLON NUM. 5.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 7 de 1825.</div></div>", "i": 10113667}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Respecto a que el Batallon n&#xFA;m. 5 erijido en 21 de Mayo de 1820 se halla en el dia reducido a cuadro de oficiales, decl&#xE1;rase disuelto; coloc&#xE1;ndose estos por el Comandante Jeneral de Armas en clase de agregados en los demas batallones del ej&#xE9;rcito (a escepcion de los Jefes que quedar&#xE1;n agregados al Estado Mayor de Plaza) hasta consultados en vacantes; distribuy&#xE9;ndose asi mismo el corto n&#xFA;mero de plazas de prest entre los insinuados batallones.</div></div>", "i": 10113668}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, comun&#xED;quese a quienes corresponda, e ins&#xE9;rtese en el Boletin.</div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><div class=\"p\">&nbsp; &nbsp;  Muxica.</div></div>", "i": 10113669}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DE GUERRA Y MARINA"], "titulo_norma": "DISOLUCION DEL BATALLON NUM. 5.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-07-08", "doble_articulado": false, "id_norma": "1143184", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-07-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-07-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-07-08", "fin_vigencia": "", 