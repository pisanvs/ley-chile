{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 2.655 EXENTA, DE 2013</div></div>", "i": 9348228}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.655, de 16 de abril de 2013, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Servicios de Capacitaci&#xF3;n Incasem Limitada (Incasem Ltda.)&quot;, RUT 76.565.500-5, contenida en la resoluci&#xF3;n exenta N&#xBA; 9.856, de 13 de octubre de 2010, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.- </div></div>", "i": 9348229}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (S).</div></div>", "i": 9348230}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2655 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2655 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 2.655 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-04-16", "doble_articulado": false, "id_norma": "1050476", "numero_fuente": "40545", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-04-27", "vigencias": [{"desde": "2013-04-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-04-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-04-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes":