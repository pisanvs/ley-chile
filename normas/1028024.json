{"html": [{"t": "<div><br><div class=\"p\">SOLICITA CONSTITUCI&#xD3;N LEGAL DEL PARTIDO PROGRESISTA</div><br></div>", "i": 9160501}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Marco Enr&#xED;quez-Ominami Gumucio y Cristian Warner Villagr&#xE1;n, Presidente y Secretario General, respectivamente, del Partido Progresista, han solicitado la constituci&#xF3;n legal del partido en la Regi&#xF3;n Metropolitana de Santiago. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de 14.431 fichas de afiliaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xBA; de la ley N&#xBA; 18.603, por resoluci&#xF3;n O-N&#xBA; 1.858, de fecha 20 de julio de 2011.- </div></div>", "i": 9160502}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 9160503}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1858", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1858"}, {"tipo": "3", "numero": "O-1858", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-1858"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCIÓN LEGAL DEL PARTIDO PROGRESISTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-07-20", "doble_articulado": false, "id_norma": "1028024", "numero_fuente": "40018", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-07-25", "vigencias": [{"desde": "2011-07-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-07-25", "fin_vigencia": ""}, "