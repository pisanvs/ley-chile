{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9049017}, {"t": "<div><div class=\"p\">Por Decreto MOP. No. 217 de 17 de Septiembre de 1991, se expropi&#xF3; el lote No. 1, rol de aval&#xFA;o 5501, superficie 5.259 m2., Comuna de Renca, para la obra Sectorizaci&#xF3;n Sistema de Distribuci&#xF3;n de Agua Potable Lo Contador Alto y Bajo, Mejoramiento Sistema de Producci&#xF3;n de Plantas Renca 4 y 5, Estanque Cerro Colorado y se acordo el precio de indemnizaci&#xF3;n con la propietaria, la Ilustre Municipalidad de Renca, ascendente a la cantidad de $ 3.355.400.- para el lote 1.- Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 9049018}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "217", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-217"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-09-17", "doble_articulado": false, "id_norma": "80943", "numero_fuente": "34091", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-10-15", "vigencias": [{"desde": "1991-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-10-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "ALV", "fecha_ingreso": "1997-12-23", "fecha_version": "1991-10-15", "fecha_actualizacion_texto": "1991-10-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9049017},