{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291643}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 291, de 9 de febrero de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por ocho meses, a contar del 29 de septiembre de 1995, el plazo otorgado a SOCIEDAD PESQUERA CALETA PORTALES S.A., para iniciar las actividades pesqueras autorizadas por Resoluci&#xF3;n N&#xB0; 812, de 1994, de esta Subsecretar&#xED;a, en virtud de haberse acreditado la existencia de una fuerza mayor.</div><br><br></div>", "i": 8291644}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 9 de febrero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8291645}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "291", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-291"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD PESQUERA CALETA PORTALES S.A.", "AMPLIACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-02-09", "doble_articulado": false, "id_norma": "34198", "numero_fuente": "35413", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-03-09", "vigencias": [{"desde": "1996-03-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-03-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-03-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_par