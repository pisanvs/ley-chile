{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que crea la tercera plaza de relator para la Corte Suprema.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. I648.- Santiago, a 8 de Febrero de 1904.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7164313}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Cr&#xE9;ase, para el servicio de la Corte Suprema, una tercera plaza de relator con la dotacion que a los funcionarios de esta clase asigna el art&#xED;culo 8.&#xB0; de la lei n&#xFA;m. I552 de 28 de Agosto de I902. </div></div>", "i": 7164314}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Efrain V&#xE1;squez Guarda.</div><br></div>", "i": 7164315}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1648", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1648"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "QUE CREA LA TERCERA PLAZA DE RELATOR PARA LA CORTE SUPREMA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CORTE SUPREMA JUSTICIA", "RELATOR", "TERCERA PLAZA", "CREACION", "DOTACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-02-08", "doble_articulado": false, "id_norma": "22817", "numero_fuente": "7824", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1904-02-08", "vigencias": [{"desde": "1904-02-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1904