{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO N&#xBA; 15, DE 2000</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 182.- Santiago, 22 de agosto de 2000.- Visto: El decreto N&#xBA; 15, del presente a&#xF1;o, del Ministerio de Transportes y Telecomunicaciones, y el n&#xFA;mero 44 del art&#xED;culo 1&#xBA; del decreto supremo N&#xBA; 1.407, de 1991, del Ministerio del Interior,</div><br><div class=\"p\">&nbsp; &nbsp;  D e c r e t o:</div><br></div>", "i": 6300538}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Der&#xF3;ganse la letra c) y el inciso final del</div><div class=\"p\">art&#xED;culo 6&#xBA; del decreto N&#xBA; 15, del a&#xF1;o en curso, citado en el Visto.</div><br></div>", "i": 6300539}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- Por orden del Presidente de la Rep&#xFA;blica, Carlos Cruz Lorenzen, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo para su conocimiento.- Saluda a Ud., Jorge Lobos D&#xED;az, Jefe Administrativo Subrogante. </div></div>", "i": 6300540}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "182", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-182"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "MODIFICA DECRETO Nº 15, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONVERTIDORES CATALITICOS", "VEHICULOS MOTORIZADOS", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-08-22", "doble_articulado": false, "id_norma": "175436", "numero_fuente": "36766", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-1