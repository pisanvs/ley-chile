{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA N&#xB0; 151, DE 1986 </div></div>", "i": 6232500}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta N&#xB0; 151 de fecha 15 de Enero de 1986, del Subsecretario de Educaci&#xF3;n P&#xFA;blica Subrogante, se rectific&#xF3; la Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xB0; 193 de 1982 del Centro de Formaci&#xF3;n T&#xE9;cnica CIISA de Santiago, en su Art&#xED;culo 2&#xB0; en lo que respecta a normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n a partir del a&#xF1;o 1982, para regularizar las diferentes situaciones acad&#xE9;micas de los alumnos.</div><br></div>", "i": 6232501}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante.</div><br></div>", "i": 6232502}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "151 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-151 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N° 151, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-01-15", "doble_articulado": false, "id_norma": "155572", "numero_fuente": "32401", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-02-18", "vigencias": [{"desde": "1986-02-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-02-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-02-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [