{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION&nbsp; (A) N&#xBA; 11, DE 2001</div><br><br><br><br></div>", "i": 8494077}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En cumplimiento de lo dispuesto por los decretos N&#xBA;s. 291, de 11 de junio y 668, de 16 de noviembre, ambos de 1999, del Ministerio de Econom&#xED;a, certifico que por resoluci&#xF3;n (A) N&#xBA; 11, de 23 de enero de 2001, del Sr. Vicepresidente Ejecutivo de la Corporaci&#xF3;n de Fomento de la Producci&#xF3;n, se modific&#xF3; el Reglamento del Programa de Cofinanciamiento de Proyectos de Preinversi&#xF3;n, que fuera aprobado por resoluci&#xF3;n (A) N&#xBA; 174 de 2000.</div><div class=\"p\">El texto completo de la resoluci&#xF3;n a que se refiere este extracto, est&#xE1; a disposici&#xF3;n de los usuarios en la Secretar&#xED;a General de la Corporaci&#xF3;n y en las Direcciones Regionales de Corfo.</div><br></div>", "i": 8494078}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de febrero de 2001.- Yerko Koscina Peralta, Secretario General.</div><br></div>", "i": 8494079}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "11", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-11"}, {"tipo": "3", "numero": "A-11", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-A-11"}], "organismos": ["CORPORACIÓN DE FOMENTO DE LA PRODUCCIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION (A) Nº 11, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-01-23", "fecha_derogacion": "2007-08-23", "doble_articulado": false, "id_norma": "182544", "numero_fuente": "36904", "tipo_version": "2", "tipo_version_s": "Última Ve