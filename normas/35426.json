{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8952434}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 719, de 12 de abril de 1996, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 899, de 1991, modificatoria de la Resoluci&#xF3;n N&#xB0; 715, de 1989, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; a EMPRESA PESQUERA NICHIRO CHILE LIMITADA, para instalar y operar un establecimiento de cultivo ubicado en Laguna Trap&#xE9;n, sector Trap&#xE9;n Alto, comuna de Puerto Montt, provincia de Llanquihue, X Regi&#xF3;n, en virtud de lo dispuesto en la Resoluci&#xF3;n N&#xB0; 886, de 1994. </div></div>", "i": 8952435}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 12 de abril de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8952436}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "719", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-719"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EMPRESA PESQUERA NICHIRO CHILE LIMITADA", "PESCA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-04-12", "doble_articulado": false, "id_norma": "35426", "numero_fuente": "35449", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-04-23", "vigencias": [{"desde": "1996-04-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-04-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci