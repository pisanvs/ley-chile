{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 85 EXENTO, DE 1996 </div></div>", "i": 5940898}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 85, de 30 de enero de 1996, se ha aprobado al Centro Educacional Asunci&#xF3;n de Rengo, un plan especial de estudio para el segundo ciclo de Educaci&#xF3;n B&#xE1;sica y para la Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, el cual se comenzar&#xE1; a aplicar a partir del a&#xF1;o escolar 1996.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas especiales de estudio para las asignaturas de Computaci&#xF3;n y Filosof&#xED;a. </div></div>", "i": 5940899}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 13 de febrero de 1996.- Juan Eduardo Garc&#xED;a-Huidobro S., Subsecretario de Educaci&#xF3;n (S). </div></div>", "i": 5940900}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "85", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-85"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 85 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIO", "CENTRO EDUCACIONAL ASUNCION", "RENGO", "PROGRAMAS ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-01-30", "doble_articulado": false, "id_norma": "20091", "numero_fuente": "35397", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-02-20", "vigencias": [{"desde": "1996-02-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-02-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-02-20", "fin_vigen