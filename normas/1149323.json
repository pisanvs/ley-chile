{"html": [{"t": "<div><div class=\"p\">EXTRACTO RESOLUCI&#xD3;N N&#xBA; 463 EXENTA, DE 16 DE ENERO DE 2020</div></div>", "i": 10157652}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por la presente, se ha modificado, a contar del a&#xF1;o escolar 2020, la <a href=\"https://www.leychile.cl/Navegar?idNorma=192586&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 14.082, de 2001, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; planes y programas especiales de estudio de 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al establecimiento educacional Colegio Huel&#xE9;n, RBD 8853-2, comuna de Vitacura, Regi&#xF3;n Metropolitana, en el sentido de sustituir los planes de estudio de 3&#xBA; a&#xF1;o de Educaci&#xF3;n Media.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10157653}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Figueroa Salas, Subsecretario de Educaci&#xF3;n.</div><div class=\"p\"> </div><br></div>", "i": 10157654}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "463 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-463 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO RESOLUCIÓN Nº 463 EXENTA, DE 16 DE ENERO DE 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1813299", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-01-16", "doble_articulado": false, "id_norma": "1149323", "numero_fuente": "42753", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-09-10", "vigencias": [{"desde": "2020-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"ini