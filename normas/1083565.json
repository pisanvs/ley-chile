{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N EXENTA N&#xBA; 3.310 DE 30 DE OCTUBRE DE 2015</div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 9647223}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.310 de 30 octubre de 2015, del Ministerio de Transportes y Telecomunicaciones, se modific&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1079634&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA;2.862, de 2015</a>, del mismo Ministerio, en el sentido de reemplazar el punto 1.3 del art&#xED;culo 5, por el siguiente: &quot;El per&#xED;odo de postulaci&#xF3;n se extender&#xE1; desde la fecha de publicaci&#xF3;n en extracto en el Diario Oficial de la presente resoluci&#xF3;n y hasta el d&#xED;a 4 de diciembre de 2015. Dicha resoluci&#xF3;n ser&#xE1; publicada &#xED;ntegramente en el banner que se indica en el punto siguiente&quot;.</div><br></div>", "i": 9647224}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Cristi&#xE1;n Bowen Garfias, Ministro de Transportes y Telecomunicaciones (S).</div></div>", "i": 9647225}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3310 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3310 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN EXENTA Nº 3.310 DE 30 DE OCTUBRE DE 2015", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 962709"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-10-30", "doble_articulado": false, "id_norma": "1083565", "numero_fuente": "41298", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-11-04", "vigencias": [{"des