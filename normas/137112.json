{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,503.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170910}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados al Ej&#xE9;rcito espedicionario al interior de la sierra del Per&#xFA; durante la campa&#xF1;a del Pac&#xED;fico por don Clemente Olivares Mu&#xF1;oz, el&#xE9;vase, por gracia, de setenta a cien pesos mensuales la pension de que actualmente disfruta. </div></div>", "i": 6170911}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintisiete de marzo de mil novecientos once.- Ramon Barros Luco.- Ramon Leon Luco.</div><br></div>", "i": 6170912}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2503", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2503"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-03-27", "doble_articulado": false, "id_norma": "137112", "numero_fuente": "9945", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-04-01", "vigencias": [{"desde": "1911-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-04-01", "fin_vigencia": "", "tipo_version": "