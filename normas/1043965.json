{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9296542}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. Exento N&#xBA;1797, de 30 de agosto de 2012, y de conformidad a lo dispuesto en el art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;12, superficie 173 m2., Rol N&#xBA;61-586, para la obra &quot;MEJORAMIENTO RUTA T-85, VARIOS TRAMOS EN LAGO RANCO &#x2013; CALCURRUPE&quot;, comuna de Lago Ranco, Regi&#xF3;n de Los R&#xED;os. La comisi&#xF3;n de peritos integrada por Patricio Fernando Casagrande Ulloa, Karin Alicia Ernst Elizalde y Mar&#xED;a Soledad N&#xFA;&#xF1;ez Arroyo, fij&#xF3; el valor de tasaci&#xF3;n con fecha 4 de febrero de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario JOS&#xC9; HUMBERTO HUEQUELEF HUENULEF, en la cantidad de $971.037.- suma que se pagar&#xE1; al contado. </div></div>", "i": 9296543}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9296544}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1797 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1797 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-08-30", "doble_articulado": false, "id_norma": "1043965", "numero_fuente": "40364", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-09-15", "vigencias": [{"desde": "2012-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-09-15", "fin_vigencia": ""}, "vigenci