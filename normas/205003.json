{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7295358}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.586, de 8 de noviembre de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA QUINTERO S.A. para ampliar las actividades pesqueras extractivas con la nave &quot;Eversen&quot;, autorizada por resoluciones N&#xBA; 382 de 1983, N&#xBA; 196 de 1985, N&#xBA; 132 de 1986, N&#xBA; 564 y N&#xBA; 1.066, ambas de 1987, N&#xBA; 320 de 1989, N&#xBA; 720 de 1993, N&#xBA; 2.586 de 2000 y N&#xBA; 899 y N&#xBA; 1.208, ambas de 2001, citadas en Visto, en orden a realizar actividades pesqueras con la nave se&#xF1;alada precedentemente, con espinel y en el &#xE1;rea mar&#xED;tima comprendida entre la I y III regiones, por fuera del &#xE1;rea de reserva artesanal, sobre el recurso hidrobiol&#xF3;gico Reineta Brama australis. </div></div>", "i": 7295359}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de noviembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7295360}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2586", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2586"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-11-08", "fecha_derogacion": "2004-05-27", "doble_articulado": false, "id_norma": "205003", "numero_fuente": "37419", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-11-27", "vigencias": [{"desde": "2004-05-27", "hasta": "", "tipo_version": "2", "tipo_v