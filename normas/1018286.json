{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9018906}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.095 de 8 de octubre de 2010 de esta Subsecretar&#xED;a, decl&#xE1;rese abierto un per&#xED;odo extraordinario de postulaciones de 60 d&#xED;as corridos, a contar de la fecha de publicaci&#xF3;n de la presente resoluci&#xF3;n, &#xFA;nicamente para efectos de proceder a la nominaci&#xF3;n del cargo de consejero titular y suplente del Consejo Zonal de Pesca, V, VI, VII, VIII y IX Regiones e Islas Oce&#xE1;nicas representante de las organizaciones gremiales de tripulantes de naves especiales per&#xED;odo 2010-2014.</div></div>", "i": 9018907}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de octubre de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9018908}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3095 EXENTO", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3095 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-10-08", "doble_articulado": false, "id_norma": "1018286", "numero_fuente": "39787", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-10-18", "vigencias": [{"desde": "2010-10-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-10-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-10-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":