{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297922}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.623, de 28 de agosto de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por OCTAVIO EDUARDO</div><div class=\"p\">CANALES GUEVARA, para un sector ubicado en Canal Jacaf,</div><div class=\"p\">comuna de Cisnes, provincia de Ays&#xE9;n, XI Regi&#xF3;n, por no</div><div class=\"p\">dar cumplimiento el respectivo proyecto t&#xE9;cnico a los</div><div class=\"p\">art&#xED;culos 88&#xB0; y 14&#xB0;, inciso 2&#xB0;, del D.S. N&#xB0; 290, de 1993, modificado por el D.S. N&#xB0; 604, de 1994, ambos del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8297923}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 28 de agosto de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297924}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1623", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1623"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "OCTAVIO EDUARDO CANALES GUEVARA", "CISNES", "DECIMOPRIMERA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-08-28", "doble_articulado": false, "id_norma": "37261", "numero_fuente": "35561", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-09-06", "