{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8815265}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.887, de 20 de noviembre de 2009, de esta Subsecretar&#xED;a, autorizase a RODRIGO HERIBERTO MU&#xD1;OZ AGUILERA para iniciar actividades pesqueras de transformaci&#xF3;n, instalar y operar planta ubicada en Avenida Dolores Endeiza N&#xBA; 86, Tongoy, IV Regi&#xF3;n, para elaborar en l&#xED;neas Cocido, Fresco-Enfriado, Congelado, Surimi, Salado H&#xFA;medo, Ahumado, Agar Agar y Alga Seca, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div></div>", "i": 8815266}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de noviembre de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8815267}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3887 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3887 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-10-20", "doble_articulado": false, "id_norma": "1009404", "numero_fuente": "39538", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-12-17", "vigencias": [{"desde": "2009-12-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-12-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-12-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_p