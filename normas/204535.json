{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 579 EXENTA, DE 2002, QUE MODIFICA LLAMADO A POSTULACION 7/2002 </div></div>", "i": 6402677}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;579, de fecha 30 de octubre de 2002, se modifican los guarismos contenidos en las ofertas I y II, letra A, de la resoluci&#xF3;n se&#xF1;alada precedentemente, en el sentido de aumentar la cifra &quot;62.837 U.F.&quot; a &quot;138.322 U.F.&quot; y disminuir la cifra de &quot;3.500 U.F. a 1.575 U.F.&quot;, respectivamente.-</div><br></div>", "i": 6402678}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Secretario Regional Ministerial Vivienda y Urbanismo Regi&#xF3;n Coquimbo.</div><br></div>", "i": 6402679}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "579 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-579 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SECRETARÍA REGIONAL MINISTERIAL IV REGIÓN COQUIMBO"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 579 EXENTA, DE 2002, QUE MODIFICA LLAMADO A POSTULACION 7/2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-10-30", "doble_articulado": false, "id_norma": "204535", "numero_fuente": "37409", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-11-15", "vigencias": [{"desde": "2002-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresa