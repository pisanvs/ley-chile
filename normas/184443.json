{"html": [{"t": "<div><div class=\"p\">CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A PESQUERA PLAYA GRANDE LIMITADA </div></div>", "i": 6331723}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La V Direcci&#xF3;n Regional del Servicio de Impuestos Internos, por resoluci&#xF3;n Ex. N&#xBA;11 de fecha 26 de marzo de 2001, concede la calidad de agente retenedor del IVA, a contar del primer d&#xED;a del mes siguiente al de esta publicaci&#xF3;n a Pesquera Playa Grande Limitada, RUT 78.409.770-6, por las adquisiciones de especies hidrobiol&#xF3;gicas que efect&#xFA;e, de acuerdo con lo establecido en la Res. Ex. N&#xBA;3.311, de 30-06-2000 de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial el d&#xED;a 03-07-2000.</div><br></div>", "i": 6331724}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco C&#xE1;rcamo Avenda&#xF1;o, Director Regional. </div></div>", "i": 6331725}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "11 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-11 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL DE VALPARAÍSO"], "titulo_norma": "CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A PESQUERA PLAYA GRANDE LIMITADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-26", "doble_articulado": false, "id_norma": "184443", "numero_fuente": "36942", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-04-20", "vigencias": [{"desde": "2001-04-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-04-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vi