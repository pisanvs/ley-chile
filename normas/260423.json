{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7340958}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.199, de 16 de abril de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a INGRID ELISABETH MEEDER MENSCHEL para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Pasaje Nuevo Uno N&#xBA; 136, Villa Manuel Bustos Alerce, Puerto Montt, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Congelado y Ahumado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 7340959}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de abril de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7340960}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1199 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1199 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-16", "doble_articulado": false, "id_norma": "260423", "numero_fuente": "38748", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-04-26", "vigencias": [{"desde": "2007-04-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-04-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-04-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingre