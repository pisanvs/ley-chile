{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N&#xB0; 11,248 Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8280125}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Reempl&#xE1;zase en el art&#xED;culo &#xFA;nico de la ley N&#xB0; 11,248 la denominaci&#xF3;n &quot;Victoriano Laynez&quot;, por esta otra &quot;Victorino Laynez&quot;.&quot;.</div><br></div>", "i": 8280126}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintisiete de Septiembre de mil novecientos cincuenta y seis.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Benjam&#xED;n Videla V.</div><br></div>", "i": 8280127}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "12147", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-12147"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA LA LEY N° 11,248", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "LEY 11.248", "CAMBIO NOMBRE", "CALLE VICTORINO LAYNEZ", "VALPARAISO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1956-09-27", "doble_articulado": false, "id_norma": "27047", "numero_fuente": "23570", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1956-10-10", "vigencias": [{"desde": "1956-10-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1956-10-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1956-10-10", "fin_vigenci