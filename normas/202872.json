{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6397213}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.832, de 28 de agosto de 2002, modif&#xED;case el numeral 4&#xBA; letra b) de la resoluci&#xF3;n N&#xBA; 1.696 de 2002, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE INVESTIGACION PESQUERA OCTAVA REGION (INPESCA), para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto FIP N&#xBA; 2002-14 denominado &quot;Evaluaci&#xF3;n del stock desovante de anchoveta y sardina com&#xFA;n entre la V y X Regiones, a&#xF1;o 2002&quot;, en el sentido de se&#xF1;alar que la fase de cruceros de prospecci&#xF3;n de huevos y adultos se realizar&#xE1; entre el 15 de agosto y el 15 de septiembre de 2002, ambas fechas inclusive.</div><br></div>", "i": 6397214}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de agosto de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6397215}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1832", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1832"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-08-28", "doble_articulado": false, "id_norma": "202872", "numero_fuente": "37365", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-09-23", "vigencias": [{"desde": "2002-09-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-09-23", "f