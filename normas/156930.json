{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA N&#xB0; 3.290, DE 1985 </div></div>", "i": 6237131}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta N&#xB0; 3290 de fecha 07 de Noviembre de 1985, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se rectific&#xF3; la Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xB0; 2903 de 1983, que autoriza a las sedes de los Centros de Formaci&#xF3;n T&#xE9;cnica, impartir planes y programas de estudios de carreras aprobadas para cada instituci&#xF3;n en el numeral que se indica, correspondiente al Centro de Formaci&#xF3;n T&#xE9;cnica &quot;Fundaci&#xF3;n DUOC&quot;:</div><br><div class=\"p\">&nbsp; &nbsp;  Numeral 11: Fundaci&#xF3;n DUOC Letra D: Sede N&#xB0; 5 del registro N&#xB0; 25- ciudad Concepci&#xF3;n</div><br><div class=\"p\">&nbsp; &nbsp;  Agregar lo que sigue: C&#xF3;digo: 11 Fecha: A contar del a&#xF1;o 1982.</div><br></div>", "i": 6237132}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de Diciembre de 1985.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6237133}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3290 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3290 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N° 3.290, DE 1985", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1985-11-07", "fecha_derogacion": "2018-12-31", "doble_articulado": false, "id_norma": "156930", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-01-07", "vigencias": [{"desde": "2018