{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9122050}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA;273 de 28 de febrero de 2011, se modific&#xF3; el numeral tercero del <a href=\"https://www.leychile.cl/Navegar?idNorma=181833&amp;idParte=0&amp;idVersion=\">decreto MOP N&#xBA;4.912 de 31 de octubre de 2000</a>, que orden&#xF3;, la expropiaci&#xF3;n del lote N&#xBA;2-A, en la parte que se refiere al n&#xFA;mero del Rol de aval&#xFA;o y al nombre del propietario seg&#xFA;n el Servicio de Impuestos Internos. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA;2.186, de 1978.- </div></div>", "i": 9122051}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9122052}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "273 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-273 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-02-28", "doble_articulado": false, "id_norma": "1023753", "numero_fuente": "39910", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-03-15", "vigencias": [{"desde": "2011-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modi