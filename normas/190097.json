{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6351597}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.892, de 11 de septiembre</div><div class=\"p\">de 2001, de esta Subsecretar&#xED;a, autor&#xED;zase a EMPRESA</div><div class=\"p\">PESQUERA SIRIUS ACHERNAR LTDA., para ampliar las</div><div class=\"p\">actividades pesqueras extractivas con la nave &quot;Cachagua</div><div class=\"p\">I&quot;, en el &#xE1;rea mar&#xED;tima que se indica, por fuera del</div><div class=\"p\">&#xE1;rea de reserva artesanal, sobre los siguientes</div><div class=\"p\">recursos hidrobiol&#xF3;gicos:</div><br><div class=\"p\">a)&nbsp;  En el &#xE1;rea mar&#xED;tima de la I a III Regiones, con</div><div class=\"p\">&nbsp; &nbsp;  arte de arrastre, sobre Merluza com&#xFA;n.</div><div class=\"p\">b)&nbsp;  En el &#xE1;rea mar&#xED;tima de la I a IV Regiones, con arte de arrastre, sobre Gamba, Besugo, Congrio dorado, Pejerrata y Raya.</div><br></div>", "i": 6351598}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de septiembre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6351599}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1892", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1892"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-09-11", "fecha_derogacion": "2003-01-16", "doble_articulado": false, "id_norma": "190097", "numero_fuente": "37075", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publica