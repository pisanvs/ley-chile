{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8311281}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.324 de 15 de Octubre de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la resoluci&#xF3;n No.</div><div class=\"p\">1.859, de 1989, de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a don FERNANDO ARANCIBIA CARVAJAL, RUT No.</div><div class=\"p\">6.780.149-0,domiciliado en calle Combarbal&#xE1; No. 535, Caldera, para instalar y operar un centro de cultivo de osti&#xF3;n del norte, en Caleta del Medio, Bah&#xED;a Salados, Comuna de Caldera, en virtud de lo dispuesto en el art&#xED;culo 7&#xB0; del DS No. 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8311282}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 15 de Octubre de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8311283}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1324", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1324"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-10-15", "doble_articulado": false, "id_norma": "80708", "numero_fuente": "34103", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-10-29", "vigencias": [{"desde": "1991-10-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-10-29", "fin_vigencia": ""}, "vigencias_version_norma"