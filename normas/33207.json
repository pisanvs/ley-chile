{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; REFORMA DE ESTATUTOS DEL BANCO SECURITY </div></div>", "i": 6006243}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Certifico que por Resoluci&#xF3;n N&#xB0; 113 de 27 de Octubre de 1994, se aprobaron las reformas introducidas a los estatutos del Banco Security, acordadas en la Junta Extraordinaria de Accionistas de 1&#xB0; de septiembre de 1994, cuya acta fue reducida a escritura p&#xFA;blica el 30 del mismo mes en la Notar&#xED;a de Santiago de don Enrique Morgan Torres.</div><div class=\"p\">&nbsp; &nbsp; Extracto de la reforma:</div><div class=\"p\">&nbsp; &nbsp; Se adoptaron modificaciones relativas al r&#xE9;gimen interno de la sociedad.-</div><br></div>", "i": 6006244}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 27 de Octubre de 1994. Jos&#xE9; Florencio Guzm&#xE1;n C., Superintendente de Bancos e Instituciones Financieras.</div><br></div>", "i": 6006245}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "113", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-113"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "REFORMA DE ESTATUTOS DEL BANCO SECURITY", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REFORMA ESTATUTARIA", "BANCO SECURITY"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-10-27", "doble_articulado": false, "id_norma": "33207", "numero_fuente": "35009", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-11-07", "vigencias": [{"desde": "1994-11-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-11-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-11-07", "fin_vigencia"