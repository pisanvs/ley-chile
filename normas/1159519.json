{"html": [{"t": "<div><div class=\"p\">NOMBRAMIENTO.</div></div>", "i": 10253935}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Marzo 26 de 1830.</div><br><div class=\"p\">&nbsp; &nbsp;  Convencido el Gobierno de que los importantes servicios del Dr. D. Juan Francisco Meneses son mas convenientes a la Rep&#xFA;blica en el Ministerio de Hacienda, que en el del Interior que hoy desempe&#xF1;a, y hall&#xE1;ndose plenamente satisfecho de su probidad y conocimientos, tiene a bien decretar sea trasladado a aquel departamento en su calidad de Ministro, y con el goce del sueldo respetivo. </div></div>", "i": 10253936}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, comun&#xED;quese e impr&#xED;mase. </div><br><div class=\"p\">&nbsp; &nbsp;  RUIZ TAGLE.</div><br><div class=\"p\">&nbsp; &nbsp;  Mardones.</div><div class=\"p\">&nbsp; &nbsp;  Pro-Secre.</div></div>", "i": 10253937}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "Ministro de Hacienda:- Nombramiento", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1830-03-26", "doble_articulado": false, "id_norma": "1159519", "numero_fuente": "1830", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1830-03-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1830-03-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1830-03-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones"