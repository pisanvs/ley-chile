{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ELENA DISSET Lei n&#xFA;m. 331.-Santiago, a 15 de Enero de 1896.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947552}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se declara, por gracia, que do&#xF1;a Elena Disset, viuda del subteniente don Antonio Diaz, tiene todos los derechos que le otorgar&#xED;an las leyes si su marido hubiera obtenido el permiso necesario para contraer matrimonio.</div><br><br></div>", "i": 5947553}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.-JORJE MONTT.- Luis Barros Borgo&#xF1;o. </div></div>", "i": 5947554}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "331", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-331"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "ELENA DISSET", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ELENA DISSET", "BENEFICIO POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-01-15", "doble_articulado": false, "id_norma": "22182", "numero_fuente": "5584", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1896-12-18", "vigencias": [{"desde": "1896-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1896-12-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1896-12-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], 