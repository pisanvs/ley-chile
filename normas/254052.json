{"html": [{"t": "<div><div class=\"p\">REASUME MANDO DEL ESTADO</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de septiembre de 2006.- Hoy se decret&#xF3; lo que sigue:</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 1.031.- Visto: Lo dispuesto en los art&#xED;culos 29&#xBA; y 32&#xBA;, N&#xBA; 7 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 8374530}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Con ocasi&#xF3;n de mi regreso al pa&#xED;s a contar de esta fecha reasumo el mando del Estado.</div><br></div>", "i": 8374531}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- MICHELLE BACHELET JERIA, Presidenta de la Rep&#xFA;blica.- Belisario Velasco Baraona, Ministro del Interior.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud., para su conocimiento.- Saluda atte. a Ud., Felipe Harboe Bascu&#xF1;&#xE1;n, Subsecretario del Interior.</div><br></div>", "i": 8374532}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1031", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1031"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARIA DEL INTERIOR"], "titulo_norma": "REASUME MANDO DEL ESTADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTA DE LA REPUBLICA", "MICHELLE BACHELET JERIA", "MANDO DE LA NACION", "REASUNCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-09-12", "doble_articulado": false, "id_norma": "254052", "numero_fuente": "38587", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-10-13", "vigencias": [{"desde": "2006-10-13", "hasta": "