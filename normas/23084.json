{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,036 que declara vijente la lei n&#xFA;m.</div><div class=\"p\">1,992, de 27 de agosto de 1907, desde su promulgacion en el &quot;Diario Oficial&quot;.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,036.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7165476}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se declara que la lei n&#xFA;m. 1,992, de 27 de agosto de 1907, rije desde su publicacion en el Diario Oficial.</div><br></div>", "i": 7165477}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 9 de setiembre de 1907.- PEDRO MONTT.- Guillermo Subercaseaux.</div><br></div>", "i": 7165478}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2036", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2036"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LEI NÚM. 2,036 QUE DECLARA VIJENTE LA LEI NÚM. 1,992, DE 27 DE AGOSTO DE 1907, DESDE SU PROMULGACION EN EL DIARIO OFICIAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHOS", "INTERNACION", "ALMACENAJE", "CAJA CREDITO", "SALITRERO", "REMISION FONDOS EXTRANJERO", "VIGENCIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-09-09", "doble_articulado": false, "id_norma": "23084", "numero_fuente": "8898", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-09-11", "vigencia