{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; &quot;PROYECTO DE LEY:</div><br><br></div>", "i": 7169586}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.o Suplem&#xE9;ntase en trescientos cincuenta mil pesos ($ 350,000), el &#xED;tem 04/k, Cap&#xED;tulo 09, Partida 061, del Ministerio de Hacienda vigente. </div></div>", "i": 7169587}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2.o Este gasto ser&#xE1; financiado con el cargo de un uno por mil sobre el producto neto y los servicios de los empr&#xE9;stitos, que, no siendo fiscales, se contraten y sirvan por intermedio de la Tesorer&#xED;a General de la Rep&#xFA;blica.</div><br></div>", "i": 7169588}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 3.o La disposici&#xF3;n a que se refiere el art&#xED;culo 2.o de esta ley ser&#xE1; de car&#xE1;cter permanente. </div></div>", "i": 7169589}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 4.o Esta Ley empezar&#xE1; a regir desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 7169590}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y, por cuanto, he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a seis de Diciembre de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Manuel Barros C. </div></div>", "i": 7169591}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4713", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4713"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O", "1929", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-12-06", "doble_articulado": false, "id_norma": "24851", "numero_fuente": "15544", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-12-10", "vigencias": [{"desde": "1929-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-12-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1929-12-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "IMH", "fecha_ingreso": "1999-03-12", "fecha_version": "1929-12-10", "fecha_actualizacion_texto": "1929-12-10", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 7169586}, {"n": "Artículo 1", "i": 7169587, "t": 6}, {"n": "Artículo 2", "i": 7169588, "t": 6}, {"n": "Artículo 3", "i": 7169589, "t": 6}, {"n": "Artículo 4", "i": 7169590, "t": 6}, {"n": "Promulgación", "i": 7169591}]}