{"html": [{"t": "<div><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DO&#xD1;A MARIA DEL CARMEN MARDONES GALAZ</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6421268}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, una pensi&#xF3;n de $ 40.000 mensuales a do&#xF1;a Mar&#xED;a del Carmen Mardones Galaz.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande esta ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda. </div></div>", "i": 6421269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a cinco de Noviembre de mil novecientos cincuenta y nueve.- JORGE ALESSANDRI RODRIGUEZ.- Roberto Vergara H.</div><br></div>", "i": 6421270}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13732", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13732"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DOÑA MARIA DEL CARMEN MARDONES GALAZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1959-11-05", "doble_articulado": false, "id_norma": "209496", "numero_fuente": "24508", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1959-12-02", "vigencias": [{"desde": "1959-12-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "195