{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A EMPRESA AGROCOMERCIAL JARPA LIMITADA </div></div>", "i": 6559899}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional del SII, por resoluci&#xF3;n de DRE09.00 N&#xBA; Ex. 18, de fecha 16 de enero de 2006, revoca, a contar de la fecha de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado del cambio de sujeto en las operaciones de Venta de Carne otorgado a la empresa Agrocomercial Jarpa Limitada, RUT N&#xBA; 78.521.080-8, conforme a lo establecido en el resolutivo N&#xBA; 16 de la resoluci&#xF3;n N&#xBA; 3.722 de 23.07.2000 de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del d&#xED;a 01.08.2000.</div><br></div>", "i": 6559900}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Octavio Sep&#xFA;lveda Becker, Director Regional (S). </div></div>", "i": 6559901}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "18 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-18 EXENTA"}, {"tipo": "3", "numero": "DRE-09-00-18 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-09-00-18 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A EMPRESA AGROCOMERCIAL JARPA LIMITADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-16", "doble_articulado": false, "id_norma": "246967", "numero_fuente": "38379", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-02-02", "vigencias": [{"desde": "2006-02