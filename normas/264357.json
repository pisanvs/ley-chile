{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7352481}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 457, de fecha 29 de junio de 2007, se expropi&#xF3; el lote de terreno N&#xBA; 22, superficie 223.4 m2, Rol N&#xBA; 182-6, comuna de Quilicura, Regi&#xF3;n Metropolitana para la obra: &quot;Mejoramiento del Cauce del Estero Las Cruces&quot;. Comunas de Quilicura y Pudahuel, Provincia de Santiago, Regi&#xF3;n Metropolitana, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Mackenna y Mackenna S.A., ascendente a la cantidad de $8.159.015. </div></div>", "i": 7352482}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 7352483}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "457", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-457"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-29", "doble_articulado": false, "id_norma": "264357", "numero_fuente": "38853", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-09-01", "vigencias": [{"desde": "2007-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2007-09-03", "fecha_version": "2007-09-01", "fecha_actualizacion_texto": "2007-09-01", "tipo_tratado": ""}, "alertas"