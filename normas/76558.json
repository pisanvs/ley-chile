{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8307099}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.345, de 21 de octubre de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstruucci&#xF3;n, decl&#xE1;rase la caducidad parcial de la Resoluci&#xF3;n N&#xBA; 362, de 1997, de esta Subscretar&#xED;a, que autoriz&#xF3; a&nbsp; PESQUERA SANTA INES S.A., para desarrollar actividades pesqueras extractivas con la nave &quot;Cavancha&quot;, en lo relativo a las especies: Anchoveta y Sardina espa&#xF1;ola, en el litoral comprendido entre la III a la IV Regi&#xF3;n, en virtud de no haber operado sobre estas unidades de pesquer&#xED;as y de conformidad a lo dispuesto en el art&#xED;culo 143 letra b) de la Ley N&#xBA; 18.892 de 1989.</div><br></div>", "i": 8307100}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de octubre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8307101}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1345", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1345"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA SANTA INES S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-10-21", "doble_articulado": false, "id_norma": "76558", "numero_fuente": "35902", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-10-28", "vigencias": [{"desde": "1997-10-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"i