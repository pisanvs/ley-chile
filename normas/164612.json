{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6262058}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta N&#xB0; 1.261 de 03 de Octubre de 1985, conforme Art.</div><div class=\"p\">5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento de aguas proporcionales que corresponden a Sector expropiado predio &quot;Hijuela Tercera del Plano de Hijuelaci&#xF3;n del Fundo Cuesta Vieja&quot; de la comuna de Curacav&#xED;, Regi&#xF3;n Metropolitana; y derechos aprovechamiento de aguas que corresponden a las parcelas N&#xB0;s. 1 a la 6 Sitios N&#xB0; 1 al 7 del proyecto de parcelaci&#xF3;n &quot;Cuesta Vieja&quot; formado por predio se&#xF1;alado. Los derechos de agua se extraen del Canal Las Mercedes. Publicaci&#xF3;n hecha conforme Art. 13 Ley N&#xB0; 18.377. </div></div>", "i": 6262059}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6262060}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1261 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1261 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHO DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-10-03", "doble_articulado": false, "id_norma": "164612", "numero_fuente": "32296", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-10-15", "vigencias": [{"desde": "1985-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-10-15", "fin_v