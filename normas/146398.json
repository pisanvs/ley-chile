{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 3,491.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 7255633}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Sustit&#xFA;yese el art&#xED;culo 14 de la lei de 16 de setiembre de 1884 por el siguiente:</div><div class=\"p\">&nbsp; &nbsp;  &quot;Art. 14. No se podr&#xE1; exceder la suma fijada en cada &#xED;tem o partida de los presupuestos de gastos&quot;. </div></div>", "i": 7255634, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a treinta de enero de mil novecientos diecinueve.- Juan Luis Sanfuentes.- Luis Claro Solar. </div></div>", "i": 7255635}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3491", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3491"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1919-01-30", "doble_articulado": false, "id_norma": "146398", "numero_fuente": "12288", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1919-02-04", "vigencias": [{"desde": "1919-02-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1919-02-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1919-02-04", "fin_vigencia": "", "tipo_version": "3"}