{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6441735}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 829, de 31 de julio de 2003, se expropiaron los lotes de terreno N&#xBA;s 55-A, 77-A y 78-A, superficie 672 m2., 18.377,00 m2. y 2.264,00 m2., roles de aval&#xFA;o 278-9 y en tr&#xE1;mite, comuna de Pelluhue, para la obra Camino Chovell&#xE9;n-Cobquecura, Sector Chovell&#xE9;n-L&#xED;mite Regional, tramo Km. 18,260.00 a Km. 35,158.60, S&#xE9;ptima Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Jacinto Vega Pav&#xE9;s o Jacinto Vega Pavez, ascendente a la cantidad total de $37.590.655.</div><br></div>", "i": 6441736}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6441737}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "829", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-829"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-07-31", "doble_articulado": false, "id_norma": "215273", "numero_fuente": "37673", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-10-01", "vigencias": [{"desde": "2003-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-10-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2003-10-01", "fecha_version": "2003-10-01", "fecha