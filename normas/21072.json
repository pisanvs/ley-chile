{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 364 EXENTO, DE 1994 </div></div>", "i": 5944057}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 364 de 17 de agosto de 1994, se han aprobado, a contar del a&#xF1;o escolar 1994, al establecimiento particular denominado &quot;Liceo Max Planck&quot; de Vi&#xF1;a del Mar, V Regi&#xF3;n de Valpara&#xED;so, planes especiales de estudio para la Educaci&#xF3;n B&#xE1;sica y Media Human&#xED;stico-Cient&#xED;fica de Adultos.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa de estudio para la asignatura de Computaci&#xF3;n.</div><br></div>", "i": 5944058}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 26 de Septiembre de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 5944059}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "364", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-364"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 364 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LICEO MAX PLANCK", "VI A DEL MAR", "QUINTA REGION", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-08-17", "doble_articulado": false, "id_norma": "21072", "numero_fuente": "34984", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-10-06", "vigencias": [{"desde": "1994-10-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-10-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-10-06", "fin_vigencia"