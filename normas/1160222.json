{"html": [{"t": "<div><div class=\"p\">&#xFEFF;COMISION CIENTIFICA.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Octubre 8 de 1830.</div></div>", "i": 10255162}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Para los efectos que se indican en la contrata celebrada por el Gobierno con don Claudio Gai en 14 de setiembre &#xFA;ltimo, nombro en comision a don Jos&#xE9; Alejo Bezanilla, a don Francisco Garc&#xED;a Huidobro y a don Jos&#xE9; Vicente Bustillos, a cuyo cargo queda el desempe&#xF1;o de las obligaciones que le impone dicha contrata. Rem&#xED;tase a cada uno de los nombrados un ejemplar de ella, y comun&#xED;quese este nombramiento.</div></div>", "i": 10255163}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  OVALLE.</div><br><div class=\"p\">&nbsp; &nbsp;  Portales.</div></div>", "i": 10255164}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "COMISION CIENTIFICA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1830-10-08", "doble_articulado": false, "id_norma": "1160222", "numero_fuente": "1830", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1830-10-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1830-10-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1830-10-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "17616", "fecha_ingreso": "2021-07-27", "fecha_version": "1830-10-08", "fecha_actualizacion_text