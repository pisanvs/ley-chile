{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Considera al departamento de Linares como de segundo &#xF3;rden para los efectos del pago de patentes</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,518.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275302}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Para el efecto del pago de las patentes, en conformidad a la lei de 22 de Diciembre de 1866, as&#xED;gnase al departamento de Lin&#xE1;res el segundo &#xF3;rden de los establecidos por el art&#xED;culo 20 de dicha lei.</div><br></div>", "i": 8275303}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 26 de Julio de 1911.- RAMON BARROS LUCO.- Rafael Orrego.</div><br></div>", "i": 8275304}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2518", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2518"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONSIDERA AL DEPARTAMENTO DE LINARES COMO DE SEGUNDO ORDEN PARA LOS EFECTOS DEL PAGO DE PATENTES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LINARES", "DEPARTAMENTO", "PATENTES", "PAGO", "CLASIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-07-26", "doble_articulado": false, "id_norma": "23343", "numero_fuente": "10049", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-08-05", "vigencias": [{"desde": "1911-08-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-08-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-08-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-02-12", "fecha_version": "1911-08-05", "fecha_actualizacion_texto": "1911-08-05", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8275302}, {"n": "Artículo UNICO", "i": 8275303, "t": 6}, {"n": "Promulgación", "i": 8275304}]}