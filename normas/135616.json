{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,618.- Santiago, 30 de setiembre de 1903.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6166007}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Decl&#xE1;rase de abono al sarjento-mayor graduado don Antonio Mar&#xED;a Torres, para los efectos de su retiro, el tiempo que estuvo separado del servicio desde el 31 de diciembre de 1890 hasta el 11 de marzo de 1895.</div><br></div>", "i": 6166008}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- C&#xE1;rlos Besa.</div><br></div>", "i": 6166009}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1618", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1618"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1903-09-30", "doble_articulado": false, "id_norma": "135616", "numero_fuente": "7718", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1903-10-03", "vigencias": [{"desde": "1903-10-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1903-10-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1903-10-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-04-28", "fecha_version": "1903-10-03",