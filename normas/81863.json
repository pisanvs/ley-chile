{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6060906}, {"t": "<div><div class=\"p\">Por Decreto M.O.P. No. 161, de 17 de Julio de 1991, se expropiaron los lotes de terreno N&#xB0;s. 18, 21 y 24, superficies 1.840, 2.380 y 2.475 m2., respectivamente, Roles de Aval&#xFA;os 503-4 y 546-116, Comuna de Santa Cruz, para la ejecuci&#xF3;n de la obra Camino Santa Cruz - Lolol - Bucalemu, Rol I-72, Sector Santa Cruz, Cuesta La Lajuela y se acord&#xF3; el precio de las indemnizaciones con sus propietarios se&#xF1;ores Luis Valenzuela Pino y Jos&#xE9; Manuel Mu&#xF1;oz Mu&#xF1;oz, ascendente a las cantidades d&#xE9; $ 526.645.- para el lote 18 y $ 1.012.436.- para los lotes 21 y 24.-</div><br></div>", "i": 6060907}, {"t": "<div><div class=\"p\">Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 6060908}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "161", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-161"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-07-17", "doble_articulado": false, "id_norma": "81863", "numero_fuente": "34058", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-09-02", "vigencias": [{"desde": "1991-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-09-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "ALV", "fecha_ingreso": "1997-12-30", "fecha_version"