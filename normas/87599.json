{"html": [{"t": "<div><div class=\"p\">REASUME MANDO DEL ESTADO</div><br><div class=\"p\">Santiago, 03 de Agosto de 1991.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">N&#xFA;m. 740.- Visto: Lo dispuesto en los art&#xED;culos 29&#xB0; y 32&#xB0;, No. 8 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile, </div><div class=\"p\">Decreto:</div><br></div>", "i": 8318550}, {"t": "<div><div class=\"p\">Con ocasi&#xF3;n de mi regreso al pa&#xED;s, a contar de esta fecha reasumo el Mando del Estado.</div><br></div>", "i": 8318551}, {"t": "<div><div class=\"p\">T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica, Enrique Krauss Rusque, Ministro del Interior.</div><div class=\"p\">Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Belisario Velasco Baraona, Subsecretario del Interior. </div></div>", "i": 8318552}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "740", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-740"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARIA DEL INTERIOR"], "titulo_norma": "REASUME MANDO DEL ESTADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-08-03", "doble_articulado": false, "id_norma": "87599", "numero_fuente": "34048", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-08-21", "vigencias": [{"desde": "1991-08-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-08-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-08-21", "fin_vigencia": "", "tipo_version": "3"}]