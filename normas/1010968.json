{"html": [{"t": "<div><br><div class=\"p\">MODIFICA CONCESI&#xD3;N DE ACUICULTURA</div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n 2.259, de 19 de noviembre de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div></div>", "i": 8870393}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  I.- Modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=246492&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n (M) 1.490, de 27 de octubre de 2005</a>, en el sentido de reemplazar el p&#xE1;rrafo 4 por el siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;4.- El concesionario deber&#xE1; dar cabal cumplimiento al Proyecto T&#xE9;cnico y Cronograma de Actividades, aprobado por resoluci&#xF3;n exenta N&#xBA; 2.359, de 27 de julio de 2005 y modificada por resoluci&#xF3;n exenta 1.281, de 9 de abril de 2009, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, Subsecretar&#xED;a de Pesca.&quot;</div></div>", "i": 8870394}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de enero de 2010.- Por la Sra. Subsecretaria, Gonzalo Campos Narducci, Subjefe Subsecretar&#xED;a de Marina Subrogante.</div></div>", "i": 8870395}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2259", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2259"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "MODIFICA CONCESIÓN DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-11-19", "doble_articulado": false, "id_norma": "1010968", "numero_fuente": "39585", "tipo_version": "3", "tipo_version_s": "Ú