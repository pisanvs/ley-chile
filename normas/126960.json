{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8336525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;1.521, de 3 de noviembre de 1998, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 11 de la resoluci&#xF3;n N&#xBA;1.157 de 1991, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA QUINTERO S.A., en el sentido de se&#xF1;alar que la resoluci&#xF3;n N&#xBA;128 de 1983, de esta Subsecretar&#xED;a, se deja sin efecto solamente en cuanto autoriz&#xF3; la operaci&#xF3;n de la nave &apos;&apos;Goden Wind&apos;&apos;. </div></div>", "i": 8336526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de noviembre de 1998.- Edith Saa Collantes, Subsecretario de Pesca (S).</div><br></div>", "i": 8336527}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1521", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1521"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A ''CIRCULO DE LOS ONCE'' PARA REALIZAR COLECTA PUBLICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA QUINTERO S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-03", "doble_articulado": false, "id_norma": "126960", "numero_fuente": "36208", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-11-07", "vigencias": [{"desde": "1998-11-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-11-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-11-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci