{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 237 EXENTO, DE 1996 </div></div>", "i": 7161268}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 237 de fecha 24 de abril de 1996 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Esucomex, las adecuaciones a los planes y programas de estudios de la carrera de Contabilidad, modific&#xE1;ndose, en consecuencia, la Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xB0; 1873 de 1995. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1996. </div></div>", "i": 7161269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 11 de junio de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161270}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "237", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-237"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 237 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA ESUCOMEX", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-04-24", "doble_articulado": false, "id_norma": "20762", "numero_fuente": "35498", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-06-22", "vigencias": [{"desde": "1996-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-06-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-06-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "