{"html": [{"t": "<div><div class=\"p\"> </div><div class=\"p\">MODIFICA MONTOS A PERCIBIR POR PR&#xC1;CTICOS DE PUERTO AUTORIZADOS</div></div>", "i": 9652268}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n DGTM. y MM. Ord. exenta N&#xBA; 12.100/78 Vrs., del 16 de noviembre de 2015, se modifican montos a percibir por pr&#xE1;cticos de puerto autorizados.</div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta circular est&#xE1; publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl).</div><br></div>", "i": 9652269}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de noviembre de 2015.- Iv&#xE1;n Valenzuela Bosne, Contraalmirante LT, Director General subrogante.- Rodrigo Ram&#xED;rez Daneri, Capit&#xE1;n de Nav&#xED;o JT, Jefe Depto. Jur&#xED;dico.</div></div>", "i": 9652270}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "78 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-78 EXENTA"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "MODIFICA MONTOS A PERCIBIR POR PRÁCTICOS DE PUERTO AUTORIZADOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; IdDO 971498"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-11-16", "doble_articulado": false, "id_norma": "1084428", "numero_fuente": "41319", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-11-28", "vigencias": [{"desde": "2015-11-28", "hasta": "", "tipo_version": "3", "tipo_version_s