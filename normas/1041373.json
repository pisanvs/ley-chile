{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.986 EXENTA, DE 19 DE JUNIO DE 2012</div></div>", "i": 9270073}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=236211&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 14.695, de 2004, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; planes y programas especiales de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Colegio Cumbres, comuna de Las Condes, provincia de Santiago, Regi&#xF3;n Metropolitana.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas especiales de estudio para 3&#xBA; a&#xF1;o de Educaci&#xF3;n Media, en el Plan de Formaci&#xF3;n Diferenciada, de los sectores que se indican en la presente resoluci&#xF3;n exenta.</div></div>", "i": 9270074}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de junio de 2012.- Ver&#xF3;nica Simpson Cifuentes, Jefa (S) Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 9270075}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3986 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3986 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.986 EXENTA, DE 19 DE JUNIO DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-19", "doble_articulado": false, "id_norma": "1041373", "numero_fuente": "40299", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-28", "vigencias": [{"desde": "2012-06-28", "hasta": "", "tipo_ver