{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 53 EXENTO, DE 1995</div><br><br></div>", "i": 5940339}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 53 de 13 de enero de 1995, se ha aprobado a contar de 1995, un plan de estudio especial para los cursos de 1&#xB0; a 8&#xB0; a&#xF1;o b&#xE1;sico para el Colegio &quot;Hispano Brit&#xE1;nico&quot; de Iquique.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s se aprueba programa de estudio de la asignatura de Computaci&#xF3;n para los cursos de 1&#xB0; a 8&#xB0; a&#xF1;o b&#xE1;sico y 1&#xB0; y 2&#xB0; nivel de transici&#xF3;n.</div><br></div>", "i": 5940340}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 13 de enero de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5940341}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "53 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-53 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 53 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "COLEGIO HISPANO BRITANICO", "IQUIQUE", "PRIMERA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-01-13", "doble_articulado": false, "id_norma": "19920", "numero_fuente": "35125", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-03-23", "vigencias": [{"desde": "1995-03-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-03-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-03-23", "fin_vigencia": "", "tipo_version": "3"}], "even