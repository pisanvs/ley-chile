{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Condona Municipalidad de Copiap&#xF3;, cr&#xE9;dito por $ 50,000</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 8277218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que condone a la I. Municipalidad de Copiap&#xF3;, el cr&#xE9;dito por cincuenta mil pesos ($ 50,000), que le fu&#xE9; otorgado a virtud de la ley n&#xFA;mero 3,447, de 12 de Diciembre de 1918.</div><br></div>", "i": 8277219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veinticinco de Mayo de mil novecientos veintis&#xE9;is.- E. Figueroa.- Maximiliano Iba&#xF1;ez. </div></div>", "i": 8277220}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4064", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4064"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONDONA MUNICIPALIDAD DE COPIAPO, CREDITO POR $;50,000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDAD", "COPIAPO", "CREDITO", "CONDONACION", "PRESIDENTE DE LA REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1926-05-25", "doble_articulado": false, "id_norma": "24439", "numero_fuente": "14470", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1926-05-26", "vigencias": [{"desde": "1926-05-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}