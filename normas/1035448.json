{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9221125}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.383, de 20 de diciembre de 2011, de esta Subsecretar&#xED;a, autor&#xED;zase el reemplazo de un n&#xFA;mero m&#xE1;ximo de 9 inscripciones vacantes de embarcaciones artesanales, categor&#xED;a bote, en el Registro Pesquero Artesanal de la VI Regi&#xF3;n, categor&#xED;a armador artesanal, secci&#xF3;n pesquer&#xED;a de la especie Merluza com&#xFA;n, arte de espinel o enmalle.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y del Servicio Nacional de Pesca.</div></div>", "i": 9221126}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de diciembre de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9221127}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3383 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3383 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-12-20", "doble_articulado": false, "id_norma": "1035448", "numero_fuente": "40146", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-12-28", "vigencias": [{"desde": "2011-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-12-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-12-