{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6434800}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xBA; 1.710 de 23 de Octubre de 1991, conforme Art.</div><div class=\"p\">5&#xBA; Transitorio C&#xF3;digo de Aguas, determin&#xF3; la divisi&#xF3;n de los Derechos de Aprovechamiento Aguas proporcionales que corresponden al Sector de la Reserva y al Sector expropiado del predio &quot;Porci&#xF3;n de la Hijuela El Molino que ha sido denominada Hijuela A y que se denominar&#xE1; Fundo El Molino Viejo&quot; de la Comuna de Rengo, Provincia de Cachapoal VI Regi&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Los derechos de aguas se extraen de los canales: Canal Apalta o Cerro y Canal Comunidad, ambos derivados del R&#xED;o Cachapoal.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme Art. 13 Ley N&#xBA; 18.377.- </div></div>", "i": 6434801}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Nacional.</div><br></div>", "i": 6434802}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1710 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1710 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-10-23", "doble_articulado": false, "id_norma": "213377", "numero_fuente": "34106", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-02", "vigencias": [{"desde": "1991-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-11-02", "f