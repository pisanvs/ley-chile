{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 8.367 EXENTA, DE 2013</div></div>", "i": 9381444}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 8.367, de 21 de octubre de 2013, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Capacitaciones Ecades Limitada (Ecades Ltda.)&quot;, RUT 76.004.292-7, contenida en la resoluci&#xF3;n exenta N&#xBA; 3.867, de 28 de mayo de 2008, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 3, del art. 21 de la ley 19.518.</div></div>", "i": 9381445}, {"t": "<div><div class=\"p\">&nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (S).</div></div>", "i": 9381446}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8367 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-8367 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 8.367 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-10-21", "doble_articulado": false, "id_norma": "1055609", "numero_fuente": "40695", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-10-30", "vigencias": [{"desde": "2013-10-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-10-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-10-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie