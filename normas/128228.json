{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6142900}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;289, de 16 de marzo de 1998, modificado por el decreto MOP N&#xBA;2.196, de 30 de octubre de 1998, se expropiaron los lotes de terreno N&#xBA;s. 20 y 20-A, superficies 2.620 y 900 M2 respectivamente, roles de aval&#xFA;o 172-1 y 153-40, comuna de Yerbas Buenas, para la obra Camino Ruta L-25, Sector Lisonjera - Yerbas Buenas y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Sociedad Gonz&#xE1;lez Fuentes y C&#xED;a. y Juan Bertucci Ferretti, ascendente a las cantidades de $21.402.600.- para el lote 20 y $1.017.000.- para el lote 20-A.-</div><br></div>", "i": 6142901}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6142902}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "289", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-289"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-03-16", "doble_articulado": false, "id_norma": "128228", "numero_fuente": "36239", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-12-15", "vigencias": [{"desde": "1998-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-12-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1998-12-16", "fec