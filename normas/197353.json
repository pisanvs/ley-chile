{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6378910}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante Resoluci&#xF3;n Ministerial N&#xBA; 33, del 27 de marzo de 2002, se autoriz&#xF3; la existencia y aprob&#xF3; el estatuto de la Cooperativa de Servicios de Transporte de la Sexta Regi&#xF3;n, de la ciudad de Rancagua; en los t&#xE9;rminos que da testimonio el acta constitutiva protocolizada con fecha 4 de marzo de 2002, bajo el N&#xBA; 466, al final de los registros del Notario de Rancagua Sr. Ernesto Montoya Peredo.</div><br><br></div>", "i": 6378911}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Se&#xF1;or Subsecretario.- Carlos Rubio Estay, Jefe Departamento de Cooperativas Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br><br></div>", "i": 6378912}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "33", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-33"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-27", "doble_articulado": false, "id_norma": "197353", "numero_fuente": "37246", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-29", "vigencias": [{"desde": "2002-04-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-04-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-04-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacio