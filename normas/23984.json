{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br></div>", "i": 5955902}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Se concede un suplemento de $ 100,000 al &#xED;tem 652, del presupuesto de Marina para el a&#xF1;o 1918.</div><div class=\"p\">&nbsp; &nbsp; Estos fondos se deducir&#xE1;n del mayor producido por derechos de internacion.</div><br></div>", "i": 5955903}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta de diciembre de mil novecientos dieciocho.- Juan Luis Sanfuentes.- Enrique Berm&#xFA;dez P. </div></div>", "i": 5955904}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3457", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3457"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1918", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1918-12-30", "doble_articulado": false, "id_norma": "23984", "numero_fuente": "12258", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1918-12-30", "vigencias": [{"desde": "1918-12-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1918-12-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1918-12-30", "fin_vigencia": "", "tipo_v