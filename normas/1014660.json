{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 722 EXENTA, DE 2010</div><br></div>", "i": 8934397}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 722, de fecha 12 de mayo de 2010, de esta Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones, se resolvi&#xF3; modificar las resoluciones exentas N&#xBA; 639, de 8 de agosto de 2008 y <a href=\"https://www.leychile.cl/Navegar?idNorma=277424&amp;idParte=0&amp;idVersion=\">N&#xBA; 708, de 1 de septiembre de 2008</a>, que aprueba Planes y Programas y otorga Reconocimiento Oficial, respectivamente, en el sentido de establecer que la nueva representante legal es la Srta. Ver&#xF3;nica del Pilar Jara Fuentealba.- </div><br></div>", "i": 8934398}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Luis R. Calder&#xF3;n Ram&#xED;rez, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de la Araucan&#xED;a.</div><br></div>", "i": 8934399}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "722 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-722 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 722 EXENTA, DE 2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-05-12", "doble_articulado": false, "id_norma": "1014660", "numero_fuente": "39690", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-06-19", "vigencias": [{"desde": "2010-06-19", "hasta": "", "tipo_version": "3"