{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Libera de derecho de aduana las bombas i mangueras que introduzcan para su servicio los Cuerpos de Bomberos de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;n. 2,803.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5954166}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Se autoriza al Presidente de la Rep&#xFA;blica para eximir de derechos de internacion las bombas i mangueras que para el servicio contra incendios introduzcan al pais los Cuerpos de Bomberos de la Rep&#xFA;blica.</div><br></div>", "i": 5954167}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 3 de Setiembre de 1913.- RAMON BARROS LUCO.- Arturo Alessandri.</div><br></div>", "i": 5954168}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2803", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2803"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LIBERA DE DERECHO DE ADUANA LAS BOMBAS I MANGUERAS QUE INTRODUZCAN PARA SU SERVICIO LOS CUERPOS DE BOMBEROS DE LA REPUBLICA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CUERPO BOMBEROS REPUBLICA", "BOMBAS", "MANGUERAS", "DERECHOS ADUANA", "LIBERACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados