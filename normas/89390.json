{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0;. 185, DE 1989</div><br><br><br></div>", "i": 6082425}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 185 de 21 de noviembre de 1989 se ha aprobado para el Colegio T&#xE9;cnico Profesional de La Reina, provincia de Santiago, Regi&#xF3;n Metropolitana, planes y programas especiales de estudio de Educaci&#xF3;n Media, Modalidad T&#xE9;cnico-Profesional que se aplicar&#xE1;n en 3er. a&#xF1;o en 1990 y en 4to, a&#xF1;o en 1991, en las Ramas y Especialidades que se indican:</div><br><div class=\"p\">Rama: Industrial.</div><div class=\"p\">Especialidades:</div><br><div class=\"p\">- Mec&#xE1;nica Automotriz y de Aviaci&#xF3;n - Electromec&#xE1;nica General y de Aviaci&#xF3;n.</div><br><div class=\"p\">Rama: T&#xE9;cnica.</div><div class=\"p\">Especialidad:</div><div class=\"p\">-.Atenci&#xF3;n de P&#xE1;rvulos con menci&#xF3;n en M&#xFA;sica y Expresi&#xF3;n Corporal.</div><br></div>", "i": 6082426}, {"t": "<div><div class=\"p\">Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6082427}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "185 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-185 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N°.185, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-11-21", "doble_articulado": false, "id_norma": "89390", "numero_fuente": "33553", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-12-23", "vi