{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,793.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6173699}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- El vicealmirante don Jorje Montt, gozar&#xE1;, durante su retiro, ademas de la pension a que tiene derecho, de los honores correspondientes al cargo de Director Jeneral de la Armada i de las gratificaciones i asignaciones fijadas actualmente por las leyes a dicho cargo.</div><div class=\"p\">&nbsp; &nbsp;  Gozar&#xE1;, asimismo, de pasaje libre por los Ferrocarriles del Estado.</div><br></div>", "i": 6173700}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a seis de agosto de mil novecientos trece.- Ramon Barros Luco.- Jorje Matte.</div><br></div>", "i": 6173701}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2793", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2793"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1913-08-06", "doble_articulado": false, "id_norma": "137954", "numero_fuente": "10645", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1913-08-07", "vigencias": [{"desde": "1913-08-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1913-08-07", "fin_vigencia": ""}, "vigencias