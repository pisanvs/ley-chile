{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETO N&#xBA;352 EXENTO, DE 2006</div></div>", "i": 9600671}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;335, de 7 de mayo de 2015, de este Ministerio, modif&#xED;case <a href=\"https://www.leychile.cl/Navegar?idNorma=247891&amp;idParte=0&amp;idVersion=\">decreto exento N&#xBA;352, de 2006, del actual Ministerio de Econom&#xED;a, Fomento y Turismo</a>, que estableci&#xF3; el &#xE1;rea de manejo y explotaci&#xF3;n de recursos bent&#xF3;nicos Clavelito en la XV Regi&#xF3;n, en el sentido de regularizar su cartograf&#xED;a, de acuerdo a lo se&#xF1;alado en el decreto extractado.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9600672}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de mayo de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9600673}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "335 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-335 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA DECRETO Nº352 EXENTO, DE 2006", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-05-07", "doble_articulado": false, "id_norma": "1077630", "numero_fuente": "41159", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publi