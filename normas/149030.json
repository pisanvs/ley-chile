{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;mero 4,481</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6210906}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Aum&#xE9;ntase, por gracia, a trescientos pesos mensuales ($ 300), la pensi&#xF3;n de que actualmente disfruta do&#xF1;a Mar&#xED;a Luisa Fr&#xED;as Jim&#xE9;nez, la que continuar&#xE1; gozando con arreglo a la ley de montep&#xED;o militar. </div></div>", "i": 6210907}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y, por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, siete de Diciembre de mil novecientos veintiocho.- Carlos Ib&#xE1;&#xF1;ez C.- Bm&#xE9; Blanche E. </div></div>", "i": 6210908}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4481", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4481"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-12-07", "doble_articulado": false, "id_norma": "149030", "numero_fuente": "15243", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-12-07", "vigencias": [{"desde": "1928-12-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-12-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1928-12-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": []