{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 251, DE 1987 </div></div>", "i": 6177296}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 251 de 18 de diciembre de 1987 se ha aprobado para el Liceo Industrial A No. 16 de Antofagasta, Provincia de Antofagasta, II Regi&#xF3;n de Antofagasta, planes y programas especiales de estudio para la Educaci&#xF3;n Media, modalidad T&#xE9;cnico - Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar 1988 y hasta el a&#xF1;o escolar de 1993, en las especialidades de:</div><div class=\"p\">1.- Minas y Mineralurg&#xED;a con menci&#xF3;n en explotaci&#xF3;n de minas.</div><div class=\"p\">2.- Minas y Mineralurg&#xED;a con menci&#xF3;n en Mineralurg&#xED;a. </div></div>", "i": 6177297}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de Enero de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6177298}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "251 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-251 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 251, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-12-18", "doble_articulado": false, "id_norma": "139017", "numero_fuente": "32988", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-05", "vigencias": [{"desde": "1988-02-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-05", "fin_vige