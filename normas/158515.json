{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6242076}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 36, del 17 de Abril de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la XIIa. Regi&#xF3;n, Magallanes y Ant&#xE1;rtica Chilena, se autoriza al Sr. Ram&#xF3;n Baltazar Gallardo Vargas, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6242077}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mario Salgado Jim&#xE9;nez, Secretario Regional Ministerial de Transportes y Telecomunicaciones, XIIa. Regi&#xF3;n, Subrogante.</div><br></div>", "i": 6242078}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "36 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-36 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XII REGIÓN DE MAGALLANES Y ANTÁRTICA CHILENA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-04-17", "doble_articulado": false, "id_norma": "158515", "numero_fuente": "32468", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-05-12", "vigencias": [{"desde": "1986-05-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-05-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-05-12"