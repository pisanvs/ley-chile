{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9737766}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.435, de 23 de septiembre 2016, de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n parcial, conforme art&#xED;culo 51 Ley 16.391, de inmueble ubicado en Col&#xF3;n 820, Rol Aval&#xFA;o N&#xBA; 265-24, comuna Curic&#xF3;, superficie 19,05 metros cuadrados, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Suc. G&#xF3;mez Rojas Isabelina. Comisi&#xF3;n integrada por peritos Patricio Dur&#xE1;n Marcos, Arquitecto; Pedro Pablo Cruz Weston, arquitecto; Rodrigo Silva Lazo, constructor civil, seg&#xFA;n informe de 22 septiembre de 2016, fij&#xF3; monto provisional indemnizaci&#xF3;n en $16.252.000.-, pagados al contado.- </div></div>", "i": 9737767}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Omar Guti&#xE9;rrez Mesina, Director Serviu Regi&#xF3;n del Maule. </div><br></div>", "i": 9737768}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3435 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3435 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "VII REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1117387", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-09-23", "doble_articulado": false, "id_norma": "1095210", "numero_fuente": "41573", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-10-01", "vigencias": [{"desde": "2016-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia":