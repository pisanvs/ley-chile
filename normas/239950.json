{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6532453}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.996, de 29 de junio de</div><div class=\"p\">2005, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA ISLA</div><div class=\"p\">QUIHUA S.A. para ampliar actividades pesqueras</div><div class=\"p\">extractivas con la nave &quot;Terranova&quot;, en orden a realizar</div><div class=\"p\">actividades pesqueras extractivas entre la V a VII</div><div class=\"p\">Regiones y en la IX Regi&#xF3;n, por fuera de reserva</div><div class=\"p\">artesanal, con cerco, sobre los recursos hidrobiol&#xF3;gicos Pampanito, Bacaladillo o mote y Jibia.</div><br></div>", "i": 6532454}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de junio de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6532455}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1996 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1996 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-29", "doble_articulado": false, "id_norma": "239950", "numero_fuente": "38205", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-08", "vigencias": [{"desde": "2005-07-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-07-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p