{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9094889}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;3.857, de 23 de diciembre de 2010, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 2&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=205268&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.595, de 2002</a>, de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a LEYLA IBET LAMA ORTIZ para iniciar actividades pesqueras extractivas con la nave &quot;Luc&#xED;a&quot;, en el sentido de actualizar la siguiente caracter&#xED;stica n&#xE1;utica de la nave:</div><br><div class=\"p\">&nbsp; &nbsp;  Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 29,84 m.</div></div>", "i": 9094890}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de diciembre de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9094891}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3857 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3857 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2010-12-23", "fecha_derogacion": "2017-02-22", "doble_articulado": false, "id_norma": "1021872", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2011-01-07", "vigencias": [{"desde": "2017-02-22", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2011-01-07", "hasta": "2017-02-21", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vige