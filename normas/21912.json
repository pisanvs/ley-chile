{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Ba&#xF1;os termales de Chillan Lei n&#xFA;m. 39.- Santiago, a 14 de Junio de 1893.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 8273651}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se escept&#xFA;an de lo dispuesto en el art. 3.&#xB0; transitorio de la lei de Municipalidades de 22 de Diciembre de 1891, los ba&#xF1;os termales i terrenos adyacentes que la Municipalidad de Chillan posee en la cordillera de este nombre.</div><br><br></div>", "i": 8273652}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Pedro Montt.</div><br></div>", "i": 8273653}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "39", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-39"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "BAÑOS DE CHILLAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CHILLAN", "MUNICIPALIDAD", "BA OS TERMALES", "ENAJENACION", "EXCEPCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-06-14", "doble_articulado": false, "id_norma": "21912", "numero_fuente": "4544", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-06-14", "vigencias": [{"desde": "1893-06-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-06-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-06-14", "fin_vigencia": "", "tipo_version": "3"}], "event