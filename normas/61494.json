{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8301788}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 269, de 19 de febrero de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a SALMONES TECMAR S.A., para continuar desarrollando las actividades de cultivo autorizadas por Resoluciones N&#xBA; 1.299, de 1988, y N&#xBA; 6, de 1992, ambas de esta Subsecretar&#xED;a, a Salmones del Navegante S.A., de mismos R.U.T. y domicilio, en virtud de la Escritura P&#xFA;blica de fecha 4 de enero de 1996, otorgada ante el Notario P&#xFA;blico de Santiago, don Kamel Saquel Zaror, que fusion&#xF3; la sociedad &quot;Salmones del Navegante S.A.&quot; con &quot;Salmones Tecmar S.A.&quot;.</div><br></div>", "i": 8301789}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de febrero de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8301790}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "269", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-269"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "SALMONES TECMAR S.A.", "PESCA", "SALMONES DEL NAVEGANTE S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-02-19", "doble_articulado": false, "id_norma": "61494", "numero_fuente": "35710", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-03-07", "vigencias": [{"desde": "1997-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"ini