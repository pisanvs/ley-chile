{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 183</div><br><div class=\"p\">Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n No. 183, celebrada el 26 de diciembre de 1991, adopt&#xF3; los siguientes acuerdos:</div><br></div>", "i": 6074207}, {"t": "<div><div class=\"p\">183-18-911226- Modifica Cap&#xED;tulo XIII del T&#xED;tulo I del Compendio de Normas de Cambios Internacionales.</div><br><div class=\"p\">Se acord&#xF3; modificar el Cap&#xED;tulo XIII &quot;L&#xED;neas de Cr&#xE9;dito Externas&quot; del T&#xED;tulo I del Compendio de Normas de Cambios Internacionales como sigue:</div><div class=\"p\">- Eliminar en la letra g) del No. 1, la frase: &quot;Estos Cr&#xE9;ditos ser&#xE1;n de plazos iguales o inferiores a 180 d&#xED;as.&quot; </div></div>", "i": 6074208}, {"t": "<div><div class=\"p\">Santiago, 26 de diciembre de 1991.- V&#xED;ctor Vial del R&#xED;o, Secretario General.</div><br></div>", "i": 6074209}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "183", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-183"}, {"tipo": "5", "numero": "183-18", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-183-18"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 183", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-12-26", "doble_articulado": false, "id_norma": "86786", "numero_fuente": "34152", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-12-27", "vigencias": [{"desde": "1991-