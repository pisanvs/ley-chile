{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO NUMERO 10/1546, DE 2001</div><br><br></div>", "i": 6344210}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Municipalidad de Vitacura, mediante decreto alcaldicio N&#xBA; 10/1546 de fecha 27 de junio de 2001, modific&#xF3; el cap&#xED;tulo VIII, art&#xED;culo N&#xBA; 3 transitorio de la Ordenanza de Propaganda y Publicidad por el siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;Los propietarios de avisos colocados sin autorizaci&#xF3;n municipal, deber&#xE1;n regularizar su situaci&#xF3;n en un plazo no mayor al 31 de diciembre de 2001, a contar de la entrada en vigencia de la modificaci&#xF3;n de la presente Ordenanza, solicitando el correspondiente permiso y pagando los derechos municipales que proceda. En caso que aqu&#xE9;l no regularice, la Municipalidad proceder&#xE1; a retirar la propaganda o publicidad no autorizada&quot;.</div><br></div>", "i": 6344211}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Alcalde.</div><br></div>", "i": 6344212}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "10", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-10"}, {"tipo": "2", "numero": "10/1546", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-10/1546"}], "organismos": ["MUNICIPALIDAD DE VITACURA"], "titulo_norma": "EXTRACTO DE DECRETO NUMERO 10/1546, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-06-27", "doble_articulado": false, "id_norma": "188043", "numero_fuente": "37023", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-07-28", "vigencias": [{"desde": "2001-07-28", "hasta": "", "tipo_vers