{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.541, DE 1987 </div></div>", "i": 8605802}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.541 de fecha 15 de Julio de 1987 del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se ampli&#xF3; la resoluci&#xF3;n exenta de Educaci&#xF3;n No. 2.349 de 1985 del Centro de Formaci&#xF3;n T&#xE9;cnica Escuela de Administraci&#xF3;n, en el sentido de introducir en el art&#xED;culo 4&#xB0; un nuevo inciso sobre las calificaciones para ser aplicado a partir del presente a&#xF1;o acad&#xE9;mico.-</div><br></div>", "i": 8605803}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 8605804}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1541 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1541 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.541, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-15", "doble_articulado": false, "id_norma": "153130", "numero_fuente": "32865", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-07", "vigencias": [{"desde": "1987-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-09-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAS", "fecha_ingreso": "2000-01-31", "fecha_versi