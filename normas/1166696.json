{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10277182}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 512, de fecha 19 de julio de 2021, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n del Maule, se modifican las resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=1134222&amp;idParte=&amp;idVersion=\">N&#xBA; 883</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1134223&amp;idParte=&amp;idVersion=\">N&#xBA; 887</a>, de fechas 21 y 24 de junio del a&#xF1;o 2019, respectivamente, ambas de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n del Maule, en el sentido de reemplazar en ambas resoluciones exentas donde se&#xF1;alan: &quot;representada legalmente por don Carlos Mart&#xED;nez Trujillo&quot;, por lo siguiente: &quot;representada legalmente por don Franco Nicol&#xE1;s C&#xF3;rdoba Mardones, RUT: 20.468.608-4&quot;.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10277183}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Carlos Miguel Palacios Maldonado, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n del Maule.</div><div class=\"p\"> </div><br></div>", "i": 10277184}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "512 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-512 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SECRETARÍA REGIONAL MINISTERIAL REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2024730", "EXTRACTO"], "derogacion_tacita": [], "deroga