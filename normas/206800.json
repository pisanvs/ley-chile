{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6410466}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n que suscribe, certifica que la Universidad de Los Andes, inscrita bajo el n&#xFA;mero C-38 del Registro de Universidades del Ministerio de Educaci&#xF3;n, ha presentado los programas de estudio de la carrera de &quot;Medicina&quot; conducente al grado de &quot;Licenciado en Medicina&quot; y al t&#xED;tulo de &quot;M&#xE9;dico Cirujano&quot;, a la Pontificia Universidad Cat&#xF3;lica de Chile, Instituci&#xF3;n que los ha aprobado y se ha constituido como entidad examinadora.</div><br><div class=\"p\">&nbsp; &nbsp;  La carrera mencionada podr&#xE1; impartirse a contar desde 1991.</div><br><br></div>", "i": 6410467}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de Enero de 1991.</div><div class=\"p\">&nbsp; &nbsp;  RAUL ALLARD NEUMANN Subsecretario de Educaci&#xF3;n </div></div>", "i": 6410468}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "DIVISIÓN DE EDUCACION SUPERIOR"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-31", "doble_articulado": false, "id_norma": "206800", "numero_fuente": "33899", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-02-20", "vigencias": [{"desde": "1991-02-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-02-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-02