{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6167817}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP No. 379, de 26 de febrero de 1999, se expropiaron los lotes de terreno No. 2, 3, 4, 5, 6, 7 y 8, superficies 157; 167,5; 2.875; 469; 1.141; 482 y 359,5 m2 respectivamente, roles de aval&#xFA;o 1061-12, 1064-12 y en tr&#xE1;mite, comuna de Vicu&#xF1;a, para la obra Camino Ruta 41-CH, sector Huanta Juntas del Toro y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Carlos Maj&#xED;n Aguirre D&#xED;az, Hugo Orlando Aguirre D&#xED;az, V&#xED;ctor Hugo Rojas N&#xFA;&#xF1;ez, ascendentes a las cantidades de $ 626.182, para el lote No. 2; $ 378.609, para el lote No. 3 y $ 2.789.634, para los lotes No. s. 4, 5, 6, 7 Y 8.-</div><br></div>", "i": 6167818}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6167819}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "379", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-379"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-02-26", "doble_articulado": false, "id_norma": "136162", "numero_fuente": "36353", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-05-03", "vigencias": [{"desde": "1999-05-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-05-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-05-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincula