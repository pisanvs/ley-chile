{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6577642}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.986, de 13 de julio de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a ALIMENTOS MULTIEXPORT S.A., para ampliar las actividades pesqueras de transformaci&#xF3;n autorizadas por las resoluciones citadas en Visto, en orden a incorporar a la planta ubicada en camino Fundo San Miguel s/n, Colina, Regi&#xF3;n Metropolitana, en las l&#xED;neas de proceso de Alga Seca, Deshidratado, Alga compactada y Alga picada los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6577643}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de julio de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6577644}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1986 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1986 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-13", "doble_articulado": false, "id_norma": "251741", "numero_fuente": "38526", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-07-29", "vigencias": [{"desde": "2006-07-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-07-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-07-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_