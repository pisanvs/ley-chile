{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO NUMERO 489 EXENTO, DE 1993 </div></div>", "i": 5944849}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0;489 de fecha 23 de Septiembre de 1993 del Ministerio de Educaci&#xF3;n, se aprobaron las modificaciones introducidas al plan y programas de estudio del Centro de Formaci&#xF3;n T&#xE9;cnica ICECOOP, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida en la ciudad de Santiago, a contar de agosto de 1993, con la siguiente denominaci&#xF3;n:</div><div class=\"p\"> Carrera:&nbsp; Administraci&#xF3;n de Cooperativas</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  cambia por:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Administraci&#xF3;n de Empresas.</div><div class=\"p\"> T&#xED;tulo: T&#xE9;cnico en Administraci&#xF3;n de Empresas.</div><br></div>", "i": 5944850}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 8 de Abril de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5944851}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "489", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-489"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO NUMERO 489 EXENTO, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "CENTRO FORMACION TECNICA", "ICECOOP", "ADMINISTRACION EMPRESAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-09-23", "doble_articulado": false, "id_norma": "21342", "numero_fuente": "34843", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion