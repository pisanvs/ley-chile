{"html": [{"t": "<div><div class=\"p\">ESTABLECE PROCEDIMIENTO PARA PAGO DE IMPUESTO QUE INDICA</div></div>", "i": 10147553}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 87, de fecha 30 de julio de 2020, establece procedimiento para pago del impuesto a las ventas y servicios que se haya postergado conforme lo dispuesto en Res. Ex. SII <a href=\"https://www.leychile.cl/Navegar?idNorma=1144402&amp;idParte=&amp;idVersion=\">N&#xB0; 41</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1147421&amp;idParte=&amp;idVersion=\">N&#xB0; 77</a> de 2020, en virtud de importaciones aceptadas a tr&#xE1;mite en los meses que indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento est&#xE1; publicado en &quot;www.sii.cl&quot;.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10147554}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fernando Javier Barraza Luengo, Director Nacional.</div><div class=\"p\"> </div><br></div>", "i": 10147555}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "87 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-87 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ESTABLECE PROCEDIMIENTO PARA PAGO DE IMPUESTO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": ["CORONAVIRUS COVID-19", "CORONAVIRUS", "COVID-19"], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1794416", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-07-30", "doble_articulado": false, "id_norma": "1148071", "numero_fuente": "42723", "tipo_version": "3", "tipo_version_s": "Única", "f