{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6468360}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 495, de 24 de febrero de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD BAKKAVOR CHILE S.A., para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en Parcela N&#xBA; 65, Lote Ruze, Porvenir, provincia de Tierra del Fuego, XII Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n Alga seca, Deshidratado, Fresco enfriado, Fresco refrigerado, Congelado, Cocido, Seco salado, Ahumado, Conserva, Harina, Fresco-Cocido-Pasteurizado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6468361}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Valpara&#xED;so, 24 de febrero de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6468362}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "495 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-495 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-24", "doble_articulado": false, "id_norma": "222288", "numero_fuente": "37808", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-11", "vigencias": [{"desde": "2004-03-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-03-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-03-11