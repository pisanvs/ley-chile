{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6516740}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 263, de 27 de enero de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a SAUL EDUARDO VEGA ZAMBRA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Avenida Guanaqueros N&#xBA; 677, Tongoy, Coquimbo, IV Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco Enfriado, Fresco Refrigerado y Congelado los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6516741}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de enero de 2005.- Edith Saa Collantes, Subsecretario de Pesca (S).</div><br></div>", "i": 6516742}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "263 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-263 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-01-27", "doble_articulado": false, "id_norma": "235724", "numero_fuente": "38093", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-02-22", "vigencias": [{"desde": "2005-02-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-02-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-02-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingres