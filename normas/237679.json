{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6524462}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;1.223, de 26 de abril de 2005 de esta Subsecretar&#xED;a, autor&#xED;zase a INVERSIONES PROCUR LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Ruta N&#xBA;68, N&#xBA;1240, Placilla de Pe&#xF1;uelas, Valpara&#xED;so, V Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso Congelado y Fresco-enfriado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6524463}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de abril de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6524464}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1223 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1223 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-04-26", "doble_articulado": false, "id_norma": "237679", "numero_fuente": "38154", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-05-06", "vigencias": [{"desde": "2005-05-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-05-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-05-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "20