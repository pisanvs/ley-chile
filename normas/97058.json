{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8328254}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 257, de 18 de febrero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud presentada por don ATILIO DEL CARMEN REYES BARRERA, de autorizaci&#xF3;n para iniciar actividades pesqueras extractivas con la nave &quot;Chubasco I&quot;, por no darse cumplimiento a lo dispuesto en el art&#xED;culo 1&#xBA; de la ley N&#xBA; 19.516, al no estar actualmente inscrita en el Registro Nacional de Pescadores Artesanales, secci&#xF3;n merluza com&#xFA;n, entre la V y IX regiones con red de arrastre.</div><br></div>", "i": 8328255}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de febrero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8328256}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "257", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-257"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "ATILIO DEL CARMEN REYES BARRERA", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-02-18", "doble_articulado": false, "id_norma": "97058", "numero_fuente": "36000", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-02-25", "vigencias": [{"desde": "1998-02-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-02-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v