{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Recompensas militares.- Se prorroga por un a&#xF1;o el plazo se&#xF1;alado para tramitar los espedientes Lei n&#xFA;m. 9.-</div><div class=\"p\">&nbsp; &nbsp; Santiago, 25 de Enero de 1893.- Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7162398}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Prorr&#xF3;gase por un a&#xF1;o el plazo fijado por el art&#xED;culo 32 de la lei de 22 de Diciembre de 1881, puesta en vijencia por la de 9 de Enero de 1892.</div><br><br></div>", "i": 7162399}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Francisco A. Pinto.</div><br></div>", "i": 7162400}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "9", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-9"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "RECOMPENSAS MILITARES.  SE PRORROGA POR UN AÑO EL PLAZO SEÑALADO PARA TRAMITAR LOS ESPEDIENTES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECOMPENSAS MILITARES", "PENSIONES", "EXPEDIENTES", "PRESENTACION", "PLAZO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-01-25", "doble_articulado": false, "id_norma": "21884", "numero_fuente": "4432", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-01-25", "vigencias": [{"desde": "1893-01-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-01-25", "fin_vigencia": ""}, "vigencias_ver