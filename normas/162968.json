{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6257000}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n de la Fiscal&#xED;a del Ministerio de Obras P&#xFA;blicas F. N&#xB0; 64 de 25 de Junio de 1985, se ha ordenado pagar la suma de $ 32.353 a don Gonzalo Urrejola Unzueta o a quien acredite derecho como valor del 100% del aval&#xFA;o fijado por la Comisi&#xF3;n de Hombres Buenos, m s su reajuste, para los lotes N&#xB0;s. 1, 2, 3 y 4, de una superficie de 1.190 m2., 910 m2., 1.280 m2., y 1.110 m2., respectivamente, para Acceso al Puente Brazo, camino Confluencia - &#xF1;ipas, comuna de Portezuelo, VIII Regi&#xF3;n. Se deja constancia que el plazo para reclamar judicialmente del aval&#xFA;o es el determinado por el art&#xED;culo 12 del decreto ley N&#xB0; 2.186, de 1978. </div></div>", "i": 6257001}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6257002}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "64", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-64"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-25", "doble_articulado": false, "id_norma": "162968", "numero_fuente": "32244", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-08-09", "vigencias": [{"desde": "1985-08-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-08-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-08-09", "fin_vigencia": "", "tipo_version":