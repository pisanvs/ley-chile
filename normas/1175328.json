{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10329211}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xBA; 93, de 19 de enero de 2022, Instruye al Departamento Agencia Nacional de Medicamentos en relaci&#xF3;n a las directrices t&#xE9;cnicas para la realizaci&#xF3;n de la validaci&#xF3;n de procesos productivos farmac&#xE9;uticos mediante el enfoque retrospectivo.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10329212}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mar&#xED;a Judith Mora Riquelme, Directora (S), Instituto de Salud P&#xFA;blica de Chile.</div><br></div>", "i": 10329213}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "93 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-93 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2119263", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-01-19", "doble_articulado": false, "id_norma": "1175328", "numero_fuente": "43237", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-04-26", "vigencias": [{"desde": "2022-04-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2022-04-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2022-04-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vi