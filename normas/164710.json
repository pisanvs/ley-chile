{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6262391}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 20, de fecha 07 de Febrero de 1985, la Secretaria Regional Ministerial de Transportes y Telecomunicaciones, IX Regi&#xF3;n, a autorizado a don Clodomiro Segundo Barriga Barriga, para efectuar toda clase de servicios de transporte de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos de locomoci&#xF3;n colectiva urbana, de acuerdo al cedreto supremo 163/84.</div><br></div>", "i": 6262392}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Temuco, 07 de Febrero de 1985.- Oscar C&#xF3;rdova Jim&#xE9;nez, Secretario Regional Ministerial de Transportes y Telecomunicaciones, IX Regi&#xF3;n.</div><br></div>", "i": 6262393}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "20", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-20"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-02-07", "doble_articulado": false, "id_norma": "164710", "numero_fuente": "32096", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-02-13", "vigencias": [{"desde": "1985-02-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-02-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-02-13", "fin_vigencia": "", "tipo_version": "