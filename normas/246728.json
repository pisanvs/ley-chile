{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6558915}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 183, de 17 de enero de 2006, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.980 de 2003, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA BIO-BIO S.A. para ampliar actividades pesqueras con la nave &quot;Pehuenco&quot;, en el &#xE1;rea mar&#xED;tima correspondiente a la III Regi&#xF3;n y al Archipi&#xE9;lago de Juan Fern&#xE1;ndez, Isla de Pascua, Islas Desventuradas e Islas Sala y G&#xF3;mez, sobre el recurso Alfonsino, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 6558916}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de enero de 2006.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6558917}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "183 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-183 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-17", "doble_articulado": false, "id_norma": "246728", "numero_fuente": "38371", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-01-24", "vigencias": [{"desde": "2006-01-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-01-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-01-24",