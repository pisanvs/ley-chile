{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,571.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6165721}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Ab&#xF3;nase, por gracia, al fiscal de la Corte de Apelaciones de Santiago, don Osvaldo Rodr&#xED;guez Cerda, para los efectos de su jubilacion, los cuatro a&#xF1;os i nueve meses que desempe&#xF1;&#xF3; el cargo de defensor de menores de Santiago, desde octubre de 1880 hasta julio de 1885.</div><br></div>", "i": 6165722}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, de acuerdo con el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, a 15 de diciembre de 1902.- JERMAN RIESCO.- J.D. Amunategui Rivera.</div><br></div>", "i": 6165723}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1571", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1571"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1902-12-15", "doble_articulado": false, "id_norma": "135536", "numero_fuente": "7463", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1902-12-19", "vigencias": [{"desde": "1902-12-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1902-12-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1902-12-19", "fin_vigencia": "", "tipo_version": "3"}],