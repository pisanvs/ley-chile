{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n, por gracia, a la viuda e hijos menores de don Rafael Cantuarias</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5959458}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia a la viuda e hijos menores de don Rafael Cantuarias, el goce de una pensi&#xF3;n mensual de cincuenta pesos, de la que disfrutar&#xE1;n en conformidad a la Ley de Montep&#xED;o Militar. </div></div>", "i": 5959459}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y, por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta de Septiembre de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- J. Eduardo Barrios. </div></div>", "i": 5959460}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4395", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4395"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A LA VIUDA E HIJOS MENORES DE DON RAFAEL CANTUARIAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RAFAEL CANTUARIAS", "DESCENDIENTES", "PENSION GRACIA", "MONTEPIO MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-09-30", "doble_articulado": false, "id_norma": "24707", "numero_fuente": "15199", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-10-16", "vigencias": [{"desde": "1928-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}]