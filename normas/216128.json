{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6444533}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.361, de 7 de octubre de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a COMPA&#xD1;&#xCD;A PESQUERA CAMANCHACA S.A. para realizar actividades extractivas en aguas internacionales con la nave &quot;&nbsp;  Loa 5&quot;&nbsp;  , cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2340-Valpara&#xED;so</div><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CB-2239</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  36,60 m</div><div class=\"p\">T.R.G. (Nacional)&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 266,30</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 346,60 m3</div><div class=\"p\">Potencia motor principal&nbsp; &nbsp;  1000,00 Hp</div><div class=\"p\">Potencia motor auxiliar&nbsp; &nbsp; &nbsp; 129,40 Hp</div><br></div>", "i": 6444534}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de octubre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6444535}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2361 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2361 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-07", "doble_articulado": false, "id_norma": "216128", "nume