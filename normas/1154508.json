{"html": [{"t": "<div><div class=\"p\">P&#xE9;rdida de caballos en el servicio militar</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de Agosto de 1813.</div></div>", "i": 10197968}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Sensible el Gobierno a las p&#xE9;rdidas que han sufrido los soldados milicianos de las divisiones de caballer&#xED;a que marcharon al Ej&#xE9;rcito al principio de la guerra; ha decretado se saque del erario p&#xFA;blico el dinero necesario para comprar inmediatamente dos mil caballos, i distribuirlos entre los soldados que justificaren haber perdido alguno en el servicio militar de la presente campa&#xF1;a. Para que llegue a noticia de los interesados, publ&#xED;quese este decreto en el Monitor.</div></div>", "i": 10197969}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Infante. - P&#xE9;rez. - Ega&#xF1;a, secretario.</div></div>", "i": 10197970}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Pérdida de caballos en el servicio militar", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1813-08-25", "doble_articulado": false, "id_norma": "1154508", "numero_fuente": "1813", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1813-08-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1813-08-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1813-08-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por"