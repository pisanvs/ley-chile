{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 11.197</div><br><div class=\"p\">CONCEDE A DON AUGUSTO GRASSET R. UNA PENSION MENSUAL CUYO MONTO SE&#xD1;ALA</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6931191}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia a don Augusto Grasset Ramos, una pensi&#xF3;n de tres mil pesos ($ 3.000) mensuales.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que significa esta ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda. </div></div>", "i": 6931192}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintitr&#xE9;s de Junio de mil novecientos cincuenta y tres.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Juan B. Rossetti.</div><br></div>", "i": 6931193}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11197", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11197"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE A DON AUGUSTO GRASSET R. UNA PENSION MENSUAL\nCUYO MONTO SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1953-06-23", "doble_articulado": false, "id_norma": "285654", "numero_fuente": "22594", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1953-07-11", "vigencias": [{"desde": "1953-07-11", "hasta": "", "tipo_version": "3", "tipo_v