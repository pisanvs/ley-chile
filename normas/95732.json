{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA</div><br><br><br><br></div>", "i": 8326619}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.184, de 29 de Agosto de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 10&#xB0; de la resoluci&#xF3;n No. 894, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don Roberto Pedro Ib&#xE1;&#xF1;ez Moncada; R.U.T. No. 4.752.615-9, domiciliado en calle Centenario No. 96, Iquique, para ampliar actividades pesqueras que tiene autorizadas por resoluci&#xF3;n No. 142, de 1986, de esta Subsecretar&#xED;a, en la forma que a continuaci&#xF3;n se indica:</div><div class=\"p\">&quot;10.- Deni&#xE9;gase la autorizaci&#xF3;n solicitada por el peticionario para operar en el litoral de la IX Regi&#xF3;n.&quot;. </div></div>", "i": 8326620}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 29 de Agosto de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8326621}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1184", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1184"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1989-08-29", "fecha_derogacion": "1990-02-19", "doble_articulado": false, "id_norma": "95732", "numero_fuente": "33480", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1989-09-25", "vigencias": [{"desde": "1990-02-19", "hasta": "", "tipo_version": "2", "tipo_ver