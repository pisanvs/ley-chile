{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO No. 846, DE 1985</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 414.- Santiago, 22 de Mayo de 1987.- Vistos: Lo dispuesto en el art&#xED;culo 32 n&#xFA;mero 8 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile y en el art&#xED;culo 2&#xB0; de la Ley No. 18.442,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 8603870}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sustit&#xFA;yese en el No. 3 del Decreto No. 846, de 1985., del Ministerio de Hacienda, la expresi&#xF3;n &quot;El 30 de junio de 1987&quot; por &quot;El 31 de agosto de 1987. </div></div>", "i": 8603871}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, registrese, comun&#xED;quese y publ&#xED;quese.- AUGUSTO PINOCHET UGARTE, General de Ej&#xE9;rcito, Presidente de la Rep&#xFA;blica.- Hern&#xE1;n B&#xFC;chi Buc, Ministro de Hacienda.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda atentamente a Ud.- Manuel Concha Mart&#xED;nez, Brigadier de Ej&#xE9;rcito, Subsecretario de Hacienda. </div></div>", "i": 8603872}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "414", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-414"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA DECRETO No. 846, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-05-22", "doble_articulado": false, "id_norma": "145305", "numero_fuente": "32788", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-05", "vigencias": [{"desde": "1987-06-05", "hasta": "", "tipo_version": "3", "tipo_v