{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Ferrocarril de Ancud a Castro Lei n&#xFA;m. 1,453.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949211}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza al Presidente de la Rep&#xFA;blica para que invierta la suma de veinte mil pesos en el estudio de un ferrocarril de trocha angosta de Ancud a la ciudad de Castro.</div><br><br></div>", "i": 5949212}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 19 de Enero de 1901.- FEDERICO ERRAZURIZ E.- Manuel A. Covarrubias.</div><br></div>", "i": 5949213}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1453", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1453"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "Ferrocarril de Ancud a Castro", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ANCUD", "CASTRO", "FERROCARRIL", "PRESIDENTE REPUBLICA", "INVERSION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-01-19", "doble_articulado": false, "id_norma": "22661", "numero_fuente": "6813", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-02-08", "vigencias": [{"desde": "1901-02-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1901-02-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"in