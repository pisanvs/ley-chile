{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6222136}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 1477 de 12 de Agosto de 1987, conforme art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a Parcelas N&#xB0;s. 1 a la 9 sitios N&#xB0;s. 1 al 8 del Proyecto de Parcelaci&#xF3;n &quot;Balmaceda&quot; de la comuna de Bulnes, VIII Regi&#xF3;n formado por predio &quot;Colt&#xF3;n de San Jos&#xE9;, hoy San Jos&#xE9; de Colt&#xF3;n&quot;. Los derechos de agua se extraen de los canales Larqui y Sandoval y Ch&#xE1;vez, derivados todos del r&#xED;o Diguill&#xED;n.</div><div class=\"p\">Publicaci&#xF3;n hecha conforme art. 13 Ley No. 18.377.- </div></div>", "i": 6222137}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6222138}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1477 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1477 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-12", "doble_articulado": false, "id_norma": "152110", "numero_fuente": "32847", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-17", "vigencias": [{"desde": "1987-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-08-17", "fin_vigencia": ""}, "vigencias_version_n