{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede fondos para la publicacion de las sesiones del Senado</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,096.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275933}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Dest&#xED;nase hasta la cantidad de cuarenta mil pesos ($ 40,000) a los gastos que orijine la publicacion de las sesiones del Senado en la prensa diaria de Santiago, en la forma que determine la Comision de Polic&#xED;a Interior de esta C&#xE1;mara. </div></div>", "i": 8275934}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 29 de Abril de 1916.- JUAN LUIS SANFUENTES._ Maximiliano Ib&#xE1;&#xF1;ez.</div><br></div>", "i": 8275935}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3096", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3096"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE FONDOS PARA LA PUBLICACION DE LAS SESIONES DEL SENADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SESIONES DEL SENADO", "FONDOS", "DESTINACION", "PUBLICACIONES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-04-29", "doble_articulado": false, "id_norma": "23733", "numero_fuente": "11466", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-05-08", "vigencias": [{"desde": "1916-05-08", "hasta": "", "tipo_version": "3",