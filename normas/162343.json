{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6255070}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 230 de 12 de Septiembre de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la 1ra. Regi&#xF3;n se autoriza a Segundo Severo D&#xED;az Aros para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6255071}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Juan W. Flaquer Hern&#xE1;ndez, Secretario Regional Ministerial de Transportes y Telecomunicaciones, 1ra. Regi&#xF3;n Tarapac&#xE1;.</div><br></div>", "i": 6255072}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "230", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-230"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-09-12", "doble_articulado": false, "id_norma": "162343", "numero_fuente": "32277", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-09-21", "vigencias": [{"desde": "1985-09-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-09-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-09-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu