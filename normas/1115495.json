{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Escepcion a favor de los mineros</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 28 de 1819.</div></div>", "i": 9902435}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se ordena a los gobernadores de las provincias i sus tenientes cumplan exactamente con lo mandado por punto jeneral sobre que los mineros no deben ser pensionados en reclutas para el ej&#xE9;rcito, ni para la marina ni en prorratas, quedando responsables por su infraccion a los males que resulten.-</div></div>", "i": 9902436}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  O&apos;Higgins.- Echeverr&#xED;a </div></div>", "i": 9902437}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Escepcion a favor de los mineros", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1819-07-28", "doble_articulado": false, "id_norma": "1115495", "numero_fuente": "1819", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1819-07-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1819-07-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1819-07-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2018-04-04", "fecha_version": "1819-07-28", "fecha_actualizacion_texto": "2018-04-04", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9902435}, {"n": "Artículo", "i": 9