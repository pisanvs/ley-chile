{"html": [{"t": "<div><div class=\"p\">NOTIFICACION </div></div>", "i": 7341222}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.861, de 10 de abril de 2007, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme DL N&#xBA; 2.186 de 1978, del Lote N&#xBA; 193, correspondiente a parte del inmueble ubicado en Las Industrias N&#xBA; 5945, Rol de Aval&#xFA;o N&#xBA; 5931-18, comuna de San Joaqu&#xED;n, aparente dominio de Teresa Rom&#xE1;n Galpi. Comisi&#xF3;n integrada por peritos se&#xF1;ores Mario Castillo Fuentes, arquitecto; Leonardo Bast&#xED;as Tessada, constructor civil y Francisco Recabarren Solar, ingeniero civil. Seg&#xFA;n informe de 24 de octubre de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $3.199.936, pagadera al contado.</div><br></div>", "i": 7341223}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 7341224}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1861 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1861 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENAN EXPROPIACIONES DE INMUEBLES QUE INDICAN; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-04-10", "doble_articulado": false, "id_norma": "260522", "numero_fuente": "38752", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-05-02", "vigencias": [{"desde": "2007-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-05-02", "fin_vig