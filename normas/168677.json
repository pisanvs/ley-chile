{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6275345}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;965, de 30 de marzo del 2000, se expropi&#xF3; el lote de terreno N&#xBA;2, superficie 6.943 m2, rol de aval&#xFA;o 2202-57, comuna de Chill&#xE1;n Viejo, para la obra Concesi&#xF3;n Internacional Ruta 5; Tramo:</div><div class=\"p\">Talca-Chill&#xE1;n, Octava Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Edith Margot Romero Donoso, ascendente a la cantidad de $46.755.412. </div></div>", "i": 6275346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6275347}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "965", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-965"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-03-30", "doble_articulado": false, "id_norma": "168677", "numero_fuente": "36663", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-15", "vigencias": [{"desde": "2000-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-05-15", "fecha_version": "2000-05-15", "fecha_actualizacion_texto": "2000-05-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Enc