{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6223205}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 830 de 27 de Junio de 1986, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a Sector Expropiado Predio &quot;Las Mercedes de Catemu&quot; de la comuna de Catemu V Regi&#xF3;n; y Derechos Aprovechamiento Aguas que corresponden a 10 parcelas N&#xB0;s. 1 a la 10, sitios A y B del Proyecto de Parcelaci&#xF3;n &quot;Las Mercedes&quot; formado por predio se&#xF1;alado. &quot;Los Derechos de Agua se extraen del canal &quot;Catemu del Bajo&quot; proveniente de la segunda secci&#xF3;n del R&#xED;o Aconcagua. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.</div><br></div>", "i": 6223206}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Ejecutivo.</div><br></div>", "i": 6223207}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "830 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-830 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTOS DE AGUAS QUE\nINDICAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-27", "doble_articulado": false, "id_norma": "152463", "numero_fuente": "32510", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-07-01", "vigencias": [{"desde": "1986-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-07-01", "fin_vigencia": ""}, "v