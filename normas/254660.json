{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6587700}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.628, de 13 de septiembre de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a HAIGREEN CHILE S.A., para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Bernardo O&apos;Higgins N&#xBA;80, Placilla, Valpara&#xED;so, V Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco Enfriado, Fresco Refrigerado, Congelado, Seco Salado y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6587701}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de septiembre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6587702}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2628 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2628 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-09-13", "doble_articulado": false, "id_norma": "254660", "numero_fuente": "38601", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-10-30", "vigencias": [{"desde": "2006-10-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-10-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-10-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul