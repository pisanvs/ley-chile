{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9359916}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.471, de 12 de junio de 2013, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la <a href=\"https://www.leychile.cl/Navegar?idNorma=260578&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.180, de 2007</a>, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA B&#xCD;O B&#xCD;O S.A., para ampliar actividades pesqueras extractivas con la nave en construcci&#xF3;n &quot;BEC 1180/07&quot;, respecto de los recursos hidrobiol&#xF3;gicos Jibia y Congrio dorado en el &#xE1;rea mar&#xED;tima comprendida entre la V a VII Regiones, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum citado en Visto de la resoluci&#xF3;n extractada.</div></div>", "i": 9359917}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de junio de 2013.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9359918}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1471 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1471 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-06-12", "doble_articulado": false, "id_norma": "1052032", "numero_fuente": "40587", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-06-18", "vigencias": [{"desde": "2013-06-18", "hasta": "", "tipo_