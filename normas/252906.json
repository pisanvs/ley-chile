{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6581674}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.028, de 18 de julio de 2006 de esta Subsecretar&#xED;a, autor&#xED;zase al SINDICATO DE TRABAJADORES INDEPENDIENTES DE LA PESCA ARTESANAL, BUZOS MARISCADORES Y ACTIVIDADES CONEXAS CALETA CERRO VERDE, para ampliar las actividades pesqueras de transformaci&#xF3;n autorizadas por la resoluci&#xF3;n citada en visto, en orden a incorporar a la planta ubicada en calle El Faro, Pasaje N&#xBA;2 s/n, Cerro Verde Bajo, comuna de Penco, VIII Regi&#xF3;n, en las l&#xED;neas de proceso de congelado y conserva, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6581675}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de julio de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6581676}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2028 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2028 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-18", "doble_articulado": false, "id_norma": "252906", "numero_fuente": "38557", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-09-05", "vigencias": [{"desde": "2006-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-09-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-09-05", "fin_vige