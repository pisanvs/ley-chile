{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; JULIO R. MORAGA Lei n&#xFA;m. 286.-Santiago, a 16 de Julio de 1895.-Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947417}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, al teniente coronel retirado del Ej&#xE9;rcito don Julio R. Moraga, derecho a optar a los beneficios que acuerda la lei de 2 de Febrero de 1892.</div><br><br></div>", "i": 5947418}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.- Jorje Montt.- C&#xE1;rlos Rivera Jofr&#xE9;.</div><br></div>", "i": 5947419}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "286", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-286"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "JULIO R. MORAGA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JULIO R MORAGA", "BENEFICIOS", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-07-16", "doble_articulado": false, "id_norma": "22139", "numero_fuente": "5165", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-07-20", "vigencias": [{"desde": "1895-07-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-07-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1895-07-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-01-25", "fecha_v