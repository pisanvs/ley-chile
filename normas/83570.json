{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6065691}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica, a requerimiento de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante, para los efectos de lo dispuesto en el Art&#xED;culo N&#xBA; 116 del Decreto Supremo de la Subsecretar&#xED;a de Marina N&#xBA; 427, de 25 de junio de 1979, que la variaci&#xF3;n experimentada por el Indice de Precios al Consumidor de los Estados Unidos de Am&#xE9;rica, entre el 1&#xBA; de diciembre de 1996 y el 30 de noviembre de 1997, fue de 1,8%.</div><br></div>", "i": 6065692}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de diciembre de 1997. Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6065693}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INDICE DE PRECIOS AL CONSUMIDOR", "ESTADOS UNIDOS DE AMERICA", "IPC", "VARIACION 1", "8%"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-17", "doble_articulado": false, "id_norma": "83570", "numero_fuente": "35945", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-12-20", "vigencias": [{"desde": "1997-12-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-12-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-12-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "GMR", "fecha_ingreso": "1998-01-09",