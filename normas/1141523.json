{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10095588}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 5.930, de 31 de diciembre de 2019, de este Servicio, se establece fecha de inicio para la entrada en vigencia del Sistema de Fiscalizaci&#xF3;n del Descarte, por parte del Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n indicada, se encuentra publicado con esta fecha en el sitio de dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y de la Subsecretar&#xED;a de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10095589}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En Valpara&#xED;so, a 31 de diciembre de 2019.- Alicia Gallardo Lagno, Directora Nacional, Servicio Nacional de Pesca y Acuicultura.</div><br></div>", "i": 10095590}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5930 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5930 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1715430; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-12-31", "doble_articulado": false, "id_norma": "1141523", "numero_fuente": "42561", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-01-24", "vigencias": [{"desde": "2020-01-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenc