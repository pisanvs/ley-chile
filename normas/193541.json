{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 956 EXENTO, DE 2001 </div></div>", "i": 7288936}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 956, de 21 de noviembre de 2001, se han modificado algunos nombres de los Colegios que integran la Asociaci&#xF3;n de Colegios Alemanes de Chile, citados en los decretos supremos exentos de Educaci&#xF3;n N&#xBA;s. 236 de 1997 y 456 de 1999 que les aprobaron planes y programas especiales de estudio para la Ense&#xF1;anza B&#xE1;sica.</div><br></div>", "i": 7288937}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de diciembre de 2001.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7288938}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "956 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-956 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 956 EXENTO, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-21", "doble_articulado": false, "id_norma": "193541", "numero_fuente": "37159", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-14", "vigencias": [{"desde": "2002-01-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JRC", "fecha_ingreso": "2002-01-14", "fecha_v