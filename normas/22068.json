{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; BENIGNO PE&#xD1;A Lei n&#xFA;m. 210.-Santiago, a 1.&#xB0; de Octubre de 1894.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947168}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Consid&#xE9;rase, para los efectos de las leyes de 22 e Diciembre de 1881 i de 9 de Enero de 1892, que don Benigno Pe&#xF1;a ha muerto en accion de guerra con el empleo de subteniente de Ej&#xE9;rcito.</div><br><br></div>", "i": 5947169}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORGE MONTT.-S. Aldunate B.</div><br></div>", "i": 5947170}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "210", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-210"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "BENIGNO PEÑA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BENIGNO PE A", "MUERTE ACTO SERVICIO", "RECONOCIMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-10-01", "doble_articulado": false, "id_norma": "22068", "numero_fuente": "4936", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-10-11", "vigencias": [{"desde": "1894-10-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-10-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-10-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v