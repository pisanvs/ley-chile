{"html": [{"t": "<div><br><div class=\"p\">EXIME A CONTRIBUYENTE DEL TIMBRAJE DE PAGAR&#xC9;S Y FIJA REQUISITOS EN SU REEMPLAZO</div></div>", "i": 9669018}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 4, de 20 de enero de 2016, que;</div><div class=\"p\">&nbsp; &nbsp;  Exime a Santander Consumer Chile S.A., de la obligaci&#xF3;n de timbraje de pagar&#xE9;s establecida en el Art. 17 Inc. 2&#xBA; del DL N&#xBA; 3.475, de 1980, y fija requisitos en su reemplazo para resguardar el inter&#xE9;s fiscal.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de enero de 2016.</div></div>", "i": 9669019}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXIME A CONTRIBUYENTE DEL TIMBRAJE DE PAGARÉS Y FIJA REQUISITOS EN SU REEMPLAZO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 992287; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-01-20", "doble_articulado": false, "id_norma": "1087074", "numero_fuente": "41369", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-01-29", "vigencias": [{"desde": "2016-01-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2016-01