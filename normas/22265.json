{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei que autoriza Inversion de Fondos Lei n&#xFA;m. 917.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7162722}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de cuarenta i cinco mil pesos en el pago de las cantidades que se consignan en el cuadro adjunto.</div><br><br></div>", "i": 7162723}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 23 de Febrero de 1897.- FEDERICO ERRAZURIZ.- C. Morla Vicu&#xF1;a.</div><br></div>", "i": 7162724}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "917", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-917"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "LEI QUE AUTORIZA INVERSION DE FONDOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTE REPUBLICA", "FACULTAD", "INVERSION FONDOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-02-23", "doble_articulado": false, "id_norma": "22265", "numero_fuente": "5642", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1897-02-27", "vigencias": [{"desde": "1897-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1897-02-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig