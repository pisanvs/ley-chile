{"html": [{"t": "<div><div class=\"p\">@@</div></div>", "i": 8624182}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 194, de 15 de enero de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a INVERTEC OSTIMAR S.A. para desarrollar actividades experimentales de cultivo sobre la especie Macrocystis sp., cuyo objetivo general consiste en desarrollar en forma experimental su cultivo en mar, en sistema suspendido, en la Regi&#xF3;n de Coquimbo.</div><div class=\"p\">&nbsp; &nbsp;  Las actividades se desarrollar&#xE1;n por el t&#xE9;rmino de 2 a&#xF1;os, en la concesi&#xF3;n de acuicultura otorgada a la peticionaria por resoluci&#xF3;n N&#xB0; 855 de 2000, de la Subsecretar&#xED;a de Marina, ubicada en Bah&#xED;a Tongoy, IV Regi&#xF3;n.</div><br></div>", "i": 8624183}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de enero de 2009.- Mar&#xED;a &#xC1;ngela Barbieri Bellolio, Subsecretaria de Pesca (S). </div></div>", "i": 8624184}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "194 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-194 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-01-15", "doble_articulado": false, "id_norma": "287275", "numero_fuente": "39288", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-02-14", "vigencias": [{"desde": "2009-02-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-02-14", "fin_vigencia": ""}, "vigencias_version_norm