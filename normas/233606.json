{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 788 EXENTO, DE 2004 </div></div>", "i": 6509049}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 788, de fecha 22 de septiembre de 2004, de Educaci&#xF3;n, se revoca la autorizaci&#xF3;n de funcionamiento de la Sede de Curacaut&#xED;n del Instituto Profesional Andali&#xE9;n.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, se deroga el decreto exento de Educaci&#xF3;n N&#xBA; 51 del 23 de enero de 2003, que autoriz&#xF3; el funcionamiento de la Sede de Curacaut&#xED;n al Instituto Profesional Andali&#xE9;n.</div><br></div>", "i": 6509050}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de noviembre de 2004.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6509051}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "788 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-788 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 788 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-09-22", "doble_articulado": false, "id_norma": "233606", "numero_fuente": "38037", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-16", "vigencias": [{"desde": "2004-12-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-12-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-12-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingre