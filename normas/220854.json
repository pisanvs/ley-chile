{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 14 EXENTA, DE 2004 </div></div>", "i": 6462255}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 14 del 29 de enero de 2004 que dispone obligaci&#xF3;n de presentar Declaraci&#xF3;n Jurada sobre aportes entregados a organismos t&#xE9;cnicos intermedios de capacitaci&#xF3;n, si el 1% de las Remuneraciones Imponibles es menor o igual a 13 UTM de diciembre del a&#xF1;o comercial correspondiente</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio Web del Servicio de Impuestos Internos (www.sii.cl) y, dem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en enero de 2004.</div><br></div>", "i": 6462256}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "14 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-14 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 14 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONTRIBUYENTES", "DECLARACION JURADA", "APORTES DE CAPACITACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-29", "doble_articulado": false, "id_norma": "220854", "numero_fuente": "37777", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-04", "vigencias": [{"desde": "2004-02-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-02-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-02-04", "fin_v