{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.591 EXENTO, DE 6 DE SEPTIEMBRE DE 2011</div></div>", "i": 9179674}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento que se indica del Ministerio de Educaci&#xF3;n, se modifica el art&#xED;culo 3&#xBA; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1016959&amp;idParte=0&amp;idVersion=\">decreto exento de Educaci&#xF3;n N&#xBA; 1.362, del 3 de septiembre de 2010</a>, que revoca el reconocimiento oficial del Centro de Formaci&#xF3;n T&#xE9;cnica Ignacio Domeyko U.L.S., de la ciudad de la Serena. La modificaci&#xF3;n tiene como &#xFA;nico objeto permitir la finalizaci&#xF3;n de los procesos de titulaci&#xF3;n pendientes de la instituci&#xF3;n, hasta el t&#xE9;rmino del primer semestre 2011. para los alumnos rezagados de dicho proceso.</div></div>", "i": 9179675}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de septiembre de 2011.- Fernando Rojas Ochagav&#xED;a, Subsecretario de Educaci&#xF3;n.</div></div>", "i": 9179676}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1591 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1591 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.591 EXENTO, DE 6 DE SEPTIEMBRE DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-09-06", "doble_articulado": false, "id_norma": "1029540", "numero_fuente": "40058", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-09-10", "vigencias": [{"desde": "2011-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic