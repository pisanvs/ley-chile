{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6484391}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;1.635, de 11 de junio de 2004, de</div><div class=\"p\">esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA; inciso 1&#xBA;</div><div class=\"p\">letra b) de la resoluci&#xF3;n N&#xBA; 871 de 2004, modificada</div><div class=\"p\">mediante resoluci&#xF3;n N&#xBA; 970 de 2004, ambas de esta</div><div class=\"p\">Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO</div><div class=\"p\">PESQUERO para efectuar una pesca de investigaci&#xF3;n de</div><div class=\"p\">conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del</div><div class=\"p\">Proyecto denominado &quot;Caracterizaci&#xF3;n de la captura de</div><div class=\"p\">pez espada (Xiphias gladius) realizada por la flota</div><div class=\"p\">artesanal de las Regiones I a X&quot;, en el sentido de extender hasta el 30 de junio de 2004, el plazo para la inscripci&#xF3;n de las embarcaciones artesanales interesadas en participar en la presente pesca de investigaci&#xF3;n. </div></div>", "i": 6484392}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de junio de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6484393}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1635", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1635"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-06-11", "doble_articulado": false, "id_norma": "22669