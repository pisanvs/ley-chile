{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCIONES N&#xBA; 27, DE 1984, Y N&#xBA;193, DE 1992 </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 153.- Santiago, 28 de julio de 1998.- Vistos: Lo dispuesto en el Art. 11 del decreto ley N&#xBA; 2.974 de 1979.</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br><br><br></div>", "i": 7237391}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case la resoluci&#xF3;n N&#xBA; 27 de 6 de marzo de 1984 en orden a eliminar al se&#xF1;or Jos&#xE9; Sep&#xFA;lveda Mardones de la n&#xF3;mina de Receptores Judiciales, y la resoluci&#xF3;n N&#xBA; 193 de 27 de junio de 1992 en cuanto se excluye como Receptor Judicial al se&#xF1;or Juan B. Lav&#xED;n Z&#xFA;&#xF1;iga.</div><br></div>", "i": 7237392}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Luis Marambio Canales, Director Nacional.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud., para su conocimiento.- Encargado Oficina de Partes.</div><br></div>", "i": 7237393}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "153", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-153"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "MODIFICA RESOLUCIONES Nº 27, DE 1984, Y Nº193, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO DE DESARROLLO AGROPECUARIO", "RECEPTORES JUDICIALES", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-28", "doble_articulado": false, "id_norma": "123264", "numero_fuente": "36144", "tipo_version": "3", "tipo_version_s": "Única", "fecha_public