{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY 9,311, EN RELACION CON LA EMISION DE BONOS</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5967536}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se declara que el art&#xED;culo 32 de la ley N.o 9,311, de 4 de Febrero de 1949, no afecta a lo dispuesto en el art&#xED;culo 2.o de la ley N.o 9,073, pudiendo, en consecuencia, emitirse los bonos necesarios para dar cumplimiento a lo prescrito en esta &#xFA;ltima ley. </div></div>", "i": 5967537}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a seis de Julio de mil novecientos cincuenta.- GABRIEL GONZALEZ VIDELA.- Carlos Vial E. </div></div>", "i": 5967538}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "9626", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-9626"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA LA LEY 9,311, EN RELACION CON LA EMISION DE\nBONOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BONOS", "EMISION", "IMPUESTO EXTRAORDINARIO", "COBRE", "PLAN EXTRAORDINARIO", "OBRAS PUBLICAS", "LICEO NI AS N 1", "SANTIAGO AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1950-07-06", "doble_articulado": false, "id_norma": "26194", "numero_fuente": "21698", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1950-07-08", "vigencias": [{"desde": "1950-07-08", "hasta": 