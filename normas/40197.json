{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DELEGA FACULTADES QUE INDICA </div></div>", "i": 6026151}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Mediante Resoluci&#xF3;n N&#xB0; Exenta 2.474 de fecha 9 de junio de 1994, el Director Regional ha delegado en el Jefe de la Oficina Jur&#xED;dica Regional de esta Direcci&#xF3;n Regional, las funciones descritas en los N&#xB0;s. 1 al 8 del dispositivo Primero de la parte de la Resoluci&#xF3;n N&#xB0; Ex.</div><div class=\"p\">2.482 de la Direcci&#xF3;n Nacional de fecha 03.06.94, publicada en extracto en el D.O. de fecha 06.06.94, revoc&#xE1;ndose, adem&#xE1;s, el p&#xE1;rrafo correspondiente de la Resoluci&#xF3;n N&#xB0; Ex. 1.030 de fecha 21.08.81, D.O. de 26.08.81.- Angel Mena Zapata, Director Regional. </div></div>", "i": 6026152}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento y fines consiguientes.- Lilian Tapia Concha, Secretaria Regional.</div><br></div>", "i": 6026153}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2474 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2474 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO PONIENTE"], "titulo_norma": "DELEGA FACULTADES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DELEGACION", "FACULTAD", "DIRECTOR REGIONAL", "OFICINA", "JURIDICA REGIONAL", "JEFE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-06-09", "doble_articulado": false, "id_norma": "40197", "numero_fuente": "34895", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-06-21", "vigencias": [{"desde": "1994-06-21", "hasta