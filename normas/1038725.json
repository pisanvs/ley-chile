{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 2.929 EXENTA, DE 2012</div><br></div>", "i": 9246822}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.929, de 26 de marzo de 2012, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Centro de Capacitaci&#xF3;n de Yoga Hari Nam Limitada (Yogatec Ltda.)&quot;, RUT 76.032.777-8, contenida en la resoluci&#xF3;n exenta N&#xBA; 9.324, de 5 de noviembre de 2009, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del art. 21 de la ley 19.518.</div></div>", "i": 9246823}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  - Francisco Ag&#xFC;ero Larrondo, Director Nacional Subrogante.</div><br></div>", "i": 9246824}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2929 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2929 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 2.929 EXENTA, DE 2012", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2012-03-26", "fecha_derogacion": "2012-07-25", "doble_articulado": false, "id_norma": "1038725", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2012-04-04", "vigencias": [{"desde": "2012-07-25", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2012-04-04", "hasta": "2012-07-24", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2012-07-25", "fin_vige