{"html": [{"t": "<div><br><div class=\"p\">DEJA SIN EFECTO RESOLUCI&#xD3;N N&#xBA; 115 EXENTA, DE 2010</div></div>", "i": 9259197}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 64, del 18 de mayo de 2012, que se&#xF1;ala:</div><div class=\"p\">&nbsp; &nbsp;  Deja sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=1015703&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n Ex. SII N&#xBA; 115, de 23 de julio de 2010</a>, y dispone la revocaci&#xF3;n de toda delegaci&#xF3;n de facultad obrada por el Director de Grandes Contribuyentes en cumplimiento de la resoluci&#xF3;n que se deja sin efecto.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de mayo de 2012.</div><br></div>", "i": 9259198, "v": ["MODIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "64 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-64 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEJA SIN EFECTO RESOLUCIÓN Nº 115 EXENTA, DE 2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-18", "doble_articulado": false, "id_norma": "1040334", "numero_fuente": "40269", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-05-24", "vigencias": [{"desde": "2012-05-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "v