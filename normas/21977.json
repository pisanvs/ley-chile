{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Estado de Sitio Lei n&#xFA;m. 112.- Santiago, a 30 de Octubre de 1893.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273725}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Der&#xF3;gase la lei de 29 de Abril &#xFA;ltimo que autoriz&#xF3; al Presidente de la Rep&#xFA;blica hasta el 31 de Diciembre del corriente a&#xF1;o, para ejercer en las provincias de Aconcagua, Valparaiso, Santiago i O&apos;Higgins las facultades que otorga el art&#xED;culo 152 de la Constitucion.</div><br><br></div>", "i": 8273726}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Pedro Montt.</div><br></div>", "i": 8273727}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "112", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-112"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "ESTADO DE SITIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ACONCAGUA", "VALPARAISO", "SANTIAGO", "O'HIGGINS", "PRESIDENTE REPUBLICA", "FACULTADES", "DEROGACION", "CONSTITUCION POLITICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-10-30", "doble_articulado": false, "id_norma": "21977", "numero_fuente": "4656", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-10-30", "vigencias": [{"desde": "1893-10-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-10-30", "fin_vigencia": ""}, "vigencias_version_no