{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10275979}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xBA; 1.001, de 23 septiembre 2021, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos que indica en condiciones que se&#xF1;ala, relativas al encuentro recreativo con ni&#xF1;os Sector La Balsa en Puerto Ays&#xE9;n, y autoriz&#xF3; Direcci&#xF3;n del Programa Quiero Mi Barrio de la I. Municipalidad de Ays&#xE9;n para realizar siguiente intervenci&#xF3;n en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - Corte total de v&#xED;a en calle Angamos entre calles Teniente Merino y Merino Jarpa, el d&#xED;a domingo 26 de septiembre entre las 14:00 y las 17:00 hrs.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10275980}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andrea Mac&#xED;as Palma, Gobernadora Regional, Gobierno Regional de Ays&#xE9;n.- Ximena Guti&#xE9;rrez Jaramillo, Asesora Jur&#xED;dica, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10275981}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1001 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1001 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2024052", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-09-23", "doble_articulado": false, "id_norma": "1166420", "numero_fuente": "43077", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-10-14", "vigencias": [{"desde": "