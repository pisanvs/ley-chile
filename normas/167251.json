{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 367, DE 1990 </div></div>", "i": 6270724}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 367 de 27 de diciembre de 1990 se ha aprobado, a partir del a&#xF1;o escolar 1991, un plan de estudio al Colegio Guillermo Gonz&#xE1;lez Heinrich No. 4 de Santiago para 1&#xB0; a 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio para la asignatura de Historia y Geograf&#xED;a de Chile para 1&#xB0; a 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica. </div></div>", "i": 6270725}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 5 de Marzo de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6270726}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "367 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-367 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 367, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-27", "doble_articulado": false, "id_norma": "167251", "numero_fuente": "33917", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-03-13", "vigencias": [{"desde": "1991-03-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-03-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-03-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vin