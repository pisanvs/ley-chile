{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6205379}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;189, de 30 de septiembre de 1999, de Serviu Regi&#xF3;n de Coquimbo, se orden&#xF3; expropiaci&#xF3;n, conforme art. 51 ley 16.391 y D.L. 2.186 de 1978, de parte del inmueble ubicado en calle Amun&#xE1;tegui N&#xBA;427 presunto Rol de aval&#xFA;o 162-138 comuna de La Serena, aparente dominio do&#xF1;a Miriam L. Trigo G., de una superficie aproximada de 50,467 metros cuadrados. Comisi&#xF3;n Peritos integrada por don Patricio Mena L&#xF3;pez, Alfredo Prieto Parra y do&#xF1;a Iris Marcich Moller, arquitectos, seg&#xFA;n informe de 14 de septiembre de 1999, fij&#xF3; monto provisional indemnizaci&#xF3;n en $2.637.309 pagadera al contado.-</div><br></div>", "i": 6205380}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n de Coquimbo.</div><br></div>", "i": 6205381}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "189", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-189"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "IV REGIÓN DE COQUIMBO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-09-30", "doble_articulado": false, "id_norma": "147694", "numero_fuente": "36514", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-11-15", "vigencias": [{"desde": "1999-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-11-15", "fin_vigen