{"html": [{"t": "<div><div class=\"p\">FIJA TARIFA DE ASEO QUE INDICA </div></div>", "i": 6700774}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se comunica a los usuarios del Servicio de Aseo de la Comuna de Coronel que de acuerdo al D.S. N&#xBA; 69 del Ministerio de Econom&#xED;a se fija la tarifa de aseo anualmente a partir de a&#xF1;o 2008 en 1,175 UTM. Dando plazo desde el 30 de octubre de 2007 desde las 8:30 hrs. para presentar sus observaciones en la Municipalidad de Coronel, ubicada en Bannen N&#xBA; 70, Coronel.</div><br></div>", "i": 6700775}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Coronel, octubre de 2007.- Ren&#xE9; Carvajal Z&#xFA;&#xF1;iga, Alcalde.</div><br></div>", "i": 6700776}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "AVI-S/N"}], "organismos": ["MUNICIPALIDAD DE CORONEL"], "titulo_norma": "FIJA TARIFA DE ASEO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CORONEL", "TARIFA DE ASEO", "ORDENANZA MUNICIPAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "265910", "numero_fuente": "38895", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-10-25", "vigencias": [{"desde": "2007-10-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-10-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-10-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2007-10-25", "fecha_version": "2007-10-25", "fecha_actualizacion_texto": "2007-10-25", "tipo_tratado