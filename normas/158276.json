{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6241393}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 365, de fecha 09 de Mayo de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la V Regi&#xF3;n, se autoriza a William Rebolledo Fuentes y Adri&#xE1;n Rojo Past&#xE9;n, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6241394}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 09 de Mayo de 1986.- Hern&#xE1;n V&#xE1;squez Wacquez, Capit&#xE1;n de Nav&#xED;o, Secretario Regional Ministerial de Transportes y Telecomunicaciones V Regi&#xF3;n. </div></div>", "i": 6241395}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "365 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-365 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL V REGIÓN DE VALPARAÍSO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-05-09", "doble_articulado": false, "id_norma": "158276", "numero_fuente": "32472", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-05-16", "vigencias": [{"desde": "1986-05-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-05-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "