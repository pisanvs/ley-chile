{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 533 EXENTO, DE 1998</div><br><br><br></div>", "i": 6110103}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA;533, de 23 de abril de 1998, se ha aprobado a la Scuola Italiana &apos;&apos;Vittorio Montiglio&apos;&apos; de Santiago, planes y programas de estudio biling&#xFC;e para los cursos de 3&#xBA; a 5&#xBA; a&#xF1;o de ense&#xF1;anza b&#xE1;sica (NB.2 y NB.3), los que ser&#xE1;n aplicados de acuerdo al cronograma establecido en el decreto supremo de Educaci&#xF3;n N&#xBA;40 de 1996 y sus modificaciones.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores de aprendizaje que se se&#xF1;alan en el presente decreto, para los cursos de 3&#xBA; a 5&#xBA; a&#xF1;o de ense&#xF1;anza b&#xE1;sica. </div></div>", "i": 6110104}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de abril de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6110105}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "533 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-533 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 533 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "SCUOLA ITALIANA VITTORIO MONTIGLIO", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-23", "doble_articulado": false, "id_norma": "98771", "numero_fuente": "36060", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-05-09", "vigencias": [{"d