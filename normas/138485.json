{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,064.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 7250190}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Los derechos de faros y valizas y de hospital se pagar&#xE1;n en conformidad a la lei n&#xFA;mero 2,913, de 3 de agosto de 1914.</div><div class=\"p\">&nbsp; &nbsp;  La presente lei rejir&#xE1; desde su publicacion en el Diario Oficial.</div><br></div>", "i": 7250191, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a dieciseis de febrero de mil novecientos dieciseis.- Juan Luis Sanfuentes.- Armando Quezada A. </div></div>", "i": 7250192}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3064", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3064"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-02-16", "doble_articulado": false, "id_norma": "138485", "numero_fuente": "11405", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-02-26", "vigencias": [{"desde": "1916-0