{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8939302}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.917, de 23 de junio de 2010, de esta Subsecretar&#xED;a, autor&#xED;zase la caza del ejemplar de la especie Lobo marino com&#xFA;n, identificado de conformidad con los Considerandos de la resoluci&#xF3;n extractada, en el &#xE1;rea mar&#xED;tima pr&#xF3;xima a la caleta de Arica, XV Regi&#xF3;n de Arica y Parinacota. La caza del ejemplar antes indicado deber&#xE1; ser efectuada por la Capitan&#xED;a de Puerto de Arica, en coordinaci&#xF3;n con el Servicio Nacional de Pesca, quien deber&#xE1; velar por el correcto manejo, inertizaci&#xF3;n y disposici&#xF3;n de los restos del ejemplar muerto.</div></div>", "i": 8939303}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de junio de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div><br></div>", "i": 8939304}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1917 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1917 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-06-23", "doble_articulado": false, "id_norma": "1014968", "numero_fuente": "39700", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-07-02", "vigencias": [{"desde": "2010-07-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-07-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-