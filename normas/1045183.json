{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 1.896, DE 2011</div></div>", "i": 9309828}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.864 de esta Subsecretar&#xED;a, modif&#xED;case <a href=\"https://www.leychile.cl/Navegar?idNorma=1027884&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 1.896 de 2011</a>, de esta Subsecretar&#xED;a, que estableci&#xF3; agrupaciones de concesiones de acuicultura de salm&#xF3;nidos en X y XI Regiones, reemplazando coordenadas geogr&#xE1;ficas de la ACS 21A y creando una ACS 21D, publicada &#xED;ntegramente en www.subpesca.cl y www.sernapesca.cl.</div></div>", "i": 9309829}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de octubre de 2012.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9309830}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2864 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2864 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 1.896, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-10-24", "doble_articulado": false, "id_norma": "1045183", "numero_fuente": "40399", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-10-31", "vigencias": [{"desde": "2012-10-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-10-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-10-31", "fin_vigencia": "", "tipo