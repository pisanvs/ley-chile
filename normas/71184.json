{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6035664}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP N&#xBA; 208, de 28 de febrero de 1997, se expropiaron los lotes de terreno N&#xBA;s. 8-B, 8-C, 8-F, 8-H y 11, superficies 192, 156, 186, 644,40 y 1924,30 m2, respectivamente, roles de aval&#xFA;os 101-26, 101-31, 101-34, 101-24 y 109-100, comuna de Quilicura, obra Proyecto Estudio de Ingenier&#xED;a Habilitaci&#xF3;n Segunda Calzada Avda. A. Vespucio, sector Carretera Panamericana Norte-Ruta 72 y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Jorge Mu&#xF1;oz Morales, Luis Torres Guti&#xE9;rrez, Jos&#xE9; Romero Lorca, Cornelio Sep&#xFA;lveda Sald&#xED;as y Juan Silva G&#xF3;mez, ascendente a las cantidades de $35.880.200, $22.161.727, $11.512.774, $38.400.940 y $122.609.799.-</div><br></div>", "i": 6035665}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6035666}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "208", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-208"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "INDEMNIZACION", "QUILICURA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-02-28", "doble_articulado": false, "id_norma": "71184", "numero_fuente": "45755", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-02", "vigencias": [{"desde": "1997-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-02", "fin_vige