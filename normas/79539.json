{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8310005}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 177 de 26 de Febrero de 1992 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, cad&#xFA;case la Resoluci&#xF3;n No. 178, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Empresa Pesquera San Miguel Ltda., RUT. No. 81.740.200-3, domiciliada en Talcahuano, para operar una nave en construcci&#xF3;n de 650 m3 de capacidad de bodega, entre las Regiones III a VII y IX en virtud de lo dispuesto en el Art&#xED;culo 143 letra b) de la Ley No. 18.892, Ley General de Pesca y Agricultura. </div></div>", "i": 8310006}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 26 de Febrero de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8310007}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "177", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-177"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-02-26", "doble_articulado": false, "id_norma": "79539", "numero_fuente": "34212", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-03-07", "vigencias": [{"desde": "1992-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-03-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-03-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "u