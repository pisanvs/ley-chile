{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 16.287 EXENTA, DE 2001 </div><br></div>", "i": 6376509}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 16.287 de 28 de diciembre del a&#xF1;o 2001, se ha aprobado al Colegio Saint John&apos;s School, comuna de Concepci&#xF3;n, VIII Regi&#xF3;n del B&#xED;o-B&#xED;o, un plan de estudio para 3&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; en el a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 6376510}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de marzo de 2002.- Juan Ruz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6376511}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "16287 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-16287 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 16.287 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-28", "doble_articulado": false, "id_norma": "196618", "numero_fuente": "37232", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-11", "vigencias": [{"desde": "2002-04-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-04-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-04-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "in