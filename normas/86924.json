{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8318266}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.833, de 31 de diciembre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud presentada por don ARNOLDO POBLETE LARA, de pr&#xF3;rroga del plazo de suspensi&#xF3;n de actividades pesqueras extractivas por fuerza mayor, con la nave &quot;Monserrat&quot;, por haber incurrido en la causal de caducidad se&#xF1;alada en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura, al 7 de abril de 1996, fecha del siniestro de la nave.</div><br></div>", "i": 8318267}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de diciembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8318268}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1833", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1833"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "ARNOLDO POBLETE LARA", "PRORROGA", "PLAZO", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-31", "doble_articulado": false, "id_norma": "86924", "numero_fuente": "35961", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-10", "vigencias": [{"desde": "1998-01-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-01-10", "fin_vigencia