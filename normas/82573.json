{"html": [{"t": "<div><div class=\"p\">PRORROGA AUTORIZACION QUE INDICA </div></div>", "i": 8313874}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 865 de 16 de Julio de 1990 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por 210 d&#xED;as a contar del 09.06.90 el plazo otorgado a Stella Maris S.A., R.U.T. No.</div><div class=\"p\">96.536.800-0, domiciliada en Santiago, para empezar a operar el establecimiento de cultivo autorizado por la Resoluci&#xF3;n No. 618, de 1989, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor. </div></div>", "i": 8313875}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 16 de Julio de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8313876}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "865", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-865"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-07-16", "doble_articulado": false, "id_norma": "82573", "numero_fuente": "33731", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-07-28", "vigencias": [{"desde": "1990-07-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-07-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-07-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado