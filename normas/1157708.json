{"html": [{"t": "<div><div class=\"p\">NOMBRAMIENTO DE DELEGADOS DE POLICIA DE ESTA CAPITAL.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Mayo 30 de 1823.</div></div>", "i": 10229401}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  70 A propuesta del Juez de polic&#xED;a urbana D. Francisco Ruiz Tagle, y consecuente el art. 3.&#xB0; de decreto 21 del presente, vengo en nombrar los Delegados de polic&#xED;a siguientes:</div><br><div class=\"p\">&nbsp; &nbsp;  Para el Cuartel 1.&#xB0; a D. Manuel Castillo.</div><div class=\"p\">&nbsp; &nbsp;  Para el 2.&#xB0; a D. Domingo Bezanilla.</div><div class=\"p\">&nbsp; &nbsp;  Para el 3.&#xB0; a D. Jos&#xE9; Jimenez.</div><div class=\"p\">&nbsp; &nbsp;  Para el 4.&#xB0; a D. Miguel Morales.</div><br><div class=\"p\">&nbsp; &nbsp;  Comuniquese al Juez de polic&#xED;a para entren al ejercicio de sus funciones, imprimi&#xE9;ndose en el Bolet&#xED;n.</div></div>", "i": 10229402}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp;  Ega&#xF1;a.</div></div>", "i": 10229403}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "NOMBRAMIENTO DE DELEGADOS DE POLICIA DE ESTA CAPITAL.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-05-30", "doble_articulado": false, "id_norma": "1157708", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-05-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "182