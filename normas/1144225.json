{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 565, DE 2020, QUE AUTORIZ&#xD3;, POR CAUSA DE FUERZA MAYOR, LA APLICACI&#xD3;N DE MEDIDAS QUE INDICA</div></div>", "i": 10114170}, {"t": "<div><br><div class=\"p\"> </div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 648, de 24 de marzo de 2020, del Servicio Nacional de Pesca y Acuicultura, se modifica la <a href=\"https://www.leychile.cl/Navegar?idNorma=1143845&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 565, de 2020</a>, que autoriz&#xF3;, por causa de fuerza mayor, la aplicaci&#xF3;n de medidas que indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n se encuentra publicado en la p&#xE1;gina de dominio electr&#xF3;nico del Servicio y de la Subsecretar&#xED;a de Pesca y Acuicultura.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10114171}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alicia Gallardo Lagno, Directora Nacional, Servicio Nacional de Pesca y Acuicultura.</div><br></div>", "i": 10114172}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "648", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-648"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 565, DE 2020, QUE AUTORIZÓ, POR CAUSA DE FUERZA MAYOR, LA APLICACIÓN DE MEDIDAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1749807; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-03-24", "doble_articulado": false, "id_norma": "1144225", "numero_fuente": "42629", "tipo_ver