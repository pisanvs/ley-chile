{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 30 EXENTA, DE 2014</div></div>", "i": 9430237}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 996, de 9 de abril de 2014, de esta Subsecretar&#xED;a, modif&#xED;quese la <a href=\"https://www.leychile.cl/Navegar?idNorma=1058357&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 30 de 2014</a>, modificada mediante resoluci&#xF3;n exenta N&#xBA; 628, de 2014, ambas de esta Subsecretar&#xED;a, que estableci&#xF3; la distribuci&#xF3;n de la fracci&#xF3;n artesanal de la pesquer&#xED;a artesanal Merluza com&#xFA;n de la IV, V, VI, VII y VIII regiones, en el sentido de se&#xF1;alar que la cuota asignada al &#xC1;rea Sur de la VI Regi&#xF3;n, se incrementar&#xE1; en 21,797 toneladas.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><br></div>", "i": 9430238, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de abril de 2014.- Paolo Trejo Carmona, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9430239}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "996 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-996 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 30 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": fals