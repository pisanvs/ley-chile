{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8353691}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;2.232, de 29 de octubre de 1999,</div><div class=\"p\">de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA SURIBERICA</div><div class=\"p\">S.A., para continuar desarrollando las actividades</div><div class=\"p\">pesqueras autorizadas a Pesquera Punta Arenas S.A., RUT</div><div class=\"p\">N&#xBA;96.539.010-3, por resoluciones N&#xBA;1.325 y N&#xBA;1.326 de</div><div class=\"p\">1992, N&#xBA;1.773 y N&#xBA;1.774 de 1995, N&#xBA;140, N&#xBA;145 y N&#xBA;2.245</div><div class=\"p\">de 1996, N&#xBA;1.571, N&#xBA;1.572, N&#xBA;1.699, N&#xBA;1.708, N&#xBA;1.881 y</div><div class=\"p\">N&#xBA;1.882 de 1998, de esta Subsecretar&#xED;a, con el m&#xE9;rito de</div><div class=\"p\">la escritura p&#xFA;blica y en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 99 de la ley N&#xBA;18.046.</div><br></div>", "i": 8353692}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, de 29 de octubre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8353693}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2232", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2232"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-29", "doble_articulado": false, "id_norma": "148034", "numero_fuente": "36519", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-11-20", "vigencias": [{"desde": "1999-11-