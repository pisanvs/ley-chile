{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6176724}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 10, de 22 de Febrero de 1988, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se autoriza al Sr. Alejandro Gilberto Carrizo Carrizo, para efectuar todo tipo de servicios de Transportes de pasajeros por calles y caminos dentro del Territorio Nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de Locomoci&#xF3;n Colectiva de Pasajeros.</div><br></div>", "i": 6176725}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rancagua, 22 de Febrero de 1988.- Rigoberto G&#xF3;mez Lav&#xED;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n.</div><div class=\"p\">Secretar&#xED;a Regional Ministerial </div></div>", "i": 6176726}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-10 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-02-22", "doble_articulado": false, "id_norma": "138860", "numero_fuente": "33008", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-29", "vigencias": [{"desde": "1988-02-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-29", "fin_vigencia": ""}, "vigencia