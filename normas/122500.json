{"html": [{"t": "<div><div class=\"p\">CERTIFICA CALIDAD DE AGENTE RETENEDOR DEL IVA A FULLMARKET S.A.</div><br><br><br></div>", "i": 6123660}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 39.- Certifico que Fullmarket S.A., RUT N&#xBA;96.624.270-1, cumple los requisitos establecidos en la Res. N&#xBA; Ex. 2.705 de 07.05.98 (D.O. de 12.05.98) modificada por la Res.</div><div class=\"p\">N&#xBA; Ex. 3.784 de 25.06.98 (D.O. de 30.06.98) y que en consecuencia tiene la calidad de agente retenedor del Impuesto al Valor Agregado, en las ventas de carnes y servicios de faenamiento de ganado que efect&#xFA;e durante el per&#xED;odo comprendido entre el 1&#xBA; del mes siguiente al de la publicaci&#xF3;n de este certificado en el Diario Oficial y el 31 de julio de 1999. </div></div>", "i": 6123661}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de julio de 1998.- Jorge A. de Calisto Bravo, Director Regional.</div><br></div>", "i": 6123662}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "39", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-39"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO PONIENTE"], "titulo_norma": "CERTIFICA CALIDAD DE AGENTE RETENEDOR DEL IVA A FULLMARKET S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "FULLMARKET S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-07-24", "fecha_derogacion": "2002-03-19", "doble_articulado": false, "id_norma": "122500", "numero_fuente": "36128", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-07-31", "vigencias": [{"desde": "2002-03