{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10313687}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xBA;161, de 28 de enero de 2022, fija precios para prestaciones PEEC del Departamento de Salud Ocupacional y elimina prestaci&#xF3;n que indica, del mismo Departamento.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.- </div></div>", "i": 10313688}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mar&#xED;a Judith Mora Riquelme, Directora (S), Instituto de Salud P&#xFA;blica de Chile.</div><div class=\"p\"> </div></div>", "i": 10313689}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "161 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-161 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2090508", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-01-28", "doble_articulado": false, "id_norma": "1173030", "numero_fuente": "43187", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-02-24", "vigencias": [{"desde": "2022-02-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2022-02-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2022-02-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "202