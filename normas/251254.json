{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6575678}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.975, de 12 de julio de 2006, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de las resoluciones N&#xBA; 284 de 2000 y N&#xBA; 52 de 2003, ambas de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autorizaron a SOCIEDAD PESQUERA VIENTO SUR S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Do&#xF1;a Mariana&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre las regiones IV y VIII, sobre el recurso Besugo, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado en Informe T&#xE9;cnico citado en Visto.</div><br></div>", "i": 6575679}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de julio de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6575680}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1975 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1975 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-12", "doble_articulado": false, "id_norma": "251254", "numero_fuente": "38515", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-07-17", "vigencias": [{"desde": "2006-07-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-07-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2