{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 17A</div><div class=\"p\"> </div></div>", "i": 10020330}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.614, de 26 de abril de 2019, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1121668&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xB0; 2.774, de 2018</a>, de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 17A, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para el centro de cultivo que indica en la resoluci&#xF3;n extractada.</div></div>", "i": 10020331}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de abril de 2019.- Rom&#xE1;n Zelaya R&#xED;os, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 10020332}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1614 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1614 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 17A", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1584747; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-04-26", "doble_articulado": false, "id_norma": "1131212", "numero_fuente": "42345", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-05-04", "vigencias": [{"desde": "2019-05-04", "hasta": "", "tipo_version": "