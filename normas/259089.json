{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6604198}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 799, de 6 de marzo de 2007, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 3.281 de 2004, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA EL GOLFO S.A. para realizar actividades pesqueras extractivas con la nave &quot;Leopardo&quot;, en la Isla de Pascua, Archipi&#xE9;lago de Juan Fern&#xE1;ndez, Islas Sala y G&#xF3;mez e Islas Desventuradas, con arrastre, sobre el recurso Alfonsino Beryx splendens, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante Informe T&#xE9;cnico citado en Visto.</div><br></div>", "i": 6604199}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de marzo de 2007.- Mar&#xED;a Angela Barbieri Bellolio, Subsecretaria de Pesca (S). </div></div>", "i": 6604200}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "799 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-799 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-03-06", "doble_articulado": false, "id_norma": "259089", "numero_fuente": "38712", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-03-13", "vigencias": [{"desde": "2007-03-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-03-13", "fin_vigencia": ""}, "vigencias