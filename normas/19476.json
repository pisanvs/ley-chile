{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; COMPLEMENTA EL DECRETO PROMULGATORIO DE LA LEY N.o 14.688</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 18.753.- Santiago, 23 de Octubre de 1961.- Visto el oficio N.o 686-a, de 22 de Octubre de 1961, de la H. C&#xE1;mara de Diputados, y</div><div class=\"p\">&nbsp; &nbsp; Teniendo presente:</div><div class=\"p\">&nbsp; &nbsp; Que en el oficio N.o 686, de fecha 20 del presente en que la Corporaci&#xF3;n mencionada comunic&#xF3; al Ejecutivo el proyecto de ley que reajusta los sueldos y salarios del sector p&#xFA;blico y privado, se omiti&#xF3; incluir en el art&#xED;culo 26.o la letra e),</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 5938977}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Complem&#xE9;ntase el art&#xED;culo 26.o del decreto</div><div class=\"p\">promulgatorio de la ley 14,688, en la siguiente</div><div class=\"p\">disposici&#xF3;n:</div><div class=\"p\">&nbsp; &nbsp; &quot;e) Con los ingresos que produzca la aplicaci&#xF3;n del</div><div class=\"p\">art&#xED;culo 169.o de la ley N.o 13.305&quot;.</div><br></div>", "i": 5938978}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- J. ALESSANDRI R.- Luis Mackenna S.</div><br></div>", "i": 5938979}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "18753", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-18753"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "COMPLEMENTA EL DECRETO PROMULGATORIO DE LA LEY N.o\n14.688", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REAJUSTE", "SUELDOS", "PENSIONES", "SALARIO MINIMO", "SUELDO VITAL", "A O 1961", "SECTOR", "PUBLICO", "PRIVADO", "FINANCIAMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "