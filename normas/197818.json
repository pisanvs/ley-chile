{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 3.450 EXENTA, DE 2002 </div></div>", "i": 6380547}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 3.450, de 26 de marzo del a&#xF1;o 2002, se ha aprobado a la Scuola Italiana &quot;Vittorio Montiglio&quot;, comuna de Las Condes, de Santiago, un plan de estudio para 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores de &quot;Idioma Extranjero 1: Italiano&quot; y de &quot;Educaci&#xF3;n Tecnol&#xF3;gica&quot;.</div><br></div>", "i": 6380548}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de abril de 2002.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6380549}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3450 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3450 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 3.450 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-26", "doble_articulado": false, "id_norma": "197818", "numero_fuente": "37253", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-08", "vigencias": [{"desde": "2002-05-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendien