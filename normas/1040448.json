{"html": [{"t": "<div><br><div class=\"p\">DEJA SIN EFECTO RESOLUCI&#xD3;N N&#xBA; 6 EXENTA, DE 2012</div></div>", "i": 9260079}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta de la Direcci&#xF3;n de Grandes Contribuyentes del Servicio de Impuestos Internos N&#xBA; 143, del 24 de mayo de 2012, que se&#xF1;ala:</div><div class=\"p\">&nbsp; &nbsp;  Deja sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=1036544&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n delegatoria Ex. DGC N&#xBA; 6, de 13 de enero de 2012</a>. Esta resoluci&#xF3;n regir&#xE1; a contar de su publicaci&#xF3;n en extracto en el Diario Oficial.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de mayo de 2012.</div><br></div>", "i": 9260080, "v": ["MODIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "143 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-143 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN DE GRANDES CONTRIBUYENTES"], "titulo_norma": "DEJA SIN EFECTO RESOLUCIÓN Nº 6 EXENTA, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-24", "doble_articulado": false, "id_norma": "1040448", "numero_fuente": "40273", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-05-29", "vigencias": [{"desde": "2012-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vig