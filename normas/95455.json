{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA N&#xB0; 3.431, DE 1988 </div></div>", "i": 9050032}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta N&#xB0; 3.431 de fecha 21 de diciembre de 1988, de la Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica, se insert&#xF3; en la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xB0; 2.346/87 del Centro de Formaci&#xF3;n T&#xE9;cnica Fundaci&#xF3;n EPSON de Santiago, las adecuaciones introducidas a la red curricular de la carrera Administraci&#xF3;n de Empresas con menci&#xF3;n en Inform&#xE1;tica, las que podr&#xE1;n aplicarse a contar de agosto de 1988.- Santiago, </div></div>", "i": 9050033}, {"t": "<div><div class=\"p\">15 de Febrero de 1989.- Paulina Dittborn Cordua, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 9050034}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3431 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3431 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N° 3.431, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-12-21", "doble_articulado": false, "id_norma": "95455", "numero_fuente": "33310", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-02-28", "vigencias": [{"desde": "1989-02-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-02-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-02-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "ALV", "fe