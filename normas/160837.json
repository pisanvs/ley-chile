{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6250109}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. No. 69, de 19 de Marzo de 1985. se expropiaron las mejoras 9-a. 9-b, 9-d, 9-e. 9-f.</div><div class=\"p\">20-a, 20-b. 29-b y 29-d, contenidas dentro de los lotes 9. 20 y 29. roles de aval&#xFA;os de los terrenos 432-1. 432-12 y 431-10. Comuna de Santiago y se acord&#xF3; el precio de indemnizaci&#xF3;n con los afectados do&#xF1;a Mireya Iturriaga Canco. Miguel Romero Barrales. Elia Avila Gonz&#xE1;lez, Hugo Mu&#xF1;oz Hern&#xE1;ndez. Carmen Cort&#xE9;s Venegas, Irma Puebla Santis. Ram&#xF3;n Gonz&#xE1;lez Lobos. Nadia Espinoza Araya y Reginald Madariaga Pino. ascendente a $ 180.000, $ 75.000, $ 80.000, $ 70.000, $ 180.000, $ 75.000, $ 50.000, $ 180.000 y $ 580.000. respectivamente. </div></div>", "i": 6250110}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6250111}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "69", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-69"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-03-19", "doble_articulado": false, "id_norma": "160837", "numero_fuente": "32146", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-04-15", "vigencias": [{"desde": "1985-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-04-15", "fin_vigencia": "", "tipo