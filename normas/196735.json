{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A DON SERGIO GUIDO RIQUELME FLORES </div></div>", "i": 7290795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/N&#xBA; Ex 425, de fecha 04 de abril de 2002, revoca, a don Sergio Guido Riquelme Flores, RUT N&#xBA; 5.773.481-7, a partir del d&#xED;a 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de Sujeto en las ventas de carne, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 16 de la resoluci&#xF3;n Ex. N&#xBA; 3.722/2000, de la Direcci&#xF3;n Nacional.</div><br></div>", "i": 7290796}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 4 de abril de 2002.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 7290797}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "425 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-425 EXENTA"}, {"tipo": "3", "numero": "DRE-425 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-425 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A DON SERGIO GUIDO RIQUELME FLORES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-04", "doble_articulado": false, "id_norma": "196735", "numero_fuente": "37236", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-16", "vigencias": [{"desde": "2002-04-16