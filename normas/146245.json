{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8352453}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.168, de 20 de octubre de 1999, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.268, de 1989, de esta Subsecretar&#xED;a, en cuanto autoriz&#xF3; al titular de la nave &apos;&apos;Mar Tirreno&apos;&apos;, hoy EMPRESA PESQUERA EPERVA S.A., para realizar actividades pesqueras extractivas en el litoral de la III Regi&#xF3;n respecto de Anchoveta, Caballa, Jurel, Sardina espa&#xF1;ola y Sardina com&#xFA;n, de conformidad con lo establecido en la letra b) del art&#xED;culo 143 del DS N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8352454}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de octubre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8352455}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2168", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2168"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-20", "doble_articulado": false, "id_norma": "146245", "numero_fuente": "36500", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-10-28", "vigencias": [{"desde": "1999-10-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-10-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-