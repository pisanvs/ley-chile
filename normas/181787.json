{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6322466}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA;29, de 31 de enero de 2001, se expropi&#xF3; el lote de terreno N&#xBA;3, superficie 569 m2., rol de aval&#xFA;o 562-14, comuna de Chimbarongo, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo Santiago-Talca. Sector K, Sexta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Fabi&#xE1;n Antonio D&#xED;az Aguayo y otra, ascendente a la cantidad de $2.468.215.</div><br></div>", "i": 6322467}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6322468}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "29 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-29 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-01-31", "doble_articulado": false, "id_norma": "181787", "numero_fuente": "36913", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-15", "vigencias": [{"desde": "2001-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2001-03-19", "fecha_version": "2001-03-15", "fecha_actualizacion_texto": "2001-03-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura"