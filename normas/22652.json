{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Segregacion del distrito 1.&#xB0; de la 9.a subdelegacion rural &quot;Las Condes&quot;</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,442.- Santiago, a 23 de Enero de 1900.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274349}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Segr&#xE9;gase de la Municipalidad de &quot;Providencia&quot; el distrito 1.&#xB0; de la 1.a subdelegacion rural &quot;Las Condes&quot; i an&#xE9;xase, con el n&#xFA;mero cuatro, a la subdelegacion 16 urbana de la circunscripcion &quot;Recoleta&quot; de la Municipalidad de Santiago.</div><br><br></div>", "i": 8274350}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ E.- Juan Antonio Orrego.</div><br></div>", "i": 8274351}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1442", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1442"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "SEGREGACION DEL DISTRITO 1.° DE LA 9.a SUBDELEGACION RURAL LAS CONDES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDADES", "PROVIDENCIA", "LAS CONDES", "SEGREGACION", "DISTRITOS", "RECOLETA", "SANTIAGO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-01-23", "doble_articulado": false, "id_norma": "22652", "numero_fuente": "6799", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-01-23", "vigenci