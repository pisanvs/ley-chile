{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;113, DE 2000 </div></div>", "i": 6306097}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Con fecha 10 de octubre de 2000 la Secretar&#xED;a Regional Ministerial de Bienes Nacionales de la IX Regi&#xF3;n, dict&#xF3; resoluci&#xF3;n N&#xBA; 113, por medio de la cual se le otorga a la I. Municipalidad de Puc&#xF3;n, una concesi&#xF3;n de uso gratuito del inmueble fiscal ubicado en Puc&#xF3;n calle Caupolic&#xE1;n esquina Ger&#xF3;nimo de Alderete, edificio antiguo o casa principal, de la comuna de Puc&#xF3;n, provincia de Caut&#xED;n, IX Regi&#xF3;n de la Araucan&#xED;a por un plazo de 2 a&#xF1;os.</div><br></div>", "i": 6306098}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Adolfo de la Jara Dur&#xE1;n, Secretario Regional Ministerial de Bienes Nacionales IX Regi&#xF3;n.</div><br></div>", "i": 6306099}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "113", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-113"}], "organismos": ["MINISTERIO DE BIENES NACIONALES", "SECRETARÍA REGIONAL MINISTERIAL IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº113, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-10", "doble_articulado": false, "id_norma": "176965", "numero_fuente": "36798", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-27", "vigencias": [{"desde": "2000-10-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-10-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-10-27", "fin_vigencia": "", "tipo_versi