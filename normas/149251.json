{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 7257459}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 444, de mayo 12 de 1987, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se renueva la concesi&#xF3;n otorgada a la Sociedad &quot;Salazar y Tepper Limitada&quot; (Ruta Sur Limitada), por resoluci&#xF3;n No. 418/82 para efectuar servicio internacional de transporte terrestre de pasajeros entre Temuco (Chile) y Zapala (Argentina) por pase fronterizo Pino Hachado, efectuando dos frecuencias semanales.</div><br></div>", "i": 7257460}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Enrique Y&#xE1;var Martin, Coronel de Ej&#xE9;rcito, Subsecretario de Transportes.</div><br></div>", "i": 7257461}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "444 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-444 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-05-12", "doble_articulado": false, "id_norma": "149251", "numero_fuente": "32779", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-05-26", "vigencias": [{"desde": "1987-05-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-05-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-05-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_pa