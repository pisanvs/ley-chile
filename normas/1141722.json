{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10096387}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xB0;5.083 de 27 de diciembre de 2019 del Instituto de Salud P&#xFA;blica de Chile, que clasifica el producto Xprovit Glu Polvo para suspensi&#xF3;n oral como Alimento.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, en el siguiente link: http://www.ispch.cl/resoluciones.-</div></div>", "i": 10096388}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mar&#xED;a Judith Mora Riquelme, Directora (S), Instituto de Salud P&#xFA;blica de Chile.</div></div>", "i": 10096389}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5083 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5083 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1718307", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-12-27", "doble_articulado": false, "id_norma": "1141722", "numero_fuente": "42565", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-01-29", "vigencias": [{"desde": "2020-01-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2020-01-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2020-01-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ing