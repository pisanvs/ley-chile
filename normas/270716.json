{"html": [{"t": "<div><div class=\"p\">CONSTITUCI&#xD3;N LEGAL PARTIDO REGIONALISTA DE LOS INDEPENDIENTES EN LA VI REGI&#xD3;N </div></div>", "i": 8435627}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Carlos Moraga Duque y Ricardo Fern&#xE1;ndez Sanhueza, Presidente y Secretario General del Partido Regionalista de los Independientes, respectivamente, han solicitado la constituci&#xF3;n legal del partido en la VI Regi&#xF3;n del Libertador General Bernardo O&apos;Higgins, acompa&#xF1;ando 3.117 fichas de afiliaciones.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xBA; de la ley N&#xBA; 18.603, por resoluci&#xF3;n O-N&#xBA; 0717, de fecha 18 de abril de 2008. </div></div>", "i": 8435628}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director. </div></div>", "i": 8435629}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "717", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-717"}, {"tipo": "3", "numero": "O-717", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-717"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "CONSTITUCIÓN LEGAL PARTIDO REGIONALISTA DE LOS\nINDEPENDIENTES EN LA VI REGIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO REGIONALISTA DE LOS INDEPENDIENTES", "SEXTA REGION", "CONSTITUCION LEGAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-04-18", "doble_articulado": false, "id_norma": "270716", "numero_fuente": "39046", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-04-25", "vigencias": [{"desde": "2008-04-25", "hasta": "", "tipo_version":