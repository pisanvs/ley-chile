{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 80, DE 1991 </div></div>", "i": 6057284}, {"t": "<div><div class=\"p\">Por decreto exento No. 80 de fecha 15 de mayo de 1991 del Ministerio de Educaci&#xF3;n, se insert&#xF3; en la resoluci&#xF3;n exenta de Educaci&#xF3;n No. 2.805 de 1989 del Centro de Formaci&#xF3;n T&#xE9;cnica Escuela de Estudios Superiores ESES - ALPES de Santiago, las adecuaciones introducidas a las carreras de: - Artes Gr&#xE1;ficas.</div><div class=\"p\">- Fotograf&#xED;a, especialidades fotograf&#xED;a publicitaria y fotograf&#xED;a period&#xED;stica</div><div class=\"p\">- T&#xE9;cnico en Comunicaci&#xF3;n Social menci&#xF3;n:</div><div class=\"p\">* Producci&#xF3;n Audiovisual</div><div class=\"p\">* Libreto y Gui&#xF3;n</div><div class=\"p\">* Producci&#xF3;n de eventos</div><div class=\"p\">* Locuci&#xF3;n y Oratoria</div><div class=\"p\"> - Ejecuci&#xF3;n musical.-</div><br></div>", "i": 6057285}, {"t": "<div><div class=\"p\">Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 6057286}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "80 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-80 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 80, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-05-15", "doble_articulado": false, "id_norma": "80414", "numero_fuente": "34042", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-08-13", "vigencias": [{"desde": "1991-08-13", "hasta": "", "tipo_version": "3", "tipo_version_s