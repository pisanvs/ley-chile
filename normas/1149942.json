{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10164034}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA; 642, de 05 de agosto de 2020, se desisti&#xF3; de la expropiaci&#xF3;n del lote N&#xBA;26, expropiado mediante Decreto Exento MOP. N&#xBA;1133, de 25 de septiembre de 2018, para la obra: &quot;Reposici&#xF3;n Pavimento Ruta U-40, Sector Osorno - Intersecci&#xF3;n Ruta U-52&quot;, Comuna y Provincia de Osorno, Regi&#xF3;n de Los Lagos&quot;, por cuanto, dicho lote fue eliminado por <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=1124194&amp;idVersion=2020-10-01\">Resoluci&#xF3;n S.R.M. Regi&#xF3;n de Los Lagos (Exenta) N&#xBA;187, de 18 de febrero de 2020</a>, por no ser necesaria la expropiaci&#xF3;n. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en los art&#xED;culos 7&#xBA; y 32&#xBA; del Decreto Ley N&#xBA;2186, de 1978.</div><br></div>", "i": 10164035, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10164036}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "642 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-642 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1823498", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-08-05", "doble_articulado": false, "id_norma": "1149942", "numero_fuente": "42769", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-10-01", "vigencias": [{"desde": "2020-10-01", "