{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6540124}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;181 de 15 de noviembre de 2004, Serviu V Regi&#xF3;n Valpara&#xED;so dispuso expropiaci&#xF3;n parcial, conforme art&#xED;culo 87 ley 8.946 y decreto ley 2.186, de 1978, de inmueble ubicado en Camino Troncal s/n, rol aval&#xFA;o 1998-1, comuna de Vi&#xF1;a del Mar, de dominio de Inmobiliaria Tacora II S.A. Comisi&#xF3;n Tasadora integrada por Sres. Osvaldo Mu&#xF1;oz Quintana, arquitecto, Alvaro Verdejo Vidal, ingeniero constructor, y Pablo Caria Giurici, constructor civil, seg&#xFA;n informe de fecha 10 de agosto de 2004 fij&#xF3; monto provisional indemnizaci&#xF3;n en $21.064.640.- que ser&#xE1; pagada al contado.</div><br></div>", "i": 6540125}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Regi&#xF3;n Valpara&#xED;so.</div><br></div>", "i": 6540126}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "181", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-181"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAISO"], "titulo_norma": "DISPONE EXPROPIACION DE INMUEBLE QUE INDICA; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-15", "doble_articulado": false, "id_norma": "242000", "numero_fuente": "38263", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-09-15", "vigencias": [{"desde": "2005-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigen