{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 934.- Santiago, a 20 de Agosto de 1897.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947955}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de sesenta i dos mil pesos al &#xED;tem 5 de la partida 7.a del presupuesto del Ministerio de Relaciones Exteriores que consulta fondos para gastos de las subcomisiones demarcadoras de l&#xED;mites i adquisicion de material para las mismas.</div><br><br></div>", "i": 5947956}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica. FEDERICO ERRAZURIZ E.- C. Morla Vicu&#xF1;a.</div><br></div>", "i": 5947957}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "934", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-934"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "Suplemento", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "MODIFICACION", "1897"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-08-20", "doble_articulado": false, "id_norma": "22281", "numero_fuente": "5785", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1897-08-21", "vigencias": [{"desde": "1897-08-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1897-08-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1897-08-21", "fin_vigen