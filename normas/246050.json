{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6556545}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.217, de 5 de diciembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a ABEL PATRICIO AGUIRRE FERNANDEZ para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en ruta norte aleda&#xF1;o al deslinde norte del Barrio Industrial, Cha&#xF1;aral, III Regi&#xF3;n de Atacama, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Picado de Algas, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6556546}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de diciembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6556547}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4217 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4217 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-05", "doble_articulado": false, "id_norma": "246050", "numero_fuente": "38358", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-01-09", "vigencias": [{"desde": "2006-01-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-01-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-01-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC