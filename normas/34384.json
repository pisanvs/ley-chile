{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291913}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 342 de 30 de Marzo de 1995 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a SOCIEDAD AHUMADOS PATAGONIA LTDA., R.U.T. N&#xB0; 50.666.390-3, para iniciar actividades pesqueras, en orden a instalar y operar una planta ubicada en Avenida 21 de Mayo N&#xB0; 1851, Coyhaique, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n de conserva y ahumado los siguientes recursos hidrobiol&#xF3;gicos: Pejerrey de mar, Salm&#xF3;n del Atl&#xE1;ntico, Salm&#xF3;n plateado, Trucha arcoiris.</div><br></div>", "i": 8291914}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 30 de Marzo de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8291915}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "342", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-342"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD AHUMADOS PATAGONIA LTDA", "INDUSTRIA PESQUERA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-03-30", "doble_articulado": false, "id_norma": "34384", "numero_fuente": "35149", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-04-22", "vigencias": [{"desde": "1995-04-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-04-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-04-22", "fin_vigencia": "", "tipo_version": "3"}], "