{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; INTERES DEL EMPRESTITO AUTORIZADO POR LEI NUM. 323 DE 20 DE DICIEMBRE DE 1895</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 355.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7162675}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza al Presidente de la Rep&#xFA;blica para contratar hasta con el cinco por ciento de interes anual, el empr&#xE9;stito autorizado por <a href=\"https://www.leychile.cl/Navegar?idNorma=22174&amp;idParte=0&amp;idVersion=\">lei n&#xFA;m. 323</a>, de 20 de Diciembre de 1895.</div><br><br><br></div>", "i": 7162676, "v": ["CONCORDANCIA"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, lo he aprobado i sancionado; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 8 de Junio de 1896.-JORJE MONTT.-Herm&#xF3;jenes P&#xE9;rez de Arce.</div><br></div>", "i": 7162677}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "355", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-355"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "INTERES DEL EMPRESTITO AUTORIZADO POR LEI NUM. 323 DE 20 DE DICIEMBRE DE 1895", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTE REPUBLICA", "EMPRESTITO", "CONTRATACION", "INTERESES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-06-08", "doble_articulado": false, "id_norma": "22206", "numero_fuente": "5427", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1896-06-09", "vigencias"