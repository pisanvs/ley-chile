{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6576978}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;1.810, de 28 de junio de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a ALEJANDRA MACARENA HERRERA HERRERA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden instalar y operar una planta ubicada en Arturo Prat N&#xBA;145, Lota, VIII Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco-enfriado, Fresco-refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA;985 de 2006, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6576979}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de junio de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6576980}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1810 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1810 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-28", "doble_articulado": false, "id_norma": "251591", "numero_fuente": "38522", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-07-25", "vigencias": [{"desde": "2006-07-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-07-25", "fin_vigencia": ""}, "vigenci