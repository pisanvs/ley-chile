{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8331565}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xBA; 881, de 12 de junio de 1998 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se rechaza la solicitud de la EMPRESA MAR DEL SUR S.A., respecto del certificado de transferencia de la nave &apos;&apos;Mar del Sur III&apos;&apos;. Se rechazan asimismo las solicitudes de la peticionaria para incluir la nave &apos;&apos;Mar del Sur III&apos;&apos; en n&#xF3;minas establecidas en el art&#xED;culo 22 del D.S. N&#xBA; 430 de 1991, de especies declaradas en plena explotaci&#xF3;n, correspondientes al &#xE1;rea del art&#xED;culo 12 Transitorio del mismo cuerpo legal.</div><br></div>", "i": 8331566}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 12 de junio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8331567}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "881", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-881"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "EMPRESA MAR DEL SUR S.A.", "NAVES PESQUERAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-06-12", "doble_articulado": false, "id_norma": "120846", "numero_fuente": "36107", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-07-07", "vigencias": [{"desde": "1998-07-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-07-07", "fin_vigencia": ""}, "vigencias