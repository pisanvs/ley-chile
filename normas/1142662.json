{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10102602}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xB0; 393, de 7 de febrero de 2020, aprueba gu&#xED;a para la fabricaci&#xF3;n, instalaci&#xF3;n y mantenci&#xF3;n de c&#xE1;maras hiperb&#xE1;ricas multiplaza utilizadas para la recomendaci&#xF3;n de superficie asociada al buceo.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10102603}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mar&#xED;a Judith Mora Riquelme, Directora (S), Instituto de Salud P&#xFA;blica de Chile.</div><br></div>", "i": 10102604}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "393 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-393 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1729870", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-02-07", "doble_articulado": false, "id_norma": "1142662", "numero_fuente": "42586", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-02-22", "vigencias": [{"desde": "2020-02-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2020-02-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2020-02-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_