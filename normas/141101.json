{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 3,370.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 9050960}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Los sub - Secretarios de Estado gozar&#xE1;n de un sueldo anual de veinte mil pesos ($ 20,000).</div><div class=\"p\">&nbsp; &nbsp;  Los Jefes de Seccion de los Ministerios gozar&#xE1;n de un sueldo anual de doce mil pesos ($ 12,000)&quot;.</div><br></div>", "i": 9050961, "v": ["CONCORDANCIA"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto en todas sus partes como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, diez de mayo de mil novecientos dieciocho.- Juan Luis Sanfuentes.- Arturo Alessandri.</div><br></div>", "i": 9050962}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3370", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3370"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1918-05-10", "doble_articulado": false, "id_norma": "141101", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1918-05-10", "vigencias": [{"desde": "1918-05-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1918-05-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1918-05-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos