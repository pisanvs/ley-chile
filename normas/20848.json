{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 269 EXENTO, DE 1995 </div></div>", "i": 5943338}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 269 de fecha 02 de mayo de 1995 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Chileno Alem&#xE1;n de Cultura de San Antonio, las adecuaciones introducidas al plan y programas de estudio de la carrera T&#xE9;cnico en Operaciones y Comercio Portuario, las que se insertaron en la Resoluci&#xF3;n Exenta del Ministerio de Educaci&#xF3;n N&#xB0; 1641 de 1989. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1995.</div><br></div>", "i": 5943339}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 25 de Mayo de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943340}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "269", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-269"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 269 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO CHILENO ALEMAN CULTURA", "SAN ANTONIO", "CENTRO FORMACION TECNICO", "PROGRAMAS ESTUDIO", "PLANES ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-02", "doble_articulado": false, "id_norma": "20848", "numero_fuente": "35192", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-06-13", "vigencias": [{"desde": "1995-06-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-06-13", "fin_vigencia": ""}, "vigencias_version_norma":