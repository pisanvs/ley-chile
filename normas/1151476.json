{"html": [{"t": "<div><div class=\"p\">&#xFEFF;OTRO.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, Octubre 8 de 1825.</div></div>", "i": 10178471}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Hall&#xE1;ndose vacante el Ministerio de Estado en el Departamento de Hacienda por dimision del que lo obtenia; y siendo preciso elejir para el un ciudadano de conocimientos y buena comportacion: concurriendo estas circunstancias en D. Diego Jos&#xE9; Benavente, he venido en elejirle por tal Ministro de Hacienda. </div></div>", "i": 10178472}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, comun&#xED;quese e impr&#xED;mase.</div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; -----&nbsp; &nbsp; Astorga.</div></div>", "i": 10178473}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DE INTERIOR"], "titulo_norma": "OTRO", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-10-08", "doble_articulado": false, "id_norma": "1151476", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-10-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-10-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-10-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2020-11-27", "fecha_version": "1825-10-08", "fecha_actualizacion_texto": "2020-11-27