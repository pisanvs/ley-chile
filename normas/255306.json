{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 10,673</div><br><br><div class=\"p\">RECONOCE EL TIEMPO QUE INDICA A DON JORGE SOUPER MATURANA</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6589751}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Recon&#xF3;cense, por gracia y para todos los efectos legales, los cuatro a&#xF1;os, dos meses y veintisiete d&#xED;as que sirvi&#xF3; don Jorge Souper Maturana como ex Oficial de Reclutamiento del Ej&#xE9;rcito. </div></div>", "i": 6589752}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y visto lo dispuesto por el art&#xED;culo 54, inciso segundo, de la Constituci&#xF3;n Pol&#xED;tica del Estado; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a tres de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Ignacio Lorca G.</div><br></div>", "i": 6589753}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10673", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10673"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "RECONOCE EL TIEMPO QUE INDICA A DON JORGE SOUPER\nMATURANA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-03", "doble_articulado": false, "id_norma": "255306", "numero_fuente": "22382", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-10-23", "vigencias": [{"desde": "1952-10-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inici