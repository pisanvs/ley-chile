{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10188281}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n DGTM y MM Ordinario N&#xBA; 12600/01/1591 Vrs., del 16 de diciembre de 2020, establece el procedimiento y los requisitos para otorgar el t&#xED;tulo de tripulante general de cubierta y m&#xE1;quinas, y el t&#xED;tulo de tripulante de la guardia de navegaci&#xF3;n y m&#xE1;quinas.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta Resoluci&#xF3;n se encuentra publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10188282}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de diciembre de 2020.- Paul Miguras Silva, Teniente 2&#xBA; AB, Jefe Depto. Abastecimiento.</div><br></div>", "i": 10188283}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1591", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1591"}, {"tipo": "3", "numero": "12600/01/1591", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-12600/01/1591"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1872844", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-12-16", "doble_articulado": false, "id_norma": "1153983", "numero_fuente": "42841", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-12-29", "v