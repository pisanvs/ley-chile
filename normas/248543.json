{"html": [{"t": "<div><div class=\"p\">ACLARA RESOLUCION N&#xBA;14 EXENTA, DEL 08.02.2005 </div></div>", "i": 6565749}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA;32, de 24 de marzo de 2006, que establece:</div><br><div class=\"p\">&nbsp; &nbsp;  Permite la autorizaci&#xF3;n de documentos tributarios a pesar que su fecha de vigencia corresponda al mismo a&#xF1;o del timbraje.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtural del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de marzo de 2006. </div></div>", "i": 6565750}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "32 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-32 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ACLARA RESOLUCION Nº14 EXENTA, DEL 08.02.2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-03-24", "doble_articulado": false, "id_norma": "248543", "numero_fuente": "38427", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-30", "vigencias": [{"desde": "2006-03-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-03-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-03-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part":