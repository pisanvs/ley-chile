{"html": [{"t": "<div><div class=\"p\">DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA </div></div>", "i": 6269030}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n</div><div class=\"p\">Exenta No. 2.022 de 28 de Septiembre de 1987, conforme</div><div class=\"p\">Art. 5&#xB0; Transitorio del C&#xF3;digo de Aguas, determin&#xF3; Derechos de Aprovechamiento de Aguas que corresponden a Sector Excluido y Sector Expropiado predio &quot;Fundo Lo Rojas&quot; de la comuna de La Cruz, Quinta Regi&#xF3;n y Derechos de Aprovechamiento de Aguas que corresponden a las parcelas N&#xB0;s. 3 a la 33 y sitios N&#xB0;s. 1 al 20 del Proyecto de Parcelaci&#xF3;n &quot;Los Faisanes&quot;, formado por predio se&#xF1;alado. Los derechos de aguas se extraen del Canal Lo Rojas. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.</div><br></div>", "i": 6269031}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6269032}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2022 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2022 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-28", "doble_articulado": false, "id_norma": "166742", "numero_fuente": "32883", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-10-01", "vigencias": [{"desde": "1987-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_v