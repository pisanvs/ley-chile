{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6599081}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 185, de 19 de enero de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a ROC&#xCD;O SALOM&#xC9; CARRERA LINAY, para ampliar las actividades pesqueras de transformaci&#xF3;n autorizadas por la resoluci&#xF3;n citada en Visto, en orden a incorporar a la planta ubicada en Eusebio Ibar N&#xBA; 1110, Puerto Ays&#xE9;n, XI Regi&#xF3;n, en las l&#xED;neas de proceso de Fresco enfriado, Fresco refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6599082}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de enero de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6599083}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "185 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-185 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-01-19", "doble_articulado": false, "id_norma": "257832", "numero_fuente": "38673", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-01-26", "vigencias": [{"desde": "2007-01-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-01-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-01-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresad