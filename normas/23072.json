{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,024 que suprime la comuna de Curaco i anexa su territorio a la de Collipulli.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,024.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274922}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ART&#xCD;CULO &#xDA;NICO. Supr&#xED;mese la comuna de Curaco i an&#xE9;xase su territorio a la de Collipulli.</div><br></div>", "i": 8274923}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 9 de setiembre de 1907.- PEDRO MONTT.- Luis A. Vergara.</div><br></div>", "i": 8274924}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2024", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2024"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 2,024 QUE SUPRIME LA COMUNA DE CURACO I ANEXA SU TERRITORIO A LA DE COLLIPULLI.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CURACO", "SUPRESION", "COLLIPULLI", "ANEXACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-09-09", "doble_articulado": false, "id_norma": "23072", "numero_fuente": "8900", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-09-13", "vigencias": [{"desde": "1907-09-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-09-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"ini