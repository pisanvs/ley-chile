{"html": [{"t": "<div><div class=\"p\">APRUEBA ORDENANZA SOBRE SUBVENCIONES MUNICIPALES </div></div>", "i": 6474199}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La I. Municipalidad de Llanquihue pone en conocimiento de la comunidad que por decreto alcaldicio N&#xBA;394-A, de fecha 31 de marzo de 2004, fue aprobada la ordenanza que norma sobre el procedimiento a observar para el otorgamiento de las Subvenciones Municipales.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto completo de la citada Ordenanza est&#xE1; a disposici&#xF3;n de quien lo solicite en la Secretar&#xED;a Municipal, cuya oficina se ubica en calle Erardo Werner 450, en la ciudad de Llanquihue.</div><br></div>", "i": 6474200}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Walterio Vargas G&#xF3;mez, Alcalde.</div><br></div>", "i": 6474201}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "394", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-394"}, {"tipo": "2", "numero": "394-A", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-394-A"}], "organismos": ["MUNICIPALIDAD DE LLANQUIHUE"], "titulo_norma": "APRUEBA ORDENANZA SOBRE SUBVENCIONES MUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-31", "doble_articulado": false, "id_norma": "223915", "numero_fuente": "37837", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-16", "vigencias": [{"desde": "2004-04-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-04-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-04-16", "fin_vigencia": "", "tipo_version": "3"