{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 71, DE 1987 </div></div>", "i": 6188697}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 71, de 14 de Abril de 1987 se ha aprobado para la Escuela Familiar Agr&#xED;cola de la Fundaci&#xF3;n &quot;Dolores Vald&#xE9;s de Covarrubias&quot;, de la comuna de Pirque, provincia Cordillera, Regi&#xF3;n Metropolitana, plan y programa especial de estudio para la Educaci&#xF3;n Media, modalidad t&#xE9;cnico - profesional, que se aplicar&#xE1; gradualmente a contar del a&#xF1;o escolar 1987 y hasta el a&#xF1;o escolar de 1992, conducente al t&#xED;tulo de T&#xE9;cnico de Nivel Medio en la Especialidad de Extensi&#xF3;n Rural Agr&#xED;cola.- </div></div>", "i": 6188698}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6188699}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "71 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-71 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 71, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-04-14", "doble_articulado": false, "id_norma": "142560", "numero_fuente": "32756", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-04-27", "vigencias": [{"desde": "1987-04-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-04-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-04-27"