{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6575782}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto Exento MOP N&#xBA; 331 de 21 de junio de 2006, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA; del Decreto MOP Exento N&#xBA;454 de 26 de marzo de 2004, en la parte en que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote N&#xBA; 23-A. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n del lote N&#xBA; 23-A, fijada por la Comisi&#xF3;n de Peritos el 21 de abril de 2003, en la cantidad de $42.000.</div><br></div>", "i": 6575783}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6575784}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "331 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-331 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-21", "doble_articulado": false, "id_norma": "251290", "numero_fuente": "38514", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-07-15", "vigencias": [{"desde": "2006-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modi