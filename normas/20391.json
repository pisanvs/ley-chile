{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 142 EXENTO, DE 1995 </div></div>", "i": 5941843}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 142 de 1&#xB0; de Marzo de 1995, se han aprobado planes y programas especiales de estudio al Liceo &quot;Pablo Neruda&quot; (ex B N&#xB0; 18) de la comuna de Navidad, provincia de Cardenal Caro, VI Regi&#xF3;n del Libertador Bernardo O&apos;Higgins, para ense&#xF1;anza b&#xE1;sica y media human&#xED;stico-cient&#xED;fica, a partir del a&#xF1;o escolar 1995.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s se aprueban programas de estudio, en las asignaturas y cursos que se indican en el presente decreto.</div><br></div>", "i": 5941844}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 7 de Marzo de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5941845}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "142", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-142"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 142 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LICEO PABLO NERUDA", "NAVIDAD", "SEXTA REGION", "PROGRAMAS ESTUDIO", "PLANES ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-03-01", "doble_articulado": false, "id_norma": "20391", "numero_fuente": "35116", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-03-13", "vigencias": [{"desde": "1995-03-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-03-13", "fin_vigencia": ""},