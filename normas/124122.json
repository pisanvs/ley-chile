{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6129696}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 1130 de 14.11.88 de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL 2186 de 1987, parte inmueble ubicado en Avda. Irarr&#xE1;zaval No. 200 - 204 - 210 - 218 - 222 y 226 tambi&#xE9;n signado por Avda. Bustamante con los N&#xB0;s 790 - 792 - 794 - 796 y 798 presunto rol aval&#xFA;os No. 950-46 comuna &#xD1;u&#xF1;oa aparentemente dominio de don Pedro Maino Scappini y Otro. Comisi&#xF3;n integrada por peritos Juan Pa&#xF1;ella Casares, arquitecto, Carlos del Pedregal S&#xE1;nchez, constructor civil y Emilio Recabarren Solar, ingeniero civil, seg&#xFA;n informe de 07 de agosto de 1988, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 33.022.500, pagadera al contado.-</div><br></div>", "i": 6129697}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director SERVIU Metropolitano.</div><br></div>", "i": 6129698}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1130", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1130"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN REGIÓN METROPOLITANA"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-11-14", "doble_articulado": false, "id_norma": "124122", "numero_fuente": "33235", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-12-01", "vigencias": [{"desde": "1988-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}