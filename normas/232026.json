{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6503254}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n N&#xBA; 601, 06 octubre 2004, Serviu Regi&#xF3;n del B&#xED;o B&#xED;o orden&#xF3; expropiaci&#xF3;n parcial inmueble ubicado en calle Nuevo Camino a Hualqui, Rol de Aval&#xFA;o N&#xBA; 3230-1 comuna Chiguayante, superficie 690,33 metros cuadrados de terreno, dentro pol&#xED;gono y linderos se&#xF1;alados plano expropiaci&#xF3;n S8R-19.229; de aparente dominio de Suc Adauy Hasbun, para ejecuci&#xF3;n programa &quot;Mejoramiento Vial Eje O&apos;Higgins de Chiguayante&quot;, conforme art&#xED;culo 51 Ley 16.391 y D.L. N&#xBA; 2.186. Comisi&#xF3;n Peritos integrada por Hern&#xE1;n C&#xE1;ceres Moscoso, ingeniero civil, Miguel Bonifetti Dall&apos;Orso, arquitecto, y Mario Bellolio Bosticca, arquitecto, seg&#xFA;n informe de fecha 24 de septiembre de 2004, fij&#xF3; monto provisional indemnizaci&#xF3;n en $17.787.043.-, pagadera de contado.</div><br></div>", "i": 6503255}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Servio Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6503256}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "601", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-601"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANIZACIÓN", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGION DEL BIOBÍO"], "titulo_norma": "DISPONE EXPROPIACIONES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-06", "doble_articulado": false, "id_norma": "232026", "numero_fuente": "38000", "tipo_