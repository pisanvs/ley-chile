{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6432977}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.585, de 9 de julio de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA LANDES S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Huachinango&quot;, en el &#xE1;rea mar&#xED;tima correspondiente a la X Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar, con cerco, los recursos hidrobiol&#xF3;gicos Caballa, Agujilla, Bonito, Machuelo o Tritre y Sardina espa&#xF1;ola. </div></div>", "i": 6432978}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de julio de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6432979}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1585 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1585 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-07-09", "fecha_derogacion": "2011-12-03", "doble_articulado": false, "id_norma": "212879", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-07-24", "vigencias": [{"desde": "2011-12-03", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-07-24", "hasta": "2011-12-02", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2011-12-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-07-24", "fin_vigencia": "2011-12-02", "tipo_version": "0"