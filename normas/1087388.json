{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE INDICA </div></div>", "i": 9674556}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 303, de 29 de enero de 2016, de esta Subsecretar&#xED;a, modif&#xED;case <a href=\"https://www.leychile.cl/Navegar?idNorma=1061562&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 1.064 de 2014</a>, de esta Subsecretar&#xED;a, que estableci&#xF3; agrupaciones de concesiones de acuicultura de salm&#xF3;nidos en X, XI y XII Regi&#xF3;n, adecuando las agrupaciones de concesiones 5 y 6 en la X Regi&#xF3;n, en la forma indicada en la resoluci&#xF3;n extractada y publicada &#xED;ntegramente en www.subpesca.cl. y www.sernapesca.cl. </div><br></div>", "i": 9674557}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de enero de 2016.- Paolo Trejo Carmona, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9674558}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "303 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-303 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y AGRICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 995327; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-01-29", "doble_articulado": false, "id_norma": "1087388", "numero_fuente": "41378", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-02-09", "vigencias": [{"desde": "2016-02-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2016-02-09", "fin_vigencia": ""}, "vigencias_ver