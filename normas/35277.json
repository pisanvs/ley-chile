{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293488}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 638, de 10 de abril de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a ALGAS DEL SUR S.A., para ampliar actividades pesqueras, en orden a instalar y operar una planta ubicada en camino al Aeropuerto s/n, Quell&#xF3;n, Chilo&#xE9;, donde podr&#xE1; procesar, en la l&#xED;nea de elaboraci&#xF3;n de Secado artificial de algas, los siguientes recursos: Cochayuyo, Chasca, Chasc&#xF3;n, Chicorea de mar, Huiro, Liquen gomoso, Luga-Luga, Pelillo.</div><br></div>", "i": 8293489}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 10 de abril de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293490}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "638", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-638"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "ALGAS DEL SUR S.A.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-04-10", "doble_articulado": false, "id_norma": "35277", "numero_fuente": "35448", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-04-22", "vigencias": [{"desde": "1996-04-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-04-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-04-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v