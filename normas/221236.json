{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6464491}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA; 1.580, de 15 de diciembre de 2003, se modificaron los numerales 1 &#xBA; y 2&#xBA; del decreto exento MOP N&#xBA; 792, de 22 de agosto de 2003, en el sentido que el lote N&#xBA; 7, se encuentra en la provincia de Llanquihue, el lote N&#xBA; 8, en la provincia de Osorno y que la superficie del lote N&#xBA; 8, es 631,88. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978. </div></div>", "i": 6464492}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6464493}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1580 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1580 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-15", "doble_articulado": false, "id_norma": "221236", "numero_fuente": "37787", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-16", "vigencias": [{"desde": "2004-02-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-02-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-02-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "DVG", "fecha_ingreso": "2004-02-16", "fecha_version": "2004-02-16", "f