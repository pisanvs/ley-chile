{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA NOMBRE A LAS CALLES QUE INDICA DEL PUEBLO DE SAN JOSE DE LA MARIQUINA.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8281861}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Denom&#xED;nanse &quot;Carlos Achar&#xE1;n Arce&quot; la calle Pedro Moreno del pueblo de San Jos&#xE9; de la Mariquina; &quot;Gustavo Exss Manns&quot; la Avenida Cementerio, del mismo pueblo, y &quot;Godofredo Meza Garc&#xED;a&quot; la calle Enrique Schmidt del pueblo mencionado&quot;.</div><br></div>", "i": 8281862}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecinueve de julio de mil novecientos sesenta y dos.- JORGE ALESSANDRI RODRIGUEZ.- S&#xF3;tero del R&#xED;o.</div><br></div>", "i": 8281863}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14871", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14871"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA NOMBRE A LAS CALLES QUE INDICA DEL PUEBLO DE\nSAN JOSE DE LA MARIQUINA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "CALLE CARLOS ACHARAN ARCE", "SAN JOSE MARIQUINA", "AVENIDA GUSTAVO EXSS MANNS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1962-07-19", "doble_articulado": false, "id_norma": "27946", "numero_fuente": "25304", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1962-