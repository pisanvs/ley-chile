{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede amnist&#xED;a a ciudadano Juan Pablo Garc&#xED;a Mu&#xF1;oz, condenado por delito de inscripci&#xF3;n doble.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente,</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 5958836}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 1.o Conc&#xE9;dese amnist&#xED;a al ciudadano Juan Pablo Garc&#xED;a Nu&#xF1;oz, condenado por doble inscripci&#xF3;n electoral, a un a&#xF1;o de reclusi&#xF3;n y p&#xE9;rdida de sus derechos de ciudadano elector por un per&#xED;odo de diez a&#xF1;os. </div></div>", "i": 5958837}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 2.o Esta ley regir&#xE1; desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 5958838}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a quince de Diciembre de mil novecientos veintisiete.- Carlos Ib&#xE1;&#xF1;ez C.- Enrique Balmaceda. </div></div>", "i": 5958839}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4222", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4222"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "Concede amnistía a ciudadano Juan Pablo García;Muñoz, condenado por delito de inscripción doble.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUAN PABLO GARCIA MU OZ", "AMNISTIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1927-12-15", "doble_articulado": false, "id_norma": "24579", "numero_fuente": "14950",