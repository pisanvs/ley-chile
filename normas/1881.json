{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5845416}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 7,01% anual durante el mes de noviembre de 1996.</div><div class=\"p\">&nbsp; &nbsp; Asimismo, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de noviembre de 1996, fue de 6,97% anual.</div><br></div>", "i": 5845417}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 4 de diciembre de 1996.- Jorge Carrasco V&#xE1;squez, Ministro de Fe.</div><br></div>", "i": 5845418}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA INTERES PROMEDIO", "TIP", "OPERACIONES CREDITO DINERO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-12-04", "doble_articulado": false, "id_norma": "1881", "numero_fuente": "35634", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-12-06", "vigencias": [{"desde": "1996-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-12-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-12-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [],