{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6426429}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.138, de 30 de mayo de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA; de la resoluci&#xF3;n N&#xBA; 927 modificada por resoluci&#xF3;n N&#xBA; 1.071, ambas de 2003, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO, para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto denominado &quot;Determinaci&#xF3;n de la Distribuci&#xF3;n Espacial de Jurel entre la V y X Regiones, Oto&#xF1;o 2003&quot;, en el sentido de se&#xF1;alar que la mencionada investigaci&#xF3;n se extender&#xE1; hasta el 15 de junio de 2003.</div><br></div>", "i": 6426430}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de mayo de 2003.-&nbsp; Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6426431}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1138", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1138"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-05-30", "doble_articulado": false, "id_norma": "211089", "numero_fuente": "37583", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-13", "vigencias": [{"desde": "2003-06-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-06-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vige