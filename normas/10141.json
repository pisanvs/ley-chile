{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5896970}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto MOP N&#xB0; 153, de 29 de Abril de 1994, se expropiaron los lotes de terreno N&#xB0;s. 2 y 7, superficies 270 m2. y 698 m2., roles de aval&#xFA;o 5-86 y 5-90, comuna de Mar&#xED;a Pinto, para la obra Camino Lolenco-Mar&#xED;a Pinto, Cruce El Redil-Mar&#xED;a Pinto, Ruta G-734, y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Jacques Simian Lasserre y El&#xED;as Jacob Helo, ascendente a las sumas de $197.654.- y $407.395.-</div><br></div>", "i": 5896971}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 5896972}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "153", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-153"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "INMUEBLE", "BIEN RAIZ", "DECRETO EXPROPIATORIO", "MARIA PINTO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-04-29", "doble_articulado": false, "id_norma": "10141", "numero_fuente": "34890-2", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-06-15", "vigencias": [{"desde": "1994-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1994-06-15", "fecha_actualizacion_texto": "1994-06-15", "tipo_tratado": ""}, "alerta