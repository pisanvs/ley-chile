{"html": [{"t": "<div><div class=\"p\">PARTIDO &quot;NUEVA ALIANZA POPULAR&quot; </div></div>", "i": 6040922}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Cecilia Vargas Cornejo, Presidente del Tribunal Supremo del partido &quot;Nueva Alianza Popular&quot;, y Eduardo Enrique Guti&#xE9;rrez Gonz&#xE1;lez, Primer Vicepresidente, en representaci&#xF3;n de la colectividad, han informado el nombramiento como Presidente del partido del se&#xF1;or Eduardo Enrique Guti&#xE9;rrez Gonz&#xE1;lez, en reemplazo de don Nicol&#xE1;s Garc&#xED;a Moreno, quien ocupar&#xE1; el cargo de Primer Vicepresidente en la Directiva Central de la colectividad.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada en virtud del Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por Resoluci&#xF3;n O-N&#xBA; 0689 de fecha 3 de julio de 1997.-</div><br></div>", "i": 6040923}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andr&#xE9;s Merino Espi&#xF1;eira, Director (S). </div></div>", "i": 6040924}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "689", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-689"}, {"tipo": "3", "numero": "O-0689", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-0689"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO NUEVA ALIANZA POPULAR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO NUEVA ALIANZA POPULAR", "DIRECTIVA CENTRAL", "PRESIDENTE", "NOMBRAMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-03", "doble_articulado": false, "id_norma": "74125", "numero_fuente": "35808", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-0