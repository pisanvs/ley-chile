{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 1.551 EXENTA, DE 2013</div></div>", "i": 9339403}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 1.551, de 6 de marzo de 2013, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Capacitaciones Profesionales Limitada (Freelance English Ltda.)&quot;, RUT 77.331.510-8, contenida en la resoluci&#xF3;n exenta N&#xBA; 5.008, de 6 agosto de 2007, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2 del Art. 21 de la ley 19.518.- </div></div>", "i": 9339404}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Felipe Bravo Coloma, Director Nacional (S).</div></div>", "i": 9339405}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1551 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1551 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 1.551 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-03-06", "doble_articulado": false, "id_norma": "1049569", "numero_fuente": "40515", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-03-21", "vigencias": [{"desde": "2013-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-03-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-03-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vi