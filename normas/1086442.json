{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9665826}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. (EXENTO) N&#xBA;1394 de 29 de diciembre de 2015, se desisti&#xF3; de la expropiaci&#xF3;n del lote 30-B, ordenada por el <a href=\"https://www.leychile.cl/Navegar?idNorma=1003498&amp;idParte=&amp;idVersion=\">Decreto MOP (Exento) N&#xBA;765 de 19 de mayo de 200</a>9, debido a que dicho lote fue eliminado mediante Resuelvo Fiscal&#xED;a (Exenta) N&#xBA;31 de 17 de enero de 2012. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA; 2186, de 1978. </div><br></div>", "i": 9665827, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9665828}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1394 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1394 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 986468", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-12-29", "doble_articulado": false, "id_norma": "1086442", "numero_fuente": "41357", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-01-15", "vigencias": [{"desde": "2016-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2016-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2016-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente