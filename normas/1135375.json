{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 266 EXENTA, DE 2019, DE ESTA SUBSECRETAR&#xCD;A</div></div>", "i": 10048778}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.815, de 16 de agosto de 2019, de esta Subsecretar&#xED;a, modif&#xED;quese el numeral 1.- de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1128583&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 266 de 2019</a>, que estableci&#xF3; la distribuci&#xF3;n para el a&#xF1;o 2019 de las fracciones artesanales de las pesquer&#xED;as artesanales de Anchoveta y Sardina com&#xFA;n en las regiones de &#xD1;uble y del Biob&#xED;o, sometidas al R&#xE9;gimen Artesanal de Extracci&#xF3;n por organizaciones de pescadores artesanales, en el sentido de reemplazar las tablas de las letras A) y B), por las siguientes:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  A) Pesquer&#xED;a de Anchoveta:</div><div class=\"p\"> </div><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/96760.jpg\">.</div><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/96761.jpg\">.</div><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/96762.jpg\">.</div><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/96763.jpg\">.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  B) Pesquer&#xED;a de sardina com&#xFA;n:</div><div class=\"p\"> </div><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/96764.jpg\">.</div><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/96765.jpg\">.</div><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/96766.jpg\">.</div><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/96767.jpg\">.</div><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/96768.jpg\">.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n extractada se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 10048779}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de agosto de 2019.- Rom&#xE1;n Zelaya R&#xED;os, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 10048780}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2815 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2815 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 266 EXENTA, DE 2019, DE ESTA SUBSECRETARÍA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1642280", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-08-16", "doble_articulado": false, "id_norma": "1135375", "numero_fuente": "42439", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-08-27", "vigencias": [{"desde": "2019-08-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-08-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2019-08-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "10418", "fecha_ingreso": "2019-08-27", "fecha_version": "2019-08-27", "fecha_actualizacion_texto": "2019-08-27", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10048778}, {"n": "Artículo", "i": 10048779, "t": 6}, {"n": "Promulgación"