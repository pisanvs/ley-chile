{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 2,216.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170184}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese a do&#xF1;a Anjela Osorio, viuda de Escanilla, nieta lej&#xED;tima del coronel de la Independencia don Agustin L&#xF3;pez Alc&#xE1;zar, una pension de cuarenta pesos ($ 40) al mes, de que gozar&#xE1; con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6170185}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, siete de setiembre de mil novecientos nueve.- Pedro Montt.- Roberto Huneeus.</div><br></div>", "i": 6170186}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2216", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2216"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1909-09-07", "doble_articulado": false, "id_norma": "136877", "numero_fuente": "9490", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1909-09-13", "vigencias": [{"desde": "1909-09-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1909-09-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1909-09-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [