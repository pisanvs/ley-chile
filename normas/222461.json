{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A SOC. CONSTRUCTORA LAGO MAIHUE LTDA.</div><br></div>", "i": 6469004}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VI Direcci&#xF3;n Regional Rancagua del Servicio de Impuestos Internos, por resoluci&#xF3;n N&#xBA; 23 de fecha 30 de enero de 2004, otorga la calidad de agente retenedor del IVA en la actividad de la construcci&#xF3;n a Soc. Constructora Lago Maihue Ltda. Rut. N&#xBA; 79.715.310-9. Resoluci&#xF3;n que entrar&#xE1; en vigencia a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, de acuerdo a lo establecido por la resoluci&#xF3;n Ex. N&#xBA; 46 del 01 septiembre del 2003, de la Direcci&#xF3;n Nacional. </div></div>", "i": 6469005}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Luis Mu&#xF1;oz Arratia, Director Regional. </div></div>", "i": 6469006}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "23", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-23"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VI DIRECCIÓN REGIONAL DE RANCAGUA"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A SOC.\nCONSTRUCTORA LAGO MAIHUE LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-30", "doble_articulado": false, "id_norma": "222461", "numero_fuente": "37810", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-13", "vigencias": [{"desde": "2004-03-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-03-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-03-