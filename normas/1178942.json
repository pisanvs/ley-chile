{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10350079}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Crea 1 cargo en la Planta Municipal Directivos Grado 7&#xB0; E.M., denominado &quot;Director de la Unidad de Gesti&#xF3;n de Riesgos de Desastres&quot;, dependiente de la Direcci&#xF3;n de Seguridad P&#xFA;blica, seg&#xFA;n lo establecido en el decreto alcaldicio N&#xB0; 7.260, de fecha 28/06/2022. Que modifica el <a href=\"https://www.leychile.cl/Navegar?idNorma=1140257&amp;idParte=&amp;idVersion=\">decreto 1/2019</a>, que Aprueba Reglamento que fija la Planta de Personal de la Municipalidad de Vi&#xF1;a del Mar, aumentando de 7 a 8 cargos la Planta Directivos Grado 7&#xB0; y modificando el total de funcionarios municipales de 1.031 a 1.032.-</div></div>", "i": 10350080}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; Leonardo Rissetti Morales, Alcalde (S).- Mar&#xED;a Cristina Rayo Sanhueza, Secretaria Municipal.</div></div>", "i": 10350081}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "7260", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-7260"}], "organismos": ["MUNICIPALIDAD DE VIÑA DEL MAR"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2159120", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-06-28", "doble_articulado": false, "id_norma": "1178942", "numero_fuente": "43307", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-07-21", "vigencias": [{"desde": "2022-07-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2022-07-21", "fin_vigencia": ""}, "vigencias_version_