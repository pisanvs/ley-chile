{"html": [{"t": "<div><div class=\"p\">APRUEBA ORDENANZA PARA EL OTORGAMIENTO DE SUBVENCIONES MUNICIPALES </div></div>", "i": 6486886}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La I. Municipalidad de Huala&#xF1;&#xE9; pone en conocimiento de la comunidad que por decreto alcaldicio N&#xBA; 553 del 22 de junio del presente a&#xF1;o, fue aprobada la ordenanza que norma sobre los procedimientos a observar para el otorgamiento de las Subvenciones Municipales.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de la citada ordenanza est&#xE1; a disposici&#xF3;n de quien lo solicite en la Secretar&#xED;a Municipal del municipio ubicado en Avda. Libertad 90, Huala&#xF1;&#xE9;.</div><br></div>", "i": 6486887}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Samuel Baeza Reyes, Alcalde.- Arturo Flores Cabrera, Secretario Municipal.</div><br></div>", "i": 6486888}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "553", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-553"}], "organismos": ["MUNICIPALIDAD DE HUALAÑE"], "titulo_norma": "APRUEBA ORDENANZA PARA EL OTORGAMIENTO DE SUBVENCIONES\nMUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-06-22", "doble_articulado": false, "id_norma": "227400", "numero_fuente": "37905", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-09", "vigencias": [{"desde": "2004-07-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-07-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-07-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion