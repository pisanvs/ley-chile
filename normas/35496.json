{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294022}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 750, de 29 de abril de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xB0; 1.344, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD PESQUERA SANTA BARBARA S.A., para operar cuatro naves en construcci&#xF3;n, por haberse configurado la causal prevista en el art&#xED;culo 143 letra b) de la Ley N&#xB0; 18.892 y sus modificaciones, citada en Visto.</div><br></div>", "i": 8294023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 29 de abril de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294024}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "750", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-750"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "SOCIEDAD PESQUERA SANTA BARBARA S.A", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-04-29", "doble_articulado": false, "id_norma": "35496", "numero_fuente": "35460", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-05-07", "vigencias": [{"desde": "1996-05-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-05-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-05-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones"