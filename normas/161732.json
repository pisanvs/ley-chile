{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 7265666}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 421, de 17.05.85, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se renueva la concesi&#xF3;n otorgada a la Empresa de origen chileno Bus Norte, Osvaldo Cid y Compa&#xF1;&#xED;a, por resoluciones N&#xBA;(s) 652 y 978, ambas de 1971 y 579/83, del Ministerio de Transportes y Telecomunicaciones para efectuar servicio regular de transporte internacional terrestre de pasajeros entre &quot;Puerto Montt - Osorno (Chile) y San Carlos de Bariloche (Argentina)&quot;, por Paso Puyehue, efectuando cinco frecuencias semanales.-</div><br></div>", "i": 7265667}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Carlos Villegas Lorca, Subsecretario de Transportes subrogante.</div><br></div>", "i": 7265668}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "421 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-421 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-17", "doble_articulado": false, "id_norma": "161732", "numero_fuente": "32189", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-06", "vigencias": [{"desde": "1985-06-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-06-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-06-06", "fin_vigencia": "", "tipo_ver