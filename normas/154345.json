{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 191, DE 1986</div><br><br></div>", "i": 7260413}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 586, de 6 de Agosto de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n No. 191, de 3 de Marzo de 1986, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a la Sociedad Conservera Mar Austral S.A., domiciliada en Santiago, para operar una planta elaboradora de congelado, conserva y deshidratado de recursos hidrobiol&#xF3;gicos en San Rafael, Comuna de Calbuco, Xa. Regi&#xF3;n, en orden a incluir en el numeral 3&#xB0; entre las especies que dicha sociedad puede elaborar, el recurso loco.</div><br></div>", "i": 7260414}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de Agosto de 1986.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 7260415}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "586", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-586"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 191, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-08-06", "fecha_derogacion": "1990-09-15", "doble_articulado": false, "id_norma": "154345", "numero_fuente": "32.566", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-09-05", "vigencias": [{"desde": "1990-09-15", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1986-09-05", "hasta": "1990-09-14", "