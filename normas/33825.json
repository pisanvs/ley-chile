{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291184}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 222, de 6 de febrero de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por SALMONES MULTIEXPORT LIMITADA, para operar un centro de cultivo ubicado en Punta Balseo, Canal Dalcahue, Comuna de Curaco de V&#xE9;lez, Provincia de Chilo&#xE9;, X Regi&#xF3;n, en virtud a lo dispuesto en el art&#xED;culo 78 inciso 2&#xB0; de la Ley General de Pesca y Acuicultura, por sobreponerse con una concesi&#xF3;n de acuicultura ya otorgada.</div><br></div>", "i": 8291185}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 6 de febrero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8291186}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "222", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-222"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION ACUICULTURA", "DENEGACION", "SALMONES MULTIEXPORT LIMITADA", "DALCAHUE", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-02-06", "doble_articulado": false, "id_norma": "33825", "numero_fuente": "35391", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-02-13", "vigencias": [{"desde": "1996-02-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-02-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig