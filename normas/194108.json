{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6694614}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.597, de esta Subsecretar&#xED;a, autor&#xED;zase a OTTO GEBLER Y CIA. LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en Camino Villarrica-Puc&#xF3;n Km. 6, comuna de Villarrica, IX Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Ahumado y semi conserva: Salm&#xF3;n del Atl&#xE1;ntico, Salm&#xF3;n plateado y Trucha arcoiris.</div><br></div>", "i": 6694615}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6694616}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2597", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2597"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "194108", "numero_fuente": "37170", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-26", "vigencias": [{"desde": "2002-01-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2002-01-28", "fecha_version": "2002-01-26", "f