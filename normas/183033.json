{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO NUMERO 629, DE 1976, DEL MINISTERIO DE AGRICULTURA</div><br><br><br></div>", "i": 7281671}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 37, de 5 de Febrero de 1981, de la Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el decreto de Agricultura N&#xBA; 629, de 1976, que autoriz&#xF3; a la Sociedad Pesquera Coloso S. A. para operar, entre otras, la embarcaci&#xF3;n &quot;Cuy&#xE9;n&quot;, en orden a facultarla para operar dicha nave, adem&#xE1;s, en la zona del litoral comprendida entre la I y II Regi&#xF3;n, bajo las condiciones que se expresan.</div><br></div>", "i": 7281672}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Roberto Verdugo Gormaz, Subsecretario de Pesca. </div></div>", "i": 7281673}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "37", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-37"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA DECRETO NUMERO 629, DE 1976, DEL MINISTERIO DE AGRICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1981-02-05", "fecha_derogacion": "2001-01-31", "doble_articulado": false, "id_norma": "183033", "numero_fuente": "30900", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1981-02-25", "vigencias": [{"desde": "2001-01-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1981-02-25", "hasta": "2001-01-30", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2001-0