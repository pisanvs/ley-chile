{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N&#xBA; 785 </div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su sesi&#xF3;n N&#xBA; 785, celebrada el 9 de septiembre de 1999, adopt&#xF3; el siguiente Acuerdo:</div><br></div>", "i": 6190815}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  785-01-990909-Modifica Cap&#xED;tulo III.B.2 del Compendio de Normas Financieras.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; modificar el Cap&#xED;tulo III.B.2 del Compendio de Normas Financieras, reemplazando en el N&#xBA; 2, la expresi&#xF3;n &apos;&apos;dos veces el capital b&#xE1;sico del respectivo Banco&apos;&apos; por la expresi&#xF3;n &apos;&apos;cuatro veces el capital b&#xE1;sico de la respectiva instituci&#xF3;n financiera&apos;&apos;.</div><br></div>", "i": 6190816}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de septiembre de 1999.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6190817}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "785", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-785"}, {"tipo": "5", "numero": "785-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-785-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION Nº 785", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-09-09", "doble_articulado": false, "id_norma": "143276", "numero_fuente": "36464", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-14", "vigencias": [{"desde": "1999-09-14", "hasta": "", "tipo_version": "3", "tipo_v