{"html": [{"t": "<div><br><div class=\"p\">NUEVA COMPOSICI&#xD3;N DE DIRECTIVA CENTRAL DEL PARTIDO HUMANISTA</div></div>", "i": 8750308}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Maril&#xE9;n Cabrera Olmos, Presidenta de la Directiva Central; y Jos&#xE9; Gabriel Feres Nazarala, Presidente del Tribunal Supremo, del Partido Humanista, respectivamente, comunican la nueva composici&#xF3;n de la Directiva Central de dicho partido:</div><div class=\"p\">Directiva Central:</div><br><div class=\"p\">Presidente&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  :&nbsp; &nbsp; Efr&#xE9;n Osorio Jara</div><div class=\"p\">Secretario General&nbsp;  :&nbsp; &nbsp; C&#xE9;sar Montenegro Ampuero</div><div class=\"p\">Tesorera&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  :&nbsp; &nbsp; Mar&#xED;a Soledad Zavala </div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Vergara</div><br><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada en virtud de lo establecido en el Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por resoluci&#xF3;n O N&#xBA; 18.904, de fecha 15 de julio de 2009.- </div></div>", "i": 8750309}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div></div>", "i": 8750310}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "18904", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolucion-18904"}, {"tipo": "3", "numero": "O Nº 18904", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolucion-O Nº 18904"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "NUEVA COMPOSICIÓN DE DIRECTIVA CENTRAL DEL PARTIDO HUMANISTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratado