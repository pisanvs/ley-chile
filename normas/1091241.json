{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 7.155 EXENTA, DE 5 DE NOVIEMBRE DE 2015</div><div class=\"p\"> </div></div>", "i": 9706656}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=1009454&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 8.497, de 2009, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, a la Scuola Italiana &quot;Arturo Dell&apos;Oro&quot; de la comuna de Valpara&#xED;so.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Sectores de Derecho y Econom&#xED;a Pol&#xED;tica (1&#xBA; a 4&#xBA; a&#xF1;o); Ciencias Humanas (1&#xBA; a 4&#xBA; a&#xF1;o); Inform&#xE1;tica (1&#xBA; a 4&#xBA; a&#xF1;o) y Artes Integradas (1&#xBA; y 2&#xBA; a&#xF1;o) de Educaci&#xF3;n Media.</div><br></div>", "i": 9706657}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 6 de noviembre de 2015.- Gonzalo Mu&#xF1;oz Stuardo, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 9706658}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7155 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-7155 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 7.155 EXENTA, DE 5 DE NOVIEMBRE DE 2015", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1030576; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-11-05", "doble_articulado": false, "id_norma": "1091241", "numero_f