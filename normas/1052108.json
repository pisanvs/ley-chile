{"html": [{"t": "<div><br><div class=\"p\">INFORMA NOMBRAMIENTO EN PARTIDO PROGRESISTA</div></div>", "i": 9360816}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Los se&#xF1;ores Camilo Lagos Miranda, Secretario General, Presidente de la Directiva Central del Partido Progresista y Carlos de Urresti Longton, Presidente del Tribunal Supremo de la colectividad, han informado el nombramiento de do&#xF1;a Patricia Morales Err&#xE1;zuriz como Vicepresidente de Asuntos Program&#xE1;ticos de la Directiva Central del partido.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada en virtud de lo establecido en el Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por resoluci&#xF3;n O-N&#xB0; 10.350, de fecha 10 de junio de 2013.- </div></div>", "i": 9360817}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Elizabeth Cabrera Burgos, Directora (S).</div></div>", "i": 9360818}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10350", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-10350"}, {"tipo": "3", "numero": "O-10350", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-10350"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "INFORMA NOMBRAMIENTO EN PARTIDO PROGRESISTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-06-10", "doble_articulado": false, "id_norma": "1052108", "numero_fuente": "40590", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-06-21", "vigencias": [{"desde": "2013-06-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-06-21", "fin