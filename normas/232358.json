{"html": [{"t": "<div><div class=\"p\">LEY NUM. 9.643</div><br><div class=\"p\">MODIFICA EN LA FORMA QUE SE&#xD1;ALA EL CODIGO ORGANICO DE TRIBUNALES</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 7316125}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Agr&#xE9;gase en el art&#xED;culo 44 del C&#xF3;digo Org&#xE1;nico de Tribunales, a continuaci&#xF3;n de las palabras &quot;Villa Alemana&quot;, la frase &quot;y el de Casablanca, que comprender&#xE1; tambi&#xE9;n la comuna de Algarrobo&quot;. </div></div>", "i": 7316126, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, nueve de Agosto de mil novecientos cincuenta.- GABRIEL GONZALEZ V.- Humberto Parada. </div></div>", "i": 7316127}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "9643", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-9643"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "MODIFICA EN LA FORMA QUE SEÑALA EL CODIGO ORGANICO DE\nTRIBUNALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1950-08-09", "doble_articulado": false, "id_norma": "232358", "numero_fuente": "21741", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1950-08-30", "vigencias": [{"desde": "1950-08-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1950-08-3