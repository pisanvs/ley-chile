{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9357909}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.379, de 3 de junio de 2013, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=1050429&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.001, de 2013</a>, que caduc&#xF3; la resoluci&#xF3;n exenta N&#xBA; 2.551, de 2004, que autoriz&#xF3; a PESCA CHILE S.A. para realizar actividades pesqueras extractivas con la nave &quot;Puerto Ballena&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 44&#xB0;30&apos; LS y 57&#xB0; LS, sobre el recurso hidrobiol&#xF3;gico Jibia, en virtud de lo se&#xF1;alado en el memor&#xE1;ndum t&#xE9;cnico citado en Visto, lo expresado en la parte considerativa de la resoluci&#xF3;n extractada y lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 9357910, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de junio de 2013.- Pablo Galilea Carrillo, Subscretario de Pesca y Acuicultura.</div></div>", "i": 9357911}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1379 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1379 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2013-06-03", "fecha_derogacion": "2014-12-06", "doble_articulado": false, "id_norma": "1051740", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "