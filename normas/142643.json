{"html": [{"t": "<div><div class=\"p\">CIRCULAR N&#xBA; 48 DE 1&#xBA; DE SEPTIEMBRE DE 1999</div><br><br></div>", "i": 6742545}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por medio de esta circular se imparten instrucciones para la aplicaci&#xF3;n de la exenci&#xF3;n del impuesto territorial que corresponde a los bienes ra&#xED;ces ubicados en la nueva zona favorecida con el r&#xE9;gimen preferencial aduanero y tributario establecido por la ley N&#xBA; 18.392, seg&#xFA;n modificaci&#xF3;n de l&#xED;mites dispuesta por la ley N&#xBA; 19.606.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta circular se encuentra incluido en la p&#xE1;gina Web de Servicio en Internet, cuya direcci&#xF3;n es http://www.sii.cl y adem&#xE1;s, se publicar&#xE1; en el Bolet&#xED;n del Servicio.</div><br></div>", "i": 6742546}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "48", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "CIR-48"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CIRCULAR Nº 48 DE 1º DE SEPTIEMBRE DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-09-01", "doble_articulado": false, "id_norma": "142643", "numero_fuente": "36458", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-07", "vigencias": [{"desde": "1999-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-09-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [],