{"html": [{"t": "<div><div class=\"p\">&#xFEFF;Ocupacion de una plaza en la Academia Militar</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago i Mayo 30 de 1817.</div></div>", "i": 9950587}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Dest&#xED;nase a la primera sesion de la Academia Militar a don Ventura Lagunas en el n&#xFA;mero de los cincuenta individuos quedota el Estado para que adquiriendo all&#xED; los conocimientos precisos, pueda d&#xE1;rsele en nuestro Ej&#xE9;rcito una colocacion correspondiente a su constante fidelidad por la sagrada causa. Impr&#xED;mase este decreto con los antecedentes que lo motivan.-</div></div>", "i": 9950588}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Quintana.</div></div>", "i": 9950589}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Ocupacion de una plaza en la Academia Militar", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1817-05-30", "doble_articulado": false, "id_norma": "1122887", "numero_fuente": "1817", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1817-05-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1817-05-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1817-05-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2018-09-21", "fecha_version": "1817-05-30", "fecha_actualizacion_texto": "2018-09-21", "tipo_tratado": ""}, "alertas": [],