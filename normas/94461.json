{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 211, DE 1988 </div></div>", "i": 6097144}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 211 de 30 de diciembre de 1988 se ha aprobado a la Escuela Especial F N&#xB0; 661 de Talagante, Regi&#xF3;n Metropolitana, un plan de estudio especial de orientaci&#xF3;n laboral para alumnos con deficiencia mental, que se desarrollar&#xE1; con car&#xE1;cter experimental por un per&#xED;odo de 4 a&#xF1;os, a contar del a&#xF1;o escolar 1989. Adem&#xE1;s, se aprueban programas de estudio correspondientes al plan que se aprueba por el presente decreto.</div><br></div>", "i": 6097145}, {"t": "<div><div class=\"p\">Santiago, 18 de Enero de 1989.- Paulina Dittborn Cordua, Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6097146}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "211 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-211 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 211, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-30", "doble_articulado": false, "id_norma": "94461", "numero_fuente": "33296", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-02-11", "vigencias": [{"desde": "1989-02-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-02-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-02-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresad