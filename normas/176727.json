{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6305278}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xB0; 3.933, de 31 de agosto de 2000, se modific&#xF3; el decreto MOP N&#xB0;298, de 24 de marzo de 1998, por cuanto en este &#xFA;ltimo se individualiz&#xF3; como lote a expropiar el N&#xB0;20, en circunstancias de que la individualizaci&#xF3;n correcta es el lote N&#xB0;9, necesario para la ejecuci&#xF3;n de la obra camino Ruta L-25, sector Lisonjera Yerbas-Buenas, Kms. 11,450 al 19,678.85. </div></div>", "i": 6305279}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6305280}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3933", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3933"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-08-31", "doble_articulado": false, "id_norma": "176727", "numero_fuente": "36788", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-16", "vigencias": [{"desde": "2000-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-10-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-10-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "MEM", "fecha_ingreso": "2000-10-16", "fecha_version": "2000-10-16", "fecha_actualizacion_texto": "2000-10-16", "tipo_tratado": ""}, "alertas": [], "alerta_gl