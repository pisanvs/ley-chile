{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291703}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 306, de 06 de Mayo de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 310, de 1984 y las Resoluciones N&#xB0; 160 y N&#xB0;233, ambas de 1985, todas de esta Subsecretar&#xED;a, que la modificaron y que autorizaron a la Sociedad Pesquera Guanaye Ltda., hoy PESQUERA IQUIQUE-GUANAYE S.A., R.U.T.</div><div class=\"p\">N&#xB0; 91.123.000-3, para operar un establecimiento de cultivo en seis sectores de Bah&#xED;a Mejillones del Sur, II Regi&#xF3;n, por renuncia de su titular, ya individualizado.- </div></div>", "i": 8291704}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 06 de Mayo de 1993. Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8291705}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "306", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-306"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "PESQUERA IQUIQUE GUANAYE S.A", "SOCIEDAD PESQUERA GUANAYE LTDA."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-05-06", "doble_articulado": false, "id_norma": "34245", "numero_fuente": "34563", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-05-12", "vigencias": [{"desde": "1993-05-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-05-12", "fin_vigencia":