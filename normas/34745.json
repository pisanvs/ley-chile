{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292405}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 428, de 25 de abril de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xB0; 1201, de 1991, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA ANTUMAPU LTDA., R.U.T. N&#xB0; 79.816.580-1, para operar la nave &quot;Antumapu I&quot;, por haberse configurado la causal prevista en el art&#xED;culo 143, letras b) y d) de la Ley N&#xB0; 18.892, citada en Visto.</div><br><br></div>", "i": 8292406}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 25 de Abril de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292407}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "428", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-428"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESQUERA ANTUMAPU", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-04-25", "doble_articulado": false, "id_norma": "34745", "numero_fuente": "35158", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-05-04", "vigencias": [{"desde": "1995-05-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-05-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-05-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "