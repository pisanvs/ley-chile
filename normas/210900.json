{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6425797}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.131, de 30 de mayo de 2003, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la resoluci&#xF3;n N&#xBA; 2.553 de 2000, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA CALCURRUPE LIMITADA para iniciar actividades pesqueras extractivas con la nave &quot;Ni&#xF1;o do Corvo&quot;, en el &#xE1;rea mar&#xED;tima, por fuera del &#xE1;rea de reserva artesanal, de las Islas San F&#xE9;lix, San Ambrosio y Archipi&#xE9;lago de Juan Fern&#xE1;ndez, sobre los recursos hidrobiol&#xF3;gicos Marrajo o tibur&#xF3;n, At&#xFA;n aleta amarilla, At&#xFA;n aleta larga, At&#xFA;n aleta azul, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 6425798}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de mayo de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6425799}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1131", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1131"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-05-30", "doble_articulado": false, "id_norma": "210900", "numero_fuente": "37576", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-05", "vigencias": [{"desde": "2003-06-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-06-05", "fi