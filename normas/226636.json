{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6484151}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.528, de 2 de junio de 2004 de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA AVENDA&#xD1;O CARDENAS LIMITADA, para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en sector rural Curanue s/n, Quell&#xF3;n, X Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n Cocido, Fresco-enfriado, Fresco-refrigerado, Congelado y Deshidratado, los recursos hidrobiol&#xF3;gicos individualizados en la resoluci&#xF3;n extractada. </div></div>", "i": 6484152}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de junio de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br><br><br></div>", "i": 6484153}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1528 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1528 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-06-02", "doble_articulado": false, "id_norma": "226636", "numero_fuente": "37891", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-22", "vigencias": [{"desde": "2004-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-06-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-06-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_