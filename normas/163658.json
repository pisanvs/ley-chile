{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6259056}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 648 de 12 de Noviembre de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n se autoriza a don Mario Antonio Retamal Letelier, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6259057}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gladys Tapia Huerta, Secretario Regional Ministerial (S), de Transportes y Telecomunicaciones Regi&#xF3;n del Maule.</div><br></div>", "i": 6259058}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "648 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-648 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-11-12", "doble_articulado": false, "id_norma": "163658", "numero_fuente": "32325", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-11-19", "vigencias": [{"desde": "1985-11-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-11-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-11-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci