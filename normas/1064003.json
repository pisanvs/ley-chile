{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA EMISOR DE BOLETAS ELECTR&#xD3;NICAS</div></div>", "i": 9485545}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 63 de 26 de junio de 2014, que autoriza a contribuyente como emisor de boleta electr&#xF3;nica.</div><br><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de boleta electr&#xF3;nica al contribuyente RUT 77.091.770-0, a contar del mes de junio de 2014. En la Oficina Virtual del SII en internet se podr&#xE1;n consultar los documentos que el contribuyente est&#xE1; autorizado a emitir en forma electr&#xF3;nica.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SIl del mes de junio de 2014.</div></div>", "i": 9485546}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "63 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-63 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISOR DE BOLETAS ELECTRÓNICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-06-26", "doble_articulado": false, "id_norma": "1064003", "numero_fuente": "40899", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-07-04", "vigencias": [{"desde": "2014-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vig