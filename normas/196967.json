{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6377680}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 489, de 28 de febrero de 2002, se rectific&#xF3; el decreto MOP N&#xBA; 1.820 de 31 de octubre de 2001, en el sentido que en la referencia y el numeral 3&#xBA;, debe decir: lotes N&#xBA; 59-AN, 59-AO y 59-AP y no como en ellos se se&#xF1;ala. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.</div><br></div>", "i": 6377681}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6377682}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "489", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-489"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-28", "doble_articulado": false, "id_norma": "196967", "numero_fuente": "37235", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-15", "vigencias": [{"desde": "2002-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-04-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "PSO", "fecha_ingreso": "2002-04-18", "fecha_version": "2002-04-15", "fecha_actualizacion_texto": "2002-04-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructur