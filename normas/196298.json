{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6375220}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;588 de 20 de marzo de 2002 de esta Subsecretar&#xED;a, modif&#xED;case el numeral 6&#xBA; de la resoluci&#xF3;n N&#xBA;37 de 2002, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO, para efectuar&nbsp; una pesca de investigaci&#xF3;n de conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del proyecto denominado &quot;Distribuci&#xF3;n espacio temporal de las capturas de jurel en la I y II Regi&#xF3;n (Primera Etapa, 2002)&quot;, en el sentido de reemplazar la nave &quot;Alerce&quot; por la nave &quot;Raul&#xED;&quot;, ambas de propiedad de Corpesca S.A., de la n&#xF3;mina de naves participantes en la se&#xF1;alada pesca de investigaci&#xF3;n. </div></div>", "i": 6375221}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de marzo de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6375222}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "588", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-588"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-20", "doble_articulado": false, "id_norma": "196298", "numero_fuente": "37224", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-02", "vigencias": [{"desde": "2002-04-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-04-02", "fin_vigencia": ""}, "vigencias_version_norm