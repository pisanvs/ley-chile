{"html": [{"t": "<div><div class=\"p\">DECLARA CADUCIDAD DE RESOLUCIONES QUE INDICA</div></div>", "i": 10080880}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 3.760, de 11 de diciembre de 2019, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad total de las resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=255429&amp;idParte=&amp;idVersion=\">N&#xB0; 3.057 de 2006</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1082236&amp;idParte=&amp;idVersion=\">N&#xB0; 2.467 de 2015</a>, que autorizaron a Pesquera Centro Sur SpA, para realizar actividades pesqueras extractivas con la nave &quot;Rafael&quot;, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum citado en Visto de la resoluci&#xF3;n extractada.</div><div class=\"p\"> </div><br><br></div>", "i": 10080881, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de diciembre de 2019.- Rom&#xE1;n Zelaya R&#xED;os, Subsecretario de Pesca y Acuicultura.</div><br></div>", "i": 10080882}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3760 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3760 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DECLARA CADUCIDAD DE RESOLUCIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1699123", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-12-11", "doble_articulado": false, "id_norma": "1140227", "numero_fuente": "42532", "tipo_version": "3", "tipo