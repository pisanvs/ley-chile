{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8307140}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.293, de 2 de octubre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por un a&#xF1;o, contado desde de febrero de 1997, el plazo para reiniciar operaciones con la nave &quot;Don Enrique&quot;, autorizada por Resoluci&#xF3;n N&#xBA; 1.505 de 1989, de esta Subsecretar&#xED;a, a PESQUERA POLARIS S.A., en virtud de haberse acreditado una circunstancia de fuerza mayor. </div></div>", "i": 8307141}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de octubre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8307142}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1293", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1293"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA POLARIS S.A.", "PLAZO", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-10-02", "doble_articulado": false, "id_norma": "76634", "numero_fuente": "35905", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-10-31", "vigencias": [{"desde": "1997-10-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-10-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-10-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url