{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SUPLEMENTO Lei n&#xFA;m. 220.-Santiago, a 17 de Diciembre de 1894.-Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947192}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de doscientos cincuentas mil pesos ($ 250,000) al &#xED;tem 3 de la partida 29 del presupuesto del Ministerio de Marina.</div><br><br></div>", "i": 5947193}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORJE MONTT.-C&#xE1;rlos Rivera Jofr&#xE9;.</div><br></div>", "i": 5947194}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "220", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-220"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1894", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-12-17", "doble_articulado": false, "id_norma": "22076", "numero_fuente": "4992", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-12-18", "vigencias": [{"desde": "1894-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-12-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-12-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-01-25", "fecha_version": "1894