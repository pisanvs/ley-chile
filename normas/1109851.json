{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 9C</div></div>", "i": 9843987}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 3.387, de 20 de octubre de 2017, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1108731&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xB0; 3.135, de 2017</a>, de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 9C, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para los centros de cultivo que se indica en la resoluci&#xF3;n extractada.</div></div>", "i": 9843988}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de octubre de 2017.- Paolo Trejo Carmona, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9843989}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3387 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3387 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 9C", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1294046", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-10-20", "doble_articulado": false, "id_norma": "1109851", "numero_fuente": "41894", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-10-28", "vigencias": [{"desde": "2017-10-28", "hasta": "", "tipo_version": "3", "tipo_v