{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6279039}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;959, de 30 de marzo de 2000, se modific&#xF3; el decreto MOP N&#xBA;2.043, de 30 de julio de 1999, dejando sin efecto la expropiaci&#xF3;n de lote N&#xBA;14-A, rol de aval&#xFA;o N&#xBA;764-109, comuna de Lampa, que figura a nombre de Alejandro Jacobo Chehade Pinto y otros, Obra: Camino Quilicura-Lampa y se aprob&#xF3; Convenio Directo de Precio por el lote N&#xBA;14-B de Inversiones Trigal S.A. y otro.- </div></div>", "i": 6279040}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6279041}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "959", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-959"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-03-30", "doble_articulado": false, "id_norma": "169770", "numero_fuente": "36678", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-01", "vigencias": [{"desde": "2000-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "IMH", "fecha_ingreso": "2000-06-01", "fecha_version": "2000-06-01", "fecha_actualizacion_texto": "2000-06-01", "tipo_tratado": ""}, "alertas":