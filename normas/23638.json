{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza la ereccion en Santiago de un monumento al Jeneral don Juan Mackenna</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,974.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275807}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Autor&#xED;zase la ereccion en la ciudad de Santiago de un monumento, costeado por suscripcion popular, i destinado a honrar la memoria del jeneral don Juan Mackenna.</div><br></div>", "i": 8275808}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 15 de Enero de 1915.- RAMON BARROS LUCO.- Pedro N. Montenegro.</div><br></div>", "i": 8275809}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2974", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2974"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA LA ERECCION EN SANTIAGO DE UN MONUMENTO AL JENERAL DON JUAN MACKENNA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUAN MACKENNA", "MONUMENTO", "ERECCION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1915-01-15", "doble_articulado": false, "id_norma": "23638", "numero_fuente": "11076", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1915-01-23", "vigencias": [{"desde": "1915-01-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1915