{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA NOMBRE A LA CALLE &quot;TALCA&quot; DE PUNTA ARENAS Por cuanto el Congreso Nacional ha tenido a bien prestar su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8278788}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Como un honor p&#xFA;blico, la calle &quot;Talca&quot; de la ciudad de Punta Arenas se denominar&#xE1; en adelante &quot;Armando Sanhueza L&#xED;bano&quot;.</div><div class=\"p\">&nbsp; &nbsp; Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 8278789}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintinueve de Septiembre de mil novecientos cuarenta y nueve.- GABRIEL GONZALEZ VIDELA.-</div><div class=\"p\">I. Holger T.</div><br></div>", "i": 8278790}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "9419", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-9419"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA NOMBRE A LA CALLE TALCA DE PUNTA ARENAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "CALLE TALCA", "PUNTA ARENAS", "ARMANDO SANHUEZA LIBANO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1949-09-29", "doble_articulado": false, "id_norma": "26085", "numero_fuente": "21475", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1949-10-11", "vigencias": [{"desde": "1949-10-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni