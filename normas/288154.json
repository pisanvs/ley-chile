{"html": [{"t": "<div><div class=\"p\">@@</div></div>", "i": 8624292}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 777, de 27 de febrero de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a NALDY ELIZABETH C&#xC1;RDENAS MANSILLA para iniciar actividades pesqueras de transformaci&#xF3;n, para iniciar y operar planta ubicada en calle Presidente Alessandri N&#xBA; 874, Queil&#xE9;n, Chilo&#xE9;, X Regi&#xF3;n, para elaborar en las l&#xED;neas de proceso de Cocido, Fresco enfriado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2.956, de 2009, de esta Subsecretar&#xED;a.</div><br></div>", "i": 8624293}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de febrero de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca. </div></div>", "i": 8624294}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "777 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-777 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-02-27", "doble_articulado": false, "id_norma": "288154", "numero_fuente": "39314", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-03-17", "vigencias": [{"desde": "2009-03-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-03-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-03-17", "f