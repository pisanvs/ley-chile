{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6445540}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.443, de 10 de octubre de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a ANDRES NOLBERTO BRICE&#xD1;O OLIVARES, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en R&#xED;o de Janeiro N&#xBA;72, Sector Maitencillo, Freirina, III Regi&#xF3;n, donde podr&#xE1; elaborar, en la l&#xED;nea de proceso de Seco-Picado, los recursos hidrobiol&#xF3;gicos Huiro negro, Huiro palo y Huiro o canutillo.</div><br></div>", "i": 6445541}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de octubre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6445542}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2443 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2443 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-10", "doble_articulado": false, "id_norma": "216368", "numero_fuente": "37696", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-10-28", "vigencias": [{"desde": "2003-10-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-10-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-10-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2003-10-28", "fec