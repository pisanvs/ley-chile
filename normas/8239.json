{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5888200}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decretos MOP. N&#xB0;s 47, 49 y 57, de 23 y 25 de febrero de 1993, se expropiaron los lotes de terreno N&#xB0;s. 48-A, 29-A y 48-D, superficies 211m2., 657m2. y 58m2., respectivamente, roles de aval&#xFA;o 547-26, 548-13 y 547-26, Comuna de Santa Cruz, para la obra Mejoramiento Camino Santa Cruz-Lolol-Bucalemu, II Etapa, sectores Santa Cruz-Cuesta La Lajuela y Santa Cruz-Los Maitenes, y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Juan Manuel Becerra Miranda, Orfelina Lira Fredes e Ilka Leonor del C. Z&#xFA;&#xF1;iga Acevedo, ascendente a las cantidades de $321.297.-, $6.887.375.- y $235.229.- </div></div>", "i": 5888201}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 5888202}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "49", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-49"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DECRETO EXPROPIATORIO", "EXPROPIACION", "BIEN INMUEBLE", "BIEN RAIZ", "SANTA CRUZ"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-02-23", "doble_articulado": false, "id_norma": "8239", "numero_fuente": "34531-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-04-01", "vigencias": [{"desde": "1993-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos