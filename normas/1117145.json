{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Devolucion de bienes secuestrados</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Marzo 7 de 1822.</div></div>", "i": 9926508}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Como parece al ministerio fiscal, se declara que todos los propietarios a quienes se haya devuelto bienes secuestrados, deben pagar los costos i gastos que se hayan impedido para secuestrarlos i conservarlos, i en su consecuencia deben abonar a los comisionados de secuestros el cuatro por ciento que se les asign&#xF3;.</div></div>", "i": 9926509}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, trascr&#xED;base a los intendentes e impr&#xED;mase.-O&apos;Higgins.-Rodr&#xED;guez.</div></div>", "i": 9926510}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Devolucion de bienes secuestrados", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1822-03-07", "doble_articulado": false, "id_norma": "1117145", "numero_fuente": "1822", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1822-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1822-03-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1822-03-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1096974", "fecha_ingreso": "2018-06-27", "fecha_version": "1822-03-07", "fecha_actualizacion_texto": "2018-06-27", "tipo_tratado": ""}, "alertas