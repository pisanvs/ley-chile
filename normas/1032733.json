{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9204087}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. (EXENTO) N&#xBA;3305 de 25 de octubre de 2011, se dej&#xF3; sin efecto el <a href=\"https://www.leychile.cl/Navegar?idNorma=1026024&amp;idParte=0&amp;idVersion=\">Decreto MOP (Exento) N&#xBA;667 de 10 de mayo de 2011</a>, que se refiere al N&#xBA;60-A, debido a que la superficie del lote N&#xBA;60-A se&#xF1;alada en dicho Decreto no corresponde a la que es necesaria afectar para la obra p&#xFA;blica: Mejoramiento Ruta I-70-J, Sector Lolol &#x2013; Ranguil, Tramo km. 0,00000 a km. 19,38878. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xB0; del Decreto Ley N&#xBA;2186, de 1978.</div><br></div>", "i": 9204088, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9204089}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3305 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-3305 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-10-25", "doble_articulado": false, "id_norma": "1032733", "numero_fuente": "40110", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-11-15", "vigencias": [{"desde": "2011-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-11-15", "fin_vigencia": "", "tipo_versio