{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8310081}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 129, de 14 de Febrero de 1992, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, der&#xF3;gase la Resoluci&#xF3;n No. 325, de 1989, de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a do&#xF1;a SOFIA MAGDALENA RIOS CONTRERAS, R.U.T. No. 5.446.188-7, No. 425, Depto. 21, Vallenar, para instalar y operar un establecimiento de cultivo del recurso Camar&#xF3;n de r&#xED;o del norte, Cryphiops caementarius, en el sector Buena Esperanza, a orillas del R&#xED;o Huasco, Comuna de Vallenar, Provincia de Huasco, III Regi&#xF3;n, por renuncia de su titular. </div></div>", "i": 8310082}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 14 de Febrero de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8310083}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "129", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-129"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-02-14", "doble_articulado": false, "id_norma": "79615", "numero_fuente": "34202", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-02-25", "vigencias": [{"desde": "1992-02-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-02-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-02-25", "fin_vigencia": "", "tipo_version": "3"}], "e