{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8334128}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.221 de 24 agosto 1998, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA EL GOLFO S.A., para continuar desarrollando actividades pesqueras con la nave denominada &apos;&apos;Loa 25&apos;&apos;, que se individualiza, autorizada por resoluci&#xF3;n N&#xBA; 843 de 1997, de esta Subsecretar&#xED;a, en el litoral de la V, VI y VII Regiones, respecto del recurso hidrobiol&#xF3;gico Jurel.</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 843 de 1997, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Pesquera San Miguel S.A. para operar la nave denominada &apos;&apos;Loa 25&apos;&apos; en virtud de lo se&#xF1;alado en la escritura de transferencia.</div><br></div>", "i": 8334129}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de agosto de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8334130}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1221", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1221"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA EL GOLFO S.A.", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-08-24", "fecha_derogacion": "1999-12-11", "doble_articulado": false, "id_norma": "123906", "numero_fuente": "36158", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-09-05", "vigencias": [{"desde": "1999-12-11", "hasta": "", "ti