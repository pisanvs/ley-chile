{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION N&#xB0; 104 DE 17 DE JUNIO DE 1985 </div></div>", "i": 6237032}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado Planes y Programas Especiales de Estudio para Segundo Ciclo de la Educaci&#xF3;n Media T&#xE9;cnico - Profesional, a contar del a&#xF1;o escolar 1985 y hasta el a&#xF1;o escolar 1900, inclusive, para el Liceo Polit&#xE9;cnico Galvarino, de &#xD1;u&#xF1;oa.</div><br><div class=\"p\">&nbsp; &nbsp;  ESPECIALIDADES:</div><br><div class=\"p\">1.- Instalaciones El&#xE9;ctricas.</div><div class=\"p\">2.- Electr&#xF3;nica Industrial.</div><div class=\"p\">3.- Secretariado Administrativo.</div><div class=\"p\">4.- Programaci&#xF3;n en Computaci&#xF3;n.</div><div class=\"p\">5.- Atenci&#xF3;n de P&#xE1;rvulos con Menci&#xF3;n en Educaci&#xF3;n Diferencial.</div><br></div>", "i": 6237033}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  28 de Junio de 1985.- Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica Subrogante.</div><br></div>", "i": 6237034}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "104 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-104 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION N° 104\nDE 17 DE JUNIO DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-17", "doble_articulado": false, "id_norma": "156896", "numero_fuente": "32364", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-01-06", "vigencias": [{"desde