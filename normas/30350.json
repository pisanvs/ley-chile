{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA ARTICULO 2&#xB0; TRANSITORIO DE LA LEY N&#xB0; 18.893 Teniendo presente que el H. Congreso Nacional dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley </div></div>", "i": 8286867}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Sustit&#xFA;yese, en el art&#xED;culo 2&#xB0; transitorio de la Ley N&#xB0; 18.893, la expresi&#xF3;n &quot;seis meses&quot;&quot; por la frase &quot;veinticuatro meses&quot;.&quot;.</div><br><br></div>", "i": 8286868, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 18 de Mayo de 1990.- PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Enrique Krauss Rusque, Ministro del Interior.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud., para su conocimiento.- Saluda a Ud.- Belisario Velasco Baraona, Subsecretario del Interior.</div><br></div>", "i": 8286869}], "proyectos": [{"categoria": "Proyecto original", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=40-06", "informacion": "Amplía a 24 meses el plazo establecido por la ley sobre Organizaciones Comunitarias", "nroBoletin": "40-06"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "18982", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-18982"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA ARTICULO 2° TRANSITORIO DE LA LEY N° 18.893", "fuente": "Diario Oficial", "resumenes": [], "materias": ["Actividad Empresarial del Estado", "Zona Franca de Iquique", "Ley no. 18.893, Art. 2° Transitorio", "Ley no.18.846, Art. 10", "Ley no. 18.982"], "terminos_libres": ["ORGANI