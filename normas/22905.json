{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PENSION DE DO&#xD1;A EMILIA HERRERA Lei n&#xFA;m. 1774.-Santiago, a 24 de Noviembre de 1905.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5951155}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.-Conc&#xE9;dese, por gracia, a do&#xF1;a Emilia Herrera, nieta del sarjento mayor graduado de la independencia, don Jos&#xE9; Mar&#xED;a Manterola, una pension equivalente al montep&#xED;o de capitan.</div><br></div>", "i": 5951156}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JERMAN RIESCO.- Manuel F&#xF3;ster R.</div><br></div>", "i": 5951157}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1774", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1774"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION DE DOÑA EMILIA HERRERA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EMILIA HERRERA", "MONTEPIO MILITAR", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-11-24", "doble_articulado": false, "id_norma": "22905", "numero_fuente": "8365", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-11-25", "vigencias": [{"desde": "1905-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1905-11-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1905-11-25", "fin_vigencia": "", "tipo_version": "3"}], "event