{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO No.249 EXENTO, DE 1990 </div></div>", "i": 7216546}, {"t": "<div><div class=\"p\">Por decreto exento No.249 de fecha 1 de octubre de 1990 del Ministro de Educaci&#xF3;n, se aprobaron los siguientes planes y programas de estudios al Centro de Formaci&#xF3;n T&#xE9;cnica Alexander von Humboldt de San Antonio, de las carreras y t&#xED;tulos t&#xE9;cnicos que se indican, para impartirse a contar del a&#xF1;o 1990:</div><br><div class=\"p\">Carrera: Tecnolog&#xED;a en Pesca</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico en Faenas Pesqueras Carrera: Tecnolog&#xED;a Industrial de Alimentos</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico Industrial de Alimentos Carrera: T&#xE9;cnico en Construcci&#xF3;n</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico en Construcci&#xF3;n.</div><br></div>", "i": 7216547}, {"t": "<div><div class=\"p\">Santiago, 12 de Noviembre de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7216548}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "249 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-249 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO Nº.249 EXENTO, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-10-01", "doble_articulado": false, "id_norma": "81547", "numero_fuente": "33829", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-11-27", "vigencias": [{"desde": "1990-11-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1