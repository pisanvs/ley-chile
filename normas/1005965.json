{"html": [{"t": "<div><br><div class=\"p\">REORGANIZA UNIDADES QUE CONFORMAN EL DEPARTAMENTO SUBDIRECCI&#xD3;N JUR&#xCD;DICA</div><br></div>", "i": 8779504}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 130, de fecha 3 de septiembre de 2009, que establece:</div><br><div class=\"p\">&nbsp; &nbsp;  Modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=31408&amp;idParte=&amp;idVersion=2009-09-08\">resoluci&#xF3;n N&#xBA; 379, de 4 de diciembre de 1991</a>, sustituyendo el N&#xBA; 6 de la letra A de la dicha resoluci&#xF3;n.</div><br><div class=\"p\">&nbsp; &nbsp;  Modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=285995&amp;idParte=&amp;idVersion=2009-09-08\">resoluci&#xF3;n N&#xBA; 10 de 2009</a> en sus dispositivos cuarto, quinto y sexto y elimina dispositivo s&#xE9;ptimo.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl), y adem&#xE1;s aparecer&#xE1; en el Bolet&#xED;n del SII del mes de septiembre de 2009.</div><br><br></div>", "i": 8779505, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8779506}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "130 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-130 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "REORGANIZA UNIDADES QUE CONFORMAN EL DEPARTAMENTO SUBDIRECCIÓN JURÍDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-09-03", "doble_