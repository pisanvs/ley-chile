{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 659, DE 2015, QUE DECLARA &#xC1;REA DE PLAGA QUE INDICA</div></div>", "i": 9588090}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 918, de 6 de abril de 2015,&nbsp; de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1075544&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 659, de 2015</a>, de esta Subsecretar&#xED;a, que declar&#xF3; &#xE1;reas de plaga y de riesgo de plaga de la especie Didymosphenia geminata, en los sectores de cuerpos de aguas, ampli&#xE1;ndolos a nuevas cuencas en las X, XI y XII Regiones, en la forma que se indica en la resoluci&#xF3;n extractada, y publicada &#xED;ntegramente en la p&#xE1;gina web www.subpesca.cl.</div></div>", "i": 9588091}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9588092}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "918 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-918 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 659, DE 2015, QUE DECLARA ÁREA DE PLAGA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-04-06", "doble_articulado": false, "id_norma": "1076118", "numero_fuente": "41129", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-04-11", "vigencias": [{"desde": "2015-04-11", "