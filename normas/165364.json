{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6264453}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 87, de 09 de Octubre de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Atacama, se autoriza a don Nilzon Vitali Colman y otros, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6264454}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Sergio Antonio Acevedo Oyarce, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n de Atacama.</div><br></div>", "i": 6264455}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "87 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-87 EXENTA"}], "organismos": ["MINISTERIO DE TRANPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-10-09", "doble_articulado": false, "id_norma": "165364", "numero_fuente": "32310", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-10-31", "vigencias": [{"desde": "1985-10-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-10-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-10-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi