{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Cambia el nombre de la calle que indica de la ciudad de Angol.</div><div class=\"p\">&nbsp; &nbsp; (Publicada en el &quot;Diario Oficial&quot; N# 23.876, de 22 de octubre de 1957).</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8280310}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Denom&#xED;nase &quot;Julio Sep&#xFA;lveda Onfray&quot; a la calle &quot;Moquehua&quot;, de la ciudad de Angol. </div></div>", "i": 8280311}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, ocho de octubre de mil novecientos cincuenta y siete.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Horacio Arce.</div><br></div>", "i": 8280312}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "12606", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-12606"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA EL NOMBRE DE LA CALLE QUE INDICA DE LA CIUDAD DE ANGOL.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "CALLE JULIO SEPULVEDA ONFRAY", "ANGOL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1957-10-08", "doble_articulado": false, "id_norma": "27188", "numero_fuente": "23876", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1957-10-22", "vigencias": [{"desde": "1957-10-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1957-1