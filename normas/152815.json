{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6224336}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 703 de 25 de agosto de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n, se autoriza a Juana San Mart&#xED;n Beltr&#xE1;n para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6224337}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Enrique Brintrup Barrera, Secretario Regional Ministerial Transp. y Telec. X Regi&#xF3;n subrogante. </div></div>", "i": 6224338}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "703 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-703 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-25", "doble_articulado": false, "id_norma": "152815", "numero_fuente": "32862", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-03", "vigencias": [{"desde": "1987-09-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-09-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por