{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6058380}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. N&#xBA; 944, de 30 de septiembre, y 1.057, de 31 de octubre, ambos de 1997, se expropiaron los lotes de terreno N&#xBA;s. 1, 2, 6 y 3, superficies 37,80; 35; 209 y 39 m&#xB2;, respectivamente, roles de aval&#xFA;os 139-23, 139-865, 139-536 y 139-761, comuna de Graneros, obra Camino Cruce Longitudinal Graneros-Codegua Ruta H-17, sector Cruce Ruta 5-La Compa&#xF1;&#xED;a y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Jaime Cid Palma, Samuel C&#xF3;rdova Valenzuela, Benjam&#xED;n Maturana Espinoza y Suc. Luis Antonio Arredondo Past&#xE9;n y Otro, ascendente a las cantidades de $385.369, $431.390, $1.066.666 y $468.403.</div><br></div>", "i": 6058381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6058382}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "944", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-944"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "GRANEROS", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-09-30", "doble_articulado": false, "id_norma": "80892", "numero_fuente": "35930", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-12-01", "vigencias": [{"desde": "1997-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-12-01", "fin_vigenc