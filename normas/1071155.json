{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9535174}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.190, de 25 de noviembre de 2014, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1069048&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 2.828 de 2014</a>, de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 19 A, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar para el centro de cultivo que indica en la resoluci&#xF3;n extractada.</div></div>", "i": 9535175}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de noviembre de 2014.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9535176}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3190 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3190 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-11-25", "doble_articulado": false, "id_norma": "1071155", "numero_fuente": "41022", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-12-02", "vigencias": [{"desde": "2014-12-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-12-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014-12-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones"