{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8300603}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 43, de 16 de enero de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n; decl&#xE1;rase la caducidad de las Resoluciones N&#xBA; 968, de 1989, N&#xBA; 1428, de 1989 y N&#xBA; 1027, de 1991, todas de esta Subsecretar&#xED;a, que autorizaron a PESQUERA TORRES DEL PAINE S.A., para ampliar actividades pesqueras extractivas con las naves &quot;Mar&#xED;a Alejandra&quot; y &quot;Mar&#xED;a Bel&#xE9;n&quot;, por haberse configurado la causal prevista en el art&#xED;culo 143 letra b) de la Ley N&#xBA; 18.892 y sus modificaciones.</div><br></div>", "i": 8300604}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de enero de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8300605}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "43", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-43"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA TORRES DEL PAINE S.A.", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-01-16", "doble_articulado": false, "id_norma": "60361", "numero_fuente": "35674", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-01-24", "vigencias": [{"desde": "1997-01-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-01-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia":