{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9293035}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xBA;1446 de 31 de julio de 2012, de conformidad lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropiaron los lotes de terrenos N&#xB0;s. 24, 28 y 29, superficies 92, 846 y 717 m2, rol de Aval&#xFA;o N&#xBA;20-26, comuna de Coinco, para la obra &quot;REPOSICI&#xD3;N PUENTE COINCO, COMUNAS DE COINCO Y DO&#xD1;IHUE&quot;. La Comisi&#xF3;n de peritos, integrada por NORMAN CALDER&#xD3;N PONTIGGIA, OSCAR NAVEA MU&#xD1;OZ Y MAR&#xCD;A ISABEL DE JES&#xDA;S R&#xCD;OS MARCUELLO, fij&#xF3; el valor de tasaci&#xF3;n con fecha 1 de agosto de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario C&#xC9;SAR RAM&#xD3;N SILVA GALAZ, en la cantidad de $7.704.564.-, suma que se pagar&#xE1; al contado. </div></div>", "i": 9293036}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9293037}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1446 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1446 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-31", "doble_articulado": false, "id_norma": "1043400", "numero_fuente": "40352", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-09-01", "vigencias": [{"desde": "2012-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-09-01", "fin_vigencia": ""}, "vigencias_version_n