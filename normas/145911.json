{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8352197}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.111, de 14 de octubre de 1999,</div><div class=\"p\">de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de</div><div class=\"p\">la resoluci&#xF3;n N&#xBA; 913, de 1992, de esta Subsecretar&#xED;a, en</div><div class=\"p\">cuanto autoriz&#xF3; a la PESQUERA INDO S.A. hoy Empresa</div><div class=\"p\">Pesquera Eperva S.A., para realizar actividades</div><div class=\"p\">pesqueras extractivas con la nave &apos;&apos;Pucar&#xE1;&apos;&apos; respecto</div><div class=\"p\">del recurso Jurel, en el litoral de la III Regi&#xF3;n, de</div><div class=\"p\">conformidad con lo establecido en la letra b) del</div><div class=\"p\">art&#xED;culo 143 del D.S. N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8352198}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de octubre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8352199}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2111", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2111"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-14", "doble_articulado": false, "id_norma": "145911", "numero_fuente": "36495", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-10-22", "vigencias": [{"desde": "1999-10-22", "hasta": "", "tipo_version": "3", "tipo_version_s