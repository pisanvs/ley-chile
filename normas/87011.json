{"html": [{"t": "<div><div class=\"p\">&quot;PARTIDO POR LA DEMOCRACIA&quot; </div></div>", "i": 7221725}, {"t": "<div><div class=\"p\">Sergio Bitar, en representaci&#xF3;n del Partido Por la</div><div class=\"p\">Democracia, ha solicitado la constituci&#xF3;n legal del Partido</div><div class=\"p\">en la IX Regi&#xF3;n de la Araucan&#xED;a acompa&#xF1;ando la cantidad de</div><div class=\"p\">2.097 afiliaciones, en conformidad a lo establecido en el</div><div class=\"p\">art&#xED;culo 17&#xBA; de la Ley N&#xBA;18.603 y Resoluci&#xF3;n Exenta N&#xBA;08 de 09 de Febrero de 1990, publicada en el Diario Oficial el 19 de Febrero del mismo a&#xF1;o. Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xBA; de la Ley N&#xBA;18.603. Por Resoluci&#xF3;n Exenta N&#xBA;O-1652 de fecha 9 de Octubre de 1991.</div><br></div>", "i": 7221726}, {"t": "<div><div class=\"p\">Santiago, 9 de Octubre de 1991.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director Servicio Electoral.</div><br></div>", "i": 7221727}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1652 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1652 EXENTA"}, {"tipo": "3", "numero": "O-1652 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-1652 EXENTA"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO POR LA DEMOCRACIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-10-09", "doble_articulado": false, "id_norma": "87011", "numero_fuente": "34097", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-10-22", "vigencias": [{"desde": "1991-10-22", "hasta": "", "tipo