{"html": [{"t": "<div><div class=\"p\">FIJA NUEVO HORARIO DE ATENCION EN JUNTAS INSCRIPTORAS </div><br></div>", "i": 6271527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n O-N&#xBA; 0168 de fecha 28 de abril de 2000, se ha dispuesto que las Juntas Inscriptoras de todo el pa&#xED;s funcionen a contar del d&#xED;a jueves 1 y hasta el mi&#xE9;rcoles 28 de junio de 2000, cierre del per&#xED;odo extraordinario de inscripciones electorales, en horario de 9:00 a 14:00 horas.</div><div class=\"p\">&nbsp; &nbsp;  Sin embargo, si al t&#xE9;rmino del horario de funcionamiento se encontraren a&#xFA;n presentes personas que requieran su inscripci&#xF3;n, se extender&#xE1; al funcionamiento pero no m&#xE1;s all&#xE1; de las 20:00 horas, salvo el d&#xED;a s&#xE1;bado en que no exceder&#xE1; de las 14:00 horas.</div><br></div>", "i": 6271528}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de abril de 2000.- Andr&#xE9;s Merino Espi&#xF1;eira, Director (S).</div><br></div>", "i": 6271529}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "168", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-168"}, {"tipo": "3", "numero": "O-0168", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-0168"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "FIJA NUEVO HORARIO DE ATENCION EN JUNTAS INSCRIPTORAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-28", "doble_articulado": false, "id_norma": "167511", "numero_fuente": "36653", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-03", "vigencias": [{"desde": "2000-05-03", "hasta": "", "tipo_version": "