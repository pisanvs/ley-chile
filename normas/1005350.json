{"html": [{"t": "<div><br><div class=\"p\">MODIFICA CONCESI&#xD3;N DE ACUICULTURA</div><br></div>", "i": 8773082}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n 1.218, de 8 de junio de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div><br><div class=\"p\">&nbsp; &nbsp;  I.- Modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=232695&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n 1.441, de 21 de julio de 2004, del Ministerio de Defensa Nacional</a>, Subsecretar&#xED;a de Marina, en el sentido de reemplazar el p&#xE1;rrafo 4.- por el siguiente:</div><div class=\"p\">&nbsp; &nbsp;  &quot;4.- El concesionario deber&#xE1; dar cabal cumplimiento al Proyecto T&#xE9;cnico y Cronograma de Actividades, aprobado por resoluci&#xF3;n exenta 476, de 20 de febrero de 2004 y modificada por la resoluci&#xF3;n exenta 2.069, de 18 de julio de 2007, ambas del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, Subsecretar&#xED;a de Pesca.&quot;.</div><br></div>", "i": 8773083}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 6 de agosto de 2009.- Por la Sra. Subsecretaria, Humberto Ram&#xED;rez Navarro, Subjefe Subsecretar&#xED;a de Marina.</div><br></div>", "i": 8773084}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1218", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-1218"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "MODIFICA CONCESIÓN DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-06-08", "doble_articulado": false, "id_norma": "1005350", "num