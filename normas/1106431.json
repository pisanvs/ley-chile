{"html": [{"t": "<div><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9825290}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 964, de fecha 24 de julio de 2017, del Serviu Regi&#xF3;n de Coquimbo, se orden&#xF3; expropiar totalmente por causa de utilidad p&#xFA;blica, conforme al art&#xED;culo 51 ley 16.391 y DL 2.186/78, el inmueble denominado Lote 8, en plano de expropiaci&#xF3;n, ubicado en calle Condell N&#xBA; 299 o calle Chacabuco esquina Condell, de la comuna de Coquimbo, Rol de Aval&#xFA;o N&#xBA; 703-08, propietario aparente Luis Armando Aguirre Ramos, superficie aprox. de terreno 199,60 m2. Comisi&#xF3;n de Peritos conformada por profesionales Marcia Aqueveque, Miguel Rubio y Alfredo Prieto, seg&#xFA;n informe de 8 de noviembre de 2016 fij&#xF3; indemnizaci&#xF3;n provisional en 2.294,50 Unidades de Fomento pagadera al contado.-</div></div>", "i": 9825291}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director (S) Serviu Regi&#xF3;n Coquimbo.</div></div>", "i": 9825292}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "964", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-964"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "IV REGIÓN DE COQUIMBO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1248081; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-07-24", "doble_articulado": false, "id_norma": "1106431", "numero_fuente": "41835", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-08-16", "vigencias": [{"desde": "2017-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"