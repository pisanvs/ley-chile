{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6340275}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 894, de 14 de mayo de 2001, de esta Subsecretar&#xED;a, autor&#xED;zase a do&#xF1;a MARIA ANA MOROZIN BAYCIC, para ampliar actividades pesqueras extractivas con la nave &quot;Samoa&quot; en el &#xE1;rea mar&#xED;tima que se indica, por fuera del &#xE1;rea de reserva artesanal, sobre los siguientes recursos hidrobiol&#xF3;gicos: a) Area mar&#xED;tima de la I a la XI Regiones, con trampas, sobre Centolla y Centoll&#xF3;n. b) En el &#xE1;rea mar&#xED;tima de la I Regi&#xF3;n y desde el paralelo 24&#xBA; L.S. hasta el l&#xED;mite sur de la VIII Regi&#xF3;n, con red de arrastre, sobre Langosta enana. c) En el &#xE1;rea mar&#xED;tima de la I Regi&#xF3;n y desde el paralelo 24&#xBA; L.S. hasta el l&#xED;mite sur de la III Regi&#xF3;n, con red de arrastre, sobre Merluza com&#xFA;n. </div></div>", "i": 6340276}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de mayo de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6340277}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "894", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-894"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-05-14", "fecha_derogacion": "2014-03-14", "doble_articulado": false, "id_norma": "186957", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2001-06-27", "vigencias": [{"desde": "2014-03-14", "hasta": "", "tipo_version"