{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9341009}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. Exento N&#xBA;322, de 28 de febrero de 2013, y de conformidad a lo dispuesto en el Art. 105 del DFL. MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;181 superficie 686 m2., Rol de aval&#xFA;o 3912-2, Comuna de Quilpu&#xE9; para la obra, &quot;MEJORAMIENTO RUTA F-50, SECTOR LO OROZCO - QUILPU&#xC9;, TRAMO 3: KM. 17,57835 A KM. 29,49799&quot;, PROVINCIA Y REGI&#xD3;N DE VALPARA&#xCD;SO. La Comisi&#xF3;n de Peritos integrada por Patricio Casagrande Ulloa, Claudio Bresky Layera y Andr&#xE9;s Echeverr&#xED;a Campo, fij&#xF3; el valor de la tasaci&#xF3;n con fecha 9 de septiembre de 2009, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario GONZALO ANDR&#xC9;S MILLAN LABBE, en la cantidad de $3.451.455.- suma que se pagar&#xE1; al contado. </div></div>", "i": 9341010}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9341011}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "322 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-322 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-02-28", "doble_articulado": false, "id_norma": "1049787", "numero_fuente": "40522", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-04-01", "vigencias": [{"desde": "2013-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-04-01", "fin_vig