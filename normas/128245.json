{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6142948}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.102, de 30 de octubre de 1998, se modific&#xF3; el decreto MOP N&#xBA;414, de 31 de julio de 1995, que autoriz&#xF3; la expropiaci&#xF3;n de los lotes N&#xBA;s.11 y 14, para la ejecuci&#xF3;n de la obra Camino Ruta 5, Longitudinal Sur, sector San Javier-Parral I, Tramo A, aprob&#xE1;ndose nuevos Convenios Directos de Precio con los propietarios afectados se&#xF1;ores Juan Segundo Rojas Rojas y Marcos o Marco Aurelio Rojas Ruiz, fij&#xE1;ndose las indemnizaciones definitivas en las cantidades de $12.241.685 y $49.133.948, para los lotes 11 y 14.- </div></div>", "i": 6142949}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6142950}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2102", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2102"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-10-30", "doble_articulado": false, "id_norma": "128245", "numero_fuente": "36239", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-12-15", "vigencias": [{"desde": "1998-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-12-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1998-12-16", "fecha_ve