{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 10 EXENTO, DE 1999</div><br><br></div>", "i": 6158687}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA;10 de 18 de enero de 1999, se ha aprobado al Colegio &apos;&apos;Saint John&apos;s School&apos;&apos; de Concepci&#xF3;n, un plan de estudio para los cursos de 5&#xBA; a 8&#xBA; a&#xF1;o (NB.3 a NB.6) de Ense&#xF1;anza B&#xE1;sica, que se aplicar&#xE1; a partir del a&#xF1;o escolar 1999, de acuerdo con lo se&#xF1;alado en el decreto supremo de Educaci&#xF3;n N&#xBA;40 de 1996 y sus modificaciones. Adem&#xE1;s se aprueban programas de estudio para los subsectores (asignaturas) que se indican en el presente decreto.</div><br></div>", "i": 6158688}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de enero de 1999.- Juan Eduardo Garc&#xED;a-Huidobro S., Subsecretario de Educaci&#xF3;n (S). </div></div>", "i": 6158689}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "10 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-10 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 10 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-01-18", "doble_articulado": false, "id_norma": "133305", "numero_fuente": "36309", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-03-09", "vigencias": [{"desde": "1999-03-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-03-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-03-09", "fin_vigencia