{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7314433}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.503 , de 3 de septiembre de 2004, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 194 de 1990, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA SAN JOSE S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Alejandr&#xED;a I&quot;, en el &#xE1;rea mar&#xED;tima correspondiente a las Regiones I y II, sobre los recursos&nbsp; hidrobiol&#xF3;gicos&nbsp; Jurel, Cojinoba del norte, Cojinoba del sur y Merluza de cola, con cerco, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7314434}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de septiembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7314435}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2503 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2503 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-09-03", "doble_articulado": false, "id_norma": "230112", "numero_fuente": "37958", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-09-09", "vigencias": [{"desde": "2004-09-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-09-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v