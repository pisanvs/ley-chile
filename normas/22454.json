{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Escuela P&#xFA;blica de Quirihue Lei n&#xFA;m. 1,186.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948521}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de diezisiete mil cuatrocientos ochenta i tres pesos noventa i siete centavos en la terminacion de una escuela p&#xFA;blica en Quirihue.</div><br><br></div>", "i": 5948522}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 26 de Enero de 1899.- FEDERICO ERRAZURIZ.- C&#xE1;rlos A. Palacios Z.</div><br></div>", "i": 5948523}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1186", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1186"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "ESCUELA PUBLICA DE QUIRIHUE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ESCUELA PUBLICA DE QUIRIHUE", "PRESIDENTE REPUBLICA", "INVERSION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-01-26", "doble_articulado": false, "id_norma": "22454", "numero_fuente": "6212", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-01-27", "vigencias": [{"desde": "1899-01-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-01-27", "fin_vigencia": ""}, "vigencias_version_norma": [{