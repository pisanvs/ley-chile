{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6173065}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 961, de 29 de abril de 1999, se expropi&#xF3; el lote de terreno N&#xBA; 117, superficie 963 m&#xB2;, rol de aval&#xFA;o 160-133, comuna de Pemuco, para la obra &apos;&apos;Concesi&#xF3;n Internacional Ruta 5 Tramo:</div><div class=\"p\">Chill&#xE1;n-Collipulli&apos;&apos;, Octava Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario V&#xED;ctor Suazo Baquedano, ascendente a la cantidad de $1.814.695.- </div></div>", "i": 6173066}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6173067}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "961", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-961"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-04-29", "doble_articulado": false, "id_norma": "137743", "numero_fuente": "36388", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-06-15", "vigencias": [{"desde": "1999-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-06-15", "fecha_version": "1999-06-15", "fecha_actualizacion_texto": "1999-06-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "e