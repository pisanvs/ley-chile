{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10108667}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA; 9, de 06 de febrero de 2020, se desisti&#xF3; de la expropiaci&#xF3;n del lote N&#xBA;9, expropiado mediante <a href=\"https://www.leychile.cl/Navegar?idNorma=1047280&amp;idParte=&amp;idVersion=\">Decreto MOP. (Exento) N&#xBA; 3169</a>, de 04 de diciembre de 2012, para la obra: &quot;Mejoramiento Canal de Prolongaci&#xF3;n D&apos;Agostini Punta Arenas, Comuna de Punta Arenas, Regi&#xF3;n de Magallanes y de la Ant&#xE1;rtica Chilena&quot;, por cuanto, dicho lote fue eliminado por Resoluci&#xF3;n Expropiaciones Fiscal&#xED;a (Exenta) N&#xBA;7, de 21 de enero de 2020, por no ser necesaria la expropiaci&#xF3;n.</div><br><br></div>", "i": 10108668, "v": ["MODIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "9 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-9 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1738359", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-02-06", "doble_articulado": false, "id_norma": "1143455", "numero_fuente": "42605", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-03-16", "vigencias": [{"desde": "2020-03-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2020-03-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2020-03-16", "fin_vigencia": "", "tipo_version": "3"}], "