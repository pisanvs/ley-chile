{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9518494}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.401, de 12 de septiembre de 2014, de esta Subsecretar&#xED;a, ampl&#xED;ese por doce meses, a contar del 10 de agosto de 2014, el plazo otorgado en el numeral 7&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=249029&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 937, de 2006</a>, a Pesquera El Golfo S.A., hoy BLUMAR S.A., para continuar desarrollando las actividades pesqueras extractivas con la nave en construcci&#xF3;n &quot;BEC937-2006&quot;, con excepci&#xF3;n de aquellas especies cuya caducidad haya sido declarada mediante resoluci&#xF3;n, en virtud de haberse acreditado una circunstancia de fuerza mayor.</div></div>", "i": 9518495}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de septiembre de 2014.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9518496}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2401 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2401 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-09-12", "doble_articulado": false, "id_norma": "1068349", "numero_fuente": "40984", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-10-16", "vigencias": [{"desde": "2014-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-10-