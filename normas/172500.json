{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 92, DE 1987 </div></div>", "i": 6287725}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 92, de 7 de mayo de 1987, se han aprobado programas especiales de estudio, seg&#xFA;n lo dispuesto en el art&#xED;culo 5&#xB0; del decreto supremo exento de Educaci&#xF3;n No. 232, de 1982, para las asignaturas que se indican, de los planes electivos de 3&#xB0; y 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico Cient&#xED;fica, del Colegio La Maisonnette, de Santiago.</div><br></div>", "i": 6287726}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de Mayo de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6287727}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "92 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-92 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 92, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-05-07", "doble_articulado": false, "id_norma": "172500", "numero_fuente": "32811", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-04", "vigencias": [{"desde": "1987-07-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-07-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2000-07-18", "fecha_ver