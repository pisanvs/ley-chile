{"html": [{"t": "<div><div class=\"p\">ACTUALIZA, SISTEMATIZA Y REFUNDE NOMINA DE &quot;GRANDES CONTRIBUYENTES&quot; </div></div>", "i": 6605297}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA;39 de 22 de marzo de 2007 </div><div class=\"p\">&nbsp; &nbsp;  Actualiza, sistematiza y refunde N&#xF3;mina de &quot;Grandes Contribuyentes&quot; para los efectos se&#xF1;alados en dispositivo 3&#xBA; de Res. Ex. N&#xBA; 34, de 24.08.01, sobre la base de los Criterios de Selecci&#xF3;n que se indican.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de marzo de 2007.</div><br></div>", "i": 6605298}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "39 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-39 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ACTUALIZA, SISTEMATIZA Y REFUNDE NOMINA DE \"GRANDES CONTRIBUYENTES\"", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMINA DE GRANDES CONTRIBUYENTES", "CRITERIOS DE SELECCION", "ACTUALIZACION", "REFUNDE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-03-22", "doble_articulado": false, "id_norma": "259414", "numero_fuente": "38724", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-03-27", "vigencias": [{"desde": "2007-03-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"ini