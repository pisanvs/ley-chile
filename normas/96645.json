{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8327724}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N &#xB0; 78 de 22 de Enero de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por 30 d&#xED;as a contar de la fecha de la presente resoluci&#xF3;n, el plazo otorgado a don ISAI HENRIQUEZ CONCHA, R.U.T.</div><div class=\"p\">No. 3.855.789-0, domiciliado en Uribe No. 337, Poblaci&#xF3;n Valencia, Valpara&#xED;so, en el numeral 4&#xB0; de la resoluci&#xF3;n No. 345, de 1990, de esta Subsecretar&#xED;a, por haberse acreditado la ocurrencia de fuerza mayor.</div><br><br></div>", "i": 8327725}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de Enero de 1991.- Andr&#xE9;s Couve Rioseco Subsecretario de Pesca.</div><br><br></div>", "i": 8327726}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "78", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-78"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-22", "doble_articulado": false, "id_norma": "96645", "numero_fuente": "33891", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-02-11", "vigencias": [{"desde": "1991-02-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-02-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-02-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text":