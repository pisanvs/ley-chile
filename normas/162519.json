{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO ALCALDICIO N&#xBA;363, DE 2000 </div><br></div>", "i": 6255597}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto N&#xBA;363 de fecha 14 de Febrero del 2000, suscrito por el Alcalde de la Comuna de Tom&#xE9;, se ordena el Estudio de Expropiaci&#xF3;n de un bien ra&#xED;z ubicado en la localidad de Dichato, inscrito a fojas 89 N&#xBA;54 del Registro de Propiedad del Conservador de Bienes Ra&#xED;ces de Tom&#xE9;, a&#xF1;o 1981 y nombra a los integrantes de la Comisi&#xF3;n que determinar&#xE1; el monto provisional de la indemnizaci&#xF3;n, debiendo ce&#xF1;irse el procedimiento a los t&#xE9;rminos establecidos en el decreto ley N&#xBA;2.186 de 1978. </div></div>", "i": 6255598}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "363", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-363"}], "organismos": ["MUNICIPALIDAD DE TOMÉ"], "titulo_norma": "EXTRACTO DE DECRETO ALCALDICIO Nº363, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-14", "doble_articulado": false, "id_norma": "162519", "numero_fuente": "36621", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-23", "vigencias": [{"desde": "2000-03-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "2000-03-23", "fecha_version": "2000-03-23", "fecha_actualizacion_texto": "