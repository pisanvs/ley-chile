{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 1,102.- Santiago, 7 de octubre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6161538}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese por gracia a do&#xF1;a Celia i a do&#xF1;a Mar&#xED;a Luisa Azagra, el goce de la pension de montepio correspondiente al empleo de teniente-coronel, de la que disfrutar&#xE1;n conjuntamente i con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6161539}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancinarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Ventura Blanco.</div><br></div>", "i": 6161540}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1102", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1102"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-10-07", "doble_articulado": false, "id_norma": "134171", "numero_fuente": "6123", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-10-12", "vigencias": [{"desde": "1898-10-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-10-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-10-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ing