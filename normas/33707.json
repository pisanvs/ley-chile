{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291031}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 200, de 23 de Marzo de 1993 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xB0; 1351, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA PUERTO CISNES S.A., domiciliada en Santiago, para instalar y operar una planta de elaboraci&#xF3;n de recursos hidrobiol&#xF3;gicos, ubicada en Lotes 1, 2, 3, 4 y 5, Manzana 1-A y 1-B, Localidad de Puerto Cisnes, Comuna de Cisnes, XI Regi&#xF3;n, en virtud de lo prescrito en el art&#xED;culo 7&#xB0; del Decreto N&#xB0; 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8291032}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 23 de marzo de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8291033}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "200", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-200"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "PESCA", "PESQUERA PUERTO", "CISNES S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-03-23", "doble_articulado": false, "id_norma": "33707", "numero_fuente": "34529", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-03-30", "vigencias": [{"desde": "1993-03-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "