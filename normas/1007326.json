{"html": [{"t": "<div><br><div class=\"p\">CERTIFICADO</div></div>", "i": 8790940}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables de entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de octubre de 2009, fue de 0,33% anual.</div></div>", "i": 8790941}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de octubre de 2009.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div></div>", "i": 8790942}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "Certificado-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-10-19", "doble_articulado": false, "id_norma": "1007326", "numero_fuente": "39491", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-10-21", "vigencias": [{"desde": "2009-10-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-10-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-10-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2009-10-21", "fecha_version": "2009-10-21", "actualizado_por": "1289", "fecha_actualizacion_texto": "2009-10-21", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "E