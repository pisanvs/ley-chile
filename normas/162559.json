{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO No. 345, DE 1985 </div></div>", "i": 6255713}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 345 de 19 de Diciembre de 1985 se ha aprobado a contar del a&#xF1;o escolar 1986 y por cuatro a&#xF1;os, con car cter de experimental, plan y programas de estudios para ser aplicados por la Escuela Especial E No. 20 de Coyhaique. Adem s, se aprueban normas para el ingreso de alumnos y para su evaluaci&#xF3;n y promoci&#xF3;n.</div><br></div>", "i": 6255714}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de Abril de 1986.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6255715}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "345 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-345 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO No. 345, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-19", "doble_articulado": false, "id_norma": "162559", "numero_fuente": "32459", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-04-29", "vigencias": [{"desde": "1986-04-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-04-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-04-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAS", "fecha_ingreso": "2000-03-23", "fecha_version": "1