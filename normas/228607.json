{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6490744}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.024, de 30 de julio de 2004 de esta Subsecretar&#xED;a, prorr&#xF3;gase hasta el 15 de agosto de 2004 el per&#xED;odo de extracci&#xF3;n del recurso loco Concholepas concholepas desde las &#xE1;reas de manejo establecidas entre la VII y XI regiones que, contando con una cuota de extracci&#xF3;n autorizada para el recurso indicado, no hubiere sido extra&#xED;da en su totalidad al 31 de julio del presente, quedando sometido en lo dem&#xE1;s a las disposiciones establecidas en las resoluciones que autorizaron la extracci&#xF3;n.</div><br></div>", "i": 6490745}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de julio de 2004.- Edith Saa Collantes, Subsecretario de Pesca (S).</div><br></div>", "i": 6490746}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2024 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2024 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-07-30", "doble_articulado": false, "id_norma": "228607", "numero_fuente": "37928", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-08-05", "vigencias": [{"desde": "2004-08-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-08-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-08-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes