{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 711 EXENTO, DE 1998</div><br><br><br></div>", "i": 6128138}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 711 de fecha 6 de julio de 1998 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; el plan y programas de estudios al Centro de Formaci&#xF3;n T&#xE9;cnica Centro Nacional de Estudios Param&#xE9;dicos y Agropecuarios Propam, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida en la Sede que se se&#xF1;ala, a contar de agosto de 1998.</div><br><br><div class=\"p\">Sede N&#xBA; 11 - Temuco.</div><br><div class=\"p\">Carrera&nbsp; &nbsp; :&nbsp; &nbsp;  Prevenci&#xF3;n de Riesgos.</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp;  :&nbsp; &nbsp;  T&#xE9;cnico en Prevenci&#xF3;n de Riesgos.</div><br><br></div>", "i": 6128139}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de agosto de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6128140}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "711 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-711 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 711 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "CENTRO DE FORMACION TECNICA CENTRO NACIONAL DE ESTUDIOS PARAMEDICOS Y AGROPECUARIOS", "PROPAM"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["extracto"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-06", "doble_articulado": false, "id_norma": "123778", "numero_fuente": "36157", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-09-04", "vigencias":