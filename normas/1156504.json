{"html": [{"t": "<div><div class=\"p\">UNIFORME DE LA INFANTERIA.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Agosto 18 de 1827.</div><br><div class=\"p\">Adicion al decreto de 14 de octubre del a&#xF1;o pr&#xF3;ximo pasado. </div></div>", "i": 10245694}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  No obstante lo prevenido en el art. 3.&#xB0; del decreto de 14 de octubre del a&#xF1;o pr&#xF3;ximo pasado sobre el uniforme designado a la infanter&#xED;a, se declara nuevamente a esta el uso de un ojal bordado de oro en el cuello de la casaca de tres pulgadas y media de largo; cometi&#xE9;ndose a los jefes de los cuerpos la mas exacta uniformidad en esta parte.</div></div>", "i": 10245695}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Comun&#xED;quese a la inspeccion jeneral. </div><br><div class=\"p\">&nbsp; &nbsp;  PINTO. </div><div class=\"p\">&nbsp; &nbsp;  Borgo&#xF1;o.</div></div>", "i": 10245696}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE LA GUERRA"], "titulo_norma": "UNIFORME DE LA INFANTERIA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1827-08-18", "doble_articulado": false, "id_norma": "1156504", "numero_fuente": "1827", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1827-08-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1827-08-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1827-08-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [],