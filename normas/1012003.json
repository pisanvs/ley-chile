{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 2.558 EXENTA, DE 2010</div></div>", "i": 8902222}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.558, de 9 de marzo de 2010, del Servicio Nacional de Capacitaci&#xF3;n y Empleo, se cancel&#xF3; del Registro de Organismos T&#xE9;cnicos Intermedios para Capacitaci&#xF3;n al &quot;Organismo T&#xE9;cnico Intermedio para Capacitaci&#xF3;n Ikasi&quot; y, por ende, qued&#xF3; sin efecto su correspondiente personalidad jur&#xED;dica, en virtud de lo dispuesto en el art&#xED;culo 79 de la ley N&#xBA; 19.518.- </div></div>", "i": 8902223}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Manuel Castro Rebolledo, Director Nacional Subrogante.</div></div>", "i": 8902224}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2558 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2558 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 2.558 EXENTA, DE 2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-03-09", "doble_articulado": false, "id_norma": "1012003", "numero_fuente": "39620", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-03-25", "vigencias": [{"desde": "2010-03-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-03-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-03-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2010-03