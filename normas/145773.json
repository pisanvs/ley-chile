{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6198507}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 177, de 26 de Febrero de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Jos&#xE9; Vidal Vidal para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 1 &quot;Centro - Poblaci&#xF3;n Los Canales&quot; de Puerto Varas, cuyo trazado fue autorizado por resoluci&#xF3;n No. 118, de 28 de Junio de 1984, de esta Secretar&#xED;a Regional. </div></div>", "i": 6198508}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n </div></div>", "i": 6198509}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "177 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-177 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-26", "doble_articulado": false, "id_norma": "145773", "numero_fuente": "32717", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-03-09", "vigencias": [{"desde": "1987-03-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-03-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-03-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc