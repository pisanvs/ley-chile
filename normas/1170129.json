{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10293676}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xBA; 1.322, de 12 noviembre 2021, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos relativas a Actividad Denominada &quot;Lavat&#xF3;n&quot; en el marco de la campa&#xF1;a 2021 &quot;Telet&#xF3;n, todos los d&#xED;as&quot; en la ciudad de Coyhaique, y autoriz&#xF3; a Instituto Telet&#xF3;n Ays&#xE9;n para realizar siguiente intervenci&#xF3;n en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - corte total de v&#xED;a en calle Francisco Bilbao entre calles Lord Cochrane y Arturo Prat, entre las 10:00 hrs. y las 18:00 hrs. del d&#xED;a s&#xE1;bado 27 de noviembre de 2021.</div></div>", "i": 10293677}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andrea Mac&#xED;as Palma, Gobernadora Regional de Ays&#xE9;n.- Javier Gonz&#xE1;lez Jara, Asesor Jur&#xED;dico.</div></div>", "i": 10293678}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1322 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1322 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2056377", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-11-12", "doble_articulado": false, "id_norma": "1170129", "numero_fuente": "43130", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-12-17", "vigencias": [{"desde": "2021-12-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"ini