{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 92, DE 1986 </div></div>", "i": 6228145}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 92, de 30 de mayo de 1986 se han aprobado para la Escuela de Tripulantes, de Vi&#xF1;a del Mar, planes y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico - Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar 1986 y hasta el a&#xF1;o escolar de 1991, en la Especialidad de: Administraci&#xF3;n Mar&#xED;timo - Portuaria.</div><br></div>", "i": 6228146}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 05 de junio de 1986.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6228147}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "92 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-92 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 92, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-05-30", "doble_articulado": false, "id_norma": "154161", "numero_fuente": "32493", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-06-11", "vigencias": [{"desde": "1986-06-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-06-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-06-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_in