{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A GONZALO R. RUZ DE LA BARRA </div></div>", "i": 6580940}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/N&#xBA; Ex-4668, de fecha 23 de junio de 2006, revoca a don Gonzalo R. Ruz de la Barra, RUT N&#xBA; 5.270.939-3, a partir del d&#xED;a 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de sujeto en actividades de la construcci&#xF3;n, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 9 de las resoluciones Ex N&#xBA; 142 de 26-12-2005, de la Direcci&#xF3;n Nacional. </div></div>", "i": 6580941}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 23 de junio de 2006.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6580942}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4668 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-4668 EXENTA"}, {"tipo": "3", "numero": "DRE-08-4668 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-4668 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A GONZALO R.\nRUZ DE LA BARRA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-23", "doble_articulado": false, "id_norma": "252706", "numero_fuente": "38553", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-08-31", "vigencias": [{"desde