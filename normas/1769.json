{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5845098}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Subsecretario de Educaci&#xF3;n, quien suscribe, certifica que la Universidad Mar&#xED;tima de Chile inscrita bajo el n&#xFA;mero C-52 del Registro de Universidades del Ministerio de Educaci&#xF3;n, impartir&#xE1; la carrera profesional de Dise&#xF1;o, conducente al t&#xED;tulo profesional de Dise&#xF1;ador, en su Casa Central de Vi&#xF1;a del Mar a contar del a&#xF1;o 1994.</div><div class=\"p\">&nbsp; &nbsp; La mencionada carrera se encuentra liberada de la obligaci&#xF3;n de someter sus planes y programas de estudios a una entidad examinadora, en virtud de lo dispuesto por el D.S. N&#xB0; 1.118 de 1986.</div><br></div>", "i": 5845099}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 26 de enero de 1994.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5845100}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["UNIVERSIDAD MARITIMA CHILE", "CARRERA PROFESIONAL", "DISE O", "VI A DEL MAR", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-01-26", "doble_articulado": false, "id_norma": "1769", "numero_fuente": "34781", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-02-03", "vigencias": [{"desde": "1994-02-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-02-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "