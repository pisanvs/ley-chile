{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6402503}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.506, de 5 de noviembre de 2002, de esta Subsecretar&#xED;a, recon&#xF3;cese la participaci&#xF3;n conjunta de los armadores que se indican, en la unidad de pesquer&#xED;a de Jurel, I y II Regiones, individualizada en el art&#xED;culo 2&#xBA; letra r) de la ley 19.713, para ejercer el l&#xED;mite m&#xE1;ximo de captura establecido por decreto exento N&#xBA; 920 de 2002, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, a partir de la fecha de la presente resoluci&#xF3;n y hasta el 31 de diciembre de 2002:</div><br><div class=\"p\">CORPESCA S.A.;&nbsp; SAN JOSE S.A., PESQ.;&nbsp; SOUTH PACIFIC</div><div class=\"p\">KORP S.A.</div><br><br></div>", "i": 6402504}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de noviembre de 2002.- Edith Saa Collantes, Subsecretario de Pesca (S).</div><br></div>", "i": 6402505}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2506", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2506"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-11-05", "doble_articulado": false, "id_norma": "204476", "numero_fuente": "37408", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-11-14", "vigencias": [{"desde": "2002-11-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-11-14", "fin_vigencia": ""}, "vigencias_version_norma