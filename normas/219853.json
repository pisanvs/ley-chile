{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1 EXENTA, DE 2004 </div></div>", "i": 6457831}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Res. Ex. SII N&#xBA; 1 del 2 de enero de 2004, se autoriza como emisor de documentos tributarios electr&#xF3;nicos a contar del mes de enero de 2004 a los contribuyentes RUT 97.051.000-1 y RUT 96.711.590-8. En el sitio web del SII se podr&#xE1; consultar los documentos que los contribuyentes est&#xE1;n autorizados a emitir en forma electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra incluido en el sitio Web del SII en Internet, cuya direcci&#xF3;n es www.sii.cl.</div><br></div>", "i": 6457832}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Juan Toro Rivera, Director.</div><br></div>", "i": 6457833}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-02", "doble_articulado": false, "id_norma": "219853", "numero_fuente": "37753", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-01-07", "vigencias": [{"desde": "2004-01-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-01-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-01-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vin