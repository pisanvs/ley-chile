{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;584 EXENTO, DE 2004</div><br><br></div>", "i": 6499586}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;584, de fecha 3 de agosto de 2004, se revoca el reconocimiento oficial del Instituto Profesional Diego Barros Arana organizado por la Sociedad Educacional del Sur S.A. y elim&#xED;nase a dicha entidad del Registro de Insitutos Profesionales en que se encuentra inscrita con el N&#xBA;101.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, se deroga el decreto exento de Educaci&#xF3;n N&#xBA;1.026, de fecha 9 de octubre de 1997, que autoriz&#xF3; el funcionamiento al Instituto Profesional Diego Barros Arana.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; Lo dispuesto en los art&#xED;culos precedentes rige a partir del 31 de diciembre de 2003.</div><br></div>", "i": 6499587}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Santiago, 28 de septiembre de 2004.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6499588}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "584 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-584 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº584 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO PROFESIONAL DIEGO BARROS ARANA", "RECONOCIMIENTO OFICIAL", "REVOCACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-08-03", "doble_articulado": false, "id_norma": "231028", "numero_fuente": "37976", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-10-02", "vigencias": [{"desde": "2004-10-02", "hasta": "", "tipo_v