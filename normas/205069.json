{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6404300}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.642, de 14 de noviembre de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a EMPACADORA DEL PACIFICO LIMITADA, RUT N&#xBA; 84.768.700-2, para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Ferrari N&#xBA; 80, Lo Espejo, Santiago, en las l&#xED;neas de proceso que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Fresco Enfriado, Fresco Refrigerado y Congelado: Caballa, Lenguado de ojos chicos, Lenguado de ojos grandes, Reineta, R&#xF3;balo, Besugo; Congelado: Trucha arcoiris, Blanquillo, Raya tembladera, Raya espinosa, Raya volant&#xED;n, Merluza de cola, Pejegallo, Sierra, Jurel. </div></div>", "i": 6404301}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de noviembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6404302}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2642", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2642"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-11-14", "doble_articulado": false, "id_norma": "205069", "numero_fuente": "37421", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-11-29", "vigencias": [{"desde": "2002-11-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-11-29", "fin_vigencia": ""}, "vigencias_version_norma":