{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6550810}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.029, de 22 de noviembre</div><div class=\"p\">de 2005, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad</div><div class=\"p\">parcial de la resoluci&#xF3;n N&#xBA; 2.954, de 2002, s&#xF3;lo en</div><div class=\"p\">cuanto autoriz&#xF3; a PESQUERA JUAN LUIS PARRA FARRES</div><div class=\"p\">LIMITADA para realizar actividades pesqueras con la nave</div><div class=\"p\">&quot;Isla Tab&#xF3;n&quot; sobre el recurso hidrobiol&#xF3;gico Bacalao de</div><div class=\"p\">profundidad, en el &#xE1;rea mar&#xED;tima comprendido entre Punta</div><div class=\"p\">Liles y la X Regi&#xF3;n, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura, y lo informado por la Divisi&#xF3;n de Administraci&#xF3;n Pesquera de la Subsecretar&#xED;a de Pesca. </div></div>", "i": 6550811}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de noviembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6550812}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4029 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4029 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-22", "doble_articulado": false, "id_norma": "244494", "numero_fuente": "38327", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-12-02", "vigen