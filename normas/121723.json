{"html": [{"t": "<div><br><div class=\"p\">CERTIFICA CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD QUEZADA, CALDERON CIA. LTDA.</div><br><br><br></div>", "i": 6120785}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 12.- Certifico que la Sociedad Quezada, Calder&#xF3;n C&#xED;a. Ltda., Rut N&#xBA; 79.786.950-3 cumple los requisitos establecidos en la resoluci&#xF3;n N&#xBA; 2.705 de 07.05.98 seg&#xFA;n consta en informe N&#xBA; 249 emitido por el Departamento de Fiscalizaci&#xF3;n el 03.07.98 y que en consecuencia tiene la calidad de agente retenedor del Impuesto al Valor Agregado por las ventas de carnes que efect&#xFA;e, a contar de la fecha de publicaci&#xF3;n de este certificado en el Diario Oficial.</div><br></div>", "i": 6120786}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de julio de 1998.- Francisco C&#xE1;rcamo Avenda&#xF1;o, Director Regional.</div><br></div>", "i": 6120787}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "12", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-12"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL DE VALPARAÍSO"], "titulo_norma": "CERTIFICA CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD QUEZADA, CALDERON CIA. LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "SOCIEDAD QUEZADA", "CALDERON CIA. LTDA."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-08", "doble_articulado": false, "id_norma": "121723", "numero_fuente": "36120", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-07-22", "vigencias": [{"desde": "1998-07-22", "hasta": "", "tipo_version": "3", "tipo_v