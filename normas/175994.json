{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;312 EXENTO, DE 2000 </div></div>", "i": 6302281}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;312 de fecha 22 de agosto de 2000 del Ministerio de Educaci&#xF3;n, se revoca el reconocimiento oficial al Instituto Profesional EACE organizado por la Sociedad Instituto Profesional EACE Limitada y elim&#xED;nase a dicha entidad del Registro de Institutos Profesionales en que se encuentra inscrito con el N&#xBA;62.</div><div class=\"p\">&nbsp; &nbsp;  Der&#xF3;gase el decreto exento de Educaci&#xF3;n N&#xBA;34 del 29 de enero de 1990 modificado por decreto exento N&#xBA;252 del 7 de junio de 1994, que autoriz&#xF3; el funcionamiento al Instituto Profesional EACE.</div><br></div>", "i": 6302282}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de septiembre de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6302283}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "312 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-312 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 312 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-08-22", "doble_articulado": false, "id_norma": "175994", "numero_fuente": "36769", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-22", "vigencias": [{"desde": "2000-09-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-09-22