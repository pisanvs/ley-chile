{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 234 EXENTO, DE 1996 </div></div>", "i": 5943004}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 234, de fecha 24 de abril de 1996, del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a la Sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica Centro Nacional de Estudios Param&#xE9;dicos y Agropecuarios Propam, para impartir plan y programas de estudios aprobados para la instituci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se se&#xF1;ala, a partir del a&#xF1;o 1996:</div><div class=\"p\"> -&nbsp; Sede N&#xB0; 9-Talca</div><div class=\"p\">&nbsp; Carrera :&nbsp; &nbsp; T&#xE9;cnico Forestal</div><div class=\"p\">&nbsp; T&#xED;tulo&nbsp; :&nbsp; &nbsp; T&#xE9;cnico Forestal</div><br></div>", "i": 5943005}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 11 de junio de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943006}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "234", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-234"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 234 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA", "CENTRO NACIONAL ESTUDIOS PARAMEDICOS AGROPECUARIOS PROPAM", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-04-24", "doble_articulado": false, "id_norma": "20752", "numero_fuente": "35511", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-07-09", "vigencias": [{"desde": "1996-07-09", "hasta