{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7368872}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 848, de 2 de abril de 2008, de esta Subsecretar&#xED;a, autor&#xED;zase a SINDICATO DE TRABAJADORES INDEPENDIENTES DE LA PESCA ARTESANAL, BUZOS MARISCADORES Y ACTIVIDADES CONEXAS CALETA CERRO VERDE para ampliar actividades de transformaci&#xF3;n autorizadas por resoluciones citadas en Visto, para incorporar planta ubicada en calle El Faro, Pasaje N&#xBA; 2 s/n, Cerro Verde Bajo, comuna de Penco, VIII Regi&#xF3;n, en l&#xED;neas proceso Alga seca y Alga fresca, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada. </div></div>", "i": 7368873}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de abril de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7368874}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "848 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-848 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-04-02", "doble_articulado": false, "id_norma": "270989", "numero_fuente": "39054", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-05-06", "vigencias": [{"desde": "2008-05-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-05-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-05-06", "fin_vigencia": "", "tipo_version": "3"}], "evento