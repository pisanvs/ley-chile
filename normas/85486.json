{"html": [{"t": "<div><div class=\"p\">RECTIFICACION </div></div>", "i": 9049422}, {"t": "<div><br><div class=\"p\">En la edici&#xF3;n del Diario Oficial No. 34.240 de 9 de Abril de 1992, se public&#xF3; resoluci&#xF3;n No. 048/92 que autoriza existencia y aprueba estatutos a &quot;Santander S.A. Administradora de Fondos de Inversi&#xF3;n&quot;, con el error que se salva a continuaci&#xF3;n: p&#xE1;gina tres, cuarta columna, donde dice &quot; Que por resoluci&#xF3;n No. 48, de fecha 31 de Marzo de 1992 se autoriz&#xF3; la existencia y...&quot; debe decir &quot;Que por resoluci&#xF3;n No. 048, de fecha 31 de Marzo de 1992 se autoriz&#xF3; la existencia y...&quot;.</div><br></div>", "i": 9049423}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "48", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-48"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "RECTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-04-09", "doble_articulado": false, "id_norma": "85486", "numero_fuente": "34247", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-04-20", "vigencias": [{"desde": "1992-04-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-04-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-04-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMB", "fecha_ingreso": "1998-01-19", "fecha_version": "1992-04-20", "fecha_actualizacion_texto": "1992-04-20", "tipo_tratado": ""}, "alertas": [], "alerta_global":