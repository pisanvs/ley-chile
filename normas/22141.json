{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PENSION Lei n&#xFA;m. 288.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947423}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, a do&#xF1;a Clotilde Garrido, viuda del piloto primero de la Armada don Ramon Osorio, la pension de montep&#xED;o que corresponde al empleo de teniente primero de Marina.</div><br><br></div>", "i": 5947424}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- Jorje Montt.- C&#xE1;rlos Rivera Jofr&#xE9;.</div><br></div>", "i": 5947425}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "288", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-288"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CLOTILDE GARRIDO", "MONTEPIO MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-07-19", "doble_articulado": false, "id_norma": "22141", "numero_fuente": "5166", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-07-22", "vigencias": [{"desde": "1895-07-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-07-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1895-07-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999