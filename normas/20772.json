{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 240, DE 1993 </div></div>", "i": 7161277}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 240 de fecha 25 de Mayo de 1993 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica CIDEC, las adecuaciones introducidas al Plan y Programas de Estudios de la Carrera de Secretariado Ejecutivo Computacional, las que se insertaron en el Decreto Exento de Educaci&#xF3;n N&#xB0; 420 de 1990. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1993.-</div><br></div>", "i": 7161278}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n. + </div></div>", "i": 7161279}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "240 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-240 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 240, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA", "CIDEC", "PLANES ESTUDIOS", "SANTIAGO", "REGION METROPOLITANA", "PROGRAMAS ESTUDIOS", "SECRETARIADO EJECUTIVO COMPUTACIONAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-05-25", "doble_articulado": false, "id_norma": "20772", "numero_fuente": "34637", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-08-10", "vigencias": [{"desde": "1993-08-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-08-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-08-10", "fin_vigencia": "", "tipo_version": "3"}], "