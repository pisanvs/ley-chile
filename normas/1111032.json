{"html": [{"t": "<div><br><div class=\"p\">ESTABLECE PROCEDIMIENTO QUE INDICA</div></div>", "i": 9851042}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 5.274, de 9 de noviembre de 2017, del Servicio Nacional de Pesca y Acuicultura se establece el procedimiento de retiro y traslado de algas varadas producto de marejadas conforme lo determinado por el Seremi de Salud de Atacama.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n individualizada podr&#xE1; ser consultado en las p&#xE1;ginas de dominio electr&#xF3;nico de este Servicio y de la Subsecretar&#xED;a de Pesca y Acuicultura.- </div></div>", "i": 9851043}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Miguel Burgos Gonz&#xE1;lez, Director Nacional, Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9851044}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5274", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5274"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "ESTABLECE PROCEDIMIENTO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1304373; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-11-09", "doble_articulado": false, "id_norma": "1111032", "numero_fuente": "41911", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-11-18", "vigencias": [{"desde": "2017-11-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-11-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vi