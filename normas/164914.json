{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 381 EXENTO DE 1999</div><br><br></div>", "i": 6263035}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 381 de 5 de noviembre de 1999, se ha aprobado, a partir del a&#xF1;o escolar 1999, un programa de Religi&#xF3;n de la Iglesia Cat&#xF3;lica para los cursos de 1&#xBA;, 2&#xBA; y 3er. a&#xF1;o de ense&#xF1;anza media, ambas modalidades, el que podr&#xE1; aplicarse seg&#xFA;n lo dispuesto en el decreto supremo de Educaci&#xF3;n N&#xBA; 924 de 1983, respetando la gradualidad establecida en el decreto supremo de Educaci&#xF3;n N&#xBA; 220 de 1998 y sus modificaciones.</div><br></div>", "i": 6263036}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de diciembre de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6263037}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "381 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-381 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 381 EXENTO DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EDUCACION", "RELIGION DE LA IGLESIA CATOLICA", "APLICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-11-05", "doble_articulado": false, "id_norma": "164914", "numero_fuente": "36638", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-12", "vigencias": [{"desde": "2000-04-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-04-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-04-12", "fin_