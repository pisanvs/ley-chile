{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6147008}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 1.316 de 3 de Agosto de 1988, conforme art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a parcelas Nos. 5 a la 8, sitios N&#xB0;s. 2, 4 y 5 del Proyecto de Parcelaci&#xF3;n &quot;Estrella de Duqueco&quot;, de la comuna de Quilleco, VIII Regi&#xF3;n, formado por predio &quot;El Rosario un retazo de terreno de veintid&#xF3;s cuadras m&#xE1;s o menos de extensi&#xF3;n y tres cuadras de terreno&quot;. Los Derechos de Agua se extraen del r&#xED;o Duqueco conducidas por canal El Rosario. Publicaci&#xF3;n hecha conforme art. 13 ley No. 18.377.-</div><br></div>", "i": 6147009}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6147010}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1316 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1316 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-03", "doble_articulado": false, "id_norma": "129439", "numero_fuente": "33150", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-08-16", "vigencias": [{"desde": "1988-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-08-16", "fin_vigencia": "", "tipo_version": "