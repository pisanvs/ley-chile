{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6046472}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 754, de 31 de julio de 1997, se expropiaron los lotes de terreno N&#xBA;s. 9-B, 77-A y 83-A, superficies 80,435 y 3.504 M2. respectivamente, roles de aval&#xFA;o en tr&#xE1;mite, comuna de Marchig&#xFC;e, para la obra Camino San Fernando - Pichilemu, Sector La Rosa - Alto Colorado (1 - 174) y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Pedro Lizana Caro, Fresia Jim&#xE9;nez Medina y Juan Jim&#xE9;nez Medina, ascendente a las cantidades de $379.250, $718.525 y $1.480.920. </div></div>", "i": 6046473}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6046474}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "754", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-754"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "MARCHIGUE", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-31", "doble_articulado": false, "id_norma": "76043", "numero_fuente": "35879", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-10-01", "vigencias": [{"desde": "1997-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-10-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CAV", "fecha_ingreso": "1997-10-10", "fech