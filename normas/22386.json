{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Contribuciones Municipales </div><div class=\"p\">&nbsp; &nbsp; Lei N&#xFA;m. 1,061.- Santiago, a 5 de Setiembre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274067}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO PRIMERO. Los tesoreros municipales, para hacer efectivo el pago de las contribuciones municipales, se sujetar&#xE1;n a las prescripciones que para los tesoreros fiscales estableci&#xF3; en sus art&#xED;culos 26 a 30 inclusive la lei de 20 de Enero de 1883, que organiz&#xF3; el servicio de las tesorer&#xED;as en la Rep&#xFA;blica.</div><br><br></div>", "i": 8274068}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ART. 2.&#xB0; En los cobros del impuesto de patentes los procedimientos judiciales no obstan a las medidas administrativas de apremio establecidas por la lei. </div></div>", "i": 8274069}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARt. 3&#xB0;.- Esta lei comenzar&#xE1; a rejir desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 8274070}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C. Walker Martinez.</div><br></div>", "i": 8274071}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1061", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1061"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONTRIBUCIONES MUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDADES", "CONTRIBUCIONES", "COBRANZA", "DISPOSICIONES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-09-05", "doble_articulado": false, "id_norma": "22386", "numero_fuente": "6094", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-09-05", "vigencias": [{"desde": "1898-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-09-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-09-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-01-28", "fecha_version": "1898-09-05", "fecha_actualizacion_texto": "1898-09-05", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8274067}, {"n": "Artículo PRIMERO", "i": 8274068, "t": 6}, {"n": "Artículo 2", "i": 8274069, "t": 6}, {"n": "Artículo 3", "i": 8274070, "t": 6}, {"n": "Promulgación", "i": 8274071}]}