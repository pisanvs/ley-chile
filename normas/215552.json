{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 306, DE 2003 </div></div>", "i": 7304203}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA; 306, de 29 de agosto 2003, se ha aprobado el convenio de fecha 22 de agosto de 2003 celebrado entre el Ministerio de Educaci&#xF3;n y la Ilustre Municipalidad de Talca, que rescilia el Convenio de Traspaso de la Escuela B&#xE1;sica F N&#xBA; 166, traspasada a dicha Corporaci&#xF3;n por Convenio de Traspaso de fecha 2 de abril de 1981, modificado por Convenio de 20 de noviembre de 1984, aprobado por decreto de N&#xBA; 954, de 22 de noviembre de 1984, de Subsecretar&#xED;a de Educaci&#xF3;n.</div><br></div>", "i": 7304204}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago,&nbsp; 22&nbsp; de agosto de 2003.- Mar&#xED;a&nbsp; Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 7304205}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "306", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-306"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 306, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-29", "doble_articulado": false, "id_norma": "215552", "numero_fuente": "37679", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-10-08", "vigencias": [{"desde": "2003-10-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-10-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-10-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe