{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza la ereccion de un monumento a don Jos&#xE9; Bunster en la ciudad de Angol</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,720.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275524}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Se autoriza la ereccion, por suscricion popular, en la ciudad de Angol, de un monumento al se&#xF1;or don Jos&#xE9; Bunster.</div><br></div>", "i": 8275525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 18 de Diciembre de 1912.- RAMON BARROS LUCO.- Guillermo Barros.</div><br></div>", "i": 8275526}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2720", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2720"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA LA ERECCION DE UN MONUMENTO A DON JOSE BUNSTER EN LA CIUDAD DE ANGOL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JOSE BUNSTER", "ANGOL", "MONUMENTO", "ERECCION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-12-18", "doble_articulado": false, "id_norma": "23448", "numero_fuente": "10464", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-12-28", "vigencias": [{"desde": "1912-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-12-28", "fin_vigenc