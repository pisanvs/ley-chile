{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 587 EXENTO, DE 2001</div><br><br></div>", "i": 6351527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 587, de 30 de agosto de 2001, se ha aprobado al Colegio &quot;Saint Jame&apos;s School&quot;, de Concepci&#xF3;n, un plan de estudio para 1&#xBA; a 8&#xBA; a&#xF1;o (NB.1, NB.2, NB.3, NB.4, NB.5, NB.6) de Ense&#xF1;anza B&#xE1;sica.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio de los subsectores que se indican, cuya ense&#xF1;anza se impartir&#xE1; en la mayor&#xED;a de las asignaturas en idioma ingl&#xE9;s. </div></div>", "i": 6351528}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de septiembre de 2001.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 6351529}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "587 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-587 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 587 EXENTO, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-08-30", "doble_articulado": false, "id_norma": "190075", "numero_fuente": "37073", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-09-29", "vigencias": [{"desde": "2001-09-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-09-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-09-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [],