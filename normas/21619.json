{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 642 EXENTO, DE 1993 </div></div>", "i": 7162172}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 642 de fecha 7 de diciembre de 1993 del Ministerio de Educaci&#xF3;n, se sustituy&#xF3; el inciso 1&#xB0; del art&#xED;culo 1&#xB0; del Decreto Exento de Educaci&#xF3;n N&#xB0; 185 del 1 de diciembre de 1988, correspondiente al Instituto Profesional de Valpara&#xED;so Limitada, por el siguiente nuevo:</div><div class=\"p\">&nbsp; &nbsp; &quot;Autor&#xED;zase el funcionamiento del Instituto Profesional que se indica, organizado por la persona jur&#xED;dica que se se&#xF1;ala:</div><div class=\"p\"> Nombre de la Instituci&#xF3;n : Instituto Profesional de</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Valpara&#xED;so Limitada.</div><div class=\"p\"> Domicilio&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Valpara&#xED;so.</div><div class=\"p\"> Organizador&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Sociedad Instituto</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Profesional de Valpara&#xED;so</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Ltda.&quot;.</div><br></div>", "i": 7162173}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n. + </div></div>", "i": 7162174}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "642 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-642 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 642 EXENTO, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_li