{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO RESOLUCIONES EXENTAS QUE INDICA</div></div>", "i": 10056266}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.049, de 11 de septiembre de 2019, de esta Subsecretar&#xED;a, d&#xE9;jense sin efecto las resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=263358&amp;idParte=&amp;idVersion=\">N&#xBA; 2.281</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=263375&amp;idParte=&amp;idVersion=\">N&#xBA; 2.298</a>, ambas de 2007, que autorizaron a Corpesca S.A. para realizar actividades extractivas en alta mar, con las naves &quot;Toconao II&quot;, matr&#xED;cula N&#xBA; 2482 y &quot;Eperva 58&quot;, matr&#xED;cula N&#xBA; 2437, por configurarse la causal establecida en el art&#xED;culo 11.- letra a) del decreto supremo N&#xBA; 360 de 2005, del actual Ministerio de Econom&#xED;a, Fomento y Turismo.</div><div class=\"p\"> </div><br><br></div>", "i": 10056267, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de septiembre de 2019.- Jos&#xE9; Pedro N&#xFA;&#xF1;ez Barruel, Subsecretario de Pesca y Acuicultura (S).</div><br></div>", "i": 10056268}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3049 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3049 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DEJA SIN EFECTO RESOLUCIONES EXENTAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1657664", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-09-11", "doble_articulado": false, "id