{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pension Lei n&#xFA;m. 954.- Santiago, a 16 de Setiembre de 1897.- Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7162766}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, a do&#xF1;a Jertr&#xFA;dis Valdivieso, viuda de Valdivieso, muerto en la batalla de Placilla, el goce de la pensi&#xF3;n que se&#xF1;ala el art&#xED;culo 11 de la lei de 22 de Diciembre de 1881.</div><br><br></div>", "i": 7162767}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C&#xE1;rlos A. Palacios Z.</div><br></div>", "i": 7162768}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "954", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-954"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JERTRUDIS VALDIVIESO", "VIUDA DE VALDIVIESO", "PENSION", "GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-09-16", "doble_articulado": false, "id_norma": "22300", "numero_fuente": "5814", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1897-09-28", "vigencias": [{"desde": "1897-09-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1897-09-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1897-09-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc