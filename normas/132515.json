{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE EXPROPIACION </div></div>", "i": 6156467}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alcalde I. Municipalidad de Conchal&#xED;, mediante Decreto Exento No. 144 de 29 de Marzo de 1988, dispone expropiaci&#xF3;n parcial, conforme Decreto Supremo No. 458, de Vivienda, de 1976, y Decretos Leyes 1.289, 2.186 y 3.464 de inmueble ubicado en Los Minerales No. 3201, Rol de Aval&#xFA;os No. 2235-1, aparentemente de propiedad de don Eduardo Allende Ledesma, para conectar Avenida Dorsal con Avenida Ferm&#xED;n Vivaceta. Deslindes parte expropiada: al Nor/Poniente: 30,00 mts. con resto de la propiedad; al Nor/Oriente: 22,00 mts. con Callej&#xF3;n Angosto y al Sur: 28,00 mts. con calle Papudo. Indemnizaci&#xF3;n provisional de $ 1.383.000.- pagadera contado.- </div></div>", "i": 6156468}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fernando Alvarez G&#xE1;lvez, Alcalde.- Neftal&#xED; Past&#xE9;n Ibarra, Secretario Municipal.</div><br></div>", "i": 6156469}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "144 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-144 EXENTO"}], "organismos": ["MUNICIPALIDAD DE CONCHALÍ"], "titulo_norma": "EXTRACTO DE EXPROPIACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-29", "doble_articulado": false, "id_norma": "132515", "numero_fuente": "33046", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-04-15", "vigencias": [{"desde": "1988-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"