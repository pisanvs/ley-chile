{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Construccion i sostenimiento de lazaretos Lei n&#xFA;m. 38.- Santiago, a 14 de Junio de 1893.- Por cuanto el Congreso Nacional ha aprobado el siguiente PROYECTO DE LEI:</div><br></div>", "i": 8273648}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se concede la suma de ochenta mil pesos ($ 80,000) para la construccion i sostenimiento de lazaretos, pago del valor de las nuevas salas construidas en el Hospital del Salvador i Lazaretos de San Jos&#xE9; de Santiago, i para la atencion de variolosos.</div><br><br></div>", "i": 8273649}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de Rep&#xFA;blica.- JORJE MONTT.- Pedro Montt.</div><br></div>", "i": 8273650}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "38", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-38"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONSTRUCCION I SOSTENIMIENTO DE LAZARETOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LAZARETOS", "CONSTRUCCION", "SOSTENIMIENTO", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-06-14", "doble_articulado": false, "id_norma": "21911", "numero_fuente": "4544", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-06-14", "vigencias": [{"desde": "1893-06-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-06-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-06-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": 