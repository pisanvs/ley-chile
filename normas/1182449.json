{"html": [{"t": "<div><div class=\"p\">SUSPENDE VEDA BIOL&#xD3;GICA PARA EL RECURSO CHOLGA EN &#xC1;REA MAR&#xCD;TIMA QUE INDICA</div></div>", "i": 10370723}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 202200129, de 30 de septiembre de 2022, de este Ministerio, susp&#xE9;ndase entre los d&#xED;as 1 y 15 de octubre de 2022, ambas fechas inclusive, la veda biol&#xF3;gica del recurso Cholga en el &#xE1;rea mar&#xED;tima de la Regi&#xF3;n de Los Lagos.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10370724}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de septiembre de 2022.- Paulo Sep&#xFA;lveda Sep&#xFA;lveda, Subsecretario de Pesca y Acuicultura (S).</div><div class=\"p\"> </div><br></div>", "i": 10370725}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "202200129 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-202200129 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "SUSPENDE VEDA BIOLÓGICA PARA EL RECURSO CHOLGA EN ÁREA MARÍTIMA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2196948", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-09-30", "doble_articulado": false, "id_norma": "1182449", "numero_fuente": "43369", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-10-05", "vigencias":