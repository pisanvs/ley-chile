{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7194072}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 20, de fecha 29 de Mayo de 1995, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se adjudic&#xF3; a la Empresa M &amp; M Servicios y Construcciones Limitada, la concesi&#xF3;n para operar, hasta el 7 de Septiembre de 1997, a contar de la fecha de publicaci&#xF3;n del presente extracto, un establecimiento ubicado en el Km. 2.5 camino a Yumbel, de la comuna de Yumbel, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de emisi&#xF3;n de contaminantes de los servicios motorizados, remolques y semirremolques, seg&#xFA;n el art&#xED;culo 7&#xB0; del D.S. N&#xB0; 156/90 en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 7194073}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Miguel Reyes N&#xFA;&#xF1;ez, Secretario Regional Ministerial de Transportes y Telecomunicaciones, VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 7194074}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "20", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-20"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANTA REVISION TECNICA", "AUTORIZACION", "EMPRESA M &amp; M", "SERVICIOS Y CONSTRUCCIONES LIMITADA", "VEHICULOS", "MOTORIZADOS", "YUMBEL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-29", "doble_articulado": false, "id_norma": "32207", "numero_f