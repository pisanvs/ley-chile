{"html": [{"t": "<div><div class=\"p\">AUTORIZA A RECEPTORES ELECTRONICOS </div></div>", "i": 6522387}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 40 de 14/04/2005, que autoriza a Organismos P&#xFA;blicos como receptores electr&#xF3;nicos.</div><br><div class=\"p\">&nbsp; &nbsp;  Se autoriza como receptores de documentos tributarios electr&#xF3;nicos, a contar del mes de abril de 2005, a los Organismos P&#xFA;blicos RUT N&#xBA; 74.805.400-6 y RUT N&#xBA; 61.607.400-8.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de abril de 2005.</div><br></div>", "i": 6522388}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "40 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-40 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A RECEPTORES ELECTRONICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONTRIBUYENTES", "EMISORES ELECTRONICOS", "AUTORIZACION", "DOCUMENTOS TRIBUTARIOS ELECTRONICOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-04-14", "doble_articulado": false, "id_norma": "237176", "numero_fuente": "38139", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-04-19", "vigencias": [{"desde": "2005-04-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-04-19", "fin_vigencia": ""