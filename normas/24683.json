{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n por gracia, al ex-Visitador de Escuelas, don Federico Ba&#xF1;ados</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5959381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, al ex-Visitador de Escuelas, don Federico Ba&#xF1;ados, el goce de una pensi&#xF3;n anual de ocho mil pesos ($ 8,000) en vez de la que actualmente disfruta.</div><br></div>", "i": 5959382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y, por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintis&#xE9;is de Julio de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- J. Eduardo Barrios. </div></div>", "i": 5959383}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4356", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4356"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "CONCEDE PENSION POR GRACIA, AL EX-VISITADOR DE ESCUELAS, DON FEDERICO BAÑADOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FEDERICO BA ADOS", "PENSION GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-07-26", "doble_articulado": false, "id_norma": "24683", "numero_fuente": "15146", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-08-10", "vigencias": [{"desde": "1928-08-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-08-10", "fin_vigencia