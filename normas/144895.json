{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6195764}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 120, de 05 de Febrero de 1987, de esta Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Pedro Reyes Guajardo para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea N&#xB0; 10 &quot;CORVI - Regional - Centro&quot; de Valdivia, cuyo trazado fue autori zado por resoluci&#xF3;n exenta N&#xB0; 12, de 04 de Enero de 1985, y modificado por resoluci&#xF3;n exenta N&#xB0; 486, de 04 de Noviembre de 1985, de esta Secretar&#xED;a Regional.</div><br></div>", "i": 6195765}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n. </div></div>", "i": 6195766}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "120 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-120 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-05", "doble_articulado": false, "id_norma": "144895", "numero_fuente": "32708", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-02-26", "vigencias": [{"desde": "1987-02-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-02-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci