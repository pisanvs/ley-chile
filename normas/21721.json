{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 709 EXENTO, DE 1993 </div></div>", "i": 7162251}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0;709 de fecha 31 de Diciembre de 1993 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Instituto AIEP las adecuaciones introducidas al plan y programas de estudio de la carrera Administraci&#xF3;n Agr&#xED;cola, las que se insertaron en el Decreto Exento de Educaci&#xF3;n N&#xB0;400 de 1990. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1994. </div></div>", "i": 7162252}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 8 de Abril de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7162253}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "709 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-709 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 709 EXENTO, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "CENTRO FORMACION TECNICA", "INSTITUTO", "AIEP", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-12-31", "doble_articulado": false, "id_norma": "21721", "numero_fuente": "34858", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-05-06", "vigencias": [{"desde": "1994-05-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-05-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-05-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente