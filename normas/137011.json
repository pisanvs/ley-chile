{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,278.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170581}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.-&nbsp; En atencion a los servicios prestados durante la guerra contra el Per&#xFA; i Bolivia por el teniente-coronel de Ej&#xE9;rcito, don Virjilio M&#xE9;ndez, aum&#xE9;ntase, por gracia, a ciento veinte pesos ($ 120) mensuales la pension de montep&#xED;o de que actualmente disfrutan su viuda e hijos lej&#xED;timos, debiendo rejir el aumento desde la fecha de la promulgacion de esta lei. </div></div>", "i": 6170582}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, cinco de marzo de mil novecientos diez.- Pedro Montt.-&nbsp; An&#xED;bal Rodr&#xED;guez H.</div><br></div>", "i": 6170583}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2278", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2278"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-03-05", "doble_articulado": false, "id_norma": "137011", "numero_fuente": "9652", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-03-30", "vigencias": [{"desde": "1910-03-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-03-30", "fin_vigenci