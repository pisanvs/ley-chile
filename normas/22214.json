{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; VENTA DE TERRENOS FISCALES FORMADOS POR EL NUEVO MALECON DE VALPARAISO</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 364.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947734}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Renu&#xE9;vase por dos a&#xF1;os la autorizacion conferida al Presidente de la Rep&#xFA;blica por lei del 1.&#xB0; de Febrero de 1888 para que proceda a vender en p&#xFA;blica subasta los terrenos fiscales formados por el nuevo malecon de Valparaiso.</div><br><br></div>", "i": 5947735}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, lo he aprobado i sancionado; i por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 17 de Julio de 1896.- JORJE MONTT.- Herm&#xF3;jenes P&#xE9;rez de Arce.</div><br></div>", "i": 5947736}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "364", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-364"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "VENTA DE TERRENOS FISCALES FORMADOS POR EL NUEVO MALECON DE VALPARAISO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VALPARAISO", "MALECON", "TERRENOS", "VENTA", "AUTORIZACION", "RENOVACION", "PLAZO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-07-17", "doble_articulado": false, "id_norma": "22214", "numero_fuente": "5461", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1896-07-21", "vigencias": [{"desde": "1896-07-21", "hasta": "", "tipo_version": "3", "tipo_version_