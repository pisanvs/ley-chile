{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,221.- Santiago, 1.&#xBA; de julio de 1899.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6162717}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- En atenci&#xF3;n a los servicios prestados al pais por el teniente-coronel don Francisco Javier Zelaya, conc&#xE9;desele, por gracia, para los efectos de su retiro, el abono de los seis a&#xF1;os ocho meses i quince dias que estuvo retirado absolutamente del Ej&#xE9;rcito desde el 30 de enero de 1873 hasta el 29 de setiembre de 1879.</div><br></div>", "i": 6162718}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- J. A. Figueroa.</div><br></div>", "i": 6162719}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1221", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1221"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-07-01", "doble_articulado": false, "id_norma": "134548", "numero_fuente": "6338", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-07-03", "vigencias": [{"desde": "1899-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-07-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-07-03", "fin_vigencia": "", "tipo_version": "3"}], 