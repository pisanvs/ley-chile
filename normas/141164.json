{"html": [{"t": "<div><div class=\"p\">EXTRACTO&nbsp; DE RESOLUCION N&#xBA;4.102 EXENTA, DE 1999 </div><br></div>", "i": 6184503}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;4.102 de 6 de mayo de 1999, se ha aprobado al Colegio San Juan Evangelista, comuna de Las Condes, de Santiago, un plan especial de estudio para primer a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 1999.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para primer a&#xF1;o de Ense&#xF1;anza Media de los subsectores que se indican en la presente resoluci&#xF3;n exenta.</div><br></div>", "i": 6184504}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de agosto de 1999.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6184505}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4102 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4102 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº4.102 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-05-06", "doble_articulado": false, "id_norma": "141164", "numero_fuente": "36447", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-08-24", "vigencias": [{"desde": "1999-08-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-08-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-08-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi