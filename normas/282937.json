{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA;7.671 EXENTA, DE 2008 </div></div>", "i": 8377653}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 7.671, de 23 de octubre de 2008, se ha modificado la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 4.515, de 2008, que aprob&#xF3; planes y programas especiales de estudio de 1&#xBA; y 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media al Colegio &quot;Redland School&quot;, de la comuna de Las Condes, de Santiago, en el sentido de eliminar del Plan de Formaci&#xF3;n General el Subsector de Educaci&#xF3;n Tecnol&#xF3;gica de 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media. </div></div>", "i": 8377654}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de noviembre de 2008.- Rosita Puga Hamilton, Jefa Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 8377655}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7671 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7671 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº7.671 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-10-23", "doble_articulado": false, "id_norma": "282937", "numero_fuente": "39232", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-12-09", "vigencias": [{"desde": "2008-12-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-12-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-12-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient