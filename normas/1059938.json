{"html": [{"t": "<div><br><div class=\"p\">INSTALA LA XIX DIRECCI&#xD3;N REGIONAL METROPOLITANA SANTIAGO NORTE, FIJANDO SU SEDE Y TERRITORIO JURISDICCIONAL</div></div>", "i": 9409811}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA;24, de 24 de febrero de 2014, que se&#xF1;ala:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Inst&#xE1;lase la XIX Direcci&#xF3;n Regional Metropolitana Santiago Norte, con sede en la comuna de Recoleta y f&#xED;jase su territorio jurisdiccional.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en febrero de 2014.</div></div>", "i": 9409812}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "24 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-24 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "INSTALA LA XIX DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO NORTE, FIJANDO SU SEDE Y TERRITORIO JURISDICCIONAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-02-24", "doble_articulado": false, "id_norma": "1059938", "numero_fuente": "40797", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-03-03", "vigencias": [{"desde": "2014-03-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia