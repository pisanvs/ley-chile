{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 10.819 EXENTA, DE 2005 </div></div>", "i": 6563728}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 10.819, de 30 de diciembre de 2005, se ha complementado la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 14.081, de 2001, del Colegio Tabancura, comuna de Vitacura, de Santiago, en el sentido de agregar Subsectores en la Formaci&#xF3;n Diferenciada para 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores de Seminario de Textos II, Introducci&#xF3;n al Periodismo II, Biolog&#xED;a Experimental II e Historia de las Revoluciones, para 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media. </div></div>", "i": 6563729}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de marzo de 2006.- Xavier Vanni Cucurella, Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6563730}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10819", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-10819"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 10.819 EXENTA, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-30", "doble_articulado": false, "id_norma": "247930", "numero_fuente": "38412", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-13", "vigencias": [{"desde": "2006-03-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-03-13", "fin_vigencia": ""}, "vigencias_version_norma":