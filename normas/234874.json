{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6513850}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 3.597, de 20 de diciembre de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PEDRO SEGUNDO MONARDEZ ALFARO para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Barraza, comuna de Punitaqui, provincia de Limar&#xED;, IV Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco Enfriado, Fresco Refrigerado, Congelado, Seco Salado, Ahumado, Alga Seca y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6513851}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de diciembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6513852}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3597 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3597 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-20", "doble_articulado": false, "id_norma": "234874", "numero_fuente": "38065", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-01-20", "vigencias": [{"desde": "2005-01-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-01-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-01-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen