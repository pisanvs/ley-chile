{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCIONES N&#xBA; 753 Y N&#xBA; 754 EXENTAS, DE 2012</div></div>", "i": 9259138}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.361, de 17 de mayo de 2012, de esta Subsecretar&#xED;a, modif&#xED;canse las resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=1038441&amp;idParte=0&amp;idVersion=\">N&#xBA; 753</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1038442&amp;idParte=0&amp;idVersion=\">N&#xBA; 754</a>, ambas de 2012, de esta Subsecretar&#xED;a de Pesca, en el sentido de excluir a los buzos, recolectores de orilla, algueros o buzos apnea y de armadores artesanales y sus embarcaciones, indicados en resoluci&#xF3;n extractada.</div><br></div>", "i": 9259139, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de mayo de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9259140}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1361 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1361 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCIONES Nº 753 Y Nº 754 EXENTAS, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-17", "doble_articulado": false, "id_norma": "1040335", "numero_fuente": "40269", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-05-24", "vigencias": [{"desde": "2012-05-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-05-24",