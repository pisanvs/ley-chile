{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 133.- Santiago, a 15 de Diciembre de 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br><br><br></div>", "i": 5946880}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese al &#xED;tem 3 de la partida 35 del presupuesto de Guerra un suplemento de quince mil pesos para pensiones que se decreten en el a&#xF1;o, con arreglo a las leyes de 22 de Diciembre de 1881, de 7 Setiembre i 21 de Diciembre de 1888 i 9 de Enero de 1892.</div><br><br></div>", "i": 5946881}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Juan Antonio Orrego.</div><br></div>", "i": 5946882}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "133", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-133"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "Suplemento", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1893", "MODIFICACION MINISTERIO", "GUERRA", "PENSIONES", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-12-15", "doble_articulado": false, "id_norma": "21996", "numero_fuente": "4695", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-12-16", "vigencias": [{"desde": "1893-12-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-12-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic