{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7304910}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.369, de 8 de octubre de 2003, de esta Subsecretar&#xED;a, modif&#xED;canse el numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA; 855 de 1989, y numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 268 de 2000, ambas de esta Subsecretar&#xED;a, que autorizaron a PESQUERA EL GOLFO S.A. para realizar actividades pesqueras extractivas con la nave &quot;Pelikan&quot;, en el sentido de actualizar e incorporar, seg&#xFA;n corresponda, las siguientes caracter&#xED;sticas n&#xE1;uticas de &#xE9;sta:</div><br><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 42,19 m.</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp; 421,75 m3</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 9,54 m.</div><br></div>", "i": 7304911}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de octubre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7304912}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2369 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2369 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-08", "doble_articulado": false, "id_norma": "216445", "numero_fuente": "37698", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-10-30", "vigencias": [{"desde": "2003-10-30", "hasta": "