{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9327585}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP Exento N&#xBA;3239 de 27 de diciembre de 2012, de conformidad a lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;3-A, superficie 58 m2, rol de Aval&#xFA;o N&#xBA;1481-176, comuna de San Carlos, para la obra &quot;REPOSICI&#xD3;N PTE. VERQUICO, RUTA N-200-M, SN. CARLOS &#x2013; POCILLAS, SN. CARLOS&quot;, VIII Regi&#xF3;n. La Comisi&#xF3;n de peritos, integrada por ROXANA CECILIA ABARZ&#xDA;A GAJARDO, VALESKA CAROLINA AL&#xC9; GO&#xD1;I Y MAR&#xCD;A ALEJANDRA GUTI&#xC9;RREZ FLORES, fij&#xF3; el valor de tasaci&#xF3;n con fecha 6 de julio de 2012, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario don SERGIO DE JES&#xDA;S HARN&#xC1;NDEZ SANHUEZA, en la cantidad de $184.570.-, suma que se pagar&#xE1; al contado. </div></div>", "i": 9327586}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9327587}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3239 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-3239 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-12-27", "doble_articulado": false, "id_norma": "1048102", "numero_fuente": "40459", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-01-15", "vigencias": [{"desde": "2013-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013