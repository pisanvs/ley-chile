{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7351042}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA; 356, de fecha 29 de junio del 2007, se expropi&#xF3; el lote de terreno N&#xBA;11, superficie 5.158 m&#xB2;, Rol 144-36, comuna de Huasco, III Regi&#xF3;n, para la obra &quot;Construcci&#xF3;n Camino Costero, Tramo Huasco - Carrizal, Provincia de Huasco, Regi&#xF3;n de Atacama, Etapa II&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Antonella Anastasia Giglio von Mayenberger y Otros, ascendente a la cantidad de $434.976.</div><br></div>", "i": 7351043}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 7351044}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "356 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-356 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-29", "doble_articulado": false, "id_norma": "263867", "numero_fuente": "38839", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-08-16", "vigencias": [{"desde": "2007-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "GMG", "fecha_ingreso": "2007-08-16", "fecha_version": "2007-08-16", "fecha_actualizacion_texto": "2007-08-16", "tipo_tratad