{"html": [{"t": "<div><div class=\"p\">RECTIFICA DECRETO ALCALDICIO No. 102 DE 1990</div><br><br></div>", "i": 8683515}, {"t": "<div><div class=\"p\">Decreto No. 349 del 04.04.90 Rectif&#xED;case el Decreto Alcaldicio No. 102 de fecha 26 de Enero de 1990, que aprueba &quot;Ordenanza sobre Derechos Municipales por Permisos, Concesiones y Servicios Municipales&quot;, para la comuna de Villa Alemana, seg&#xFA;n se indica a continuaci&#xF3;n:</div><div class=\"p\">En el No. 9 del T&#xED;tulo IV; Derechos Girados por el Departamento de Aseo, Ornato e Inspecci&#xF3;n General. Dice: &quot;9&#xB0; Bodegaje de Veh&#xED;culos Municipales, Diario 5%&quot; Debiendo decir: 9&#xB0; Bodegaje de Veh&#xED;culos en sitios municipales, diario... 5%.</div><br></div>", "i": 8683516}, {"t": "<div><div class=\"p\">An&#xF3;tese, comun&#xED;quese, publ&#xED;quese en el Diario Oficial de la Rep&#xFA;blica y Arch&#xED;bese.- Ra&#xFA;l Bustamante Bertoglio, Alcalde.- Jos&#xE9; Luis Toledo Villagra, Secretario Municipal. </div></div>", "i": 8683517}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "349", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-349"}], "organismos": ["MUNICIPALIDAD DE VILLA ALEMANA"], "titulo_norma": "RECTIFICA DECRETO ALCALDICIO No. 102 DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-04-04", "doble_articulado": false, "id_norma": "89908", "numero_fuente": "33650", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-04-20", "vigencias": [{"desde": "1990-04-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-04-20", "fin_vigencia": ""}, "vi