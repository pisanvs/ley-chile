{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6070630}, {"t": "<div><div class=\"p\">Por Decreto MOP No. 263, de 24 de septiembre de 1992, se expropiaron los lotes de terreno No. s. 4, 4-A y 8, superficies 22.383 m2, 23.926 m2. y 7.579 m2., roles de aval&#xFA;o 9050-30 para los lotes 4 y 4-A y s/rol, Comuna de Melipilla, para la obra Autopista Santiago - San Antonio, sector Puangue - Leyda y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Gabriel Lira Larra&#xED;n y Graciela Fern&#xE1;ndez Orellana, ascendente a las cantidades de $ 7.987.500.-, $ 9.454.857.- y $ 5.910.750.-, respectivamente. </div></div>", "i": 6070631}, {"t": "<div><div class=\"p\"> Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 6070632}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "263", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-263"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-09-24", "doble_articulado": false, "id_norma": "85544", "numero_fuente": "34405", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-11-02", "vigencias": [{"desde": "1992-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1998-01-19", "fecha_version": "1992-11-02", "fecha_actualizacion_texto": "1992-11-02", "tipo_tr