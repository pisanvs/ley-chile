{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede abono de tiempo de servicios a don Carlos Morgan.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado el al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 9042230}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, para los efectos de su jubilaci&#xF3;n, a don Carlos Morgan Quintana, un abono de nueve meses (9), y la mitad del tiempo que sirvi&#xF3; a contrata como ingeniero de la Armada. </div></div>", "i": 9042231}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta y uno de Diciembre de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Carlos O. Frodden.</div><br></div>", "i": 9042232}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4756", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4756"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "CONCEDE ABONO DE TIEMPO DE SERVICIOS A DON CARLOS MORGAN.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CARLOS MORGAN QUINTANA", "TIEMPO SERVIDO", "ABONO", "CONCESION", "JUBILACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-12-31", "doble_articulado": false, "id_norma": "24889", "numero_fuente": "15577", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-01-22", "vigencias": [{"desde": "1929-01-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-01-22", "fin_vigencia": ""}, "v