{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 2.255 EXENTO, DE 2005 </div></div>", "i": 7328478}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 2.255, de 30 de diciembre de 2005, se ha modificado el decreto exento de Educaci&#xF3;n N&#xBA; 393, de 1997 y sus modificaciones, que aprob&#xF3; planes y programas de estudio biling&#xFC;e para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica al Colegio &quot;Andr&#xE9;e English School&quot;, de la comuna de La Reina, de Santiago. Adem&#xE1;s, se aprueba programa de estudio para el Subsector de Tecnolog&#xED;a de la Informaci&#xF3;n del Sector de Tecnolog&#xED;a para los cursos de 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica. </div></div>", "i": 7328479}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de marzo de 2006.- Pedro Montt Leiva, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7328480}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2255 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2255 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 2.255 EXENTO, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-30", "doble_articulado": false, "id_norma": "248142", "numero_fuente": "38415", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-16", "vigencias": [{"desde": "2006-03-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-03-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-03-16", "fin_vi