{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6589441}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 759, de fecha 31 de agosto de 2006, se expropi&#xF3; el lote de terreno N&#xBA; 108, superficie 3.713 m2. Rol N&#xBA; 259-125 comuna de Carahue, IX Regi&#xF3;n, para la obra &quot;Camino Reposici&#xF3;n Ruta S-40, Sector Nueva Imperial Carahue, tramo Km. 0,00000 al Km 21,58295, correspondiente al subtramo III Km. 12,86300 al Km.</div><div class=\"p\">21,58295&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Isabel Clorinda Caniulaf Toro y otros, ascendente a la cantidad de $3.697.705 para el lote N&#xBA; 108.</div><br></div>", "i": 6589442}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6589443}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "759", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-759"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-08-31", "doble_articulado": false, "id_norma": "255203", "numero_fuente": "38614", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-11-15", "vigencias": [{"desde": "2006-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2006-11-15", "fecha_version": "2006