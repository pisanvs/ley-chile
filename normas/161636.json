{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6252821}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto N&#xBA; 119, de 25 de Abril de 1985, se expropi&#xF3; el lote N&#xBA; 2, sitio N&#xBA; 2, manzana 12, cuya superficie es 1.194 m2., rol de aval&#xFA;o 902-2, comuna de Coyhaique, XI Regi&#xF3;n, para calle rodaje en Aeropuerto Balmaceda y se acord&#xF3; el precio de indemnizaci&#xF3;n con su propietaria Filomena Mascare&#xF1;o Cifuentes y otros, ascendente a la cantidad de $ 2.127.675.-</div><br></div>", "i": 6252822}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6252823}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "119", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-119"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-04-25", "doble_articulado": false, "id_norma": "161636", "numero_fuente": "32185", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-01", "vigencias": [{"desde": "1985-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2000-03-20", "fecha_version": "1985-06-01", "fecha_actualizacion_texto": "1985-06-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6252821}, {"n": "Artíc