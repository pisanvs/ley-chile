{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297703}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 1.544, de 16 de Agosto de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por SALMONES AUCAR</div><div class=\"p\">LTDA. para un centro de cultivo ubicado en Punta</div><div class=\"p\">Quechuco, Sector Guardiamo, Comuna de Quemchi, Provincia</div><div class=\"p\">de Chilo&#xE9;, X Regi&#xF3;n, conforme lo dispuesto en los</div><div class=\"p\">art&#xED;culos 78&#xB0; y 87&#xB0; de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8297704}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 16 de Agosto de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297705}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1544", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1544"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "SALMONES AUCAR LTDA", "QUEMCHI", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-08-16", "doble_articulado": false, "id_norma": "37144", "numero_fuente": "35549", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-08-23", "vigencias": [{"desde": "1996-08-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-08-23", "fin_vi