{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA EL ARTICULO DE LA LEY N&#xB0; 9,102 Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8279478}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Reempl&#xE1;zase en el art&#xED;culo 1&#xB0; de la ley N&#xB0; 9,102 la frase &quot;ocho por ciento (8 %) anual&quot; por esta otra:</div><div class=\"p\">&nbsp; &nbsp; &quot;diez por ciento (10 %) anual&quot;.</div><br><br></div>", "i": 8279479}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, seis de Marzo de mil novecientos cincuenta y cuatro.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Santiago Wilson. </div></div>", "i": 8279480}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11509", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11509"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA EL ARTICULO DE LA LEY N° 9,102", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "LEY 9.102", "LEY 6956", "INTERES", "PRESTAMO", "CREDITO", "EMPRESTITO", "MUNICIPALIDAD PUERTO PORVENIR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1954-03-06", "doble_articulado": false, "id_norma": "26686", "numero_fuente": "22802", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1954-03-19", "vigencias": [{"desde": "1954-03-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1954-03-19", "fin_vigencia": ""