{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 4.676 EXENTA, DE 26 DE OCTUBRE DE 2022</div></div>", "i": 10381928}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.676, de 26 de octubre de 2022, de la Subsecretar&#xED;a de Transportes, se autoriza al siguiente taller para adecuar veh&#xED;culos al uso de gas licuado de petr&#xF3;leo (GLP), como combustible:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/156637.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.- </div><div class=\"p\">&nbsp; </div></div>", "i": 10381929}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Denisse Alejandra Ram&#xED;rez Parra, Subsecretaria de Transportes (S).</div><div class=\"p\"> </div><br></div>", "i": 10381930}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4676 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4676 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 4.676 EXENTA, DE 26 DE OCTUBRE DE 2022", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2222068", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-10-26", "doble_articulado": false, "id_norma": "1184819", "numero_fuente": "43410", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-11-25", "vigencias": [{"desde": "2022-11-25", "hasta": "", "tipo_vers