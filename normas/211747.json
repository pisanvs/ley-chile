{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6428956}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.187 de 6 de junio de 2003 de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA LANDES S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Bonito&quot;, en las &#xE1;reas mar&#xED;timas que en cada caso se indican, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar los siguientes recursos hidrobiol&#xF3;gicos: a) Entre la V a X Regiones, con cerco: Cojinoba del sur; b) En la X Regi&#xF3;n, con cerco: Bonito.</div><br></div>", "i": 6428957}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de junio de 2003.- Edith Saa Collantes, Subsecretaria de Pesca (S).</div><br></div>", "i": 6428958}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1187", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1187"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-06-06", "fecha_derogacion": "2004-12-02", "doble_articulado": false, "id_norma": "211747", "numero_fuente": "37596", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-06-30", "vigencias": [{"desde": "2004-12-02", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-06-30", "hasta": "2004-12-01", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2004-12-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-06-30