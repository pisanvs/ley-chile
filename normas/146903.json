{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6202549}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 201 de 7 de Abril de 1987, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del Bfo Bio, se autoriza al se&#xF1;or Carlos Fuentes Mu&#xF1;oz, para efectuar todo tipo de servicio de locomoci&#xF3;n colectiva por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6202550}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco Navarro Ruiz, Secretario Regional Ministerial Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br><br></div>", "i": 6202551}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "201 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-201 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-04-07", "doble_articulado": false, "id_norma": "146903", "numero_fuente": "32747", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-04-14", "vigencias": [{"desde": "1987-04-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-04-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-04-14", "fin_vigencia": "", "tipo_version": "3"}], "even