{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA A DERIS S.A. PARA REALIZAR ACTIVIDADES EXTRACTIVAS EN ALTA MAR</div><div class=\"p\">&nbsp; &nbsp; </div></div>", "i": 9654731}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta n&#xFA;mero 3.139 , de 19 de noviembre de 2015, de esta subsecretar&#xED;a, autoriza a Deris S.A., para realizar actividades extractivas en alta mar, con la nave f&#xE1;brica &quot;Puerto Ballena&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp;  CB-2043</div><div class=\"p\">&nbsp; &nbsp;  Puerto de Matr&#xED;cula&nbsp; &nbsp; Valpara&#xED;so</div><div class=\"p\">&nbsp; &nbsp;  Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2512</div><div class=\"p\">&nbsp; &nbsp;  Eslora de arqueo&nbsp; &nbsp; &nbsp;  49,65 m.</div><div class=\"p\">&nbsp; &nbsp;  T.R.G. (Internacional) 753.</div><div class=\"p\">&nbsp; &nbsp;  Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 9,50 m</div><div class=\"p\">&nbsp; &nbsp;  Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  6,50 m</div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 9654732}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de noviembre de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 9654733}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3139 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3139 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "AUTORIZA A DERIS S.A. PARA REALIZAR ACTIVIDADES EXTRACTIVAS EN ALTA MAR", "fuente": "Diario Oficial", "