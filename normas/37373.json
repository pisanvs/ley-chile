{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8298123}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.741, de 28 de Noviembre de 1995,</div><div class=\"p\">de esta Subsecretar&#xED;a de Pesca del Ministerio de</div><div class=\"p\">Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el</div><div class=\"p\">numeral 2&#xB0; de la Resoluci&#xF3;n N&#xB0; 493, de 1992, de esta</div><div class=\"p\">Subsecretar&#xED;a, por la cual se autoriz&#xF3; a PESQUERA</div><div class=\"p\">COLOMBA S.A., R.U.T. N&#xB0; 93.530.830-K, para operar una</div><div class=\"p\">nave en construcci&#xF3;n, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 3&#xB0; transitorio incisos 3&#xB0; y 4&#xB0; de la Ley General de Pesca y Acuicultura, en el sentido de se&#xF1;alar sus actuales caracter&#xED;sticas n&#xE1;uticas.</div><div class=\"p\">&nbsp; &nbsp; D&#xE9;janse sin efecto las Resoluciones 494, de 1992 y 736, de 1994, ambas de esta Subsecretar&#xED;a, en virtud de lo dispuesto en la presente Resoluci&#xF3;n.</div><br></div>", "i": 8298124}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 28 de Noviembre de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8298125}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1741", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1741"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "AUTORIZACION", "PESQUERA COLOMBA S.A.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1995-11-28", "fecha_der