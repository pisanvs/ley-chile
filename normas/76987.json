{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8307494}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.333, de 14 de octubre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, apru&#xE9;base la solicitud presentada por&nbsp;  CARDENIO ANGULO AROS y SOCIEDAD CULTIVOS ACUATICOS MANANTIALES S.A., para transferir la autorizaci&#xF3;n de acuicultura otorgada por Resoluciones N&#xBA; 194, de 1988 y N&#xBA; 1.921, de 1995, ambas de esta Subsecretar&#xED;a, a Cardenio Angulo Aros, ubicada en el Puerto Nuevo, comuna de La Uni&#xF3;n, provincia de Valdivia, a la Sociedad Cultivos Acu&#xE1;ticos Manantiales S.A. Esta transferencia deber&#xE1; efectuarse conforme a las normas legales y reglamentarias vigentes.</div><br></div>", "i": 8307495}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de octubre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8307496}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1333", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1333"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "CARDENIO ANGULO AROS", "SOCIEDAD CULTIVOS ACUATICOS MANANTIALES S.A.", "LA UNION", "SOCIEDAD CULTIVOS ACUATICOS MANANTIALES S.A.", "TRANSFERENCIA", "CONCESION DE ACUICULTURA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-10-14", "doble_articulado": false, "id_norma": "76987", "numero_fuente": "35915", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion":