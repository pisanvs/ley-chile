{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6295681}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.591, de 19 de julio de 2000, de esta Subsecretar&#xED;a, ot&#xF3;rgase a SOCIEDAD COMERCIAL AGRICOLA Y FORESTAL NALCAHUE LTDA. una ampliaci&#xF3;n de plazo para iniciar las actividades programadas para el primer a&#xF1;o de vigencia del proyecto t&#xE9;cnico y cronograma de actividades aprobado por resoluci&#xF3;n N&#xBA; 730, de 1998, de esta Subsecretar&#xED;a, para instalar y operar una piscicultura en la localidad de Chesque Alto, comuna de Villarrica, provincia de Caut&#xED;n, IX Regi&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  En virtud de la ampliaci&#xF3;n de plazo otorgada, la peticionaria deber&#xE1; iniciar sus actividades en la piscicultura se&#xF1;alada antes del 12 de agosto de 2000. </div></div>", "i": 6295682}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de julio de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6295683}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1591", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1591"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-07-19", "doble_articulado": false, "id_norma": "174004", "numero_fuente": "36735", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-09", "vigencias": [{"desde": "2000-08-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci