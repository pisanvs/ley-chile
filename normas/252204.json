{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br><br></div>", "i": 6579253}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.693, de 27 de julio de 2006, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme D.L. N&#xBA; 2.186 de 1978, del Lote N&#xBA; 130, correspondiente al inmueble ubicado en San Juan, sitio 130, Manzana 5, Sector C, Rol de aval&#xFA;o N&#xBA; 4033-130, comuna de Quinta Normal, aparente dominio de don Ernesto Medina Vald&#xE9;s. Comisi&#xF3;n integrada por peritos se&#xF1;ores In&#xE9;s Ot&#xE1;rola Castillo, arquitecto; Mario Zamorano Villablanca, arquitecto; y Miguel Fern&#xE1;ndez C&#xE1;diz, constructor civil. Seg&#xFA;n informe de 13 de junio de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $2.388.100, pagadera al contado.</div><br></div>", "i": 6579254}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6579255}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3693 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3693 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES DE INMUEBLES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-27", "doble_articulado": false, "id_norma": "252204", "numero_fuente": "38540", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-08-16", "vigencias": [{"desde": "2006-08-16", "hasta": "", "tipo_version": "