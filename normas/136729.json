{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6169658}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;694, de 29 de marzo de 1999, se expropiaron los lotes de terreno N&#xBA;s. 4 y 10, superficies 10.145 y 8.551 m2 respectivamente, roles de aval&#xFA;o 516-52 y 511-47, comuna de Carahue, para la Obra Camino&nbsp; Costero Tir&#xFA;a-Carahue, Sector Puyanhue Tranapuente y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Arturo Alessandri Castro Antivil o Arturo Alessandri Castro Antiville y otros e Irma Ulloa Burgos, ascendente a las cantidades de $2.412.636.- para el lote 4 y $652.052.- para el lote 10.-</div><br></div>", "i": 6169659}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6169660}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "694", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-694"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-03-29", "doble_articulado": false, "id_norma": "136729", "numero_fuente": "36364", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-05-15", "vigencias": [{"desde": "1999-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-05-18", "fecha_version": "1999-05-15", "fecha