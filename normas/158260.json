{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 64, DE 1986 </div></div>", "i": 6241339}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 64, de 18 de abril de 1986, se han aprobado programas especiales de estudio para la asignatura de Alem&#xE1;n, que se aplicar&#xE1;n a contar del a&#xF1;o lectivo 1986 simult&#xE1;neamente en todos los cursos de Educaci&#xF3;n General B&#xE1;sica y Educaci&#xF3;n Media, de los colegios alemanes que se se&#xF1;alan.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se deroga el decreto supremo de Educaci&#xF3;n No. 222 de 1976.</div><br></div>", "i": 6241340}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de Abril de 1986.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6241341}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "64 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-64 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 64, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-04-18", "doble_articulado": false, "id_norma": "158260", "numero_fuente": "32472", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-05-16", "vigencias": [{"desde": "1986-05-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-05-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-05-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"te