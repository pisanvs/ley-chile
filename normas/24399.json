{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 4,007, que permite la residencia de los cuerpos del Ej&#xE9;rcito</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 4,007.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br><br><br></div>", "i": 5957694}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Perm&#xED;tese, por el t&#xE9;rmino de un a&#xF1;o, la residencia de los cuerpos del Ej&#xE9;rcito permanente en el lugar de las sesiones del Congreso Nacional y diez leguas a su circunferencia. Esta lei empezar&#xE1; a rejir desde la fecha de su publicacion en el Diario Oficial.</div><br></div>", "i": 5957695}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 19 de febrero de 1924.-Arturo Alessandri.- L. Brieba A.</div><br></div>", "i": 5957696}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4007", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4007"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "LEI NUM. 4,007, QUE PERMITE LA RESIDENCIA DE LOS CUERPOS DEL EJERCITO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EJERCITO CHILE", "CONGRESO NACIONAL", "RESIDENCIA", "SESIONES", "FIJACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1924-02-19", "doble_articulado": false, "id_norma": "24399", "numero_fuente": "13806", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1924-02