{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 13, DE 1989 </div></div>", "i": 7228848}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 13 de 25 de enero de 1989 se ha aprobado al Colegio &quot;La Dehesa&quot; de Santiago, un plan especial de estudio para ser aplicado a partir de 1989 de 1&#xB0; a 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica.</div><div class=\"p\">Adem&#xE1;s, se aprueban programas para las asignaturas que se indican, de los Planes Electivos, del Area Tecnol&#xF3;gica, para 3&#xB0; y 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica.- </div></div>", "i": 7228849}, {"t": "<div><div class=\"p\">Adelchi Colombo Breschi, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante.</div><br></div>", "i": 7228850}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "13 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-13 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 13, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-01-25", "doble_articulado": false, "id_norma": "94604", "numero_fuente": "33322", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-03-14", "vigencias": [{"desde": "1989-03-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-03-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-03-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes":