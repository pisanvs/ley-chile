{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA EN LA FORMA QUE INDICA EL ARTICULO N&#xB0; 28 DE LA LEY QUE CREO LA CAJA DE LA HABITACION</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5967837}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Reempl&#xE1;zase en el art&#xED;culo 28 de la ley N&#xB0; 7,600, que cre&#xF3; la Caja de la Habitaci&#xF3;n, la cifra $ 100.000, por la frase &quot;cuarenta sueldos vitales de la provincia de Santiago&quot;.</div><br></div>", "i": 5967838}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintid&#xF3;s de Marzo de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Alejandro Serani B.</div><br></div>", "i": 5967839}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10313", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10313"}], "organismos": ["MINISTERIO DEL TRABAJO"], "titulo_norma": "MODIFICA EN LA FORMA QUE INDICA EL ARTICULO N° 28 DE\nLA LEY QUE CREO LA CAJA DE LA HABITACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAJA HABITACION", "PRESTAMOS", "OTORGAMIENTO", "DISPOSICIONES", "MODIFICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-03-22", "doble_articulado": false, "id_norma": "26337", "numero_fuente": "22221", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-04-07", "vigencias": [{"desde": "1952-04-07", "hasta": "", "tipo_vers