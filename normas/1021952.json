{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9098310}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.819, de 20 de diciembre de 2010, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 5 Bis.- de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1015833&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.849 de 2010</a>, de esta Subsecretar&#xED;a, que autoriz&#xF3; a CONSULTORES PESQUEROS MARACTIVO LTDA., para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Caracterizaci&#xF3;n de zonas de pesca artesanal de los recursos Sardina com&#xFA;n (Strangomera bentincki) y Anchoveta (Engraulis ringens) en las costas de la Novena Regi&#xF3;n, 2010&quot;, en el sentido de autorizar que la cuota asignada a la embarcaci&#xF3;n &quot;R&#xED;o Tolt&#xE9;n I&quot; pueda ser capturada por la embarcaci&#xF3;n &quot;R&#xED;o Queule I&quot;.</div></div>", "i": 9098311}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de diciembre de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9098312}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3819 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3819 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-20", "doble_articulado": false, "id_norma": "1021952", "numero_fuente": "39856", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publica