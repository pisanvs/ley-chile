{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO NUMERO&nbsp; 236, DE 1997 </div></div>", "i": 6037244}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Supremo de Educaci&#xF3;n N&#xBA; 236, del 27 de marzo de 1997, se aprueba Convenio de fecha veinte de septiembre de 1996, celebrado entre el Ministerio de Educaci&#xF3;n y la Ilustre Municipalidad de Tocopilla que modifica el Convenio de Traspaso a la Ilustre Municipalidad de Tocopilla por Convenio aprobado por Decreto Supremo de Educaci&#xF3;n N&#xBA; 5500 de 19 de agosto de 1981.</div><br></div>", "i": 6037245}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de mayo de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6037246}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "236", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-236"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO NUMERO 236, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MINISTERIO DE EDUCACION", "MUNICIPALIDAD DE TOCOPILLA", "CONVENIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-27", "doble_articulado": false, "id_norma": "71510", "numero_fuente": "35771", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-22", "vigencias": [{"desde": "1997-05-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-05-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_ingreso": "1997-05-30", "fecha_version