{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295147}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 994, de 22 de mayo de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por SOCIEDAD</div><div class=\"p\">AGRICOLA AGUAS BLANCAS LIMITADA, R.U.T. N&#xB0; 79.755.440-5,</div><div class=\"p\">para un sector ubicado en la localidad de Malloco,</div><div class=\"p\">Comuna de Pe&#xF1;aflor, Provincia de Santiago, por no dar</div><div class=\"p\">cumplimiento el respectivo proyecto t&#xE9;cnico a los</div><div class=\"p\">art&#xED;culos N&#xB0; 78&#xB0; y N&#xB0; 87&#xB0;, de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8295148}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 22 de mayo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295149}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "994", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-994"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "SOCIEDAD AGRICOLA AGUAS BLANCAS LIMITADA", "PE AFLOR", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-22", "doble_articulado": false, "id_norma": "35992", "numero_fuente": "35478", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-05-29", "vigencias": [{"desde": "1996-05-29", "