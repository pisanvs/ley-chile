{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9243339}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 2.549, de 30 de septiembre de 2011, de esta Subsecretar&#xED;a, autor&#xED;zase a CLAUDIA GUILLERMINA GODOY REYES para capturar, en el sector de Isla Magdalena XII Regi&#xF3;n de Magallanes y la Ant&#xE1;rtica Chilena, a partir de la publicaci&#xF3;n de la presente resoluci&#xF3;n, ejemplares de la especie Ping&#xFC;ino de Magallanes (Spheniscus magellanicus), en la forma y condiciones se&#xF1;aladas en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  La solicitante ser&#xE1; la persona responsable de esta autorizaci&#xF3;n.</div></div>", "i": 9243340}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de septiembre de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9243341}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2549", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2549"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-09-30", "doble_articulado": false, "id_norma": "1038197", "numero_fuente": "40218", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-03-21", "vigencias": [{"desde": "2012-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-03-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-03-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes"