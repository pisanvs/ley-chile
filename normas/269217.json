{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7363839}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 323, de 1 de febrero de 2008, de esta Subsecretar&#xED;a, autor&#xED;zase a ANTARCTIC SEA FISHERIES S.A. para continuar desarrollando actividades pesqueras en alta mar con la nave &quot;Antarctic Bay&quot;, autorizada mediante resoluci&#xF3;n N&#xBA; 1.757, de 2007, de esta Subsecretar&#xED;a, en virtud de la escritura p&#xFA;blica de cambio de raz&#xF3;n social y dem&#xE1;s disposiciones legales citadas en visto de la resoluci&#xF3;n extractada.</div><div class=\"p\">D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2.910, de 2007, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 7363840}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de febrero de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7363841}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "323 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-323 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-02-01", "doble_articulado": false, "id_norma": "269217", "numero_fuente": "38983", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-02-09", "vigencias": [{"desde": "2008-02-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-02-09", "fin_vigencia": ""}, "vigencias_version_norma