{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 10, DE 1980 </div></div>", "i": 6072256}, {"t": "<div><br><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 10 de 12 de enero de 1990 se ha modificado, a contar del a&#xF1;o 1990, el decreto supremo exento de Educaci&#xF3;n No. 296, de 1981, que aprob&#xF3; plan y programas especiales de estudio al Instituto Comercial Alem&#xE1;n de Santiago, en el sentido de sustituir el Plan Electivo por el que se indica en el presente decreto. </div></div>", "i": 6072257}, {"t": "<div><div class=\"p\">Santiago, 23 de Enero de 1990.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6072258}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "10 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-10 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 10, DE 1980", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-12", "doble_articulado": false, "id_norma": "86107", "numero_fuente": "33596", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-14", "vigencias": [{"desde": "1990-02-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1998-01-22", "fecha_version": "1990-02-14", "fecha_actualizacion_texto"