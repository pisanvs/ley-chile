{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8300606}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 45, de 16 de enero de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xBA; 36 de 1991, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA OCEANICA LIMITADA, para realizar actividades pesqueras extractivas con la nave &quot;Don Nelson&quot;, matr&#xED;cula 1995, en el litoral de la III y IV regiones, en virtud de lo se&#xF1;alado en la letra b) del art&#xED;culo 143 del D.S. N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8300607}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de enero de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8300608}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "45", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-45"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA OCEANICA LIMITADA", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-01-16", "doble_articulado": false, "id_norma": "60367", "numero_fuente": "35674", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-01-24", "vigencias": [{"desde": "1997-01-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-01-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia"