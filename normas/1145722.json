{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10123893}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 55 del 20 de mayo de 2020, que regula inscripci&#xF3;n en el r&#xE9;gimen de tributaci&#xF3;n simplificada establecido en el art&#xED;culo 35 A del nuevo p&#xE1;rrafo 7&#xBA; bis de la Ley sobre Impuesto a las Ventas y Servicios. Sustituye obligaciones dispuestas en el <a href=\"https://www.leychile.cl/Navegar?idNorma=6369&amp;idParte=8675457&amp;idVersion=\">art&#xED;culo 51 </a>de la <a href=\"https://www.leychile.cl/Navegar?idNorma=6369&amp;idParte=&amp;idVersion=\">Ley sobre Impuesto a las Ventas y Servicios</a> y en el p&#xE1;rrafo 2&#xBA; del t&#xED;tulo IV del libro primero del C&#xF3;digo Tributario.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento, est&#xE1; publicado en &quot;www.sii.cl&quot;.</div><br></div>", "i": 10123894}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "55 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-55 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1765289; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-05-20", "doble_articulado": false, "id_norma": "1145722", "numero_fuente": "42665", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-05-27", "vigencias": [{"desde": "2020-05-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_v