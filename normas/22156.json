{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AMNISTIA lei n&#xFA;m. 305.- Santiago, a 17 de Setiembre de 1895.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947466}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese amnist&#xED;a por los delitos que estando sometidos, segun la lei, al conocimiento de los jueces i tribunales militares hubiesen sido cometidos durante la &#xFA;ltima guerra contra el Per&#xFA; i Bolivia.</div><br></div>", "i": 5947467}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Ismael Valdes Valdes.</div><br></div>", "i": 5947468}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "305", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-305"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "AMNISTIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PERU", "BOLIVIA", "GUERRA", "AMNISTIA", "DELITOS", "TRIBUNALES", "MILITARES", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-09-17", "doble_articulado": false, "id_norma": "22156", "numero_fuente": "5214", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-09-17", "vigencias": [{"desde": "1895-09-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-09-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1895-09-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacio