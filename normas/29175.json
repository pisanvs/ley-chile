{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DEROGA EL ARTICULO 4 DE LA LEY N&#xB0; 17.292 Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5982421}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Der&#xF3;gase el art&#xED;culo 4 de la ley N&#xB0; 17.292.&quot;.</div><br></div>", "i": 5982422, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, once de Abril de mil novecientos setenta y dos.- SALVADOR ALLENDE GOSSENS.- Presidente de la Rep&#xFA;blica.- Humberto Martones M., Ministro de Tierras y Colonizaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda atentamente a Ud.- Lautaro Ojeda Herrera, Subsecretario de Tierras y Colonizaci&#xF3;n.</div><br></div>", "i": 5982423}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "17639", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-17639"}], "organismos": ["MINISTERIO DE TIERRAS Y COLONIZACIÓN"], "titulo_norma": "DEROGA EL ARTICULO 4 DE LA LEY N° 17.292", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DEROGACION PARCIAL", "LEY 17292", "ASOCIACION REMO", "RIO MAULE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1972-04-11", "doble_articulado": false, "id_norma": "29175", "numero_fuente": "28234", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1972-04-25", "vigencias": [{"desde": "1972-04-25", "hasta": "", "tipo_version": "3", "t