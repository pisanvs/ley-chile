{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 8.450 EXENTA, DE 2008 </div></div>", "i": 7382643}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xB0; 8.450, de 27 de noviembre de 2008, se han complementado las resoluciones exentas de Educaci&#xF3;n Nos 4.104 y 12.870, ambas de 1999, 5.925 de 2001 y 3.390 de 2002, que aprobaron planes y programas especiales de estudio de 1&#xB0; a 4&#xB0; a&#xF1;o de Ense&#xF1;anza Media, al Colegio Calasanz, comuna de &#xD1;u&#xF1;oa, de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio del Subsector Cultura Religiosa, &#xC9;tica y Moral para todos los cursos de Ense&#xF1;anza Media.</div><br></div>", "i": 7382644}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de diciembre de 2008.- Jaime Veas S&#xE1;nchez, Jefe Divisi&#xF3;n de Educaci&#xF3;n General (S). </div></div>", "i": 7382645}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8450 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8450 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 8.450 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-11-27", "doble_articulado": false, "id_norma": "283993", "numero_fuente": "39246", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-12-26", "vigencias": [{"desde": "2008-12-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-12-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-12-