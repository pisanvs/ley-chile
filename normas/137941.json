{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,827.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6173653}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Autor&#xED;zase la inversion de cuatrocientos cuarenta mil pesos ($ 440,000), en los trabajos de terminacion del edificio de los Tribunales de Justicia de Santiago.</div><br></div>", "i": 6173654}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a tres de diciembre de mil novecientos trece.- Ramon Barros Luco.- Enrique Za&#xF1;artu P. </div></div>", "i": 6173655}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2827", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2827"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1913-12-03", "doble_articulado": false, "id_norma": "137941", "numero_fuente": "10744", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1913-12-09", "vigencias": [{"desde": "1913-12-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1913-12-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1913-12-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1