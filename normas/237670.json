{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6524441}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.183 de 25 de abril de 2005 de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 2.019 de 2001, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a BUENA PESCA S.A. para ampliar actividades pesqueras con la nave &quot;Nicomar&quot; entre el l&#xED;mite norte de la I Regi&#xF3;n y el paralelo 47&#xBA; L.S., sobre el recurso Bacalao de profundidad, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura. </div></div>", "i": 6524442}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de abril de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6524443}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1183 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1183 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-04-25", "doble_articulado": false, "id_norma": "237670", "numero_fuente": "38153", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-05-05", "vigencias": [{"desde": "2005-05-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-05-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-05-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text":