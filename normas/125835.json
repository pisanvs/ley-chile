{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 945 EXENTO, DE 1998</div><br><br><br><br></div>", "i": 6134788}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 945 de 30 de septiembre de 1998, se ha aprobado, a contar de la fecha en vigencia del presente decreto, un plan especial de estudio para alumnos con d&#xE9;ficit auditivo, que podr&#xE1; ser aplicado por la Escuela Particular N&#xBA; 148 &apos;&apos;La Pur&#xED;sima&apos;&apos;, de la comuna de San Miguel, provincia de Santiago, Regi&#xF3;n Metropolitana.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio correspondientes a los &#xE1;mbitos y &#xE1;reas de desarrollo del plan que se ajustar&#xE1;n a los objetivos, contenidos, procedimientos y actitudes u objetivos transversales. </div></div>", "i": 6134789}, {"t": "<div><div class=\"p\">Santiago, 8 de octubre de 1998.</div><br><div class=\"p\">&nbsp; &nbsp;  - Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6134790}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "945 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-945 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 945 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "ESCUELA PARTICULAR N 148 LA PURISIMA", "SAN MIGUEL", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-09-30", "doble_articulado": false, "id_norma": "125835", "numero_fuente": "36186", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-10-13", "vi