{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7210927}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 732, de 31 de julio de 1997, se expropiaron los lotes de terreno N&#xBA;s. 8 y 30, superficies 122 y 1.798 M2., roles de aval&#xFA;os 802-9 y 814-62, comuna de Traigu&#xE9;n, obra Camino Pavimentaci&#xF3;n Asf&#xE1;ltica, sector Camino Traigu&#xE9;n-Galvarino y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Jos&#xE9; Poblete Estuardo y Carlos Cort&#xE9;s S&#xE1;nchez, ascendente a las cantidades de $230.151 y $1.884.865.</div><br></div>", "i": 7210928}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 7210929}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "732", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-732"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "TRAIGUEN", "NOVENA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-31", "doble_articulado": false, "id_norma": "75966", "numero_fuente": "35867", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-09-15", "vigencias": [{"desde": "1997-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "CAV", "fecha_ingreso": "1997-10-08", "fec