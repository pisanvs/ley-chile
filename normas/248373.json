{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 30, DE 2006 </div></div>", "i": 6565176}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 30, de 16 de marzo de 2006, el suscrito ha delegado en los funcionarios de su dependencia de la Direcci&#xF3;n Regional en Temuco, y las Unidades de Angol, Victoria y Villarrica, las funciones en materias referentes a la ley N&#xBA; 17.235, sobre Impuesto Territorial, descritas en la resoluci&#xF3;n Ex. N&#xBA; 21 de 01-03-2006 de la Direcci&#xF3;n Nacional publicada en la p&#xE1;gina web oficial del SII: www.sii.cl.</div><br></div>", "i": 6565177}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Ren&#xE9; Cornejo C&#xE1;ceres, Director Regional. </div></div>", "i": 6565178}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "30", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-30"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 30, DE 2006", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-03-16", "doble_articulado": false, "id_norma": "248373", "numero_fuente": "38422", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-24", "vigencias": [{"desde": "2006-03-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-03-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-03-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresad