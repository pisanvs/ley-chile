{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 406 EXENTO, DE 2000 </div></div>", "i": 6388001}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 406 de fecha 29 de septiembre de 2000 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; al Instituto Profesional Instituto Nacional del F&#xFA;tbol la carrera de Entrenador de F&#xFA;tbol, conducente al t&#xED;tulo profesional de Entrenador de F&#xFA;tbol, para ser impartida a contar del a&#xF1;o 2001 en jornada vespertina, en su Sede de la ciudad de Santiago, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6388002}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de octubre de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6388003}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "406 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-406 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 406 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-29", "doble_articulado": false, "id_norma": "200164", "numero_fuente": "37303", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-09", "vigencias": [{"desde": "2002-07-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-07-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_po