{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUA EN COMUNA DE COPIAPO </div></div>", "i": 7338514}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n</div><div class=\"p\">exenta N&#xBA; 1.137 del 13 de marzo de 2007, conforme</div><div class=\"p\">art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, complement&#xF3; resoluci&#xF3;n exenta N&#xBA; 1.907, de 9 de septiembre de 1987, que aprob&#xF3; distribuci&#xF3;n de derechos de aprovechamiento de aguas del Proyecto de Parcelaci&#xF3;n &quot;Piedra Colgada&quot;, de la comuna de Copiap&#xF3;, provincia de Copiap&#xF3;, III Regi&#xF3;n, en el sentido de establecer que los derechos de aprovechamiento de aguas subterr&#xE1;neas que se extraen de los pozos profundos identificados como Pozo coordenadas 27&#xB0;10&apos; - 70&#xB0;20&apos; Sectores C-9, D-3 y D-5, son de car&#xE1;cter consuntivo, de ejercicio permanente y continuo.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13 ley N&#xBA; 18.377.</div><br></div>", "i": 7338515}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Nacional.</div><br></div>", "i": 7338516}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1137 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1137 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUA EN COMUNA DE COPIAPO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHOS DE APROVECHAMIENTO DE AGUAS", "COPIAPO", "TERCERA REGION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-03-13", "doble_articulado": false,