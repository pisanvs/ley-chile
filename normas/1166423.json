{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10276107}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xB0; 1.047 de 29 septiembre 2021, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos que indica en condiciones que se&#xF1;ala, relativas Exposici&#xF3;n Emprendedoras Ays&#xE9;n, y autoriz&#xF3; a Direcci&#xF3;n de Aseo, Ornato y Medio Ambiente de la I. Municipalidad de Ays&#xE9;n para realizar siguiente intervenci&#xF3;n en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - Corte total de calle Esmeralda, entre calles Bernardo O&apos;Higgins y Arturo Prat, entre las 00:00 horas del d&#xED;a domingo 3 de octubre y las 17:00 horas del d&#xED;a lunes 4 de octubre de 2021.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10276108}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andrea Mac&#xED;as Palma, Gobernadora Regional, Gobierno Regional de Ays&#xE9;n.- Ximena Guti&#xE9;rrez Jaramillo, Asesora Jur&#xED;dica, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10276109}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1047 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1047 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2024055", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-09-29", "doble_articulado": false, "id_norma": "1166423", "numero_fuente": "43077", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-1