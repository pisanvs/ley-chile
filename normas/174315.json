{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6296846}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 2.143 de fecha 29 de mayo de 2000, se expropi&#xF3; los lotes de terreno N&#xBA;s. 1, 2, 3, 4 y 5, superficies 5.450, 3.510, 1.603, 1.843 y 1.440 m&#xB2; respectivamente, roles de aval&#xFA;o 104-9 y 104-10, comuna de Corral, para la obra &apos;&apos;Camino Longitudinal Costero Sur Sector Corral - Chaihuin, Tramo El Morro - Chaihuin, Km. 8,880 al Km. 10,000&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Marta Trivi&#xF1;o Vera, Lidia Grimilda Espa&#xF1;a Espa&#xF1;a y Mari&#xF3;n Oslavelia Fr&#xE1;nqez Fr&#xE1;nquez y otra y Mari&#xF3;n Oslavelia Fr&#xE1;nqez Fr&#xE1;nquez y otros, ascendente a las cantidades de $1.086.008.- para el lote 1, $1.029.985.- para lotes 2 y 3 y $725.766.- para los lotes 4 y 5.</div><br></div>", "i": 6296847}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6296848}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2143", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2143"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-29", "doble_articulado": false, "id_norma": "174315", "numero_fuente": "36740", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-16", "vigencias": [{"desde": "2000-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-16", "fin_vigencia": ""}, "vigencias_version