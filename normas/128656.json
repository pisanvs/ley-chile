{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8337767}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.656, de 24 de noviembre de 1998, de esta Subsecretar&#xED;a, autor&#xED;zase a ABELARDO SANTANDER VERGARA para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Caleta Los Verdes (Ruta A-1), Iquique, I Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Precocido, congelado y fresco-refrigerado: Almeja o taca, almeja y erizo.</div><br></div>", "i": 8337768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de noviembre de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8337769}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1656", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1656"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-24", "doble_articulado": false, "id_norma": "128656", "numero_fuente": "36246", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-12-23", "vigencias": [{"desde": "1998-12-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-12-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-12-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1998-12-23", "fecha_version": "1998