{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6356245}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n Ministerial N&#xBA; 87, del 5 de octubre del a&#xF1;o 2001, se autoriz&#xF3; la existencia y aprob&#xF3; el estatuto de la Cooperativa de Ahorro y Cr&#xE9;dito Uni&#xF3;n Familiar Limitada, de la ciudad de Santiago, en los t&#xE9;rminos que da testimonio el acta constitutiva protocolizada con fecha 4 de septiembre del 2001, al final de los Registros del bimestre septiembre/octubre del mismo a&#xF1;o, del Notario de Santiago, don El&#xED;as Jarufe Rojas, bajo el N&#xBA; 1. </div></div>", "i": 6356246}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas.</div><br></div>", "i": 6356247}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "87", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-87"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-10-05", "doble_articulado": false, "id_norma": "191368", "numero_fuente": "37106", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-09", "vigencias": [{"desde": "2001-11-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-11-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-11-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci