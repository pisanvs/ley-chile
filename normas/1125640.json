{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Declaracion a favor de don Tomas Garmendia</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, i Marzo 23 de 1819.</div></div>", "i": 9973611}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se declara que don Tomas Garmendia ha desvanecido plenamente las sospechas que dieron m&#xE9;rito a mand&#xE1;rsele comparecer ante esta Supremac&#xED;a a que se sincerase de ellas. La injenua esposicion que hace en este memorial de sus nobles sentimientos patri&#xF3;ticos, lo califican de buen ciudadano americano. Ins&#xE9;rtese lo actuado en la Gaceta Ministerial para su satisfaccion, d&#xE1;ndosele testimonio de esta providencia para su resguardo.-</div></div>", "i": 9973612}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  O&apos;Higgins.- Echeverr&#xED;a.</div></div>", "i": 9973613}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Declaracion a favor de don Tomas Garmendia", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1819-03-23", "doble_articulado": false, "id_norma": "1125640", "numero_fuente": "1819", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1819-03-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1819-03-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1819-03-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "504", "fecha_ingreso": "2018-12-04", "fecha_version": "181