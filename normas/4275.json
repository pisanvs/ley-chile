{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 47.- Santiago, 6 de Marzo de 1931.- En uso de las facultades que me confiere la ley n&#xFA;mero 4,945, de 6 de Febrero del presente a&#xF1;o,</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 7116282}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Modif&#xED;case el inciso 2.o del art&#xED;culo 2.o de la ley n&#xFA;mero 4,557, de 29 de Enero de 1929, en la siguiente forma:</div><div class=\"p\">&nbsp; &nbsp; &quot;El Instituto Bacteriol&#xF3;gico de Chile depender&#xE1; del Ministerio de Bienestar Social&quot;.</div><br></div>", "i": 7116283}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- C. IBA&#xD1;EZ C.- Alberto Edwards.- Carlos Castro Ruiz. </div></div>", "i": 7116284}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "47", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-47"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO BACTERIOLOGICO CHILE", "DEPENDENCIA", "MINISTERIO", "BIENESTAR SOCIAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-03-16", "doble_articulado": false, "id_norma": "4275", "numero_fuente": "15932", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-03-25", "vigencias": [{"desde": "1931-03-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1931-03-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1931-03-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pend