{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5904292}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto MOP. N&#xB0;264, de 31 de Agosto de 1993, se expropiaron los lotes de terreno N&#xB0;s. 4, 13 y 17, superficies 1.635 m2., 1.229 m2., y 4.999 m2., roles de aval&#xFA;o 1216-169, 1216-29 y 1216-35, comuna de Teodoro Schmidt, para la obra Camino Freire-Tolt&#xE9;n por Hualp&#xED;n, sector Hualp&#xED;n-Puente Peule y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Cecilio Penchulef Cheuqueo y Jos&#xE9; Holzapfel Az&#xF3;car, ascendente a las cantidades de $ 202.561.- para el lote N&#xB0; 4 y $ 618.984.- para los lotes N&#xB0;s. 13 y 17.-</div><br></div>", "i": 5904293}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 5904294}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "264", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-264"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DECRETO EXPROPIATORIO", "EXPROPIACION", "BIEN RAIZ", "BIEN INMUEBLE", "TEODORO SCHMIDT", "NOVENA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-08-31", "doble_articulado": false, "id_norma": "11696", "numero_fuente": "34680-2", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-10-01", "vigencias": [{"desde": "1993-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-10-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac