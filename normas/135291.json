{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,645.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6164948}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se declaran de utilidad p&#xFA;blica los terrenos que, segun los planos formados al efecto i aprobados por el Presidente de la Rep&#xFA;blica, sean necesarios para la construccion de los ferrocarriles de Melipilla a Puangue i de Alcones al t&#xFA;nel del Arbol, inclusive. </div></div>", "i": 6164949}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a 19 de febrero de 1904.- JERMAN RIESCO.- Manuel Espinosa Jara.</div><br></div>", "i": 6164950}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1645", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1645"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-02-19", "doble_articulado": false, "id_norma": "135291", "numero_fuente": "7834", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1904-02-22", "vigencias": [{"desde": "1904-02-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1904-02-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1904-02-22", "fin_vigencia": "", "tipo_version": "3"}], "event