{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 2.907 EXENTA, DE 2015, DEL MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 9647302}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.907, de 6 de octubre de 2015, se modific&#xF3; la <a href=\"https://www.leychile.cl/Navegar?idNorma=1077920&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.219, de 2015</a>, que estableci&#xF3; condiciones espec&#xED;ficas de operaci&#xF3;n y utilizaci&#xF3;n de v&#xED;as para servicios de transporte p&#xFA;blico de pasajeros que se presten al interior de la zonas F (Unidad de negocio N&#xBA; 7), del Sistema de Transporte P&#xFA;blico de Santiago. Texto &#xED;ntegro de la resoluci&#xF3;n exenta N&#xBA; 2.907, de 2015, se encuentra en la p&#xE1;gina web www.dtpm.cl.</div><br><br></div>", "i": 9647303}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Andr&#xE9;s G&#xF3;mez-Lobo Echenique, Ministro de Transportes y Telecomunicaciones.</div></div>", "i": 9647304}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2907 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-2907 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 2.907 EXENTA, DE 2015, DEL MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; IdDO 962365"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-10-06", "doble_articulado": false, "id_norma": "1083595", "numero_fuente": "41299", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "201