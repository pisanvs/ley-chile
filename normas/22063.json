{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SUPLEMENTO Lei n&#xFA;m 205.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947145}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese un suplemento de sesenta mil ciento sesenta i seis pesos sesenta i seis centavos al &#xED;tem 1.&#xB0; de la partida 5.a del presupuesto del Ministerio de Relaciones Exteriores.</div><br><br></div>", "i": 5947146}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto en todas sus partes como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 6 de Setiembre de 1894.-JORGE MONTT.-M.S&#xE1;nchez Fontecilla.</div><br></div>", "i": 5947147}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "205", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-205"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1894", "MODIFICACION MINISTERIO", "RELACIONES EXTERIORES", "SUPLEMENTO.-"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-09-06", "doble_articulado": false, "id_norma": "22063", "numero_fuente": "4915", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-09-13", "vigencias": [{"desde": "1894-09-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-09-13", "fin_vigencia": ""}, "vigencias_ver