{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6180273}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.525, de 10 de junio de 1999, se modific&#xF3; el decreto MOP N&#xBA;526, de 31 de octubre de 1994, que expropi&#xF3; entre otros el lote de terreno N&#xBA;105, para la obra Camino Lo Orozco Quilpu&#xE9;, que figura a nombre de Julio Aris Navarro, rol de aval&#xFA;o 3455-7, Comuna de Quilpu&#xE9;, V Regi&#xF3;n, orden&#xE1;ndose la consignaci&#xF3;n judicial del valor provisional de la indemnizaci&#xF3;n ascendente a la cantidad de $91.250, por haber quedado sin efecto el convenio directo de precio suscrito con el expropiado. La indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA;2.186, de 1978.-</div><br></div>", "i": 6180274}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6180275}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1525", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1525"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-06-10", "doble_articulado": false, "id_norma": "139959", "numero_fuente": "36428", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-08-02", "vigencias": [{"desde": "1999-08-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-08-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1