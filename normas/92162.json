{"html": [{"t": "<div><div class=\"p\">DERECHOS DE APROVECHAMIENTO DE AGUAS EN LA COMUNA DE COIHUECO </div></div>", "i": 6090798}, {"t": "<div><div class=\"p\">Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta N 1.487 de 01 de Septiembre de 1989, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a la Reserva del predio &quot;La Palma&quot;, ubicado en la comuna de Coihueco, VIII Regi&#xF3;n.</div><div class=\"p\">Los derechos de agua se extraen de R&#xED;o Chill&#xE1;n por el Canal La Palma.</div><div class=\"p\">Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377. </div></div>", "i": 6090799}, {"t": "<div><div class=\"p\">Director Nacional (S).</div><br></div>", "i": 6090800}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1487 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1487 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DERECHOS DE APROVECHAMIENTO DE AGUAS EN LA COMUNA DE\nCOIHUECO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-09-01", "doble_articulado": false, "id_norma": "92162", "numero_fuente": "33497", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-10-16", "vigencias": [{"desde": "1989-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-10-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-10-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMZ", "