{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACIONES QUE INDICA </div></div>", "i": 6191226}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;102, de 10 de agosto de 1999, Serviu V Regi&#xF3;n Valpara&#xED;so, dispuso expropiaci&#xF3;n parcial, conforme art&#xED;culo 87 ley 8.946 y decreto ley 2.186, de 1978, de inmueble ubicado Avenida Cementerio, rol aval&#xFA;o 30-127, comuna Casablanca, de dominio Sociedad de Transportes Santa Luc&#xED;a Limitada. Comisi&#xF3;n tasadora integrada por Sres. Osvaldo Mu&#xF1;oz Quintana (arquitecto), Alvaro Verdejo Vidal (ingeniero constructor), y Pablo Caria Giurici (contructor civil), seg&#xFA;n informe fecha 28 julio 1999, fij&#xF3; monto provisional indemnizaci&#xF3;n en $9.041.756.-, que ser&#xE1; pagada de contado.-</div><br></div>", "i": 6191227}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alberto Ram&#xED;rez Urz&#xFA;a, Director Serviu V Regi&#xF3;n. </div></div>", "i": 6191228}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "102", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-102"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAISO"], "titulo_norma": "ORDENA EXPROPIACIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-08-10", "doble_articulado": false, "id_norma": "143410", "numero_fuente": "36465", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-15", "vigencias": [{"desde": "1999-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-15", "fin_vigencia": ""}, "vigencias_ver