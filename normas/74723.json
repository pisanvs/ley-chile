{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8305153}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.034, de 17 de julio de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 1 de la Resoluci&#xF3;n N&#xBA; 1.214 de 1988, de esta Subsecretar&#xED;a, que fij&#xF3; las caracter&#xED;sticas n&#xE1;uticas de la nave &quot;Roble&quot;, Matr&#xED;cula 2273, de SOCIEDAD PESQUERA COLOSO S.A., en el sentido de se&#xF1;alar que la capacidad de bodega de dicha nave es de 369,6 m3.</div><br></div>", "i": 8305154}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de julio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8305155}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1034", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1034"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "SOCIEDAD PESQUERA COLOSO S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-07-17", "fecha_derogacion": "2000-02-01", "doble_articulado": false, "id_norma": "74723", "numero_fuente": "35836", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-08-07", "vigencias": [{"desde": "2000-02-01", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1997-08-07", "hasta": "2000-01-31", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2000-02-01", "fin_vigencia": ""}, "vige