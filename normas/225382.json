{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 6.748 EXENTA, DE 2004 </div></div>", "i": 6479835}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 6.748 de 7 de mayo de 2004, se ha aprobado al &quot;Liceo Industrial Remehue&quot; de Osorno, dependiente del Instituto de Educaci&#xF3;n Rural, un plan especial de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media T&#xE9;cnico-Profesional en las Especialidades de Edificaci&#xF3;n y Acuicultura, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2004.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 6479836}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de mayo de 2004.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6479837}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6748 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-6748 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 6.748 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-07", "doble_articulado": false, "id_norma": "225382", "numero_fuente": "37864", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-05-19", "vigencias": [{"desde": "2004-05-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-05-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-05-19", "fin_vige