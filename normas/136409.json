{"html": [{"t": "<div><div class=\"p\">&nbsp;  Lei n&#xFA;m. 2,131.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6168739}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se concede, por gracia, a do&#xF1;a Francisca Mart&#xED;nez viuda de Vald&#xE9;s, hija del capitan de la Independencia don Pedro Mart&#xED;nez, la pensi&#xF3;n de cuarenta i cinco pesos ($ 45) mensuales que la lei de 14 de setiembre de 1900 asigna a la hija de un capitan.</div><br></div>", "i": 6168740}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, cinco de setiembre de mil novecientos ocho.- Pedro Montt.- An&#xED;bal Rodr&#xED;guez H.</div><br></div>", "i": 6168741}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2131", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2131"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1908-09-05", "doble_articulado": false, "id_norma": "136409", "numero_fuente": "9192", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1908-09-22", "vigencias": [{"desde": "1908-09-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1908-09-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1908-09-22", "fin_vigencia": "", "tipo_version": "3"}], 