{"html": [{"t": "<div><div class=\"p\">CADUCA RESOLUCION N&#xB0; 258, DE 1981 </div></div>", "i": 8350578}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 81, de 26 de Enero de 1987, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se declara la caducidad de la Resoluci&#xF3;n N&#xB0; 258, de 1981, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a don Jos&#xE9; Adalio Tacul Nitor, c&#xE9;dula de identidad N&#xB0; 6.235.202-7, domiciliado en Curanu&#xE9;, Quell&#xF3;n, para instalar y operar un cultivo de Chorito Quilmahue, Mytilus chilensis, en la localidad de Estero Huildad, Comuna de Quell&#xF3;n, Chilo&#xE9;, X Regi&#xF3;n, en atenci&#xF3;n a lo dispuesto en el art&#xED;culo 7&#xB0;, del Decreto de Econom&#xED;a N&#xB0; 175, de 1980. </div></div>", "i": 8350579}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de Enero de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8350580}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "81", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-81"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "CADUCA RESOLUCION N° 258, DE 1981", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-01-26", "doble_articulado": false, "id_norma": "144040", "numero_fuente": "32687", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-02-02", "vigencias": [{"desde": "1987-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-02-02"