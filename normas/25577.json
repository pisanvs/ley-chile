{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DISPONE QUE LA COMUNA DE PURRANQUE FORMARA PARTE DEL DEPARTAMENTO DE RIO NEGRO</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8278348}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1&#xB0;.- La comuna de Purranque formar&#xE1; parte del departamento de R&#xED;o Negro.</div><br></div>", "i": 8278349}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2&#xB0;.- Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 8278350}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintinueve de Julio de mil novecientos cuarenta y tres.- JUAN ANTONIO RIOS M.- J. Allard. </div></div>", "i": 8278351}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "7458", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-7458"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DISPONE QUE LA COMUNA DE PURRANQUE FORMARA PARTE DEL\nDEPARTAMENTO DE RIO NEGRO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMUNA", "PURRANQUE", "DEPARTAMENTO RIO NEGRO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1943-07-29", "doble_articulado": false, "id_norma": "25577", "numero_fuente": "19636", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1943-08-18", "vigencias": [{"desde": "1943-08-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "v