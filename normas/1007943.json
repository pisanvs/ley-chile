{"html": [{"t": "<div><br><div class=\"p\">COMPLEMENTA RESOLUCI&#xD3;N N&#xBA; 109 EXENTA, DE 2005</div></div>", "i": 8798971}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 165 del 06 de noviembre de 2009 que establece:</div><div class=\"p\">&nbsp; &nbsp;  Lo dispuesto en la <a href=\"https://www.leychile.cl/Navegar?idNorma=243334&amp;idParte=0&amp;idVersion=\">Resol. Ex. SII N&#xBA; 109, de 2005</a>, se aplicar&#xE1; tambi&#xE9;n a la modalidad de prepago como medio de acceso a servicios de informaci&#xF3;n y/o comunicaci&#xF3;n de datos.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de noviembre de 2009.</div></div>", "i": 8798972}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "165 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-165 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SUBSECRETARÍA DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2009-11-06", "fecha_derogacion": "2012-11-13", "doble_articulado": false, "id_norma": "1007943", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2009-11-12", "vigencias": [{"desde": "2012-11-13", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2009-11-12", "hasta": "2012-11-12", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vig