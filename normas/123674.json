{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8333950}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.129, de 5 de agosto de 1998, de esta Subsecretar&#xED;a, autor&#xED;zase a LUIS ORLANDO RETAMALES CARDENAS, para ampliar actividades pesqueras autorizadas por resoluciones N&#xBA; 566, de 1992 y N&#xBA; 199, de 1993, ambas de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Camino al Tepual Km. 5, comuna de Puerto Montt, provincia de Llanquihue, X Regi&#xF3;n, en la elaboraci&#xF3;n de conservas, los siguientes recursos hidrobiol&#xF3;gicos: Congelado: Loco, Pulpo, Cojinoba del norte y Cojinoba del sur; Salado: Pepino de mar. </div></div>", "i": 8333951}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de agosto de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8333952}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1129", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1129"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "LUIS ORLANDO RETAMALES CARDENAS", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-08-05", "fecha_derogacion": "1999-03-25", "doble_articulado": false, "id_norma": "123674", "numero_fuente": "36155", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-09-02", "vigencias": [{"desde": "1999-03-25", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-09-02", "hasta": "1999-03-24", "tipo_version": "0", "tipo_version_s