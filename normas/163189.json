{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6257649}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. N&#xB0; 464, de fecha 31 de Diciembre de 1984, se expropiaron los lotes de terrenos N&#xB0;s. 1 y 2, cuyas superficies son 12.222 m2. y 11.778 m2., roles de aval&#xFA;o 7263 y 72-64, comuna de Ch&#xE9;pica, VI Regi&#xF3;n, para Alcantarillado de Ch&#xE9;pica, Laguna de Estabilizaci&#xF3;n, y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios don Jos&#xE9; M. Rebolledo Henr&#xED;quez y don Alfonso Morales Devia, ascendentes a $ 705.014 para el lote 1 y $ 671.346 para el lote 2.-</div><br></div>", "i": 6257650}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6257651}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "464", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-464"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-12-31", "doble_articulado": false, "id_norma": "163189", "numero_fuente": "32086", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-02-01", "vigencias": [{"desde": "1985-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMZ", "fecha_ingreso": "2000-03-30", "fecha_version": "1985-02-01", "fecha_actualizacion_texto": "1985-