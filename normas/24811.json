{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Modifica el art&#xED;culo 1.o de la ley n&#xFA;mero 4,634, de 13 de Agosto &#xFA;ltimo</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5960382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Reempl&#xE1;zase el inciso segundo del art&#xED;culo 1.o de la ley 4,634, de fecha 13 de Agosto de 1929, por el siguiente:</div><div class=\"p\">&nbsp; &nbsp; &quot;El gasto se deducir&#xE1; del &#xED;tem 06 a, cap&#xED;tulo 15, partida 06, del Presupuesto de Hacienda vigente&quot;. </div></div>", "i": 5960383}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veinticuatro de Septiembre de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Rodolfo Jaramillo B.</div><br></div>", "i": 5960384}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4658", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4658"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA EL ARTICULO 1.o DE LA LEY NUMERO  4,634, DE 13 DE AGOSTO ULTIMO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VICTOR BARROS BORGO O", "PENSION POR GRACIA", "FINANCIAMIENTO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-09-24", "doble_articulado": false, "id_norma": "24811", "numero_fuente": "15481", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-09-25", "vigencias": [{"desde": "1929-09-25", "ha