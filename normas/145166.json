{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7254531}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto de Registro No. 108 del 11.08.87 se ha modificado el Decreto de Registro No. 089 en el siguiente sentido:</div><div class=\"p\">a) Se&#xF1;alar que la propiedad expropiada tiene el Rol de Aval&#xFA;os No. 2006-5.</div><div class=\"p\">b) Se cambia la imputaci&#xF3;n presupuestaria por la siguiente: &quot;Subt&#xED;tulo 31 Item 62 Asignaci&#xF3;n 048, Denominaci&#xF3;n &quot;Construcci&#xF3;n, Pavimentaci&#xF3;n y Prolongaci&#xF3;n Avda. Grecia Calama del Presupuesto vigente.- </div></div>", "i": 7254532}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Alcalde.</div><br></div>", "i": 7254533}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "108", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-108"}], "organismos": ["MUNICIPALIDAD DE CALAMA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-11", "doble_articulado": false, "id_norma": "145166", "numero_fuente": "32871", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-15", "vigencias": [{"desde": "1987-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "MEM", "fecha_ingreso": "1999-10-11", "fecha_version": "1987-09-15", "fecha_actualizacion_texto": "1987-09-15", "tipo_tratado": "