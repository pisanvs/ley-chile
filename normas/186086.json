{"html": [{"t": "<div><div class=\"p\">FIJA NUEVO HORARIO DE ATENCION EN JUNTAS INSCRIPTORAS</div><br><br></div>", "i": 6337375}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n O-N&#xBA; 356, de fecha 31 de mayo de 2001, se ha dispuesto que las Juntas Inscriptoras de todo el pa&#xED;s funcionen a contar del d&#xED;a martes 3 de julio de 2001, en horario de 9:00 a 13:00 horas.</div><div class=\"p\">&nbsp; &nbsp;  Sin embargo, si al t&#xE9;rmino del horario de funcionamiento se encontraren a&#xFA;n presentes personas que requieran su inscripci&#xF3;n, se extender&#xE1; el funcionamiento pero no m&#xE1;s all&#xE1; de las 20:00 horas, salvo el d&#xED;a s&#xE1;bado en que no exceder&#xE1; de las 14:00 horas.</div><br></div>", "i": 6337376}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de mayo de 2001.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director Servicio Electoral.</div><br></div>", "i": 6337377}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "356", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-356"}, {"tipo": "3", "numero": "O-356", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-356"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "FIJA NUEVO HORARIO DE ATENCION EN JUNTAS INSCRIPTORAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUNTAS INSCRIPTORAS", "HORARIO DE ATENCION", "FUNCIONAMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-31", "doble_articulado": false, "id_norma": "186086", "numero_fuente": "36978", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-06-04", "vigencias": [{"desde": "2001-06-04", "hasta": "", "tipo_version": "3", "tipo_versio