{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pension de Montepio, se eleva Lei n&#xFA;m. 949.- Santiago, a 9 de Setiembre de 1897.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7162763}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. El&#xE9;vase, por gracia, a ciento cincuenta pesos mensuales la pension de montepio militar de que actualmente disfruta do&#xF1;a Juana Bunster viuda del vice-almirante de la Armada Nacional, don Santiago Jorje Bynon.</div><br><br></div>", "i": 7162764}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C&#xE1;rlos A. Palacios Z.</div><br></div>", "i": 7162765}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "949", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-949"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "PENSION DE MONTEPIO, SE ELEVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUANA BUNSTER", "MONTEPIO MILITAR", "AUMENTA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-09-09", "doble_articulado": false, "id_norma": "22295", "numero_fuente": "5800", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1897-09-09", "vigencias": [{"desde": "1897-09-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1897-09-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1897-09-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente