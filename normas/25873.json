{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AUTORIZA EL TRASPASO DE FONDOS EN EL ITEM QUE INDICA Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5966028}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Trasp&#xE1;sase la cantidad de cincuenta mil pesos ($ 50.000) del &#xED;tem 15/02/01 a la partida 15/02/04 f-1/a) del Presupuesto vigente.</div><div class=\"p\">&nbsp; &nbsp; Esta ley regir&#xE1; desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 5966029}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veinticuatro de Diciembre de mil novecientos cuarenta y siete.- GABRIEL GONZALEZ VIDELA.-</div><div class=\"p\">Dr. Jos&#xE9; Santos Salas.</div><br></div>", "i": 5966030}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "8935", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-8935"}], "organismos": ["MINISTERIO DEL TRABAJO"], "titulo_norma": "AUTORIZA EL TRASPASO DE FONDOS EN EL ITEM QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1948", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1947-12-24", "doble_articulado": false, "id_norma": "25873", "numero_fuente": "20944", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1948-01-06", "vigencias": [{"desde": "1948-01-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1948-01-06", "f