{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA CONCESION DE RADIODIFUSION SONORA Santiago, 27 de Febrero de 1991.- Con esta fecha se ha decretado lo que sigue: N&#xFA;m. 60.- Vistos:</div><div class=\"p\"> _______________________________________________________</div><div class=\"p\"> | NOTA: VER DIARIO OFICIAL N&#xB0; 34.963 DE 10 DE&nbsp; &nbsp; &nbsp; &nbsp;  |</div><div class=\"p\"> |&nbsp; &nbsp; &nbsp;  SEPTIEMBRE DE 1994, PAGINAS 8 y 9.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; |</div><div class=\"p\"> |_____________________________________________________|</div><br></div>", "i": 7135263}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, reg&#xED;strese, t&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Por orden del Presidente de la Rep&#xFA;blica.- V&#xED;ctor Germ&#xE1;n Correa D&#xED;az, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Saluda atentamente a Ud., Jorge Rosenblut Ratinoff, Subsecretario de Telecomunicaciones.</div><br></div>", "i": 7135264}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "60", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-60"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "MODIFICA CONCESION DE RADIODIFUSION SONORA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "CONCESION RADIODIFUSION SONORA", "FRECUENCIA MODULADA", "TEMUCO", "NOVENA REGION", "UNIVERSIDAD FRONTERA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-02-27", "doble_articulado": false, "id_norma": "8456", "numero_fuente": "34963", "tipo_version": "3", "tipo_version_s": "Única", "fe