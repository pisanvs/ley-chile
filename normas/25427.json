{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N.o 6,270, SOBRE NORMAS PARA LA JUBILACION DE LOS EMPLEADOS DEL CONGRESO NACIONAL Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8278267}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Reempl&#xE1;zase, en el inciso primero del art&#xED;culo 3.o de la ley n&#xFA;mero 6,270, de 13 de Octubre de 1938, la frase &quot;___y desempe&#xF1;ado &#xE9;ste por un a&#xF1;o&quot;, por esta otra: &quot;___ y desempe&#xF1;ado este cargo inferior por un a&#xF1;o&quot;.</div><br></div>", "i": 8278268, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, trece de Agosto de mil novecientos cuarenta y uno.- PEDRO AGUIRRE CERDA.- Arturo Olavarr&#xED;a B.</div><br></div>", "i": 8278269}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "7009", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-7009"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA LA LEY N.o 6,270, SOBRE NORMAS PARA LA\nJUBILACION DE LOS EMPLEADOS DEL CONGRESO NACIONAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONGRESO NACIONAL", "EMPLEADOS", "JUBILACION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1941-08-13", "doble_articulado": false, "id_norma": "25427", "numero_fuente": "19048", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1941-08-28", "vigencias": [{"desde": "1941-08-28"