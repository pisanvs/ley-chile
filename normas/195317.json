{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6371909}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 372, de 8 de febrero de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a JOSE ADALIO GUINEO NANCUCHEO, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en Ruta 5, Recta Chacao Km. 25, comuna de Ancud, X Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n que se indican los siguientes recursos hidrobiol&#xF3;gicos: Seco-Salado: Pelillo, Luga Luga y Luga roja.</div><br></div>", "i": 6371910}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de febrero de 2002.- Edith Saa Collantes, Subsecretaria de Pesca (S).</div><br></div>", "i": 6371911}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "372", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-372"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-08", "doble_articulado": false, "id_norma": "195317", "numero_fuente": "37205", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-03-08", "vigencias": [{"desde": "2002-03-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-03-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-03-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2002-03-08", "fecha_version": "2002-03-08", "fec