{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7193782}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 8 de 15 de Septiembre de 1993, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n, se adjudic&#xF3; a don Henoch Mainhard Nikolaus, la concesi&#xF3;n para operar, por un plazo de cinco a&#xF1;os a contar de la publicaci&#xF3;n del presente extracto, un establecimiento ubicado en calle General Urrutia N&#xB0; 746, de la Comuna de Villarrica, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de contaminantes de todo tipo de veh&#xED;culos motorizados, sus remolques y semirremolques, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.- </div></div>", "i": 7193783}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Humberto Ivor Fierro Bustos, Secretario Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n.</div><br></div>", "i": 7193784}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION REVISION TECNICA", "PLANTA REVISION TECNICA", "HENOCH MAINHARD NIKOLAUS", "VEHICULOS MOTORIZADOS", "NOVENA REGION", "VILLARRICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-09-15", "doble_articulado": false, "id_norma": "31978", "numero_fuente": "34717", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-11-16", "vigencias": [{"desde": "1993-11-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"