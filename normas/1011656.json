{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8891889}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 967, de 26 de febrero de 2010, de esta Subsecretar&#xED;a, modif&#xED;quese el numeral 3&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1010248&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 61, de 2010, de esta Subsecretar&#xED;a de Pesca</a>, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto FIP N&#xBA; 2009-04 denominado &quot;Evaluaci&#xF3;n hidroac&#xFA;stica reclutamiento de Anchoveta y Sardina com&#xFA;n entre la V-X Regiones, a&#xF1;o 2010&quot;, en el sentido de se&#xF1;alar que la pesca de investigaci&#xF3;n se extender&#xE1; hasta el 31 de marzo de 2010, inclusive.</div></div>", "i": 8891890}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de febrero de 2010.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8891891}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "967 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-967 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-02-26", "doble_articulado": false, "id_norma": "1011656", "numero_fuente": "39609", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-03-12", "vigencias": [{"desde": "2010-03-12", "hasta": "", "tipo_version": "3", "tipo_versio