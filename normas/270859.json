{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3282/16.04.2008 </div></div>", "i": 7368716}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante la resoluci&#xF3;n N&#xBA; 3.282 de fecha 16 de abril de 2008 de la Direcci&#xF3;n Nacional de Aduanas, se sustituy&#xF3; el texto del Manual de Pagos, puesto en vigencia por resoluci&#xF3;n N&#xBA; 3.256 de 1980. El Manual de Pagos tiene por objeto explicitar, uniformar y refundir en un solo texto todas las instrucciones relativas al pago de grav&#xE1;menes generado por el ingreso de mercanc&#xED;as extranjeras al pa&#xED;s.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de esta resoluci&#xF3;n se encuentra publicado en la p&#xE1;gina web del Servicio Nacional de Aduanas.</div><br></div>", "i": 7368717}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3282", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3282"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3282/16.04.2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DIRECCION NACIONAL DE ADUANAS", "IMPORTACION", "MANUAL DE PAGOS", "GRAVAMENES ADUANEROS", "DERECHOS ADUANEROS", "TEXTO REFUNDIDO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-04-16", "doble_articulado": false, "id_norma": "270859", "numero_fuente": "39052", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-05-03", "vigencias": [{"desde": "2008-05-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-05-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008