{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8306779}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.263 de 25 de septiembre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xBA; 1.412, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA EICOMAR S.A., s&#xF3;lo en lo que se refiere al sector 2, del centro de cultivo ubicado en Isla Guar, comuna de Puerto Montt, X Regi&#xF3;n, por haberse denegado la respectiva solicitud de concesi&#xF3;n de acuicultura, por Resoluci&#xF3;n exenta N&#xBA; 350, de 13 de junio de 1997, de la Subsecretar&#xED;a de Marina. </div></div>", "i": 8306780}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de septiembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8306781}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1263", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1263"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "AUTORIZACION", "PESQUERA EICOMAR S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-09-25", "doble_articulado": false, "id_norma": "76120", "numero_fuente": "35882", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-10-04", "vigencias": [{"desde": "1997-10-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-10-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig