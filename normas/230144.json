{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6496386}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director del Servicio Electoral, certifica que a fojas 02 bajo el n&#xFA;mero 2 del &quot;Registro Especial de Entidades Recaudadoras&quot; que conserva este Servicio, figura inscrita, con fecha 3 de septiembre de 2004, la entidad denominada &quot;Tesorero Nacional Partido Dem&#xF3;crata Cristiano&quot;, formada por el Partido Dem&#xF3;crata Cristiano.</div><div class=\"p\">&nbsp; &nbsp;  Se otorga el presente certificado al Partido Dem&#xF3;crata Cristiano para su publicaci&#xF3;n en el Diario Oficial, en cumplimiento de lo dispuesto en el inciso cuarto del art&#xED;culo 21 de la ley N&#xBA; 19.884. </div></div>", "i": 6496387}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de septiembre de 2004.</div><br></div>", "i": 6496388}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO DEMOCRATA CRISTRIANO", "ENTIDAD RECAUDADORA TESORERO NACIONAL DEL PARTIDO DEMOCRATA CRISTIANO", "INSCRIPCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-09-03", "doble_articulado": false, "id_norma": "230144", "numero_fuente": "37959", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-09-10", "vigencias": [{"desde": "2004-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-09-10", "fin_vigencia": ""}, "vigencias_version_no