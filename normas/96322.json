{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 298 EXENTO, DE 1998 </div></div>", "i": 6102690}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 298 de 20 de enero de 1998, se ha aprobado al Colegio &quot;Maim&#xF3;nides&quot; de la comuna de Providencia, provincia de Santiago, Regi&#xF3;n Metropolitana, un plan de estudio bilig&#xFC;e para los cursos de 1&#xBA; a 4&#xBA; a&#xF1;&#xF3; (NB.1 y NB.2) de Ense&#xF1;anza B&#xE1;sica, el cual se aplicar&#xE1; a partir del a&#xF1;o escolar 1998.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los cursos que se indican, los cuales se impartir&#xE1;n mayoritariamente en idioma ingl&#xE9;s.-</div><br></div>", "i": 6102691}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6102692}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "298 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-298 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 298 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIO MAIMONIDES", "PROVIDENCIA", "REGION METROPOLITANA", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-01-20", "doble_articulado": false, "id_norma": "96322", "numero_fuente": "35990", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-02-13", "vigencias": [{"desde": "1998-02-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-02-13", "fin