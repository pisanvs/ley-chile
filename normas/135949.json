{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6167191}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 82 del 16 de Marzo de 1988 de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la Primera Regi&#xF3;n Tarapac&#xE1;, se autoriza a Lucinda Mercedes Maya Arancibia para efectuar todo tipo de servicio de transportes de pasajeros por calles y caminos dentro del territorio nacional a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6167192}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Eliecer Aedo Rivera, Secretario Regional Ministerial Transportes y Telecomunicaciones I Regi&#xF3;n Tarapac&#xE1;. </div></div>", "i": 6167193}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "82 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-82 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-16", "doble_articulado": false, "id_norma": "135949", "numero_fuente": "33034", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-03-30", "vigencias": [{"desde": "1988-03-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-03-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-03-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac