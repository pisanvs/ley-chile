{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10034357}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA; 391 de 19 de junio de 2019, se dej&#xF3; sin efecto los numerales 3&#xB0;, 4&#xBA;, 5&#xBA; y 6&#xBA;, del <a href=\"https://www.leychile.cl/Navegar?idNorma=1121933&amp;idParte=&amp;idVersion=\">Decreto Exento MOP. 804 de 23 de julio de 2018</a>, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote de terreno N&#xBA; 3, expropiado con motivo de la obra: &quot;Camino Ruta 5 Norte, Tramo Santiago - Los Vilos Sector: Km. 84.540,00 al Km. 86.620,00 Enlace Llay-Llay&quot;, Comuna de Llay-Llay, Regi&#xF3;n de Valpara&#xED;so. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n fijada mediante tasaci&#xF3;n de 21 de agosto de 2017, ascendente a la cantidad $13.839.800.-, para el lote N&#xBA;3.</div></div>", "i": 10034358}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "391 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-391 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1612903", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-06-19", "doble_articulado": false, "id_norma": "1133279", "numero_fuente": "42392", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-07-01", "vigencias": [{"desde": "2019-07-01",