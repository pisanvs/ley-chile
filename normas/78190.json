{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 88 DE 1992</div><br><br><br></div>", "i": 9048926}, {"t": "<div><div class=\"p\">Por Decreto Exento No. 88 de fecha 10 de Abril de 1992 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; el plan y programas de estudio al Centro de Formaci&#xF3;n T&#xE9;cnica Centro de Estudios Navieros Concepci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar del a&#xF1;o 1992, en la ciudad de Concepci&#xF3;n.</div><div class=\"p\">Carrera: Administraci&#xF3;n de Empresas menci&#xF3;n en comercio Exterior.</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico en Administraci&#xF3;n de Empresas menci&#xF3;n en Comercio Exterior.</div><br></div>", "i": 9048927}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "88 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-88 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 88 DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1992-04-10", "fecha_derogacion": "2004-04-13", "doble_articulado": false, "id_norma": "78190", "numero_fuente": "34320", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1992-07-20", "vigencias": [{"desde": "2004-04-13", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1992-07-20", "hasta": "2004-04-12", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2004-04-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-07-20", "fin_v