{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACIONES</div></div>", "i": 9696328}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Res. Ex. N&#xBA; 1.242 de 29/12/15. Exp. N&#xBA;1501854. Vistos: Ley N&#xB0;18.755; Ley N&#xBA;18.575, resoluci&#xF3;n N&#xBA;1.600/2008 de la CGR. Considerando: 1.- ADC N&#xB0;097091, que se&#xF1;ala que al revisar el equipaje, se detecta 0,3 kgs de pl&#xE1;tanos y 0,1 kgs de manzanas, no declaradas. 2.- La infractora se&#xF1;ala que la fruta la tra&#xED;a para colaci&#xF3;n, pero que olvid&#xF3; declarar. 3.- La infractora no registra denuncias anteriores. Resuelvo: Absu&#xE9;lvase por esta &#xFA;nica vez a do&#xF1;a Gaby Sarahi Mart&#xED;nez Torrez, C&#xE9;dula de Identidad N&#xBA;8412807, nacionalidad boliviana, domicilio indeterminado. </div></div>", "i": 9696329}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Firma: C&#xE9;sar Cardozo Rojas, Director Regional Regi&#xF3;n de Tarapac&#xE1; SAG.</div></div>", "i": 9696330}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1242 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-1242 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO REGIÓN DE TARAPACÁ"], "titulo_norma": "NOTIFICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1012765; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-12-29", "doble_articulado": false, "id_norma": "1089438", "numero_fuente": "41433", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-04-15", "vigencias": [{"desde": "2016-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2016-04-15", "fin_vigencia": ""