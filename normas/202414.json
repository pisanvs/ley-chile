{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6395824}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.818, de 27 de agosto de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BAHIA CORONEL S.A., para ampliar las actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluci&#xF3;n N&#xBA; 744 de 2002, de esta Subsecretar&#xED;a, en orden a poder incorporar a la planta ubicada en Pedro Aguirre Cerda N&#xBA; 639, Lo Rojas, Coronel, VIII Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Harina y Aceite: Bacaladillo o mote, Machuelo o tritre, Anchoa blanca, Sardina redonda, Jurel fino, Vinciguerria.</div><br></div>", "i": 6395825}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de agosto de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6395826}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1818", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1818"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-08-27", "doble_articulado": false, "id_norma": "202414", "numero_fuente": "37354", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-09-07", "vigencias": [{"desde": "2002-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-09-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-09-07", "fin_vigencia": "", "tipo_ver