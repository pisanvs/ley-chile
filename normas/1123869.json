{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 4.390 EXENTA, DE 20 DE AGOSTO DE 2018</div></div>", "i": 9954713}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por el presente acto administrativo se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=1073393&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 9.310, de 2014, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Colegio Sagrado Coraz&#xF3;n-Apoquindo, de la comuna de Las Condes, provincia de Santiago, Regi&#xF3;n Metropolitana, en el sentido de sustituir el plan de estudio de 1&#xBA; y 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media, a contar del a&#xF1;o escolar 2019.-</div></div>", "i": 9954714}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Figueroa Salas, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 9954715}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4390 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4390 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 4.390 EXENTA, DE 20 DE AGOSTO DE 2018", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1476563; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-08-20", "doble_articulado": false, "id_norma": "1123869", "numero_fuente": "42179", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-10-12", "vigencias": [{"desde": "2018-10-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2018-10-12", "fin_vige