{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,103.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6177066}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- El&#xE9;vase, por gracia, a la suma de cuatro mil pesos ($ 4,000), la pension que actualmente perciben la viuda e hijos del ex - juez letrado de Osorno, don Abelardo Contreras, de la cual gozar&#xE1;n con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6177067}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y, por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintidos de julio de 1916.- Juan Luis Sanfuentes.- Alberto Romero.</div><br></div>", "i": 6177068}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3103", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3103"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-07-22", "doble_articulado": false, "id_norma": "138951", "numero_fuente": "11533", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-07-27", "vigencias": [{"desde": "1916-07-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1916-07-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1916-07-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingre