{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 209 EXENTA, DE 2008 </div></div>", "i": 7364617}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 209 exenta, de 30 de enero de 2008, se autoriz&#xF3;, de conformidad a lo dispuesto en el N&#xBA; 5 de la resoluci&#xF3;n N&#xBA; 65, de 2000, del Ministerio de Transportes y Telecomunicaciones, al taller que a continuaci&#xF3;n se individualiza, para adecuar veh&#xED;culos al uso de gas natural comprimido como combustible:</div><br><div class=\"p\">Empresa&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Nombre del&nbsp; &nbsp;  Direcci&#xF3;n</div><div class=\"p\">Habilitada&nbsp; &nbsp; &nbsp; &nbsp;  Taller&nbsp; &nbsp; &nbsp;  del Taller&nbsp;  Ciudad</div><br><div class=\"p\">Gritti y&nbsp; &nbsp; &nbsp; &nbsp;  Autogas&nbsp; &nbsp; &nbsp; &nbsp;  Ventus</div><div class=\"p\">Schalchli Ltda.&nbsp; Express Ltda.&nbsp;  N&#xBA; 1261&nbsp;  Concepci&#xF3;n</div><br><div class=\"p\">&nbsp; &nbsp;  La autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.</div><br><br></div>", "i": 7364618}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Elinett Wolff Rioseco, Subsecretaria de Transportes.</div><br></div>", "i": 7364619}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "209 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-209 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 209 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-01-30", "doble_articulad