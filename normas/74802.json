{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 487, DE 1997</div><br><br></div>", "i": 6042946}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto de Educaci&#xF3;n N&#xBA; 487, del 11 de julio de 1997, se aprueba Convenio de fecha treinta de mayo de 1997, celebrado entre el Ministerio de Educaci&#xF3;n P&#xFA;blica y la I. Municipalidad de Molina, que rectifica Convenio de Traspaso de la Escuela B&#xE1;sica E N&#xBA; 291, de Molina, traspasada por Convenio aprobado por Decreto Supremo de Educaci&#xF3;n N&#xBA; 8.516 de 16 de noviembre de 1981. </div></div>", "i": 6042947}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 1 de agosto de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6042948}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "487", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-487"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 487, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONVENIO DE TRASPASO", "MUNICIPALIDAD DE MOLINA", "MINISTERIO DE EDUCACION PUBLICA", "ESCUELA BASICA E N 291", "MOLINA", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-11", "doble_articulado": false, "id_norma": "74802", "numero_fuente": "35838", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-08-09", "vigencias": [{"desde": "1997-08-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-08-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-08-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [