{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO</div></div>", "i": 9961633}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (Exento) N&#xB0; 1345 de 11 de octubre de 2018, se modific&#xF3; el numeral segundo del <a href=\"https://www.leychile.cl/Navegar?idNorma=1095581&amp;idParte=0&amp;idVersion=\">Decreto MOP (Exento) N&#xB0; 719</a> de 8 de septiembre de 2016, que orden&#xF3; la expropiaci&#xF3;n, entre otros, del Lote N&#xB0;123, en la parte que se refiere al nombre del propietario y rol de aval&#xFA;o, seg&#xFA;n certificado de aval&#xFA;o emitido por el Servicio de Impuestos Internos, quedando como a continuaci&#xF3;n se indica: LOTE 123; WEBER FLORES ERWIN RODRIGO Y OTRO, superficie 51 m2., rol de aval&#xFA;o 124-63, Comuna de R&#xCD;O CLARO. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA; 2186, de 1978. </div></div>", "i": 9961634}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1345 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1345 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1487570", "NORMA SIN PROMULGACIÓN", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-10-11", "doble_articulado": false, "id_norma": "1124928", "numero_fuente": "42195", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-11-03", "vigencias": [{"desde": "2018-11-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2018-11-03", "fin_vig