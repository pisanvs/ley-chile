{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 8.541 EXENTA, DE 20 DE DICIEMBRE DE 2012</div></div>", "i": 9328293}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=274755&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 4.515, de 2008, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; planes y programas especiales de estudio de 1&#xBA; y 2&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Colegio Redland School, comuna de Las Condes, provincia de Santiago, Regi&#xF3;n Metropolitana.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio del Sector de Filosof&#xED;a para 1&#xB0; a&#xF1;o de Educaci&#xF3;n Media.</div></div>", "i": 9328294}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de diciembre de 2012.- Ricardo H.C. Evangelista, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 9328295}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8541 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-8541 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "DIVISIÓN DE EDUCACIÓN GENERAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 8.541 EXENTA, DE 20 DE DICIEMBRE DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-12-20", "doble_articulado": false, "id_norma": "1048153", "numero_fuente": "40460", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-01-16", "vigencias": [{"desde": "2013-01-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia":