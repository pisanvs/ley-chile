{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION (E) N&#xBA; 406, DE 2005</div><br><br><br></div>", "i": 7319160}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En cumplimiento de lo dispuesto en los decretos del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA; 291, de 11 de junio de 1999, y N&#xBA; 668, de 16 de noviembre de 1999, certifico que por resoluci&#xF3;n (E) N&#xBA; 406, de 31 de marzo de 2005, del se&#xF1;or Vicepresidente Ejecutivo, se modific&#xF3; el Reglamento del Fondo de Desarrollo y Modernizaci&#xF3;n de Microempresas y fij&#xF3; nuevo texto.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de la antes referida resoluci&#xF3;n estar&#xE1; a disposici&#xF3;n de los usuarios en la Secretar&#xED;a General de la Corporaci&#xF3;n y en las Direcciones Regionales.</div><br></div>", "i": 7319161}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de abril de 2005.- Yerko Koscina Peralta, Secretario General.</div><br></div>", "i": 7319162}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "406 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-406 EXENTA"}], "organismos": ["CORPORACIÓN DE FOMENTO DE LA PRODUCCIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION (E) Nº 406, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REGLAMENTO", "FONDO DE DESARROLLO Y MODERNIZACION DE MICROEMPRESAS", "CORFO", "CORPORACION DE FOMENTO DE LA PRODUCCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-03-31", "fecha_derogacion": "2007-10-19", "doble_articulado": false, "id_norma": "236893", "numero_fuente": "38130", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-04-08", "vigen