{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9335428}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 241, de 29 de enero de 2013, de esta Subsecretar&#xED;a, autor&#xED;zase a MARCELINO GONZ&#xC1;LEZ RIVERA, para ampliar actividades pesqueras extractivas con la nave &quot;Surmar I&quot;, en el &#xE1;rea mar&#xED;tima que de la IV a IX Regiones, por fuera del &#xE1;rea de reserva artesanal, con arrastre, donde podr&#xE1; capturar, los siguientes recursos hidrobiol&#xF3;gicos: Mict&#xF3;fido Triphoturus mexicanus, Mict&#xF3;fido Diogenichthys sp., Mict&#xF3;fido Ceratoscopelus sp., Mict&#xF3;fido Diaphus sp., Mict&#xF3;fido Gonichthys sp., Mict&#xF3;fido Gymnoscopelus sp., Mict&#xF3;fido Hygophum sp., Mict&#xF3;fido Lampadena sp., Mict&#xF3;fido Lampanyctus sp. y Mict&#xF3;fido Myctophum sp.</div></div>", "i": 9335429}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de enero de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9335430}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "241 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-241 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2013-01-29", "fecha_derogacion": "2013-06-10", "doble_articulado": false, "id_norma": "1049135", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2013-02-27", "vigencias": [{"desde": "2013-06-10", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"