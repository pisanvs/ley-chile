{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MONTEPIO Lei n&#xFA;m. 178.-Santiago, a 22 de Enero de 1894.-Por cuanto el Congreso Nacional ha aprobado el siguiente PROYECTO DE LEI:</div><br></div>", "i": 5947040}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese por gracia a do&#xF1;a Javiera Quezada el montep&#xED;o correspondiente al empleo de sarjento mayor de Ej&#xE9;rcito, siempre que por la muerte de don Tadeo Quezada no hubiere otra asignacion fiscal.</div><br><br></div>", "i": 5947041}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORGE MONTT.- Juan Antonio Orrego.</div><br></div>", "i": 5947042}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "178", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-178"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "MONTEPIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JAVIERA QUEZADA", "MONTEPIO MILITAR", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-01-22", "doble_articulado": false, "id_norma": "22038", "numero_fuente": "4734", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-02-03", "vigencias": [{"desde": "1894-02-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-02-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-02-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-01-25", "fecha_version"