{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div><br></div>", "i": 8797465}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA;39.488, de 17 de octubre de 2009, se public&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1007255&amp;idParte=&amp;idVersion=2009-11-05\">resoluci&#xF3;n N&#xBA;285 exenta</a>, que determina la existencia de un mecanismo de cobro y registro de los costos directos de reproducci&#xF3;n para efectos que indica, con los errores que se salvan a continuaci&#xF3;n: en el sumario, primera columna y p&#xE1;gina tres, primera columna, donde dice &quot;... Intendencia Regi&#xF3;n Metropolitana de Santiago...&quot; debe decir &quot;...Gobierno Regional Metropolitano de Santiago...&quot;.</div><br></div>", "i": 8797466, "v": ["RECTIFICACION"]}, {"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8797467}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "67", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-67"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARÍA DEL INTERIOR", "GOBIERNO REGIONAL REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1007784", "numero_fuente": "39503", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-11-05", "vigencias": [{"desde": "2009-11-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-11-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-11-05", "fin_vigencia": "", "tipo_version": "3"}], "event