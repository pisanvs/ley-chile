{"html": [{"t": "<div><br><div class=\"p\">MODIFICA ORDENANZA N&#xBA; 22, DE 2001, SOBRE DERECHOS MUNICIPALES</div><br></div>", "i": 9525522}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por ordenanza N&#xBA;134, de 29 de octubre de 2014, se modifica la ordenanza N&#xBA;22, de 28 de diciembre de 2001, &quot;Ordenanza Local sobre Derechos Municipales&quot;, que rige para el a&#xF1;o 2014, cuyo texto refundido y sistematizado fue aprobado por <a href=\"https://www.leychile.cl/Navegar?idNorma=1057591&amp;idParte=0&amp;idVersion=\">decreto alcaldicio Ex. N&#xBA;2.590, de 17 de diciembre de 2013</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo se encuentra en la p&#xE1;gina web municipal, Transparencia Activa en carpeta marco normativo aplicable/ordenanzas/derechos/sobre derechos municipales.</div><br></div>", "i": 9525523}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La Alcaldesa.</div></div>", "i": 9525524}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "134", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "Ordenanza-134"}], "organismos": ["MUNICIPALIDAD DE PROVIDENCIA"], "titulo_norma": "MODIFICA ORDENANZA Nº 22, DE 2001, SOBRE DERECHOS MUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-10-29", "doble_articulado": false, "id_norma": "1069179", "numero_fuente": "41001", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-11-07", "vigencias": [{"desde": "2014-11-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-11-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic