{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Recompensa de mil pesos a do&#xF1;a Elvira Ar&#xE9;valo v. de Flores</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,410.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, una recompensa de mil pesos a do&#xF1;a Elvira Ar&#xE9;valo v. de Flores, hija &#xFA;nica del ex-alcaide de la c&#xE1;rcel de Melipilla, don V&#xED;ctor Ar&#xE9;valo, muerto en el servicio.</div><br><br></div>", "i": 5949106}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 27 de Diciembre 1900.- FEDERICO ERRAZURIZ E.- Francisco J. Herboso.</div><br></div>", "i": 5949107}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1410", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1410"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "RECOMPENSA DE MIL PESOS A DOÑA ELVIRA AREVALO V. DE FLORES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ELVIRA AREVALO VIUDA DE FLORES", "RECOMPENSA POR", "GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-12-27", "doble_articulado": false, "id_norma": "22629", "numero_fuente": "6782", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-01-03", "vigencias": [{"desde": "1901-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ú