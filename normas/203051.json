{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;770 EXENTO, DE 2002 </div></div>", "i": 6397920}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;770 de fecha 27 de agosto de 2002, de Educaci&#xF3;n, se declara aprobada a la Universidad Jos&#xE9; Santos Ossa la modificaci&#xF3;n al Plan y a los Programas de estudio de la carrera de Psicopedagog&#xED;a.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, dicha carrera se imparte en jornada diurna en su sede de la ciudad de Antofagasta.</div><div class=\"p\">&nbsp; &nbsp;  Las modificaciones se har&#xE1;n efectivas a contar del segundo semestre del a&#xF1;o 2002.</div><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase presente para todos los efectos legales y administrativos.</div><br></div>", "i": 6397921}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de septiembre de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6397922}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "770 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-770 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº770 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-08-27", "doble_articulado": false, "id_norma": "203051", "numero_fuente": "37373", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-10-02", "vigencias": [{"desde": "2002-10-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-10-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-1