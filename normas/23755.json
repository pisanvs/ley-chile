{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede fondos para la construccion de un Pabellon de Anatom&#xED;a para la Escuela de Medicina</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,121.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7166336}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para quie invierta hasta la suma de de cincuenta mil pesos ($ 50,000) en la construccion de un Pabellon de Anatom&#xED;a para la Escuela de Medicina. </div></div>", "i": 7166337}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 6 de Setiembre de 1916.- JUAN LUIS SANFUENTES.- Alberto Romero.</div><br></div>", "i": 7166338}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3121", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3121"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "CONCEDE FONDOS PARA LA CONSTRUCCION DE UN PABELLON DE ANATOMÍA PARA LA ESCUELA DE MEDICINA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ESCUELA MEDICINA", "PABELLON ANATOMIA", "CONSTRUCCION", "FONDOS", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-09-06", "doble_articulado": false, "id_norma": "23755", "numero_fuente": "11570", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-09-09", "vigencias": [{"desde": "1916-09-09", "hast