{"html": [{"t": "<div><br><div class=\"p\">PONE T&#xC9;RMINO AL NOMBRAMIENTO COMO ALCALDE DE MAR AD-HON&#xD3;REM</div></div>", "i": 9721101}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n D.G.T.M. y M.M. Ord. N&#xB0; 1120/139 Vrs., de fecha 29 de junio de 2016, pone t&#xE9;rmino al nombramiento como Alcalde de Mar Ad-Hon&#xF3;rem.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl).</div></div>", "i": 9721102}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de junio de 2016.- Osvaldo Schwarzenberg Ashton, Vicealmirante, Director General.- Rodrigo Ram&#xED;rez Daneri, Capit&#xE1;n de Nav&#xED;o JT, Jefe Depto. Jur&#xED;dico.</div><br></div>", "i": 9721103}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "139", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-139"}, {"tipo": "3", "numero": "1120/139", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1120/139"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "PONE TÉRMINO AL NOMBRAMIENTO COMO ALCALDE DE MAR AD-HONÓREM", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1049315; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-06-29", "doble_articulado": false, "id_norma": "1093399", "numero_fuente": "41527", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-08-06", "vigencias": [{"desde": "2016-08-06", "hasta": "", "tipo_version": "3