{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 2 EXENTA, DE 2001 </div></div>", "i": 6315872}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n Ex. N&#xBA;02 de fecha 8 de enero de 2001, se dispuso ampliar al 31.01.2001 el plazo otorgado en el resolutivo N&#xBA;9 de la Res. Ex. N&#xBA;4.228 de 24.06.99, modificada por la Res. Ex. 5.004 de 22.07.99, para que los contribuyentes reiteren la solicitud para diferir la exigibilidad de los requisitos establecidos en el resolutivo N&#xBA;4 de la Res. Ex. N&#xBA;4.228 de 1999, para optar por sustituir los Libros de Contabilidad por hojas sueltas llevadas computacionalmente.</div><br></div>", "i": 6315873}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese en extracto.- Javier Etcheberry Celhay, Director Nacional.</div><br></div>", "i": 6315874}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 2 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-01-08", "doble_articulado": false, "id_norma": "180023", "numero_fuente": "36859", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-11", "vigencias": [{"desde": "2001-01-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-01-11", "fin_vigencia": "", "tipo_ver