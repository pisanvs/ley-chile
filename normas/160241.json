{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;146 EXENTO, DE 1999 </div></div>", "i": 6247977}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;146, de fecha 9 de junio de 1999, del Ministerio de Educaci&#xF3;n, se declara aprobada al Instituto Profesional Diego Barros Arana la carrera de Ingenier&#xED;a de Ejecuci&#xF3;n en Medio Ambiente, conducente al t&#xED;tulo profesional de Ingeniero de Ejecuci&#xF3;n en Medio Ambiente, para ser impartida en jornada diurna en su sede de la ciudad de Concepci&#xF3;n, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6247978}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de junio de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6247979}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "146 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-146 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº146 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-06-09", "doble_articulado": false, "id_norma": "160241", "numero_fuente": "36609", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-09", "vigencias": [{"desde": "2000-03-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresad