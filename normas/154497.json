{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6229166}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 266, de 12 de Diciembre de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n, se autoriza a don Abel Enrique Gruner Rodr&#xED;guez para efectuar toda clase de servicios de transporte de pasajeros, por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos de locomoci&#xF3;n colectiva urbanos, de acuerdo a lo dispuesto en el D.S. 163/84.</div><br></div>", "i": 6229167}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Temuco, 12 de Diciembre de 1986.- Eduardo Zepeda Hauyon, Secretario Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n subrogante.</div><br></div>", "i": 6229168}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "266", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-266"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-12-12", "doble_articulado": false, "id_norma": "154497", "numero_fuente": "32659", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-12-31", "vigencias": [{"desde": "1986-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-12-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-12-31", "fin_vigencia": "", "tipo_versi