{"html": [{"t": "<div><div class=\"p\">RESOLUCION N&#xBA; 1.884 - 16.04.07 </div></div>", "i": 7342156}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I.- Modif&#xED;quese como se indica el Compendio de Normas Aduaneras:</div><br><div class=\"p\">&nbsp; &nbsp;  1.- CAPITULO IV Elim&#xED;nase el p&#xE1;rrafo segundo de la letra b) del numeral 16.5.</div><div class=\"p\">&nbsp; &nbsp;  2.- Elim&#xED;nase en el Anexo N&#xBA; 35, Instrucciones llenado del formulario Salida Temporal, numeral 11.13, p&#xE1;rrafo octavo, el siguiente texto &quot;En recuadro valor de la observaci&#xF3;n se&#xF1;ale el correspondiente valor del procesamiento, en d&#xF3;lares de los Estados Unidos de Norteam&#xE9;rica, dos decimales. En recuadro glosa indique &quot;Valor de Procesamiento&quot;.</div><br></div>", "i": 7342157}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1884", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1884"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS"], "titulo_norma": "RESOLUCION Nº 1.884 - 16.04.07", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMPENDIO DE NORMAS ADUANERAS", "FORMULARIO SALIDA TEMPORAL", "INSTRUCCIONES DE LLENADO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-04-16", "doble_articulado": false, "id_norma": "260944", "numero_fuente": "38766", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-05-18", "vigencias": [{"desde": "2007-05-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-05-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-05-18", "fin_vigencia": "", "tipo_version": "3"}