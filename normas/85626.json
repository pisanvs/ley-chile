{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8317216}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n exenta N&#xBA; 119 de fecha 10 de diciembre de 1997, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se ha rechazado el Recurso de Reclamaci&#xF3;n interpuesto por Exosur S.A., Rut:</div><div class=\"p\">96.539.360-9 y confirmada la Resoluci&#xF3;n N&#xBA; 695 de 1997 de la Subsecretar&#xED;a de Pesca, que declar&#xF3; la caducidad parcial de la Resoluci&#xF3;n N&#xBA; 1.866 del a&#xF1;o 1989 de esa Subsecretar&#xED;a, que autoriz&#xF3; a dicha empresa para desarrollar actividades pesqueras con la nave &quot;La Crabe Tambour&quot;.-</div><br></div>", "i": 8317217}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Oscar Landerretche Gacit&#xFA;a, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8317218}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "119 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-119 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECURSO DE RECLAMACION", "EXOSUR S.A.", "CADUCIDAD", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-10", "doble_articulado": false, "id_norma": "85626", "numero_fuente": "35956", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-05", "vigencias": [{"desde": "1998-01-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-05", "fin_vigencia": ""}, "vigencias_version_norma"