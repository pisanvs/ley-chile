{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 725 EXENTA, DE 2011, QUE RECTIFICA LO QUE INDICA</div></div>", "i": 9110289}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 725, de 10.02.2011, del Ministerio de Transportes y Telecomunicaciones se rectifica de oficio, de conformidad con lo dispuesto en el art&#xED;culo 62&#xBA; de la ley N&#xBA; 19.880, el llamado a concurso p&#xFA;blico para el otorgamiento de concesiones de radiodifusi&#xF3;n sonora, correspondiente al primer cuatrimestre de 2011, publicado en la edici&#xF3;n N&#xBA; 39.860 del Diario Oficial del d&#xED;a 15 de enero de 2011, en el sentido de dejar sin efecto la inclusi&#xF3;n en el mismo, en la tabla correspondiente a &quot;solicitudes de renovaci&#xF3;n&quot;, de la concesi&#xF3;n de radiodifusi&#xF3;n sonora en frecuencia modulada para la localidad de Chill&#xE1;n, VIII Regi&#xF3;n.- </div></div>", "i": 9110290}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Subsecretar&#xED;a de Telecomunicaciones.</div></div>", "i": 9110291}, {"t": "<div class='ab'><a href='Navegar/pdf/PDF/16544.PDF'>Descargar NORMA (PDF, 104 K)</a></div>", "i": null}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "725 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-725 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TELECOMUNICACIONES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 725 EXENTA, DE 2011, QUE RECTIFICA LO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-02-10", "doble_articulado": false, "id_norma": "1023