{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8301180}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 156, de 31 de enero de 1997 de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de</div><div class=\"p\">acuicultura, presentada por SOCIEDAD DE CULTIVOS MARINOS</div><div class=\"p\">CHIVILINGO LTDA., para un sector ubicado en Caleta</div><div class=\"p\">Chivilingo, Golfo de Arauco, Comuna de Lota, Provincia de</div><div class=\"p\">Concepci&#xF3;n, VIII Regi&#xF3;n, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 14&#xBA;, del D.S. N&#xBA; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xBA; 392, de 1990, de esta Subsecretar&#xED;a, en virtud de lo se&#xF1;alado precedentemente.</div><br></div>", "i": 8301181}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de enero de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8301182}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "156", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-156"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "SOLICITUD", "SOCIEDAD DE CULTIVOS MARINOS CHIVILINGO LTDA."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-01-31", "doble_articulado": false, "id_norma": "60859", "numero