{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6191741}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP No. 1.775, de 30 de junio de 1999, se expropiaron los lotes de terreno No. s. 7-A, 7-B y 32, superficies 100, 286 y 344 m2, respectivamente, roles de aval&#xFA;os 197-582, 197-108 y 202-572 de la comuna de Longav&#xED; para la obra Camino Ruta L-55, sector Chalet Quemado - Quinta y se acord&#xF3; precio de la indemnizaci&#xF3;n con sus propietarios Sergio Antonio Fuentes y Otras, Ester del Carmen Hern&#xE1;ndez Mart&#xED;nez y Otras y Arturo Osvaldo Molina Barra, ascendentes a las cantidades de $ 198.180, lote No. 7-A; $ 321.052, lote No. 7-B y $ 302.555, lote No. 32.-</div><br></div>", "i": 6191742}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6191743}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1775", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1775"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-06-30", "doble_articulado": false, "id_norma": "143572", "numero_fuente": "36465", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-15", "vigencias": [{"desde": "1999-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999