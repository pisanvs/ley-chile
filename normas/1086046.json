{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 17 B</div><div class=\"p\">&nbsp; &nbsp; </div></div>", "i": 9661167}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.531, de 28 de diciembre de 2015, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1075205&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 535, de 2015</a>, de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la Agrupaci&#xF3;n 17 B, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para los centros de cultivo 100630 y 103456, como se indica en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp; </div><br></div>", "i": 9661168}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de diciembre de 2015.- Paolo Trejo Carmona, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9661169}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3531 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-3531 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 17 B", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 982800; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-12-28", "doble_articulado": false, "id_norma": "1086046", "numero_fuente": "41347", "tipo_version": "3", "tipo_version_s": "Única", "f