{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6216716}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 409, de 13 de Mayo de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a V&#xED;ctor Altamirano Toledo, Marcelo Uribe Puschel, Dagoberto Suazo Arcos, Luis Delgado Fuentealba, Iv&#xE1;n Albornoz Molina y Bernardino Monsalve Castillo para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 15 &quot;San Luis - Centro&quot; de Valdivia, cuyo trazado fue autorizado por resoluci&#xF3;n exenta No. 356, de 26 de Agosto de 1985, de esta Secretar&#xED;a Regional.- </div></div>", "i": 6216717}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Enrique Bintrup Barrera, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n subrogante.</div><br></div>", "i": 6216718}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "409 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-409 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-05-28", "doble_articulado": false, "id_norma": "150644", "numero_fuente": "32789", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-06", "vigencias": [{"desde": "1987-06-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-06", "fin_vigencia":