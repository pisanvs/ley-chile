{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8300534}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 7, de 9 de enero de 1997, de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad parcial de la Resoluci&#xF3;n</div><div class=\"p\">N&#xBA; 264 de 1985, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA</div><div class=\"p\">COLOSO S.A., para ampliar actividades pesqueras extractivas con</div><div class=\"p\">la nave &quot;Lientur&quot;, en lo relativo a las especies Sardina</div><div class=\"p\">espa&#xF1;ola, Jurel, Anchoa y Caballa en el litoral de la V Regi&#xF3;n,</div><div class=\"p\">por haberse configurado la causal de caducidad prevista en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley N&#xBA; 18.892.</div><br></div>", "i": 8300535}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de enero de 1997.-</div><br><div class=\"p\">&nbsp; &nbsp;  Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca. </div></div>", "i": 8300536}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD PARCIAL", "AUTORIZACION", "AMPLIACION", "PESQUERA COLOSO S.A.", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["extracto"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-01-09", "doble_articulado": false, "id_norma": "60194", "numero_fuente": "35669", "tipo_version": "3", "tipo_version_s": "Única"