{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9104767}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 248, de 26 de enero de 2011, de esta Subsecretar&#xED;a, rectif&#xED;case el Visto, numeral 1&#xBA; y extracto de la resoluci&#xF3;n exenta N&#xBA; 184 de 2011, de esta Subsecretar&#xED;a de Pesca que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n sobre el recurso Reineta en el sentido de se&#xF1;alar que el proyecto se denomina &quot;Monitoreo biol&#xF3;gico pesquero artesanal de Reineta (Brama australis), en la Provincia de Arauco VIII Regi&#xF3;n, Per&#xED;odo enero-diciembre 2011&quot; y no como all&#xED; se indica.</div><br></div>", "i": 9104768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de enero de 2011.- Felipe Palacio Rives, Subsecretario de Pesca (S).</div></div>", "i": 9104769}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "248 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-248 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-01-26", "doble_articulado": false, "id_norma": "1022460", "numero_fuente": "39873", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-01-31", "vigencias": [{"desde": "2011-01-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-01-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-01-31", "fin_vigencia": "", "tipo