{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6247721}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 25, de 10 de Enero de 1991 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deniega la autorizaci&#xF3;n solicitada por don RICARDO RODRIGUEZ WOOD, R.U.T. No.</div><div class=\"p\">6.473.442-3, domiciliado en Loteo Club A&#xE9;reo s - n&#xB0;, Casilla No. 164, Castro, para prorrogar el plazo establecido en el numeral 5&#xB0;, de la Resoluci&#xF3;n No. 408, de 1989, de esta Subsecretar&#xED;a, en atenci&#xF3;n a lo dispuesto en el art&#xED;culo 7&#xB0; del Decreto No. 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. Se caduca, en m&#xE9;rito de lo antes se&#xF1;alado y de conformidad a lo dispuesto en el art&#xED;culo y la norma antes mencionados, la Resoluci&#xF3;n No. 408, antes citada.</div><br></div>", "i": 6247722}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de Enero de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br><br></div>", "i": 6247723}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "25", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-25"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-10", "doble_articulado": false, "id_norma": "160180", "numero_fuente": "33875", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-01-23", "vigencias": [{"desde": "1991-01-23", "hasta": "", "tipo_version": "