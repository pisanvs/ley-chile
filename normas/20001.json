{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 70, DE 1992 </div></div>", "i": 5940600}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 70 de 25 de marzo de 1992 se ha derogado, a contar del a&#xF1;o escolar 1992, el decreto supremo exento de Educaci&#xF3;n N&#xB0; 61, de 1989.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se declara que, a partir de esa misma fecha, los Liceos dependientes de la Corporaci&#xF3;n de Desarrollo Social de la I. Municipalidad de Providencia, se regir&#xE1;n por los decretos supremos exentos de Educaci&#xF3;n N&#xB0;s. 300 de 1981; 129 de 1989 y 190 de 1990, en lo relativo a planes y programas de estudio.</div><br></div>", "i": 5940601}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 15 de Abril de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5940602}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "70 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-70 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 70, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LICEOS", "CORPORACION DESARROLLO SOCIAL", "MUNICIPALIDAD", "PROVIDENCIA", "PLAN ESTUDIO", "PROGRAMAS ESTUDIO", "ESTABLECIMIENTO ENSE ANZA MEDIA", "HORAS CLASES", "ASIGNATURA CIENCIAS NATURALES", "ESTABLECIMIENTO EDUCACION", "MEDIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-03-25", "doble_articulado": false, "id_norma": "20001", "numero_fuente": "34250", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-04-24", "vigencias": [{"desde": "1992-04-24", "hasta"