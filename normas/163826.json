{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 423, DE 1985, QUE APRUEBA MODIFICACION DE CONVENIO DE TRASPASO ESCUELA BASICA G-1161, COMUNA DE RIO NEGRO </div></div>", "i": 6259583}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto N&#xB0; 423, de 1985, se aprob&#xF3; una modificaci&#xF3;n al convenio de traspaso de la Escuela B&#xE1;sica G-1161 de R&#xED;o Negro, aprobado por decreto N&#xB0; 9.636 de 1981 y N&#xB0; 40 de 1985, de Educaci&#xF3;n, que incide en la cl&#xE1;usula primera.</div><br></div>", "i": 6259584}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 06 de Agosto de 1985.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br><br></div>", "i": 6259585}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "423", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-423"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO N° 423, DE 1985, QUE APRUEBA\nMODIFICACION DE CONVENIO DE TRASPASO ESCUELA BASICA\nG-1161, COMUNA DE RIO NEGRO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-08-06", "doble_articulado": false, "id_norma": "163826", "numero_fuente": "32253", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-08-21", "vigencias": [{"desde": "1985-08-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-08-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-08-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fec