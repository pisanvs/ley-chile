{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 3,956.-&nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6192684}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Se declara de abono, por gracia, al oficial de la 5.a circunscripcion civil del departamento de Santiago, don Florencio P&#xE9;rez, para los efectos de su jubilacion, el tiempo en que desempe&#xF1;&#xF3; las funciones de receptor de mayor cuant&#xED;a del mismo departamento.&quot; </div></div>", "i": 6192685}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a nueve de julio de mil novecientos veintitres.-&nbsp; Arturo Alessandri.-&nbsp; Alcib&#xED;ades Roldan.</div><br></div>", "i": 6192686}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3956", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3956"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1923-07-09", "doble_articulado": false, "id_norma": "143914", "numero_fuente": "13623", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1923-07-11", "vigencias": [{"desde": "1923-07-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1923-07-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1923-07-11", "f