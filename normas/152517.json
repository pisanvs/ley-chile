{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br></div>", "i": 6223413}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 109, de 11 de Junio de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Atacama, se autoriza a Pascual Herm&#xF3;genes Avalos Prado, para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 4 &quot;Torreblanca - Avenida Matta&quot;, cuyo trazado que a continuaci&#xF3;n se indica fue autorizado por resoluci&#xF3;n No. 29, de 15 de Junio de 1984, de esta Secretar&#xED;a Regional.</div><br><div class=\"p\">Ida: Matta, Merced, Brasil, Torreblanca.</div><div class=\"p\">Regreso: Torreblanca, Brasil, Aldea, Colchagua, Ram&#xED;rez, Matta.</div><br></div>", "i": 6223414}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Sergio Antonio Acevedo 0yarce, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de Atacama.</div><br></div>", "i": 6223415}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "109 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-109 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-12", "doble_articulado": false, "id_norma": "152517", "numero_fuente": "32511", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-07-02", "vigencias": [{"desde": "1986-07-02", "hasta": "", "tipo_version": "3", "tipo_