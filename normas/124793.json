{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8334807}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.265, de 31 de agosto de 1998, de esta Subsecretar&#xED;a, autor&#xED;zase a COMERCIAL ALESA S.A., para ampliar actividades pesqueras autorizadas por resoluciones N&#xBA; 310, de 1986, N&#xBA; 302, de 1987, N&#xBA; 562, de 1992, N&#xBA; 138, de 1994 y N&#xBA; 1.195, de 1.995, todas de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en el Sector Nudo Bar&#xF3;n s/n&#xBA;, Valpara&#xED;so, V Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de Congelado y Fresco-enfriado el recurso Abal&#xF3;n rojo.</div><br></div>", "i": 8334808}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de agosto de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8334809}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1265", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1265"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "COMERCIAL ALESA S.A.", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-08-31", "fecha_derogacion": "2001-06-05", "doble_articulado": false, "id_norma": "124793", "numero_fuente": "36169", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-09-22", "vigencias": [{"desde": "2001-06-05", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-09-22", "hasta": "2001-06-04", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"