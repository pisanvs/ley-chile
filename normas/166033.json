{"html": [{"t": "<div><div class=\"p\">AUTORIZA A SOCIEDAD ARMADORES ALFA LIMITADA PARA DESARROLLAR ACTIVIDADES PESQUERAS.</div><br><br><br></div>", "i": 7267939}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 16, de 09 de Enero de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a , Fomento y Reconstrucci&#xF3;n se autoriza a Sociedad Armadores Alfa Limitada domiciliada en la ciudad de Iquique ,para operar en el litoral comprendido entre la Primera y Segunda Regi&#xF3;n , la embarcaci&#xF3;n de barco pesquero suscrito con Astilleros y Servicios Navales (ASENAV) Ltda el 22 de Noviembre de 1984 , en faenas extractivas de jurel , sadrinas espa&#xF1;ola , caballa y anchoa </div></div>", "i": 7267940}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago 09 de Enero de 1985 .- Roberto Verdugo Gormas , Subsecretario de Pesca </div></div>", "i": 7267941}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "16", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-16"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A SOCIEDAD ARMADORES ALFA LIMITADA PARA DESARROLLAR\nACTIVIDADES PESQUERAS.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1985-01-09", "fecha_derogacion": "1993-03-17", "doble_articulado": false, "id_norma": "166033", "numero_fuente": "32075", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1985-01-19", "vigencias": [{"desde": "1993-03-17", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1985-01-19", "hasta": "1993-03-16", "tip