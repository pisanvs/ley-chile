{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede derecho a jubilar al Pro-Rector de la Universidad don Jos&#xE9; Miguel Besoain</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,961.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 9042138}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Conc&#xE9;dese, por gracia, al pro-rector de la Universidad, don Jos&#xE9; Miguel Besoain, el derecho de jubilar con la pension que en conformidad a las leyes del ramo le corresponda por los a&#xF1;os que compruebe haber servido al Estado.</div><br></div>", "i": 9042139}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 26 de Diciembre de 1914.- RAMON BARROS LUCO.- Absalon Valencia.</div><br></div>", "i": 9042140}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2961", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2961"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "CONCEDE DERECHO A JUBILAR AL PRO-RECTOR DE LA UNIVERSIDAD DON JOSE MIGUEL BESOAIN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JOSE MIGUEL BESOAIN", "PRO-RECTOR UNIVERSITARIO", "JUBILACION POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1914-12-26", "doble_articulado": false, "id_norma": "23626", "numero_fuente": "11060", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1914-01-04", "vigencias