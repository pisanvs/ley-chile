{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE RESOLUCIONES</div><br><br></div>", "i": 8929319}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 632, de 6 de Junio de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, se prorroga por seis meses a contar de la fecha de la presente Resoluci&#xF3;n, el plazo otorgado a don NAZAEL HERNAN RIQUELME ESPINOZA, R.U.T. N&#xB0; 4.511.011-k, domiciliado en Valdivia, Carampangue N&#xB0; 642, en el numeral 5&#xB0; de la Resoluci&#xF3;n N&#xB0; 255, de 1990, de esta Subsecretar&#xED;a, que la autoriz&#xF3; para iniciar actividades de cultivo, en virtud de haber acreditado la ocurrencia de fuerza mayor.</div><br></div>", "i": 8929320}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 6 de Junio de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8929321}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "632", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-632"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NAZAEL HERNAN RIQUELME ESPINOZA", "PESCA", "PLAZO", "PRORROGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-06-06", "fecha_derogacion": "1995-03-15", "doble_articulado": false, "id_norma": "31570", "numero_fuente": "34009", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-07-05", "vigencias": [{"desde": "1995-03-15", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1991-07-05", "hasta": "1995-03-14", "tipo_version": "0", "tipo_version_s":