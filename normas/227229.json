{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO ALCALDICIO DE REGISTRO No. 146, DE 1987 </div></div>", "i": 8930768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El siguiente es el extracto del Decreto Alcaldicio de Registro No. 146:</div><div class=\"p\">&nbsp; &nbsp;  1.- Modificase el Decreto Alcaldicio de Registro No. 089 del 20 de Julio de 1987, en su punto 1&#xB0; en el sentido de se&#xF1;alar que el terreno a expropiar se encuentra amparado por la inscripci&#xF3;n de fojas 1.548 v&#xED;a. No. 951 de 1987, a nombre de la Sucesi&#xF3;n Varas Moro.</div><br></div>", "i": 8930769}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Carlos Cantero Ojeda, Alcalde I. Municipalidad de Calama.</div><br></div>", "i": 8930770}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "146", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-146"}], "organismos": ["MUNICIPALIDAD DE CALAMA"], "titulo_norma": "EXTRACTO DE DECRETO ALCALDICIO DE REGISTRO NO. 146, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO. SIN FECHA DE PUBLICACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "227229", "numero_fuente": "32934", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-01", "vigencias": [{"desde": "1987-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2004-07-06", "fecha_version": "1987-12-01", "fecha_actualizacion_texto": "1987-12-01", "tipo_tratado