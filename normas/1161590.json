{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xB0; 1.179 EXENTA, DE 18.03.2020</div></div>", "i": 10244395}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 1.427 de 9 de junio de 2021, del Director Nacional de Aduanas, se eliminan los p&#xE1;rrafos segundo y quinto del numeral 3, del art&#xED;culo 1 de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1144043&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xB0; 1.179 de 18 de marzo de 2020</a>.</div><div class=\"p\">&nbsp; &nbsp;  La resoluci&#xF3;n extractada entra en vigencia a partir de la publicaci&#xF3;n en el Diario Oficial.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10244396}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de junio de 2021.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><div class=\"p\"> </div><br></div>", "i": 10244397}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1427 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1427 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCIÓN N° 1.179 EXENTA, DE 18.03.2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1961690", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-06-09", "doble_articulado": false, "id_norma": "1161590", "numero_fuente": "42981", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-06