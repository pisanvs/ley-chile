{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6509662}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.294, de 16 de noviembre de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a MANUEL ROBERTO ROJAS ARAYA para ampliar actividades pesqueras de transformaci&#xF3;n en orden a incorporar a la planta ubicada en calle 20 de Marzo N&#xBA; 50, poblaci&#xF3;n Victoria, Coquimbo, IV Regi&#xF3;n, en la l&#xED;nea de proceso de Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 3.170 de 2004, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6509663}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de noviembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6509664}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3294 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3294 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-16", "doble_articulado": false, "id_norma": "233806", "numero_fuente": "38039", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-18", "vigencias": [{"desde": "2004-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-12-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-12