{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,751, que concede fondos para combatir la viruela.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,751.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 8276683}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de ciento cincuenta mil pesos ($150,000) en combatir la epidemia de viruelas.</div><br></div>", "i": 8276684}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a once de Mayo de mil novecientos veintiuno.- ARTURO ALESSANDRI.- Pedro Aguirre Cerda. </div></div>", "i": 8276685}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3751", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3751"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NÚM. 3,751, QUE CONCEDE FONDOS PARA COMBATIR LA VIRUELA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VIRUELA", "PREVENCION", "FONDOS", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1921-05-11", "doble_articulado": false, "id_norma": "24226", "numero_fuente": "12974", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1921-05-18", "vigencias": [{"desde": "1921-05-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1921-05-18", "fin_vigencia": ""}, "vigencias_version_norma":