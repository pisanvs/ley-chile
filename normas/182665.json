{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6325644}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 286, de 21 de febrero de 2001, de esta Subsecretar&#xED;a,&nbsp; autor&#xED;zase a&nbsp; SOUTH PACIFIC ABALONE S.A., para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en Panamericana Norte Km. 183, Los Molles, comuna de La Ligua, V Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n que se indican los siguientes recursos hidrobiol&#xF3;gicos: congelado, conserva, deshidratado, ahumado y fresco-refrigerado: Abal&#xF3;n rojo, Turbot, Loco.</div><div class=\"p\">&nbsp; &nbsp;  El recurso Loco deber&#xE1; provenir de pescadores artesanales debidamente autorizados.</div><div class=\"p\">&nbsp; &nbsp;  Los recursos Abal&#xF3;n y Turbot deber&#xE1;n provenir de centros de cultivos autorizados.</div><br></div>", "i": 6325645}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de febrero de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6325646}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "286", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-286"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-21", "doble_articulado": false, "id_norma": "182665", "numero_fuente": "36907", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-08", "vigencias": [{"desde": "2001-03-08", "hasta": "", "tipo_version": "