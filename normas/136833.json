{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 285.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170019}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese a la corporacion denominada &quot;Sociedad de Artesanos de la Union de Chillan&quot; el permiso requerido por el art&#xED;culo 556 del C&#xF3;digo Civil para que pueda conservar por treinta a&#xF1;os la propiedad de un bien ra&#xED;z que tiene adquirido en la calle del Dieziocho de Setiembre de dicha ciudad.&quot; </div></div>", "i": 6170020}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de julio de 1895.- JORJE MONTT.- O. Renjifo.</div><br></div>", "i": 6170021}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "285", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-285"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-07-13", "doble_articulado": false, "id_norma": "136833", "numero_fuente": "5162", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-07-17", "vigencias": [{"desde": "1895-07-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-07-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1895-07-17", "