{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8915752}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Se rectifica publicaci&#xF3;n efectuada con fecha 18 de marzo de 2010, del <a href=\"https://www.leychile.cl/Navegar?idNorma=1011838&amp;idParte=&amp;idVersion=2010-05-05\">D.S. N&#xBA; 294 de 2009, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n</a>, en el sentido de indicar que el art&#xED;culo &#xFA;nico de dicho decreto contenido en la p&#xE1;gina 5, 2&#xAA; columna, debi&#xF3; se&#xF1;alar el guarismo 99,9% y no 99% como en &#xE9;l se indica.</div><br></div>", "i": 8915753, "v": ["RECTIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "123", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-123"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1013029", "numero_fuente": "39652", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-05-05", "vigencias": [{"desde": "2010-05-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-05-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-05-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "RECTIFICACION", "url_part": "rectificacion"}], "ingresado_por": "3721", "fecha_ingreso": "2010-05-05", "fecha_version": "2010-05-05", "actualizado_por": "3721", "fecha_actualizacion_texto": "2010-05-05", "tipo_tratado": ""}, "alertas": [], "alerta_global": ""