{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7303858}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.000, de 21 de agosto de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de las resoluciones N&#xBA; 763 de 1995, N&#xBA; 610 de 1996 y N&#xBA; 931 de 1998, y el numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA; 1.899 de 2001, todas de esta Subsecretar&#xED;a, que autorizaron a PESQUERA SAN JOSE S.A. para realizar actividades pesqueras extractivas con la nave &quot;Don Julio&quot;, en el sentido de modificar e incorporar en esta &#xFA;ltima las siguientes caracter&#xED;sticas n&#xE1;uticas:</div><br><div class=\"p\">Eslora de arqueo&nbsp; &nbsp;  58,94 m</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  12,00 m</div><div class=\"p\">Capacidad de bodega&nbsp;  1610,03 m3</div><br></div>", "i": 7303859}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7303860}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2000 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2000 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-21", "doble_articulado": false, "id_norma": "214923", "numero_fuente": "37664", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-20", "vigencias": [{"desde": "2003-09-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni