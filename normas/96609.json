{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA;. 352, DE 1990 </div></div>", "i": 7231114}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n N&#xBA;. 352, de 27 de diciembre de 1990, se han aprobado plan y programas especiales de estudio de educaci&#xF3;n media human&#xED;stico - cient&#xED;fica al Colegio Coya de Rancagua, el que se aplicar&#xE1; simult&#xE1;neamente de 1&#xB0; a 4&#xB0; medio, a partir del a&#xF1;o escolar 1991.</div><br></div>", "i": 7231115}, {"t": "<div><div class=\"p\">Santiago, 12 de Febrero de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7231116}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "352 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-352 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº. 352, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-27", "doble_articulado": false, "id_norma": "96609", "numero_fuente": "33901", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-02-22", "vigencias": [{"desde": "1991-02-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-02-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-02-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JRC", "fecha_ingreso": "1998-03-30", "fecha_version": "1991-02-22", "fecha_actualizacion_texto": "1