{"html": [{"t": "<div><div class=\"p\">AUTORIZA A CULTIVOS GRACILARIAS S.A. PARA DESARROLLAR ACTIVIDADES PESQUERAS </div></div>", "i": 7264931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 264, de 17 de Marzo de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Cultivos Gracilarias S.A., domiciliada en Puerto Montt, para instalar y operar un establecimiento de cultivo de alga Gracilaria spp., en un&nbsp; rea de 90.000 m2., ubicada en Quillaipe, Comuna de Puerto Montt, Provincia de Llanquihue, X Regi&#xF3;n.</div><br></div>", "i": 7264932}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de Marzo, de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7264933}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "264", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-264"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A CULTIVOS GRACILARIAS S.A. PARA DESARROLLAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-03-17", "doble_articulado": false, "id_norma": "160552", "numero_fuente": "32436", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-04-02", "vigencias": [{"desde": "1986-04-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-04-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-04-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones"