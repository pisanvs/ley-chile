{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 569, DE 2005 </div></div>", "i": 6564570}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 569, de 16 de diciembre de 2005, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Magallanes y Ant&#xE1;rtica Chilena, se dispuso el inicio de la Puesta en Marcha definitiva de la Planta de Revisi&#xF3;n T&#xE9;cnica Clase AB de la Comuna de Puerto Natales, correspondiente a la Concesi&#xF3;n Uno, adjudicada a &quot;Serviden y Compa&#xF1;&#xED;a Limitada&quot; con una (1) l&#xED;nea de revisi&#xF3;n liviana y una (1) l&#xED;nea de revisi&#xF3;n pesada, a contar del 19 de diciembre de 2005.</div><br><br></div>", "i": 6564571}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Gustavo Faraldo Iriarte, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de Magallanes y Ant&#xE1;rtica Chilena.</div><br></div>", "i": 6564572}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "569", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-569"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XII REGIÓN DE MAGALLANES Y ANTÁRTICA CHILENA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 569, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-16", "doble_articulado": false, "id_norma": "248209", "numero_fuente": "38416", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-17", "vigencias": [{"desde": "2006-03-17", "hasta": "", "tipo_version": "3", "tipo_ver