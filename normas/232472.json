{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUA EN COMUNA DE OVALLE </div></div>", "i": 6504937}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n</div><div class=\"p\">exenta N&#xBA; 4.178 del 27 de octubre de 2004, conforme</div><div class=\"p\">art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, complement&#xF3; resoluci&#xF3;n general N&#xBA; 1980, de 6 de noviembre de 1979, que aprob&#xF3; distribuci&#xF3;n de derechos de aprovechamiento de aguas del Proyecto de Parcelaci&#xF3;n &quot;Chile Nuevo&quot;, de la comuna de Ovalle, provincia de Limar&#xED;, IV Regi&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Los derechos de aprovechamiento de aguas se extraen de la quebrada El Ingenio, est&#xE1;n expresados en unidad de volumen por unidad de tiempo, son de car&#xE1;cter consuntivo, de ejercicio permanente y continuo. Publicaci&#xF3;n hecha conforme art&#xED;culo 13&#xBA; ley N&#xBA; 18.377. </div></div>", "i": 6504938}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Nacional.</div><br></div>", "i": 6504939}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4178 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4178 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUA EN COMUNA DE OVALLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-27", "doble_articulado": false, "id_norma": "232472", "numero_fuente": "38011", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-11-15", "vigencias": [{"desde": "2004-11-15", "has