{"html": [{"t": "<div><div class=\"p\">NOTIFICACION </div></div>", "i": 6086635}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 981, de 27 de Octubre 1989, de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL 2.186 de 1978, parte inmueble ubicado en calle Zanj&#xF3;n de la Aguada No. 301, presunto rol aval&#xFA;os N&#xB0; 714-8, comuna San Joaqu&#xED;n, aparentemente dominio de don Ram&#xF3;n Salinas Gonz&#xE1;lez. Comisi&#xF3;n integrada por peritos Srs. Jorge Cavagnaro Michelis, ingeniero civil, Luis Rojas Quezada, constructor civil, y Luis del Pozo Concha, arquitecto, seg&#xFA;n informe de 20.07.89, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 152.000.-, pagadera al contado.-</div><br></div>", "i": 6086636}, {"t": "<div><div class=\"p\">Director SERVIU Metropolitano.</div><br></div>", "i": 6086637}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "981", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-981"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-10-27", "doble_articulado": false, "id_norma": "90709", "numero_fuente": "33536", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-12-01", "vigencias": [{"desde": "1989-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_in