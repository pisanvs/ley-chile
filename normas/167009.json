{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 853, DE 1986 </div></div>", "i": 6269842}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.176, de 05 de Octubre de 1987, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n No. 853, de 11 de noviembre de 1986, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Pesquera Sur Exportaciones Ltda., domiciliada en Penco, para instalar y operar un establecimiento de cultivo de alga del g&#xE9;nero Gracilaria, en dos sectores de fondo de mar, en el extremo norte de Isla Tenglo, en el sentido de sustituir en el numeral 2&#xB0; de dicha resoluci&#xF3;n el guarismo &quot;52.000&quot; por &quot;52.500&quot;.</div><br></div>", "i": 6269843}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 05 de Octubre de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 6269844}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1176", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1176"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 853, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-10-05", "doble_articulado": false, "id_norma": "167009", "numero_fuente": "32895", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-10-16", "vigencias": [{"desde": "1987-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-10-16", "fin_vigencia": ""}, "vigencias_version_norm