{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6539957}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.817 de 26 de agosto de 2005 de esta Subsecretar&#xED;a, autor&#xED;zase a EMPRESA CULTIVOS MARINOS FLAMENCO S.A., para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Panamericana Norte Km. 940, Sector Caleta Flamenco, Comuna de Cha&#xF1;aral, III Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Fresco Enfriado, Fresco Refrigerado y Congelado los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6539958}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de agosto de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6539959}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2817 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2817 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-08-26", "doble_articulado": false, "id_norma": "241941", "numero_fuente": "38262", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-09-14", "vigencias": [{"desde": "2005-09-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-09-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-09-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ing