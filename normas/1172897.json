{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10312174}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xB0; 33, de 13 enero 2022, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos relativa a la actividad denominada Aniversario Ays&#xE9;n &quot;Concierto Banda Benem&#xE9;rita de Carabineros de Chile&quot; en la ciudad de Pto. Ays&#xE9;n, y autoriz&#xF3; a la I. Municipalidad de Ays&#xE9;n para realizar las siguientes intervenciones en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - Corte total de v&#xED;a en calle Esmeralda, entre calle Arturo Prat y calle Bernardo O&apos;Higgins de la comuna de Ays&#xE9;n, el d&#xED;a martes 18 de enero de 2022, desde las 17:30 hrs. hasta las 23:00 hrs.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10312175}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco Lara Acevedo, Gobernador Regional (S), Gobierno Regional de Ays&#xE9;n.- Ximena Guti&#xE9;rrez Jaramillo, Asesor Jur&#xED;dico, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10312176}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "33 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-33 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2088536", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-01-13", "doble_articulado": false, "id_norma": "1172897", "numero_fuente": "43183", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-02-19"