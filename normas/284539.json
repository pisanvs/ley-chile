{"html": [{"t": "<div><div class=\"p\">ACTUALIZA, SISTEMATIZA Y REFUNDE N&#xD3;MINA DE &quot;GRANDES CONTRIBUYENTES&quot; </div></div>", "i": 8676671}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0;173, del 31 de diciembre de 2008. Actualiza, sistematiza y refunde N&#xF3;mina de &quot;Grandes Contribuyentes&quot; para los efectos se&#xF1;alados en dispositivo 3&#xB0; de Res. Ex. N&#xB0; 34, de 24.08.01, sobre la base de los Criterios de Selecci&#xF3;n que se indican.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl), y adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en diciembre, de 2008. </div></div>", "i": 8676672}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "173 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-173 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ACTUALIZA, SISTEMATIZA Y REFUNDE NÓMINA DE \"GRANDES CONTRIBUYENTES\"", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2008-12-31", "fecha_derogacion": "2010-01-06", "doble_articulado": false, "id_norma": "284539", "numero_fuente": "39255", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2009-01-07", "vigencias": [{"desde": "2010-01-06", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2009-01-07", "hasta": "2010-01-05", "tipo_version": "0", "tipo_version_s": "T