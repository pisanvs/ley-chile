{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8300888}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 86, de 17 de enero de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n; deni&#xE9;gase la autorizaci&#xF3;n solicitada por PESQUERA MAR DEL SUR S.A., para sustituir la nave &quot;Mar del Sur II&quot; por la nave &quot;Mar del Sur IV&quot;, por no darse cumplimiento a lo </div><div class=\"p\">establecido en los art&#xED;culos 1&#xBA; y 2&#xBA; del D.S. N&#xBA; 64 de 1992, del </div><div class=\"p\">Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, en virtud de haber sido caducada la autorizaci&#xF3;n de pesca de la nave &quot;Mar del </div><div class=\"p\">Sur II&quot;, mediante Resoluci&#xF3;n N&#xBA; 30, de 1996, de esta Subsecretar&#xED;a.</div><br></div>", "i": 8300889}, {"t": "<div><br><div class=\"p\">Valpara&#xED;so, 17 de enero de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8300890}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "86", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-86"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA MAR DEL SUR S.A.", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-01-17", "doble_articulado": false, "id_norma": "60471", "numero_fuente": "35676", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-01-27", "vigencias": [{"desde": "1997-01-27", "hasta": "", "tipo_version": "3", "tipo_version_s"