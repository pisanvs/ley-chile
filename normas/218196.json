{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6451793}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP Exento N&#xBA; 1.382 de fecha 31 de octubre de 2003, se expropiaron los lotes de terreno N&#xBA;s. 14Z13, 14Z14, 14Z15, 14Z16, 14Z17, 14Z18, 14Z19, 14Z20 y 14Z21, superficies 3.664 m2, 428 m2, 477 m2, 806 m2, 437 m2, 642 m2, 199 m2, 35 m2 y 209 m2, rol de Aval&#xFA;o N&#xBA; 214-45, comuna de Curepto, para la obra &quot;Camino Ruta K-60 y K-16, Sector Mejoramiento Gualleco Curepto - Puente Lautaro Tramo Km. 46,180 a Km.</div><div class=\"p\">83,91430; Comuna de Curepto, Provincia de Talca&quot;, VII Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Rodomiro Fern&#xE1;ndez Matus, ascendente a la cantidad de $1.228.279.</div><br></div>", "i": 6451794}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6451795}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1382 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1382 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-31", "doble_articulado": false, "id_norma": "218196", "numero_fuente": "37724", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-01", "vigencias": [{"desde": "2003-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-12-01", "fin_vigencia": "", "tipo_version": "3