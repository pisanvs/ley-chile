{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede un suplemento para publicaciones de la C&#xE1;mara de Diputados</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,040.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275888}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Conc&#xE9;dese un suplemento de treinta mil pesos ($ 30,000) al &#xED;tem 3,107 de la partida 14 del Presupuesto del Interior para costear la publicacion de Boletin de Sesiones de la C&#xE1;mara de Diputados i las demas impresiones de esta misma C&#xE1;mara.</div><br></div>", "i": 8275889}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 4 de Diciembre de 1915.- RAMON BARROS LUCO.- E. Villegas E.</div><br></div>", "i": 8275890}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3040", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3040"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE UN SUPLEMENTO PARA PUBLICACIONES DE LA CAMARA DE DIPUTADOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL DE LA NACION", "1915", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1915-12-04", "doble_articulado": false, "id_norma": "23685", "numero_fuente": "11343", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1915-12-14", "vigencias": [{"desde": "1915-12-14", "hasta": "", "tipo_version