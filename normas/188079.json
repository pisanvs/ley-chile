{"html": [{"t": "<div><div class=\"p\">AUTORIZA A SOCIEDAD DISTRIBUIDORA LO ESPEJO LIMITADA PARA DESARROLLAR ACTIVIDADES PESQUERAS QUE INDICA </div><br></div>", "i": 6344311}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 240 del 7 de Julio de 1983, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a la Sociedad Distribuidora Lo Espejo Limitada, domiciliada en la cuidad de Santiago, para elaborar en la l&#xED;nea de congelado los recursos hidrobiol&#xF3;gicos loco, jaiba, congrio y merluza, en las instalaciones ubicadas en calle Lo Sierra 2205, Lo Espejo, Santiago, de Agroindustrial Lo Espejo Ltda.</div><br></div>", "i": 6344312}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 Julio 1983.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6344313}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "240", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-240"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A SOCIEDAD DISTRIBUIDORA LO ESPEJO LIMITADA PARA DESARROLLAR ACTIVIDADES PESQUERAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1983-07-07", "fecha_derogacion": "1989-05-04", "doble_articulado": false, "id_norma": "188079", "numero_fuente": "31626", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1983-07-23", "vigencias": [{"desde": "1989-05-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1983-07-23", "hasta": "1989-05-03", "tipo_version": "0