{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO NUMERO 36 EXENTO, DE 1994 </div></div>", "i": 5940059}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 36 de 27 de Enero de 1994 se ha aprobado al Colegio Horizontes, de la comuna de Vitacura, Santiago, para agregar, a partir de 1994, la asignatura de Historia de Chile en 1&#xB0; y 2&#xB0; a&#xF1;o de Ense&#xF1;anza Media, con una carga horaria de 2 clases semanales.</div><br></div>", "i": 5940060}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 28 de Febrero de 1994.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5940061}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "36", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-36"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO NUMERO 36 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO HORIZONTES", "VITACURA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-01-27", "doble_articulado": false, "id_norma": "19832", "numero_fuente": "34846", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-04-22", "vigencias": [{"desde": "1994-04-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-04-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-04-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1994-04-22", "fecha_actualizacion_texto": "1994-04-22", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estr