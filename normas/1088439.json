{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 7</div><div class=\"p\"> </div></div>", "i": 9682823}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;735, de 9 de marzo de 2016, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1075203&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 533, de 2015</a>, de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la Agrupaci&#xF3;n 7, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para el centro de cultivo que indica en la resoluci&#xF3;n extractada.</div><br></div>", "i": 9682824}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de marzo de 2016.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9682825}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "735 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-735 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 7", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1005897; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-03-09", "doble_articulado": false, "id_norma": "1088439", "numero_fuente": "41409", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-03-16", "vigencias": [{"desde": "2016-03-16", "hasta": "", "tipo_version": "3", "tipo_version_s