{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6384163}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 621, de 28 de marzo de 2002, se expropi&#xF3; el lote de terreno N&#xBA; 48, superficie 895., rol de aval&#xFA;o 104-137, comuna de Curacav&#xED;, para la obra Concesi&#xF3;n Internacional Interconexi&#xF3;n Vial Santiago Valpara&#xED;so Vi&#xF1;a del Mar Tramo 6 A2: Km. 33.200,00 al 33.880,00, Regi&#xF3;n Metropolitana y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Avelina del Carmen Carrera Araya y Otros, ascendente a la cantidad de $6.210.220.- para el lote N&#xBA; 48. </div></div>", "i": 6384164}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6384165}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "621", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-621"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-28", "doble_articulado": false, "id_norma": "198937", "numero_fuente": "37272", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-01", "vigencias": [{"desde": "2002-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MAS", "fecha_ingreso": "2002-06-06", "fecha_version": "2002-06-01", "fecha_actualizacion_texto": "20