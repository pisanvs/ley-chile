{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 342 EXENTO, DE 1996 </div></div>", "i": 5943932}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 342, de fecha 18 de junio de 1996 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; el plan y programas de estudios del Centro de Formaci&#xF3;n T&#xE9;cnica Inacap de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida en la Sede N&#xB0; 8 Col&#xF3;n, a contar del a&#xF1;o 1996:</div><div class=\"p\"> Carrera : Secretariado Ejecutivo Biling&#xFC;e con</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  menci&#xF3;n en Comercio Exterior.</div><div class=\"p\"> T&#xED;tulo&nbsp; : T&#xE9;cnico de Nivel Superior en</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Secretariado Ejecutivo Biling&#xFC;e (4 semestres)</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  T&#xE9;cnico de Nivel Superior en Secretariado</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Ejecutivo Biling&#xFC;e con menci&#xF3;n en Comercio</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Exterior (1 semestre adicional).</div><br></div>", "i": 5943933}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 9 de julio de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943934}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "342", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-342"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 342 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "CENTRO FORMACION TECNICA INACAP", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tra