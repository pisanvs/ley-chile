{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6479675}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA; 616, de fecha 27 de abril de 2004, se expropi&#xF3; el lote de terreno N&#xBA; 1, superficie 628 m&#xB2;, rol de aval&#xFA;o en tr&#xE1;mite, comuna de Lolol, para la obra &quot;Camino Portezuelo - Los Tricahues, Rol I-580, sector Puente Los Tricahues, Km. 0,270 a Km. 0,338&quot;, VI Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietaria Jeorgina del Carmen o Jeorgina Pizarro D&#xED;az, ascendente a la cantidad de $1.115.933.</div><br></div>", "i": 6479676}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6479677}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "616 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-616 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-27", "doble_articulado": false, "id_norma": "225326", "numero_fuente": "37861", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-05-15", "vigencias": [{"desde": "2004-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2004-05-17", "fecha_version": "2004-05-15", "fecha_actualizacion_texto": "2004-05-15", "tipo_t