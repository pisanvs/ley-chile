{"html": [{"t": "<div><br><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A AGR&#xCD;COLA Y FORESTAL LAS ASTAS S.A.</div></div>", "i": 8788589}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del SII, por resoluci&#xF3;n DRE08/N&#xBA; Ex. 9.074, de fecha 25 de septiembre de 2009, otorga a Agr&#xED;cola y Forestal Las Astas S.A., RUT N&#xBA; 76.667.500-K, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las ventas de ganado vivo, establecido en la resoluci&#xF3;n N&#xBA; Ex. 3.721 de 28-07-2000 de la Direcci&#xF3;n Nacional. La presente autorizaci&#xF3;n surtir&#xE1; efecto a partir del d&#xED;a primero del mes siguiente a la fecha de publicaci&#xF3;n de este extracto en el Diario Oficial.- </div></div>", "i": 8788590}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Sergio Flores Guti&#xE9;rrez, Director Regional.</div></div>", "i": 8788591}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9074 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-9074 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SUBSECRETARÍA DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A AGRÍCOLA Y FORESTAL LAS ASTAS S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-09-25", "doble_articulado": false, "id_norma": "1007027", "numero_fuente": "39482", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-10-09", "vigencias": [{"desde": "2009-10-09", "hasta": "", "tipo_version": "3", "tipo_version_