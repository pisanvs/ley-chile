{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6344005}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n n&#xFA;mero 1.567, de 13 de julio de</div><div class=\"p\">2001, de esta Subsecretar&#xED;a, decl&#xE1;rase que con fecha 9</div><div class=\"p\">de febrero de 2001 ha quedado sin efecto la resoluci&#xF3;n</div><div class=\"p\">N&#xBA;1.897 de 2000, de esta Subsecretar&#xED;a, que autoriz&#xF3; a</div><div class=\"p\">SOCIEDAD PESQUERA LANGEVELD LIMITADA para desarrollar</div><div class=\"p\">actividad extractiva con una embarcaci&#xF3;n en</div><div class=\"p\">construcci&#xF3;n, en conformidad con lo dispuesto en el</div><div class=\"p\">art&#xED;culo 9&#xBA; de la ley N&#xBA; 19.713. Dicha nave queda permanente e irrevocablemente excluida de la actividad pesquera extractiva.</div><br></div>", "i": 6344006}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de julio de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6344007}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1567", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1567"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-07-13", "doble_articulado": false, "id_norma": "187970", "numero_fuente": "37020", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-07-25", "vigencias": [{"desde": "2001-07-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-07-25", "fin_vigen