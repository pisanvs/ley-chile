{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6062099}, {"t": "<div><div class=\"p\">Por Decreto M.O.P. No. 181, de 25 de Julio de 1990, se expropiaron los lotes N&#xB0;s. 22, 42 y 44, superficies 2.969 m2., 1.182 m2. y 1.217 m2., respectivamente, rol de aval&#xFA;o de los tres lotes 5004-70, Comuna de Coronel, para la obra Ampliaci&#xF3;n Ruta 160, Camino Concepci&#xF3;n - Coronel y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios Omar Vargas Valeria, Hilda Uribe Fuentes y Jos&#xE9; Lino L&#xF3;pez Sanzana, ascendente a las cantidades de S 4.870.128, $ 1.571.602 y $ 1.321.987.-</div><br></div>", "i": 6062100}, {"t": "<div><div class=\"p\">Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 6062101}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "181", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-181"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-07-25", "doble_articulado": false, "id_norma": "82382", "numero_fuente": "33760", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-09-01", "vigencias": [{"desde": "1990-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PGA", "fecha_ingreso": "1998-01-02", "fecha_version": "1990-09-01", "fecha_actualizacion_texto": "1990-09-01", "tipo_tratado": ""}