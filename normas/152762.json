{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6224097}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 1.705 de 26 de Agosto de 1987, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Proporcionales que corresponden a parcelas N&#xB0;s. 1 a la 6 y 14 a la 21 y sitios N&#xB0;s. 5 al 9 del Proyecto de Parcelaci&#xF3;n &quot;Los Casta&#xF1;os&quot; de la comuna de Maule, S&#xE9;ptima Regi&#xF3;n, formado por predios &quot;Fundo San Manuel e Islas Chaparros o Los Casta&#xF1;os&quot;</div><div class=\"p\">&quot;Las Delicias de Chequ&#xE9;n&quot; y &quot;Trafalgar antes Beansejour&quot;. Los Derechos de Agua se extraen del canal San Manuel o Montero, derivado del rio Maule y Derrames captados del Esterillo o Estero Maquehua.</div><div class=\"p\">Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.- </div></div>", "i": 6224098}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6224099}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1705 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1705 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-26", "doble_articulado": false, "id_norma": "152762", "numero_fuente": "32860", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-01", "vigencias": [{"desde": "1987-09-01", "hasta": "", "tipo