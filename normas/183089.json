{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6327317}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por R.M. (Ex.) N&#xBA; 36, de 15 de marzo de 2001, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ac&#xF3;gese el recurso de reclamaci&#xF3;n interpuesto por MARCELINO GONZALEZ RIVERA, en contra de la resoluci&#xF3;n N&#xBA; 172 de 2001, de la Subsecretar&#xED;a de Pesca. Consid&#xE9;rese en la determinaci&#xF3;n de su l&#xED;mite m&#xE1;ximo de captura en la unidad de pesquer&#xED;a Merluza com&#xFA;n, las siguientes capturas totales de la nave &apos;&apos;Don Marcelo&apos;&apos;, en los meses que se indican:</div><br><div class=\"p\">Mayo de 2000: 228,598 toneladas Junio de 2000: 151,107 toneladas </div></div>", "i": 6327318}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; de Gregorio Rebeco, Ministro de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6327319}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "36 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-36 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-15", "doble_articulado": false, "id_norma": "183089", "numero_fuente": "36919", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-22", "vigencias": [{"desde": "2001-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-03-22", "fin_vigencia