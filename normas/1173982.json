{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10319783}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xBA; 130 de 1 febrero 2022, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos relativas a la actividad denominada &quot;Conexi&#xF3;n de uni&#xF3;n domiciliaria de alcantarillado de la comuna de Coyhaique&quot;, y autoriz&#xF3; a la Municipalidad de Coyhaique para realizar la siguiente intervenci&#xF3;n en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - Corte total de v&#xED;a en calle Pedro Aguirre Cerda N&#xBA; 676, entre calles Simpson y calle Lautaro, de la ciudad de Coyhaique, los trabajos se desarrollar&#xE1;n durante 5 d&#xED;as corridos, una vez aprobada la presente resoluci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10319784}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andrea Mac&#xED;as Palma, Gobernadora Regional.- Javier Gonz&#xE1;lez Jara, Asesor Jur&#xED;dico.</div><br></div>", "i": 10319785}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "130 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-130 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2102050"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-02-01", "doble_articulado": false, "id_norma": "1173982", "numero_fuente": "43209", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-03-22", "vigencias": [{"desde": "2022-03-22", "hasta": "", "tipo_version": "3", "tip