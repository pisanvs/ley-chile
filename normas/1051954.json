{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9359497}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. (Exento) N&#xBA; 826 de 20 de mayo de 2013, que dej&#xF3; sin efecto los Decretos MOP <a href=\"https://www.leychile.cl/Navegar?idNorma=1029081&amp;idParte=0&amp;idVersion=\">N&#xB0; 1620</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1029132&amp;idParte=0&amp;idVersion=\">1671 de 18 de agosto de 2011</a>, que orden&#xF3;, la expropiaci&#xF3;n de los lotes N&#xB0; 2-A y 2-B, por no ser necesarios para la obra p&#xFA;blica &quot;Proyecto Definitivo Puente Quehue, camino Puc&#xF3;n &#x2013; Curarrehue, sector Km. 0,00000 a Km. 0,76686&quot;, Comuna de Puc&#xF3;n, IX Regi&#xF3;n. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA; 2186, de 1978. </div><br></div>", "i": 9359498, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9359499}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "826 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-826 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-05-20", "doble_articulado": false, "id_norma": "1051954", "numero_fuente": "40585", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-06-15", "vigencias": [{"desde": "2013-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-06-15", "fin_vigencia": "