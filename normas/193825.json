{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6366043}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.983, de 30 de noviembre de 2001, se expropi&#xF3; el lote de terreno N&#xBA;11-B, superficie 271 m2., rol de aval&#xFA;o 2131-17, comuna de Puerto Montt, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: R&#xED;o Bueno - Puerto Montt. Sector: Rotonda Cardonal de Kms.</div><div class=\"p\">1.022,900 al 1.023,350, D&#xE9;cima Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Alberto Ampuero Vivar, ascendente a la cantidad de $9.245.826. </div></div>", "i": 6366044}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6366045}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1983", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1983"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-30", "doble_articulado": false, "id_norma": "193825", "numero_fuente": "37160", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-15", "vigencias": [{"desde": "2002-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2002-01-16", "fecha_version": "2002-01-15", "fecha_actualizacion_texto": "2002-01-15", "tipo_trat