{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10096661}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xBA; 47, de 8 de enero de 2020, del Instituto de Salud P&#xFA;blica de Chile, que el producto Papel Higi&#xE9;nico Elite Pro Bio Active, no corresponde a ning&#xFA;n producto de competencia del Instituto de Salud P&#xFA;blica de Chile.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, en el siguiente link: http://www.ispch.cl/resoluciones.- </div></div>", "i": 10096662}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mar&#xED;a Judith Mora Riquelme, Directora (S), Instituto de Salud P&#xFA;blica de Chile.</div></div>", "i": 10096663}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "47 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-47 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1718311; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-01-08", "doble_articulado": false, "id_norma": "1141726", "numero_fuente": "42565", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-01-29", "vigencias": [{"desde": "2020-01-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2020-01-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2020-01-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen