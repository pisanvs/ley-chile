{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6578063}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA; 354, de fecha 30 de junio de 2006, se expropiaron los lotes de terrenos N&#xBA;s 1 y 1, superficie 3.003 y 1.895 m2 respectivamente, rol N&#xBA; 610-71, comuna de San Ignacio, VIII Regi&#xF3;n para la obra &quot;Proyecto Laja Diguill&#xED;n, Canal Matriz Diguill&#xED;n Larqui Canal alimentador N&#xBA; 7, Km. 0,004 al Km.0,125 y proyecto Laja Diguill&#xED;n, Canal Matriz Diguill&#xED;n Larqui, lotes adicionales, Canal Matriz Km. 0,000 al Km. 0,113&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Pedro Celestino Rojas, ascendente a la cantidad de $3.991.793.</div><br></div>", "i": 6578064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6578065}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "354 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-354 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-30", "doble_articulado": false, "id_norma": "251863", "numero_fuente": "38528", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-08-01", "vigencias": [{"desde": "2006-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "in