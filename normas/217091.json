{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.321 EXENTA, DE 2003 </div></div>", "i": 7305343}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.321 de fecha 24 de octubre del a&#xF1;o 2003, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriz&#xF3; originariamente a la empresa chilena Manuel Octavio Esp&#xED;ndola S&#xE1;nchez (Pullman del Sur), para efectuar servicio internacional de transporte terrestre de pasajeros entre Santiago (Chile) y Asunci&#xF3;n (Paraguay), en tr&#xE1;nsito por territorio argentino y viceversa, con dos (2) frecuencias semanales, de ida y vuelta, utilizando el paso fronterizo: Sistema Cristo Redentor.</div><br></div>", "i": 7305344}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Claudio Navea N&#xFA;&#xF1;ez, Jefe Divisi&#xF3;n Administraci&#xF3;n y Finanzas.</div><br></div>", "i": 7305345}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1321 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1321 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.321 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-24", "doble_articulado": false, "id_norma": "217091", "numero_fuente": "37708", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-11-12", "vigencias": [{"desde": "2003-11-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-11-12", "fin_vigencia": ""}, "vigencias_version_norma":