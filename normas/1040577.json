{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9262113}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (Exento) N&#xBA;772, de fecha 30 de abril de 2012, y de conformidad a lo dispuesto en el art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;21, superficie 631,5 m2, rol de aval&#xFA;o 2323-12, para la obra: &quot;MEJORAMIENTO PASADAS URBANAS RUTA S-30-40 TEMUCO-CARAHUE, TRAMO LABRANZA&quot;, comuna de Temuco, Provincia de Caut&#xED;n, Regi&#xF3;n de La Araucan&#xED;a. La Comisi&#xF3;n de Peritos integrada por Enrique Augusto Vallete de la Harpe, Yaschala Maribel Y&#xE1;&#xF1;ez Riffo y Mar&#xED;a Soledad N&#xFA;&#xF1;ez Arroyo, fij&#xF3; el valor de la tasaci&#xF3;n con fecha 20 de julio de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario ELIAS AGUILERA, en la cantidad de $80.235.344.- suma que se pagar&#xE1; al contado.</div></div>", "i": 9262114}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9262115}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "772 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-772 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-04-30", "doble_articulado": false, "id_norma": "1040577", "numero_fuente": "40276", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-01", "vigencias": [{"desde": "2012-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-06-01", "fi