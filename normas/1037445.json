{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9238351}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 191, de 14 de febrero de 2012, de este Ministerio, establ&#xE9;zcase R&#xE9;gimen Artesanal de Extracci&#xF3;n en la VII Regi&#xF3;n, para las pesquer&#xED;as artesanales de Anchoveta y Sardina com&#xFA;n, el cual regir&#xE1; a partir de la fecha de publicaci&#xF3;n del presente decreto de conformidad con la Ley General de Pesca y Acuicultura y hasta el 31 de diciembre de 2016, ambas fechas inclusive.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y del Servicio Nacional de Pesca.</div></div>", "i": 9238352}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de febrero de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9238353}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "191 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-191 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-02-14", "doble_articulado": false, "id_norma": "1037445", "numero_fuente": "40193", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-02-21", "vigencias": [{"desde": "2012-02-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-02-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-02-21"