{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede suplementos el presupuesto del Ministerio de Justicia.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1701.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5950989}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese un suplemento de ocho mil pesos ($ 8 000) al &#xED;tem 1837 de la partida 22 del presupuesto de Justicia, que consulta fondos para atender al servicio de conduccion i aprehension de reos. </div></div>", "i": 5950990}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 15 de Setiembre de 1904.- JERMAN RIESCO.- Alejandro F&#xED;erro.</div><br></div>", "i": 5950991}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1701", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1701"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "Concede suplementos el presupuesto del Ministerio de;Justicia.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1904", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-09-15", "doble_articulado": false, "id_norma": "22860", "numero_fuente": "8008", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1904-09-16", "vigencias": [{"desde": "1904-09-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia