{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9133178}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 806, de 6 de abril de 2011, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad total de la <a href=\"https://www.leychile.cl/Navegar?idNorma=188347&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.451 de 2001</a>, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA DEL ESTRECHO S.A. para continuar actividades pesqueras extractivas con la nave &quot;Curaco&quot;, en virtud de lo dispuesto en el art&#xED;culo 143 letra b de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum citado en Visto de la resoluci&#xF3;n extractada.</div><br></div>", "i": 9133179, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9133180}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "806 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-806 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-04-06", "doble_articulado": false, "id_norma": "1024527", "numero_fuente": "39936", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-04-14", "vigencias": [{"desde": "2011-04-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-04-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-04-14", "fin_vigenci