{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;383 EXENTO, DE 2002 </div></div>", "i": 6384121}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;383 de fecha 3 de mayo de 2002 del Ministerio de Educaci&#xF3;n, se revoca la autorizaci&#xF3;n de funcionamiento de la Sede de Osorno al Instituto Profesional Andali&#xE9;n, a contar del a&#xF1;o 2002.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, se deroga el decreto exento de Educaci&#xF3;n N&#xBA;114 del 10 de abril de 2000 que autoriz&#xF3; el funcionamiento de la Sede de Osorno al Instituto Profesional Andali&#xE9;n.</div><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase presente para todos los efectos legales y administrativos.</div><br><br></div>", "i": 6384122}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de mayo de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6384123}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "383 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-383 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº383 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-03", "doble_articulado": false, "id_norma": "198923", "numero_fuente": "37276", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-06", "vigencias": [{"desde": "2002-06-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-06-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-06-06", "fin_vigencia": "", "tipo_version"