{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A FRUTICOLA OLMUE S.A.</div><br><br></div>", "i": 6520793}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del SII, por resoluci&#xF3;n DRE08/N&#xBA; Ex. 474, de fecha 21 de marzo de 2005, otorga a Frut&#xED;cola Olmu&#xE9; S.A., RUT N&#xBA; 96.687.510-0, la calidad de agente retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las ventas de berries, establecido en la resoluci&#xF3;n N&#xBA; Ex-26, de 24-02-2005 de la Direcci&#xF3;n Nacional. La presente autorizaci&#xF3;n surtir&#xE1; efecto a partir del d&#xED;a primero del mes siguiente a la fecha de publicaci&#xF3;n de este extracto en el Diario Oficial y tendr&#xE1; vigencia hasta el 31-05-2005.-</div><br></div>", "i": 6520794}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Flores Guti&#xE9;rrez, Director Regional. </div></div>", "i": 6520795}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "474 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-474 EXENTA"}, {"tipo": "3", "numero": "DRE-08-474 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-474 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A FRUTICOLA OLMUE S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-03-21", "doble_articulado": false, "id_norma": "236793", "numero_fuente": "38125", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-04-02", "vi