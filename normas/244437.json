{"html": [{"t": "<div><div class=\"p\">CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A DO&#xD1;A MARLENE LUCINDA SOTO PINCHEIRA </div></div>", "i": 6550515}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VII Direcci&#xF3;n Regional Talca del SII, por resoluci&#xF3;n exenta N&#xBA; 978, de fecha 9 de noviembre de 2005, concede a la contribuyente do&#xF1;a Marlene Lucinda Soto Pincheira, RUT N&#xBA; 12.963.652-1, a contar del d&#xED;a primero del mes siguiente de la fecha de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado del cambio de sujeto en las Ventas de Arroz, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 15&#xBA; de la resoluci&#xF3;n Ex. N&#xBA; 1341/2000, de la Direcci&#xF3;n Nacional.</div><br></div>", "i": 6550516}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Mirtha Barra Paredes, Directora Regional.</div><br><br></div>", "i": 6550517}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "978 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-978 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VII DIRECCIÓN REGIONAL DE TALCA"], "titulo_norma": "CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A DOÑA\nMARLENE LUCINDA SOTO PINCHEIRA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-09", "doble_articulado": false, "id_norma": "244437", "numero_fuente": "38325", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-11-30", "vigencias": [{"desde": "2005-11-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-11-30", "fin_vigencia": ""}, "