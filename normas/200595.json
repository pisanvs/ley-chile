{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6389374}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.377, de 3 de julio de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a COMERCIALIZADORA PRODUCTOS DEL MAR CALETA ANGOSTA LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en Caleta Angosta s/n, Huasco, III Regi&#xF3;n, en donde podr&#xE1; elaborar, en las l&#xED;neas de proceso que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Alga seca, Picado de algas: Chasc&#xF3;n, Huiro, Huiro palo.</div><br></div>", "i": 6389375}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de julio de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6389376}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1377", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1377"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-07-03", "doble_articulado": false, "id_norma": "200595", "numero_fuente": "37311", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-18", "vigencias": [{"desde": "2002-07-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-07-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2002-07-18", "fecha_ver