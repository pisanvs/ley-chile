{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7283636}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.073, de 31 de mayo de 2001, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de las resoluciones N&#xBA; 1.452 de 1996 y N&#xBA; 588 de 1999, ambas de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA LA PENINSULA S.A. para realizar actividades con la nave &quot;Loa 2&quot;, respecto de los recursos Anchoveta y Sardina com&#xFA;n, en el &#xE1;rea mar&#xED;tima de la X Regi&#xF3;n.</div><br></div>", "i": 7283637}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de mayo de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7283638}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1073", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1073"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-31", "doble_articulado": false, "id_norma": "186268", "numero_fuente": "36982", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-06-08", "vigencias": [{"desde": "2001-06-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-06-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-06-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "CNB", "fecha_ingreso": "2001-06-