{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7277857}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.248, de 18 de octubre de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a EMPRESA CONSTRUCCIONES Y CARPINTERIA NAVAL CONCAR S.A., para ampliar actividades pesqueras de transformaci&#xF3;n autorizadas por resoluciones N&#xBA; 1.159 y N&#xBA; 1.441, ambas de 1996, N&#xBA; 701, de 1998 y N&#xBA; 122 de 1999, todas de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Lote 5 D-5, Sector R&#xED;o Guanaco, comuna de Navarino, Puerto Williams, XII Regi&#xF3;n, en las l&#xED;neas de elaborac&#xF3;n de Congelado, Fresco-enfriado, Conserva y Ahumado el recurso hidrobiol&#xF3;gico Gamba Aristaedmorphia foliacea.</div><div class=\"p\">&nbsp; &nbsp;  La materia prima deber&#xE1; cumplir con las normas de importaci&#xF3;n.</div><br></div>", "i": 7277858}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de octubre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7277859}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2248", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2248"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-18", "doble_articulado": false, "id_norma": "176935", "numero_fuente": "36797", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-26", "vigencias": [{"desde": "2000-10-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "