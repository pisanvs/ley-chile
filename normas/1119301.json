{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 48, DE 31 DE MAYO DE 2018</div></div>", "i": 9920467}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n del Servicio de Impuestos Internos N&#xB0; 48, del 31 de mayo de 2018, que establece obligaci&#xF3;n de presentar anualmente informaci&#xF3;n sobre cuentas financieras, de conformidad al art&#xED;culo 62 ter del C&#xF3;digo Tributario.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en mayo de 2018. </div></div>", "i": 9920468}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "48", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-48"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 48, DE 31 DE MAYO DE 2018", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1409820", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2018-05-31", "fecha_derogacion": "2024-10-16", "doble_articulado": false, "id_norma": "1119301", "numero_fuente": "42075", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2018-06-06", "vigencias": [{"desde": "2024-10-16", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2018-06-06", "hasta": "2024-10-15", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2024-10-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vige