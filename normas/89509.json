{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION No 32</div><br><div class=\"p\">Certifico que el Consejo de este Banco Central de Chile en su Sesi&#xF3;n No 32, celebrada el 31 de mayo de 1990, adopt&#xF3; los siguientes acuerdos:</div><br><div class=\"p\">32-13-900531- Se suspende colocaci&#xF3;n de Pagar&#xE9;s Reajustables del Banco Central de Chile con Pago en Cupones (P.R.C.). </div></div>", "i": 6082847}, {"t": "<div><div class=\"p\">Se acord&#xF3; suspender la colocaci&#xF3;n de Pagar&#xE9;s Reajustables del Banco Central de Chile con Pago en Cupones (P.R.C.), a contar del d&#xED;a 1&#xBA; de junio de 1990.</div><br></div>", "i": 6082848}, {"t": "<div><div class=\"p\">Santiago, 31 de mayo de 1990.- V&#xED;ctor Vial del R&#xED;o, Secretario General Interino.</div><br></div>", "i": 6082849}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "32", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-32"}, {"tipo": "5", "numero": "32-13", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-32-13"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO BANCO CENTRAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-05-31", "doble_articulado": false, "id_norma": "89509", "numero_fuente": "33684", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-06-01", "vigencias": [{"desde": "1990-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-06-01", "fin_vigencia": "", "tipo_versi