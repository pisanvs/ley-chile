{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 9.755 EXENTA, DE 2013</div></div>", "i": 9394349}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 9.755, de 10 de diciembre de 2013, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Master Gesti&#xF3;n en Capacitaci&#xF3;n Limitada (MasterChile Ltda.)&quot;, RUT 76.915.460-4 contenida en la resoluci&#xF3;n exenta N&#xBA; 1.648 de 7 de marzo de 2008, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del art. 21 de la ley 19.518.</div></div>", "i": 9394350}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (S).</div></div>", "i": 9394351}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9755 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-9755 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 9.755 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-12-10", "doble_articulado": false, "id_norma": "1057609", "numero_fuente": "40742", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-12-27", "vigencias": [{"desde": "2013-12-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-12-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-12-27", "fin_vigencia": "", "tipo_version":