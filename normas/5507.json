{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Decreto con fuerza de ley n&#xFA;mero 357</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 357.- Santiago, 20 de Mayo de 1931.- Vistos estos antecedentes y las facultades extraordinarias que me confiere la ley N&#xB0; 4,945, de 6 de Febrero de 1931.</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 7121447}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Directorio del Casino del Balneario de Vi&#xF1;a del Mar, a que se refiere la ley N&#xB0; 4,283, de 7 de Febrero de 1928 (art. 8&#xB0; inc. tercero), se aumentar&#xE1; en un miembro, que tendr&#xE1; car&#xE1;cter de representante de la Beneficencia P&#xFA;blica, y que ser&#xE1; designado por la Junta de Beneficencia de Valpara&#xED;so.</div><br></div>", "i": 7121448}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Bolet&#xED;n de Leyes y Decretos del Gobierno.- C. IBA&#xD1;EZ C.- Dr. Ricardo Puelma L.- R. Jaramillo.- C. O. Frodden. </div></div>", "i": 7121449}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "357", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-357"}], "organismos": ["MINISTERIO DE BIENESTAR SOCIAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CASINO", "VI A DEL MAR", "COMPOSICION", "DIRECTORIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-05-20", "doble_articulado": false, "id_norma": "5507", "numero_fuente": "15985", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-05-30", "vigencias": [{"desde": "1931-05-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "193