{"html": [{"t": "<div><br><div class=\"p\">ANDHA CHILE</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 9658807}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  N&#xE9;lida Victoria Torres Salazar, Presidenta de la Directiva Central Provisional del Partido Andha Chile, en formaci&#xF3;n, con fecha 11 de diciembre de 2015, ha solicitado la constituci&#xF3;n legal del partido en las Regiones IV de Coquimbo, XI del General Carlos Ib&#xE1;&#xF1;ez del Campo, XII de Magallanes de la Ant&#xE1;rtica Chilena. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de 1.170 afiliaciones.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el <a href=\"https://www.leychile.cl/Navegar?idNorma=29994&amp;idParte=8285857&amp;idVersion=\">art&#xED;culo 17&#xBA;</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=29994&amp;idParte=0&amp;idVersion=\">ley N&#xBA; 18.603</a>, por resoluci&#xF3;n O-N&#xBA; 255, de fecha 17 de diciembre de 2015.</div><br></div>", "i": 9658808}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Elizabeth Cabrera Burgos, Directora (S).</div></div>", "i": 9658809}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "255", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-255"}, {"tipo": "3", "numero": "O-255", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-255"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "ANDHA CHILE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 979123; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-12-17", "doble_articulado": false, "id_norma": "1085675", "numero_fuente": "41339", "tipo_version": "3", "tipo