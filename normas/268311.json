{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7361439}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.477, de 6 de diciembre de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a ROBERTO GERM&#xC1;N CALLEJAS &#xC1;NGEL para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Argande&#xF1;a N&#xBA; 845, Parte Alta, Coquimbo, para elaborar en las l&#xED;neas de proceso de cocido, fresco enfriado, fresco refrigerado y congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 7361440}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de diciembre de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7361441}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3477 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3477 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-12-06", "doble_articulado": false, "id_norma": "268311", "numero_fuente": "38958", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-01-11", "vigencias": [{"desde": "2008-01-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-01-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-01-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fech