{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE EXPROPIACION </div></div>", "i": 6096861}, {"t": "<div><div class=\"p\">Alcalde de I. Municipalidad de Conchal&#xED;, mediante Decreto Exento No. 486 de 31 de Octubre de 1389, se notific&#xF3; el Decreto Exento No. 415 de fecha 13 de Septiembre de 1989 que orden&#xF3; expropiaci&#xF3;n parcial del inmueble ubicado en calle La Serena No. 796, Rol de Aval&#xFA;o No. 1045 37, en el sentido de los deslindes particulares que quedan como sigue: Norte:</div><div class=\"p\">20,80 mts. con resto del predio; Sur; 20,60 mts. con resto del predio; Oriente: 58,00 mts. con predios Rol de Aval&#xFA;o N&#xB0;s 1045-36 y 1045-1; Poniente: 56,10 mts. con predio Rol de Aval&#xFA;o No. 1045-37. (Fdo.) </div></div>", "i": 6096862}, {"t": "<div><div class=\"p\">Jaime Ugarte Fr&#xED;as, Alcalde de Conchal&#xED;.- Neftal&#xED; Past&#xE9;n Ibarra, Secretario Municipal.</div><br></div>", "i": 6096863}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "486", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-486"}], "organismos": ["MUNICIPALIDAD DE CONCHALÍ"], "titulo_norma": "EXTRACTO DE EXPROPIACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-10-31", "doble_articulado": false, "id_norma": "94366", "numero_fuente": "33522", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-11-15", "vigencias": [{"desde": "1989-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_