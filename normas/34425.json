{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291973}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 353, de 24 de Mayo de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 1&#xB0; de la Resoluci&#xF3;n N&#xB0; 1118, de 1990, de esta Subsecretar&#xED;a, que fij&#xF3; las caracter&#xED;sticas n&#xE1;uticas de la nave &quot;Vikingo&quot;, autorizada a COMPA&#xD1;IA PESQUERA CAMANCHACA S.A., R.U.T.</div><div class=\"p\">N&#xB0; 93.711.000-6, en el sentido de se&#xF1;alar que la capacidad de bodega de dicha embarcaci&#xF3;n es de 1.284,6 m3 y no como all&#xED; se indica.</div><br></div>", "i": 8291974, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 24 de Mayo de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8291975}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "353", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-353"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMPANIA PESQUERA CAMANCHACA S.A.", "MODIFICACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1993-05-24", "fecha_derogacion": "2005-03-30", "doble_articulado": false, "id_norma": "34425", "numero_fuente": "34580", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1993-06-02", "vigencias": [{"desde": "2005-03-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1993-06-02", "hasta": "2005-03-29", "tipo_version": "0", "tip