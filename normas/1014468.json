{"html": [{"t": "<div><br><div class=\"p\">ESTABLECE ORGANIZACI&#xD3;N DE LA DIRECCI&#xD3;N DE GRANDES CONTRIBUYENTES</div><br></div>", "i": 8933725}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 95, del 8 de junio de 2010, que establece organizaci&#xF3;n de la Direcci&#xF3;n de Grandes Contribuyentes.</div><div class=\"p\">&nbsp; &nbsp;  Establece las unidades de la Direcci&#xF3;n de Grandes Contribuyentes que realizar&#xE1;n las labores de fiscalizaci&#xF3;n que le corresponden.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en junio de 2010.</div></div>", "i": 8933726}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "95 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-95 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ESTABLECE ORGANIZACIÓN DE LA DIRECCIÓN DE GRANDES CONTRIBUYENTES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2010-06-08", "fecha_derogacion": "2023-06-30", "doble_articulado": false, "id_norma": "1014468", "numero_fuente": "39684", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2010-06-12", "vigencias": [{"desde": "2023-06-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2010-06-12", "hasta": "2023-06-29", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigenc