{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6404185}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.360, de 30 de octubre de 2002, modif&#xED;case el numeral 4&#xBA; de la resoluci&#xF3;n N&#xBA; 1.696, de 2002, modificada mediante resoluciones N&#xBA; 1.832 y N&#xBA; 1.901, ambas de 2002, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE INVESTIGACION PESQUERA OCTAVA REGION (INPESCA) para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto FIP N&#xBA; 2002-14 &quot;Evaluaci&#xF3;n del stock desovante de anchoveta y sardina com&#xFA;n entre la V y X Regiones, a&#xF1;o 2002&quot;, en el sentido de se&#xF1;alar que la pesca de investigaci&#xF3;n y la fase de cruceros de prospecci&#xF3;n de huevos y adultos se extender&#xE1;n hasta el 15 de noviembre de 2002.</div><br></div>", "i": 6404186}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de octubre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6404187}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2360", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2360"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-10-30", "doble_articulado": false, "id_norma": "205028", "numero_fuente": "37420", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-11-28", "vigencias": [{"desde": "2002-11-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"