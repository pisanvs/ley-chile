{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 76, DE 2000 </div></div>", "i": 6302952}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n ministerial N&#xBA; 76, de fecha 4 de agosto de 2000, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la personalidad jur&#xED;dica de la &apos;&apos;Asociaci&#xF3;n Gremial de Due&#xF1;os de Camiones de la Provincia de Huasco A.G.&apos;&apos;, inscrita bajo el N&#xBA; 1.800 del Registro que para tal efecto lleva este ministerio, por haberse configurado respecto de ella, la causal de cancelaci&#xF3;n contemplada en el art&#xED;culo 18 N&#xBA; 2, letra d), del DL N&#xBA; 2.757, de 1979.</div><br></div>", "i": 6302953}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alvaro D&#xED;az P&#xE9;rez, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6302954}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "76", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-76"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 76, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-08-04", "doble_articulado": false, "id_norma": "176207", "numero_fuente": "36777", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-02", "vigencias": [{"desde": "2000-10-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-10-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-10-0