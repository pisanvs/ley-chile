{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9204281}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. (EXENTO) N&#xBA;3301 de 25 de octubre de 2011, se modific&#xF3; el numeral primero y segundo del Decreto MOP N&#xBA;1981 de 17 de noviembre de 2009, que orden&#xF3;, la expropiaci&#xF3;n del lote N&#xBA;40, en la parte que se refiere al kilometraje final del lote, rol de aval&#xFA;o y al nombre del expropiado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA;2186, de 1978. </div></div>", "i": 9204282}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9204283}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3301 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-3301 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-10-25", "doble_articulado": false, "id_norma": "1032729", "numero_fuente": "40110", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-11-15", "vigencias": [{"desde": "2011-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "20652", "fecha_ingreso": "2011-11-16", "fecha_version": "2011-11-15", "fecha_actualizacion_texto": "2011-11-16", "tipo_tratado": ""},