{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 341 EXENTO, DE 1993 </div></div>", "i": 7161657}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 341 de fecha 1 de Julio de 1993 del Ministerio de Educaci&#xF3;n, se sustituy&#xF3; el art&#xED;culo 1&#xB0; del Decreto Exento de Educaci&#xF3;n N&#xB0; 235 del 24 de Noviembre de 1987 correspondiente al Instituto Profesional VIPRO, por el siguiente nuevo:</div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1&#xB0;: Autor&#xED;zase el funcionamiento del Instituto Profesional que se indica, organizado por la persona jur&#xED;dica que se se&#xF1;ala:</div><br><div class=\"p\"> Nombre de la Instituci&#xF3;n : Instituto Profesional VIPRO.</div><div class=\"p\"> Domicilio&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Santiago.</div><div class=\"p\"> Organizador&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Sociedad Instituto</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Profesional Vicente</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; P&#xE9;rez Rosales Limitada</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; o I.P. VIPRO Limitada.&quot;.</div><br></div>", "i": 7161658}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 5 de Septiembre de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 7161659}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "341 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-341 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 341 EXENTO, DE 1993", "fuente": "Diario Oficial", "resumenes": [], 