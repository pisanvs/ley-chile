{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;1.035 EXENTO, DE 1998</div><br><br></div>", "i": 7242756}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;1.035 de fecha 10 de noviembre de 1998 del Ministerio de Educaci&#xF3;n, se rectific&#xF3; el decreto N&#xBA;270 del 20 de junio de 1994 correspondiente al Instituto Profesional Santo Tom&#xE1;s, en el sentido de se&#xF1;alar que la carrera aprobada por el Consejo Superior de Educaci&#xF3;n por Acuerdo N&#xBA;22 del 27 de enero de 1994, es de &apos;&apos;Ingenier&#xED;a de Ejecuci&#xF3;n en Administraci&#xF3;n con menci&#xF3;n en Turismo y Hoteler&#xED;a&apos;&apos;, conducente al t&#xED;tulo profesional de Ingeniero de Ejecuci&#xF3;n en Administraci&#xF3;n con menci&#xF3;n en Turismo y Hoteler&#xED;a.</div><br></div>", "i": 7242757}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de noviembre de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7242758}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1035 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1035 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº1.035 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-10", "doble_articulado": false, "id_norma": "128485", "numero_fuente": "36241", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-12-17", "vigencias": [{"desde": "1998-12-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-12-17", "fin_vigencia": ""}, "vigen