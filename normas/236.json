{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xB0; 434</div><div class=\"p\">&nbsp; &nbsp; 434-04-950628 - Tasa de inter&#xE9;s para pago diferido de derechos de Aduana.</div><br></div>", "i": 5843733}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Se acord&#xF3;, en conformidad con lo establecido en la letra c) del Art. N&#xB0; 10 de la Ley N&#xB0; 18.634, que la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de derechos de Aduana durante el Semestre que expira el 31 de Diciembre de 1995, ser&#xE1; de 11.2% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.</div><br></div>", "i": 5843734}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 28 de Mayo de 1995.- V&#xED;ctor Vial del R&#xED;o, Ministro de Fe.</div><br></div>", "i": 5843735}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "434", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-434"}, {"tipo": "5", "numero": "434-04", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-434-04"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO BANCO CENTRAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA INTERES", "PAGO DIFERIDO", "DERECHOS ADUANEROS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-28", "doble_articulado": false, "id_norma": "236", "numero_fuente": "35206-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-07-01", "vigencias": [{"desde": "1995-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia