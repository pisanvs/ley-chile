{"html": [{"t": "<div><div class=\"p\">Donativos patri&#xF3;ticos</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago i diciembre 15 de 1817</div></div>", "i": 10235008}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Don Nicolas de Echeverr&#xED;a ser&#xE1; reconocido por uno de los mejores republicanos amantes de la libertad e independencia de su pais por su ofrenda de cien pesos, que equivale a una de las mayores sumas de otros donantes, por constar al Gobierno el estado de su escasa fortuna. D&#xE9;nsele a su nombre las gracias por el Ministerio de Hacienda.</div></div>", "i": 10235009}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  imprimase en la Gazeta su memorial con este decreto i se tome razon. - Cruz. - Astorga. - Dr. Villegas.</div></div>", "i": 10235010}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Donativos patrióticos", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1817-12-15", "doble_articulado": false, "id_norma": "1159373", "numero_fuente": "1817", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1817-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1817-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1817-12-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "906", "fecha_ingreso": "2021-06-01", "fecha_version": "1817-12-15", "fecha_actualizacion_texto": "2021-06-01", "tipo_tratado": ""}, "a