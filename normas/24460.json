{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 5958259}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.o Der&#xF3;gase el decreto-ley n&#xFA;mero 671, de 17 de Octubre de 1925, sobre prohibici&#xF3;n de entrar o salir del territorio chileno, cuando el pa&#xED;s se encuentre en guerra o conmoci&#xF3;n interior.</div><br></div>", "i": 5958260, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 2.o Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 5958261}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, quince de Septiembre de mil novecientos veintes&#xE9;is.- Emiliano Figueroa.- C. Ib&#xE1;&#xF1;ez C. </div></div>", "i": 5958262}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4088", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4088"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TERRITORIO CHILENO", "INGRESO", "SALIDA PROHIBICION", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1926-09-15", "doble_articulado": false, "id_norma": "24460", "numero_fuente": "14585", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1926-09-30", "vigencias": [{"desde": "1926-09-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], 