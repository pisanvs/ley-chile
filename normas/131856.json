{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO&nbsp; N&#xBA; 1.141 EXENTO, DE 1998 </div><br></div>", "i": 6154652}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 1.141 de 30 de diciembre de 1998, se han validado los estudios realizados por los alumnos de los establecimientos que se reg&#xED;an por la ley N&#xBA; 12.446 y se otorgar&#xE1;n por los respectivos Secretarios Regionales Ministeriales de Educaci&#xF3;n las Licencias Medias y seg&#xFA;n los casos, los t&#xED;tulos de T&#xE9;cnicos de Nivel Medio en la especialidad correspondiente.</div><br></div>", "i": 6154653}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de febrero de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6154654}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1141 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1141 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.141 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-12-30", "doble_articulado": false, "id_norma": "131856", "numero_fuente": "36294", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-02-19", "vigencias": [{"desde": "1999-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-02-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-02-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-02-