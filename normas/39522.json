{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DERECHOS DE APROVECHAMIENTO DE AGUAS EN COMUNA DE MELIPILLA </div></div>", "i": 6024204}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n</div><div class=\"p\">Exenta N&#xB0; 1113, de 30 de Junio de 1993, conforme</div><div class=\"p\">art&#xED;culo 5&#xB0; transitorio C&#xF3;digo Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a Parcelas N&#xB0;s. 2, 4, 25, 26, 31, 33-A, 33-B, 34 Lote B y 34 resto; Huertos N&#xB0;s. 1 al 12 y 14 al 34 y Escuela del Proyecto de Parcelaci&#xF3;n de la Colonia &quot;Arturo Lyon Pe&#xF1;a&quot;, formado por el predio Fundo Carmen Bajo de la comuna de Melipilla, Regi&#xF3;n Metropolitana.</div><div class=\"p\">&nbsp; &nbsp; Los derechos de aguas se extraen del R&#xED;o Maipo por Canal Chocal&#xE1;n.</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n hecha conforme art&#xED;culo 13 Ley N&#xB0; 18.377.-</div><br></div>", "i": 6024205}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director Nacional.</div><br></div>", "i": 6024206}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1113", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1113"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "DERECHOS DE APROVECHAMIENTO DE AGUAS EN COMUNA DE\nMELIPILLA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHO APROVECHAMIENTO AGUAS", "ESCUELA PROYECTO PARCELACION COLONIA", "ARTURO LYON PE A", "MELIPILLA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-06-30", "doble_articulado": false, "id_norma": "39522", "numero_fuente": "34615-3", "tipo_version": "3", "tipo_version_s": "Única", "fech