{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297505}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.491, de 20 de Octubre de 1995,</div><div class=\"p\">de esta Subsecretar&#xED;a de Pesca del Ministerio de</div><div class=\"p\">Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la</div><div class=\"p\">solicitud de concesi&#xF3;n de acuicultura presentada por</div><div class=\"p\">SOCIEDAD PESQUERA EL HUINCO LIMITADA, R.U.T. N&#xB0;</div><div class=\"p\">79.851.460-1, para un sector ubicado en Bancos de</div><div class=\"p\">Coihu&#xED;n, Comuna de Puerto Montt, Provincia de</div><div class=\"p\">Llanquihue, X Regi&#xF3;n, en virtud de lo dispuesto en los</div><div class=\"p\">art&#xED;culos 76&#xB0;, 77&#xB0;, 78&#xB0; y 5&#xB0; transitorio, inciso 6&#xB0;, de la Ley General de Pesca y Acuicultura y el art&#xED;culo 14&#xB0; del D.S. N&#xB0; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 652, 1990, de esta Subsecretar&#xED;a, en virtud de lo se&#xF1;alado precedentemente.</div><br></div>", "i": 8297506}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 20 de Octubre de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297507}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1491", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1491"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD PESQUERA EL HUINCO LIMITADA", "CONCESION", "ACUICULTURA", "DENEGACION", "PUERTO MONTT", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tra