{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6592943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.112 de 16 de noviembre de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA ALCAR S.A. para ampliar las actividades pesqueras de transformaci&#xF3;n autorizadas por la resoluci&#xF3;n N&#xBA; 1.332 de 2006, de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Tongoy, Puerto Aldea, Parque Acu&#xED;cola, IV Regi&#xF3;n, en las l&#xED;neas de proceso de cocido, fresco-enfriado, fresco-refrigerado, congelado, seco-salado, ahumado, conserva y harina, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6592944}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de noviembre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6592945}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3112 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3112 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-11-16", "doble_articulado": false, "id_norma": "256184", "numero_fuente": "38638", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-12-14", "vigencias": [{"desde": "2006-12-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-12-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-12-14", "fin_vigencia": "", "tipo_ver