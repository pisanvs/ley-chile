{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295255}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.017, de 10 de agosto de 1995, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por EDUARDO NARCISO</div><div class=\"p\">HERNANDEZ VALDERRAMA, para un centro de cultivo ubicado</div><div class=\"p\">en sector Las Cruces, Bah&#xED;a Chacabuco, Comuna y</div><div class=\"p\">Provincia de Ays&#xE9;n, XI Regi&#xF3;n, por no dar cumplimiento</div><div class=\"p\">el respectivo proyecto t&#xE9;cnico a lo dispuesto en los</div><div class=\"p\">art&#xED;culos 78&#xB0; y 87&#xB0; de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8295256}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 10 de agosto de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295257}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1017", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1017"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "EDUARDO NARCISO HERNANDEZ VALDERRAMA", "LAS CRUCES", "BAHIA CHACABUCO", "AYSEN", "DECIMOPRIMERA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-08-10", "doble_articulado": false, "id_norma": "36034", "numero_fuente": "35248", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-08-21", "vigencias": [{"desde": "1995-08-21"