{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6443253}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 129 de 09 septiembre de 2002, Serviu Regi&#xF3;n Valpara&#xED;so dispuso expropiaci&#xF3;n parcial, conforme art&#xED;culo 87 ley 8.946 y decreto ley 2.186, de 1978, de inmueble ubicado en Limache N&#xBA; 1772, rol aval&#xFA;o 690-006, comuna Vi&#xF1;a del Mar, de presunto dominio de Juan Valls Llebot Comisi&#xF3;n Tasadora integrada por Sres. Paola Domingo Porcella, constructor civil, Alvaro Verdejo Vidal, ingeniero constructor, y Pablo Caria Giurici, constructor civil, seg&#xFA;n Informe de fecha 13 de noviembre de 2002, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 80.182.760.- que ser&#xE1; pagada al contado. </div></div>", "i": 6443254}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Regi&#xF3;n Valpara&#xED;so.</div><br></div>", "i": 6443255}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "129", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-129"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAISO"], "titulo_norma": "ORDENA EXPROPIACIONES PARCIALES DE INMUEBLES QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-09-09", "doble_articulado": false, "id_norma": "215747", "numero_fuente": "37685", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-10-15", "vigencias": [{"desde": "2003-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"i