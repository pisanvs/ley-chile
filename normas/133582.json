{"html": [{"t": "<div><div class=\"p\">CONCEDE AMNISTIA A LOS PROCESADOS CON OCASION DE LA HUELGA EN LOS SERVICIOS DE CORREOS Y TELEGRAFOS</div><br><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente.</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6159524}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico, conc&#xE9;dese amnist&#xED;a a los procesados con ocasi&#xF3;n de la huelga producida &#xFA;ltimamente en los Servicios de Correos y Tel&#xE9;grafos.</div><br></div>", "i": 6159525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto ha transcurrido el plazo de 30 d&#xED;as que fija el art&#xED;culo 55 de la Constituci&#xF3;n Pol&#xED;tica del Estado; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, treinta de Agosto de mil novecientos cincuenta.- GABRIEL GONZALEZ VIDELA.- Humberto Parada. </div></div>", "i": 6159526}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "9665", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-9665"}], "organismos": ["MINISTERIO DE JUSTICIA", "SUBSECRETARIA DE JUSTICIA"], "titulo_norma": "CONCEDE AMNISTIA A LOS PROCESADOS CON OCASION DE LA HUELGA\nEN LOS SERVICIOS DE CORREOS Y TELEGRAFOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1950-08-30", "doble_articulado": false, "id_norma": "133582", "numero_fuente": "21745", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1950-09-04", "vigencias": [{"desde": "1950-09-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}]