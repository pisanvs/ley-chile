{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA;422, DE 1990</div><br><br></div>", "i": 7216829}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento N&#xBA;422 de fecha 28 de Diciembre de 1990 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; al Centro de Formaci&#xF3;n T&#xE9;cnica IPROSEC de Osorno el plan y programas de estudio de la carrera y t&#xED;tulo t&#xE9;cnico que se indica, para impartirse a contar del a&#xF1;o 1990:</div><br><div class=\"p\">Carrera: Administraci&#xF3;n de Empresas.</div><div class=\"p\">T&#xED;tulo : T&#xE9;cnico en administraci&#xF3;n de Empresas.</div><br><div class=\"p\">&nbsp; &nbsp;  Por este mismo cuerpo legal se insert&#xF3; en la Resoluci&#xF3;n Exenta N&#xBA;1988 de 1986 y N&#xBA;2447 de 1989 del Centro mencionado, las adecuaciones introducidas a la carrera de Secretariado Ejecutivo con menci&#xF3;n en Computaci&#xF3;n.</div><br><br></div>", "i": 7216830}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de Julio de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br><br></div>", "i": 7216831}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "422 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-422 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº422, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-28", "doble_articulado": false, "id_norma": "81828", "numero_fuente": "34070", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-09-17", "vigencias": [{"desde": "1991-09-17", "hasta": "", "tipo_version": "3", "tipo_v