{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6076677}, {"t": "<div><div class=\"p\">El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 5.50% anual durante el mes de abril de 1991.</div><div class=\"p\">Asimismo, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de abril de 1991, fue de 5,50% anual.</div><br></div>", "i": 6076678}, {"t": "<div><div class=\"p\">Santiago 03 de mayo de 1991.- Mar&#xED;a Eliana Torres Contreras, Secretario General Subrogante.</div><br></div>", "i": 6076679}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-05-03", "doble_articulado": false, "id_norma": "87594", "numero_fuente": "33960", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-05-06", "vigencias": [{"desde": "1991-05-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-05-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-05-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PGA", "fecha_ingreso": "1998-02-03", "fecha_version": "19