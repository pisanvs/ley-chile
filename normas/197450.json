{"html": [{"t": "<div><div class=\"p\">CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD COMERCIAL CORDILLERA LIMITADA </div></div>", "i": 6379285}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La V Direcci&#xF3;n Regional del Servicio de Impuestos Internos, por resoluci&#xF3;n exenta N&#xBA; 35 del 15 de abril de 2002, concede la calidad de Agente Retenedor del IVA, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, a la Sociedad Comercial Cordillera Limitada, RUT 79.735.320-5, en las adquisiciones de Especies Hidrobiol&#xF3;gicas, conforme a lo establecido en la resoluci&#xF3;n Ex. N&#xBA; 3.311 del 30-06-2000, la cual entr&#xF3; en vigencia el 1 de julio de 2000.-</div><br></div>", "i": 6379286}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco C&#xE1;rcamo Avenda&#xF1;o, Director Regional. </div></div>", "i": 6379287}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "35 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-35 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL DE VALPARAÍSO"], "titulo_norma": "CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD COMERCIAL CORDILLERA LIMITADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-15", "doble_articulado": false, "id_norma": "197450", "numero_fuente": "37249", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-03", "vigencias": [{"desde": "2002-05-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2