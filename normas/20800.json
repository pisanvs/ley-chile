{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 248, DE 1993 </div></div>", "i": 7161345}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto exento N&#xB0; 248 de fecha 25 de mayo de 1993 del Ministerio de Educaci&#xF3;n, se sustituy&#xF3; el inciso 1&#xB0; del art&#xED;culo 1&#xB0; del Decreto Exento de Educaci&#xF3;n N&#xB0; 132 de 05.09.89 correspondiente al Instituto Profesional CENAFOM, por el siguiente nuevo:</div><div class=\"p\">&nbsp; &nbsp; &quot;Autor&#xED;zase el funcionamiento del Instituto Profesional que se indica, organizado por la persona jur&#xED;dica que se se&#xF1;ala:</div><div class=\"p\"> Nombre de la Instituci&#xF3;n:&nbsp; Instituto Profesional</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; CENAFOM</div><div class=\"p\"> Domicilio:&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Santiago.</div><div class=\"p\"> Organizador:&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Sociedad Instituto</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Profesional CENAFOM S.A. o</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; I.P. CENAFOM S.A.&quot;.</div><br></div>", "i": 7161346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 2 de Julio de 1993.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161347}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "248 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-248 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 248, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTIT