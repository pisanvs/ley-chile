{"html": [{"t": "<div><br><div class=\"p\">ORDENA EXPROPIACI&#xD3;N DE INMUEBLES QUE SE&#xD1;ALA</div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9076133}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.030, de fecha 7 de diciembre de 2010, del Serviu IV Regi&#xF3;n de Coquimbo, se orden&#xF3; expropiar, conforme al art&#xED;culo 51 ley 16.391 y DL 2.186/78, el inmueble denominado Lote 57 de superficie aproximada de 248,8 m&#xB2;, Rol N&#xBA; 29-1, de aparente dominio de H&#xE9;ctor Arce Cerda, ubicado en la comuna de Coquimbo. Comisi&#xF3;n de Peritos conformada por profesionales Mar&#xED;a Iris Marcich Moller, Alfredo Prieto Parra, y Luis Jeffery Mercado, seg&#xFA;n informe de 30 de noviembre de 2010, fij&#xF3; indemnizaci&#xF3;n provisional en $39.236.640, pagadero al contado.- </div></div>", "i": 9076134}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director Serviu IV Regi&#xF3;n Coquimbo.</div></div>", "i": 9076135}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1030", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1030"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "IV REGIÓN DE COQUIMBO"], "titulo_norma": "ORDENA EXPROPIACIÓN DE INMUEBLES QUE SEÑALA; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO."], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-07", "doble_articulado": false, "id_norma": "1020770", "numero_fuente": "39835", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-12-15", "vigencias": [{"desde": "2010-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"ini