{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6550846}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.107, de 24 de noviembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a las organizaciones de pescadores artesanales sometidas al R&#xE9;gimen Artesanal de Extracci&#xF3;n en la unidad de pesquer&#xED;a de Merluza del sur de la XI Regi&#xF3;n, pertenecientes a la Flota Norte 1 y Flota Sur 2, para realizar actividades pesqueras extractivas en las fechas que en cada caso se se&#xF1;ala:</div><br><div class=\"p\">a)&nbsp;  Flota Norte 1:&nbsp; 28 de noviembre al 4 de diciembre,</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  ambas fechas inclusive.</div><div class=\"p\">b)&nbsp;  Flota Sur 2:&nbsp; &nbsp; 5 de diciembre al 11 de diciembre,</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  ambas fechas inclusive.</div><br></div>", "i": 6550847}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de noviembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6550848}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4107 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4107 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-24", "doble_articulado": false, "id_norma": "244506", "numero_fuente": "38327", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-12-02", "vigen