{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6357290}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.472, de 28 de septiembre de 2001, se expropi&#xF3; el lote de terreno N&#xBA; 28-1, superficie 307 m2., rol de aval&#xFA;o 3624-33, comuna de Quilpu&#xE9;, para la obra Concesi&#xF3;n Internacional Interconexi&#xF3;n Vial Santiago - Valpara&#xED;so-Vi&#xF1;a del Mar, Troncal Sur-Enlace Quilpu&#xE9; Oriente Ramal Nor-Poniente Km. 96.373,50 al Km.</div><div class=\"p\">97.040,00, Quinta Regi&#xF3;n se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietaria Amparo Granados D&#xED;az Fern&#xE1;ndez, ascendente a la cantidad de $31.195.972. </div></div>", "i": 6357291}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6357292}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1472", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1472"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-09-28", "doble_articulado": false, "id_norma": "191607", "numero_fuente": "37111", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-15", "vigencias": [{"desde": "2001-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2001-11-15", "fecha_