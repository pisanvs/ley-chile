{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294685}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 877 de 21 de Septiembre de 1994 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 1247, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don GUILLERMO PINTO BASCU&#xD1;AN, para operar un establecimiento de cultivo, en un sector del R&#xED;o Pudeto, comuna de Ancud, provincia de Chilo&#xE9;, X Regi&#xF3;n, por haberse caducado la concesi&#xF3;n mar&#xED;tima de acuicultura.- </div></div>", "i": 8294686}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 21 de Septiembre de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294687}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "877", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-877"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["GUILLERMO PINTO BASCUNAN", "CONCESION ACUICULTURA", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-09-21", "doble_articulado": false, "id_norma": "35777", "numero_fuente": "34981", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-10-03", "vigencias": [{"desde": "1994-10-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-10-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-10-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc