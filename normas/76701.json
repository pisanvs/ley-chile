{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8307164}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.392, de 24 de octubre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case la Resoluci&#xF3;n N&#xBA; 1.076, de 1997, que otorg&#xF3; a HELMKE Y COMPA&#xD1;IA LIMITADA, una autorizaci&#xF3;n de acuicultura en la localidad de Chinquihue, comuna de Puerto Montt, provincia de Llanquihue, X Regi&#xF3;n, en orden a agregar como numeral 9, el siguiente:</div><div class=\"p\">&nbsp; &nbsp;  &quot;9.- D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xBA; 2.030, de 1989, de esta Subsecretar&#xED;a, en virtud de lo dispuesto en la presente Resoluci&#xF3;n.&quot;.</div><br></div>", "i": 8307165}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de octubre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8307166}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1392", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1392"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "HELMKE Y COMPA IA LIMITADA", "AUTORIZACION", "ACUICULTURA", "PUERTO MONTT", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-10-24", "doble_articulado": false, "id_norma": "76701", "numero_fuente": "35907", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-11-04", "vigencias": [{"desde": "1997-11-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "v