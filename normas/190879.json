{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 11.755 EXENTA, DE 2001 </div></div>", "i": 6354410}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 11.755, de 9 de octubre de 2001, se aprueba Plan y Programa de Estudios para Cuarto A&#xF1;o de Ense&#xF1;anza Media al Colegio Sagrados Corazones de Manquehue de la comuna de Vitacura, el que ser&#xE1; aplicado a partir del a&#xF1;o escolar 2002, de acuerdo a la gradualidad establecida en el decreto N&#xBA; 220, de 1998, y sus modificaciones. </div></div>", "i": 6354411}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de octubre de 2001.- Juan Ruz Ruz, Jefe Divisi&#xF3;n Educaci&#xF3;n General.</div><br></div>", "i": 6354412}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "11755 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-11755 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 11.755 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-10-09", "doble_articulado": false, "id_norma": "190879", "numero_fuente": "37093", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-10-24", "vigencias": [{"desde": "2001-10-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-10-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-10-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2001-10-24", "fecha_version": "2001-10-24", "fecha_act