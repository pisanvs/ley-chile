{"html": [{"t": "<div><div class=\"p\">AUTORIZA EMISORES ELECTR&#xD3;NICOS </div></div>", "i": 6628329}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 122, de 25 de octubre de 2007, que autoriza a contribuyentes como emisores electr&#xF3;nicos.</div><br><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisores de documentos tributarios RUT 96.767.630-6 y RUT 96.571.220-8 a contar del mes de octubre 2007. En la oficina virtual del SII en Internet se podr&#xE1; consultar los documentos que los contribuyentes est&#xE1;n autorizados a emitir en forma electr&#xF3;nica.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de octubre de 2007.</div><br></div>", "i": 6628330}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "122 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-122 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISORES ELECTRÓNICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-10-25", "doble_articulado": false, "id_norma": "266067", "numero_fuente": "38900", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-10-31", "vigencias": [{"desde": "2007-10-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-10-31", "fin_vigencia": ""}