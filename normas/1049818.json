{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9341323}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 763, de 21 de marzo de 2013, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1028110&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.859, de 2011</a>, que autoriz&#xF3; a PESCA CHILE S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Puerto Williams&quot;, respecto del recurso hidrobiol&#xF3;gico Jibia en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 47&#xB0; L.S. y 57&#xB0; L.S., en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum citado en Visto de la resoluci&#xF3;n extractada.</div><br></div>", "i": 9341324}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de marzo de 2013.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9341325}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "763 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-763 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-03-21", "doble_articulado": false, "id_norma": "1049818", "numero_fuente": "40523", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-04-02", "vigencias": [{"desde": "2013-04-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"