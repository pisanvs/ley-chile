{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.458, DE 1988 </div></div>", "i": 6150158}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.458, de fecha 03 de Junio de 1988, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se aprobaron las adecuaciones introducidas a la carrera de Comunicaci&#xF3;n Audiovisual del Centro de Formaci&#xF3;n T&#xE9;cnica Escuela de Altos Estudios de la Comunicaci&#xF3;n y Educaci&#xF3;n, EACE de Santiago, las que podr&#xE1;n aplicarse a contar del primer semestre acad&#xE9;mico 1988.</div><br></div>", "i": 6150159}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6150160}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1458 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1458 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.458, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-06-03", "doble_articulado": false, "id_norma": "130515", "numero_fuente": "33132", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-07-28", "vigencias": [{"desde": "1988-07-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-07-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-07-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-01-21", "fecha_version