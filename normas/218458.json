{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION SH N&#xBA; 71, DE 2003</div><br><br></div>", "i": 8495901}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Con fecha 4 de diciembre de 2003, el Servicio de Impuestos Internos ha dictado la resoluci&#xF3;n SH N&#xBA; 71 referida a delegaci&#xF3;n de facultades para actualizar en forma centralizada el catastro de bienes ra&#xED;ces en base a la informaci&#xF3;n correspondiente a las declaraciones presentadas por los contribuyentes v&#xED;a Internet.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de esta resoluci&#xF3;n ser&#xE1; publicado en el Bolet&#xED;n del Servicio de Impuestos Internos correspondiente al mes de diciembre y est&#xE1; disponible en Internet en el Sitio Web www.sii.cl.</div><br></div>", "i": 8495902}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "71", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-71"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION SH Nº 71, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FACULTADES", "DELEGACION", "CATASTRO DE BIENES RAICES", "IMPUESTO TERRITORIAL", "FISCALIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-04", "doble_articulado": false, "id_norma": "218458", "numero_fuente": "37732", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-11", "vigencias": [{"desde": "2003-12-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-12-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-12-11", "fin_vigenc