{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 148, DE 1984 </div></div>", "i": 6275965}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n exento N&#xB0; 148, de 14 de Septiembre de 1984, se ha declarado la aplicaci&#xF3;n del decreto supremo de Educaci&#xF3;n exento N&#xB0; 283, de 1981, que aprob&#xF3; el plan especial de estudio para educaci&#xF3;n media del Colegio Bautista de Temuco, en el sentido que se aplica a contar del a&#xF1;o 1982 en los cursos de 1&#xB0;, 2&#xB0; y 3er a&#xF1;o medio, a contar de 1983 en los mismos cursos y a contar del a&#xF1;o 1984 desde 1&#xB0; a 4&#xB0; a&#xF1;o medio. </div></div>", "i": 6275966}, {"t": "<div><div class=\"p\">Santiago, 12 de Febrero de 1985.- Marta Stefanowsky Bandyra, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 6275967}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "148 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-148 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 148, DE 1984", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-09-14", "doble_articulado": false, "id_norma": "168888", "numero_fuente": "32107", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-02-26", "vigencias": [{"desde": "1985-02-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-02-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-02-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": 