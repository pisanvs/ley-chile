{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA ARTICULO 2&#xB0; TRANSITORIO DE LA LEY N&#xB0; 18.893 Teniendo presente que el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 8287636}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Sustit&#xFA;yese en el art&#xED;culo 2&#xB0; transitorio de la Ley N&#xB0; 18.893 la expresi&#xF3;n &quot;treinta y seis meses&quot;, introducida por el art&#xED;culo &#xFA;nico de la Ley N&#xB0; 19.096, por la de &quot;cinco a&#xF1;os&quot;.&quot;.</div><br></div>", "i": 8287637, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 28 de diciembre de 1992.- PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Enrique Krauss Rusque, Ministro del Interior.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud., para su conocimiento.- Saluda a Ud., Belisario Velasco Baraona, Subsecretario del Interior.</div><br></div>", "i": 8287638}], "proyectos": [{"categoria": "Proyecto original", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=882-06", "informacion": "Modifica ley 18893 sobre Organizaciones Comunitarias Territoriales y Funcionales", "nroBoletin": "882-06"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "19192", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-19192"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA ARTICULO 2° TRANSITORIO DE LA LEY N° 18.893", "fuente": "Diario Oficial", "resumenes": [], "materias": ["Organizaciones Comunales", "Ley no. 19.192"], "terminos_libres": ["ORGANIZACIONES COMUNITARIAS TER