{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO RESOLUCION No. 33, DE 1986 </div></div>", "i": 6242508}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 53, de 28 de Abril de 1986, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se dej&#xF3; sin efecto la Resoluci&#xF3;n Ministerial No. 33, de 14 de Marzo de 1986, mediante la cual se cancel&#xF3; la personalidad jur&#xED;dica de la entidad gremial denominada &quot;Asociaci&#xF3;n de Taxis Colectivos No. 7 Cerro Mar, Asociaci&#xF3;n Gremial&quot;.-</div><br></div>", "i": 6242509}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jorge Valenzuela Dur&#xE1;n, Coronel de Ej&#xE9;rcito, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 6242510}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "53", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-53"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "DEJA SIN EFECTO RESOLUCION No. 33, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-04-28", "doble_articulado": false, "id_norma": "158659", "numero_fuente": "32480", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-05-27", "vigencias": [{"desde": "1986-05-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-05-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-05-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_