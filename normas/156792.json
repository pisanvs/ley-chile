{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6236733}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta N&#xB0; 145 de 08 de Febrero de 1985, conforme Art. 5&#xB0; transitorio C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento de aguas proporcionales que corresponden a Sector excluido y Sector expropiado predio &quot;Hijuela Cuarta de Picoltu&#xE9; o Coronado&quot; de la comuna de Mulch&#xE9;n, VIII Regi&#xF3;n; y derechos de aprovechamiento de aguas que corresponden a las parcelas N&#xB0;s. 1 y 2 del Proyecto de Parcelaci&#xF3;n &quot;Nuevo Chile&quot; formado en parte por predio se&#xF1;alado. Los derechos de agua se extraen del Canal Coronado que se saca del r&#xED;o Bureo.Publicaci&#xF3;n hecha conf&#xF3;rme Art. 13 Ley N&#xB0; 18.377.-</div><br></div>", "i": 6236734}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6236735}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "145 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-145 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-02-08", "doble_articulado": false, "id_norma": "156792", "numero_fuente": "32110", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-01", "vigencias": [{"desde": "1985-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-