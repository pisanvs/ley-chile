{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6228549}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 294 de 26 de mayo de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Mario Garfias Pe&#xF1;a y Ren&#xE9; Berrocal Torres para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 10 &quot;Corvi - Regional - Centro&quot; de Valdivia, cuyo trazado fue autorizado por resoluci&#xF3;n exenta No. 012 de 04 de enero de 1985 y modificado por resoluci&#xF3;n exenta No. 486, de 04 de noviembre de 1985, de esta Secretar&#xED;a Regional.- </div></div>", "i": 6228550}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6228551}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "294 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-294 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-05-26", "doble_articulado": false, "id_norma": "154290", "numero_fuente": "32.564", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-09-03", "vigencias": [{"desde": "1986-09-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-09-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v