{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6305185}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 3.461, de 31 de julio del 2000, se expropiaron los lotes de terreno N&#xBA;s. 1, 2, 3, 4 y 5, superficies 6.980, 2.517, 521, 954 y 8.332 m&#xB2;. respectivamente, rol de aval&#xFA;o N&#xBA; 521-92, comuna de Carahue, para la obra Camino Costero Tir&#xFA;a - Carahue, Tramo Tir&#xFA;a - Bajo Yupehue, Km. 19.000,00 a Km.</div><div class=\"p\">23.413,36 y se acord&#xF3; precio de la indemnizaci&#xF3;n con su propietaria Emelina del Rosario Hormaz&#xE1;bal S&#xE1;ez en la cantidad de $4.626.703, para los lotes N&#xBA;s. 1, 2, 3, 4 y 5.</div><br></div>", "i": 6305186}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6305187}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3461", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3461"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-07-31", "doble_articulado": false, "id_norma": "176696", "numero_fuente": "36788", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-16", "vigencias": [{"desde": "2000-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-10-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-10-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2000-10-16", "fecha_version": "2000