{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6444736}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. No. 174, de 26 de julio de 1991, se expropiaron los lotes N&#xBA;s. 18-B y 18-C, superficies 383 m2. y 383 m2., roles de aval&#xFA;o 2036-024 y 2036-003, respectivamente, Comuna de La Cisterna, para la obra Avenida Am&#xE9;rico Vespucio, sector Gran Avenida Ochagav&#xED;a y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios don Enrique Brante Osorio y do&#xF1;a rifaria Brante Osorio, ascendentes a $ 8.565.081.- para el lote 18-B y $ 6.068.618.- para el lote 18-C.</div><br></div>", "i": 6444737}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6444738}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "174", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-174"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-07-26", "doble_articulado": false, "id_norma": "216164", "numero_fuente": "34068", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-09-14", "vigencias": [{"desde": "1991-09-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-09-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-09-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2003-10-21", "fecha_version": "1991-09-14", "fecha_actualizacion_texto": "1991-09-14", "tipo_tr