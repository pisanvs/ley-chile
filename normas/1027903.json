{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 1.729 EXENTA, DE 2011</div></div>", "i": 9159515}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.729, de fecha 13 de julio de 2011, de Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se modifica la <a href=\"https://www.leychile.cl/Navegar?idNorma=262603&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.208</a>, citada en el Visto, que aprueba el programa de ense&#xF1;anza para la obtenci&#xF3;n de licencia de conductor Clase B, a la Escuela de Conductores No Profesionales o Clase B &quot;Escuela de Conductores Condutec&quot;, cuyo propietario y director es el se&#xF1;or Francisco Harold Salazar Z&#xFA;&#xF1;iga, en el sentido de aprobar la nueva sede de la escuela ubicada en Av. Cuatro &#xC1;lamos N&#xBA; 610, comuna de Maip&#xFA;.- </div><br></div>", "i": 9159516, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Sergio Stephan Orellana, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div></div>", "i": 9159517}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1729 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1729 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL REGIÓN METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 1.729 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-07-13", "doble_articulado": false, "id_norma