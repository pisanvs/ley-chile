{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7303828}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.034, de 21 de agosto de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de las resoluciones N&#xBA; 1.513 de 1996 y N&#xBA; 720 de 1997, y el numeral 2&#xBA; de la resoluci&#xF3;n&nbsp; N&#xBA; 1.165 de 1998, todas de esta Subsecretar&#xED;a, que autorizaron a&nbsp; PESQUERA EL GOLFO S.A. para realizar actividades pesqueras extractivas con la nave &quot;Trinidad&quot;, en el sentido de actualizar e incorporar, seg&#xFA;n corresponda, las siguientes caracter&#xED;sticas n&#xE1;uticas de &#xE9;sta:</div><br><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; 38,59 m</div><div class=\"p\">Potencia principal&nbsp; &nbsp; 1589,00 Hp</div><div class=\"p\">Potencia auxiliar&nbsp; &nbsp;  283,00 Hp</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  8,60 m</div><br><br></div>", "i": 7303829}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7303830}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2034 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2034 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-21", "doble_articulado": false, "id_norma": "214862", "numero_fuente": "37663", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-17", "vige