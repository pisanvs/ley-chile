{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;5.282 EXENTA, DE 2000 </div></div>", "i": 6279787}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;5.282, de fecha 17 de mayo de 2000 del Ministerio de Educaci&#xF3;n, se declara que no se concedi&#xF3; el reconocimiento oficial al Centro de Formaci&#xF3;n T&#xE9;cnica UDA, organizado por la Sociedad Centro de Formaci&#xF3;n T&#xE9;cnica UDA S.A. o C.F.T. UDA, ubicado en calle Copayapu N&#xBA;485, de la ciudad de Copiap&#xF3;.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, se elimina del Libro de Registro de Centros de Formaci&#xF3;n T&#xE9;cnica el N&#xBA;275 de fecha 30 de diciembre de 1999, correspondiente al Centro de Formaci&#xF3;n T&#xE9;cnica UDA, de la ciudad de Copiap&#xF3;. </div></div>", "i": 6279788}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 1 de junio de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6279789}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5282 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5282 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº5.282 EXENTA, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-17", "doble_articulado": false, "id_norma": "170212", "numero_fuente": "36680", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-03", "vigencias": [{"desde": "2000-06-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-03", "fin_vigencia": ""}, "vigencias_version_norm