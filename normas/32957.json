{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8290109}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 85, de 16 de enero de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xB0; 291, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a EMPRESA DE CONSTRUCCION Y CARPINTERIA NAVAL CONCAR S.A., R.U.T. N&#xB0; 96.514.850-7, para iniciar actividades pesqueras extractivas con las naves &quot;Antonio Lorenzo&quot; y &quot;Mar&#xED;a Tamara&quot;, por haberse configurado las causales previstas en los art&#xED;culos 143 letra b) y 12 transitorio de la Ley N&#xB0; 18.892 y sus modificaciones. </div></div>", "i": 8290110}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 16 de enero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8290111}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "85", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-85"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "PESCA", "EMPRESA CONSTRUCCION", "CARPINTERIA NAVAL CONCAR S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-01-16", "fecha_derogacion": "1996-04-26", "doble_articulado": false, "id_norma": "32957", "numero_fuente": "35373", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-01-23", "vigencias": [{"desde": "1996-04-26", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "199