{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div><br><br></div>", "i": 6418882}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA; 14, de fecha 24 de enero del a&#xF1;o 2003, se aprob&#xF3; la disoluci&#xF3;n voluntaria de la Cooperativa de Vivienda y Servicios Habitacionales &quot;San Jorge Limitada&quot;, que consta en la escritura p&#xFA;blica suscrita con fecha 18 de diciembre del a&#xF1;o 2002, ante el Notario P&#xFA;blico de Concepci&#xF3;n, don Enrique Herrera Silva.</div><br></div>", "i": 6418883}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Ra&#xFA;l Oliva Camadro, Jefe Departamento Cooperativas, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6418884}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "14", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-14"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-24", "doble_articulado": false, "id_norma": "208849", "numero_fuente": "37521", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-03-28", "vigencias": [{"desde": "2003-03-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-03-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-03-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe