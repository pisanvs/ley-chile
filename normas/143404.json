{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACIONES QUE INDICA </div></div>", "i": 6191208}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;349, de 16 de agosto de 1999, de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xBA;2.186, de 1978, de parte del inmueble ubicado en calle Fresia Escobar N&#xBA;0593, que corresponde al Lote 12, poblaci&#xF3;n Santa Eduvigis, presunto rol de aval&#xFA;os N&#xBA;3647-9, comuna de La Granja, de aparente dominio de don Ren&#xE9; Alfonso N&#xFA;&#xF1;ez Orellana. Comisi&#xF3;n integrada por Peritos Sres. Luis Rojas Quezada, constructor civil, Juan Pagola Idiart y Ren&#xE9; Ureta Koster, arquitectos, seg&#xFA;n informe de 28 de mayo de 1999, fij&#xF3; monto provisional de indemnizaci&#xF3;n en $8.544.900.-, pagadera al contado.-</div><br></div>", "i": 6191209}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 6191210}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "349", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-349"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-08-16", "doble_articulado": false, "id_norma": "143404", "numero_fuente": "36465", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-15", "vigencias": [{"desde": "1999-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-15", "fin_vigencia": ""}, "vigencias_ver