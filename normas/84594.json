{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8316438}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.727, de 15 de diciembre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura N&#xBA; 94103118, presentada por CARLOS AUGUSTO BECKER ALVEAR, para operar un centro de cultivo en Isla A&#xF1;ihue, comuna de Quemchi, provincia de Chilo&#xE9;, X Regi&#xF3;n, conforme lo dispuesto en los art&#xED;culos 78 y 87 de la Ley General de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xBA; 306, de 1997, de esta Subsecretar&#xED;a, en virtud de lo dispuesto en la presente Resoluci&#xF3;n.</div><br></div>", "i": 8316439}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de diciembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8316440}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1727", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1727"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION DE ACUICULTURA", "CARLOS AUGUSTO BECKER ALVEAR", "QUEMCHI", "CHILOE", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-15", "doble_articulado": false, "id_norma": "84594", "numero_fuente": "35947", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-12-23", "vigencias": [{"desde": "1997-12-23", "hasta": "", "tipo_version": "3", "ti