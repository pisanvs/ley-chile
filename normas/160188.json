{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 341, DE 1990 </div></div>", "i": 6247745}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 341 de 21 de diciembre de 1990 se han aprobado planes y programas especiales de estudio para impartir ense&#xF1;anza orientada a la vida del trabajo, a la Escuela Especial F No. 680, de Pe&#xF1;aflor, Regi&#xF3;n Metropolitana, por un per&#xED;odo de 4 a&#xF1;os, a partir de marzo de 1991, a trav&#xE9;s de los cursos talleres: Sellado y Plastificado; Encuadernaci&#xF3;n y Empaste; y Calzado.</div><br></div>", "i": 6247746}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 08 de Enero de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6247747}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "341 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-341 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 341, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-21", "doble_articulado": false, "id_norma": "160188", "numero_fuente": "33876", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-01-24", "vigencias": [{"desde": "1991-01-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-01-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-01-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso":