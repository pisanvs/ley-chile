{"html": [{"t": "<div><div class=\"p\">SE DISPONE LA QUINCUAG&#xC9;SIMA CUARTA EMISI&#xD3;N DE OTORGAMIENTO DEL APORTE &#xDA;NICO DE CAR&#xC1;CTER REPARATORIO LEY N&#xBA; 20.874, A LAS PERSONAS QUE SE INDIVIDUALIZAN Y POR LOS MONTOS QUE EN CADA CASO SE INDICA</div></div>", "i": 10108843}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 57, de 14 de febrero de 2020, el Director Nacional del Instituto de Previsi&#xF3;n Social, dispone el pago de la quincuag&#xE9;sima cuarta emisi&#xF3;n de otorgamiento del Aporte &#xDA;nico de car&#xE1;cter reparatorio <a href=\"https://www.leychile.cl/Navegar?idNorma=1083194&amp;idParte=&amp;idVersion=\">ley N&#xBA; 20.874</a>, a las personas que se individualizan y por los montos que en cada caso se indica.- </div></div>", "i": 10108844}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Patricio Coronado Rojo.</div><br><br></div>", "i": 10108845}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "57 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-57 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARÍA DE PREVISIÓN SOCIAL", "INSTITUTO DE PREVISIÓN SOCIAL"], "titulo_norma": "SE DISPONE LA QUINCUAGÉSIMA CUARTA EMISIÓN DE OTORGAMIENTO DEL APORTE ÚNICO DE CARÁCTER REPARATORIO LEY Nº 20.874, A LAS PERSONAS QUE SE INDIVIDUALIZAN Y POR LOS MONTOS QUE EN CADA CASO SE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1740313; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-02-14", "doble_articulado": false, "id_norma": "1143493", "numero_fuente": "42606", "tipo_version": "3", "tipo_version_s": "Única", "fecha_public