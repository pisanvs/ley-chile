{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6307501}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.334 de 20 de octubre de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a CORPESCA S.A., para ampliar las actividades pesqueras extractivas con la nave &apos;&apos;Icalma&apos;&apos;, en el &#xE1;rea mar&#xED;tima de la I y II Regiones, donde podr&#xE1; capturar, con red de cerco, por fuera del &#xE1;rea de reserva artesanal, los recursos hidrobiol&#xF3;gicos Anchoa blanca, Jurel fino, Sardina redonda y Vinciguerria.</div><br></div>", "i": 6307502}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de octubre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6307503}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2334", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2334"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-20", "doble_articulado": false, "id_norma": "177476", "numero_fuente": "36805", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-11-06", "vigencias": [{"desde": "2000-11-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-11-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-11-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "2000-11-06", "fecha_version": "2000-11-06", "fe