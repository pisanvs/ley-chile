{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7269697}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 352, de 27 de Marzo de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por 30 d&#xED;as a contar de esta fecha el plazo otorgado a don ROQUE MASSERA UNGERER, R.U.T.</div><div class=\"p\">No. 5.248.899-0, Direcci&#xF3;n Postal, Casilla No. 434, Rancagua, en el numeral 4&#xB0; de la Resoluci&#xF3;n No. 25, de 1990, de esta Subsecretar&#xED;a de Pesca, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor. </div></div>", "i": 7269698}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de Marzo de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 7269699}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "352", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-352"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-03-27", "doble_articulado": false, "id_norma": "168492", "numero_fuente": "33941", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-12", "vigencias": [{"desde": "1991-04-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-04-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-04-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modif