{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0;. 179,DE 1989 </div></div>", "i": 8603793}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n N&#xB0;. 179, de 09 de noviembre de 1989, se ha agregado, a contar del a&#xF1;o 1990, en el art&#xED;culo 1&#xB0; del decreto supremo exento de Educaci&#xF3;n No. 319 de 1986, que aprob&#xF3; plan especial de estudio para la Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica al Colegio Redland School, de Santiago, en la parte correspondiente a las Asignaturas Electivas del Plan de Estudio para 2&#xB0; a&#xF1;o medio, la asignatura de Computaci&#xF3;n, la que deber&#xE1; cumplir los Objetivos Generales que se aprueban en este decreto. </div></div>", "i": 8603794}, {"t": "<div><div class=\"p\">Santiago, 06 de Diciembre de 1989.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 8603795}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "179 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-179 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N°. 179,DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-11-09", "doble_articulado": false, "id_norma": "89374", "numero_fuente": "33552", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-12-22", "vigencias": [{"desde": "1989-12-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-12-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "