{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292393}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 426 de 25 de Abril de 1995 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por un a&#xF1;o, a contar de la fecha de la presente Resoluci&#xF3;n, el plazo de vigencia de la Resoluci&#xF3;n N&#xB0; 710, de 1985, de esta Subsecretar&#xED;a que autoriz&#xF3; a EMPRESA PESQUERA GALILEA LIMITADA, R.U.T. N&#xB0; 79.591.630-K, para desarrollar actividades pesqueras extractivas con la nave &quot;Galilea II&quot;, por haberse acreditado la existencia de fuerza mayor.</div><br><br></div>", "i": 8292394}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 25 de Abril de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292395}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "426", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-426"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EMPRESA PESQUERA GALILEA LIMITADA", "PESCA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-04-25", "doble_articulado": false, "id_norma": "34737", "numero_fuente": "35166", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-05-13", "vigencias": [{"desde": "1995-05-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-05-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-05-13", "fin_vigencia": "", "tipo_version