{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8304265}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 860, de 23 de junio de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xBA; 768 de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA AURO SOCIEDAD ANONIMA, para realizar actividades pesqueras extractivas con la nave &quot;Albimer&quot;, matr&#xED;cula 2684, en el litoral de la III y IV Regiones, en virtud de lo se&#xF1;alado en la letra b) del Art. 143 del D.S. N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8304266}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de junio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8304267}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "860", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-860"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "PESQUERA AURO SOCIEDAD ANONIMA", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-06-23", "fecha_derogacion": "1998-08-19", "doble_articulado": false, "id_norma": "73940", "numero_fuente": "35804", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-07-01", "vigencias": [{"desde": "1998-08-19", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1997-07-01", "hasta": "1998-08-18", "tip