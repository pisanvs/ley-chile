{"html": [{"t": "<div><div class=\"p\">PARTIDO &quot;UNION DEMOCRATA INDEPENDIENTE&quot; </div></div>", "i": 7221646}, {"t": "<div><div class=\"p\">Joaqu&#xED;n Lav&#xED;n Infante, en representaci&#xF3;n del Partido Uni&#xF3;n Dem&#xF3;crata Independiente, ha solicitado la constituci&#xF3;n legal del Partido en las Regiones X y XI acompa&#xF1;ando las siguientes cantidades de afiliaciones:</div><br><div class=\"p\">- D&#xE9;cima Regi&#xF3;n: 2.579 - Und&#xE9;cima Regi&#xF3;n: 203 Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xBA; de la Ley N&#xBA;18.603. Por resoluci&#xF3;n exenta N&#xBA;O-1.656 de fecha 14 de Octubre de 1991.</div><br></div>", "i": 7221647}, {"t": "<div><div class=\"p\">Santiago, 14 de Octubre de 1991.- Andr&#xE9;s Merino Espi&#xF1;eira, Director subrogante.</div><br></div>", "i": 7221648}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1656 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1656 EXENTA"}, {"tipo": "3", "numero": "O-1656 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-1656 EXENTA"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO UNION DEMOCRATA INDEPENDIENTE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-10-14", "doble_articulado": false, "id_norma": "86976", "numero_fuente": "34095", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-10-19", "vigencias": [{"desde": "1991-10-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-10-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-1