{"html": [{"t": "<div><div class=\"p\">CERTIFICA CALIDAD DE&nbsp; AGENTE&nbsp; RETENEDOR DEL IVA A MEAT WAY</div><div class=\"p\">S.A.</div><br></div>", "i": 6124584}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 34.- Certifico que Meat Way S.A., Rut. N&#xBA; 96.756.740-K, cumple los requisitos establecidos en la Res.</div><div class=\"p\">N&#xBA; Ex. 2.705 de 07.05.98 (D.O. de 12.05.98) modificada por la Res. N&#xBA; Ex. 3.784 de 25.06.98 (D.O. de 30.06.98) y que en consecuencia tiene la calidad de agente retenedor del Impuesto al Valor Agregado en las ventas de carne&nbsp; y servicios de faenamiento&nbsp; de ganado que efect&#xFA;e durante el per&#xED;odo comprendido entre el 1&#xBA; del mes siguiente al de la publicaci&#xF3;n de este certificado en el Diario Oficial y el 31 de julio de 1999.</div><br></div>", "i": 6124585}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de julio de 1998.- Jorge A. de Calisto Bravo, Director Regional.</div><br></div>", "i": 6124586}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "34", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-34"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO PONIENTE"], "titulo_norma": "CERTIFICA CALIDAD DE AGENTE RETENEDOR DEL IVA A MEAT WAY\nS.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "MEAT WAY S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-24", "doble_articulado": false, "id_norma": "122781", "numero_fuente": "36133", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-08-06", "vigencias": [{"desde": "1998-08-06", "h