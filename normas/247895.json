{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 10.824 EXENTA, DE 2005</div><br><br></div>", "i": 6563631}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 10.824, de 30 de diciembre de 2005, se han modificado las resoluciones exentas de Educaci&#xF3;n N&#xBA;s. 12.993, de 2000; 16.288, de 2001, y 14.116, de 2002, y sus modificaciones, que aprobaron planes y programas especiales de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, al Colegio &quot;Craighouse&quot;, de la comuna de Lo Barnechea, de Santiago, en el sentido de sustituir los planes de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, a partir del a&#xF1;o escolar 2006. </div></div>", "i": 6563632}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de marzo de 2006.- Xavier Vanni Cucurella, Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6563633}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10824 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-10824 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 10.824 EXENTA, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-30", "doble_articulado": false, "id_norma": "247895", "numero_fuente": "38411", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-11", "vigencias": [{"desde": "2006-03-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-03-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-03-11", "fin_