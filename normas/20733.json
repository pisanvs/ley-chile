{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 230, DE 1992 </div></div>", "i": 5942949}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 230 de fecha 12 de Agosto de 1992 del Ministerio de Educaci&#xF3;n, se aprobaron las modificaciones introducidas al plan y programas de estudio del Centro de Formaci&#xF3;n T&#xE9;cnica Inacap, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida en todas las Sedes que contaban con su aprobaci&#xF3;n, a contar del a&#xF1;o 1992, con la siguiente denominaci&#xF3;n:</div><div class=\"p\"> Carrera: Dibujo&nbsp; y Proyectos T&#xE9;cnicos menci&#xF3;n Dibujo T&#xE9;cnico Mec&#xE1;nico, cambia por:</div><div class=\"p\"> Carrera: Dibujo T&#xE9;cnico Industrial.</div><div class=\"p\"> T&#xED;tulo: T&#xE9;cnico en Dibujo T&#xE9;cnico Industrial. </div></div>", "i": 5942950}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 14 de Diciembre de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5942951}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "230", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-230"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 230, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA INACAP", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "DIBUJO TECNICO INDUSTRIAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-12-14", "doble_articulado": false, "id_norma": "20733", "numero_fuente": "34508", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-03-05", "vigencias": [{"des