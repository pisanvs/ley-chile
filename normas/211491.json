{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7300548}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.201, de 10 de junio de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 2&#xBA; de las resoluciones N&#xBA; 439 de 1984, N&#xBA; 1.102 de 1992, N&#xBA; 81 de 1999 y el numeral 1&#xBA; de las resoluciones N&#xBA; 583 de 1999 y N&#xBA; 706 de 2000, todas de esta Subsecretar&#xED;a, que autorizaron a SOCIEDAD PESQUERA SAN ANTONIO S.A. para desarrollar actividades pesqueras con la nave&nbsp;  &quot;Vigri&quot;, en el sentido de incorporar y actualizar las siguientes caracter&#xED;sticas n&#xE1;uticas de &#xE9;sta:</div><br><div class=\"p\">&nbsp; &nbsp;  Eslora de arqueo&nbsp; 28,14 m</div><div class=\"p\">&nbsp; &nbsp;  Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  6,87 m</div><br></div>", "i": 7300549}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de junio de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7300550}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1201", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1201"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-10", "doble_articulado": false, "id_norma": "211491", "numero_fuente": "37589", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-21", "vigencias": [{"desde": "2003-06-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-06-21", "fin_v