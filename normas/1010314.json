{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div><br></div>", "i": 8846821}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xB0; 39.562, de fecha 16 de enero de 2010, se public&#xF3; el Acuerdo N&#xB0; 1519-03-100114 &quot;Modifica Cap&#xED;tulos IV.E.1 y IV.E.2 del Compendio de Normas Financieras&quot; con el error de transcripci&#xF3;n que se salva a continuaci&#xF3;n:</div><br><div class=\"p\">En la p&#xE1;gina 45, primera columna:</div><br><div class=\"p\">b) Incorporar en su N&#xB0; 6 los siguientes p&#xE1;rrafos finales:</div><br><div class=\"p\">Donde dice:&nbsp;  &quot;BCU o BDC&quot;</div><br><div class=\"p\">Debe decir:&nbsp; &nbsp; &quot;BCU o BCD&quot;</div><br><div class=\"p\">En la p&#xE1;gina 45, segunda columna:</div><br><div class=\"p\">Anexo N&#xB0; 2, N&#xB0; 3, quinto p&#xE1;rrafo:</div><br><div class=\"p\">Donde dice:&nbsp;  &quot;BCU o BDC&quot;</div><br><div class=\"p\">Debe decir:&nbsp; &nbsp; &quot;BCU o BCD&quot;</div><br></div>", "i": 8846822, "v": ["RECTIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de enero de 2010.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 8846823}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "79", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-79"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-01-16", "doble_articulado": false, "id_norma": "1010314", "numero_fuente": "39565", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-01-20",