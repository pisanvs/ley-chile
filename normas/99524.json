{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8330267}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 712, de 25 de mayo de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de las Resoluciones N&#xBA; 925 de 1995 y N&#xBA; 910 de 1997, de esta Subsecretar&#xED;a, que autorizaron a SOCIEDAD ARMADORES PESQUEROS PORVENIR LTDA., para operar la nave &apos;&apos;Isla L&#xF3;pez&apos;&apos;, matr&#xED;cula 1869, por no haber iniciado actividades dentro del plazo que ten&#xED;a para ello, en virtud de lo se&#xF1;alado en el Art. 143 letra b), del D.S.</div><div class=\"p\">N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8330268}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de mayo de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8330269}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "712", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-712"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "SOCIEDAD ARMADORES PESQUEROS PORVENIR LTDA.", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-05-25", "fecha_derogacion": "1999-05-08", "doble_articulado": false, "id_norma": "99524", "numero_fuente": "36078", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-06-01", "vigencias": [{"desde": "1999-05-08", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última