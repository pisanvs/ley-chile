{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6112080}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. N&#xBA;581, de 30 de abril de 1998, se expropiaron los lotes de terreno N&#xBA;s 34 y 55-A, superficies 366 y 200 m&#xB2;., roles de aval&#xFA;o 2589-73 y 2590-108, comuna de San Bernardo, respectivamente, para la obra Estudio de Anteproyecto e Ingenier&#xED;a, para el Sistema Norte - Sur, sector Las Acacias - R&#xED;o Maipo y se acord&#xF3; precio de indemnizaci&#xF3;n con los propietarios Chen Hermanos Limitada y Sergio Cerda Silva, ascendentes a las cantidades de $11.229.475, para el lote N&#xBA;34, y $6.712.275, para el lote N&#xBA;55-A.</div><br></div>", "i": 6112081}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6112082}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "581", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-581"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SAN BERNARDO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-30", "doble_articulado": false, "id_norma": "99544", "numero_fuente": "36089", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-06-15", "vigencias": [{"desde": "1998-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "in