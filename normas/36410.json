{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8296140}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n n&#xFA;mero 1.172, de 7 de Diciembre de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por un a&#xF1;o, a contar de la fecha de la presente Resoluci&#xF3;n, el plazo otorgado a don SERGIO AUGUSTO PRADO CARRASCO, R.U.T. N&#xB0; 4.649.463-4, para sustituir la nave &quot;Santa Teresa II&quot;, autorizada por Resoluci&#xF3;n N&#xB0; 113, de 1990, de esta Subsecretar&#xED;a, en virtud de haberse acreditado la existencia de una fuerza mayor.</div><br></div>", "i": 8296141}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 7 de Diciembre de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8296142}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1172", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1172"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SERGIO AUGUSTO PRADO CARRASCO", "PESCA", "PRORROGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-12-07", "fecha_derogacion": "1996-06-03", "doble_articulado": false, "id_norma": "36410", "numero_fuente": "35050", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-12-26", "vigencias": [{"desde": "1996-06-03", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1994-12-26", "hasta": "1996-06-02", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1