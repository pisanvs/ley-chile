{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 49</div><br><div class=\"p\">Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n No. 49, celebrada el 17 de agosto de 1990, adopt&#xF3; el siguiente acuerdo:</div><br></div>", "i": 6081891}, {"t": "<div><div class=\"p\">49-01-900817- Se suspende colocaci&#xF3;n de Pagares Reajustables del Banco Central de Chile (P.R.B.C.)</div><br><div class=\"p\">Se acord&#xF3; suspender la venta de Pagar&#xE9;s Reajustables del Banco Central de Chile (P.R.B.C.) a los plazos de 180 y 360 d&#xED;as, a partir del d&#xED;a 20 de agosto de 1990. </div></div>", "i": 6081892}, {"t": "<div><div class=\"p\">Santiago, 20 de agosto de 1990.- V&#xED;ctor Vial del R&#xED;o, Secretario General Interino.</div><br></div>", "i": 6081893}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "49", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-49"}, {"tipo": "5", "numero": "49-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-49-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE CHILE\nEN SU SESION No. 49", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-08-17", "doble_articulado": false, "id_norma": "89235", "numero_fuente": "33750", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-08-21", "vigencias": [{"desde": "1990-08-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-08-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-08-2