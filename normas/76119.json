{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8306776}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.254 de 25 de septiembre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud presentada por PESQUERA BALZAK S.A., para ampliaci&#xF3;n de plazo para operar por causal de fuerza mayor con la nave &quot;Luminosa&quot;, autorizada por Resoluci&#xF3;n N&#xBA; 693, de 1994, que autoriz&#xF3; a la peticionaria a iniciar actividades extractivas con la nave precitada. </div></div>", "i": 8306777}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de septiembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8306778}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1254", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1254"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "PESQUERA BALZAK S.A.", "AMPLIACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-09-25", "doble_articulado": false, "id_norma": "76119", "numero_fuente": "35882", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-10-04", "vigencias": [{"desde": "1997-10-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-10-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-10-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_po