{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6575504}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 1.705, de 21 de junio de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a CONGELADOS DEL SUR S.A., para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Ram&#xF3;n Freire interior s/n, camino a Teguel, Dalcahue, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de cocido, fresco enfriado, fresco refrigerado y congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;janse sin efecto las resoluciones N&#xBA; 271 de 1988, N&#xBA; 250 de 1989, N&#xBA; 396 de 1994, N&#xBA; 1.199 de 1998 y N&#xBA; 1.037 de 2006, todas de esta Subsecretar&#xED;a, en virtud de la carta renuncia citada en Visto y del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6575505}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de junio de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6575506}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1705 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1705 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-21", "doble_articulado": false, "id_norma": "251197", "numero_fuente": "38513", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-07-14", "vigencias": [{"de