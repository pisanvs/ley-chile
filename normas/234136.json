{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6510991}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.407, de 29 de noviembre de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a CULTIVOS MARINOS FLAMENCO S.A. para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta en Caleta Flamenco, a 32 kil&#xF3;metros al sur de Cha&#xF1;aral, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de cocido, fresco-refrigerado y congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6510992}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de noviembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6510993}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3407 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3407 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-29", "doble_articulado": false, "id_norma": "234136", "numero_fuente": "38049", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-31", "vigencias": [{"desde": "2004-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-12-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-12-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2004-12-3