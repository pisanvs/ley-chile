{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Cuentas pendientes del Ministerio del Interior Lei n&#xFA;m. 1,438.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274337}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la cantidad de treinta i nueve mil trescientos ochenta i tres pesos diecinueve centavos en el pago de las cuentas pendientes por servicios de cargo del ministerio del Interior. </div></div>", "i": 8274338}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- Santiago, a 21 de Enero de 1901.- FEDERICO ERRAZURIZ E.- Juan Antonio Orrego.</div><br></div>", "i": 8274339}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1438", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1438"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CUENTAS PENDIENTES DEL MINISTERIO DEL INTERIOR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MINISTERIO INTERIOR", "CUENTAS PENDIENTES", "PAGO", "INVERSION", "FONDOS", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-01-21", "doble_articulado": false, "id_norma": "22648", "numero_fuente": "6797", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-01-21", "vigencias": [{"desde": "1901-01-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "