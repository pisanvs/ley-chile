{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTOS DE RESOLUCIONES</div><br><br></div>", "i": 8288823}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 666 de 11 de Junio de 1991, de esta Subsecretar&#xED; de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2&#xB0; de la resoluci&#xF3;n N&#xB0; 433, de 12 de Abril de 1991, que autoriz&#xF3; a SOCIEDAD CHILENA DE NUTRICION ANIMAL LIMITADA, R.U.T.</div><div class=\"p\">N&#xB0; 79.530.240-9, domiciliada en la Regi&#xF3;n Metropolitana, en el sentido de eliminar la autorizaci&#xF3;n para procesar los recursos pejerrey de mar y r&#xF3;balo, en virtud de lo dispuesto en el D.S. N&#xB0; 316, de 1985, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8288824}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 11 de Junio de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8288825}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "666", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-666"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "EXTRACTOS DE RESOLUCIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD CHILENA NUTRICION ANIMAL LTDA", "PESCA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-06-11", "fecha_derogacion": "1996-04-12", "doble_articulado": false, "id_norma": "31590", "numero_fuente": "33996", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-06-19", "vigencias": [{"desde": "1996-04-12", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Vers