{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 360, DE 1990 </div></div>", "i": 6270093}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 360 de 27 de diciembre de 1990 se han aprobado programas de estudio orientados a la vida laboral, por un per&#xED;odo de 4 a&#xF1;os, a partir de marzo de 1991, para ser aplicados por la Escuela Diferencial F No. 546, dependiente de la I. Municipalidad de La Granja, Regi&#xF3;n Metropolitana, a trav&#xE9;s de cursos talleres de Carpinter&#xED;a y Muebler&#xED;a, y Costura y Modas. </div></div>", "i": 6270094}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 5 de Marzo de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6270095}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "360 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-360 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 360, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-27", "doble_articulado": false, "id_norma": "167112", "numero_fuente": "33914", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-03-09", "vigencias": [{"desde": "1991-03-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-03-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-03-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2000-04-27", "fecha_version": "1991-03-09",