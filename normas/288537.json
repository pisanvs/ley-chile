{"html": [{"t": "<div><div class=\"p\">&amp;#160;</div></div>", "i": 8468866}, {"t": "<div><br><div class=\"p\">Por decreto (exento) MOP N&#xBA;425 de fecha 27 de febrero del 2009, se expropi&#xF3; el lote de terreno N&#xBA;14, superficie 39 m2, Rol N&#xBA;154-79, comuna de Petorca, V Regi&#xF3;n para la obra &quot;Reposici&#xF3;n Ruta E-35, Cruce Longitudinal Cabildo - Petorca, Sector III, Tramo Km. 40,40000 a Km. 57,65500, Comuna y Provincia de Petorca, V Regi&#xF3;n&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario BERNARDO ENRIQUE OLMOS HERRERA, ascendente a la cantidad de $1.665.686.- para el lote N&#xBA;14.</div></div>", "i": 8468867}, {"t": "<div><div class=\"p\">Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 8468868}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "425 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-425 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-02-27", "doble_articulado": false, "id_norma": "288537", "numero_fuente": "39327", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-04-01", "vigencias": [{"desde": "2009-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "114", "fecha_ingreso": "2009-04-01", "fecha_version": "2009-04-01", "actualizado_por": "114", "fec