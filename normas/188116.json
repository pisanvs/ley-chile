{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6344425}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA; 326, de 30 de marzo de 2001, se orden&#xF3; la expropiaci&#xF3;n y aprob&#xF3; Plano y Cuadro de expropiaci&#xF3;n del lote de terreno N&#xBA; 40, y por decreto exento MOP N&#xBA; 917, de 29 de junio de 2001, se autoriz&#xF3; el valor de la consignaci&#xF3;n provisional de la expropiaci&#xF3;n v&#xED;a judicial, en la cantidad de $2.470.872, necesario para ejecuci&#xF3;n de la obra Proyecto Estudio de Factibilidad y Dise&#xF1;o del Embalse Corrales y sus obras complementarias, el pago de la indemnizaci&#xF3;n se efectuar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.</div><br></div>", "i": 6344426}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6344427}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "326 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-326 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-30", "doble_articulado": false, "id_norma": "188116", "numero_fuente": "37026", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-08-01", "vigencias": [{"desde": "2001-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-08-01", "fin_