{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 420 EXENTO, DE 1999</div><br><br><br></div>", "i": 6239906}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xB0; 420 de fecha 9 de diciembre de 1999 del Ministerio de Educaci&#xF3;n, se aprobaron los planes y programas de estudios al Centro de Formaci&#xF3;n T&#xE9;cnica Inacap CIES, de las carreras y t&#xED;tulos t&#xE9;cnicos de nivel superior que se indican, para ser impartidos a contar del a&#xF1;o 1999:</div><br><br><div class=\"p\">Carrera : Administraci&#xF3;n Hotelera menci&#xF3;n Recepci&#xF3;n y</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Habitaciones o Alimentos&nbsp; y Bebidas.</div><div class=\"p\">T&#xED;tulo&nbsp; : T&#xE9;cnico de Nivel Superior en Administraci&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Hotelera menci&#xF3;n Recepci&#xF3;n y Habitaciones o</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Alimentos y Bebidas.</div><div class=\"p\">Carrera : Servicios Tur&#xED;sticos.</div><div class=\"p\">T&#xED;tulo&nbsp; : T&#xE9;cnico de Nivel Superior en Servicios</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Tur&#xED;sticos.</div><br></div>", "i": 6239907}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de febrero de 2000.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6239908}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "420 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-420 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 420 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogad