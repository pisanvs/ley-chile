{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA NOMBRE A LA AVENIDA 4 NORTE DE LA CIUDAD DE TALCA</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8281317}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. La Avenida 4 Norte o Alameda de la ciudad de Talca se denominar&#xE1; en lo sucesivo &quot;Alameda Bernardo O&apos;Higgins&quot;.&quot; </div></div>", "i": 8281318}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese aefecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintisiete de Septiembre de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.-</div><div class=\"p\">S&#xF3;tero del R&#xED;o G.</div><br></div>", "i": 8281319}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14103", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14103"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA NOMBRE A LA AVENIDA 4 NORTE DE LA CIUDAD DE\nTALCA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "AVENIDA BERNARDO O'HIGGINS", "TALCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-09-27", "doble_articulado": false, "id_norma": "27677", "numero_fuente": "24764", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-10-08", "vigencias": [{"desde": "1960-10-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1960-10-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig