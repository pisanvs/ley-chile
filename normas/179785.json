{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6315207}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;5.022, de 31 de octubre de 2000, se expropi&#xF3; el lote terreno N&#xBA;1-a, superficie 1.259 m&#xB2;, rol de aval&#xFA;o 191-21, comuna de Arauco, para la obra Camino Arauco - Llico, Sector Curaquilla - Llico, Km.</div><div class=\"p\">6,54000 a Km. 28,00000 y se acord&#xF3; precio de la indemnizaci&#xF3;n con su propietario Rodolfo Gaete Jenicek y otra, ascendente a la cantidad de $512.954.</div><br></div>", "i": 6315208}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6315209}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "5022", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-5022"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-31", "doble_articulado": false, "id_norma": "179785", "numero_fuente": "36851", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-02", "vigencias": [{"desde": "2001-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2001-01-05", "fecha_version": "2001-01-02", "fecha_actualizacion_texto": "2001-01-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado