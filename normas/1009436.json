{"html": [{"t": "<div><br><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESI&#xD3;N ORDINARIA N&#xBA; 1514</div></div>", "i": 8815699}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile, en su Sesi&#xF3;n Ordinaria N&#xBA; 1514, celebrada el 17 de diciembre de 2009, adopt&#xF3; el siguiente Acuerdo:</div><br><div class=\"p\">1514-03-091217 &#x2013; Tasa de inter&#xE9;s para pago diferido de derechos de aduana.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3;, en conformidad con lo establecido en la letra c) del Art. 10 de la ley N&#xB0; 18.634, que la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de derechos de aduana durante el semestre que expira el 30 de junio de 2010, ser&#xE1; de 5,7% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.</div></div>", "i": 8815700}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de diciembre de 2009.- Juan Esteban Laval Zald&#xED;var, Ministro de Fe (S).</div></div>", "i": 8815701}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1514", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1514"}, {"tipo": "3", "numero": "1514-03", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1514-03"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESIÓN ORDINARIA Nº 1514", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-12-17", "doble_articulado": false, "id_norma": "1009436", "numero_fuente": "39541", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-12-21", "vigencias": [{"desde":