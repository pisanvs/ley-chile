{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6468107}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 777, de 3 de marzo de 2004, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 2.448, de 2000, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a SOCIEDAD PESQUERA IBIZA LIMITADA para operar la nave &quot;Monte Igueldo&quot; en la I Regi&#xF3;n, sobre el recurso Besugo, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 6468108}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de marzo de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6468109}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "777 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-777 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-03", "doble_articulado": false, "id_norma": "222205", "numero_fuente": "37807", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-10", "vigencias": [{"desde": "2004-03-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-03-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-03-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JRC", "fech