{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;&nbsp; 500 EXENTO, DE 1997 </div></div>", "i": 7208644}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto&nbsp; Exento N&#xBA; 500 de fecha 6 de mayo de 1997 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica INACAP, las adecuaciones al plan y programas de estudios de la carrera de Mec&#xE1;nica Automotriz. Modific&#xE1;ndose, en consecuencia, la Resoluci&#xF3;n exenta del Ministerio de Educaci&#xF3;n N&#xBA; 3.008 del 9 de noviembre de 1988, en el sentido de incorporar dichas adecuaciones, las que podr&#xE1;n aplicarse a contar del a&#xF1;o 1997, en las sedes que ya contaban con su autorizaci&#xF3;n.</div><br></div>", "i": 7208645}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de junio de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7208646}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "500 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-500 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 500 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO DE FORMACION TECNICA INACAP", "PLAN DE ESTUDIOS", "PROGRAMAS DE ESTUDIOS", "MECANICA AUTOMOTRIZ"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-05-06", "doble_articulado": false, "id_norma": "73919", "numero_fuente": "35802", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-06-28", "vigencias": [{"desde": "1997-06-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-06-28", "fin_vigencia": "