{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293986}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 746, de 22 de Junio de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a CASTROMONTT S.A., R.U.T. N&#xB0; 96.610.210-1, para iniciar actividades pesqueras, en orden a instalar y operar una planta secadora artificial de algas ubicada en Lechagua, Kil&#xF3;metro 5, Camino a Quetalmahue, Chilo&#xE9;, X&#xAA;. Regi&#xF3;n, donde podr&#xE1; procesar los siguientes recursos: Cochayuyo, Chicorea de mar, Luga-Luga, Pelillo, Carola.</div><br></div>", "i": 8293987}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 22 de Junio de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293988}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "746", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-746"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CASTROMONTT S.A.", "INDUSTRIA PESQUERA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1995-06-22", "fecha_derogacion": "2002-01-16", "doble_articulado": false, "id_norma": "35481", "numero_fuente": "35223", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1995-07-21", "vigencias": [{"desde": "2002-01-16", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1995-07-21", "hasta": "2002-01-15", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2002-01-16", "fin_vigencia": ""}, "vigencia