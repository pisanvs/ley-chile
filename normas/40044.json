{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE RESOLUCION EXENTA N&#xB0; 2.008, DE 1993 </div></div>", "i": 6025695}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n Exenta N&#xB0; 2.008 de fecha 19 de mayo de 1993 del Ministerio de Educaci&#xF3;n, se declar&#xF3; que no se concede el reconocimiento oficial al Centro de Formaci&#xF3;n T&#xE9;cnica CIET-TALCA, organizado por lA Sociedad Centro de Formaci&#xF3;n T&#xE9;cnica Centro Integral de Educaci&#xF3;n Talca Limitada, ubicado en calle 4 Norte N&#xB0; 1.309 de la ciudad de Talca y se elimin&#xF3; del Libro de Registros de Centros de Formaci&#xF3;n T&#xE9;cnica el N&#xB0; 223 de fecha 18 de Noviembre de 1992, correspondiente al Centro de Formaci&#xF3;n T&#xE9;cnica CIET-TALCA.-</div><br></div>", "i": 6025696}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 6025697}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2008", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2008"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N° 2.008, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO DE FORMACION TECNICA CIET-TALCA", "SEPTIMA REGION", "MODIFICACION", "TALCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-05-19", "doble_articulado": false, "id_norma": "40044", "numero_fuente": "34620", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-07-21", "vigencias": [{"desde": "1993-07-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-07-21", "fin_vigencia": ""}, "vigenci