{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 415, DE 1990 </div></div>", "i": 5944427}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 415, de fecha 28 de Diciembre de 1990, del Ministerio de Educaci&#xF3;n, se encarg&#xF3; a la Universidad de Tarapac&#xE1; la funci&#xF3;n de entidad examinadora para las carreras de Psicopedagog&#xED;a; Pedagog&#xED;a en Educaci&#xF3;n General B&#xE1;sica menci&#xF3;n Computaci&#xF3;n y Traducci&#xF3;n e Interpretariado Ingl&#xE9;s-Espa&#xF1;ol del Instituto Profesional Iquique English College.</div><div class=\"p\">&nbsp; &nbsp; La Universidad de Tarapac&#xE1; y el Instituto Profesional Iquique English College deber&#xE1;n suscribir un convenio, en el que establecer&#xE1;n los derechos y obligaciones entre ambas partes.</div><br></div>", "i": 5944428}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 30 de Abril de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5944429}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "415", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-415"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 415, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO PROFESIONAL IQUIQUE ENGLISH COLLEGE", "UNIVERSIDAD TARAPACA", "ENTIDAD EXAMINADORA", "DESIGNACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-28", "doble_articulado": false, "id_norma": "21195", "numero_fuente": "33966", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-05-13", "vigencias": [{"desde": "1991-05-13", "hasta": "", "tipo_version": "3"