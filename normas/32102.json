{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7193939}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 13, de 19 de Abril de 1995, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se adjudic&#xF3; a &quot;Alberto Fernando Barroso Ar&#xE1;nguiz&quot; la concesi&#xF3;n para operar, por un plazo de cuatro meses, a contar de la publicaci&#xF3;n del presente extracto, un establecimiento ubicado en calle Vicu&#xF1;a Mackenna N&#xB0; 1374, de la comuna de Melipilla, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de emisi&#xF3;n de contaminantes de veh&#xED;culos a que se refiere el inciso segundo del art&#xED;culo 7&#xB0; del Decreto Supremo N&#xB0; 156/90 del Ministerio de Transportes y Telecomunicaciones, en la forma, modo y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 7193940}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; M&#xF3;nica Wityk Peluchonneau, Secretario Regional Ministerial de Transportes y Telecomunicaciones (S) Regi&#xF3;n Metropolitana.</div><br></div>", "i": 7193941}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "13", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-13"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANTA REVISION TECNICA", "AUTORIZACION", "ALBERTO", "FERNANDO BARROSO ARANGUIZ", "MELIPILLA", "VEHICULOS", "MOTORIZADOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-04-19", "doble_articulado": false, "id_norma": "32102", "n