{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6172022}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 6,05% anual durante el mes de mayo de 1999.</div><br><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad con lo dispuesto en el N&#xBA; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de mayo de 1999, fue de 5,88% anual. </div></div>", "i": 6172023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de junio de 1999.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6172024}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-06-04", "doble_articulado": false, "id_norma": "137428", "numero_fuente": "36382", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-06-08", "vigencias": [{"desde": "1999-06-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-06-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-06-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-