{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8938913}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;758, de 31 de mayo de 2010, y en base a la facultad otorgada por el art&#xED;culo 105 del D.F.L. M.O.P. N&#xBA;850 de 1997, que fij&#xF3; el texto actualizado de la Ley N&#xBA;15.840, se expropi&#xF3; el lote de terreno N&#xBA;43, para la obra: &quot;Mejoramiento Ruta D-805, Illapel - Caren&quot;, Provincia de Choapa, IV Regi&#xF3;n, Comuna de Illapel, que figura a nombre de MAR&#xCD;A RAM&#xCD;REZ OLIVARES, rol de aval&#xFA;o E/T, superficie 726 M2. La Comisi&#xF3;n de Peritos, fij&#xF3; con fecha 5 de noviembre de 2008, en la cantidad de $929.800. La indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA;2186, de 1978. </div><br></div>", "i": 8938914}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 8938915}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "758 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-758 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-05-31", "doble_articulado": false, "id_norma": "1014919", "numero_fuente": "39699", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-07-01", "vigencias": [{"desde": "2010-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-07-01", "fin_vigencia