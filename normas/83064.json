{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION QUE INDICA </div></div>", "i": 8314649}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 639, 16 de Mayo de 1990. de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, der&#xF3;gase la Resoluci&#xF3;n No. 417, de 1984, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Complejo Frigor&#xED;fico Huel&#xE9;n Limitada, R.U.T. No. 89.415.600-7; domiciliado en la ciudad de Antofagasta, para desarrollar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta industrial ubicada en calle Iquique No. 4430, Antofagasta, por renuncia de su titular.</div><br></div>", "i": 8314650}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 16 de Mayo de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8314651}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "639", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-639"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "DEROGA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-05-16", "doble_articulado": false, "id_norma": "83064", "numero_fuente": "33680", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-05-28", "vigencias": [{"desde": "1990-05-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-05-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-05-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu