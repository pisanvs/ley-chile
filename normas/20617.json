{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 192 EXENTO, DE 1995 </div><br></div>", "i": 5942539}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 192 de fecha 20 de Marzo de 1995 del Ministerio de Educaci&#xF3;n, se revoc&#xF3; el reconocimiento oficial del Instituto Profesional ITES de Vi&#xF1;a del Mar, organizado por la Sociedad Garc&#xED;a y Silva Limitada y se elimin&#xF3; a dicha entidad del Registro de Institutos Profesionales en que se encontraba inscrito con el N&#xB0; 84.</div><div class=\"p\">&nbsp; &nbsp; Por este mismo cuerpo legal se derog&#xF3; el Decreto Exento de Educaci&#xF3;n N&#xB0; 46 de fecha 25 de Febrero de 1992, que reconoci&#xF3; oficialmente al Instituto Profesional ITES.</div><br></div>", "i": 5942540}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 29 de Marzo de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5942541}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "192 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-192 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 192 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO PROFESIONAL ITES", "VI A DEL MAR", "QUINTA REGION", "RECONOCIMIENTO OFICIAL", "REVOCACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-03-20", "doble_articulado": false, "id_norma": "20617", "numero_fuente": "35135", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-04-04", "vigencias": [{"desde": "1995-04-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inici