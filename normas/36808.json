{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SOLICITA CONSTITUCION LEGAL DEL &quot;PARTIDO SOCIALISTA DE CHILE&quot; EN LA I REGION </div></div>", "i": 6016268}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Camilo Escalona Medina e Isabel Allende Bussi, Presidente y Secretario General, respectivamente, en representaci&#xF3;n del &quot;Partido Socialista de Chile&quot;, han solicitado la constituci&#xF3;n legal del Partido en la I Regi&#xF3;n de Tarapac&#xE1;, acompa&#xF1;ando 1.011 fichas de afiliaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la Ley N&#xB0; 18.603, por Resoluci&#xF3;n O-N&#xB0; 1369 de fecha 02 de mayo de 1996. </div></div>", "i": 6016269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 02 de mayo de 1996.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6016270}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1369", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1369"}, {"tipo": "3", "numero": "O-1369", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-1369"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCION LEGAL DEL PARTIDO SOCIALISTA DE CHILE EN LA I REGION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO SOCIALISTA DE CHILE", "PRIMERA REGION", "CONSTITUCION LEGAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-02", "doble_articulado": false, "id_norma": "36808", "numero_fuente": "35465", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-05-13", "vigencias": [{"desde": "1996-05-13", "hasta": "", "tipo_v