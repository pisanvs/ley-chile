{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6175274}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 27, de 02 de Febrero de 1988, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Atacama, se autoriza a Hern&#xE1;n Pizarro Noel para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6175275}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gloria Ver&#xF3;nica Isla Quezada, Secretario Regional Ministerial de Transportes y&apos; Telecomunicaciones Regi&#xF3;n de Atacama subrogante.</div><br></div>", "i": 6175276}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "27 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-27 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-02-02", "doble_articulado": false, "id_norma": "138407", "numero_fuente": "32994", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-12", "vigencias": [{"desde": "1988-02-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-02-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p