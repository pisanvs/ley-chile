{"html": [{"t": "<div><div class=\"p\">COMPLEMENTA RESOLUCI&#xD3;N EX. SII N&#xBA; 16, DE 06.02.2019</div></div>", "i": 10013077}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 38, de 27 de marzo de 2019, que establece:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Complementa <a href=\"https://www.leychile.cl/Navegar?idNorma=1128820&amp;idParte=&amp;idVersion=\">Res. Ex. SII N&#xBA; 16, de 06.02.2019</a>, que estableci&#xF3; plazo para que los productores, fabricantes o importadores de tabaco elaborado, puedan finalizar la comercializaci&#xF3;n de aquellos productos que no tienen incorporada la marcaci&#xF3;n establecida por el Sistema de Trazabilidad Fiscal.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII de marzo de 2019.</div></div>", "i": 10013078}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "38 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-38 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "COMPLEMENTA RESOLUCIÓN EX. SII Nº 16, DE 06.02.2019", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1569850", "EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-03-27", "doble_articulado": false, "id_norma": "1130254", "numero_fuente": "42321", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-04-03", "vigen