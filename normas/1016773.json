{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8973359}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP N&#xB0; 1007 de fecha 30 de julio del 2010, se modific&#xF3; el <a href=\"https://www.leychile.cl/Navegar?idNorma=1007608&amp;idParte=0&amp;idVersion=\">Decreto MOP N&#xBA;1555 de 30 de septiembre de 2009</a>, en el sentido de se&#xF1;alar que el Kilometraje final del lote 43-C, es 3,91525, a su superficie es 355 M2; y, en los numerales tercero y sexto, debe decir $21.387.738.- no como se indic&#xF3; en dicho decreto.</div><br></div>", "i": 8973360}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 8973361}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1007", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1007"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-07-30", "doble_articulado": false, "id_norma": "1016773", "numero_fuente": "39751", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-09-01", "vigencias": [{"desde": "2010-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "16291", "fecha_ingreso": "2010-09-01", "fecha_version": "2010-09-01", "actualizado_por": "16291", "fecha_actualizacion_texto":