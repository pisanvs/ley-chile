{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ORDENA EXPROPIACIONES QUE INDICA </div></div>", "i": 6009963}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 395 de 24 de abril de 1996 de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xB0; 2.186 de 1978, parte inmueble ubicado en la esquina Sur-Poniente de las Avdas. Departamental y Las Industrias, presunto rol de aval&#xFA;os N&#xB0; 5417-11 al 5417-44, 5414-16 al 5416-44, 5418-11 al 5418-44, comuna de San Joaqu&#xED;n, de aparente dominio de varios propietarios cuya identidad se desconoce. Comisi&#xF3;n integrada por peritos Carlos Pe&#xF1;a Vermejo, ingeniero civil; Jorge Navarro Navarrete y Roberto Correa Bezanilla, arquitectos seg&#xFA;n informe de 25 de octubre de 1995 fij&#xF3; monto provisional de indemnizaci&#xF3;n en $ 24.500.000 pagadera al contado.-</div><br></div>", "i": 6009964}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director Serviu Metropolitano.</div><br></div>", "i": 6009965}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "395", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-395"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SAN JOAQUIN", "REGION", "METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-04-24", "doble_articulado": false, "id_norma": "34597", "numero_fuente": "35579-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-10-01", "vigencias": [{"desde": "1996-10-01", "hasta": "", "tipo_versi