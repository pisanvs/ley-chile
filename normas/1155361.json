{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10197650}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xBA; 788, del 23 de diciembre de 2020, Serviu Regi&#xF3;n de &#xD1;uble orden&#xF3; expropiaci&#xF3;n parcial de inmueble ubicado en Avenida Huambal&#xED; N&#xBA; 140, comuna de Chill&#xE1;n, rol de aval&#xFA;o N&#xBA; 00697-00008, de aparente dominio de Fuentes Candia Miguel El&#xED;as. La parte afecta a expropiaci&#xF3;n parcial de terreno es de 168,03 m2 (Lote 29) y cuyos linderos particulares, enmarcados en el plano S16R-030, para el proyecto &quot;Mejoramiento Avenida Huambal&#xED;, Chill&#xE1;n&quot;, conforme art&#xED;culo 51 ley 16.391 y DL 2.186. Comisi&#xF3;n Peritos integrada por el arquitecto Mario Fabrizzio Bellolio Bostica, Constructor Civil &#xCD;talo Renzo Zerga Arancibia y por el Ingeniero Civil Orlando Javier Paredes V&#xE1;squez, que fij&#xF3; el monto de la indemnizaci&#xF3;n provisional por la expropiaci&#xF3;n, en la suma de $37.860.392.- </div></div>", "i": 10197651}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n de &#xD1;uble.</div><div class=\"p\"> </div><br></div>", "i": 10197652}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "788 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-788 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "XVI REGIÓN DE ÑUBLE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1887750", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-12-23", "do