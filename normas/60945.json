{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8301279}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xBA; 68 de 17 de Enero de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 1 de la Resoluci&#xF3;n N&#xBA; 240, de 1996, de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a PESQUERA VIENTO SUR S.A., para operar la nave &quot;Sunnan II&quot;, en el sentido de se&#xF1;alar que sus actuales caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><br><div class=\"p\">Nombre&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  &quot;Sunnan II&quot;</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2142</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp;  25,2&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; m.</div><div class=\"p\">T.R.G.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  98,1</div><div class=\"p\">Cap. de Bodega&nbsp; &nbsp; &nbsp;  127,9&nbsp; &nbsp; &nbsp; &nbsp;  m3.</div><div class=\"p\">Potencia total&nbsp; &nbsp; &nbsp;  563&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Hp.</div><div class=\"p\">Arte de pesca&nbsp; &nbsp; &nbsp; &nbsp; Arrastre de fondo</div><br></div>", "i": 8301280}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de enero de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8301281}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "68", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-68"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA VIENTO SUR S.A", "PESCA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tra