{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;152 EXENTO, DE 2000 </div></div>", "i": 6282089}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;152, de fecha 17 de mayo de 2000, del Ministerio de Educaci&#xF3;n, se declara modificado los planes y programas de estudios de la carrera de Derecho de la Universidad Mar&#xED;tima de Chile, que fueran aprobadas por la Universidad de Talca, en su calidad de entidad examinadora, seg&#xFA;n consta en Nota S/N&#xBA;de fecha 31 de marzo de 2000. Dichas modificaciones rigen a contar del presente a&#xF1;o acad&#xE9;mico.</div><br></div>", "i": 6282090}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 1&#xBA; de junio de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6282091}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "152 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-152 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº152 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-17", "doble_articulado": false, "id_norma": "170937", "numero_fuente": "36691", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-16", "vigencias": [{"desde": "2000-06-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-06-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-06-16", "fec