{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">DEJA SIN EFECTO RESOLUCIONES QUE INDICA</div></div>", "i": 9645658}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.771, de 16 de octubre de 2015, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto las resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=1080802&amp;idParte=&amp;idVersion=\">N&#xBA; 2.232</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1080803&amp;idParte=&amp;idVersion=\">N&#xBA; 2.233</a>, ambas de 2015, que otorgaron a Camanchaca Pesca Sur S.A. y a Bracpesca S.A., respectivamente, un permiso extraordinario de pesca para la unidad de pesquer&#xED;a del recurso hidrobiol&#xF3;gico Langostino colorado, en los porcentajes y condiciones indicados en las citadas resoluciones, en virtud de lo se&#xF1;alado en la parte considerativa de la resoluci&#xF3;n extractada.</div><br><br></div>", "i": 9645659, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de octubre de 2015.- Paolo Trejo Carmona, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9645660}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2771 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2771 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DEJA SIN EFECTO RESOLUCIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 961030", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-10-16", "doble_articulado": false, "id_