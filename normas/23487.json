{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede derecho a jubilar a don N&#xE9;stor S&#xE1;nchez.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,776.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275581}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- En atencion a los servicios prestados por el Secretario de la C&#xE1;mara de Diputados, don N&#xE9;stor S&#xE1;nchez, que se encuentra imposibilitado para continuar en el desempe&#xF1;o de sus funciones, conc&#xE9;dese el derecho de jubilar con el sueldo &#xED;ntegro asignado a su empleo.</div><br></div>", "i": 8275582}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 9 de Julio de 1913.- Ramon Barros Luco.- Manuel Rivas Vicu&#xF1;a.</div><br></div>", "i": 8275583}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2776", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2776"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Concede derecho a jubilar a don Néstor Sánchez.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NESTOR SANCHEZ", "SECRETARIO CAMARA DIPUTADOS", "DERECHO", "JUBILACION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1913-07-09", "doble_articulado": false, "id_norma": "23487", "numero_fuente": "10620", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1913-07-09", "vigencias": [{"desde": "1913-07-0