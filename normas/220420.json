{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION (A) N&#xBA; 262, DE 16-12-2003 </div></div>", "i": 6460573}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En cumplimiento de lo dispuesto en el decreto de Econom&#xED;a N&#xBA;291, de 11 de junio de 1999, certifico que por resoluci&#xF3;n (A) N&#xBA;262, de 16 de diciembre de 2003, del Sr. Vicepresidente Ejecutivo de la Corporaci&#xF3;n de Fomento de la Producci&#xF3;n, se puso en ejecuci&#xF3;n el Acuerdo de Consejo N&#xBA;2285, de 15 de diciembre de 2003, que modific&#xF3; la integraci&#xF3;n del Comit&#xE9; de Asignaci&#xF3;n de Fondos -CAF-</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de la citada resoluci&#xF3;n est&#xE1; a disposici&#xF3;n de los usuarios en la Secretar&#xED;a General de la Corporaci&#xF3;n y en las Direcciones Regionales. </div></div>", "i": 6460574}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de enero de 2004.- Corporaci&#xF3;n de Fomento de la Producci&#xF3;n, Yerko Koscina Peralta, Secretario General.</div><br></div>", "i": 6460575}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "262", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-262"}, {"tipo": "3", "numero": "A-262", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-A-262"}], "organismos": ["CORPORACIÓN DE FOMENTO DE LA PRODUCCIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION (A) Nº 262, DE 16-12-2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-16", "doble_articulado": false, "id_norma": "220420", "numero_fuente": "37767", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-01-23", "vigencias"