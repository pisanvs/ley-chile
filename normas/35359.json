{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293653}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 678, de 12 de abril de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por el SINDICATO DE TRABAJADORAS INDEPENDIENTES PESCADORAS ARTESANALES Y ALGUERAS LAS CARMELITAS, para un centro de cultivo ubicado en Sector Morro de Chanhue, Ribera Norte R&#xED;o de Maull&#xED;n, Comuna de Maull&#xED;n, Provincia de Llanquihue, X Regi&#xF3;n, conforme lo dispuesto en el art&#xED;culo 78, inciso 2&#xB0;, de la Ley General de Pesca y Acuicultura. </div></div>", "i": 8293654}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 12 de abril de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293655}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "678", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-678"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION ACUICULTURA", "DENEGACION", "DECIMA REGION", "SINDICATO TRABAJADORAS INDEPENDIENTES PESCADORAS", "ARTESANALES ALGUERAS LAS CARMELITAS", "MAULLIN"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-04-12", "fecha_derogacion": "1997-05-16", "doble_articulado": false, "id_norma": "35359", "numero_fuente": "35446", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-04-19", "vigencias": [{"desde": "1997-05-16", "hasta": "", "tipo_version": "2", "tipo_version_s": "Ú