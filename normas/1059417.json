{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 163 EXENTA, DE 2008</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 16, del 7 de febrero de 2014, que establece:</div></div>", "i": 9406494}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=283853&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta del SII N&#xBA; 163, de fecha 16.12.2008</a>, que establece nuevos formatos de declaraci&#xF3;n jurada solicitud de devoluci&#xF3;n por cambio de sujeto de derecho del IVA, en lo referido a la documentaci&#xF3;n que deben presentar los peticionarios de este tipo de devoluciones.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de febrero de 2014.</div></div>", "i": 9406495}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Alejandro Burr Ort&#xFA;zar, Director.</div></div>", "i": 9406496}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "16 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-16 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 163 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-02-07", "doble_articulado": false, "id_norma": "1059417", "numero_fuente": "40782", "tipo_version": "3"