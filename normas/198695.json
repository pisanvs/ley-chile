{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xB0; 76, DE 1988</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 24.- Santiago, 27 de Febrero de 1989.- Visto: Lo dispuesto por los art&#xED;culos 56&#xB0;, 88&#xB0; y 89&#xB0; de la Ley 18.290; art&#xED;culo 4&#xB0; letra h) del DFL N&#xB0; 279, de 1960 y 3&#xB0; de la Ley N&#xB0; 18.696.</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 7414766}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Sustit&#xFA;yese en los n&#xFA;meros 1 y 2 de la resoluci&#xF3;n N&#xB0; 76 de 1988 del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, la expresi&#xF3;n &quot;Regi&#xF3;n Metropolitana&quot; por &quot;Provincia de Santiago&quot;.</div><br></div>", "i": 7414767}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- Carlos Silva Echiburu, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo para su conocimiento.- Saluda a Ud.- Patricia Mu&#xF1;oz Villela, Jefe Depto. Administrativo. </div></div>", "i": 7414768}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "24", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-24"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "MODIFICA RESOLUCION N° 76, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-02-27", "doble_articulado": false, "id_norma": "198695", "numero_fuente": "33326", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-03-18", "vi