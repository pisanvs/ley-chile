{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10155141}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto (Exento) MOP. N&#xB0;469 de 26 de junio de 2020, se modific&#xF3; y desisti&#xF3; parcialmente de la expropiaci&#xF3;n del lote N&#xB0; 11-B, realizada por <a href=\"https://www.leychile.cl/Navegar?idNorma=1040516&amp;idParte=&amp;idVersion=\">Decreto (Exento) MOP. N&#xB0;644 de 09 de abril de 2012</a>, expropiado para la ejecuci&#xF3;n de obra &quot;Ampliaci&#xF3;n Ruta 5, Sector Copiap&#xF3; - Toledo, Tramo I&quot;, reduci&#xE9;ndose la superficie expropiada a 10.618 m2 y modificando el numeral segundo de dicho Decreto, se&#xF1;alando como nuevo propietario a SCUOLA ITALIANA DI COPIAPO, rol de aval&#xFA;o 38-16, de la comuna de Copiap&#xF3;. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en los art&#xED;culos 7&#xBA; y 32&#xB0; del Decreto Ley N&#xB0;2186, de 1978. </div></div>", "i": 10155142}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10155143}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "469 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-469 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1805048"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-06-26", "doble_articulado": false, "id_norma": "1148882", "numero_fuente": "42745", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-09-01", "vigencias": [{"desde": "2020-09-01", "hasta": "", "