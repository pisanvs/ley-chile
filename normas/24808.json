{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><br></div>", "i": 7169479}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Trasp&#xE1;sase la cantidad de trescientos sesenta y cinco mil pesos ($ 365,000) del &#xED;tem 01, Cap&#xED;tulo 02, Partida 07 al &#xED;tem 04 e, Cap&#xED;tulo 02, Partida 07 en el Presupuesto de Educaci&#xF3;n P&#xFA;blica vigente&quot;.</div><div class=\"p\">&nbsp; &nbsp; Esta ley comenzar&#xE1; a regir desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 7169480}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintitr&#xE9;s de Septiembre de mil novecientos veintinueve.- Carlos Ib&#xE1;&#xF1;ez C.- Mariano Navarrete C.</div><br></div>", "i": 7169481}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4655", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4655"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO ENTRADAS GASTOS", "1929", "A O", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-09-23", "doble_articulado": false, "id_norma": "24808", "numero_fuente": "15479", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-09-23", "vigencias": [{"desde": "1929-09-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-09-2