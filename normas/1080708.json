{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE INDICA</div></div>", "i": 9629945}, {"t": "<div><div class=\"p\">&nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.143 de 11 de agosto de 2015 de esta Subsecretar&#xED;a, modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1071500&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.211 de 2014</a> de esta Subsecretar&#xED;a, que autoriz&#xF3; a Deris S.A. para realizar operaciones pesqueras de conformidad con lo dispuesto en el art&#xED;culo 12 transitorio de la ley N&#xBA; 18.892, en el sentido de incorporar a la nave f&#xE1;brica &quot;Saint Pierre&quot;, la que podr&#xE1; operar en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 47&#xBA; L.S. y 57&#xBA; L.S., en aguas exteriores, respecto de los recursos y con las obligaciones establecidas en la resoluci&#xF3;n exenta N&#xBA; 2.061 de 2015, de esta Subsecretar&#xED;a.</div></div>", "i": 9629946}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de agosto de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9629947}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2143 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2143 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-08-11", "doble_articulado": false, "id_norma": "1080708", "numero_fuente": "41237", "tipo_version": "3", "t