{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE ORDENANZA N&#xBA; 142, DE 2015</div></div>", "i": 9647414}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por ordenanza N&#xBA; 142, de 27 de octubre de 2015, se modifica la ordenanza N&#xBA; 22, de 28 de diciembre de 2001, &quot;Ordenanza Local sobre Derechos Municipales&quot;, que rige para el a&#xF1;o 2015, cuyo texto refundido y sistematizado fue fijado <a href=\"https://www.leychile.cl/Navegar?idNorma=1075354&amp;idParte=0&amp;idVersion=\">por decreto alcaldicio Ex. N&#xBA; 2.547, de 23 de diciembre de 2014</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo se podr&#xE1; previsualizar en la p&#xE1;gina web municipal, www.providencia.cl en Transparencia Municipal en:</div><br><div class=\"p\">&nbsp; &nbsp;  . Carpeta Potestades y Marco Normativo / Marco Normativo Aplicable / Ordenanzas / Derecho / Sobre Derechos Municipales.</div><div class=\"p\">&nbsp; &nbsp;  . Carpeta Actos y Resoluciones / Actos y Resoluciones con efectos sobre terceros / Ordenanzas / Derecho / Sobre Derechos Municipales.</div></div>", "i": 9647415}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La Alcaldesa.</div></div>", "i": 9647416}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "142", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "Ordenanza-142"}], "organismos": ["MUNICIPALIDAD DE PROVIDENCIA"], "titulo_norma": "EXTRACTO DE ORDENANZA Nº 142, DE 2015", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 962724; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-10-27", "doble_articulado": false, "id_norma": "1083604", "numero_fuente": "41299", "tipo_version": "3", "tipo_ve