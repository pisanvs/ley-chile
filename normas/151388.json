{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8356644}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.579, de 27 de diciembre de 1999 de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA SURIBERICA S.A., para realizar operaciones pesqueras, a contar del 1&#xBA; de enero del a&#xF1;o 2000 y hasta el 31 de diciembre del mismo a&#xF1;o, ambas fechas inclusive, con el barco f&#xE1;brica denominado &apos;&apos;Isla Camila&apos;&apos;, en aguas interiores, al Sur del paralelo 47&#xB0; L.S., respecto de los recursos y con las obligaciones, establecidas en sus respectivas resoluciones.</div><br></div>", "i": 8356645}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de diciembre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8356646}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2579", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2579"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA SURIBERICA S.A.", "OPERACIONES PESQUERAS", "BARCO FABRICA", "ISLA CAMILA", "AUTORIZA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-27", "doble_articulado": false, "id_norma": "151388", "numero_fuente": "36564", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-01-17", "vigencias": [{"desde": "2000-01-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-01-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-01-17", "fin_vigencia": "", "tipo_versio