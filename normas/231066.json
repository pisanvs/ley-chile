{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;92 EXENTA, DE 28 DE SEPTIEMBRE DE&nbsp; 2004 </div></div>", "i": 8660153}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Establece obligaci&#xF3;n para las personas e</div><div class=\"p\">instituciones que se indican de informar al Servicio de</div><div class=\"p\">Impuestos Internos las donaciones en dinero que reciban</div><div class=\"p\">para fines p&#xFA;blicos, de acuerdo a lo dispuesto por el</div><div class=\"p\">art&#xED;culo 8&#xBA; de la ley 19.885 de 2003.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio Web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, se publicar&#xE1; en el Bolet&#xED;n del SII del mes de septiembre de 2004.</div><br></div>", "i": 8660154}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "92 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-92 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº92 EXENTA, DE 28 DE SEPTIEMBRE DE 2004", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": ["DONACIONES ELECTORALES", "PARTIDOS POLITICOS", "DONACIONES EN DINERO", "INSTITUTOS DE FORMACION POLITICA", "FRANQUICIAS TRIBUTARIAS", "REQUISITOS", "BENEFICIOS TRIBUTARIOS", "CERTIFICADO DE DONACION", "CANDIDATOS", "SECRETO TRIBUTARIO", "OBLIGACION DE INFORMAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-09-28", "fecha_derogacion": "2017-02-16", "doble_articulado": false, "id_norma": "231066", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-10-05", "vigencias": [{"desde":