{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.565&nbsp; EXENTA, DE 1998 </div></div>", "i": 6105912}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Res. Ex. N&#xBA;1.565, de fecha 18 de marzo de 1998, se posterg&#xF3; la entrada en vigencia de la Res. Ex.</div><div class=\"p\">N&#xBA;6.582 que establece el procedimiento de operaci&#xF3;n en las ventas de colaciones por medio de vales o cupones, al 1&#xBA; de junio de 1998.</div><div class=\"p\">En consecuencia, dicho procedimiento de operaci&#xF3;n s&#xF3;lo ser&#xE1; exigible a partir del 1&#xBA; de junio de 1998. </div></div>", "i": 6105913}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese y publ&#xED;quese.- Javier Etcheberry Celhay, Director.</div><br></div>", "i": 6105914}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1565 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1565 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.565 EXENTA, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PROCEDIMIENTO", "VENTA", "COLACION", "VALES", "CUPONES", "ALMUERZOS", "COLACIONES", "VIGENCIA", "POSTERGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-03-18", "doble_articulado": false, "id_norma": "97326", "numero_fuente": "36021", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-03-21", "vigencias": [{"desde": "1998-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-03-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-03-21", "fin_vigenci