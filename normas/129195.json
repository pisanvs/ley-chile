{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6146280}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Secc. 2da. No. 777, 08 de Julio de 1988, Alcalde I. Municipalidad de Santiago, dispone expropiaci&#xF3;n total inmueble Coronel Pantoja 139 y Vidaurre 1667 - 1669, Rol 448-11 Comuna de Santiago, aparentemente dominio sucesi&#xF3;n Forster Berguecio. Deslindes: Norte, 15,90 mts. otro propietario y 0,90 ctms. otro propietario; Sur, 19,10 mts. calle Vidaurre; Oriente, 24,95 Coronel Pantoja; Poniente, 23,20 otro propietario. Indemnizaci&#xF3;n provisional $ 4.969.725,- pagadera contado.</div><br></div>", "i": 6146281}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gustavo Alessandri V., Alcalde Santiago. </div></div>", "i": 6146282}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "777", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-777"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-07-08", "doble_articulado": false, "id_norma": "129195", "numero_fuente": "33135", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-08-01", "vigencias": [{"desde": "1988-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-01-12", "fecha_version": "1988-08-01", "fecha_actualizacion_texto": "1988-08-01", "tipo_tratado": ""}, "alertas":