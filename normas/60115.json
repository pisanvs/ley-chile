{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8300474}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 2.178, de 27 de diciembre de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento</div><div class=\"p\">y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de</div><div class=\"p\">acuicultura presentada por PESQUERA CERNA ROSALES LIMITADA, para</div><div class=\"p\">un sector ubicado en la localidad de Teupa, Comuna de Castro,</div><div class=\"p\">provincia de Chilo&#xE9;, X Regi&#xF3;n, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 78&#xBA;, inciso 2&#xBA;, de la Ley General de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xBA; 432, de 1988, de esta Subsecretar&#xED;a, en virtud de lo se&#xF1;alado precedentemente. </div></div>", "i": 8300475}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de diciembre de 1996.Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8300476}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2178", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2178"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA CERNA ROSALES LIMITADA", "CONCESION DE ACUICULTURA", "DENEGACION", "CASTRO", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-12-27", "doble_articulado": false, "id_norma": "60115", "numero_fuente": "35661", "tipo_version": "3", "tipo_version_s": "Única", "fe