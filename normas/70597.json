{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 310 EXENTO, DE 1997 </div></div>", "i": 7205959}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 310 de 14 de marzo de 1997, se ha aprobado a la Scuola Italiana &quot;Vittorio Montiglio&quot; de Santiago, para que, a partir del a&#xF1;o escolar 1997, aplique planes y programas de estudio biling&#xFC;e en el 1&#xBA;&nbsp; y 2&#xBA; a&#xF1;o de ense&#xF1;anza b&#xE1;sica (NB.1), de acuerdo al cronograma establecido en el Decreto Supremo de Educaci&#xF3;n N&#xBA; 40 de 1996.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los cursos de 1&#xBA; y 2&#xBA; a&#xF1;o b&#xE1;sico.</div><br></div>", "i": 7205960}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 2 de abril de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7205961}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "310 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-310 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 310 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SCUOLA ITALIANA VITTORIO MONTIGLIO", "SANTIAGO", "REGION METROPOLITANA", "PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-14", "doble_articulado": false, "id_norma": "70597", "numero_fuente": "35739", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-12", "vigencias": [{"desde": "1997-04-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia"