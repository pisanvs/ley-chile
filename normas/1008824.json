{"html": [{"t": "<div><br><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL EN SU SESI&#xD3;N ORDINARIA N&#xBA; 1512</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile, en su Sesi&#xF3;n Ordinaria N&#xBA; 1512, celebrada el 3 de diciembre de 2009, adopt&#xF3; el siguiente Acuerdo:</div></div>", "i": 8812796}, {"t": "<div><br><div class=\"p\">1512-05-091203 -Modifica Cap&#xED;tulo III.F.6 del Compendio de Normas Financieras.</div><br><div class=\"p\">-&nbsp; &nbsp; Suprimir, en el Cap&#xED;tulo III.F.6 del Compendio de Normas Financieras, la expresi&#xF3;n &quot;al a&#xF1;o 2008&quot; y agregar, antes del punto aparte, lo siguiente: &quot;, en tanto el Banco no determine modificarlo para un pr&#xF3;ximo per&#xED;odo anual en uso de sus facultades legales&quot;.</div><br></div>", "i": 8812797}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de diciembre de 2009.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 8812798}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1512", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1512"}, {"tipo": "5", "numero": "1512-05", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1512-05"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL EN SU SESIÓN ORDINARIA Nº 1512", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-12-03", "doble_articulado": false, "id_norma": "1008824", "numero_fuente": "39530", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-12-07", "vigencias": [{"desde": "2009