{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6746092}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.540, de 12 de diciembre de 2007, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 2.764 de 2007, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESCA CHILE S.A. para realizar actividades pesqueras extractivas con una nave en construcci&#xF3;n, en el &#xE1;rea mar&#xED;tima del litoral comprendido entre los paralelos 37&#xB0; L.S. y 41&#xB0;28,6&apos; L.S. sobre el recurso Raya volant&#xED;n Dipturus chilensis, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura. </div></div>", "i": 6746093}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de diciembre de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 6746094}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3540 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3540 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-12-12", "doble_articulado": false, "id_norma": "267720", "numero_fuente": "38939", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-18", "vigencias": [{"desde": "2007-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-12-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-12-18", "fin