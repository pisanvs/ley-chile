{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PABLO WILKINSON Lei n&#xFA;m. 320.-Santiago, a 13 de Diciembre de 1895.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947512}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se declara, por gracia, que el ex-teniente del Ej&#xE9;rcito constitucional, don Pablo Wilkinson, tiene opcion a los beneficios que acuerda el art&#xED;culo 3.&#xB0; de la lei de 2 de Febrero de 1892.</div><br><br></div>", "i": 5947513}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORJE MONTT.- Luis Barros Borgo&#xF1;o.</div><br></div>", "i": 5947514}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "320", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-320"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PABLO WILKINSON", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PABLO WILKINSON", "BENEFICIO POR GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-12-13", "doble_articulado": false, "id_norma": "22171", "numero_fuente": "5296", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-12-28", "vigencias": [{"desde": "1895-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-12-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1895-12-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": []