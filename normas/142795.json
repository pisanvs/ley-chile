{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 3,679.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6189346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al visitador de escuelas jubilado, don Pedro P. Morales Vera el aumento de su pension de jubilacion hasta el monto &#xED;ntegro del sueldo de que gozaba a la fecha de su jubilacion. El aumento rejir&#xE1; desde la publicacion de esta lei en el Diario Oficial.</div><br></div>", "i": 6189347}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a cinco de noviembre de mil novecientos veinte.- Juan Luis Sanfuentes.- Lorenzo Montt. </div></div>", "i": 6189348}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3679", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3679"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1920-11-05", "doble_articulado": false, "id_norma": "142795", "numero_fuente": "12829", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1920-11-23", "vigencias": [{"desde": "1920-11-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1920-11-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1920-11-23", "fin_vigencia":