{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6275282}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;786, de 29 de febrero de 2000, se expropiaron los lotes de terreno N&#xBA;s. 1 y 6, superficies 260 y 60 m&#xB2;, roles de aval&#xFA;o 139-1 y 52-93, comunas de Peralillo y Pumanque respectivamente, para la obra Camino Ruta I-60, Sector Poblaci&#xF3;n Pumanque y se acord&#xF3; precio de las indemnizaciones con sus propietarios, Inmobiliaria e Inversiones Siete Mares S.A. y Manuel Benito Flores Quinteros, ascendentes a las cantidades de $949.683, lote N&#xBA;1 y $469.878, lote N&#xBA;6.</div><br></div>", "i": 6275283}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6275284}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "786", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-786"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-29", "doble_articulado": false, "id_norma": "168656", "numero_fuente": "36663", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-15", "vigencias": [{"desde": "2000-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-05-15", "fecha_version": "2000-05-15", "fecha_actualizacion_texto": "2000-05-15