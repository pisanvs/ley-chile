{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 4.157 EXENTA, DE 2014</div></div>", "i": 9497986}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 4.157, de 4 de agosto de 2014, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Capacitaciones Mauricio Valderrama E.I.R.L. (Life Training E.I.R.L.)&quot;, RUT 76.301.618-8 contenida en la resoluci&#xF3;n exenta N&#xBA; 1.087, de 6 de marzo de 2014, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 3, del Art. 21 de la ley 19.518.</div></div>", "i": 9497987}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Marcia Pardo Gonz&#xE1;lez, Jefe del Departamento de Desarrollo y Regulaci&#xF3;n de Mercado (PT).</div></div>", "i": 9497988}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4157 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4157 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 4.157 EXENTA, DE 2014", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2014-08-04", "fecha_derogacion": "2014-09-30", "doble_articulado": false, "id_norma": "1065567", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2014-08-19", "vigencias": [{"desde": "2014-09-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2014-08-19", "hasta": "2014-09-29", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigenc