{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6348850}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante Resoluci&#xF3;n Ministerial N&#xBA;73, de fecha 25 de julio del 2001, se aprob&#xF3; la reforma integral al estatuto de la Sociedad Cooperativa de Ahorros Santo Cura de Ars Limitada, en adelante Cooperativa de Ahorro y Cr&#xE9;dito Santo Cura de Ars Limitada, en los t&#xE9;rminos que da testimonio la escritura p&#xFA;blica otorgada con fecha 11 de enero del 2001, ante el Notario de Santiago don Arturo Carvajal Escobar, rectificada por escritura p&#xFA;blica otorgada con fecha 15 de junio del 2001, ante el mismo notario.</div><br></div>", "i": 6348851}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Sr. Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6348852}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "73", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-73"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-07-25", "doble_articulado": false, "id_norma": "189220", "numero_fuente": "37059", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-09-11", "vigencias": [{"desde": "2001-09-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-09-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "200