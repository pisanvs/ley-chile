{"html": [{"t": "<div><br><div class=\"p\">CONSTITUCI&#xD3;N PARTIDO PROGRESISTA EN III REGI&#xD3;N DE ATACAMA</div></div>", "i": 9239883}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Marco Enr&#xED;quez-Ominami Gumucio, Presidente de la Directiva Central del Partido Progresista, ha solicitado la constituci&#xF3;n legal del partido en la III Regi&#xF3;n de Atacama. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de 642 fichas de afiliaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la ley N&#xB0; 18.603, por resoluci&#xF3;n N&#xB0; O-237, de fecha de 13 de febrero de 2012.- </div><br></div>", "i": 9239884}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Elizabeth Cabrera Burgos, Directora (S).</div></div>", "i": 9239885}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "237", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-237"}, {"tipo": "3", "numero": "O-237", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-237"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "CONSTITUCIÓN PARTIDO PROGRESISTA EN III REGIÓN DE ATACAMA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-02-13", "doble_articulado": false, "id_norma": "1037666", "numero_fuente": "40204", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-03-05", "vigencias": [{"desde": "2012-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-03-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-03-05", "fin