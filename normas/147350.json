{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8353142}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.253, de 29 de octubre de 1999, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la resoluci&#xF3;n N&#xBA; 254 de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la SOCIEDAD MAGUILLINES LIMITADA, para operar la nave &apos;&apos;Heracles&apos;&apos;, matr&#xED;cula 560 de Constituci&#xF3;n, en virtud de lo se&#xF1;alado en el art&#xED;culo 143 letra b), del D.S. N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, por no haber operado la mencionada nave, por m&#xE1;s de doce meses en las pesquer&#xED;as autorizadas.</div><br></div>", "i": 8353143}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de octubre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8353144}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2253", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2253"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-29", "doble_articulado": false, "id_norma": "147350", "numero_fuente": "36511", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-11-11", "vigencias": [{"desde": "1999-11-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-11-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-11-11", "fin_vigencia": "", "tipo_version": "3"