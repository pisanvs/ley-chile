{"html": [{"t": "<div><div class=\"p\">MODIFICA CONCESIONES DE ACUICULTURA QUE SE INDICAN, EN LA X REGION DE LOS LAGOS </div></div>", "i": 7278133}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Mediante resoluci&#xF3;n (M) N&#xBA; 1.556, de fecha 1 de septiembre de 2000, de esta Subsecretar&#xED;a de Marina del Ministerio de Defensa Nacional, se resolvi&#xF3; lo siguiente:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; 1.- Modif&#xED;canse las resoluciones (M) N&#xBA;s. 1.188 y 1.189, ambas de 1997, en el sentido que se sustituye &#xED;ntegramente en sus textos la raz&#xF3;n social Alimentos Multiexport Limitada y RUT, por los siguientes:</div><div class=\"p\">Salmones&nbsp; Multiexport&nbsp; Limitada, RUT N&#xBA;79.891.160-0&quot;.</div><br></div>", "i": 7278134}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Santiago, 23 de octubre de 2000.- Jorge Minoletti Olivares, Subsecretario de Marina.</div><br></div>", "i": 7278135}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1556", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1556"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "MODIFICA CONCESIONES DE ACUICULTURA QUE SE INDICAN, EN\nLA X REGION DE LOS LAGOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-01", "doble_articulado": false, "id_norma": "177750", "numero_fuente": "36814", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-11-16", "vigencias": [{"desde": "2000-11-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-11-16", "fin_vigencia": ""}, "vigencias_versio