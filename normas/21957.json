{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Amnist&#xED;a Lei n&#xFA;m. 89.- Santiago, a 28 de Agosto de 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273687}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se concede amnist&#xED;a para los delitos pol&#xED;ticos cometidos desde el 1.&#xB0; de Enero hasta el 28 de Agosto de 1891 i que no hubieren sido comprendidos en las leyes de 25 de Diciembre de 1891 i 4 de Febrero de 1893.</div><div class=\"p\">&nbsp; &nbsp; Se escept&#xFA;an de esta amnist&#xED;a los responsables en el suceso de &quot; Lo Ca&#xF1;as&quot; i los ex-Ministros de Estado que firmaron el decreto que estableci&#xF3; la dictadura i cuya acusacion pende ante el Senado.</div><br><br></div>", "i": 8273688}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.-Pedro Montt.</div><br></div>", "i": 8273689}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "89", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-89"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AMNISTIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AMNISTIA", "DELITOS POLITICOS", "EXCEPCIONES", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-08-28", "doble_articulado": false, "id_norma": "21957", "numero_fuente": "4606", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-08-28", "vigencias": [{"desde": "1893-08-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-08-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-08-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-01-07", "fecha_version": "1893-08-28", "fecha_actualizacion_texto": "1893-08-28", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8273687}, {"n": "Artículo UNICO", "i": 8273688, "t": 6}, {"n": "Promulgación", "i": 8273689}]}