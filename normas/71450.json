{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 457 EXENTO, DE 1997 </div></div>", "i": 6037050}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 457 de</div><div class=\"p\">18 de abril de 1997, se ha aprobado al Colegio</div><div class=\"p\">&apos;&apos;Lirima&apos;&apos; de Iquique, un plan de estudio para los</div><div class=\"p\">cursos de 1&#xBA; a 4&#xBA; a&#xF1;o (NB.1 y NB.2) de Ense&#xF1;anza B&#xE1;sica,</div><div class=\"p\">los cuales podr&#xE1;n ser aplicados a partir del a&#xF1;o escolar</div><div class=\"p\"> 1997, de acuerdo al cronograma establecido en el</div><div class=\"p\">art&#xED;culo 4&#xBA; del Decreto Supremo de Educaci&#xF3;n N&#xBA; 40 de 1996. Adem&#xE1;s, se aprueba programa de la asignatura (subsector de aprendizaje) Ingl&#xE9;s para 1&#xBA; a 4&#xBA; a&#xF1;o b&#xE1;sico.</div><br></div>", "i": 6037051}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de abril de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6037052}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "457 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-457 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 457 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO LIRIMA", "PLAN DE ESTUDIO", "APROBACION", "IQUIQUE", "PRIMERA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-18", "doble_articulado": false, "id_norma": "71450", "numero_fuente": "35766", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-15", "vigencias": [{"desde": "1997-05-15