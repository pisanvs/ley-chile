{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SUPLEMENTO Lei n&#xFA;m. 228.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947224}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de cuatro mil quinientos pesos ($ 4,500) al &#xED;tem 413 de la partida 16 del presupuesto del Ministerio de Justicia, que asigna quinientos pesos ($ 500) para el servicio de la c&#xE1;rcel de Mariluan.</div><br><br></div>", "i": 5947225}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 26 de Diciembre de 1894.- JORJE MONTT.-</div><div class=\"p\">O. Renjifo.</div><br></div>", "i": 5947226}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "228", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-228"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1894", "MODIFICACION", "MINISTERIO", "JUSTICIA CARCEL MARILUAN", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-12-26", "doble_articulado": false, "id_norma": "22084", "numero_fuente": "4998", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-12-26", "vigencias": [{"desde": "1894-12-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-12-26", "fin_vigencia": ""}, "vi