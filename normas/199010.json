{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6384376}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 901, de 9 de mayo de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PRODUCTORA Y COMERCIALIZADORA AGROCAMARONES LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en calle s/n, Salala, comuna de Ovalle, Provincia de Limar&#xED;, IV Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n de fresco- enfriado, fresco-refrigerado y congelado, el recurso hidrobiol&#xF3;gico camar&#xF3;n de r&#xED;o.</div><br></div>", "i": 6384377}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de mayo de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6384378}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "901", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-901"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-09", "doble_articulado": false, "id_norma": "199010", "numero_fuente": "37277", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-07", "vigencias": [{"desde": "2002-06-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-06-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-06-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "