{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MUNICIPALIDAD DE LA SERENA Lei n&#xFA;m. 372.- Santiago, a 12 de Agosto de 1896.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273964}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese a la Municipalidad de la Serena un auxilio estraordinario de diez mil pesos, que invertir&#xE1; en el mantenimiento de la polic&#xED;a de seguridad durante los meses de Julio i Agosto del presente a&#xF1;o.</div><br><br></div>", "i": 8273965}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- O. Renjifo.</div><br></div>", "i": 8273966}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "372", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-372"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MUNICIPALIDAD DE LA SERENA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDAD DE LA SERENA", "POLICIA SEGURIDAD", "MANTENIMIENTO", "FONDOS", "VIGENCIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-08-12", "doble_articulado": false, "id_norma": "22222", "numero_fuente": "5480", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1896-08-12", "vigencias": [{"desde": "1896-08-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1896-08-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1896-08-12", "fin_v