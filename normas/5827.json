{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; TRASPASA FONDOS</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 170.- Santiago, 8 de Julio de 1932.-</div><div class=\"p\">&nbsp; &nbsp; Hemos acordado y decretamos:</div><br></div>", "i": 7123416}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Trasp&#xE1;sase las siguientes cantidades del &#xED;tem 7/5/4/e (arriendo de bienes ra&#xED;ces de ense&#xF1;anza comercial) del Presupuesto de Educaci&#xF3;n P&#xFA;blica vigente a los &#xED;tem que se indican del mismo Presupuesto:</div><div class=\"p\">&nbsp; &nbsp; $ 10,543.92, a 7/3/4/e (arriendo de bienes ra&#xED;ces de Educaci&#xF3;n Secundaria).</div><div class=\"p\">&nbsp; &nbsp; $ 25,576.08, a 7/2/4/e (arriendo de bienes ra&#xED;ces de Educaci&#xF3;n Primaria).</div><br></div>", "i": 7123417}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Pract&#xED;quense por la Contralor&#xED;a General las operaciones correspondientes a los &#xED;tem referidos.</div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- CARLOS DAVILA.- C. Soto.</div><br></div>", "i": 7123418}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "170", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-170"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "TRASPASA FONDOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1932", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-07-08", "doble_articulado": false, "id_norma": "5827", "numero_fuente": "16337", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-07-30", "vigencias": [{"desde": "1932-07-30", "hasta": "", "tipo_ve