{"html": [{"t": "<div><div class=\"p\">ACEPTA RENUNCIA A DON EDMUNDO JAIME PEREZ YOMA EN CARGO QUE INDICA</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de enero de 1998.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 67.- Visto: Lo dispuesto en el art&#xED;culo 32 n&#xFA;meros 9 y 10 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile.</div><br><div class=\"p\">&nbsp; &nbsp;  D e c r e t o:</div><br></div>", "i": 8323872}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico: Ac&#xE9;ptase, a contar de esta fecha, la renuncia a don Edmundo Jaime P&#xE9;rez Yoma al cargo de Ministro de Defensa Nacional.</div><br></div>", "i": 8323873}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- EDUARDO FREI RUIZ-TAGLE, Presidente de la Rep&#xFA;blica.- Carlos Figueroa Serrano, Ministro del Interior.</div><br><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud., para su conocimiento.- Saluda a Ud., Belisario Velasco Baraona, Subsecretario del Interior.</div><br></div>", "i": 8323874}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "67", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-67"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARIA DEL INTERIOR"], "titulo_norma": "ACEPTA RENUNCIA A DON EDMUNDO JAIME PEREZ YOMA EN CARGO\nQUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RENUNCIA VOLUNTARIA", "EDMUNDO JAIME PEREZ YOMA", "MINISTRO DE DEFENSA", "MINISTERIO DE DEFENSA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-01-16", "doble_articulado": false, "id_norma": "93902", "numero_fuente": "35982", "tipo_version