{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6275525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.071, de 30 de marzo del 2000, se expropi&#xF3; el lote de terreno N&#xBA;498, superficie 128 m2, rol de aval&#xFA;o 1465-4, comuna de Puente Alto, para la obra Concesi&#xF3;n Internacional Ruta 5, Tramo Santiago-Talca. Sector a: Acceso Sur a Santiago, Regi&#xF3;n Metropolitana y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Oriana Burgos Altamirano, ascendente a la cantidad de $13.721.869.</div><br></div>", "i": 6275526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6275527}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1071", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1071"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-03-30", "doble_articulado": false, "id_norma": "168740", "numero_fuente": "36663", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-15", "vigencias": [{"desde": "2000-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2000-05-16", "fecha_version": "2000-05-15", "fecha_actualizacion_texto": "2000-05-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura":