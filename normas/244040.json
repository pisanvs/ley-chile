{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6548592}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA; 1.070 de 26 de octubre de 2005, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA; del decreto MOP exento N&#xBA; 576 de 31 de marzo de 2004, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n del lote N&#xBA; 5, fijada por la Comisi&#xF3;n de Peritos, con fecha 10 de agosto de 2001, ascendente a la cantidad de $193.600.</div><br></div>", "i": 6548593}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6548594}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1070 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1070 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-10-26", "doble_articulado": false, "id_norma": "244040", "numero_fuente": "38312", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-11-15", "vigencias": [{"desde": "2005-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso":