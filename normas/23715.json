{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aumenta la asignacion concedida para el hospital de San Fernando</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,075.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275921}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- El&#xE9;vase de $ 30,000 a $ 40,000 la asignacion al hospital de San Fernando que consulta el &#xED;tem 2,133, partida 10, del proyecto de presupuesto para 1916, correspondiente al Ministerio del Interior. </div></div>", "i": 8275922}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 24 de Marzo de 1916.- JUAN LUIS SANFUENTES.- Maximiliano Ib&#xE1;&#xF1;ez.</div><br></div>", "i": 8275923}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3075", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3075"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Aumenta la asignacion concedida para el hospital de;San Fernando", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["HOSPITAL SAN FERNANDO", "ASIGNACION", "MODIFICACION", "PRESUPUESTO A O 1916", "MINISTERIO INTERIOR."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-03-24", "doble_articulado": false, "id_norma": "23715", "numero_fuente": "11433", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-03-30", "vigencias": [{"desde": "1916-03-30", "hasta": "", "tipo_version": "3",