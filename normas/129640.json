{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br><br><br></div>", "i": 7243834}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 330, de 25 de Julio de 1988, la Subsecretar&#xED;a de Telecomunicaciones aprob&#xF3; la Norma de Ex&#xE1;menes para optar a Licencias de Aficionados a las Radiocomunicaciones, estableci&#xE9;ndose el procedimiento para rendir los ex&#xE1;menes estipulados en los art&#xED;culos 16&#xB0;, 18&#xB0; y 20&#xB0; del Reglamento del Servicio de Aficionados, decreto No.</div><div class=\"p\">45, de 26 de Abril de 1984.</div><div class=\"p\">Se deja sin efecto las resoluciones exentas No. 350, del 29 de Octubre de 1985 y No. 137, del 13 de Mayo de 1986, ambas de la Subsecretar&#xED;a de Telecomunicaciones.</div><div class=\"p\">La Subsecretar&#xED;a de Telecomunicaciones proporcionar&#xE1; ejemplares de la citada resoluci&#xF3;n a los Radio Clubes, a las organizaciones que los agrupen o a las personas interesadas en rendir examen.-</div><br></div>", "i": 7243835}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gustavo Arenas Corral, Coronel de Ej&#xE9;rcito, Subsecretario de Telecomunicaciones.</div><br></div>", "i": 7243836}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "330 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-330 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RADIOCOMUNICACIONES", "SERVICIO DE AFICIONADOS", "LICENCIAS DE AFICIONADOS", "EXAMENES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1988-07-25", "fecha_derogac