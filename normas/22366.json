{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplementos Lei n&#xFA;m. 1,040.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br></div>", "i": 9042095}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Conc&#xE9;dese un suplemento de 1.025,395 pesos al &#xED;tem 31 de la partida 4.a del presupuesto de Marina; 440,895 pesos al &#xED;tem 32 de la misma partida i presupuesto; i 860,000 pesos al &#xED;tem 7 de la partida 21 del indicado presupuesto.</div><br></div>", "i": 9042096}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 8 de Junio de 1898.- FEDERICO ERRAZURIZ.- V. Blanco.</div><br></div>", "i": 9042097}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1040", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1040"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "SUPLEMENTOS", "fuente": "Boletin de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1898", "MODIFICACION", "MINISTERIO", "MARINA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["ESTA LEY NO HA SIDO PUBLICADA EN EL DIARIO OFICIAL"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-06-08", "doble_articulado": false, "id_norma": "22366", "numero_fuente": "SUPLEMENTO A O 1898, PAGINA N 466", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1898-06-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-06-08", "fin_vigencia": ""}, "vigenc