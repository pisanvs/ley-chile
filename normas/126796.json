{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 996 EXENTO, DE 1998</div><br><br><br><br></div>", "i": 7241666}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 996 de 20 de octubre de 1998, se ha modificado, a contar de su total tramitaci&#xF3;n, el decreto supremo exento de Educaci&#xF3;n N&#xBA; 320 de 1993, que aprob&#xF3; un plan de estudio especial de educaci&#xF3;n comercial de adultos, en la forma que indica el presente decreto.</div><br></div>", "i": 7241667}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 2 de noviembre de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7241668}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "996 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-996 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 996 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EDUCACION DE ADULTOS", "PLANES DE ESTUDIO", "ESTABLECIMIENTOS EDUCACIONALES", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-10-20", "doble_articulado": false, "id_norma": "126796", "numero_fuente": "36206", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-11-05", "vigencias": [{"desde": "1998-11-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-11-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-11-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "M