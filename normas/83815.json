{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7430081}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 69, de 26 de enero de 1990, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriz&#xF3; complementariamente a la empresa peruana Expreso Internacional Orme&#xF1;o S.A. para efectuar servicio internacional de transporte terrestre de pasajeros entre Lima (Per&#xFA;) y Buenos Aires (Argentina), en tr&#xE1;nsito por territorio chileno, utilizando los pasos fronterizos de Concordia y Cristo Redentor, con cuatro (4) frecuencias mensuales.-</div><br></div>", "i": 7430082}, {"t": "<div><div class=\"p\">Patricio Figueroa Cruz, Subsecretario de Transportes Subrogante.</div><br></div>", "i": 7430083}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "69", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-69"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-26", "doble_articulado": false, "id_norma": "83815", "numero_fuente": "33592", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-09", "vigencias": [{"desde": "1990-02-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "MEM", "fecha_ingreso": "1998-01-09