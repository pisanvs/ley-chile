{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 8.189 EXENTA, DE 2011</div></div>", "i": 9188014}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En cumplimiento de lo se&#xF1;alado en el art&#xED;culo 48 de la Ley N&#xBA; 19.880, el Servicio Nacional de Capacitaci&#xF3;n y Empleo cumple con informar que mediante resoluci&#xF3;n exenta N&#xBA; 8.189 de 8 de septiembre de 2011, se modific&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1027423&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 5.239 de 16 de junio de 2011</a>, modificada por resoluci&#xF3;n exenta N&#xBA; 7.907 de septiembre de 2011, que aprob&#xF3; Instrucciones para la Ejecuci&#xF3;n del &quot;Programa Formaci&#xF3;n en el Puesto de Trabajo 2011&quot;. El texto completo de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio, www.sence.cl.-</div></div>", "i": 9188015}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Francisco Ag&#xFC;ero Larrondo, Director Nacional Subrogante.</div></div>", "i": 9188016}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8189 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-8189 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 8.189 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-09-08", "doble_articulado": false, "id_norma": "1030234", "numero_fuente": "40071", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-09-27", "vigencias": [{"desde": "2011-09-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"