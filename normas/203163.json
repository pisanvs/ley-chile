{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6398300}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;1.994 de 13 de septiembre de 2002, modif&#xED;case el numeral 6&#xBA; de la resoluci&#xF3;n N&#xBA;712 de 2002, de esta Subsecretar&#xED;a que autoriz&#xF3; al&nbsp; INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Monitoreo y evaluaci&#xF3;n hidroac&#xFA;stica del Jurel, I y II Regi&#xF3;n&quot;, en el sentido de reemplazar la nave &quot;Ralun&quot; por la nave &quot;Costa Grande 1&quot;, ambas de propiedad de Compa&#xF1;&#xED;a Pesquera Camanchaca S.A., de la n&#xF3;mina de naves participantes en la se&#xF1;alada pesca de investigaci&#xF3;n. </div></div>", "i": 6398301}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de septiembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6398302}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1994", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1994"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-09-13", "doble_articulado": false, "id_norma": "203163", "numero_fuente": "37375", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-10-04", "vigencias": [{"desde": "2002-10-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-10-04", "fin_vigencia": ""}, "vigen