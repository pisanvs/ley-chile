{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6074802}, {"t": "<div><div class=\"p\">El Banco Central de Chile, en conformidad con lo dispuesto en el N&#xBA;5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de octubre de 1991, fue de 5,28%anual.</div><br></div>", "i": 6074803}, {"t": "<div><div class=\"p\">Santiago, 18 de octubre de 1991.- Isaac Telias Ergas. Ministro de Fe Subrogante.</div><br></div>", "i": 6074804}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-10-18", "doble_articulado": false, "id_norma": "86975", "numero_fuente": "34095", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-10-19", "vigencias": [{"desde": "1991-10-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-10-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-10-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CQA", "fecha_ingreso": "1998-01-29", "fecha_version": "1991-10-19", "fecha_actualizacion_texto": "1991-10-19", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6074802}, {"n": "Artículo", "i": 6074803, "t": 6}, {"n": "Pro