{"html": [{"t": "<div><div class=\"p\">EXCEPCIONA A MOISES VELASCO CASTELLON DEL REGIMEN DE CAMBIO DE SUJETO DEL IVA</div><br><br></div>", "i": 6500415}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional del SII, por resoluci&#xF3;n DRE 09.00 N&#xBA; Ex. 359, de fecha 5 de octubre de 2004, excepciona, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n a Mois&#xE9;s Velasco Castell&#xF3;n, Rut. N&#xBA; 5.557.077-9, del r&#xE9;gimen de cambio de sujeto del Impuesto al Valor Agregado, en las ventas de trigo, establecido en la resoluci&#xF3;n N&#xBA; Ex. 5.281, de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del 04/12/2000. El peticionario exepcionado pasa a tener la calidad de retenedor del Impuesto al Valor Agregado en sus operaciones de compra de trigo.-</div><br></div>", "i": 6500416}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Cornejo C&#xE1;ceres, Director Regional. </div></div>", "i": 6500417}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "359 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-359 EXENTA"}, {"tipo": "3", "numero": "DRE-09-00-359 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-09-00-359 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "EXCEPCIONA A MOISES VELASCO CASTELLON DEL REGIMEN DE CAMBIO DE SUJETO DEL IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-05", "doble_articulado": false, "id_norma": "231202", "numero_fuente": "37983", "tipo_version": "3", "tipo_version_s": "Única", "fecha_p