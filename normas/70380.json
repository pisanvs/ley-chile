{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8302193}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 445, de 27 de marzo de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rese la caducidad parcial de la Resoluci&#xF3;n N&#xBA; 172 de 1992, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA MARBELLA S.A., para realizar actividades pesqueras extractivas con la nave &quot;Costa Grande 2&quot;, en el litoral de la V y IX Regiones, en virtud del art&#xED;culo 143 letra b) de la Ley N&#xBA; 18.892 y sus modificaciones.</div><br></div>", "i": 8302194}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de marzo de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8302195}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "445", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-445"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA MARBELLA S.A.", "AUTORIZACION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-27", "doble_articulado": false, "id_norma": "70380", "numero_fuente": "35734", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-07", "vigencias": [{"desde": "1997-04-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-04-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-04-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi