{"html": [{"t": "<div><br><div class=\"p\">REEMPLAZA NORMAS PARA LA DEVOLUCI&#xD3;N DEL IMPUESTO A TURISTAS</div></div>", "i": 9353021}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 46, de 10 de mayo de 2013, que establece:</div><div class=\"p\">&nbsp; &nbsp;  Reemplaza normas para la devoluci&#xF3;n del impuesto del T&#xED;tulo II y del art&#xED;culo 42 de la Ley sobre Impuesto a las Ventas y Servicios, contenida en el <a href=\"https://www.leychile.cl/Navegar?idNorma=6369&amp;idParte=0&amp;idVersion=\">DL N&#xB0; 825, de 1974</a>, a las personas naturales sin domicilio ni residencia en el pa&#xED;s, que compren mercanc&#xED;as en la Zona Franca de Extensi&#xF3;n de la Regi&#xF3;n de Arica y Parinacota.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de mayo de 2013.</div></div>", "i": 9353022}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "46 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-46 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "REEMPLAZA NORMAS PARA LA DEVOLUCIÓN DEL IMPUESTO A TURISTAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN PROMULGACIÓN", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-05-10", "doble_articulado": false, "id_norma": "1051138", "numero_fuente": "40560", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "201