{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10033538}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xBA; 1.513, de 11 de junio de 2019, deja sin efecto resoluci&#xF3;n exenta N&#xBA; 857 de 2015, de este Instituto, y aprueba protocolo con exposici&#xF3;n a radiaciones ionizantes asociadas al uso de equipos de tomograf&#xED;a computada, elaborada por el Departamento Salud Ocupacional del Instituto de Salud P&#xFA;blica de Chile.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.- </div></div>", "i": 10033539}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mar&#xED;a Judith Mora Riquelme, Directora (S), Instituto de Salud P&#xFA;blica de Chile. </div></div>", "i": 10033540}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1513 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1513 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1611181", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-06-11", "doble_articulado": false, "id_norma": "1133110", "numero_fuente": "42389", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-06-26", "vigencias": [{"desde": "2019-06-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-06-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2019-06-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes