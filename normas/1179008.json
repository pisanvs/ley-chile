{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO RESOLUCIONES EXENTAS QUE INDICA</div></div>", "i": 10350669}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.435, de 15 de julio de 2022, de esta Subsecretar&#xED;a, d&#xE9;jense sin efecto las resoluciones exentas <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=263356&amp;idVersion=2022-07-22\">N&#xB0; 2.279</a>, <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=263359&amp;idVersion=2022-07-22\">N&#xB0; 2.282</a>, <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=263364&amp;idVersion=2022-07-22\">N&#xB0; 2.287</a>, <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=263730&amp;idVersion=2022-07-22\">N&#xB0; 2.344</a>, <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=263731&amp;idVersion=2022-07-22\">N&#xB0; 2.345</a>, <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=263733&amp;idVersion=2022-07-22\">N&#xB0; 2.347</a>, <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=263734&amp;idVersion=2022-07-22\">N&#xB0; 2.348</a>, <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=263736&amp;idVersion=2022-07-22\">N&#xB0; 2.349</a>, <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=263740&amp;idVersion=2022-07-22\">N&#xB0; 2.353</a>, <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=263742&amp;idVersion=2022-07-22\">N&#xB0; 2.355</a>, <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=263743&amp;idVersion=2022-07-22\">N&#xB0; 2.356</a>, <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=264113&amp;idVersion=2022-07-22\">N&#xB0; 2.452</a>, <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=264117&amp;idVersion=2022-07-22\">N&#xB0; 2.455</a>, <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=264123&amp;idVersion=2022-07-22\">N&#xB0;.2.466</a>, todas de 2007, que autorizaron a Corpesca S.A. para realizar actividades extractivas en alta mar, con las naves industriales &quot;Don Antonio&quot;, &quot;Isluga&quot;, &quot;J.M. Hamwee&quot;, &quot;Guanaye&quot;, &quot;Eperva 48&quot;, &quot;Huayquique&quot;, &quot;Eperva 52&quot;, &quot;Don Edmundo&quot;, &quot;&#xC1;guila Real&quot;, &quot;Gavil&#xE1;n&quot;, &quot;Puchuldiza&quot;, &quot;Til Til&quot;, &quot;Raul&#xED;&quot; y &quot;Tambo&quot;, por configurarse la causal establecida en el art&#xED;culo 11.- letra a) del decreto supremo N&#xB0; 360 de 2005, del actual Ministerio de Econom&#xED;a, Fomento y Turismo.</div><br></div>", "i": 10350670, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de julio de 2022.- Paulo Sep&#xFA;lveda Sep&#xFA;lveda, Subsecretario de Pesca y Acuicultura (S).</div><br></div>", "i": 10350671}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1435 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1435 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DEJA SIN EFECTO RESOLUCIONES EXENTAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2159733", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-07-15", "doble_articulado": false, "id_norma": "1179008", "numero_fuente": "43308", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-07-22", "vigencias": [{"desde": "2022-07-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2022-07-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2022-07-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "10418", "fecha_ingre