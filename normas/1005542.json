{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA RECEPTORES ELECTR&#xD3;NICOS</div></div>", "i": 8774473}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA;122, de 26 de agosto de 2009, que autoriza a contribuyentes como receptores electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como receptor de documentos tributarios electr&#xF3;nicos a contribuyentes RUT N&#xBA;61.979.160-6 y RUT N&#xBA;61.979.110-K, a contar del mes de agosto 2009. En la oficina virtual del SII en Internet se podr&#xE1;n consultar los documentos que los contribuyentes est&#xE1;n autorizados a emitir en forma electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de agosto de 2009.</div></div>", "i": 8774474}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "122 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-122 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA RECEPTORES ELECTRÓNICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-08-26", "doble_articulado": false, "id_norma": "1005542", "numero_fuente": "39449", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-08-29", "vigencias": [{"desde": "2009-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "20