{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6571017}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.291, de 10 de mayo de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a FIORDO AUSTRAL S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Ruta 5 Sur, camino a Pargua, kil&#xF3;metro 1030, sector Alto Bonito, Puerto Montt, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso Fresco enfriado, Fresco refrigerado, Congelado y Conserva, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6571018}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de mayo de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6571019}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1291 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1291 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-05-10", "doble_articulado": false, "id_norma": "249952", "numero_fuente": "38474", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-05-27", "vigencias": [{"desde": "2006-05-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-05-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-05-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_p