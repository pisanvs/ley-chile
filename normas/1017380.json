{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 2.305 EXENTA, DE 2010</div><br></div>", "i": 9011363}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.305, de fecha 10 de septiembre de 2010, de Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se aprueban los Planes y Programas de la Escuela de Conductores Profesionales &quot;Silva, Contreras y Compa&#xF1;&#xED;a Limitada&quot; o &quot;Conductores Chile Ltda.&quot;, RUT N&#xBA; 76.094.867-5, cuyo representante legal es el se&#xF1;or Rodrigo Florencio Silva Sanhueza, para impartir los cursos conducentes a la obtenci&#xF3;n de licencia de conductor profesional Clase A2 y A4.- </div></div>", "i": 9011364}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Stephan Orellana, Secretario Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana (S).</div></div>", "i": 9011365}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2305 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2305 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL REGIÓN METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 2.305 EXENTA, DE 2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-09-10", "doble_articulado": false, "id_norma": "1017380", "numero_fuente": "39770", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-09-27", "vigencias": [{"desde": "2010-09-27", "hasta": "", "tipo_version": "3", "tipo_v