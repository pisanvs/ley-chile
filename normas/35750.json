{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294619}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 864 de 14 de Septiembre de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el extracto de la Resoluci&#xF3;n N&#xB0; 788, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la Empresa Pesquera Pacto S.A., R.U.T. N&#xB0; 95.648.000-0, en el sentido de reemplazar la longitud del v&#xE9;rtice D, donde dice 73&#xB0;39&apos;46,10&quot; W debe decir 73&#xB0;39&apos;53,10&quot; W. D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 321, de 1994, de esta Subsecretar&#xED;a, en virtud de lo dispuesto en la presente. </div></div>", "i": 8294620}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 14 de Septiembre de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294621}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "864", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-864"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EMPRESA PESQUERA PACTO S.A.", "MODIFICACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-09-14", "fecha_derogacion": "1998-12-07", "doble_articulado": false, "id_norma": "35750", "numero_fuente": "34975", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-09-26", "vigencias": [{"desde": "1998-12-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1994-09-26", "hasta": "1998-12-06", "tipo_version": "0", "tipo_version_s