{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7365529}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 593, de 3 de marzo de 2008, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA PAC&#xCD;FICO SUR S.A. para continuar desarrollando las actividades pesqueras autorizadas a Pesquera Costa Afuera S.A. con las naves en construcci&#xF3;n autorizadas mediante resoluciones exentas N&#xBA; 2.568, de 2001, y N&#xBA; 3.015, de 2003, ambas de esta Subsecretar&#xED;a, en virtud de escritura p&#xFA;blica y dem&#xE1;s disposiciones legales citadas en la resoluci&#xF3;n extractada.</div><br></div>", "i": 7365530}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de marzo de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7365531}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "593 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-593 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-03-03", "doble_articulado": false, "id_norma": "269738", "numero_fuente": "39007", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-03-08", "vigencias": [{"desde": "2008-03-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-03-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-03-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC