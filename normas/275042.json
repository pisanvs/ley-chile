{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6655804}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.869, de 21 de julio de 2008, de esta Subsecretar&#xED;a, autor&#xED;zase a SINDICATO DE TRABAJADORES INDEPENDIENTES DE BUZOS Y RAMOS AFINES para iniciar actividades pesqueras de transformaci&#xF3;n, para iniciar y operar planta ubicada en sector Pelao S&#xE1;ez, Tal Tal, II Regi&#xF3;n, para elaborar en las l&#xED;neas de proceso de Alga Seca, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1.536 de 2008, de esta Subsecretar&#xED;a.</div><br></div>", "i": 6655805}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de julio de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 6655806}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1869 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1869 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-07-21", "doble_articulado": false, "id_norma": "275042", "numero_fuente": "39127", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-08-01", "vigencias": [{"desde": "2008-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-08-01", "fin_vigencia": "", "tipo_versi