{"html": [{"t": "<div><br><div class=\"p\">AMPL&#xCD;A PLAZO PARA INICIAR ACTIVIDADES DE ACUICULTURA</div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n 2.263, de fecha 19 de noviembre de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div></div>", "i": 8860075}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Ampl&#xED;ase por cuatro a&#xF1;os, a contar del 26 de julio de 2009, d&#xED;a siguiente de cumplido el primer a&#xF1;o desde la fecha de entrega material de la concesi&#xF3;n de acuicultura, el plazo para iniciar actividades de acuicultura autorizadas mediante <a href=\"https://www.leychile.cl/Navegar?idNorma=270774&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 168, de fecha 11 de febrero de 2008, del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina</a>.</div></div>", "i": 8860076}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de enero de 2010.- Por la Sra. Subsecretaria, Gonzalo Campos Narducci, Subjefe Subsecretar&#xED;a de Marina Subrogante.</div></div>", "i": 8860077}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2263", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2263"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "AMPLÍA PLAZO PARA INICIAR ACTIVIDADES DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-11-19", "doble_articulado": false, "id_norma": "1010580", "numero_fuente": "39575", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-02-01", "vigencias": [{"desde": "2010-02-01", "hasta": "", "tipo_version": "3", "tip