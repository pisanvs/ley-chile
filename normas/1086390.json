{"html": [{"t": "<div><div class=\"p\">&nbsp;  </div><div class=\"p\">PARTIDO FRENTE POPULAR</div></div>", "i": 9665173}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Marco Riquelme Garc&#xED;a, Presidente de la Directiva Central Provisional del Partido Frente Popular, en formaci&#xF3;n, con fecha 30 de diciembre de 2015, ha solicitado la constituci&#xF3;n legal del partido en la Regi&#xF3;n IV de Coquimbo. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de 756 afiliaciones.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el <a href=\"https://www.leychile.cl/Navegar?idNorma=29994&amp;idParte=8285857&amp;idVersion=\">art&#xED;culo 17&#xBA;</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=29994&amp;idParte=0&amp;idVersion=\">ley N&#xBA; 18.603</a>, por resoluci&#xF3;n O-N&#xBA; 1, fecha 5 de enero de 2016.-</div></div>", "i": 9665174}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Elizabeth Cabrera Burgos, Directora (S).</div></div>", "i": 9665175}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1"}, {"tipo": "3", "numero": "O-1", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-1"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO FRENTE POPULAR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 985824; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-01-05", "doble_articulado": false, "id_norma": "1086390", "numero_fuente": "41355", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacio