{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA N&#xB0; 890, DE 1986 </div></div>", "i": 6225794}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta N&#xB0; 890 de fecha 14 de Abril de 1986, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se aprobaron las modificaciones introducidas al plan y programas de estudio al Centro de Formaci&#xF3;n T&#xE9;cnica Escuela Superior de Comercio Exterior de Santiago ESCES - de la carrera y t&#xED;tulo t&#xE9;cnico que se indica, para impartirse a contar del a&#xF1;o 1986: Carrera: Contabilidad T&#xED;tulo: Contador General.-</div><br></div>", "i": 6225795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Mart&#xED;n, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6225796}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "890 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-890 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N° 890, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-04-14", "doble_articulado": false, "id_norma": "153383", "numero_fuente": "32486", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-06-03", "vigencias": [{"desde": "1986-06-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-06-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-06-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ing