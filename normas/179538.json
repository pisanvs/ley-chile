{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6314152}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.624, de 18 de diciembre de 2000, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA; de la resoluci&#xF3;n N&#xBA; 2.455 de 2000, modificada mediante resoluci&#xF3;n N&#xBA; 2.539 de 2000, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO, para efectuar una pesca de investigaci&#xF3;n de conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del proyecto denominado &apos;&apos;Pesca de Investigaci&#xF3;n de Merluza de cola entre la V y la X Regiones&apos;&apos;, en el sentido de se&#xF1;alar que el l&#xED;mite m&#xE1;ximo de captura autorizado para el mes de diciembre se incrementar&#xE1; en 2.651 toneladas. </div></div>", "i": 6314153}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de diciembre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca. </div></div>", "i": 6314154}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2624", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2624"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-12-18", "doble_articulado": false, "id_norma": "179538", "numero_fuente": "36849", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-12-29", "vigencias": [{"desde": "2000-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-12-29", "fin_vigencia": ""},