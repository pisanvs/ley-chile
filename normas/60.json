{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xB0; 143</div><div class=\"p\">&nbsp; &nbsp; Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xB0; 143, celebrada el 5 de julio de 1991, adopt&#xF3; el siguiente acuerdo:</div><br></div>", "i": 5843288}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Se acord&#xF3; designar en la funci&#xF3;n de Ministro de Fe Subrogante en las actuaciones del Consejo del Banco Central de Chile, al Abogado don Isaac Telias Ergas.</div><div class=\"p\">&nbsp; &nbsp; El desempe&#xF1;o de la funci&#xF3;n de Ministro de Fe en las actuaciones del Consejo y del Banco, ser&#xE1; sin perjuicio de las funciones que competen al se&#xF1;or Isaac Telias Ergas como Abogado del Banco Central de Chile. </div></div>", "i": 5843289}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 9 de julio de 1991.- V&#xED;ctor Vial del R&#xED;o, Secretario General.</div><br></div>", "i": 5843290}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "143", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-143"}, {"tipo": "5", "numero": "143-02", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-143-02"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE\nCHILE EN SU SESION N° 143", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BANCO CENTRAL CHILE", "CONSEJO", "ISAAC TELIAS ERGAS", "MINISTRO FE SUBROGANTE", "NOMBRAMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-07-09", "doble_articulado": false, "id_norma": "60", "numero_fuente": "34013", "tipo_version": "3", "tipo_version_s": "Única"