{"html": [{"t": "<div><div class=\"p\">AUTORIZA A SOCIEDAD SALMOSUR S.A. PARA AMPLIAR ACTIVIDADES PESQUERAS </div></div>", "i": 6241815}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 389, de 8 de Julio de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a la Sociedad Salmosur S.A., domiciliada en la comuna de Santiago, para instalar en un sector de Puerto Rosales, en el Lago Llanquihue, 30 balsas jaulas para engorda de trucha arco iris que tiene en crianza en las instalaciones de la Sociedad de Pesquer&#xED;a y Piscicultura Lago Llanquihue Ltda.</div><br></div>", "i": 6241816}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de Julio de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6241817}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "389", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-389"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A SOCIEDAD SALMOSUR S.A. PARA AMPLIAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-07-08", "doble_articulado": false, "id_norma": "158421", "numero_fuente": "32224", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-07-17", "vigencias": [{"desde": "1985-07-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-07-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-07-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi