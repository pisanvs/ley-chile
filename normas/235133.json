{"html": [{"t": "<div><div class=\"p\">LEY NUM. 15.982</div><br><div class=\"p\">ACLARA LEY N.o 15.412, DE 1964</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6514697}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Decl&#xE1;rase que la beneficiaria de la ley N.o 15.412, de fecha 8 de Enero de 1964, es do&#xF1;a Sara Beatriz Sol&#xED;s Vargas.</div><br></div>", "i": 6514698}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a nueve de Diciembre de mil novecientos sesenta y cuatro.- EDUARDO FREI MONTALVA.- Sergio Molina S.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a U. para su conocimiento.- Dios guarde a U.- Andr&#xE9;s Zald&#xED;var Larra&#xED;n, Subsecretario de Hacienda.</div><br></div>", "i": 6514699}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "15982", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-15982"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ACLARA LEY N.o 15.412, DE 1964", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1964-12-09", "doble_articulado": false, "id_norma": "235133", "numero_fuente": "26028", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1964-12-31", "vigencias": [{"desde": "1964-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1964-12-31", "fi