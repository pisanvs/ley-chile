{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 3.665 EXENTO, DE 30 DE DICIEMBRE DE 2009</div></div>", "i": 8902121}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por el presente decreto se ha modificado el <a href=\"https://www.leychile.cl/Navegar?idNorma=226420&amp;idParte=0&amp;idVersion=\">decreto exento de Educaci&#xF3;n N&#xBA; 235, de 2004</a>, que aprob&#xF3; planes y programas de estudio biling&#xFC;es para los cursos de 1&#xBA; a 8&#xBA; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica, al Liceo Lorenzo Baeza Vega de Isla de Pascua, Regi&#xF3;n de Valpara&#xED;so.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio especiales biling&#xFC;es de 1&#xBA; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica para los sectores que se indican en el presente decreto.</div></div>", "i": 8902122}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de marzo de 2010.- Cristi&#xE1;n Mart&#xED;nez Ahumada, Subsecretario de Educaci&#xF3;n.</div></div>", "i": 8902123}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3665 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-3665 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 3.665 EXENTO, DE 30 DE DICIEMBRE DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-12-30", "doble_articulado": false, "id_norma": "1011979", "numero_fuente": "39619", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-03-24", "vigencias": [{"desde": "2010-03-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-0