{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6337327}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 992, de 28 de mayo de 2001, de esta Subsecretar&#xED;a, modif&#xED;case la resoluci&#xF3;n N&#xBA; 145 de 2001, de esta Subsecretar&#xED;a, que fij&#xF3; la n&#xF3;mina de armadores y embarcaciones que cumplen con los requisitos legales para operar en las unidades de pesquer&#xED;a de Sardina espa&#xF1;ola Sardinops sagax y Anchoveta Engraulis ringens, declaradas en estado de plena explotaci&#xF3;n y sometidas a dicho r&#xE9;gimen de administraci&#xF3;n, en el litoral de la I y II Regiones, en el &#xE1;rea se&#xF1;alada en sus respectivas autorizaciones, al 30 de junio de 2000, en el sentido de incluir en el numeral 1&#xBA; lo siguiente:</div><br><div class=\"p\">Armador&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Nave</div><br><div class=\"p\">MOYA GARCIA, GERMAN&nbsp; &nbsp; &nbsp; &nbsp;  Lobera 84</div><br></div>", "i": 6337328}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de mayo de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6337329}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "992", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-992"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-05-28", "fecha_derogacion": "2001-08-11", "doble_articulado": false, "id_norma": "186070", "numero_fuente": "36977", "tipo_version": "2", "tipo_version_s": "Última Ver