{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA EXCEPCI&#xD3;N R&#xC9;GIMEN CAMBIO SUJETO IVA BERRIES</div><br></div>", "i": 8515215}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional Concepci&#xF3;n del SII, por resoluci&#xF3;n DRE08/N&#xBA; Ex- 2927, de fecha 23-03-09, excepciona, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, a Soc. Agr&#xED;cola Cato Ltda., RUT N&#xBA; 77.406.340-4, del r&#xE9;gimen de Cambio de Sujeto de IVA, en las ventas de Berries, establecido en la resoluci&#xF3;n Ex N&#xBA; 55, de 02-06-2005 de la Direcci&#xF3;n Nacional. Consecuencialmente, el (la) peticionario(a) excepcionado(a) pasa a tener la calidad de Agente Retenedor del Impuesto al Valor Agregado en sus operaciones de compras de Berries.</div></div>", "i": 8515216}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 23 de marzo de 2009.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div></div>", "i": 8515217}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2927 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolucion-2927 EXENTA"}, {"tipo": "3", "numero": "DRE08/Nº 2927 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolucion-DRE08/Nº 2927 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "AUTORIZA EXCEPCIÓN RÉGIMEN CAMBIO SUJETO IVA BERRIES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-03-23", "doble_articulado": false, "id_norma": "1001032", "numero_fuente": "39331", "tipo_version": "3", "tipo_version_s": "Única", "fecha