{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,284.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br><br></div>", "i": 8367076}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- El&#xE9;vase, por gracia, a dos mil cuatrocientos pesos ($ 2,400) la pension anual concedida por lei n&#xFA;mero 1,131, de 16 de Diciembre de 1898, a las nietas solteras de don Antonio Garc&#xED;a Reyes, se&#xF1;oritas Mar&#xED;a Amelia, Ines, Carolina i Filomena Garc&#xED;a Cordovez. </div></div>", "i": 8367077, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como le&#xED; de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintiuno de Setiembre de mil novecientos diecisiete.- Juan Luis Sanfuentes.- Ismael Tocornal.</div><br></div>", "i": 8367078}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3284", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3284"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1917-09-21", "doble_articulado": false, "id_norma": "193094", "numero_fuente": "11884", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1917-10-01", "vigencias": [{"desde": "1917-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1917-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1917