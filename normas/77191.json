{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8307701}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 540 de 05 de Junio de 1992 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modificase la Resoluci&#xF3;n No. 123, de 1986, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA PUNTA ANGAMOS S.A., domiciliada en Santiago, para ampliar actividades pesqueras, en su numeral primero letra a), en el sentido de indicar que el actual nombre del PAM &quot;LIBRA&quot; es &quot;ANGAMOS 3&quot;. </div></div>", "i": 8307702}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 05 de Junio de 1992.- Jorge Marshall Rivera, Subsecretario de Pesca Subrogante.</div><br></div>", "i": 8307703}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "540", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-540"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-06-05", "doble_articulado": false, "id_norma": "77191", "numero_fuente": "34376", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-09-28", "vigencias": [{"desde": "1992-09-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-09-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-09-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JRC", "fecha_ingreso": "1997-11-07", "fecha_ve