{"html": [{"t": "<div><br><div class=\"p\">DEJA SIN EFECTO RESOLUCI&#xD3;N N&#xB0; 19 EXENTA, DE 2004</div></div>", "i": 9354701}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 49, del 22 de mayo de 2013.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto, a contar del a&#xF1;o tributario 2013, la obligaci&#xF3;n de presentar n&#xF3;mina establecida en el dispositivo primero de la resoluci&#xF3;n exenta N&#xBA; 19, del 29 de enero de 2004, ya que similar obligaci&#xF3;n dispone la resoluci&#xF3;n exenta SII N&#xBA; 9, del 19 de enero de 2012.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de mayo de 2013.</div></div>", "i": 9354702}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "49 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-49 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEJA SIN EFECTO RESOLUCIÓN N° 19 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-05-22", "doble_articulado": false, "id_norma": "1051340", "numero_fuente": "40569", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-05-28", "vigencias": [{"desde": "2013-05-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-05-28", "fin_vigencia": "