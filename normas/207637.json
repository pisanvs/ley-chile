{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA; 366, DE 1990</div><br><br><br></div>", "i": 6414390}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 366 de 27 de diciembre de 1990 se ha aprobado, por un periodo de 4 a&#xF1;os, a contar de marzo de 1991, a la Escuela Especial F N&#xBA; 103 de Cha&#xF1;aral, III Regi&#xF3;n de Atacama, un programa de estudio para el nivel laboral destinado a escolares discapacitados, de acuerdo a los objetivos que se indican para cada uno de los curso talleres en las especialidades de Tejidos y Muebler&#xED;a.</div><br></div>", "i": 6414391}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 04 de Marzo de 1991.- Ra&#xFA;l Allar Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6414392}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "366 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-366 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº 366, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-27", "doble_articulado": false, "id_norma": "207637", "numero_fuente": "33919", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-03-15", "vigencias": [{"desde": "1991-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2003-02