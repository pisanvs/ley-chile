{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10192478}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.368 de 24 de diciembre 2020 de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n parcial, conforme art&#xED;culo 51 ley 16.391, de inmueble ubicado en Pdte Ib&#xE1;&#xF1;ez 1154, Rol Aval&#xFA;o N&#xBA; 311-10, Comuna Linares, superficie terreno 42,78 m2, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Arturo Eugenio Guti&#xE9;rrez Andrade. Comisi&#xF3;n integrada por peritos Patricio Ulises Dur&#xE1;n Marcos, Arquitecto; Rodrigo Antonio Silva Lazo, Constructor Civil y Pedro Pablo Cruz Weston, Arquitecto, seg&#xFA;n informe de 3 octubre 2017, fij&#xF3; monto provisional indemnizaci&#xF3;n en $8.108.777.-, con reajustes legales, pagados al contado.- </div></div>", "i": 10192479}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Claudio Daneck Mu&#xF1;oz, Director (S) Serviu Regi&#xF3;n del Maule.</div><br></div>", "i": 10192480}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2368 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2368 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "VII REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1876089", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-12-24", "doble_articulado": false, "id_norma": "1154678", "numero_fuente": "42855", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-01-15", "vigencias": [{"d