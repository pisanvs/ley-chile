{"html": [{"t": "<div><br><div class=\"p\">CERTIFICADO</div><br></div>", "i": 9072894}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables de entre 90 y 365 d&#xED;as fue de 3,14% anual durante el mes de noviembre de 2010.</div><br><div class=\"p\">&nbsp; &nbsp;  Asimismo, de conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables de entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de noviembre de 2010, fue de 3,38% anual.</div><br></div>", "i": 9072895}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 6 de diciembre de 2010.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div></div>", "i": 9072896}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "Certificado-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-06", "doble_articulado": false, "id_norma": "1020611", "numero_fuente": "39830", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-12-09", "vigencias": [{"desde": "2010-12-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-12-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-12-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion