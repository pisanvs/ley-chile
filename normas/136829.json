{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 216.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170001}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese al &#xED;tem 13 de la partida 8.&#xAA; del presupuesto del Culto un suplemento de tres mil quinientos pesos ($ 3,500) para gastos imprevistos. </div></div>", "i": 6170002}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de diciembre de 1894.- JORJE MONTT.- Luis Barros Borgo&#xF1;o.</div><br></div>", "i": 6170003}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "216", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-216"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-12-17", "doble_articulado": false, "id_norma": "136829", "numero_fuente": "4995", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-12-21", "vigencias": [{"desde": "1894-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-12-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-12-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-05-20", "fec