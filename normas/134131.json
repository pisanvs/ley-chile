{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 974.- Santiago, 27 de diciembre de 1897.- Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6161422}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Decl&#xE1;rase de abono al guardian de la c&#xE1;rcel p&#xFA;blica de la capital, don Jos&#xE9; Ugarte, para los efectos de la jubilacion, el tiempo que sirvi&#xF3; dicho empleo, comprendido entre el 1.&#xBA; de noviembre de 1863 hasta el 18 de marzo de 1892.</div><br></div>", "i": 6161423}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- J. D. Amunategui Rivera.</div><br></div>", "i": 6161424}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "974", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-974"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-12-27", "doble_articulado": false, "id_norma": "134131", "numero_fuente": "5890", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1897-12-29", "vigencias": [{"desde": "1897-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1897-12-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1897-12-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac