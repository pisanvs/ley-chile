{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.076 EXENTA, DE 2000 </div></div>", "i": 6296503}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.076 de fecha 5 de julio de 2000, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se renov&#xF3; la autorizaci&#xF3;n otorgada a la empresa chilena Olga Isabel Flores Andrade, para efectuar servicio internacional terrestre de pasajeros entre Iquique (Chile) y Arequipa (Per&#xFA;), utilizando el paso fronterizo de Concordia, con una (1) frecuencia semanal de ida y vuelta.-</div><br></div>", "i": 6296504}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Patricio Tombolini V&#xE9;liz, Subsecretario de Transportes.</div><br></div>", "i": 6296505}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1076 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1076 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.076 EXENTA, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-07-05", "doble_articulado": false, "id_norma": "174217", "numero_fuente": "36738", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-12", "vigencias": [{"desde": "2000-08-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-08-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM