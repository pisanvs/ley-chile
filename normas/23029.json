{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,950 que concede jubilacion a don Jos&#xE9; Ramon Ballesteros, taqu&#xED;grafo del Senado</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,950.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274859}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. En atencion a los servicios prestados por el taqu&#xED;grafo primero del Senado don Jos&#xE9; Ramon Ballesteros, acu&#xE9;rdasele por gracia, el derecho de jubilar con el sueldo de su empleo.</div><br></div>", "i": 8274860}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 1.&#xB0; de Julio de 1907.- PEDRO MONTT.- Luis A. Vergara.</div><br></div>", "i": 8274861}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1950", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1950"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Lei núm. 1,950 que concede jubilacion a don José;Ramon Ballesteros, taquígrafo del Senado", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JOSE RAMON BALLESTEROS", "JUBILACION POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-07-01", "doble_articulado": false, "id_norma": "23029", "numero_fuente": "8839", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-07-03", "vigencias": [{"desde": "1907-07-03", "hasta": "", "tipo_version": "3", "t