{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 245 EXENTO, DE 2000 </div></div>", "i": 7276077}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 245 de fecha 4 de julio de 2000 del Ministerio de Educaci&#xF3;n, se aprueban las adecuaciones al plan y programas de estudios de la carrera de Turismo del Centro de Formaci&#xF3;n T&#xE9;cnica de ENAC, que se encuentran anexas y forman parte del presente decreto. Modif&#xED;case, en consecuencia, el decreto exento de Educaci&#xF3;n N&#xBA; 120 del 8 de mayo de 1992, en el sentido de incorporar dichas adecuaciones. Las adecuaciones que se aprueban, podr&#xE1;n aplicarse a contar del a&#xF1;o 2000.</div><br></div>", "i": 7276078}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de julio de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7276079}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "245 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-245 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 245 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-07-04", "doble_articulado": false, "id_norma": "174218", "numero_fuente": "36739", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-14", "vigencias": [{"desde": "2000-08-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-08-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [],