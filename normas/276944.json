{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 1.128 EXENTA, DE 2008 </div></div>", "i": 6658104}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.128, de 6 de agosto de 2008, se autoriz&#xF3;, de conformidad a lo dispuesto en el N&#xBA; 5 de la resoluci&#xF3;n N&#xBA; 65, de 2000, del Ministerio de Transportes y Telecomunicaciones, al taller que a continuaci&#xF3;n se individualiza para adecuar veh&#xED;culos al uso de gas licuado de petr&#xF3;leo como combustible:</div><br><div class=\"p\"> Empresa&nbsp; &nbsp; &nbsp;  Nombre del&nbsp;  Direcci&#xF3;n</div><div class=\"p\">Habilitada&nbsp; &nbsp; &nbsp;  Taller&nbsp; &nbsp;  del taller&nbsp; &nbsp;  Ciudad</div><br><div class=\"p\">Italgas S.A.&nbsp;  Vaccaro y&nbsp; &nbsp;  Porvenir</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  C&#xED;a. Ltda.&nbsp; &nbsp;  N&#xBA; 427&nbsp; &nbsp; &nbsp; Santiago</div><br><div class=\"p\">&nbsp; &nbsp;  La autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.</div><br><br></div>", "i": 6658105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Erazo Torricelli, Subsecretario de Transportes.</div><br></div>", "i": 6658106}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1128 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1128 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 1.128 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-08-06", "doble_ar