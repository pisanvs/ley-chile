{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6220095}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 1.300 de 29 de Julio 1986, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas determin&#xF3; derechos de Aprovechamiento de Aguas proporcionales que corresponden a sectores excluido y expropiado del predio &quot;El Crucero de Palmilla&quot;, de la Comuna de Palmilla, Sexta Regi&#xF3;n; y derechos de aprovechamiento de aguas que corresponden a las parcelas N&#xB0;s. 1 a la 5 y sitios N&#xB0;s. 1 al 3 del Proyecto de Parcelaci&#xF3;n &quot;La Turbina&quot;, formado por predio se&#xF1;alado.</div><div class=\"p\">Los derechos de agua se extraen del Canal Day derivado del r&#xED;o Tinguiririca y derrames de la zona de Paniahue. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.-</div><br></div>", "i": 6220096}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6220097}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1300 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1300 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-07-29", "doble_articulado": false, "id_norma": "151559", "numero_fuente": "32835", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-01", "vigencias": [{"desde": "1987-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "