{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6316273}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP 175, de 30 de noviembre del 2000, se expropiaron los lotes de terreno N&#xBA;s. 61-F, 61-1 y 62-1, superficies 188 m&#xB2;, 122 m&#xB2; y 212 m&#xB2;, rol de aval&#xFA;o 1545-93, comuna de Los Angeles, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo:</div><div class=\"p\">Chill&#xE1;n-Collipulli, By Pass Los Angeles, Octava Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Manuel Hern&#xE1;n Godoy Alvarez, ascendente a la cantidad total de $1.953.490.-</div><br></div>", "i": 6316274}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6316275}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "175 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-175 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-11-30", "doble_articulado": false, "id_norma": "180148", "numero_fuente": "36862", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-15", "vigencias": [{"desde": "2001-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2001-01-15", "fecha_version": "2001-01-15", "fecha_actualizacion_te