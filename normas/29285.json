{"html": [{"t": "<div><div class=\"p\">MODIFICA LA LEY N&#xB0; 11.860 </div><br><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente,</div><br><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8284463}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Modif&#xED;case el inciso primero del art&#xED;culo 46 de la ley N&#xB0; 11.860, de 14 de Septiembre de 1955, en la siguiente forma: Supr&#xED;mese el punto final que figura despu&#xE9;s de la palabra &quot;Regidores&quot; y agr&#xE9;gase a continuaci&#xF3;n la siguiente frase: &quot;Y votar su renuncia al cargo de Alcalde.</div><br></div>", "i": 8284464}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecisiete de Octubre de mil novecientos setenta y dos.- SALVADOR ALLENDE GOSSENS.- Jaime Su&#xE1;rez B.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda atentamente a Ud.- Daniel Vergara Bustos, Subsecretario del Interior.</div><br></div>", "i": 8284465}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "17792", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-17792"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA LA LEY N° 11.860", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "LEY 11860"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1972-10-17", "doble_articulado": false, "id_norma": "29285", "numero_fuente": "28390", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1972-10-30", "vigencias": [{"desde": "1972-10-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1972-10-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1972-10-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "fecha_version": "1972-10-30", "fecha_actualizacion_texto": "1972-10-30", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8284463}, {"n": "Artículo UNICO", "i": 8284464, "t": 6}, {"n": "Promulgación", "i": 8284465}]}