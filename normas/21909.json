{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei de Conversion Met&#xE1;lica.- Se derogan varios art&#xED;culos</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 36.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 7162434}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se derogan los art&#xED;culos 1.&#xB0;, 2.&#xB0;, 3.&#xB0;, 4.&#xB0;, 5.&#xB0;, 6.&#xB0; i 8.&#xB0; de la lei de 26 de Noviembre de 1892.</div><div class=\"p\">&nbsp; &nbsp; El producto de la &#xFA;ltima venta de bonos enajenados en conformidad a la lei de 26 de Noviembre de 1892, se destinar&#xE1; al pago de la deuda flotante del Estado.</div><br><br></div>", "i": 7162435}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 13 de Mayo de 1893.- JORJE MONTT.- Alejandro Vial.</div><br></div>", "i": 7162436}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "36", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-36"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "SE DEROGAN VARIOS ARTICULOS DE LA LEI DE CONVERSION METÁLICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BONOS DEL ESTADO", "CONVERSION METALICA", "EMISION", "DEROGACION", "MODIFICACION", "EMPRESTITO", "AMORTIZACION", "ENAJENACION", "PAPEL MONEDA", "ORO", "PLATA", "INCINERACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-05-13", "doble_articulado": false, "id_norma": "21909", "numero_fuente": "4518", "tipo_