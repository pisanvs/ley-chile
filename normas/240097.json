{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6533022}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 426 de fecha 31 de mayo del 2005, se expropi&#xF3; el lote de terreno N&#xBA;86-B, superficie 6.978 m&#xB2;, Rol N&#xBA; 679-150, comuna de Lautaro, IX Regi&#xF3;n para la obra &quot;Camino Ruta S-10, sector Cruce Long.</div><div class=\"p\">(Lautaro)-Galvarino, Tramo Km. 0,000 al Km. 34,50853&quot;, Etapa Km. 0,000 a Km. 18,000&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Rosa del Carmen Huenulao Catrileo y Otros, ascendente a la cantidad de $8.736.908.- para el lote N&#xBA;86-B.</div><br></div>", "i": 6533023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6533024}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "426", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-426"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-05-31", "doble_articulado": false, "id_norma": "240097", "numero_fuente": "38211", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-15", "vigencias": [{"desde": "2005-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-07-15", "fecha_version": "2005-07-15", "fecha_actuali