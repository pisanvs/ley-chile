{"html": [{"t": "<div><div class=\"p\">CERTIFICADO N&#xB0; 1</div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA</div></div>", "i": 10305679}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Certifico que Exportadora Volc&#xE1;n Foods Limitada, RUT 77.223.122-9, cumple los requisitos establecidos en la resoluciones exentas N&#xB0; 55, del 02/06/2005, publicada en el Diario Oficial el 08/06/2005 y <a href=\"https://www.leychile.cl/Navegar?idNorma=249898&amp;idParte=&amp;idVersion=\">N&#xB0; 58</a>, del 19/05/2006, publicada en el Diario Oficial el 25/05/2006 y en consecuencia tiene los requisitos de Agente Retenedor del Impuesto al Valor Agregado en las adquisiciones de Berries que efect&#xFA;e, a contar del mes siguiente de la publicaci&#xF3;n de este certificado en el Diario Oficial.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10305680}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 30 de diciembre de 2021.- Carlos Alberto Ocares Maturana, Director Regional Concepci&#xF3;n.</div><div class=\"p\"> </div><br></div>", "i": 10305681}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "1", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "Certificado-1"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL CONCEPCIÓN"], "titulo_norma": "CERTIFICADO N° 1; OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2078636"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-12-30", "doble_articulado": false, "id_norma": "1171907", "numero_fuente": "43164", "tipo_version": "3", "tipo_version_s": "Única", "fecha_pu