{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6021088}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n Exenta N&#xB0; 164 del 29 de Diciembre de 1992, se autoriza a Alberto Barroso A. la concesi&#xF3;n para operar, hasta el 14 de Febrero de 1995, un establecimiento ubicado en In&#xE9;s Rivas 0298, Comuna de La Cisterna, destinado a la verificaci&#xF3;n de emisi&#xF3;n de contaminantes de veh&#xED;culos motorizados livianos a que se refiere el D.S. N&#xB0; 211/91, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.</div><br></div>", "i": 6021089}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Juan Fuentes Isla, Secretario Regional Ministerial Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana, Subrogante.</div><br></div>", "i": 6021090}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "164", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-164"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANTA REVISION TECNICA", "REVISION TECNICA", "ALBERTO BARROSO ARANGUIZ VEHICULOS MOTORIZADOS", "LA CISTERNA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-12-29", "doble_articulado": false, "id_norma": "38467", "numero_fuente": "34494", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-02-17", "vigencias": [{"desde": "1993-02-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-02-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-02-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie