{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8330037}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 614, de 29 de abril de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a NESTLE CHILE S.A., para continuar desarrollando las actividades pesqueras autorizadas a Productos Alimenticios Savory S.A., en virtud de la escritura p&#xFA;blica y disposiciones legales vigentes.</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 989, de 10 de julio de 1997, de esta Subsecretar&#xED;a, en virtud de lo dispuesto en la presente resoluci&#xF3;n.</div><br></div>", "i": 8330038}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de abril de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8330039}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "614", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-614"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "NESTLE CHILE S.A.", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-29", "doble_articulado": false, "id_norma": "99049", "numero_fuente": "36064", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-05-14", "vigencias": [{"desde": "1998-05-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-05-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-05-14", "fin_vigencia": "", "