{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AUMENTA EL SUELDO DE LOS EMPLEADOS DE CORREOS I TELEGRAFOS.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1757.-Santiago, a 7 de Setiembre de 1905.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br><br></div>", "i": 8274670}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.-Mi&#xE9;ntras se dicta la lei que reorganiza los servicios de correos i tel&#xE9;grafos, aum&#xE9;ntase en un cuarenta por ciento el sueldo de los empleados de &#xE1;mbos ramos desde el departamento de Copiap&#xF3; al norte, i en un treinta por ciento en el resto de la Rep&#xFA;blica.</div><br></div>", "i": 8274671}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Juan Antonio Orrego.</div><br></div>", "i": 8274672}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1757", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1757"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUMENTA EL SUELDO DE LOS EMPLEADOS DE CORREOS I TELEGRAFOS.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CORREOS", "TELEGRAFOS", "REMUNERACIONES", "PERSONAL", "AUMENTA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-09-07", "doble_articulado": false, "id_norma": "22897", "numero_fuente": "8303", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-09-07", "vigencias": [{"desde": "1905-09-07", "hasta": "", "tipo_version": "3", "tipo_v