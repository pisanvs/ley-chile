{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.115, de 18 de junio de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, cad&#xFA;case parcialmente la Resoluci&#xF3;n N&#xB0; 903, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA SAN JOSE S.A., para desarrollar actividades pesqueras extractivas con la nave &quot;Rengo&quot;, s&#xF3;lo en lo que se refiere a la autorizaci&#xF3;n para esta nave en el litoral de la II Regi&#xF3;n sobre los recursos hidrobiol&#xF3;gicos se&#xF1;alados en el numeral 4&#xB0; de la Resoluci&#xF3;n citada precedentemente.</div><br></div>", "i": 8295796}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 18 de junio de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295797}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1115", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1115"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "PESCA", "PESQUERA SAN JOSE S.A"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-06-18", "doble_articulado": false, "id_norma": "36269", "numero_fuente": "35499", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-06-24", "vigencias": [{"desde": "1996-06-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-06-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-