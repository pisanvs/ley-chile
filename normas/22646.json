{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Ferrocarril de Serena a Rivadavia. 800,000 pesos Lei n&#xFA;m. 1,436.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949164}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la suma de ochocientos mil pesos en pagar los trabajos hechos en la construccion del ferrocarril de Serena a Rivadavia.</div><br></div>", "i": 5949165}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 19 de Enero de 1901.- FEDERICO ERRAZURIZ E.- Manuel A. Covarrubias.</div><br></div>", "i": 5949166}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1436", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1436"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "FERROCARRIL DE SERENA A RIVADAVIA  800,000 PESOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FERROCARRIL SERENA-RIVADAVIA", "CONSTRUCCION", "FONDOS", "INVERSION", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-01-19", "doble_articulado": false, "id_norma": "22646", "numero_fuente": "6797", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-01-21", "vigencias": [{"desde": "1901-01-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1901-01-21", "f