{"html": [{"t": "<div><div class=\"p\">APRUEBA REFORMA DE ESTATUTOS DE &quot;COMPA&#xD1;IA DE SEGUROS GENERALES INA KAPPES S.A.&quot; </div></div>", "i": 6259510}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico: Que por resoluci&#xF3;n No. 14, de 30 de Enero de 1985, se aprob&#xF3; reforma de estatutos de sociedad an&#xF3;nima &quot;Compa&#xF1;&#xED;a de Seguros. Generales Ina Kappes S.A.&quot; que consta de la escritura p&#xFA;blica de fecha 14 de Enero de 1985, otorgada en la Notar&#xED;a de Santiago de don V&#xED;ctor Manuel Correa Valenzuela. La reforma consiste en cambiar la raz&#xF3;n social que en lo sucesivo ser&#xE1; &quot;Cigna Compa&#xF1;&#xED;a de Seguros (Chile) S.A.&quot;.</div><br></div>", "i": 6259511}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de Enero de 1985.- Ana Mar&#xED;a Siefer Navas, Secretario General.</div><br></div>", "i": 6259512}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "14", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-14"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "APRUEBA REFORMA DE ESTATUTOS DE COMPAÑIA DE SEGUROS GENERALES INA KAPPES S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-30", "doble_articulado": false, "id_norma": "163800", "numero_fuente": "32090", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-02-06", "vigencias": [{"desde": "1985-02-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-02-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-02-06", "fin_vi