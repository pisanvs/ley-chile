{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9052151}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 43, de 22 de febrero de 1988, se expropiaron los lotes N&#xBA;s 6, 53, 58-A, 58-B, 87 y 99, cuyas superficies son 150 M2. 304,8 M2. 177,6 M2. 271,1 M2. 77,4 M2. y 99,7 M2., respectivamente, roles de aval&#xFA;os 44-66, 46-176, 46-28, 46-28, 46-91 y 46-70, Comuna de Peumo, para Ruta H-66-G Pelequ&#xE9;n Cruce Las Ara&#xF1;as, sector Codao Las Cabras y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios Domitilia Fuentes y otras, Pedro Amigo y otras, C&#xE9;sar Correa y otro, C&#xE9;sar Correa y otro, Protacio Rodr&#xED;guez y otros e Ismael Vald&#xE9;s, ascendente a las cantidades de $ 269.194, $ 181.185, $ 99.638, $ 133.197, $ 113.923 y $ 107.570. </div></div>", "i": 9052152}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 9052153}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "43", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-43"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-02-22", "doble_articulado": false, "id_norma": "176102", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-03-15", "vigencias": [{"desde": "1988-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes