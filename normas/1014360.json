{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 5.274 EXENTA, DE 2010</div></div>", "i": 8931893}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 5.274, de 26 de mayo de 2010, del Servicio Nacional de Capacitaci&#xF3;n y Empleo, se modifica el numeral 12.2 del texto del Manual de Procedimientos Programa Reinserci&#xF3;n Laboral Para Personas Mayores de 40 a&#xF1;os que hayan perdido su empleo, reemplazando la frase &quot;Liquidaci&#xF3;n de remuneraciones debidamente firmada a lo menos por el trabajador&quot; por la frase &quot;Fotocopia de la liquidaci&#xF3;n de remuneraciones&quot;.- </div></div>", "i": 8931894}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Manuel Castro Rebolledo, Director Nacional Subrogante.</div></div>", "i": 8931895}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5274 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5274 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 5.274 EXENTA, DE 2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-05-26", "doble_articulado": false, "id_norma": "1014360", "numero_fuente": "39681", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-06-09", "vigencias": [{"desde": "2010-06-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-06-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-06-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_p