{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9293068}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. (Exento) N&#xBA;1462, de fecha 31 de julio de 2012, y de conformidad a lo dispuesto en el art&#xED;culo 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;5, superficie 820 m2., rol N&#xBA;2026-163, para la obra &quot;REPOSICI&#xD3;N Y CONSTRUCCI&#xD3;N DE PUENTES VARIAS PROVINCIAS REGI&#xD3;N METROPOLITANA&quot;, comuna de Melipilla, Regi&#xF3;n Metropolitana. La comisi&#xF3;n de peritos, integrada por N&#xE9;stor Abello Rodr&#xED;guez, Douglas Herrera Flores y Marcela Redard Ayala, fij&#xF3; el valor de tasaci&#xF3;n con fecha 29 de julio de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario RICARDO H&#xC9;CTOR SEP&#xDA;LVEDA BAGU, en la cantidad de $16.096.418, suma que se pagar&#xE1; al contado.</div></div>", "i": 9293069}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9293070}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1462 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1462 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-31", "doble_articulado": false, "id_norma": "1043416", "numero_fuente": "40352", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-09-01", "vigencias": [{"desde": "2012-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-09-01", "fin_vigencia": ""}, "vig