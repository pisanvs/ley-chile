{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6028585}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile en conformidad con lo dispuesto en el N&#xBA; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de enero de 1997, fue 6,93% anual. </div></div>", "i": 6028586}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, enero 17 de 1997.-</div><br><div class=\"p\">&nbsp; &nbsp;  Jorge Carrasco V&#xE1;squez, Ministro de fe. </div></div>", "i": 6028587}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA DE INTERES PROMEDIO", "OPERACIONES DE CREDITO DE DINERO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-01-17", "doble_articulado": false, "id_norma": "60196", "numero_fuente": "35670", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-01-20", "vigencias": [{"desde": "1997-01-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-01-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-01-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CDG", "fecha_ingreso": "1997-02-04", "fecha_version": "1997-01-20", "fecha_actualizacion_texto": "1997-01-20", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "e