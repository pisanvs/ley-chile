{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO NUMERO 254 EXENTO, DE 1997 </div></div>", "i": 6037247}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento N&#xBA; 254 de fecha 4 de marzo de 1997 del Ministerio de Educaci&#xF3;n, se declar&#xF3; aprobada a la Universidad Jos&#xE9; Santos Ossa, inscrita en el Registro de Universidades bajo el Folio C-N&#xBA;59 del a&#xF1;o 1992, la carrera de Contador P&#xFA;blico-Auditor, conducente al t&#xED;tulo profesional de Contador P&#xFA;blico-Auditor y al grado de Licenciado en Ciencias Contables, para ser impartida a contar de 1997 en la ciudad de Antofagasta, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6037248}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de marzo de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6037249}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "254 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-254 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO NUMERO 254 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["UNIVERSIDAD JOSE SANTOS OSSA", "PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-04", "doble_articulado": false, "id_norma": "71511", "numero_fuente": "35771", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-22", "vigencias": [{"desde": "1997-05-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-22", "fin_vigen