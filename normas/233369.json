{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6508273}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.345, de 25 de noviembre de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a MU&#xD1;OZ Y FERNANDEZ LIMITADA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Avenida Pedro Aguirre Cerda N&#xBA; 6090, Antofagasta, II Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco enfriado, Fresco-refrigerado, Congelado, Conserva, Seco salado, Salado h&#xFA;medo los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6508274}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de noviembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6508275}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3345 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3345 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-25", "doble_articulado": false, "id_norma": "233369", "numero_fuente": "38033", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-11", "vigencias": [{"desde": "2004-12-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-12-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-12-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes"