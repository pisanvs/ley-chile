{"html": [{"t": "<div><div class=\"p\">ENCLAJE DE BUQUES</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 16 de 1825.</div><br><div class=\"p\">&nbsp; &nbsp;  He acordado y decreto lo siguiente:</div></div>", "i": 10115529}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Todo buque que anclare en cualquiera de los puertos habilitados de Chile, y trajere a su bordo mercader&#xED;as, sea de la clase que se fueren, aun de las libres de derechos, y para los objetos mas privilejiados, debe presentar los manifiestos por mayor y menor prevenidos por la ampliacion al Reglamento de libre comercio de 813.</div></div>", "i": 10115530}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon donde corresponda, trascribase e imprimase.</div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.&nbsp; &nbsp;  Correa de Saa.</div></div>", "i": 10115531}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "ENCLAJE DE BUQUES", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-07-16", "doble_articulado": false, "id_norma": "1143273", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-07-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-07-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-07-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2020-04-20", "fecha_version": "1825-07-1