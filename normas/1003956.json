{"html": [{"t": "<div><br><div class=\"p\">DEROGA AUTORIZACI&#xD3;N DE EMISORES ELECTR&#xD3;NICOS</div></div>", "i": 8735809}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta, del Servicio de Impuestos Internos, N&#xBA;94, de 26 de junio de 2009, que deroga autorizaci&#xF3;n otorgada a contribuyentes para operar como emisores electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  Der&#xF3;gase autorizaci&#xF3;n otorgada para operar como Emisor de Documentos Tributarios Electr&#xF3;nicos, al contribuyente RUT N&#xBA;9.585.068-5.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos, en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de junio de 2009.</div></div>", "i": 8735810}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "94 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-94 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-06-26", "doble_articulado": false, "id_norma": "1003956", "numero_fuente": "39402", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-07-03", "vigencias": [{"desde": "2009-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-07-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-07-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vi