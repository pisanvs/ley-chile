{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6561533}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 201 de 18 de enero de 2006 de esta Subsecretar&#xED;a, autor&#xED;zase a JAE HO CHOUNG, EMPRESA INDIVIDUAL DE RESPONSABILIDAD LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a su planta ubicada en Caleta Level s/n&#xBA;, Sector Puerto Ed&#xE9;n, XII Regi&#xF3;n, en las l&#xED;neas de proceso de Alga Seca, Congelado, Fresco-Enfriado, Fresco Refrigerado y Cocido, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA;705 de 1988, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6561534}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de enero de 2006.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6561535}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "201 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-201 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-18", "doble_articulado": false, "id_norma": "247354", "numero_fuente": "38392", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-02-17", "vigencias": [{"desde": "2006-02-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-02-17", "fin_vigencia