{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 228, DE 1990</div><br><br></div>", "i": 7231285}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento No. 228 de fecha 10 de septiembre del Ministro de Educaci&#xF3;n, se insert&#xF3; en la Resoluci&#xF3;n Exenta de Educaci&#xF3;n No. 143 de 1987 del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Superior de T&#xE9;cnicas de la Comunicaci&#xF3;n ISTECO de Santiago, las adecuaciones introducidas a la carrera de Direcci&#xF3;n y Producci&#xF3;n de Televisi&#xF3;n, las que podr&#xE1;n aplicarse a contar del a&#xF1;o 1990.</div><br><br></div>", "i": 7231286}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de Noviembre de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br><br></div>", "i": 7231287}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "228 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-228 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 228, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-09-10", "doble_articulado": false, "id_norma": "96746", "numero_fuente": "33828", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-11-26", "vigencias": [{"desde": "1990-11-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-11-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-11-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part":