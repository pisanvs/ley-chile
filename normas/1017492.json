{"html": [{"t": "<div><br><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A YUSEF SABAG CASTILLO</div><br></div>", "i": 9012177}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/N&#xBA; Ex 9.190, de fecha 13 de septiembre de 2010, revoca a Yusef Sabag Castillo, RUT N&#xBA; 4.827.392-0, a partir de la fecha de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las ventas de Madera, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 18 de la Res. Ex. N&#xBA; 4916 del 31-10-2000, de la Direcci&#xF3;n Nacional del Servicio de Impuestos Internos.-</div><br></div>", "i": 9012178}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n 13 de septiembre de 2010.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div></div>", "i": 9012179}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9190 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-9190 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A YUSEF SABAG CASTILLO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-09-13", "doble_articulado": false, "id_norma": "1017492", "numero_fuente": "39773", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-09-30", "vigencias": [{"desde": "2010-09-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-09-30", "fin_vigencia": ""}, "vi