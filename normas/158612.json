{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6242354}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 96, de 12 de mayo de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Atacama, se autoriza a Hugo Valenzuela Fuentevilla y Otros para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 3 &quot;Quinta Valle - Avenida Matta&quot;, cuyo trazado que a continuaci&#xF3;n se indica fue autorizado por resoluci&#xF3;n No. 28, de 13 de junio de 1984, de esta Secretar&#xED;a Regional.</div><div class=\"p\">&nbsp; &nbsp;  Ida: Valle, Bagnara, Carbonell, Serrano, Matta.</div><div class=\"p\">&nbsp; &nbsp;  Regreso: Matta, Merced, Talca, Prat, Valle.- </div></div>", "i": 6242355}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Antonio Acevedo Oyarce, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n de Atacama.</div><br></div>", "i": 6242356}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "96 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-96 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-05-12", "doble_articulado": false, "id_norma": "158612", "numero_fuente": "32483", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-05-30", "vigencias": [{"desde": "1986-05-30", "hasta": "", "tipo_version": "3", "tipo_version