{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6254774}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 584 de 02 de Septiembre de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la regi&#xF3;n se autoriza a la Empresa de Buses Bonanza para efectuar todo tipo de servicio de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br><br></div>", "i": 6254775}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Manuel Coloma Amaro, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n del Maule.</div><br></div>", "i": 6254776}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "584 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-584 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-09-02", "doble_articulado": false, "id_norma": "162259", "numero_fuente": "32274", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-09-16", "vigencias": [{"desde": "1985-09-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-09-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-09-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":