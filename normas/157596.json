{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6238956}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. N&#xB0; 50, de 22 de Febrero de 1985, se expropiaron los lotes N&#xB0;s. 10, 12 y 13, cuyas superficies son 120 m2., 320 m2. y 670 m2., roles de aval&#xFA;o 318-33, 318-35, y 318-37, todos de la Comuna de Concepci&#xF3;n, VIII Regi&#xF3;n y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios Alex Trautmann Vergara, H&#xE9;ctor Zambrano Zambrano y H&#xE9;ctor Ram&#xF3;n, Jorge Aurelio, Sergio Augusto y Eliana Aurora Montero Melo, ascendente a las cantidades de $ 42.398, para el lote N&#xB0; 10, $ 103.620, para el lote N&#xB0; 12 y $ 190.525, para el lote N&#xB0; 13.-</div><br></div>", "i": 6238957}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6238958}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "50", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-50"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-02-22", "doble_articulado": false, "id_norma": "157596", "numero_fuente": "32122", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-15", "vigencias": [{"desde": "1985-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ing