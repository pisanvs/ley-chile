{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8786480}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xBA; 1423, de 31 de agosto de 2009, se revoc&#xF3; el <a href=\"https://www.leychile.cl/Navegar?idNorma=185091&amp;idParte=&amp;idVersion=2009-10-01\">Decreto Exento MOP N&#xBA;214, de 30 de marzo de 2001</a>, que ordenaba la expropiaci&#xF3;n del lote de terreno N&#xBA; 157-1, para la obra &quot;Concesi&#xF3;n Internacional Ruta 5. Tramo: Santiago - Talca. Sector: Km. 68.400,00 al Km. 95.600,00. By-Pass Rancagua&quot;, debido a que en virtud de nuevos antecedentes se determin&#xF3; que dicho lote forma parte de un camino que tiene la calidad de bien nacional de uso p&#xFA;blico, y en consecuencia no es procedente su expropiaci&#xF3;n. </div><br><br></div>", "i": 8786481, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 8786482}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1423 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1423 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-08-31", "doble_articulado": false, "id_norma": "1006774", "numero_fuente": "39475", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-10-01", "vigencias": [{"desde": "2009-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-10-01", "fin_vigen