{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.264 EXENTA, DE 2002 </div></div>", "i": 7291512}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 1.264 de 20 de febrero de 2002, se ha aprobado al Colegio Hispano Americano (PP. Escolapios) de Santiago, un plan de estudio para 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, que se aplicar&#xE1; a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 7291513}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de abril de 2002.- Javier San Miguel Bertr&#xE1;n, Jefe Divisi&#xF3;n de Educaci&#xF3;n General (S). </div></div>", "i": 7291514}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1264 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1264 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.264 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-20", "doble_articulado": false, "id_norma": "197737", "numero_fuente": "37250", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-04", "vigencias": [{"desde": "2002-05-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion