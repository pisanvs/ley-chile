{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA;5.841 EXENTA, DE 2008 </div></div>", "i": 6656836}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA;5.841, de 31 de julio</div><div class=\"p\">de 2008, del Servicio Nacional de Capacitaci&#xF3;n y Empleo,</div><div class=\"p\">dej&#xF3; sin efecto la cancelaci&#xF3;n de la inscripci&#xF3;n en el</div><div class=\"p\">Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n</div><div class=\"p\">a la sociedad &quot;Pronova Capacitaci&#xF3;n Limitada&quot;, RUT</div><div class=\"p\">76.535.670-9, atendido que el mencionado organismo</div><div class=\"p\">acredit&#xF3; el cumplimiento de lo preceptuado en los</div><div class=\"p\">art&#xED;culos 12 y 21 de la ley N&#xBA;19.518, y, lo dispuesto en el n&#xFA;meral 5 del art&#xED;culo 85 del mismo cuerpo legal. </div></div>", "i": 6656837}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fernando Rouliez Fleck, Director Nacional. </div></div>", "i": 6656838}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5841 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5841 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº5.841 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-07-31", "doble_articulado": false, "id_norma": "275860", "numero_fuente": "39135", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-08-11", "vigencias": [{"desde": "2008-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia":