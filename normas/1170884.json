{"html": [{"t": "<div><div class=\"p\">PONE T&#xC9;RMINO AL NOMBRAMIENTO COMO ALCALDE DE MAR AD-HON&#xD3;REM</div></div>", "i": 10298719}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n D.G.T.M. y M.M. Ordinario N&#xBA; 1.120/120 Vrs., del 20 de diciembre de 2021, pone t&#xE9;rmino al nombramiento como Alcalde de Mar Ad-Hon&#xF3;rem sector &quot;Boca de Rapel&quot; del Sr. Lorenzo Guasp Mu&#xF1;oz, dependiente de la Capitan&#xED;a de Puerto de Pichilemu.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10298720}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de diciembre de 2021.- Por orden del Sr. Director General Zvonimir Yuras C&#xE1;rdenas, Capit&#xE1;n de Nav&#xED;o LT, Subdirector Suplente.- Cristi&#xE1;n Pfeifer Rojas, Capit&#xE1;n de Nav&#xED;o JT, Jefe Depto. Jur&#xED;dico.</div><div class=\"p\"> </div><br></div>", "i": 10298721}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "120", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-120"}, {"tipo": "3", "numero": "1.120/120", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1.120/120"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "PONE TÉRMINO AL NOMBRAMIENTO COMO ALCALDE DE MAR AD-HONÓREM", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2066610", "EX