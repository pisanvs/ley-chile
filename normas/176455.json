{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7276941}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n n&#xFA;mero 2.119, de 29 de septiembre de 2000, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1.543, de 2000, de esta Subsecretar&#xED;a, que declar&#xF3; la caducidad de las resoluciones N&#xBA; 1.271, de 1988 y N&#xBA; 151, de 1998, que autorizaron a PESQUERA CANTABRICO S.A., para operar la nave &apos;&apos;Maresma&apos;&apos;, por haberse acreditado el pago de la patente &#xFA;nica pesquera. </div></div>", "i": 7276942}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de septiembre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca. </div></div>", "i": 7276943}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2119", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2119"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-29", "doble_articulado": false, "id_norma": "176455", "numero_fuente": "36779", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-04", "vigencias": [{"desde": "2000-10-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-10-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-10-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JCT", "fecha_ingreso": "2