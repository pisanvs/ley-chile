{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA;184, DE 1992 </div></div>", "i": 6050895}, {"t": "<div><div class=\"p\">Por Decreto Exento N&#xBA;184 de fecha 30 de junio de 1992 del Ministerio de Educaci&#xF3;n, se derog&#xF3; el Decreto Exento de Educaci&#xF3;n N&#xBA;43 de 11 de mayo de 1989, que autoriz&#xF3; el funcionamiento al Instituto Profesional Superior de Computaci&#xF3;n de Santiago, organizado por la Sociedad Compa&#xF1;&#xED;a de Asesores en Programaci&#xF3;n Computacional S.A., ASPRO S.A., y se elimin&#xF3; del Libro de Registro de Institutos Profesionales el N&#xBA;47 correspondiente a la instituci&#xF3;n antes se&#xF1;alada.-</div><br></div>", "i": 6050896}, {"t": "<div><div class=\"p\">Santiago, 14 de Agosto de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6050897}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "184 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-184 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº184, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-06-30", "doble_articulado": false, "id_norma": "77636", "numero_fuente": "34350", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-08-25", "vigencias": [{"desde": "1992-08-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-08-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-08-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v