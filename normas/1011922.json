{"html": [{"t": "<div><br><div class=\"p\">SUSPENDE FUNCIONAMIENTO DE JUNTAS INSCRIPTORAS QUE SE&#xD1;ALA</div></div>", "i": 8900773}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Susp&#xE9;ndese el funcionamiento de las Juntas Inscriptoras de Champa en la Regi&#xF3;n Metropolitana de Santiago, y de Codegua, Rengo, Requ&#xED;noa y San Fernando en la VI Regi&#xF3;n del Libertador Gral. Bernardo O&#x2019;Higgins.</div><div class=\"p\">&nbsp; &nbsp;  La suspensi&#xF3;n dispuesta opera desde el d&#xED;a 1 de abril de 2010 y por un plazo de 30 d&#xED;as o hasta que se restablezcan las condiciones necesarias para su funcionamiento.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada por resoluci&#xF3;n N&#xBA; O-0591 de 18 de marzo de 2010.-</div></div>", "i": 8900774}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, marzo 18 de 2010.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director Servicio Electoral.</div></div>", "i": 8900775}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "591", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-591"}, {"tipo": "3", "numero": "O-591", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-O-591"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SUSPENDE FUNCIONAMIENTO DE JUNTAS INSCRIPTORAS QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-03-18", "doble_articulado": false, "id_norma": "1011922", "numero_fuente": "39617", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-03-22", "vigencias": [{"desde": "2010-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio