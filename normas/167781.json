{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA </div></div>", "i": 6272516}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n n&#xFA;mero 88, de fecha 26 de abril de 1990,</div><div class=\"p\">del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se</div><div class=\"p\">cancel&#xF3; la Personalidad Jur&#xED;dica de la Asociaci&#xF3;n Gremial de</div><div class=\"p\">Funcionarios del Liceo Experimental Manuel de Salas,</div><div class=\"p\">inscrita bajo el n&#xFA;mero 1.905 del Registro que para tal</div><div class=\"p\">efecto lleva este Ministerio, por haberse configurado</div><div class=\"p\">respecto de ella, la causal de cancelaci&#xF3;n contemplada en el</div><div class=\"p\">art&#xED;culo 18 No. 2 letra a) del DL No. 2.757, de 1979.- </div></div>", "i": 6272517}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jorge Marshall Rivera, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6272518}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "88", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-88"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-04-26", "doble_articulado": false, "id_norma": "167781", "numero_fuente": "33925", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-03-22", "vigencias": [{"desde": "1991-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vi