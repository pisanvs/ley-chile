{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6266218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 277 del 04 de diciembre de 1984, de la Secretario Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se autoriza a la se&#xF1;ora Elia N&#xFA;&#xF1;ez Segovia para efectuar todo tipo de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n del servicio urbano de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6266219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Manuel Coloma Amaro, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n del Maule. </div></div>", "i": 6266220}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "277", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-277"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-12-04", "doble_articulado": false, "id_norma": "165952", "numero_fuente": "32072", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-01-16", "vigencias": [{"desde": "1985-01-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-01-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-01-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMZ", "fecha_ingre