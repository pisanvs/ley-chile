{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8350325}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.730, de 2 de septiembre de 1999, de esta Subsecretar&#xED;a, autor&#xED;zase a COMPA&#xD1;&#xCD;A PESQUERA CAMANCHACA S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluci&#xF3;n N&#xBA; 11, de 1980, de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Manuel Montt N&#xBA; 1941, comuna de Tom&#xE9;, provincia de Concepci&#xF3;n, VIII Regi&#xF3;n, en la l&#xED;nea de elaboraci&#xF3;n de Conserva, el recurso hidrobiol&#xF3;gico Caballa.</div><br></div>", "i": 8350326}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de septiembre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8350327}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1730", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1730"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-09-02", "doble_articulado": false, "id_norma": "143829", "numero_fuente": "36470", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-22", "vigencias": [{"desde": "1999-09-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-09-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part