{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE&nbsp; DECRETO N&#xBA; 545 EXENTO, DE 2003 </div></div>", "i": 7302724}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 545 de fecha 15 de julio de 2003, de Educaci&#xF3;n, se modifica el decreto exento N&#xBA; 280 de Educaci&#xF3;n de 1&#xBA; de diciembre de 1981, en el inciso segundo y siguientes, correspondiente al Reglamento Acad&#xE9;mico del Instituto Profesional Agrario Adolfo Matthei.</div><div class=\"p\">&nbsp; &nbsp;  La presente modificaci&#xF3;n rige a contar del a&#xF1;o 2001.</div><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase presente para todos los efectos legales y administrativos.</div><br></div>", "i": 7302725}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de julio de 2003.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 7302726}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "545 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-545 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 545 EXENTO, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-07-15", "doble_articulado": false, "id_norma": "213820", "numero_fuente": "37640", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-08-21", "vigencias": [{"desde": "2003-08-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-08-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-08-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vi