{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 14,284</div><br><div class=\"p\">AUMENTA, POR GRACIA, LA PENSION DE DO&#xD1;A MARTA DIAZ VIUDA DE SAMITH</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6576544}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Aum&#xE9;ntase, por gracia, la pensi&#xF3;n de que disfruta do&#xF1;a Mar&#xED;a D&#xED;az viuda de Samith, a E&#xBA; 45 mensuales.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande esta ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda.</div><br></div>", "i": 6576545}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a diez de Noviembre de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- Eduardo Figueroa G.</div><br></div>", "i": 6576546}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14284", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14284"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "AUMENTA, POR GRACIA, LA PENSION DE DOÑA MARTA DIAZ VIUDA\nDE SAMITH", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-11-10", "doble_articulado": false, "id_norma": "251486", "numero_fuente": "24807", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-11-30", "vigencias": [{"desde": "1960-11-30", "hasta": "", "tipo_version": "3", "tipo_versi