{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6218766}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 88, de fecha 03.07.87, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la XI Regi&#xF3;n, se autoriza a la Empresa Transportes Austral Ltda., para efectuar todo tipo de servicio de transportes de pasajeros por calles y caminos dentro del territorio nacional a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6218767}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Coyhaique, 03.07.87.- Ra&#xFA;l Castillo Ceardi, Secretario Regional Ministerial de Transportes y Telecomunicaciones XI Regi&#xF3;n.</div><br></div>", "i": 6218768}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "88 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-88 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XI REGIÓN DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-03", "doble_articulado": false, "id_norma": "151166", "numero_fuente": "32818", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-13", "vigencias": [{"desde": "1987-07-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-07-13", "fin_vigencia": "", "tipo_ve