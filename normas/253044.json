{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA </div></div>", "i": 6582102}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Ministerial T.R. N&#xBA; 44, de 28 de junio de 2006, se cancel&#xF3; la personalidad jur&#xED;dica de la &quot;Asociaci&#xF3;n Gremial de Due&#xF1;os de Buses Rurales, Urbanos y Particulares, V Regi&#xF3;n Cordillera&quot; inscrita bajo el N&#xBA; 3.642 por haberse configurado la causal contemplada en la letra a), n&#xFA;mero 2, del art&#xED;culo 18 del decreto ley N&#xBA; 2.757, de 1979.</div><br></div>", "i": 6582103}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Javiera Estrada Quezada, Jefe Unidad Asociaciones Gremiales y Martilleros.</div><br></div>", "i": 6582104}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "44", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-44"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-28", "doble_articulado": false, "id_norma": "253044", "numero_fuente": "38560", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-09-08", "vigencias": [{"desde": "2006-09-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-09-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-09-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingr