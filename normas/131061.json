{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; EXTRACTO DE RESOLUCION EXENTA No. 1.459, DE 1988 </div></div>", "i": 7245101}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.459, de fecha 03 de Junio de 1988, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se aprobaron las adecuaciones introducidas a las carreras de Secretariado Ejecutivo Biling&#xFC;e, T&#xE9;cnico en Auditor&#xED;a con menci&#xF3;n en Computaci&#xF3;n y T&#xE9;cnico en Construcci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto de Massachusets de Talca, las que podr&#xE1;n aplicarse a contar del primer semestre acad&#xE9;mico 1988.</div><br></div>", "i": 7245102}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 08 de Julio de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7245103}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1459 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1459 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_derogacion": "2024-01-31", "doble_articulado": false, "id_norma": "131061", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1988-09-20", "vigencias": [{"desde": "2024-01-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1988-09-20", "hasta": "2024-01-30", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2024-01-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-09-20", "fin