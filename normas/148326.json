{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6207872}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 687, de fecha 07 de Mayo de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones da la V Regi&#xF3;n, se autoriza al se&#xF1;or Gustavo Mart&#xED;nez P&#xE9;rez para efectuar todo tipo de servicies de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6207873}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 07 de Mayo de 1987.- Hern&#xE1;n V&#xE1;squez Wacquez, Capit&#xE1;n de Nav&#xED;o, Secre tario Regional Ministerial de Transportes y Telecomunicaciones V Regi&#xF3;n.</div><br></div>", "i": 6207874}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "687 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-687 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL V REGIÓN DE VALPARAÍSO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-05-07", "doble_articulado": false, "id_norma": "148326", "numero_fuente": "32774", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-05-19", "vigencias": [{"desde": "1987-05-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-05-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-05-1