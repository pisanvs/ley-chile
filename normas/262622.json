{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7347477}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.661, de 1 de junio de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a COMERCIALIZADORA ANDES DEL SUR LIMITADA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Costa Tengo Alto, Parcela A s/n&#xBA;, Puerto Montt, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco-enfriado, Fresco-refrigerado y Congelado los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 568, de 1998, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 7347478}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de junio de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7347479}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1661 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1661 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-01", "doble_articulado": false, "id_norma": "262622", "numero_fuente": "38811", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-07-12", "vigencias": [{"desde": "2007-07-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-07-12", "fin_vigencia": ""