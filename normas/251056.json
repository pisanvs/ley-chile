{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CERTIFICADO</div><br><br></div>", "i": 6574896}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 2,26% anual durante el mes de junio de 2006.</div><div class=\"p\">Asimismo, en conformidad con lo dispuesto en el N&#xBA; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de junio de 2006, fue de 2,25% anual. </div></div>", "i": 6574897}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 5 de julio de 2006.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6574898}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-05", "doble_articulado": false, "id_norma": "251056", "numero_fuente": "38507", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-07-07", "vigencias": [{"desde": "2006-07-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-07-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-07-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendien