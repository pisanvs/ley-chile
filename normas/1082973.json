{"html": [{"t": "<div><div class=\"p\">&nbsp;  </div><div class=\"p\">MODIFICA RESOLUCIONES QUE INDICA</div></div>", "i": 9642713}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.739, de 8 de octubre de 2015, de esta Subsecretar&#xED;a, mod&#xED;ficase el numeral 1&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=239814&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.973 de 2005</a> y el numeral 2&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=265468&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.826 de 2007</a>, ambas de esta Subsecretar&#xED;a de Pesca y Acuicultura, que autorizaron a Compa&#xF1;&#xED;a Pesquera Camanchaca S.A., para realizar actividades pesqueras extractivas con la nave &quot;Atacama IV&quot;, en el sentido de actualizar las siguientes caracter&#xED;sticas n&#xE1;uticas:</div><br><div class=\"p\">&nbsp; &nbsp;  Eslora de arqueo (m)&nbsp; 34,17</div><div class=\"p\">&nbsp; &nbsp;  T.R.G. (Nacional)&nbsp; &nbsp;  368,00</div><div class=\"p\">&nbsp; &nbsp;  Manga (m)&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  10,60</div><div class=\"p\">&nbsp; &nbsp;  Puntal (m)&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 4,50</div></div>", "i": 9642714}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de octubre de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9642715}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2739 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2739 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "cate