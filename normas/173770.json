{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6294759}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;298, de fecha 24 de marzo de 1998, se orden&#xF3; y aprob&#xF3; el plano y cuadro de expropiaci&#xF3;n del lote de terreno N&#xBA;9, y Por decreto MOP N&#xBA;2.030, de fecha 29 de mayo de 2000, se autoriza el valor de la consignaci&#xF3;n provisional de la expropiaci&#xF3;n por la v&#xED;a judicial, en la cantidad de $460.500, para la ejecuci&#xF3;n de la obra Camino Ruta L-25, Sector Lisonjera - Yerbas Buenas, Tramo Km. 11.419 a Km. 19.855; el pago de la indemnizaci&#xF3;n se efectuar&#xE1; al contado. La publicaci&#xF3;n se realiza en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xB0; del decreto ley N&#xBA;2.186, de 1978. </div></div>", "i": 6294760}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6294761}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "298", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-298"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-03-24", "doble_articulado": false, "id_norma": "173770", "numero_fuente": "36714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-15", "vigencias": [{"desde": "2000-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vi