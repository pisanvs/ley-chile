{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 63.- Santiago, 7 de Agosto de 1893.- Por cuanto el Congreso Nacional ha aprobado el siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6169964}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese al teniente-coronel don Jos&#xE9; Agust&#xED;n Fraga, para los efectos de su retiro, el abono de tiempo que medi&#xF3; entre su retiro del Ej&#xE9;rcito el 18 de Junio de 1888 y su reincorporaci&#xF3;n &#xE1; &#xE9;l, que fue el 22 de Febrero de 1891.</div><br></div>", "i": 6169965}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, o&#xED;do el Consejo de Estado, he tenido &#xE1; bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese &#xE1; efecto como ley de la Rep&#xFA;blica.- JORGE MONTT.- V.</div><div class=\"p\">D&#xE1;vila Larrain.</div><br></div>", "i": 6169966}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "63", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-63"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-08-07", "doble_articulado": false, "id_norma": "136817", "numero_fuente": "4594", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-08-12", "vigencias": [{"desde": "1893-08-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-08-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-08-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado