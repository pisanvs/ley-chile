{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6271135}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 558, de 28 de febrero de 2000, se expropiaron los lotes de terreno N&#xBA; 22 y 23, superficies 10.245,3 m&#xB2; y 8.069,33 m&#xB2;, roles de aval&#xFA;o 511-16 y 511-97, comuna de Carahue, Obra Camino Costero Tir&#xFA;a-Carahue, sector Puyanhue-Tranapuente y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Santos Segundo Burgos Burgos y Ana Rosa Pinto M&#xE9;ndez, ascendente a las cantidades de $1.341.246, para el lote N&#xBA; 22 y $959.140, para el lote N&#xBA; 23.</div><br></div>", "i": 6271136}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6271137}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "558", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-558"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-28", "doble_articulado": false, "id_norma": "167397", "numero_fuente": "36652", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-02", "vigencias": [{"desde": "2000-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2000-05-02", "fecha_version": "2000-05-02", "fecha_actualizacion_texto": "2000-05-02",