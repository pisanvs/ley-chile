{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8305269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.078, de 31 de julio de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la transferencia de la autorizaci&#xF3;n de pesca y la ampliaci&#xF3;n de plazo para iniciar actividades pesqueras extractivas con la nave &quot;Walvis&quot;, solicitadas por don IGOR VALDIVIA MORI, por cuanto los hechos invocados como fuerza mayor no configuran el beneficio de ampliaci&#xF3;n de plazo establecido en el art&#xED;culo 143 letra b) de la Ley N&#xBA; 18.892 y sus modificaciones.</div><br></div>", "i": 8305270}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de julio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8305271}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1078", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1078"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "PESCA", "AMPLIACION", "IGOR VALDIVIA MORI", "TRANSFERENCIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-31", "doble_articulado": false, "id_norma": "74796", "numero_fuente": "35838", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-08-09", "vigencias": [{"desde": "1997-08-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-08-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-08-09