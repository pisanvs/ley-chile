{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7380792}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.887, de 4 de noviembre de 2008, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3 y 4.- de la resoluci&#xF3;n exenta N&#xBA; 320, de 2008, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO, para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Monitoreo de la pesquer&#xED;a de Jaibas extra&#xED;da por la flota artesanal trampera de Ancud, Regi&#xF3;n de Los Lagos&quot;, en el sentido de ampliar el plazo de autorizaci&#xF3;n de la Pesca de Investigaci&#xF3;n hasta el 30 de enero de 2009, e incorporar a la nave &quot;Karen III&quot;, RPA N&#xBA; 950545. </div></div>", "i": 7380793}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de noviembre de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretaria de Pesca.</div><br></div>", "i": 7380794}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2887 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2887 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-11-04", "doble_articulado": false, "id_norma": "281312", "numero_fuente": "39211", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-11-13", "vigencias": [{"desde": "2008-11-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-11-13", "fin_vigenci