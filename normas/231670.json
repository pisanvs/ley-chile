{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.538 EXENTA, DE 2004 </div></div>", "i": 6502069}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.538, de 19 de octubre de 2004, la Subsecretar&#xED;a de Transportes, modific&#xF3; numeral 4&#xBA; de resoluciones exentas Nos 1.195 y 1.199, de 2004, de esta Subsecretar&#xED;a, reemplazando expresi&#xF3;n &quot;con cargo a la referida instituci&#xF3;n policial&quot;, por la siguiente:</div><div class=\"p\">&quot;con cargo al presupuesto vigente de la Subsecretar&#xED;a de Transportes&quot;.</div><br></div>", "i": 6502070}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Guillermo D&#xED;az Silva, Subsecretario de Transportes.</div><br></div>", "i": 6502071}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1538 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1538 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.538 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-19", "doble_articulado": false, "id_norma": "231670", "numero_fuente": "37994", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-10-25", "vigencias": [{"desde": "2004-10-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-10-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-10-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modif