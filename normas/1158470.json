{"html": [{"t": "<div><div class=\"p\">REBAJA DE DERECHOS AL AZ&#xDA;CAR Y YERBA - MATE.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Febrero 5 de 1828.</div></div>", "i": 10235657}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  19 El Vice-Presidente de la Rep&#xFA;blica de acuerdo con la Comision nacional decreta lo siguiente:</div><div class=\"p\">&nbsp; &nbsp;  1.&#xB0; Los derechos espec&#xED;ficos que hoi pagan los az&#xFA;cares y yerba-mate ser&#xE1;n rebajados al 27 p %. se&#xF1;alados jeneralmente a la introduccion de los efectos extranjeros.</div><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; Esta disposicion empezar&#xE1; a tener efecto desde el 1.&#xB0; de julio del presente a&#xF1;o.</div><div class=\"p\">&nbsp; &nbsp;  3.&#xB0; T&#xF3;mese razon, e impr&#xED;mase para su circulacion.</div></div>", "i": 10235658}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  PINTO</div><div class=\"p\">&nbsp; &nbsp;  Blanco.</div></div>", "i": 10235659}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "REBAJA DE DERECHOS AL AZÚCAR Y YERBA - MATE", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1828-02-05", "doble_articulado": false, "id_norma": "1158470", "numero_fuente": "1828", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1828-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1828-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1828-07-01", "fin_vigencia": "", "tip