{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10068800}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decretos Exentos MOP N&#xB0;s. 1137, 1138, 1139, 1140, 1141, 1142, 1143, 1144, 1145, 1146, 1147, 1148, 1149, 1150, 1151 y 1152, todos de 14 de octubre de 2019, se desisti&#xF3; de la expropiaci&#xF3;n de los lotes N&#xB0; s. 6, 19, 17, 10, 11, 4, 15, 30, 27, 26, 20, 24, 7, 29, 16 y 25, los cuales fueron expropiados mediante Decretos MOP (Exento) N&#xB0; s. 1691, 1845, 1847, 1686, 1694, <a href=\"https://www.leychile.cl/Navegar?idNorma=1055740&amp;idParte=&amp;idVersion=\">1695</a>, 1911, 1851, 1854, 1848, 1850, 1689, 1852, 1917 y 1858 de octubre de 2013 y N&#xB0; 1910 de noviembre de 2013, correspondiente a la obra &quot;Construcci&#xF3;n Entubamiento Canal Azapa&quot;, Comuna de Arica, Regi&#xF3;n de Arica y Parinacota, los cuales experimentaron un cambio de trazado.</div><br></div>", "i": 10068801}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1142 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1142 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1680596", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-10-14", "doble_articulado": false, "id_norma": "1138665", "numero_fuente": "42503", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-11-15", "vigencias": [{"desde": "2019-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-11-15", "fin_vigenci