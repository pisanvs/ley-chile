{"html": [{"t": "<div><div class=\"p\">&nbsp;  </div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA;6.506 EXENTA, DE 02.10.2015</div></div>", "i": 9642576}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta se han modificado las resoluciones exentas Nos <a href=\"https://www.leychile.cl/Navegar?idNorma=140274&amp;idParte=0&amp;idVersion=\">4.086</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=176479&amp;idParte=0&amp;idVersion=\">12.879</a>, ambas de 1999, del Ministerio de Educaci&#xF3;n, y sus modificaciones, que aprobaron planes y programas especiales de estudio de 1&#xBA; y 2&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Instituto Hebreo &quot;Dr. Chaim Weizmann&quot;, comuna de Lo Barnechea, provincia de Santiago, Regi&#xF3;n Metropolitana.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Sectores de Idioma Extranjero: Hebreo e Historia y Cultura Jud&#xED;a de 1&#xBA; y 2&#xBA; a&#xF1;o de Educaci&#xF3;n Media.</div><br></div>", "i": 9642577}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 2 de octubre de 2015.- Gonzalo Mu&#xF1;oz Stuardo, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 9642578}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6506 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6506 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº6.506 EXENTA, DE 02.10.2015", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; IdDO 956236"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-10-02", "doble_articulado": false, "i