{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6274025}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.031 de 21 de Diciembre de 1987 de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se autoriza a don Ladislao Alberto Contreras Castillo de la Empresa de Buses &quot;Biotal&quot; para efectuar todo tipo de servicio de transporte de pasajeros, por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva. </div></div>", "i": 6274026}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Hern&#xE1;n Poblete Rodr&#xED;guez, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n del Maule.</div><br></div>", "i": 6274027}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1031 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1031 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-12-21", "doble_articulado": false, "id_norma": "168230", "numero_fuente": "32955", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-28", "vigencias": [{"desde": "1987-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-28", "fin_vigencia": "", "tipo_version": "