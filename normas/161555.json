{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7265550}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 412 de 1 de marzo de 2000 de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA IQUIQUE-GUANAYE S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluciones N&#xBA; 2 de 1980, N&#xBA; 53 de 1993, N&#xBA; 166 de 1994,&nbsp; N&#xBA; 245, N&#xBA; 544 y N&#xBA; 1.443, todas de esta Subsecretar&#xED;a, donde podr&#xE1; incorporar a la planta ubicada en Manuel Rodr&#xED;guez N&#xBA; 302, Talcahuano, VIII Regi&#xF3;n, en la l&#xED;nea de elaboraci&#xF3;n que se indica, los siguientes recursos hidrobiol&#xF3;gicos: Conservas: Agujilla, Cabinza, Cochinilla, Cojinoba del norte, Cojinoba del sur, Dorado, Palometa, Roncacho y Sierra.</div><br></div>", "i": 7265551}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de marzo de 2000.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 7265552}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "412", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-412"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA IQUIQUE GUANAYE S.A.", "ACTIVIDADES PESQUERAS DE TRANSFORMACION", "RECURSOS HIDROBIOLOGICOS", "TALCAHUANO", "OCTAVA REGION", "AUTORIZA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-03-01", "fecha_derogacion": "2001-05-05", "doble_articulado": false, "id_norma": "161555", "numero_fuente": "36618", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-