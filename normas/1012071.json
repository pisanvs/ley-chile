{"html": [{"t": "<div><br><div class=\"p\">DECLARA AMPLIADO PLAZO PARA INICIAR ACTIVIDADES DE ACUICULTURA</div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n 2.482, de fecha 28 de diciembre de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div></div>", "i": 8903102}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Decl&#xE1;rase ampliado, entre el 21 de abril de 2006 y el 21 de abril de 2010, ambas fechas inclusive, el plazo para iniciar actividades de acuicultura autorizadas mediante <a href=\"https://www.leychile.cl/Navegar?idNorma=234883&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 1.651, de fecha 20 de octubre de 2004, del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina</a>.</div></div>", "i": 8903103}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 1 de marzo de 2010.- Por la Sra. Subsecretaria, Felipe Garc&#xED;a-Huidobro Correa, Subjefe Subsecretar&#xED;a de Marina.</div></div>", "i": 8903104}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2482", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2482"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "DECLARA AMPLIADO PLAZO PARA INICIAR ACTIVIDADES DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-12-28", "doble_articulado": false, "id_norma": "1012071", "numero_fuente": "39622", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-03-27", "vigencias": [{"desde": "2010-03-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "201