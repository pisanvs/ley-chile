{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO NUMERO 282 EXENTO, DE 1996 </div></div>", "i": 5943453}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 282 de 20 de mayo de 1996, se ha autorizado al Colegio Ingl&#xE9;s de Quintero N&#xB0; 271, para impartir la asignatura de Idioma Extranjero - Ingl&#xE9;s en 7&#xB0; y 8&#xB0; a&#xF1;o de ense&#xF1;anza b&#xE1;sica con una carga horaria de 4 clases semanales y suprimir la asignatura de Idioma Extranjero 2 - Franc&#xE9;s. </div></div>", "i": 5943454}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 29 de mayo de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943455}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "282", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-282"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO NUMERO 282 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO INGLES QUINTERO", "PLANES ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-20", "doble_articulado": false, "id_norma": "20884", "numero_fuente": "35483", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-06-04", "vigencias": [{"desde": "1996-06-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-06-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-06-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1996-06-04", "fecha_actualizacion_texto": "1996-06-04", "t