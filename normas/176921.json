{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7277848}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.299, de 19 de octubre de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.249 de 1996, de esta Subsecretar&#xED;a, que autoriz&#xF3; a&nbsp; PESQUERA BIO BIO S.A. para operar la nave &apos;&apos;Gardar&apos;&apos;, s&#xF3;lo en lo relativo a la operaci&#xF3;n respecto de los recursos Anchoveta y Sardina espa&#xF1;ola, en el litoral comprendido entre la III y IV Regiones, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7277849}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de octubre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7277850}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2299", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2299"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-19", "doble_articulado": false, "id_norma": "176921", "numero_fuente": "36796", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-25", "vigencias": [{"desde": "2000-10-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-10-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-10-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc