{"html": [{"t": "<div><div class=\"p\">&nbsp;  Ley n&#xFA;mero 4,384</div><br><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5959438}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Der&#xF3;ganse los art&#xED;culos 1.o y 2.o de la ley n&#xFA;mero 4,246 de 1.o de Febrero de 1928.</div><div class=\"p\">&nbsp; &nbsp;  Esta ley comenzar&#xE1; a regir desde la fecha de su publicaci&#xF3;n en el Diario Oficial&quot;.</div><br></div>", "i": 9338157}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, ocho de Agosto de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- Pablo Ram&#xED;rez. </div></div>", "i": 5959439}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4384", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4384"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ADMINISTRACION PUBLICA", "PERSONAL", "ASCENSO", "SUELDO", "INGRESO", "REINCORPORACION", "REGLAMENTACION", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-08-08", "doble_articulado": false, "id_norma": "24701", "numero_fuente": "15147", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-08-11", "vigencias": [{"desde": "1928-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-08-11", "fin_vigencia": ""}, "vigencia