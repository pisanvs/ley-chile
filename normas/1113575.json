{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO</div></div>", "i": 9875085}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. (EXENTO) N&#xB0; 1775 de 22 de diciembre de 2017, se desisti&#xF3; de la expropiaci&#xF3;n del lote N&#xB0;112, ordenada por el <a href=\"https://www.leychile.cl/Navegar?idNorma=1096160&amp;idParte=&amp;idVersion=\">Decreto MOP (Exento) N&#xB0;860 de 3 de octubre de 2016</a>, para la obra. &quot;Reposici&#xF3;n Pav. Ruta M-50&quot;, Sector &quot;Chanco - Constituci&#xF3;n&quot;, Tramo III Pellines - Cruce Vi&#xF1;ales, kil&#xF3;metro 78,36200 a km. 100,90000&quot;, debido a que el lote fue eliminado mediante Resuelvo S.R.M. (Exenta) VII Regi&#xF3;n N&#xB0;1153 de 20 de junio de 2017. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xB0; y 32&#xB0; del Decreto Ley N&#xB0; 2186, de 1978. </div><br></div>", "i": 9875086, "v": ["MODIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1775 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1775 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1332404", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-12-22", "doble_articulado": false, "id_norma": "1113575", "numero_fuente": "41957", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-01-15", "vigencias": [{"desde": "2018-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2018-01-15", "fin_vigencia": ""}, "vi