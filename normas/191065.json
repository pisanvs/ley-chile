{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 12.350 EXENTA, DE 2001 </div></div>", "i": 6355104}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 12.350, de 22 de octubre de 2001, se ha aprobado, a contar del a&#xF1;o escolar 2002, al Liceo Carmela Carvajal de Prat, comuna de Providencia, de Santiago, el siguiente plan de estudio para 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programa de estudio para el Subsector de Filosof&#xED;a y Psicolog&#xED;a del Plan de la Formaci&#xF3;n Diferenciada.</div><br><br></div>", "i": 6355105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de octubre de 2001.- Juan Ruz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6355106}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "12350 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-12350 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 12.350 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-10-22", "doble_articulado": false, "id_norma": "191065", "numero_fuente": "37099", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-10-31", "vigencias": [{"desde": "2001-10-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-10-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-10-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "C