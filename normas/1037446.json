{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9238236}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 167, de 23 de enero de 2012, de esta Subsecretar&#xED;a, ampl&#xED;ese por doce meses, a contar del 7 de enero de 2012, el plazo otorgado por el numeral 5.- inciso 1&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1021873&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.858 de 2010</a>, de esta Subsecretar&#xED;a, que autoriz&#xF3; a LEYLA IBET LAMA ORTIZ para ampliar actividades pesqueras extractivas con la nave &quot;Luc&#xED;a&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre la XV a X Regiones, Islas de Pascua, Salas y G&#xF3;mez, Desventuradas y Archipi&#xE9;lago de Juan Fern&#xE1;ndez, por fuera del &#xE1;rea de reserva artesanal, con palangre y enmalle, sobre Albacora o Pez espada y su fauna acompa&#xF1;ante, en virtud de haberse acreditado una circunstancia de fuerza mayor.</div><br></div>", "i": 9238237}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de enero de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9238238}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "167 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-167 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2012-01-23", "fecha_derogacion": "2017-02-22", "doble_articulado": false, "id_norma": "1037446", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2012-02-21", "vigen