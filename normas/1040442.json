{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.277 EXENTA, DE 11 DE MAYO DE 2012</div></div>", "i": 9259730}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=249886&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 4.186, de 2006, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Liceo Experimental &quot;Manuel de Salas&quot;, comuna de &#xD1;u&#xF1;oa, de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, correspondientes al Plan de Formaci&#xF3;n General, de los Sectores que se indican en la presente resoluci&#xF3;n exenta.</div></div>", "i": 9259731}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de mayo de 2012.- Ver&#xF3;nica Simpson Cifuentes, Jefa (S) Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 9259732}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3277 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-3277 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.277 EXENTA, DE 11 DE MAYO DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-11", "doble_articulado": false, "id_norma": "1040442", "numero_fuente": "40272", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-05-28", "vigencias": [{"desde": "2012-05-28", "hasta": "", "tipo_versi