{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9253943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (exento) N&#xBA;528 de fecha 22 de marzo de 2012, y de conformidad a lo dispuesto en el Art. 105 del DFL. MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;21, superficie 5.045 m2, rol de aval&#xFA;o 1216-40, para la obra &quot;REPOSICION PUENTE SAN ANTONIO EN RUTA 5 CHILOE&quot;, Comuna de Ancud, Provincia de Chilo&#xE9;, Regi&#xF3;n de Los Lagos. La Comisi&#xF3;n de Peritos integrada por Norman Estanislao Calder&#xF3;n Pontiggia, Sonia Catalina Gallegos Blanch y Patricio Fernando Casagrande Ulloa, fij&#xF3; valor de tasaci&#xF3;n con fecha 02 de agosto de 2010, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario JOS&#xC9; ARIEL MEDINA SOTO, en la cantidad de $59.134.527, suma que se pagar&#xE1; al contado. </div></div>", "i": 9253944}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9253945}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "528 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-528 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-03-22", "doble_articulado": false, "id_norma": "1039578", "numero_fuente": "40251", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-05-02", "vigencias": [{"desde": "2012-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-05-02", "fin_vigencia": ""}, "vigencias_vers