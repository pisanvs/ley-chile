{"html": [{"t": "<div><div class=\"p\">DESIGNA SUJETOS PASIVOS QUE INDICA</div></div>", "i": 10119843}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 50 del 4 de mayo de 2020, que:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Designa Sujetos Pasivos, conforme lo dispuesto en el <a href=\"https://www.leychile.cl/Navegar?idNorma=1060115&amp;idParte=9414085&amp;idVersion=\">art&#xED;culo 3&#xBA;</a> inciso segundo de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1060115&amp;idParte=&amp;idVersion=\">ley N&#xBA; 20.730</a> y el <a href=\"https://www.leychile.cl/Navegar?idNorma=1065874&amp;idParte=9500523&amp;idVersion=\">art&#xED;culo 5&#xBA;</a> del <a href=\"https://www.leychile.cl/Navegar?idNorma=1065874&amp;idParte=&amp;idVersion=\">decreto supremo N&#xBA; 71, de 2014</a>, del Ministerio Secretar&#xED;a General de la Presidencia, en raz&#xF3;n del cargo y responsabilidad que en cada caso se indica.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl).</div><div class=\"p\"> </div><br></div>", "i": 10119844}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "50 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-50 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESIGNA SUJETOS PASIVOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1760168; EXTRACTO; NORMA SIN PROMULGA