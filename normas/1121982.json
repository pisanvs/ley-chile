{"html": [{"t": "<div><div class=\"p\">SISTEMA DE MARCACI&#xD3;N TABACO ELABORADO</div></div>", "i": 9941972}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 61, de 10 de agosto de 2018, que establece:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Determina contribuyentes obligados a aplicar a los bienes o productos, sus envases, paquetes o envoltorios, el sistema de marcaci&#xF3;n establecido en el <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=9510277&amp;idVersion=\">art&#xED;culo 60 quinquies</a> del <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=0&amp;idVersion=\">C&#xF3;digo Tributario</a> y 13 bis del <a href=\"https://www.leychile.cl/Navegar?idNorma=6372&amp;idParte=0&amp;idVersion=\">DL N&#xB0; 828, de 1974</a>, e indica empresa con la cual los contribuyentes obligados deber&#xE1;n contratar, con el objeto de implementar el Sistema de Trazabilidad Fiscal.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de agosto de 2018.</div></div>", "i": 9941973}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "61 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-61 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "SISTEMA DE MARCACIÓN TABACO ELABORADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1446654", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-08-10", "doble_articulado": false, "id_norma": "1121982", "numero_fuente": "42134", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-08-17", "vigencias": [{"desde": "2018-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2018-08-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2018-08-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresado_por": "98", "fecha_ingreso": "2018-08-17", "fecha_version": "2018-08-17", "fecha_actualizacion_texto": "2018-08-17", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9941972}, {"n": "Artículo", "i": 9941973, "t": 6}]}