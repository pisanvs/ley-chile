{"html": [{"t": "<div><div class=\"p\">DELEGA FACULTADES QUE INDICA</div><br><div class=\"p\">N&#xFA;m. 39.- Santiago, 12 de Mayo de 1992.- Visto: el art&#xED;culo 43 de la ley No.18.575 y la ley No.18.059,</div><br><div class=\"p\">Resuelvo:</div><br></div>", "i": 6076072}, {"t": "<div><div class=\"p\">Del&#xE9;gase en los Secretarios Regionales Ministeriales del Ministerio de Transportes y Telecomunicaciones, las facultades que otorga a esta Secretar&#xED;a de Estado la letra b) del art&#xED;culo 1&#xBA; y el art&#xED;culo 2&#xBA; de la ley No.18.059 antes referida.</div><br></div>", "i": 6076073}, {"t": "<div><div class=\"p\">An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- V. Germ&#xE1;n Correa D&#xED;az, Ministro de Transportes y Telecomunicaciones.</div><br><div class=\"p\">Lo que transcribo para su conocimiento, saluda a Ud.- Patricia Mu&#xF1;oz Villela, Jefe Administrativo. </div></div>", "i": 6076074}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "39", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-39"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "DELEGA FACULTADES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-05-12", "doble_articulado": false, "id_norma": "87387", "numero_fuente": "34295", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-06-19", "vigencias": [{"desde": "1992-06-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-06-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-06-19", "fin_vigencia