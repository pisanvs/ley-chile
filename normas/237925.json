{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.260 EXENTA, DE 2005 </div></div>", "i": 6526035}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.260, de 6 de abril de 2005, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se dispuso el inicio de la puesta en marcha definitiva de la concesi&#xF3;n dos, adjudicada a &quot;S.G.S Chile Limitada&quot;, para operar en la comuna de San Bernardo una planta revisora clase A2, con tres (3) l&#xED;neas de revisi&#xF3;n livianas y tres (3) l&#xED;neas de revisi&#xF3;n pesadas, a contar del 6 de abril de 2005. </div></div>", "i": 6526036}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Silvio Albarr&#xE1;n Alb&#xE1;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6526037}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1260 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1260 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.260 EXENTA, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-04-06", "doble_articulado": false, "id_norma": "237925", "numero_fuente": "38160", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-05-13", "vigencias": [{"desde": "2005-05-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-05-13", "fin_vi