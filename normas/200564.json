{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO</div><br><br></div>", "i": 6389285}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA; 20, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n de 3 de marzo del a&#xF1;o 1995, se aprob&#xF3; la disoluci&#xF3;n de la Cooperativa de Vivienda y Servicios Habitacionales &quot;Villa Monterrey&quot; Limitada, que consta en la escritura p&#xFA;blica suscrita con fecha 24 de noviembre de 1994 ante el Notario P&#xFA;blico de Quilpu&#xE9;, don Jorge Acu&#xF1;a P&#xE9;rez. </div></div>", "i": 6389286}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Sr. Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6389287}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "20", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-20"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-03-03", "doble_articulado": false, "id_norma": "200564", "numero_fuente": "37309", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-16", "vigencias": [{"desde": "2002-07-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-07-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "