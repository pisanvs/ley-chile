{"html": [{"t": "<div><div class=\"p\">EXTIENDE LA SUSPENSI&#xD3;N DISPUESTA POR RESOLUCI&#xD3;N N&#xB0; 2.299, DE 2021, DNA</div></div>", "i": 10285316}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 2.670, de 10 de noviembre de 2021, del Director Nacional de Aduanas, se extiende la suspensi&#xF3;n de la vigencia de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1166120&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xB0; 2.299, de 2021</a>, hasta el 09.12.2021.</div><div class=\"p\">&nbsp; &nbsp;  Esta resoluci&#xF3;n entrar&#xE1; en vigencia a partir de su publicaci&#xF3;n en el Diario Oficial.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div></div>", "i": 10285317}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de noviembre de 2021.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div></div>", "i": 10285318}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2670 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2670 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTIENDE LA SUSPENSIÓN DISPUESTA POR RESOLUCIÓN N° 2.299, DE 2021, DNA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2041607", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-11-10", "doble_articulado": false, "id_norma": "1168405", "numero_fuente": "43105", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-11-17", "v