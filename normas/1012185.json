{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8904156}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.130, de 25 de marzo de 2010, de esta Subsecretar&#xED;a, autor&#xED;zase a LUNA Y GALAZ LIMITADA para capturar, en el &#xE1;rea mar&#xED;tima de la X Regi&#xF3;n de Los Lagos, en el plazo de 1 a&#xF1;o contado desde la fecha de la presente resoluci&#xF3;n, la cantidad total de 120 ejemplares de la especie Lobo marino com&#xFA;n, en la forma y bajo las condiciones se&#xF1;aladas en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  El solicitante designa como persona responsable de esta autorizaci&#xF3;n a don Claudio Galaz Guerra.</div></div>", "i": 8904157}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de marzo de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 8904158}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1130", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1130"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-03-25", "doble_articulado": false, "id_norma": "1012185", "numero_fuente": "39626", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-04-01", "vigencias": [{"desde": "2010-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "