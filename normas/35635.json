{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294352}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 816, de 6 de mayo de 1996, de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por GASTON BERNARDO</div><div class=\"p\">PE&#xD1;A NU&#xD1;EZ, para un sector ubicado en la Ribera Norte</div><div class=\"p\">del R&#xED;o Maull&#xED;n, comuna de Maull&#xED;n, provincia de</div><div class=\"p\">Llanquihue, X Regi&#xF3;n, en virtud de lo dispuesto en los</div><div class=\"p\">art&#xED;culos 76&#xB0;, 77&#xB0;, 78&#xB0; y 5&#xB0;, transitorio, inciso 6&#xB0;, de la Ley General de Pesca y Acuicultura y el art&#xED;culo 14&#xB0; del D.S. N&#xB0; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; D&#xE9;jase sin efecto las Resoluciones N&#xB0; 320, de 1990 y N&#xB0; 28, de 1991, ambas de esta Subsecretar&#xED;a, en virtud de lo se&#xF1;alado precedentemente.</div><br></div>", "i": 8294353}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 6 de mayo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294354}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "816", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-816"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "GASTON BERNARDO", "PENA NUNEZ"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_ta