{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6509476}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA; 1.642, de 25 de noviembre</div><div class=\"p\">de 2004, y en base a la facultad otorgada por el</div><div class=\"p\">art&#xED;culo 105 del DFL MOP N&#xBA; 850 de 1997, que fij&#xF3; el texto actualizado de la ley N&#xBA;&nbsp; 15.840, se expropi&#xF3; para el Fisco, el lote de terreno N&#xBA; 2, para la obra Camino CH-203, sector Bifurcaci&#xF3;n Co&#xF1;aripe - Choshuenco, Tramo Km. 56,68000 a Km. 93,28612, que figura a nombre de Mart&#xED;nez Mart&#xED;nez Olga, rol de aval&#xFA;o 187-35, comuna de Panguipulli, X Regi&#xF3;n, superficie 821 m&#xB2;. La Comisi&#xF3;n de Peritos, fij&#xF3; con fecha 5 de diciembre de 2000, en la cantidad de $985.200. La indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.</div><br></div>", "i": 6509477}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6509478}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1642 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1642 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-25", "doble_articulado": false, "id_norma": "233749", "numero_fuente": "38036", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-15", "vigencias": [{"desde": "2004-12-15", "hasta": "", "tipo_version": "