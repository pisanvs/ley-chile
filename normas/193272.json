{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6364271}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.816, de 31 de octubre del 2001, se expropi&#xF3; el lote de terreno N&#xBA;32 superficie 25.633 m2., rol de aval&#xFA;o 690-46, comuna de El Tabo, para la obra Red Vial Litoral Central Sector 3: Eje Costero Interior. Subtramo: Las Pataguas-Quillaicillo Km.</div><div class=\"p\">5.936,10 al Km. 8.408,204 Quinta Regi&#xF3;n, se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietaria Gloria Eliana Guzm&#xE1;n Riquelme, ascendente a la cantidad de $18.450.669.</div><br></div>", "i": 6364272}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6364273}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1816", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1816"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-10-31", "doble_articulado": false, "id_norma": "193272", "numero_fuente": "37149", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-02", "vigencias": [{"desde": "2002-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2002-01-04", "fecha_version": "2002-01-02", "fecha_actualizacion_texto": "2002-01-02", "tipo_tratad