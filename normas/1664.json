{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5844806}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Certifico: Que por Resoluci&#xF3;n N&#xB0; 78 de 27 de Junio de 1994, se aprob&#xF3; reforma de estatutos de la socieadad an&#xF3;nima &quot;UAP Seguros de Vida/Chile/S.A.&quot;, que consta de la escritura p&#xFA;blica de 3 de Mayo de 1994, otorgada en la Notar&#xED;a de Santiago de don Ra&#xFA;l Undurraga Laso.</div><div class=\"p\">&nbsp; &nbsp; La reforma consiste en aumentar el capital social de $ 2.256.834.554.- dividido en 274.245 acciones sin valor nominal, a la suma de $ 6.541.535.806.- dividido en 1.111.189 acciones sin valor nominal, dentro del plazo de 3 a&#xF1;os contado desde el 30 de marzo de 1994. </div></div>", "i": 5844807}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 27 de Junio de 1994.- Rodrigo O. Costa Aranda, Secretario General.</div><br></div>", "i": 5844808}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "78", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-78"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-06-27", "doble_articulado": false, "id_norma": "1664", "numero_fuente": "34908", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-07-07", "vigencias": [{"desde": "1994-07-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-07-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-07-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1