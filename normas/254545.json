{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7333390}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.860, de 18 de octubre de 2006, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de las resoluciones N&#xBA; 766, de 1993, y N&#xBA; 294, de 2000, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autorizaron a Pesquera Friosur S.A., hoy FRIOSUR VII S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Friosur VII&quot;, en el &#xE1;rea mar&#xED;tima correspondiente a la IX y X Regiones, con red de arrastre, sobre el recurso Reineta, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7333391}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de octubre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7333392}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2860 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2860 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-10-18", "doble_articulado": false, "id_norma": "254545", "numero_fuente": "38596", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-10-24", "vigencias": [{"desde": "2006-10-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-10-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-10-24", "fin_vigencia": "",