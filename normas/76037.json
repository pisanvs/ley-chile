{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6046460}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 603, de 30 de junio de 1997, se expropiaron los lotes de terreno N&#xBA;s. 25, 32 y 38, superficie 336,00, 235,25 y 1.059,22 M2.</div><div class=\"p\">respectivamente, roles de aval&#xFA;o 402-28, 402-36 y 402-42, comuna de Vicu&#xF1;a, para la obra Proyecto Embalse Puclaro, Sector Variante a Ruta 41-CH y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Hern&#xE1;n Gonz&#xE1;lez Roco y otros y Julio Vilches Roco, ascendente a las cantidades de $6.113.023.- y $11.746.892.-</div><br></div>", "i": 6046461}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6046462}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "603", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-603"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "VICU A", "CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-06-30", "doble_articulado": false, "id_norma": "76037", "numero_fuente": "35879", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-10-01", "vigencias": [{"desde": "1997-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-10-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CAV", "fecha_ingreso": "1997-10-10", "fecha_v