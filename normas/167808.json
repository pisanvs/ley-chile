{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7268988}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 283, de 8 de Marzo de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por 1 a&#xF1;o a contar del 21 de Septiembre de 1990, el plazo concedido a SOCIEDAD PESQUERA LANDES S.A., R.U.T. No. 92.387.000-8, domiciliada en la ciudad de Santiago, en el numeral 5&#xB0; de la resoluci&#xF3;n No. 1413, de 1989, de esta Subsecretar&#xED;a de Pesca, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case la resoluci&#xF3;n No. 1.413 antes citada, la menci&#xF3;n del contrato de construcci&#xF3;n, se&#xF1;alando que se refiere al contrato No. 143, de 3 de Septiembre de 1990, suscrito por la interesada con los astilleros Marco Chilena Ltda. respecto de la nave autorizada.</div><br></div>", "i": 7268989}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de Marzo de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 7268990}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "283", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-283"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-03-08", "fecha_derogacion": "1993-01-25", "doble_articulado": false, "id_norma": "167808", "numero_fuente": "33930", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-03-28", "