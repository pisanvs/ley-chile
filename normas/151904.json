{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 248, DE 1986 </div></div>", "i": 8357060}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 801 de 28 de Julio de 1987 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n No. 248, de 1986, de esta Subsecretar&#xED;a, autoriz&#xF3; a Pesquera Montemar S.A., para operar dos naves en construcci&#xF3;n, en el sentido de se&#xF1;alar que la eslora de una de las embarcaciones que se autorizan por la citada Resoluci&#xF3;n es de 16,50 mt. </div></div>", "i": 8357061}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de Julio de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8357062}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "801", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-801"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 248, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-28", "doble_articulado": false, "id_norma": "151904", "numero_fuente": "32842", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-10", "vigencias": [{"desde": "1987-08-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-08-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-08-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAS", "fecha_ingreso": "2000-01