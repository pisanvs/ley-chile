{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aprueba la Convenci&#xF3;n Postal Panamericana, subscrita en Buenos Aires el a&#xF1;o 1921</div><br><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 8801566}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Apru&#xE9;base la Convenci&#xF3;n Postal Panamericana subscrita en Buenos Aires, el a&#xF1;o 1921. </div><br></div>", "i": 8801567}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a diecis&#xE9;is de Julio de mil novecientos veintisiete.- Carlos Ib&#xE1;&#xF1;ez C.- Conrado R&#xED;os Gallardo. </div></div>", "i": 8801568}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4137", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4137"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES"], "titulo_norma": "APRUEBA LA CONVENCIÓN POSTAL PANAMERICANA, SUBSCRITA EN BUENOS AIRES EL AÑO 1921", "fuente": "", "resumenes": [], "materias": ["Convención Postal Panamericana"], "terminos_libres": ["ACUERDOS INTERNACIONALES", "CONVENCION POSTAL PANAMERICANA", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1927-07-16", "doble_articulado": false, "id_norma": "24502", "numero_fuente": "14832", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1927-07-28", "vigencias": [{"desde": "1927-07-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1927-07-28", "fin_vigen