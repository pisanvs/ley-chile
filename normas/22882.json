{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede 46396 pesos para la adquisicion de calzado para el Ej&#xE9;rcito.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. I729.- Santiago, a 2 de Febrero de 1905.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente:</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5951089}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Se autoriza al Presidente de la Rep&#xFA;blica para invertir la suma de cuarenta i seis mil trescientos noventa i seis pesos ($ 46396) en atender a la adquisicion de calzado para el servicio del Ej&#xE9;rcito. </div></div>", "i": 5951090}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-</div><div class=\"p\">&nbsp; &nbsp; JERMAN RIESCO.- A. Bascu&#xF1;an S. M.</div><br></div>", "i": 5951091}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1729", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1729"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "CONCEDE 46396 PESOS PARA LA EDQUISICION DE CALZADO PARA EL EJERCITO.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EJERCITO", "CALZADO", "ADQUISICION", "FONDOS", "INVERSION", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-02-02", "doble_articulado": false, "id_norma": "22882", "numero_fuente": "8127", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-02-03", "vigencias": [{"desde": "1905-02-03", "hasta": "", "tipo_versi