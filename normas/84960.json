{"html": [{"t": "<div><div class=\"p\">DEROGA PARCIALMENTE RESOLUCION QUE INDICA </div></div>", "i": 8316804}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 142, de 29 de Enero de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deroga parcialmente el numeral 1&#xB0; de la Resoluci&#xF3;n No. 500, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don Luis Humberto Herrera Luna, R.U.T. No.</div><div class=\"p\">3.800.300-3, domiciliado en Coquimbo, calle Manuel Rodr&#xED;guez No. 1802, para ampliar actividades pesqueras, eliminando la porci&#xF3;n de fondo de mar, para el cultivo del recurso hidrobiol&#xF3;gico alga gracilaria, por renuncia de su titular. </div></div>", "i": 8316805}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 29 de Enero de 1990.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8316806}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "142", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-142"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "DEROGA PARCIALMENTE RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-29", "doble_articulado": false, "id_norma": "84960", "numero_fuente": "33602", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-21", "vigencias": [{"desde": "1990-02-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-21", "fin_vigen