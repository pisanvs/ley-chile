{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 407&nbsp; EXENTO, DE 2003 </div></div>", "i": 7301143}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 407, de fecha 4 de junio de 2003, del Ministerio de Educaci&#xF3;n, se aprueban las modificaciones introducidas al plan y programas de estudios del Centro de Formaci&#xF3;n T&#xE9;cnica Alexander von Humboldt, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar del a&#xF1;o 2003, en la sede central de San Antonio:</div><br><br><div class=\"p\">Carrera: T&#xE9;cnico en construcci&#xF3;n</div><div class=\"p\">T&#xED;tulo : T&#xE9;cnico de nivel superior en construcci&#xF3;n (decreto exento N&#xBA; 249 del 01.10.90) </div></div>", "i": 7301144}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de junio de 2003.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 7301145}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "407 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-407 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 407 EXENTO, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-04", "doble_articulado": false, "id_norma": "211920", "numero_fuente": "37598", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-02", "vigencias": [{"desde": "2003-07-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-07-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-07