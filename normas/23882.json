{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,304, que concede derecho a jubilar a don Jos&#xE9; Mar&#xED;a Ladron de Guevara.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,304.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 5955523}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al profesor del Liceo de Valparaiso, don Jos&#xE9; Mar&#xED;a Ladr&#xF3;n de Guevara, el derecho de jubilar con la pension anual de ocho mil cuatrocientos pesos ($ 8,400).</div><br></div>", "i": 5955524}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado he tenido a bien aprobarlo i sancionarlo; por tanto prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veinticinco de Setiembre de mil novecientos diecisiete.- JUAN LUIS SANFUENTES.- Anjel Guarello.</div><br></div>", "i": 5955525}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3304", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3304"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "LEI NUM. 3,304, QUE CONCEDE DERECHO A JUBILAR A DON JOSE MARIA LADRON DE GUEVARA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JOSE MARIA LADRON DE GUEVARA", "JUBILACION POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1917-09-25", "doble_articulado": false, "id_norma": "23882", "numero_fuente": "11881", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1917-09-27", "vigencias": [{"desde": "1917-09-27", "hasta": "", "tip