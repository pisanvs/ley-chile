{"html": [{"t": "<div><div class=\"p\">RECTIFICA RESOLUCION EXENTA No. 9, DE 1989</div><br><div class=\"p\">N&#xFA;m. 27 exenta.- Talca, 23 de Junio de 1989.- Visto: El Decreto Supremo No. 83. de 1988 y sus modificaciones posteriores, todos del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes: y Teniendo presente: - Visita efectuada a terreno el d&#xED;a 29 de Marzo de 1989,</div><br><div class=\"p\">Resuelvo:</div><br></div>", "i": 7410802}, {"t": "<div><div class=\"p\">Rectif&#xED;case la resoluci&#xF3;n exenta No. 9 de 1&#xBA; de marzo de 1989, publicada en el Diario Oficial el 13 de Abril de 1989, en la categor&#xED;a v&#xED;a Colectora Distribuidora corresponde calle Pe&#xF1;a entre Guaiquillo y San Mart&#xED;n.</div><br></div>", "i": 7410803}, {"t": "<div><div class=\"p\">An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- J. Hern&#xE1;n Poblete Rodr&#xED;guez, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n del Maule.</div><br></div>", "i": 7410804}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "27 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-27 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "RECTIFICA RESOLUCION EXENTA No. 9, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-06-23", "doble_articulado": false, "id_norma": "94321", "numero_fuente": "33421", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-07-13", "vigencias": [{"desde": "1989-07-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia":