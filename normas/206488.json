{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6409361}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 3.008, de 27 de diciembre de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA ISLADAMAS S.A. para realizar actividades extractivas en aguas internacionales con la nave &quot;Lonquimay&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 1840</div><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CB-2566</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  22,00 m</div><div class=\"p\">T.R.G. (Internacional)&nbsp; &nbsp; &nbsp;  81,90</div><div class=\"p\">Cap. de bodega&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  140,00 m3</div><div class=\"p\">Potencia motor principal&nbsp; &nbsp;  425,00 Hp</div><div class=\"p\">Potencia motor auxiliar&nbsp; &nbsp; &nbsp; 13,20 Hp</div><br></div>", "i": 6409362}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de diciembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6409363}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3008", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3008"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-27", "doble_articulado": false, "id_norma": "206488", "numero_fuente": "37453", "tipo_version": "3", "tipo_version_s": "Única", "f