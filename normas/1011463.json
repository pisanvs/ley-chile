{"html": [{"t": "<div><br><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 104 EXENTA, DE 2009</div></div>", "i": 8887235}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 45, del 1 de marzo de 2010, que modifica la <a href=\"https://www.leychile.cl/Navegar?idNorma=1004476&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta SII N&#xBA; 104, de 20 de julio de 2009</a>, de la Direcci&#xF3;n Nacional, que suprime Departamento Tribunal Tributario y Oficina Jur&#xED;dica, y crea Departamento Jur&#xED;dico y Oficina de Procedimientos Administrativos Tributarios en la II Direcci&#xF3;n Regional Antofagasta; delega facultad que se&#xF1;ala y autoriza delegaci&#xF3;n de facultad que indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en marzo de 2010.</div></div>", "i": 8887236}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "45", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-45"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 104 EXENTA, DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-03-01", "doble_articulado": false, "id_norma": "1011463", "numero_fuente": "39603", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-03-05", "vigencias": [{"desde": "2010-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}]