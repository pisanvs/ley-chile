{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Asigna al Intendente de Antofagasta 4 000 pesos para gastos de representacion</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1809.- Santiago, a 12 de Febrero de 1906.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274733}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO PRIMERO. As&#xED;gnase al Intendente de Antofagasta la suma de cuatro mil pesos ($ 4 000) anuales para gastos de representacion; i </div></div>", "i": 8274734}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ART. 2.&#xB0; Los subdelegados de Calama, Mejillones i Toco gozar&#xE1;n de un sueldo de dos mil pesos ($ 2 000) anuales cada uno.</div><br></div>", "i": 8274735}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Miguel Cruchaga.</div><br></div>", "i": 8274736}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1809", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1809"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "ASIGNA AL INTENDENTE DE ANTOFAGASTA 4 000 PESOS PARA GASTOS DE REPRESENTACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INTENDENTE", "ANTOFAGASTA", "GASTOS REPRESENTACION", "SUBDELEGADOS", "CALAMA", "MEJILLONES", "TOCO", "SUELDO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-02-12", "doble_articulado": false, "id_norma": "22931", "numero_fuente": "8429", "tipo_version": "3", "tipo_version_s": "Única", "f