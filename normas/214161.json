{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6437596}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA;704, de fecha 31 de julio de 2003, se expropi&#xF3; el lote de terreno N&#xBA; 64, superficie 497,0 m&#xB2;, rol de aval&#xFA;o N&#xBA; 512-394, comuna de Carahue, para la obra &quot;Camino Ruta S-36, sector Tranapuente - Nahuent&#xFA;e, tramo Km. 0,000 a Km. 9,997062, correspondiente al Subtramo II, Km. 4,235 a Km.</div><div class=\"p\">9,997062&quot;, IX Regi&#xF3;n, y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Humberto Torres Millaqueo, ascendente a la cantidad de $435.213. </div></div>", "i": 6437597}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6437598}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "704 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-704 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-07-31", "doble_articulado": false, "id_norma": "214161", "numero_fuente": "37649", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-01", "vigencias": [{"desde": "2003-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2003-09-01", "fecha_version": "2003-09-01", "fecha