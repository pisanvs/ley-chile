{"html": [{"t": "<div><div class=\"p\">DERECHOS DE APROVECHAMIENTO DE AGUAS EN COMUNA DE RIO CLARO </div></div>", "i": 6298399}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n</div><div class=\"p\">exenta N&#xBA; 2.098 del 18 de agosto de 2000, conforme</div><div class=\"p\">art&#xED;culo 5&#xBA; transitorio C&#xF3;digo de Aguas, ratific&#xF3; resoluci&#xF3;n general de la Oficina de Normalizaci&#xF3;n Agraria N&#xBA; 2.524, de fecha 14 de noviemvbre de 1979, que determin&#xF3; derechos aprovechamiento de aguas proporcionales en la parte del Proyecto de Parcelaci&#xF3;n &apos;&apos;Los Cerrillos&apos;&apos;, de la comuna de R&#xED;o Claro, VII Regi&#xF3;n, conformada por las parcelas N&#xBA;s. 38 a 59 y 78; sitios N&#xBA;s 5 al 24 y reserva Cora N&#xBA; 1.</div><div class=\"p\">&nbsp; &nbsp;  Los derechos de aguas se extraen del canal Cumpeo. Publicaci&#xF3;n hecha conforme art&#xED;culo 13 ley N&#xBA; 18.377.- </div></div>", "i": 6298400}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Nacional.</div><br></div>", "i": 6298401}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2098 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2098 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE APROVECHAMIENTO DE AGUAS EN COMUNA DE RIO\nCLARO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-08-18", "doble_articulado": false, "id_norma": "174798", "numero_fuente": "36754", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-01", "vigenc