{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8296338}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.207, de 22 de Diciembre de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 1 de la Resoluci&#xF3;n N&#xB0; 614, de 1993, de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a PESQUERA EPERVA S.A., R.U.T. N&#xB0; 91.643.000-0, para sustituir las naves &quot;Angamos 5&quot;, &quot;Eperva 32&quot; y &quot;Marsopa II&quot; por la nave &quot;Eperva 64&quot;, en el sentido de se&#xF1;alar que la capacidad de bodega de esta &#xFA;ltima es de 650 m3 y no como en dicha Resoluci&#xF3;n se indica.</div><br></div>", "i": 8296339}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 22 de Diciembre de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8296340}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1207", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1207"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "AUTORIZACION", "PESQUERA EPERVA S.A"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-12-22", "doble_articulado": false, "id_norma": "36490", "numero_fuente": "35062", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-01-09", "vigencias": [{"desde": "1995-01-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-01-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-01-09", "fin_vigencia": ""