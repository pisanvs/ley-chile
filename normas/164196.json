{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCIONES N&#xBA;s. 184, DE 1980, Y 51, DE 1981 </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 62.- Santiago, 17 de Mayo de 1985.- Vistos: Lo dispuesto en el Art. 4&#xBA; del decreto ley N&#xBA; 2.974, de 1979,</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 7266851}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;canse las resoluciones N&#xBA;s. 184 de 18.04.80 y 51 de 13.03.81, sobre designaci&#xF3;n de Ministros de Fe en lo referente a la VI Regi&#xF3;n en la siguiente forma:</div><br><div class=\"p\">&nbsp; &nbsp;  En resoluci&#xF3;n N&#xBA; 184 se elimina al funcionario se&#xF1;or Gustavo Far&#xED;as G&#xE1;lvez.</div><div class=\"p\">&nbsp; &nbsp;  En resoluci&#xF3;n N&#xBA; 51 se eliminan a los se&#xF1;ores Raimundo Villagr&#xE1;n Lillo y Alvaro Cubillos Cubillos. </div></div>", "i": 7266852}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Fernando Lasalvia Souza, Vicepresidente Ejecutivo Subrogante.</div><br></div>", "i": 7266853}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "62", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-62"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "MODIFICA RESOLUCIONES Nºs. 184, DE 1980, Y 51, DE 1981", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-17", "doble_articulado": false, "id_norma": "164196", "numero_fuente": "32203", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-22", "vigencias": [{"desde": "1985