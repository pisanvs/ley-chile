{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,673.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 8345629}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se concede, por gracia, a don Jos&#xE9; Manuel Padilla Encina, empleado policial retirado, el derecho a que su pensi&#xF3;n le sea computada sobre la base del sueldo asignado al empleo de inspector de la polic&#xED;a de Santiago.</div><br></div>", "i": 8345630}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, veintitres de agosto de mil novecientos doce.- Ramon Barros Luco.- Guillermo Barros.</div><br></div>", "i": 8345631}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2673", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2673"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-08-23", "doble_articulado": false, "id_norma": "137658", "numero_fuente": "10364", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-08-28", "vigencias": [{"desde": "1912-08-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-08-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-08-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresad