{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.115 EXENTO, DE 1997 </div></div>", "i": 6063133}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 1.115 de 28 de octubre de 1997, se ha aprobado, a contar del a&#xF1;o escolar 1997, un plan especial de estudio de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica para Adultos, al &quot;Instituto Docencia&quot; de Santiago, que se desarrollar&#xE1; en cuatro semestres.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para las asignaturas que se se&#xF1;alan en el presente decreto. </div></div>", "i": 6063134}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de diciembre de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6063135}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1115 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1115 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.115 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "INSTITUTO DOCENCIA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-10-28", "doble_articulado": false, "id_norma": "82743", "numero_fuente": "35924", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-12-17", "vigencias": [{"desde": "1997-12-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-12-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-12-17", "fin_vigencia": "", "tip