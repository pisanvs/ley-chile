{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 10,691</div><br><div class=\"p\">ABONA EL TIEMPO QUE INDICA EN LA HOJA DE SERVICIOS DE DON CESAR GACITUA VERGARA</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6600218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Ab&#xF3;nanse, por gracia y para todos los efectos legales, tres a&#xF1;os y siete meses&nbsp; en la hoja de servicios de don C&#xE9;sar Gacit&#xFA;a Vergara.</div><div class=\"p\">&nbsp; &nbsp;  Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el &quot;Diario Oficial&quot;.</div><br></div>", "i": 6600219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a siete de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Ignacio Lorca G.</div><br></div>", "i": 6600220}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10691", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10691"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ABONA EL TIEMPO QUE INDICA EN LA HOJA DE SERVICIOS DE\nDON CESAR GACITUA VERGARA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-07", "doble_articulado": false, "id_norma": "258084", "numero_fuente": "22387", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-10-29", "vigencias": [{"desde": "1952-10-29", "hasta": "", "tipo_