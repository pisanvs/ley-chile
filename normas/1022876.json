{"html": [{"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Vi&#xF1;a del Mar, febrero 6 de 1877.</div><br><div class=\"p\">&nbsp; &nbsp;  Considerando:</div><br><div class=\"p\">&nbsp; &nbsp;  1.&#xBA; Que conviene estimular a las mujeres a que hagan estudios s&#xE9;rios i s&#xF3;lidos;</div><br><div class=\"p\">&nbsp; &nbsp;  2.&#xBA; Que ellas pueden ejercer con ventaja algunas de las profesiones denominadas cient&#xED;ficas; i</div><br><div class=\"p\">&nbsp; &nbsp;  3.&#xBA; Que importa facilitarles los medios de que puedan ganar la subsistencia por s&#xED; mismas,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div></div>", "i": 9108845}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Se declara que las mujeres deben ser admitidas a rendir ex&#xE1;menes v&#xE1;lidos para obtener t&#xED;tulos profesionales, con tal que ellas se sometan para ello a las mismas disposiciones a que est&#xE1;n sujetos los hombres.</div></div>", "i": 9108846}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Comun&#xED;quese i publ&#xED;quese.</div><br><div class=\"p\">&nbsp; &nbsp;  PINTO</div><div class=\"p\">&nbsp; &nbsp;  Miguel Luis Amun&#xE1;tegui.</div><br></div>", "i": 9108847}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE JUSTICIA, CULTO E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": ["DECRETO AMUNÁTEGUI"], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1877-02-06", "doble_articulado": false, "id_norma": "1022876", "numero_fuente": "4", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1877-03-04", "vigencias": [{"d