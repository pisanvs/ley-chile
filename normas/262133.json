{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL 5% ANTICIPO IVA EN LA VENTA DE CARNE A FAENADORA SAN VICENTE LTDA. </div></div>", "i": 7346366}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 02.- Certifico que la empresa Faenadora San Vicente Ltda. RUT N&#xBA; 78.483.600-2, cumple con los requisitos establecidos en la resoluci&#xF3;n exenta N&#xBA; 3.722 de 28 de julio de 2000 y que consecuencia, se le ha otorgado la Calidad de Agente Retenedor de anticipo del 5% del Impuesto al Valor Agregado, en las ventas de carnes, a contar del 1&#xBA; del mes siguiente al de publicaci&#xF3;n de este certificado en el Diario Oficial. </div></div>", "i": 7346367}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de Junio de 2007.- Bernardo Seaman Gonz&#xE1;lez, Director Regional.</div><br></div>", "i": 7346368}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "2", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-2"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN GRANDES CONTRIBUYENTES"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL 5% ANTICIPO IVA\nEN LA VENTA DE CARNE A FAENADORA SAN VICENTE LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "IVA", "FAENADORA SAN VICENTE LTDA", "CARNE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-14", "doble_articulado": false, "id_norma": "262133", "numero_fuente": "38798", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-06-26", "vigencias": [{"desde": "2007-06-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "