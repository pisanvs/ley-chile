{"html": [{"t": "<div><div class=\"p\">RESOLUCION EXENTA N&#xB0; 352, DE 1986 </div></div>", "i": 8357093}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n Exenta N&#xB0; 352 de 14 de mayo de 1986 del Ministerio del Interior disponer: 1) Revoca permiso de turismo de extranjero Ricardo Chac&#xF3;n Cu&#xE9;llar, boliviano;</div><div class=\"p\">2) Notificar que extranjero debe abandonar el pa&#xED;s en el plazo de 72 horas; 3) Comunicar a Polic&#xED;a de Investigaciones de Chile, Jefatura Nacional de Extranjer&#xED;a y Polic&#xED;a Internacional, para conocimiento y fines.</div><br></div>", "i": 8357094}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese y comun&#xED;quese.- Alberto Cardemil Herrera, Subsecretario del Interior.</div><div class=\"p\">&nbsp; &nbsp;  Notificaci&#xF3;n practicada seg&#xFA;n lo ordena el art&#xED;culo 142 inciso 2&#xB0; del DS N&#xB0; 597 de 1984 del Ministerio de Interior.</div><br></div>", "i": 8357095}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "352 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-352 EXENTA"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARIA DEL INTERIOR"], "titulo_norma": "RESOLUCION EXENTA N° 352, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-05-14", "doble_articulado": false, "id_norma": "151928", "numero_fuente": "35.593", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-10-10", "vigencias": [{"desde": "1986-10-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-10-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic