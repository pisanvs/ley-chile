{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PENSION Lei n&#xFA;m. 208.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947153}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. En atencion a los servicios del ex-Superintendente de Aduana don Jos&#xE9; Manuel Moya, se asigna a su viuda e hijas solteras una pension anual de dos mil pesos, de que disfrutar&#xE1;n conjuntamente durante sus dias, acreciendo la parte de las que murieren a las sobrevivientes.</div><br><br></div>", "i": 5947154}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, lo he aprobado i sancionado; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 6 de Setiembre de 1894.-JORGE MONTT.-C&#xE1;rlos Riesco.</div><br></div>", "i": 5947155}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "208", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-208"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUAN MANUEL MOYA", "VIUDA", "HIJAS SOLTERAS", "PENSION", "GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-09-06", "doble_articulado": false, "id_norma": "22066", "numero_fuente": "4911", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-09-07", "vigencias": [{"desde": "1894-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-09-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici