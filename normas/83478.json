{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8315150}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n N&#xBA;494, de 9 de Abril de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n N&#xBA;1.065, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Fundaci&#xF3;n Chile S.A., R.U.T. N&#xBA;70.300.000-2, domiciliada en Santiago, para ampliar actividades pesqueras, en orden a se&#xF1;alar que tal autorizaci&#xF3;n debe entenderse otorgada a Fundaci&#xF3;n Chile. </div></div>", "i": 8315151}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 9 de Abril de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8315152}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "494", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-494"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-04-09", "doble_articulado": false, "id_norma": "83478", "numero_fuente": "33648", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-04-18", "vigencias": [{"desde": "1990-04-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-04-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-04-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CQA", "fecha_ingreso": "1998-01-08", "fecha_ve