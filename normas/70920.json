{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8302671}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 577 de 22 de abril de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rese la caducidad parcial de la Resoluci&#xF3;n N&#xBA; 172, de 1982, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA MARBELLA S.A., para realizar actividades pesqueras extractivas con la nave &quot;Costa Grande 2&quot;, en el litoral de la V y IX Regiones, en virtud de lo dispuesto en el art&#xED;culo 143, letra b), de la Ley N&#xBA; 18.892 y sus modificaciones citada en Visto.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xBA; 445, de 1997, de esta Subsecretar&#xED;a, por haberse dictado con error de hecho. </div></div>", "i": 8302672}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de abril de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8302673}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "577", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-577"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "PESQUERA MARBELLA S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-22", "doble_articulado": false, "id_norma": "70920", "numero_fuente": "35753", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-29", "vigencias": [{"desde": "1997-04-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Únic