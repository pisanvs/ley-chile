{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 10.317 EXENTA, DE 2001 </div><br></div>", "i": 6354343}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 10.317 de 5 de septiembre del a&#xF1;o 2001, se ha modificado la resoluci&#xF3;n N&#xBA; 857 del 7 de febrero de 2001 que aprob&#xF3; planes y programas especiales de estudio para tercer a&#xF1;o de ense&#xF1;anza media, al colegio Claretiano de Santiago, en el sentido siguiente, en el Subsector del Plan de Formaci&#xF3;n Diferenciada correspondiente a Biolog&#xED;a dice:</div><div class=\"p\">&quot;Evoluci&#xF3;n y Literatura&quot;, debe decir: &quot;Evoluci&#xF3;n, Ecolog&#xED;a y Ambiente&quot;.</div><br></div>", "i": 6354344}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de octubre de 2001.- Juan Ruz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6354345}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10317 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-10317 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 10.317 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-09-05", "doble_articulado": false, "id_norma": "190857", "numero_fuente": "37090", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-10-20", "vigencias": [{"desde": "2001-10-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-10-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-10-20", "fin_vigencia": ""