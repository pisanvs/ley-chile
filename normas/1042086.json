{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9279426}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.942, de 18 de julio de 2012, de esta Subsecretar&#xED;a, la n&#xF3;mina de armadores y embarcaciones que cumplen con los requisitos legales para operar en la unidad de pesquer&#xED;a de Merluza de cola, declarada en estado de plena explotaci&#xF3;n y sometida a dicho r&#xE9;gimen de administraci&#xF3;n, en el litoral de la V a X Regiones, en el &#xE1;rea se&#xF1;alada en sus respectivas autorizaciones, al 30 de junio de 2012, es la siguiente:</div><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/27294.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><br></div>", "i": 9279427}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de julio de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9279428}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1942 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-1942 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-18", "doble_articulado": false, "id_norma": "1042086", "numero_fuente": "40318", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-07-23", "vigencias": [{"desde": "2012-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-07-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-07-23"