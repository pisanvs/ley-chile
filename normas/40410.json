{"html": [{"t": "<div><div class=\"p\">DELEGA EN EL SUBDIRECTOR JURIDICO FACULTAD QUE INDICA </div><br><br></div>", "i": 7202840}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; Ex 3913, de 1&#xB0; de Septiembre de 1994, el suscrito ha delegado en el Subdirector Jur&#xED;dico la facultad para representar judicialmente al Servicio en las reclamaciones que presenten los contribuyentes contra liquidaciones, giros, pagos, resoluciones y denuncias y que deban tramitarse con arreglo a los procedimientos establecidos en el T&#xED;tulo II; en el p&#xE1;rrafo 1&#xB0; del T&#xED;tulo III, y en los p&#xE1;rrafos 1&#xB0; y 2&#xB0; del T&#xED;tulo IV, del Libro Tercero, del C&#xF3;digo Tributario.- </div></div>", "i": 7202841}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Javier Etcheberry Celhay, Director.</div><br></div>", "i": 7202842}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3913", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3913"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DELEGA EN EL SUBDIRECTOR JURIDICO FACULTAD QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SUBDIRECTOR JURIDICO", "DELEGACION", "FACULTAD", "SERVICIO", "IMPUESTOS INTERNOS", "DIRECTOR NACIONAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-09-01", "doble_articulado": false, "id_norma": "40410", "numero_fuente": "34963", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-09-10", "vigencias": [{"desde": "1994-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-09-10", "fin_vigencia": ""}, "vigencias_vers