{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA RESOLUCION N&#xB0; 1.877 EXENTA, DE 1992, SOBRE DELEGACION DE FACULTADES </div></div>", "i": 7202351}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n Exenta N&#xB0; 1.643 de 5 de Mayo de 1995, el Director Regional de la VII Direcci&#xF3;n Regional Talca, ha procedido a modificar la parte dispositiva de la Resoluci&#xF3;n Ex. N&#xB0; 1.877, de fecha 25 de Marzo de 1992, de esta Direcci&#xF3;n Regional.</div><div class=\"p\">&nbsp; &nbsp; 1&#xB0; Reempl&#xE1;zase, en el inciso segundo de la letra a), la expresi&#xF3;n &quot;graves&quot; por la palabra &quot;complejas&quot;; y 2&#xB0; Supr&#xED;mese la letra d), pasando las letras f); g), y h) a ser d); f), y g), respectivamente.-</div><br></div>", "i": 7202352}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Sergio Flores Guti&#xE9;rrez, Director Regional. </div></div>", "i": 7202353}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1643 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1643 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL VII REGIÓN DEL MAULE"], "titulo_norma": "MODIFICA RESOLUCION N° 1.877 EXENTA, DE 1992, SOBRE DELEGACION DE FACULTADES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DELEGACION", "FACULTAD", "SERVICIO IMPUESTOS INTERNOS", "DIRECCION REGIONAL", "SEPTIMA REGION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-05", "doble_articulado": false, "id_norma": "39883", "numero_fuente": "35170", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-05-18", "vigencias": [{"desde": "1995-05-18", "hasta": "", "tipo_v