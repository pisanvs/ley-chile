{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N EXENTA QUE INDICA</div></div>", "i": 9851039}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 5, de 9 de noviembre de 2017, de esta Direcci&#xF3;n Zonal de Pesca y Acuicultura, modif&#xED;quese la <a href=\"https://www.leychile.cl/Navegar?idNorma=1107082&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3, de 2017</a>, de esta Direcci&#xF3;n Zonal, que estableci&#xF3; medidas de administraci&#xF3;n para las especies &#xED;cticas de importancia recreativa en la cuenca del r&#xED;o Yelcho, en los t&#xE9;rminos se&#xF1;alados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de la presente resoluci&#xF3;n se encuentra publicado en www.subpesca.cl.</div></div>", "i": 9851040}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Puerto Montt, 9 de noviembre de 2017.- Juan Guti&#xE9;rrez Pedreros, Director Zonal de Pesca X Regi&#xF3;n de Los Lagos.</div></div>", "i": 9851041}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "DIRECCIÓN ZONAL REGIÓN X DE LOS LAGOS"], "titulo_norma": "MODIFICA RESOLUCIÓN EXENTA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1304354; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-11-09", "doble_articulado": false, "id_norma": "1111031", "numero_fuente": "41911", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-11-18", "vigencias": [{"desde": "2017-11-18", "hasta