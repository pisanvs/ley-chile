{"html": [{"t": "<div><div class=\"p\">DECLARA CADUCIDAD DE RESOLUCION No. 28, DE 1985 </div></div>", "i": 8526652}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 848 de 30.07.87 de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n, se declara la caducidad de la resoluci&#xF3;n No.</div><div class=\"p\">28, de 1985, de esta entidad, que autoriz&#xF3; a don Mart&#xED;n</div><div class=\"p\">Rozas Covarrubias para desarrollar actividades de cultivo en</div><div class=\"p\">el Sector Array&#xE1;n, Regi&#xF3;n Metropolitana y en la rada de</div><div class=\"p\">Quintay, V Regi&#xF3;n, por incurrir en la causal se&#xF1;alada en el</div><div class=\"p\">art&#xED;culo 7&#xB0; del Decreto No. 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8526653}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30.07.87.- Roberto Cabezas Bello Subsecretario de Pesca.</div><br></div>", "i": 8526654}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "848", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-848"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "DECLARA CADUCIDAD DE RESOLUCION No. 28, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-30", "doble_articulado": false, "id_norma": "151797", "numero_fuente": "32838", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-05", "vigencias": [{"desde": "1987-08-05", "hasta": "", "tipo_version": "3", "tipo_ve