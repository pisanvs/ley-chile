{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N QUE INDICA</div></div>", "i": 9645643}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.827, de 23 de octubre de 2015, de esta Subsecretar&#xED;a, rectif&#xED;case <a href=\"https://www.leychile.cl/Navegar?idNorma=1068546&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 2.667, de 2014</a>, de esta Subsecretar&#xED;a, que modific&#xF3; la resoluci&#xF3;n N&#xBA; 1.064, de 2014, que estableci&#xF3; agrupaciones de concesiones de acuicultura de Salm&#xF3;nidos en X, XI y XII Regi&#xF3;n, reemplazando ACS 49 y 50, por ACS 49 A, 49 B, 50 A y 50 B, en la forma indicada en la resoluci&#xF3;n extractada y publicada &#xED;ntegramente en www.subpesca.cl y www.sernapesca.cl.</div><div class=\"p\">&nbsp; </div></div>", "i": 9645644}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de octubre de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9645645}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2827 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2827 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "RECTIFICA RESOLUCIÓN QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; IdDO 961031"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-10-23", "doble_articulado": false, "id_norma": "1083239", "numero_fuente": "41295", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-10-30", "vigencias": [{"desde": "2015-10-30", "hasta": "", "ti