{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA DECRETO EXENTO N&#xB0;87, DE 1990</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 579 exento.- Santiago, 4 de Noviembre de 1993.- Visto: Lo dispuesto en las Leyes N&#xB0;s.18.956 y 18.962; decretos Supremos de Educaci&#xF3;n N&#xB0;s.2.039 y 9.555, ambos de 1980; Resoluci&#xF3;n N&#xB0;55, de 1992 de la Contralor&#xED;a General de la Rep&#xFA;blica; y en los art&#xED;culos 32 N&#xB0;8 y 35 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile, Decreto:</div><br></div>", "i": 7162074}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico: Modif&#xED;case el Decreto Supremo Exento de Educaci&#xF3;n N&#xB0;87 de 1990, en el sentido de sustituir en el art&#xED;culo 12 el n&#xFA;mero &quot;4&quot; por &quot;5&quot;.</div><br></div>", "i": 7162075, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese y publ&#xED;quese.- Por orden del Presidente de la Rep&#xFA;blica, Jorge Arrate Mac Niven, Ministro de Educaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a usted para su conocimiento.- Saluda a usted.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7162076}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "579 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-579 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "MODIFICA DECRETO EXENTO N°87, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ESTABLECIMIENTOS EDUCACIONALES", "EDUCACION", "DIFERENCIAL", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-11-04", "doble_articulado": false, "id_norma": "21503", "num