{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div></div>", "i": 9312888}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA; 40.064, de 17 de septiembre de 2011, se public&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1030093&amp;idParte=&amp;idVersion=\">decreto exento N&#xBA; 193 que &quot;ESTABLECE ORDEN DE SUBROGANCIA DEL SUBSECRETARIO DEL MEDIO AMBIENTE</a>&quot;: Con el error que se salva a continuaci&#xF3;n: I Cuerpo, p&#xE1;gina cuatro, segunda columna, donde dice &quot;... N&#xFA;m. 119 exento.- Santiago, 12 de septiembre de 2001.- ...&quot;, debe decir &quot; ... N&#xFA;m. 119 exento.- Santiago, 12 de septiembre de 2011.- ...&quot;.</div><br></div>", "i": 9312889, "v": ["RECTIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "230", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-230"}], "organismos": ["MINISTERIO DEL MEDIO AMBIENTE"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN PROMULGACIÓN NI FECHA DE PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1045892", "numero_fuente": "40414", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-11-20", "vigencias": [{"desde": "2012-11-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-11-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-11-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "RECTIFICACION", "url_part": "rectificacion"}], "ingresado_por": "2932", "fecha_ingreso": "2012-11-20