{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;mero 4,480</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6210940}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atenci&#xF3;n a los servicios prestados por el ex-buzo mayor de la Armada Nacional, Francisco Santib&#xE1;&#xF1;ez Herrera, aum&#xE9;ntasele la pensi&#xF3;n de retiro de que actualmente disfruta a la suma de ciento cincuenta pesos mensuales ($ 150).</div><br></div>", "i": 6210941}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y, por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiocho de Noviembre de mil novecientos veintiocho.- Carlos Ib&#xE1;&#xF1;ez del Campo.- C. O. Fr&#xF6;dden. </div></div>", "i": 6210942}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4480", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4480"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-11-28", "doble_articulado": false, "id_norma": "149041", "numero_fuente": "15253", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-12-20", "vigencias": [{"desde": "1928-12-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-12-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1928-12-20", "fin_vigencia": "", "tipo_version": "3"}]