{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6596885}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.517, de 27 de diciembre de 2006, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de la resoluci&#xF3;n N&#xBA; 64 de 2006, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESCA SURIBERICA S.A. para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Dise&#xF1;o e implementaci&#xF3;n de una l&#xED;nea piloto de captura de Bacalao de profundidad (Dissostichus eleginoides) con trampas, a&#xF1;o 2006&quot;, en el sentido de extender el per&#xED;odo de ejecuci&#xF3;n de la citada pesca de investigaci&#xF3;n hasta el d&#xED;a 4 de febrero de 2007, inclusive.</div><br></div>", "i": 6596886}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de diciembre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6596887}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3517 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3517 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-12-27", "doble_articulado": false, "id_norma": "257338", "numero_fuente": "38661", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-01-12", "vigencias": [{"desde": "2007-01-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-01-12", "fin_vigen