{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8330249}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n N&#xBA; 828, de 4 de junio de 1998, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura N&#xBA; 96103177, presentada por el</div><div class=\"p\">SINDICATO DE TRABAJADORES INDEPENDIENTES, PESCADORES</div><div class=\"p\">ARTESANALES, ALGUEROS Y RAMOS SIMILARES de Curaco de V&#xE9;lez, Huenao, La Planchada y Changuitad de la comuna de Curaco de V&#xE9;lez, para operar un centro de cultivo en Changuitad Sur, comuna de Curaco de V&#xE9;lez, provincia de Chilo&#xE9;, X Regi&#xF3;n, conforme lo dispuesto en el art&#xED;culo 14 del D.S. N&#xBA; 290 de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8330250}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de junio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8330251}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "828", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-828"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "CURACO DE VELEZ", "SINDICATO DE TRABAJADORES INDEPENDIENTES", "PESCADORES ARTESANALES", "ALGUEROS Y RAMOS SIMILARES DE CURACO DE VELEZ", "HUENAO", "LA PLANCHADA Y CHANGUITAD", "DECIMA REGION", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha