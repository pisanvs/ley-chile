{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6388590}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA;779 de fecha 31 de mayo de 2002, se expropiaron los lotes de terreno N&#xBA;s 1-A y 2-A, superficie 1.730 y 700 m2 respectivamente, Rol N&#xBA;238-44, comuna de Tolt&#xE9;n, IX Regi&#xF3;n para la obra &apos;&apos;Estudio de Ingenier&#xED;a Varios Puentes en la IX Regi&#xF3;n, sector Puente Puchilco&apos;&apos;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Margarita Silvia Liempi Calf&#xED;n, ascendente a la cantidad de $923.580. </div></div>", "i": 6388591}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6388592}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "779 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-779 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-31", "doble_articulado": false, "id_norma": "200317", "numero_fuente": "37308", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-15", "vigencias": [{"desde": "2002-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MAS", "fecha_ingreso": "2002-07-15", "fecha_version": "2002-07-15", "fecha_actualizacion_texto": "2002-07-15", "tipo_tratad