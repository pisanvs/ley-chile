{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6202426}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 79, de fecha 28 de Enero de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la V Regi&#xF3;n, se autoriza a Octavio Valenzuela Rodena, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del territorio nacional, a acepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6202427}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de Enero de 1987.- H&#xE9;ctor Soto Miranda, Secretario Regional Ministerial de Transportes y Telecomunicaciones subrogante V Regi&#xF3;n.</div><br></div>", "i": 6202428}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "79 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-79 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL V REGIÓN DE VALPARAÍSO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-01-28", "doble_articulado": false, "id_norma": "146860", "numero_fuente": "32742", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-04-08", "vigencias": [{"desde": "1987-04-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-04-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-04-08", "fin_vigencia": "", "tipo_version": "3"}],