{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6092894}, {"t": "<div><div class=\"p\">Por Decreto M.O.P. No. 43, de 28 de febrero de 1989, se expropiaron los lotes N&#xB0;s. 2-B, 10, 25 y 29, superficies 6.500 m2., 11.120 m2., 5.458 m2. y 23.350 m2., respectivamente, roles de aval&#xFA;os 2.209-47, 2.204-20, 2.207-4 y 2.202-16, para Camino Longitudinal Sur, Ruta 5, sector By Pass Chillin y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios Nenrod Mardones Soto, Julia In&#xE9;s Middleton Prado y otros, Clemencia Eliana S&#xE1;nchez y otras, y H&#xE9;ctor Venegas Gajardo, ascendente a las cantidades de $ 2.797.340, $ 355. 219, $ 273.040 y $ 3.274.023.-</div><br></div>", "i": 6092895}, {"t": "<div><div class=\"p\">Fiscal del Ministerio de Obras P&#xFA;blicas.</div><div class=\"p\">(1&#xB0;) </div></div>", "i": 6092896}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "43", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-43"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-02-28", "doble_articulado": false, "id_norma": "92948", "numero_fuente": "33336", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-04-01", "vigencias": [{"desde": "1989-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1998-03-02", "fecha_v