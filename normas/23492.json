{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede derecho a jubilar a don J. Guillermo Guerra Lei n&#xFA;m. 2,781.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275584}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Conc&#xE9;dese, por gracia, al Secretario de Comisiones de la C&#xE1;mara de Diputados don J. Guillermo Guerra el derecho a jubilar con una pension equivalente a las veintidos cuarentavas partes del sueldo de que actualmente goza en dicho empleo. </div></div>", "i": 8275585}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 23 de Julio de 1913.- Ramon Barros Luco.- Manuel Rivas Vicu&#xF1;a.</div><br></div>", "i": 8275586}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2781", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2781"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE DERECHO A JUBILAR A DON J. GUILLERMO GUERRA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["J GUILLERMO GUERRA", "JUBILACION POR GRACIA", "COMISION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1913-07-23", "doble_articulado": false, "id_norma": "23492", "numero_fuente": "10637", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1913-07-29", "vigencias": [{"desde": "1913-07-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1913-07-29"