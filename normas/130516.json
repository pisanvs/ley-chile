{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 7412216}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.072, de 22 de junio de 1988, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriza al se&#xF1;or H&#xE9;ctor Adolfo Pacheco Bahamonde, para efectuar servicio internacional de transporte terrestre de pasajeros entre Punta Arenas (Chile) y R&#xED;o Grande (Argentina), por el Paso de San Sebasti&#xE1;n, el que se atender&#xE1; con dos (2) frecuencias semanales.</div><br></div>", "i": 7412217}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Manuel G&#xE1;rate Meneses, Coronel, Subsecretario de Transportes.</div><br></div>", "i": 7412218}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1072 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1072 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-06-22", "doble_articulado": false, "id_norma": "130516", "numero_fuente": "33132", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-07-28", "vigencias": [{"desde": "1988-07-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-07-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-07-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-01-21", "fecha_version": "1988-07-28", "fe