{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div><br></div>", "i": 8747482}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA; 39.415, de 20 de julio de 2009, se public&#xF3; decreto n&#xFA;mero 1.161 exento, que &quot;ESTABLECE &#xC1;REA DE MANEJO Y EXPLOTACI&#xD3;N DE RECURSOS BENT&#xD3;NICOS PARA LA VIII REGI&#xD3;N&quot;, con el error de transcripci&#xF3;n que se salva a continuaci&#xF3;n: tanto en el Sumario como en la p&#xE1;gina tres, primera columna, donde dice &quot;.... N&#xFA;m. 1.661 exento...&quot; debe decir &quot;... N&#xFA;m. 1.161 exento...&quot;.</div><br></div>", "i": 8747483, "v": ["RECTIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "48", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-48"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1004344", "numero_fuente": "39416", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-07-21", "vigencias": [{"desde": "2009-07-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-07-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-07-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "RECTIFICACION", "url_part": "rectificacion"}], "ingresado_por": "362", "fecha_ingreso": "2009-07-21", "fecha_version": "2009-07-21", "actualizado_por": "362", "fecha_actualizacion_texto": "2009-07-2