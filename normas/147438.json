{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 197, DE 1987 </div></div>", "i": 7256353}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 197, de 24 de septiembre de 1987, se ha aprobado, a contar del a&#xF1;o escolar 1988, al Instituto Comercial &quot;Iquique English College&quot;, de Iquique, un plan especial de estudio de ense&#xF1;anza media t&#xE9;cnico - profesional, para la formaci&#xF3;n de t&#xE9;cnicos de nivel medio en la especialidad de Secretariado Administrativo Biling&#xFC;e con menci&#xF3;n en T&#xE9;cnicas Contables.</div><br></div>", "i": 7256354}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 02 de Octubre de 1987.- Mar&#xED;a Piedad Ruiz Ferreras, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 7256355}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "197 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-197 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 197, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-24", "doble_articulado": false, "id_norma": "147438", "numero_fuente": "32895", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-10-16", "vigencias": [{"desde": "1987-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-10-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-10-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text