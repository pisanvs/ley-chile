{"html": [{"t": "<div><div class=\"p\">Ley N&#xFA;m. 9,549</div><br><div class=\"p\">&nbsp; &nbsp; FIJA PLAZO DE DURACION AL DERECHO DE AUTOR A QUE SE REFIERE EL DECRETO QUE INDICA</div><br><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div></div>", "i": 9083937}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1.o. El derecho de autor a que se refiere el decreto ley N.o 345, de 17 de Marzo de 1925, dura la vida del autor y cincuenta a&#xF1;os m&#xE1;s contados desde la fecha del fallecimiento de &#xE9;ste.</div><br></div>", "i": 9083938}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2.o. Esta ley comenzar&#xE1; a regir desde su publicaci&#xF3;n en el Diario Oficial&quot;.</div><br></div>", "i": 9083939}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintiocho de Diciembre de mil novecientos cuarenta y nueve.- GABRIEL GONZALEZ VIDELA.- A. Mallet.</div><br><br></div>", "i": 9083940}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "9549", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-9549"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "FIJA PLAZO DE DURACION AL DERECHO DE AUTOR A QUE SE REFIERE EL DECRETO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHO AUTOR", "DURACION", "FIJACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1949-12-28", "fecha_derogacion": "1970-10-02", "doble_articulado": false, "id_norma"