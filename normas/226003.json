{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6482045}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 1.426, de 24 de mayo de 2004, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA; de la resoluci&#xF3;n N&#xBA; 1.111, de 2004, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del proyecto denominado &quot;Monitoreo biol&#xF3;gico-pesquero de Sardina com&#xFA;n y Anchoveta en aguas interiores de la X Regi&#xF3;n&quot;, en el sentido de reemplazar las embarcaciones artesanales La Campari II, Ori&#xF3;n, Pac&#xED;fico A, por las embarcaciones artesanales Don Jos&#xE9;, Ori&#xF3;n II y Pac&#xED;fico Alfa, respectivamente, en la n&#xF3;mina de naves participantes en la presente pesca de investigaci&#xF3;n. </div></div>", "i": 6482046}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de mayo de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6482047}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1426 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1426 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-24", "doble_articulado": false, "id_norma": "226003", "numero_fuente": "37876", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-03", "vigencias": [{"desde": "2004-06-03", "hasta": "", "tipo_