{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6422711}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por decreto MOP (exento) N&#xBA;238 de fecha 31 de marzo del 2003, se expropi&#xF3; el lote de terreno N&#xBA;58-A, superficie 3.230 m2, Rol N&#xBA;142-25, comuna de Chonchi, X Regi&#xF3;n para la obra &quot;Camino Ruta 5, Sector Chonchi-Tara, Km.1.205,160 a Km. 1.215,004&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Br&#xED;gida P&#xE9;rez Oyarz&#xFA;n y otros, ascendente a la cantidad de $1.272.334.- </div></div>", "i": 6422712}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6422713}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "238 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-238 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-03-31", "doble_articulado": false, "id_norma": "209957", "numero_fuente": "37548", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-05-02", "vigencias": [{"desde": "2003-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2003-05-02", "fecha_version": "2003-05-02", "fecha_actualizacion_texto": "2003-05-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "est