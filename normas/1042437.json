{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUA EN COMUNA DE LA LIGUA</div></div>", "i": 9285665}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xBA; 3.968 del 9 de julio de 2012, conforme art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, rectific&#xF3; la <a href=\"https://www.leychile.cl/Navegar?idNorma=247312&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 549, de fecha 27 de enero de 2006</a>, que aclar&#xF3; y complement&#xF3; la resoluci&#xF3;n exenta N&#xBA; 936 de 1&#xBA; de abril de 2002, que aprob&#xF3; el Estudio T&#xE9;cnico de Divisi&#xF3;n de los Derechos de Aprovechamiento de Aguas del Proyecto de Parcelaci&#xF3;n de la Cooperativa de Reforma Agraria Asignataria &quot;Pullally Limitada&quot;, ubicado en la comuna de La Ligua, Regi&#xF3;n de Valpara&#xED;so, en el sentido de indicar correctamente las coordenadas del pozo San Manuel que son: Norte: 6.409.048 metros; Este: 279.621 metros.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13&#xBA; Ley N&#xBA; 18.377.- </div></div>", "i": 9285666}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Nacional.</div></div>", "i": 9285667}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3968 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3968 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUA EN COMUNA DE LA LIGUA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-09", "doble_articulado": false, "id_norma": "104243