{"html": [{"t": "<div><div class=\"p\">DISPONE EXPROPIACION QUE SE&#xD1;ALA</div><div class=\"p\">(Extracto)</div><br><br><br></div>", "i": 6057808}, {"t": "<div><div class=\"p\">Por Decreto Secc. 2da. No. 109, de fecha 29 de noviembre de 1991, Alcalde I. Municipalidad de Santiago, dispone expropiaci&#xF3;n total conforme DS No. 458 de Vivienda y Urbanismo, Decreto Ley No. 2186 y Ley No. 18.695, inmueble Alonso Ovalle No. 1654, Rol No. 448-020, Santiago, aparente dominio Sucesi&#xF3;n Cecilia Portales R., superficie aproximada a expropiar 472 mt2. Deslinde: Norte, 17 10 mts. con calle Alonso Ovalle; Sur, 6,40 mts. con calle Coronel Pantoja y 12 mts. con predio de uso p&#xFA;blico; Oriente, 42, 70 mts. otro propietario y Poniente, 44,35 mts. l&#xED;nea quebrada con predio uso p&#xFA;blico. Indemnizaci&#xF3;n provisional $ 18.868.000.- pagadera contado.</div><br></div>", "i": 6057809}, {"t": "<div><div class=\"p\"> Jaime Ravinet de la Fuente, Alcalde Santiago. </div></div>", "i": 6057810}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "109", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-109"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "DISPONE EXPROPIACION QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-11-29", "doble_articulado": false, "id_norma": "80646", "numero_fuente": "34143", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-12-16", "vigencias": [{"desde": "1991-12-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-12-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia"