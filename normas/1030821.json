{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9192726}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n n&#xFA;mero 2.436, de 12 de septiembre de 2011, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD ALVER LIMITADA para realizar actividades de colecta de semillas, por seis meses con superficie y coordenadas geogr&#xE1;ficas se&#xF1;aladas en la resoluci&#xF3;n extractada.</div><br></div>", "i": 9192727}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de septiembre de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9192728}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2436", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2436"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-09-12", "doble_articulado": false, "id_norma": "1030821", "numero_fuente": "40081", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-10-08", "vigencias": [{"desde": "2011-10-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-10-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-10-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2011-10-11", "fecha_version": "2011-10-08", "fecha_actualizacion_texto": "2011-10-11", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9192726}, {"n": "Artículo", "i":