{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6510387}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;3.446, de 1 de diciembre de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a COMUNIDAD INDIGENA TRAUN KALIN, para efectuar una siembra de peces, de conformidad con el proyecto &quot;Repoblamiento con Trucha arcoiris en la Laguna Coipulafqu&#xE9;n, X Regi&#xF3;n&quot;, elaborado por la peticionaria y aprobado por esta Subsecretar&#xED;a, con el objeto de repoblar la laguna Coipulafqu&#xE9;n, X Regi&#xF3;n, con la liberaci&#xF3;n de 65 ejemplares adultos, entre 800 y 1.000 gramos de Trucha arcoiris, de manera de implementar y favorecer la pesca deportiva y recreativa.</div><div class=\"p\">&nbsp; &nbsp;  Las actividades de siembra se realizar&#xE1;n dentro del plazo de dos meses contados desde la fecha de la resoluci&#xF3;n.</div><br></div>", "i": 6510388}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de diciembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6510389}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3446 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3446 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-01", "doble_articulado": false, "id_norma": "234010", "numero_fuente": "38046", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-28", "vigencias": [{"desde": "2004-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s"