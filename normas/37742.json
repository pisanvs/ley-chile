{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xB0; 5.944, DE 1995</div><br><br><br><br><br></div>", "i": 6018957}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Materia: Modifica plazos de obligatoriedad de dar aviso o ampliaciones de actividades o giros y de cambio de domicilio.</div><div class=\"p\">&nbsp; &nbsp; Esta Resoluci&#xF3;n uniforma el plazo de la obligatoriedad de los contribuyentes de dar aviso de cambios de domicilio y de cambios o ampliaciones de actividades o giros dentro de los dos meses siguientes a la fecha en que ellos se efect&#xFA;en.</div><div class=\"p\">&nbsp; &nbsp; La vigencia de la Resoluci&#xF3;n es a contar del 01-01-96.</div><div class=\"p\">&nbsp; &nbsp; La presente Resoluci&#xF3;n ser&#xE1; publicada in extenso en el Bolet&#xED;n del Servicio del mes de marzo de 1996. </div></div>", "i": 6018958}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, marzo de 1996.- Javier Etcheberry Celhay. + </div></div>", "i": 6018959}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5944", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5944"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS"], "titulo_norma": "EXTRACTO DE RESOLUCION N° 5.944, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DOMICILIO", "GIRO", "CAMBIO", "CONTRIBUYENTE", "OBLIGACION", "AVISO", "SERVICIO IMPUESTOS INTERNOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-01-01", "fecha_derogacion": "1997-11-27", "doble_articulado": false, "id_norma": "37742", "numero_fuente": "35418-1", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-03-15", "vigencias": [{"desde": "1997-11-27", "has