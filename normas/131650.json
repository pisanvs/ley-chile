{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8340828}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 121 de 21 de enero de 1999 de esta Subsecretar&#xED;a, autor&#xED;zase&nbsp; a&nbsp; CONSERVERA SACRAMENTO SOCIEDAD ANONIMA, para ampliar actividades pesqueras autorizadas por las resoluciones N&#xBA; 151, de 1990, N&#xBA; 651, de 1991, N&#xBA; 1.266, de 1992, N&#xBA; 1.841, de 1996 y N&#xBA; 83 de 1998, todas de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en calle Eulogio Goycolea N&#xBA; 720, Calbuco, X Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n que se indican los siguientes recursos hidrobiol&#xF3;gicos: Congelado y Deshidratado: Pepino de mar.</div><br></div>", "i": 8340829}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de enero de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8340830}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "121", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-121"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-01-21", "fecha_derogacion": "2007-06-30", "doble_articulado": false, "id_norma": "131650", "numero_fuente": "36289", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-02-13", "vigencias": [{"desde": "2007-06-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-02-13", "hasta": "2007-06-29", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia":