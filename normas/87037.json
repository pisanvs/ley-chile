{"html": [{"t": "<div><div class=\"p\">&quot;PARTIDO SOCIALDEMOCRACIA CHILENA&quot; </div></div>", "i": 6075063}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Roberto Mu&#xF1;oz Barra y Jorge Ib&#xE1;&#xF1;ez Vergara, en representaci&#xF3;n del Partido Socialdemocracia Chilena, han solicitado la constituci&#xF3;n legal del Partido en las Regiones Cuarta y S&#xE9;ptima, acompa&#xF1;ando fichas de afiliaciones en las cantidades que se indican:</div><br><div class=\"p\">Cuarta Regi&#xF3;n:&nbsp; 1.606.-</div><div class=\"p\">S&#xE9;ptima Regi&#xF3;n: 2.755.-</div><br><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la Ley No. 18.603 por Resoluci&#xF3;n Exenta No. O-1.640 de fecha 24 de Septiembre de 1991.-</div><br><br></div>", "i": 6075064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br><br></div>", "i": 6075065}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1640 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1640 EXENTA"}, {"tipo": "3", "numero": "0-1640 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-0-1640 EXENTA"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "\"PARTIDO SOCIALDEMOCRACIA CHILENA\"", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-09-24", "doble_articulado": false, "id_norma": "87037", "numero_fuente": "34082", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-10-03", "vigencias": [{"desde": "1991-10-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vige