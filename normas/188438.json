{"html": [{"t": "<div><div class=\"p\">INFORMA SOBRE ORDENANZA N&#xBA; 2, DE 2001</div><br><br></div>", "i": 6345682}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se ha dictado la ordenanza N&#xBA; 2 de fecha 3 de julio de 2001, que modifica y actualiza &quot;Normas Sanitarias de Aseo y Ornato&quot;, la que incluye las siguientes materias:</div><br><div class=\"p\">GENERALIDADES</div><br><div class=\"p\">CAPITULO I&nbsp;  De las Normas Sanitarias y de Higiene</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Ambiental.</div><div class=\"p\">CAPITULO II&nbsp; Limpieza de las v&#xED;as p&#xFA;blicas</div><div class=\"p\">CAPITULO III Recolecci&#xF3;n de residuos domiciliarios</div><div class=\"p\">CAPITULO IV&nbsp; Evacuaci&#xF3;n de residuos domiciliarios en</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  viviendas unifamiliares.</div><div class=\"p\">CAPITULO V&nbsp;  Evacuaci&#xF3;n de materiales de</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  construcci&#xF3;n.</div><div class=\"p\">CAPITULO VI&nbsp; Sanciones.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro oficial de la presente ordenanza municipal se encuentra en Secretar&#xED;a Municipal, para quien lo solicite.</div><br></div>", "i": 6345683}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Leopoldo Gonz&#xE1;lez Charpentier, Alcalde.- Fernando Sancho Fern&#xE1;ndez, Secretario Municipal.</div><br></div>", "i": 6345684}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "2", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "ORZ-2"}], "organismos": ["MUNICIPALIDAD DE JUAN FERNANDEZ"], "titulo_norma": "INFORMA SOBRE ORDENANZA Nº 2, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaci