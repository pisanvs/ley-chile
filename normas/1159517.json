{"html": [{"t": "<div><br><div class=\"p\">DECRETO &#x2013; NOMBRANDO MINISTRO.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Abril 6 de 1830.</div></div>", "i": 10263270}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  No sufriendo ya demoras la actual crisis del Estado, y habi&#xE9;ndose retardado el despacho del Gobierno por falta de los ministros nombrados, que no han hecho presente todavia en estado de encargarse de los respectivos ministerios; nombro Ministro de Estado en los departamentos de Relaciones Exteriores, del Interior y de Guerra y Marina a don Diego Portales, de cuya aptitud me hallo plenamente satisfecho, esperando de su amor patrio este nuevo e importante servicio a la causa p&#xFA;blica.- </div></div>", "i": 10263271}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon y comun&#xED;quese. </div><br><div class=\"p\">&nbsp; &nbsp;  OVALLE. </div><br><div class=\"p\">&nbsp; &nbsp;  Meneses.&nbsp; </div></div>", "i": 10263272}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DECRETO – NOMBRANDO MINISTRO", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1830-04-06", "doble_articulado": false, "id_norma": "1159517", "numero_fuente": "1830", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1830-04-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1830-04-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1830-04-06", "fin_vigencia": "", "tip