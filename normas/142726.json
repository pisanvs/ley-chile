{"html": [{"t": "<div><div class=\"p\">COMPLEMENTA DECRETO EXENTO No. 890, DE 1985 </div></div>", "i": 6189170}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rancagua, 12 de Marzo de 1987.- Con esta fecha la</div><div class=\"p\">Alcald&#xED;a decret&#xF3; lo siguiente:</div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 180 exento.- Complem&#xE9;ntase el Decreto Exento</div><div class=\"p\">No. 890, de 17 de Diciembre de 1985, que aprob&#xF3; la</div><div class=\"p\">Ordenanza Local de Derechos Municipales por servicios,</div><div class=\"p\">concesiones y permisos de la I. Municipalidad de</div><div class=\"p\">Rancagua, en el sentido de agregar como No. 6&#xB0; del</div><div class=\"p\">art&#xED;culo 16 el siguiente derecho:</div><div class=\"p\">&nbsp; &nbsp;  &quot;6&#xB0;.- Permisos provisorios para conducir otorgados por el Juzgado de Polic&#xED;a Local con vigencia de 30 d&#xED;as.</div><div class=\"p\">0,09 UTM&quot;.</div><br></div>", "i": 6189171}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese, inf&#xF3;rmese a la Intendencia Regional de la VI Regi&#xF3;n, publ&#xED;quese por una vez en el Diario Oficial y arch&#xED;vese.- Francisco Balart P&#xE1;ez, Alcalde de Rancagua.- Ricardo Sandoval Hern&#xE1;ndez, Secretario Municipal (S).</div><br></div>", "i": 6189172}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "180 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-180 EXENTO"}], "organismos": ["MUNICIPALIDAD DE RANCAGUA"], "titulo_norma": "COMPLEMENTA DECRETO EXENTO No. 890, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-03-12", "doble_articulado": false, "id_norma": "1