{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 728 EXENTO, DE 1998</div><br><br><br></div>", "i": 6123165}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 728 de 6 de julio de 1998, se ha aprobado al Colegio &apos;&apos;Instituci&#xF3;n Teresiana&apos;&apos; de la comuna de Las Condes, provincia de Santiago, Regi&#xF3;n Metropolitana, un plan de estudio para los cursos de 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza media Human&#xED;stico-Cient&#xED;fica, los que ser&#xE1;n aplicados a partir del a&#xF1;o escolar 1998.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para las asignaturas contempladas en los Planes Electivos y para los Talleres Complementarios.</div><br></div>", "i": 6123166}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 21 de julio de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6123167}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "728 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-728 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 728 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIO INSTITUCION TERESIANA", "LAS CONDES", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-06", "doble_articulado": false, "id_norma": "122422", "numero_fuente": "36127", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-07-30", "vigencias": [{"desde": "1998-07-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Únic