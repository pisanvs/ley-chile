{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8774021}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.818, de 21 de agosto de 2009, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad total de las <a href=\"https://www.leychile.cl/Navegar?idNorma=238183&amp;idParte=&amp;idVersion=2009-08-28\">resoluciones exentas N&#xBA;1.376</a> y N&#xBA;3.205 ambas de 2005, que autorizaron a AQUAFISH S.A., para desarrollar actividades pesqueras extractivas con la nave &quot;Altar 10&quot;, matr&#xED;cula 3121, por haber incurrido en la causal de caducidad prevista en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura, de conformidad con los informes t&#xE9;cnicos citados en los Vistos de la resoluci&#xF3;n extractada.</div><br><br></div>", "i": 8774022, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de agosto de 2009.- Mar&#xED;a &#xC1;ngela Barbieri Bellolio, Subsecretaria de Pesca (S).</div><br></div>", "i": 8774023}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2818 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-2818 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-08-21", "doble_articulado": false, "id_norma": "1005508", "numero_fuente": "39448", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-08-28", "vigencias": [{"desde": "2009-08-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "20