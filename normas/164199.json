{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6260804}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 182 de fecha 19 de Julio de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la IIa. Regi&#xF3;n, se autoriza al Sr. Misael del Rosar&#xED;o Tapia Campusano para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de la Locomoci&#xF3;n Colectiva de Pasajeros.</div><br></div>", "i": 6260805}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Guido M. Ram&#xED;rez Maturana, Secretar&#xED;o Regional Ministerial de Transportes y Telecomunicaciones de la IIa. Regi&#xF3;n. Antofagasta, 19 de Julio de 1985. </div></div>", "i": 6260806}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "182", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-182"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL II REGIÓN DE ANTOFAGASTA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-07-19", "doble_articulado": false, "id_norma": "164199", "numero_fuente": "32290", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-10-07", "vigencias": [{"desde": "1985-10-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-10-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-10-07", "fin_vigencia": "", "tipo_ver