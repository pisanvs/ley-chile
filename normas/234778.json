{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; EXTRACTO DE RESOLUCION N&#xBA;12.899 EXENTA, DE 2004 </div></div>", "i": 6513524}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;12.899, de 19 de octrubre de 2004, se ha aprobado un plan especial de estudio para 1&#xBA; y 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media Human&#xED;stico-Cient&#xED;fica, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2005.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio para el Subsector de Filosof&#xED;a para 1&#xBA; y 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media.</div><br></div>", "i": 6513525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de enero de 2005.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6513526}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "12899 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-12899 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº12.899 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-19", "doble_articulado": false, "id_norma": "234778", "numero_fuente": "38062", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-01-17", "vigencias": [{"desde": "2005-01-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-01-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-01-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_po