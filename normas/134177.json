{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,110.- Santiago, 26 de octubre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 7247249}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados a la Nacion por el jeneral de la Independencia, don Juan Gregorio de las Heras, conc&#xE9;dese, por gracia, a su nieta do&#xF1;a Mar&#xED;a Teresa G. de las Heras, una pension mensual de treinta pesos de que gozar&#xE1; con arreglo a la lei de montep&#xED;o militar. </div></div>", "i": 7247250, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Ventura Blanco.</div><br></div>", "i": 7247251}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1110", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1110"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-10-26", "doble_articulado": false, "id_norma": "134177", "numero_fuente": "6140", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-11-02", "vigencias": [{"desde": "1898-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p