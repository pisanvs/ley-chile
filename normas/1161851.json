{"html": [{"t": "<div><div class=\"p\">GOBERNADOR DE VALPARAISO</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Diciembre 4 de 1832.</div></div>", "i": 10254506}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Hall&#xE1;ndose vacante el empleo de gobernador de la plaza de Valpara&#xED;so, por promoci&#xF3;n del que lo desempe&#xF1;aba al Ministro de Estado en los departamentos de Guerra y Marina, vengo en nombrar para que le subrogue interinamente a Teniente coronel de ej&#xE9;rcito don Diego Portales, con el sueldo se&#xF1;alado a los de su clase.</div></div>", "i": 10254507}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Refr&#xE9;ndese, t&#xF3;mese razon, publ&#xED;quese y circ&#xFA;lese.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  PRIETO. </div><div class=\"p\">&nbsp; &nbsp;  Joaquin Tocornal.</div></div>", "i": 10254508}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "GOBERNADOR DE VALPARAISO", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-12-04", "doble_articulado": false, "id_norma": "1161851", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-12-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-12-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-12-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "906", "fecha_ingreso": "2021-07-22", "fecha_version": "1832-12-