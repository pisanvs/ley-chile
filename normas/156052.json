{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6234331}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 204, de 28 de enero de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp;  PESQUERA OMEGA LTDA., para ampliar las actividades pesqueras extractivas con la nave &apos;&apos;Christina S&apos;&apos;, en el litoral de la I a la X Regiones, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar con trampas: Centolla del norte Lithodes wiracocha, Centolla del norte Lithodes panamensis, Centolla Neolithodes diomedae, Centoll&#xF3;n del norte Paralomis longipes, Centoll&#xF3;n del norte Paralomis papillata, Centoll&#xF3;n del norte Paralomis otsuae, Centoll&#xF3;n del norte Paralomis spinosissima, Centolla Lithodes santolla y Centoll&#xF3;n del norte Paralomis granulosa.</div><br></div>", "i": 6234332}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de enero de 2000.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 6234333}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "204", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-204"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-01-28", "fecha_derogacion": "2014-12-16", "doble_articulado": false, "id_norma": "156052", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-02-14", "vigencias": [{"desde": "2014-12-16", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2000-02-14", "hasta": "2014-12-15"