{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6099204}, {"t": "<div><div class=\"p\">El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 8,57% anual durante el mes de noviembre de 1989.</div><div class=\"p\">Asimismo, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de noviembre de 1989, fue de 8,49% anual.</div><br></div>", "i": 6099205}, {"t": "<div><div class=\"p\">Santiago, 04 de diciembre de 1989.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6099206}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE HACIENDA", "BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-12-04", "doble_articulado": false, "id_norma": "95209", "numero_fuente": "33539", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-12-05", "vigencias": [{"desde": "1989-12-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-12-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-12-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "19