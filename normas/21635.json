{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0;649, EXENTO DE 1993</div><br><br></div>", "i": 7162181}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 649 de fecha 7 de diciembre de</div><div class=\"p\">1993 del Ministerio de Educaci&#xF3;n, se sustituy&#xF3; el</div><div class=\"p\">art&#xED;culo 1&#xB0; del Decreto Exento de Educaci&#xF3;n N&#xB0; 91 del 28 de abril de 1988, correspondiente al Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Superior de Administraci&#xF3;n, por el siguiente nuevo:</div><div class=\"p\">&nbsp; &nbsp; &quot;Autor&#xED;zase el funcionamiento del Centro de Formaci&#xF3;n T&#xE9;cnica que se indica, organizado por la persona jur&#xED;dica que se se&#xF1;ala, cuyo fin es la docencia a nivel t&#xE9;cnico para egresados de ense&#xF1;anza media:</div><div class=\"p\">&nbsp; &nbsp; Nombre de la Instituci&#xF3;n: Centro de Formaci&#xF3;n T&#xE9;cnica Integraci&#xF3;n y Superaci&#xF3;n de Ays&#xE9;n.</div><div class=\"p\">&nbsp; &nbsp; Domicilio : Coyhaique.</div><div class=\"p\">&nbsp; &nbsp; Organizador: Sociedad Centro de Formaci&#xF3;n T&#xE9;cnica Integraci&#xF3;n y Superaci&#xF3;n de Ays&#xE9;n Limitada o C.F.T. ISA Ltda.&quot;.</div><br></div>", "i": 7162182}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n + </div></div>", "i": 7162183}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "649 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-649 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N°649, EXENTO DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "CENTRO FORMACION TECNICA", "INSTITUTO", "SUPERIOR", "ADMINISTRACION", "AYSEN", "CENTRO FORMACION", "TECNICA INTEGRACION SUPERACION DECIMOPRIMERA REGION"