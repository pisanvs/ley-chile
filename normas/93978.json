{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 210, DE 1988 </div></div>", "i": 6095809}, {"t": "<div><div class=\"p\">El decreto exento N&#xB0; 210 del Ministerio de Educaci&#xF3;n P&#xFA;blica de 1988 autoriz&#xF3; el cambio de la Fundaci&#xF3;n Nacional de la Cultura, por la Sociedad Educacional Luis Galdames S.A., como organizador del Instituto Profesional de Educaci&#xF3;n Superior Luis Galdames, manteni&#xE9;ndose para el Instituto Profesional, sus actuales deudas y obligaciones.- </div></div>", "i": 6095810}, {"t": "<div><div class=\"p\">Santiago, 25 de Enero de 1989. Adelchi Colombo Breschi, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 6095811}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "210 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-210 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 210, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-01-25", "doble_articulado": false, "id_norma": "93978", "numero_fuente": "33288", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-02-02", "vigencias": [{"desde": "1989-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-02-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-02-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CQA", "fecha_ingreso": "1998-03-05", "fecha_version": "1989-02-02", "fecha_actualizacion_texto": "1989-02