{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5910273}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto MOP N&#xB0; 389, de 18 de noviembre de 1993, se expropiaron los lotes de terreno N&#xB0;s. 9 y 14, superficies 7.220 m2. y 1.670 m2., roles de aval&#xFA;o 109-017 y 105-027, Comuna de Pencahue, para la obra Regad&#xED;o Pencahue, Canal Las Tizas y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Gabriel Sep&#xFA;lveda Fern&#xE1;ndez y Mar&#xED;a Raquel Contardo Castro y otros, ascendente a las cantidades de $180.009.- y $72.864.- </div></div>", "i": 5910274}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 5910275}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "389", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-389"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "DECRETO EXPROPIATORIO", "BIEN RAIZ", "PENCAHUE", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-11-18", "doble_articulado": false, "id_norma": "12955", "numero_fuente": "34740-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-12-15", "vigencias": [{"desde": "1993-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-12-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1993-12-15", "fecha_actualizacion_texto": "1993-12-15", "tipo_tratado": ""}, "alertas": [], "alerta_glob