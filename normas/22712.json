{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que rehabilita a don Jos&#xE9; Maria Barahona para que pueda tramitar su espediente de invalidez</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 21 de Enero de 1902.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949377}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Rehabil&#xED;tase al sarjento mayor de Ej&#xE9;rcito don Jos&#xE9; Mar&#xED;a Barahona para que pueda tramitar su espediente de invalidez, en conformidad a la lei de 22 de Diciembre de 1881.</div><br></div>", "i": 5949378}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Beltran Mathieu.</div><br></div>", "i": 5949379}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1520", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1520"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "QUE REHABILITA A DON JOSE MARIA BARAHONA PARA QUE PUEDA TRAMITAR SU ESPEDIENTE DE INVALIDEZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JOSE MARIA BARAHONA", "EXPEDIENTE INVALIDEZ", "TRAMITACION", "REHABILITACION POR GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1902-01-21", "doble_articulado": false, "id_norma": "22712", "numero_fuente": "7128", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1902-01-23", "vigencias": [{"desde": "1902-01-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenc