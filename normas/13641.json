{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5914147}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto M.O.P. N&#xB0; 471, de fecha 13 de octubre de 1994, se expropi&#xF3; el lote de terreno N&#xB0; 7, superficie 63.000 M2., rol de aval&#xFA;o 5015-80, Comuna de Punta Arenas, para la ejecuci&#xF3;n de la Obra Nuevo Puerto Comercial, Punta Arenas, XII Regi&#xF3;n, Bah&#xED;a Catalina y se acord&#xF3; precio de indemnizaci&#xF3;n con su propietario Astilleros y Maestranza de la Armada (ASMAR), ascendente a la cantidad de $397.787.280.</div><br></div>", "i": 5914148}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 5914149}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "471", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-471"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DECRETO EXPROPIATORIO", "EXPROPIACION", "BIEN INMUEBLE", "BIEN RAIZ", "PUNTA ARENAS", "DECIMO SEGUNDA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-10-13", "doble_articulado": false, "id_norma": "13641", "numero_fuente": "35005-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-11-02", "vigencias": [{"desde": "1994-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1994-11-02", "fecha_actualizacion_texto": "1994-11-02", "tipo_tratado": ""}, "alertas":