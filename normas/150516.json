{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6216347}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta</div><div class=\"p\">No. 590 de 13.05.87, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de</div><div class=\"p\">Aguas determin&#xF3; derechos de Aprovechamiento de Aguas</div><div class=\"p\">proporcionales que corresponden a sectores excluidos y</div><div class=\"p\">expropiados de predios &quot;Hijuela Primera o el Maitenal de la</div><div class=\"p\">Trinidad&quot; e &quot;Hijuela Segunda San Guillermo de la Trinidad&quot;,</div><div class=\"p\">de la Comuna de Limache, Quinta Regi&#xF3;n. Los derechos de agua</div><div class=\"p\">se extraen del Canal Waddignton.- Publicaci&#xF3;n hecha conforme</div><div class=\"p\">Art. 13 Ley No. 18.377.</div><br></div>", "i": 6216348}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6216349}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "590 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-590 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-05-13", "doble_articulado": false, "id_norma": "150516", "numero_fuente": "32784", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-01", "vigencias": [{"desde": "1987-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-01", "fin_vigencia": ""}, "vi