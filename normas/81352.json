{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8312251}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 1.381, de 09 de Noviembre de 1990 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se rectifica el numeral 1&#xB0; de la Resoluci&#xF3;n No. 425, de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don JOSE RENE SERON, domiciliado en calle E. Riquelme Quenuir, Comuna de Maull&#xED;n, para iniciar actividades pesqueras de cultivo de algas del g&#xE9;nero Gracilaria, en el sentido de indicar que el RUT del interesado es el No. 2.314.392-5, y no el que err&#xF3;neamente se consigna en dicha Resoluci&#xF3;n. </div></div>", "i": 8312252}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 09 de Noviembre de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8312253}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1381", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1381"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1990-11-09", "fecha_derogacion": "1996-07-17", "doble_articulado": false, "id_norma": "81352", "numero_fuente": "33832", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1990-11-30", "vigencias": [{"desde": "1996-07-17", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1990-11-30", "hasta": "1996-07-16", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1996-07-17", "fin_vigenc