{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,013.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6175486}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados al pais por el teniente-coronel don Eleuterio Ramirez, conc&#xE9;dese, por gracia, a sus nietos se&#xF1;ores don Arturo, don Enrique i do&#xF1;a Adriana Ram&#xED;rez Baeza, una pension anual de dos mil cuatrocientos pesos ($ 2,400), de que gozar&#xE1;n con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6175487}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintisiete de agosto de mil novecientos quince.- Ramon Barros Luco.- Guillermo Soublette. </div></div>", "i": 6175488}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3013", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3013"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1915-08-27", "doble_articulado": false, "id_norma": "138471", "numero_fuente": "11261", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1915-09-04", "vigencias": [{"desde": "1915-09-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1915-09-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig