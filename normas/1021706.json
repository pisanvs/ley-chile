{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N O N&#xBA; 3.080 QUE DISPONE LA NOTIFICACI&#xD3;N POR AVISO A LAS PERSONAS QUE INDIVIDUALIZA SOBRE TRANSPARENCIA, L&#xCD;MITE Y CONTROL DEL GASTO ELECTORAL</div></div>", "i": 9091938}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n O N&#xBA; 3.080, de 10 de diciembre de 2010, el Servicio Electoral dispuso la notificaci&#xF3;n por aviso a las personas individualizadas a continuaci&#xF3;n, respecto de las actos administrativos que se indican, relacionados con la ley N&#xBA; 19.884, sobre Transparencia, L&#xED;mite y Control del Gasto Electoral, y la ley N&#xBA; 20.285, sobre Acceso a la Informaci&#xF3;n P&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/15556.jpg\">.</div><br></div>", "i": 9091939}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div></div>", "i": 9091940}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3080", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3080"}, {"tipo": "3", "numero": "O-3080", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-3080"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN O Nº 3.080 QUE DISPONE LA NOTIFICACIÓN POR AVISO A LAS PERSONAS QUE INDIVIDUALIZA SOBRE TRANSPARENCIA, LÍMITE Y CONTROL DEL GASTO ELECTORAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-10", "doble_articulado": false, "id_norma": "1021706", "numero_fuente": "39849", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacio