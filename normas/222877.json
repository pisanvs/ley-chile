{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6697617}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En conformidad a los decretos supremos N&#xB0;s. 121 de 1967 y 808 de 1969 (V. y U.), f&#xED;janse los siguientes valores, por el per&#xED;odo que se indica:</div><br><div class=\"p\">a)&nbsp; Valor Provisional de la Cuota de Ahorro en $782,82 (setecientos ochenta y dos pesos coma ochenta y dos centavos).</div><div class=\"p\">&nbsp; &nbsp; Per&#xED;odo de vigencia: 11 de abril de 2004 al 10 de mayo de 2004.</div><div class=\"p\">b)&nbsp; Valor Provisional de la Unidad Reajustable en $136,37 (ciento treinta y seis pesos coma treinta y siete centavos).</div><div class=\"p\">&nbsp; &nbsp; Per&#xED;odo de vigencia: 1 de abril de 2004 al 30 de abril de 2004.</div><br></div>", "i": 6697618}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Saluda atentamente a usted, Sonia Tschorne Berestesky, Subsecretaria de Vivienda y Urbanismo. </div></div>", "i": 6697619}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "AVI-S/N"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CUOTA DE AHORRO", "UNIDAD REAJUSTABLE", "VIVIENDAS ECONOMICAS", "VALOR PROVISIONAL", "ABR-MAY-2004", "FIJACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "222877", "numero_fuente": "37817", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-22", "vigencias": [{"desde": "2004-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-03-22", "fin_vigencia": "