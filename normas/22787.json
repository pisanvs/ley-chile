{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que declara libres de derechos de internacion las sales pot&#xE1;sicas destinadas a abonos agr&#xED;colas Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7164256}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se declaran libres de derechos de internacion las sales pot&#xE1;sicas destinadas esclusivamente a ser empleadas como abono en la agricultura.</div><br></div>", "i": 7164257}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 29 de Julio de 1903.- JERMAN RIESCO.- Manuel Salinas.</div><br></div>", "i": 7164258}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1607", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1607"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "QUE DECLARA LIBRES DE DERECHOS DE INTERNACION LAS SALES POTÁSICAS DESTINADAS A ABONOS AGRÍCOLAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SALES POTASICAS", "USO AGRICOLA", "DERECHOS INTERNACION", "EXENCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1903-07-29", "doble_articulado": false, "id_norma": "22787", "numero_fuente": "7652", "tipo_version": "3", "tipo_version_s": "Ún