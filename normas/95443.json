{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7229688}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta N&#xB0; 3 de 20 de Enero de 1989 se cancel&#xF3; la resoluci&#xF3;n N&#xB0; 889 de 16 de Julio de 1985 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Va. Regi&#xF3;n que autoriz&#xF3; a la Sociedad Centromotori Ltda. para efectuar las revisiones t&#xE9;cnicas de los veh&#xED;culos de transporte de personas de m&#xE1;s de nueve (9) asientos, incluido el del conductor; de veh&#xED;culos motorizados de carga con capacidad para transportar m&#xE1;s de 1.750 kilos, sus remolques y semirremolques y los taxis, en el establecimiento ubicado en calle Angamos s/n&#xB0;, Barrancas, Comuna de San Antonio.</div><br></div>", "i": 7229689}, {"t": "<div><div class=\"p\">Valpara&#xED;so 20 de Enero de 1989.- Hern&#xE1;n V&#xE1;squez Wacquez, Secretario Regional Ministerial de Transportes y Telecomunicaciones Va. Regi&#xF3;n.</div><br></div>", "i": 7229690}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-01-20", "doble_articulado": false, "id_norma": "95443", "numero_fuente": "33309", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-02-27", "vigencias": [{"desde": "1989-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-02-27", "fin_vigencia