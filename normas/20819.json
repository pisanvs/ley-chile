{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 255 EXENTO, DE 1995 </div></div>", "i": 5943218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 255 de 26 de abril de 1995, se ha aprobado un plan especial de estudio al Colegio &quot;Carmen Mc Phee&quot;, de la comuna de Providencia, Regi&#xF3;n Metropolitana, para la Ense&#xF1;anza B&#xE1;sica y Media Human&#xED;stico-Cient&#xED;fica, el que se aplicar&#xE1; a partir del presente a&#xF1;o escolar.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa para la asignatura de Computaci&#xF3;n.</div><br></div>", "i": 5943219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 9 de mayo de 1995.- Jaime P&#xE9;rez de Arce, Subsecretario de Educacion.</div><br></div>", "i": 5943220}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "255", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-255"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 255 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIO", "COLEGIO CARMEN MC PHEE", "PROVIDENCIA", "REGION METROPOLITANA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-04-26", "doble_articulado": false, "id_norma": "20819", "numero_fuente": "35171", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-05-19", "vigencias": [{"desde": "1995-05-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-05-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-05-19", "fin_vigencia": "", "tipo_version": "3"}], "eve