{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6296822}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.832, de 28 de abril de 2000, se expropiaron los lotes de terreno N&#xBA;s. 3, 4, 5 y 6, superficies 993,1; 5.138,8; 5.269,6 y 10.813,7, roles de aval&#xFA;os 541-626, 541-625, 541-662 y 541-665, comuna de Saavedra, para la obra Camino Costero Sur, Sector Puerto Saavedra - Porma, Tramo Tranapuente - Puerto Saavedra - Chelle, Km. 53.250,000 - Km. 56.315,096 y Km. 65.260,000 - Km. 100.240,000 y se acord&#xF3; precio de la indemnizaci&#xF3;n con sus propietarios Jorge Ren&#xE9; Carrillo Valencia, Marcos Leonardo Carmona Angulo y Elia Edith Carmona Contreras en las cantidades de $909.188, lote N&#xBA; 3;</div><div class=\"p\">$5.226.752, lotes N&#xBA;s. 4 y 6 y $1.767.277, lote N&#xBA; 5. </div></div>", "i": 6296823}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6296824}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1832", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1832"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-28", "doble_articulado": false, "id_norma": "174307", "numero_fuente": "36740", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-16", "vigencias": [{"desde": "2000-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-08-16", "fin_v