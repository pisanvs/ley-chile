{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292630}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n n&#xFA;mero 465, de 13 de Mayo de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a don ARNOLDO MARIA POBLETE LARA, R.U.T. N&#xB0; 2.957.102-3, para ampliar las actividades de pesca autorizadas por Resoluci&#xF3;n N&#xB0; 1.401, de 1990 y N&#xB0; 377, de 1991, ambas de esta Subsecretar&#xED;a, en orden a operar la nave &quot;Monserrat&quot;, en el litoral de las Regiones que se se&#xF1;alan a continuaci&#xF3;n, donde podr&#xE1; extraer los siguientes recursos hidrobiol&#xF3;gicos:</div><div class=\"p\">&nbsp; _____________________________________________________</div><div class=\"p\"> | NOTA: VER DIARIO OFICIAL N&#xB0; 34.881 DE 04 DE JUNIO&nbsp;  |</div><div class=\"p\"> |&nbsp; &nbsp; &nbsp;  DE 1994, PAGINA 2.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; |</div><div class=\"p\"> |_____________________________________________________|</div><br></div>", "i": 8292631}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 13 de Mayo de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292632}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "465", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-465"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ARNOLDO MARIA POBLETE LARA", "PESCA", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-05-1