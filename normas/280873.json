{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACI&#xD3;N TOTAL DE INMUEBLE QUE INDICA NOTIFICACI&#xD3;N </div></div>", "i": 6797015}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 817, de 28 de julio de 2008, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme D.L. N&#xBA;2.186 de 1978, del Lote N&#xBA; 27, correspondiente a la totalidad del inmueble ubicado en F. Vivaceta N&#xBA; 3039, Rol de Aval&#xFA;o N&#xBA;2234-12, de la Comuna de Conchal&#xED;, aparente dominio de Carrasco V&#xE1;squez Claudio Domingo. Comisi&#xF3;n integrada por peritos se&#xF1;ores Victoria Blanco Costa, arquitecto; Samantha Aldunce Dastres, Constructor Civil y Norma Calder&#xF3;n Pontiggia, ingeniero agr&#xF3;nomo. Seg&#xFA;n informe de 30 de mayo de 2008, fij&#xF3; monto provisional indemnizaci&#xF3;n en $81.003.470.-, pagadera al contado.</div><br></div>", "i": 6797016}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director (S), Serviu Metropolitano.</div><br></div>", "i": 6797017}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "817", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-817"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "ORDENA EXPROPIACIÓN TOTAL DE INMUEBLE QUE INDICA; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-07-28", "doble_articulado": false, "id_norma": "280873", "numero_fuente": "39202", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-11-03", "vigencias": [{"desde": "2008-11-03", "hasta": "", "tipo_version": "3", "ti