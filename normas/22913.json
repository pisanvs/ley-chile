{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede un suplemento al Presupuesto del Interior.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1785.- Santiago, a 29 de Diciembre de 1905.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274679}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Conc&#xE9;dese un suplemento de veinte mil pesos ($20 000) al &#xED;tem 2805 de la partida 81 del presupuesto del Ministerio del Interior para la Construccion de una doble l&#xED;nea entre Antofagasta i Pueblo Hundido.</div><br></div>", "i": 8274680}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Miguel Cruchaga.</div><br></div>", "i": 8274681}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1785", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1785"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE UN SUPLEMENTO AL PRESUPUESTO DEL INTERIOR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1905", "MODIFICACION", "MINISTERIO", "INTERIOR", "FERROCARRIL ANTOFAGASTA-PUEBLO HUNDIDO", "DOBLE", "LINEA", "CONSTRUCCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-12-29", "doble_articulado": false, "id_norma": "22913", "numero_fuente": "8393", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-12-30", "vigencias": [{"desde": "1905-12-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}