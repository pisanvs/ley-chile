{"html": [{"t": "<div><div class=\"p\">AUMENTA LA TASA DEL IMPUESTO TERRITORIAL EN LA COMUNA DE LICANTEN</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 3,130.- Santiago, 16 de Junio de 1959.- Vistos estos antecedentes y lo dispuesto en el inciso segundo del art&#xED;culo 119 de la ley N.o 13,305, publicada en el &quot;Diario Oficial&quot; de 6 de Abril de 1959,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 8373500}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Decl&#xE1;rase que el aumento de la tasa del impuesto</div><div class=\"p\">territorial establecido en el inciso primero del</div><div class=\"p\">art&#xED;culo 119 de la ley N.o 13,305 es del uno por mil en la comuna de Licant&#xE9;n.</div><br></div>", "i": 8373501}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- Por orden del Presidente, S&#xF3;tero del R&#xED;o G.</div><br></div>", "i": 8373502}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3130", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3130"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUMENTA LA TASA DEL IMPUESTO TERRITORIAL EN LA COMUNA DE\nLICANTEN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1959-06-16", "doble_articulado": false, "id_norma": "247374", "numero_fuente": "24395", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1959-07-18", "vigencias": [{"desde": "1959-07-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1959-07-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1959-07-18", "fin_