{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 39, DE 1987 </div></div>", "i": 7252548}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 39 de</div><div class=\"p\">25 de febrero de 1987 se han aprobado, a contar del</div><div class=\"p\">presente a&#xF1;o escolar, planes especiales de estudio y sus</div><div class=\"p\">respectivos programas para el Centro Vocacional</div><div class=\"p\">Artesanal Rural, particular &quot;Alberto Hurtado Cruchaga&quot;, de la localidad de Padre Hurtado, comuna de Pe&#xF1;aflor, correspondientes a los cursos de 7&#xB0; y 8&#xB0; a&#xF1;o de Educaci&#xF3;n General B&#xE1;sica y 1&#xB0; y 2&#xB0; a&#xF1;o de Educaci&#xF3;n Media, modalidad T&#xE9;cnico-Profesional.</div><br></div>", "i": 7252549}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 06 de Marzo 1987.- Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 7252550}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "39 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-39 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 39, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-25", "doble_articulado": false, "id_norma": "141582", "numero_fuente": "32725", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-03-18", "vigencias": [{"desde": "1987-03-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-03-18", "fin_vigencia": ""}, "vigencia