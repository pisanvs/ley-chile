{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8290371}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 113, de 16 de enero de 1996, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por INVERSIONES Y ASESORIAS EL MANANTIAL LTDA., para operar un centro de cultivo ubicado al Noreste del Islote Poe, Estero Reloncav&#xED;, Comuna de Cocham&#xF3;, Provincia de Llanquihue, X Regi&#xF3;n, en virtud a lo dispuesto en el art&#xED;culo 78&#xB0; inciso 2&#xB0; de la Ley General de Pesca y Acuicultura por sobreponerse parcialmente con otra solicitud de concesi&#xF3;n de acuicultura de mejor prelaci&#xF3;n. </div></div>", "i": 8290372}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 16 de enero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8290373}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "113", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-113"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "INVERSIONES", "ASESORIAS EL MANANTIAL LTDA.", "COCHAMO", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-01-16", "doble_articulado": false, "id_norma": "33209", "numero_fuente": "35375", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-01-25", "vigencias": [{"desde": "1996-01-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "