{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 12.879 EXENTA, DE 1999 </div></div>", "i": 6303794}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 12.879 de 29 de diciembre de 1999, se ha aprobado al Instituto &apos;&apos;Hebreo&apos;&apos; de Santiago, un plan y programa especial de estudio, para 2&#xBA; a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1;, en ambos cursos, a partir del a&#xF1;o escolar 2000, seg&#xFA;n el decreto supremo de Educaci&#xF3;n N&#xBA; 220, de 1998 y sus modificaciones.</div><br></div>", "i": 6303795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de marzo de 2000.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6303796}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "12879 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-12879 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 12.879 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-29", "doble_articulado": false, "id_norma": "176479", "numero_fuente": "36780", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-05", "vigencias": [{"desde": "2000-10-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-10-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-10-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "i