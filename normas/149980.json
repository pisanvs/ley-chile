{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 128, DE 1987 </div></div>", "i": 6214462}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 128 de 11 de junio de 1987 se ha aprobado para la Escuela Industrial &quot;San Jos&#xE9;&quot;, de la comuna de Villarrica, provincia de Caut&#xED;n, IX Regi&#xF3;n de La Araucan&#xED;a, un Plan y Programa Especial de Estudio para la Educaci&#xF3;n Media, modalidad T&#xE9;cnico - Profesional, que se aplicar&#xE1; gradualmente a contar del a&#xF1;o escolar 1987 y hasta el a&#xF1;o escolar de 1992, en la Especialidad de Mec&#xE1;nica de Combusti&#xF3;n Interna y Automotriz. </div></div>", "i": 6214463}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de Junio de 1987.- Ren&#xE9; Salam&#xE9; Mart&#xED;n, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6214464}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "128 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-128 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 128, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-11", "doble_articulado": false, "id_norma": "149980", "numero_fuente": "32805", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-26", "vigencias": [{"desde": "1987-06-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-06-26", "fin_vigencia": "", "tipo_version": "3"