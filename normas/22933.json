{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede vi&#xE1;ticos a los inspectores de las oficinas fiscales i municipales.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1811.- Santiago, a 7 de Febrero de 1906.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5951263}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Los inspectores de oficinas fiscales i los inspectores de tesorer&#xED;as municipales gozar&#xE1;n de un vi&#xE1;tico de diez pesos diarios mi&#xE9;ntras permanezcan fuera de la capital en el desempe&#xF1;o de sus funciones. </div></div>", "i": 5951264}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Belfor Fernandez.</div><br></div>", "i": 5951265}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1811", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1811"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE VIATICOS A LOS INSPECTORES DE LAS OFICINAS FISCALES I MUNICIPALES.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSPECTORES OFICINAS FISCALES", "INSPECTORES", "TESORERIAS MUNICIPALES", "VIATICOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-02-07", "doble_articulado": false, "id_norma": "22933", "numero_fuente": "8426", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1906-02-09", "vigencias": [{"desde": "1906-02-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], 