{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 368 EXENTA, DE 2000 </div><br></div>", "i": 6259429}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;368, de 28 de marzo de 2000, de la Subsecretar&#xED;a de Telecomunicaciones, Ministerio de Transportes y Telecomunicaciones, que se extracta, se prorrog&#xF3; para el 24 de mayo del a&#xF1;o 2000 la fecha para la recepci&#xF3;n y apertura de las propuestas del concurso p&#xFA;blico para otorgar concesiones de servicio p&#xFA;blico telef&#xF3;nico inal&#xE1;mbrico en la banda 3.400-3.700 MHz.-</div><br></div>", "i": 6259430}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Subsecretar&#xED;a de Telecomunicaciones.</div><br></div>", "i": 6259431}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "368 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-368 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TELECOMUNICACIONES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-03-28", "doble_articulado": false, "id_norma": "163772", "numero_fuente": "36629", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-01", "vigencias": [{"desde": "2000-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2000-04-03", "fecha_version": "2000-04-01", "fecha_actuali