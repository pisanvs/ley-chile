{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8323890}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 54, de 19 de enero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 600, de 1995, de esta Subsecretar&#xED;a, que autoriz&#xF3; a&nbsp; SOCIEDAD PESQUERA HORIZONTE LTDA., para desarrollar actividades pesqueras con la nave &quot;Don Peter&quot;, en el sentido de actualizar las caracter&#xED;sticas n&#xE1;uticas de esta &#xFA;ltima, en los t&#xE9;rminos que se indica:</div><br><div class=\"p\">Nombre&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &quot;Don Peter&quot;</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  1987</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; 22 m.</div><div class=\"p\">T.R.G.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 81,9 t.</div><div class=\"p\">Capacidad de bodega&nbsp;  138,3 m3.</div><div class=\"p\">Arte de pesca&nbsp; &nbsp; &nbsp; &nbsp;  Cerco</div><br></div>", "i": 8323891}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de enero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8323892}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "54", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-54"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "AUTORIZACION", "SOCIEDAD PESQUERA HORIZONTE LTDA.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado