{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DISPONE QUE EL LICEO DE HOMBRES N&#xB0; 1 DE CONCEPCION, SE DENOMINARA &quot;LICEO DE HOMBRES ENRIQUE MOLINA GARMENDIA&quot;</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5973301}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Denom&#xED;nase &quot;Liceo de Hombres Enrique Molina Garmendia&quot; al Liceo de Hombres N&#xB0; 1 de Concepci&#xF3;n&quot;.</div><br></div>", "i": 5973302}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diez de octubre de mil novecientos cincuenta y nueve.- JORGE ALESSANDRI RODRIGUEZ.- Francisco Cereceda.</div><br></div>", "i": 5973303}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13594", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13594"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "DISPONE QUE EL LICEO DE HOMBRES N° 1 DE CONCEPCION, SE DENOMINARA LICEO DE HOMBRES ENRIQUE MOLINA GARMENDIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMBRE", "LICEO HOMBRES ENRIQUE MOLINA GARMENDIA", "CONCEPCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1959-10-10", "doble_articulado": false, "id_norma": "27524", "numero_fuente": "24475", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1959-10-24", "vigencias": [{"desde": "1959-10-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"