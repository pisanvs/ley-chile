{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 860 EXENTO, DE 1998</div><br><br><br></div>", "i": 7238598}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 860 de 28 de agosto de 1998, se ha validado, por &#xFA;nica vez y por v&#xED;a de excepci&#xF3;n, los estudios realizados por las alumnas de 1&#xBA; y 4&#xBA; a&#xF1;o medio, a&#xF1;o escolar 1997, en el Colegio &apos;&apos;Instituci&#xF3;n Teresiana&apos;&apos; de la comuna de Las Condes, provincia de Santiago, Regi&#xF3;n Metropolitana, de acuerdo al decreto supremo exento de Educaci&#xF3;n N&#xBA; 1.216 de 1997.</div><br></div>", "i": 7238599}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de septiembre de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7238600}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "860 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-860 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 860 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO INSTITUCION TERESIANA", "LAS CONDES", "ALUMNAS", "VALIDACION DE ESTUDIOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-28", "doble_articulado": false, "id_norma": "124089", "numero_fuente": "36162", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-09-10", "vigencias": [{"desde": "1998-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-09-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-09-10", "fin_vigencia": "", "tipo_