{"html": [{"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  ELECCION POPULAR DE CABILDOS.</div><br><div class=\"p\">&nbsp; &nbsp;  EL PRESIDENTE DE LA REPUBLICA DE CHILE.</div><br><div class=\"p\">&nbsp; &nbsp;  47 Por cuanto el Soberano Congreso Nacional ha decretado lo siguiente:</div></div>", "i": 9486613}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1.&#xB0; &quot;Los pueblos elejir&#xE1;n popularmente sus cabildos.</div><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; La eleccion se har&#xE1; el mismo dia que la de los gobernadores, y en la misma forma.&quot;</div></div>", "i": 9486614}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por tanto, ordeno que se publique por lei insert&#xE1;ndose en el Boletin. Dado en el Palacio de Gobierno en Santiago a 27 de Julio de 1826.</div><br><div class=\"p\">&nbsp; &nbsp;  Blanco.</div><br><div class=\"p\">&nbsp; &nbsp;  Ventura Blanco Encalada</div></div>", "i": 9486615}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "S/N", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "Ley-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "ELECCION POPULAR DE CABILDOS", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1826-07-27", "doble_articulado": false, "id_norma": "1063096", "numero_fuente": "1826", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1826-07-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1826-07-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1826-07-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "in