{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.747, DE 1988 </div></div>", "i": 7243650}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 1.747 de fecha 01 de Julio de</div><div class=\"p\">1988, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se modific&#xF3; el</div><div class=\"p\">art&#xED;culo 1&#xB0; de la Resoluci&#xF3;n Exenta de Educaci&#xF3;n No. 1.206 de 1986 del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Superior de Estudios Jur&#xED;dicos Canon de Santiago, en el sentido de modificar la secuencialidad curricular de la carrera T&#xE9;cnico Jur&#xED;dico, autorizando plan especial de estudios del 1&#xB0; y 2&#xB0; nivel efectuado desde el 24 de agosto de 1987 al 11 de enero de 1988, s&#xF3;lo para los alumnos que cursaron en forma regular su 3&#xB0; y 4&#xB0; nivel de la carrera en 1985.-</div><br></div>", "i": 7243651}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7243652}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1747 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1747 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.747, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-07-01", "doble_articulado": false, "id_norma": "129413", "numero_fuente": "33144", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-08-10", "vigencias": [{"desde": "1988-08-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigen