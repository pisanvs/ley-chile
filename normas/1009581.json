{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA A INSTITUCI&#xD3;N SIN FINES DE LUCRO COMO DISTRIBUIDORA DE ALIMENTOS CUYA COMERCIALIZACI&#xD3;N SEA INVIABLE</div></div>", "i": 8816240}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 191, del 21 de diciembre, que autoriza a la instituci&#xF3;n sin fines de lucro como distribuidora de alimentos cuya comercializaci&#xF3;n sea inviable.</div><div class=\"p\">&nbsp; &nbsp;  La entidad autorizada al efecto corresponde a Rol &#xDA;nico Tributario N&#xBA; 65.018.488-2.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en diciembre de 2009.</div></div>", "i": 8816241}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "191 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-191 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SUBSECRETARÍA DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A INSTITUCIÓN SIN FINES DE LUCRO COMO DISTRIBUIDORA DE ALIMENTOS CUYA COMERCIALIZACIÓN SEA INVIABLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-12-21", "doble_articulado": false, "id_norma": "1009581", "numero_fuente": "39545", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-12-26", "vigencias": [{"desde": "2009-12-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-12-26", "fin_vigenci