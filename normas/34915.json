{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292678}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 472, de 8 de Julio de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case la Resoluci&#xF3;n N&#xB0; 1.133, de 1992, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA EL GOLFO S.A., para desarrollar actividades extractivas con la nave &quot;Saint John&quot;, en el sentido de se&#xF1;alar sus actuales caracter&#xED;sticas n&#xE1;uticas.</div><div class=\"p\">&nbsp; &nbsp; D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 1.437, de 1992, de esta Subsecretar&#xED;a, atendido el tenor de la Resoluci&#xF3;n N&#xB0; 1.133, citada en Visto.</div><br></div>", "i": 8292679, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 8 de Julio de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8292680}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "472", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-472"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "PESCA", "PESQUERA GOLFO S.A.", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1993-07-08", "fecha_derogacion": "2012-03-28", "doble_articulado": false, "id_norma": "34915", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1993-07-17", "vigencias": [{"desde": "2012-03-28", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1993-07-17", "hasta": "2012-03-27", "t