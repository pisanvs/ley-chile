{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297646}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.529, de 26 de Octubre de 1995,</div><div class=\"p\">de esta esta Subsecretar&#xED;a de Pesca del Ministerio de</div><div class=\"p\">Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la</div><div class=\"p\">solicitud de concesi&#xF3;n de acuicultura presentada por</div><div class=\"p\">AQUASUR FISHERIES SOCIEDAD PESQUERA LTDA., R.U.T. N&#xB0;</div><div class=\"p\">79.728.530-7, para el centro de cultivo ubicado al Este</div><div class=\"p\">de Isla Traigu&#xE9;n, Canal Costa, Comuna y Provincia de</div><div class=\"p\">Ays&#xE9;n, XI Regi&#xF3;n, por no haberse aprobado el respectivo</div><div class=\"p\">proyecto t&#xE9;cnico, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 67, inciso 5&#xB0;, de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8297647}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 26 de Octubre de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297648}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1529", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1529"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION ACUICULTURA", "DENEGACION", "AQUASUR FISHERIES", "SOCIEDAD PESQUERA LTDA."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-10-26", "doble_articulado": false, "id_norma": "37116", "numero_fuente": "35308", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion":