{"html": [{"t": "<div><div class=\"p\">MODIFICA EL D.F.L. N.o 244, DE 1931, QUE APROBO LA LEY GENERAL DE SERVICIOS ELECTRICOS</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br><br></div>", "i": 8368065}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo 1.o Supr&#xED;mese del art&#xED;culo 64 del decreto con fuera de la ley N.o 244, publicado en el Diario Oficial de fecha 30 de Mayo de 1931, las palabras: &quot;de servicio p&#xFA;blico&quot;.</div><br></div>", "i": 8368066, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo 2.o Esta ley comenzar&#xE1; a regir desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><br></div>", "i": 8368067}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, diez de Septiembre de mil novecientos cuarenta y uno.- PEDRO AGUIRRE CERDA.- Arturo Olavarr&#xED;a B.</div><br></div>", "i": 8368068}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "7052", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-7052"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA EL D.F.L. N.o 244, DE 1931, QUE APROBO LA LEY\nGENERAL DE SERVICIOS ELECTRICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1941-09-05", "doble_articulado": false, "id_norma": "202032", "numero_fuente": "19068", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacio