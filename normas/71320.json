{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6036664}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 386 de 24 de abril de 1997 de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xBA; 2.186 de 1978, de parte del inmueble ubicado en Avda. Domingo Santa Mar&#xED;a N&#xBA; 4078, 4078-A y 4080 (ex 4078-B), presunto rol de aval&#xFA;os N&#xBA; 469-23 comuna de Renca, de aparente dominio de don Jorge Gonz&#xE1;lez Zamorano. Comisi&#xF3;n integrada por peritos Sra. Patricia Zavala Contreras, constructor civil, Jorge Navarro Navarrete, arquitecto y Ram&#xF3;n Undurraga Montes, ingeniero civil seg&#xFA;n informe de 5 de febrero de 1997 fij&#xF3; monto provisional de indemnizaci&#xF3;n en $5.059.800.- pagadera al contado.</div><br></div>", "i": 6036665}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Director SERVIU Metropolitano.</div><br></div>", "i": 6036666}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "386", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-386"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "RENCA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-24", "doble_articulado": false, "id_norma": "71320", "numero_fuente": "35766", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-15", "vigencias": [{"desde": "1997-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-15", "fin_vigencia": ""}, "vigencias_vers