{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291901}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 340, de 19 de Febrero de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a PESQUERA EL GOLFO</div><div class=\"p\">S.A., para ampliar las actividades pesqueras que tiene</div><div class=\"p\">autorizadas por las Resoluciones N&#xB0; 1.150, de 1988 y N&#xB0;</div><div class=\"p\">535, de 1992, ambas de esta Subsecretar&#xED;a, en orden a</div><div class=\"p\">operar la nave &quot;Queil&#xE9;n&quot;, autorizada por las</div><div class=\"p\">Resoluciones se&#xF1;aladas precedentemente, en el litoral de</div><div class=\"p\">la III y IV Regi&#xF3;n, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, con cerco el recurso hidrobiol&#xF3;gico Jurel.</div><div class=\"p\">&nbsp; &nbsp; La presente autorizaci&#xF3;n es sin perjuicio de las que corresponda conferir a otras autoridades, de acuerdo a las disposiciones legales y reglamentarias vigentes o que se establezcan.</div><br></div>", "i": 8291902}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 19 de Febrero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8291903}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "340", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-340"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA EL GOLFO S.A.", "AMPLIACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "