{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6163263}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 652, de fecha 10 de Agosto de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Miguel Gangas Inostroza para efectuar el servicio p&#xFA;blico urbano de locomoci&#xF3;n colectiva de pasajeros en la ciudad de Valdivia, L&#xED;nea No. 5, cuyo trazado fue autorizado por reroluci&#xF3;n No.</div><div class=\"p\">83, de 29 de Abril de 1982, y modificado por reroluci&#xF3;n No. 245, de 21 de abril de 1986, ambas de esta Secretaria Regional.-</div><br></div>", "i": 6163264}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6163265}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "652 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-652 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-10", "doble_articulado": false, "id_norma": "134723", "numero_fuente": "33012", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-03-04", "vigencias": [{"desde": "1988-03-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-03-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig