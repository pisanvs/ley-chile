{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 937 EXENTA, DE 2014</div></div>", "i": 9414142}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 937, de 26 de febrero de 2014, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Servicios de Capacitaci&#xF3;n Coaching All Sociedad An&#xF3;nima (Coaching All S.A.)&quot;, RUT 76.192.711-6 contenida en la resoluci&#xF3;n exenta N&#xBA; 7.416 de 23 de agosto de 2012, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.</div></div>", "i": 9414143}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (S).</div></div>", "i": 9414144}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "937 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-937 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 937 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-02-26", "doble_articulado": false, "id_norma": "1060156", "numero_fuente": "40803", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-03-10", "vigencias": [{"desde": "2014-03-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-03-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014-03-10", "fin_vigencia