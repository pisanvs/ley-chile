{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7294790}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.213 de 11 de octubre de 2002 de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 722 de 1993, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA QUINTERO S.A. a operar la nave &quot;Crusoe I&quot;, sobre el recurso Raya en el &#xE1;rea mar&#xED;tima correspondiente a la VIII Regi&#xF3;n, ello en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura, y del memor&#xE1;ndum de la Divisi&#xF3;n de Desarrollo Pesquero de esta Subsecretar&#xED;a, citado en Visto.</div><br></div>", "i": 7294791}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de octubre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7294792}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2213", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2213"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-10-11", "doble_articulado": false, "id_norma": "203690", "numero_fuente": "37386", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-10-18", "vigencias": [{"desde": "2002-10-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-10-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-10-18", "fin_vigencia": "", "tipo_version": "3"}], "