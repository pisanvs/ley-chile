{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 198, DE 1993 </div><br></div>", "i": 7161087}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 198 de fecha 30 de Abril de 1993 del Ministerio de Educaci&#xF3;n, se sustituy&#xF3; el Art&#xED;culo 1&#xB0; del Decreto Exento N&#xB0; 36 de 1990 correspondiente al Instituto Profesional de Desarrollo Regional Los Leones, por el siguiente nuevo:</div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1&#xB0;: Autor&#xED;zase el funcionamiento del Instituto Profesional que se indica, organizado por la persona jur&#xED;dica que se se&#xF1;ala:</div><div class=\"p\"> Nombre de la Instituci&#xF3;n&nbsp;  : Instituto Profesional Los</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Leones.</div><div class=\"p\"> Domicilio&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Santiago.</div><div class=\"p\"> Organizador&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Sociedad Instituto</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Profesional Los Leones</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Limitada o I.P. Los Leones</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Ltda.&quot;.-</div><br></div>", "i": 7161088}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n. + </div></div>", "i": 7161089}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "198 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-198 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"]