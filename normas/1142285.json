{"html": [{"t": "<div><div class=\"p\">ESTABLECE LA OBLIGACI&#xD3;N DE DECLARAR LOS FORMULARIOS N&#xDA;MEROS 29 Y 50 A TRAV&#xC9;S DE INTERNET</div></div>", "i": 10100042}, {"t": "<div><br><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 19, del 6 de febrero de 2020, que dispone:</div><div class=\"p\">&nbsp; &nbsp;  Los formularios N 29 y 50, de declaraci&#xF3;n mensual y pago simult&#xE1;neo de impuestos, deber&#xE1;n presentarse &#xFA;nicamente a trav&#xE9;s de internet en la p&#xE1;gina web del Servicio de Impuestos Internos: www.sii.cl, cuyas instrucciones se encontrar&#xE1;n disponibles en el mismo sitio.os</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos internos en internet (www.sii.cl).</div><br></div>", "i": 10100043}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "19 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-19 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ESTABLECE LA OBLIGACIÓN DE DECLARAR LOS FORMULARIOS NÚMEROS 29 Y 50 A TRAVÉS DE INTERNET", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1724926; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-02-06", "doble_articulado": false, "id_norma": "1142285", "numero_fuente": "42577", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-02-12", "vigencias": [{"desde": "2020-02-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"in