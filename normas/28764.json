{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DENOMINA JULIA GARAY GUERRA A LA CALLE SE&#xD1;ORET PLAYA DE LA CIUDAD DE PUNTA ARENAS</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 8283732}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico Denom&#xED;nase &quot;Julia Garay Guerra&quot; a la actual calle &quot;Se&#xF1;oret Playa&quot; de la ciudad de Punta Arenas&quot;.</div><br></div>", "i": 8283733}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintis&#xE9;is de noviembre de mil novecientos sesenta y ocho. EDUARDO FREI MONTALVA. Enrique Krauss, Ministro del Interior subrogante.</div><br></div>", "i": 8283734}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "17034", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-17034"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DENOMINA JULIA GARAY GUERRA A LA CALLE SEÑORET PLAYA\nDE LA CIUDAD DE PUNTA ARENAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "CALLE JULIA GARAY GUERRA", "PUNTA ARENAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1968-11-26", "doble_articulado": false, "id_norma": "28764", "numero_fuente": "27214", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1968-12-09", "vigencias": [{"desde": "1968-12-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1968-12-09", "f