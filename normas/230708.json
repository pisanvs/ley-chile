{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6498563}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.652, de 16 de septiembre</div><div class=\"p\">de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA CHILE</div><div class=\"p\">S.A. para ampliar actividades pesqueras extractivas con</div><div class=\"p\">la nave &quot;Tuamapu&quot;, en las &#xE1;reas mar&#xED;timas que en cada</div><div class=\"p\">caso se indican, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; capturar el recurso hidrobiol&#xF3;gico que a continuaci&#xF3;n se se&#xF1;ala: a) Entre el paralelo 37&#xB0; LS y 57&#xB0; LS, con poteras: Jibia; b) Entre el paralelo 41&#xB0;28,6&apos; LS y 47&#xB0; LS, con palangre: Jibia. </div></div>", "i": 6498564}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de septiembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6498565}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2652 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2652 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-09-16", "fecha_derogacion": "2006-02-10", "doble_articulado": false, "id_norma": "230708", "numero_fuente": "37973", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-09-29", "vigencias": [{"desde": "2006-02-10", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-09-29", "hasta":