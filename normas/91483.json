{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6089090}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 439, de 9 de mayo 1989, de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL 2.186, de 1978, parte inmueble ubicado Santa Isabel No. 0308, presunto rol aval&#xFA;os 916-19, comuna Providencia, aparentemente dominio de Mar&#xED;a Zapata G. y otro. Comisi&#xF3;n integrada por peritos Jorge Navarro Navarrete, arquitecto, Emilio Recabarren Solar, ingeniero civil, y Luis Rojas Quezada, constructor civil, seg&#xFA;n informe de 21.12.88, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 2.557.000.-, pagadera al contado.</div><br></div>", "i": 6089091}, {"t": "<div><div class=\"p\">Director SERVIU Metropolitano.</div><br></div>", "i": 6089092}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "439", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-439"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIVIENDA Y URBANIZACIÓN REGION METROPOLITANA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-09", "doble_articulado": false, "id_norma": "91483", "numero_fuente": "33386", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-06-01", "vigencias": [{"desde": "1989-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingre