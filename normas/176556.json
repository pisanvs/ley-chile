{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6304191}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA;82, de fecha 11</div><div class=\"p\">de agosto del a&#xF1;o 2000, se autoriz&#xF3; la existencia y se</div><div class=\"p\">aprobaron los estatutos de la Cooperativa de Trabajo en</div><div class=\"p\">Servicios Profesionales y Desarrollo Sustentable, de</div><div class=\"p\">sigla &apos;&apos;Emergen&apos;&apos;, de Santiago, en los t&#xE9;rminos que da</div><div class=\"p\">testimonio el instrumento protocolizado con fecha 11 de</div><div class=\"p\">julio del a&#xF1;o 2000, ante el Notario de Santiago, don</div><div class=\"p\">Arturo Carvajal Escobar, bajo el n&#xFA;mero 60.</div><br></div>", "i": 6304192}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Sr. Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6304193}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "82", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-82"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-08-11", "doble_articulado": false, "id_norma": "176556", "numero_fuente": "36784", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-11", "vigencias": [{"desde": "2000-10-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig