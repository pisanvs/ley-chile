{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N (M) N&#xBA; 1.338, DE 2009</div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n 158, de 26 de enero de 2010, Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina, se resolvi&#xF3;:</div></div>", "i": 8915352}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Rectif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1006538&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n 1.338, de 26 de junio de 2009</a>, que modific&#xF3; la concesi&#xF3;n de Acuicultura otorgada al Sr. Sigisfredo Ra&#xFA;l Legue Catipill&#xE1;n, por resoluci&#xF3;n 1.251, de 13 de junio de 2002, ambas del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina, en el siguiente sentido:</div><div class=\"p\">&nbsp; &nbsp;  Reempl&#xE1;zase en el numeral 1, letra B), de la parte resolutiva lo siguiente:</div><br><div class=\"p\">Donde dice:&nbsp; &nbsp; &quot;Carta S.H.O.A. N&#xBA; 7310, 4&#xAA; Edici&#xF3;n 1999 (Datum WGS-84)&quot;.</div><div class=\"p\">Debe decir:&nbsp; &nbsp; &quot;Plano DPC-308, 1&#xAA; Edici&#xF3;n 2006 (Datum WGS-84)&quot;.</div></div>", "i": 8915353}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de abril de 2010.- Felipe Garc&#xED;a-Huidobro Correa, Subjefe (M).</div></div>", "i": 8915354}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "158", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-158"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "RECTIFICA RESOLUCIÓN (M) Nº 1.338, DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-01-26", "doble_ar