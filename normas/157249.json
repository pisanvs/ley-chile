{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6237951}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n</div><div class=\"p\">Exenta N&#xB0; 1.685 de 18 de Diciembre de 1985, conforme</div><div class=\"p\">Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento de aguas proporcionales que corresponden a Sector Excluido y Sector Expropiado Predio &quot;Parte del Predio R&#xFA;stico denominado Huanipangue&quot; de la comuna de San Nicol&#xE1;s, VIII Regi&#xF3;n: y derechos de aprovechamiento de aguas que corresponder&#xE1; a las parcelas N&#xB0;s. 1 a la 5, sitios: N&#xB0;s. 1 al 9 del proyecto de parcelaci&#xF3;n &quot;La Fortuna&quot; formado por predio se&#xF1;alado. Los derechos de agua se extraen de derrames del Fundo Monte Blanco por canal Huampangue. Publicaci&#xF3;n hecha conforme, Art. 13 Ley N&#xB0; 18.377.</div><br></div>", "i": 6237952}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6237953}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1685 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1685 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHO DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-18", "doble_articulado": false, "id_norma": "157249", "numero_fuente": "32372", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-01-15", "vigencias": [{"desde": "1986-01-15", "hasta": "", "tipo_version": "3", "ti