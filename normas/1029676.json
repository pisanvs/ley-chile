{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9184532}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (exento) N&#xBA;1595 de fecha 29 de julio de 2011, se expropiaron los lotes de terreno N&#xBA;s 4 y 5, superficie 998 y 378 m2 respectivamente, rol N&#xBA;60-276, comuna de Futrono, para la obra &quot;Construcci&#xF3;n Puentes Caicayen y Hueinahue, camino Maihue Hueinahue - Rupumeica&quot;, Comunas de Futrono y Lago Ranco, Regi&#xF3;n de los R&#xED;os y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario LUCILA OTILIA CAIHUANTE CHOCANO, ascendente a la cantidad de $4.881.851.- </div></div>", "i": 9184533}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9184534}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1595 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1595 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-07-29", "doble_articulado": false, "id_norma": "1029676", "numero_fuente": "40062", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-09-15", "vigencias": [{"desde": "2011-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "362", "fecha_ingreso": "2011-09-15", "fecha_version": "2011-09-15", "fecha_actualiz