{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6387170}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA;802, de 31 de mayo de 2002, se rectific&#xF3; el decreto MOP (exento) N&#xBA;98, de 25 de febrero de 2002, que orden&#xF3; la expropiaci&#xF3;n del lote de terreno N&#xBA;23-F, rol de aval&#xFA;o 162-34, comuna de San Nicol&#xE1;s, para la obra &apos;&apos;Camino Ruta N-60-O, Sector R&#xED;o &#xD1;uble-Portezuelo, Km.</div><div class=\"p\">6.900.00 a Km. 28.833.35&apos;&apos;, VIII Regi&#xF3;n, por el cual se rectific&#xF3; el numeral 2, en lo que respecta a la superficie del lote que es de 164 m&#xB2; y no la que all&#xED; se expresa.- </div></div>", "i": 6387171}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6387172}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "802 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-802 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-31", "doble_articulado": false, "id_norma": "199902", "numero_fuente": "37296", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-01", "vigencias": [{"desde": "2002-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "i