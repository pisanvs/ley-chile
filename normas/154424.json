{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6228946}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 208 de fecha 08 de Septiembre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la II Regi&#xF3;n, se autoriza a Oscar Sep&#xFA;lveda Rivera, para efectuar todo tipo de servicio de Transportes de pasajeros por calles y caminos dentro del Territorio Nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.- </div></div>", "i": 6228947}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Guido M. Ram&#xED;rez Maturana, SEREMI de Transportes y Telecomunicaciones II Regi&#xF3;n.</div><div class=\"p\">Secretar&#xED;a Regional Ministerial III Regi&#xF3;n </div></div>", "i": 6228948}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "208 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-208 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL II REGIÓN DE ANTOFAGASTA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-08", "doble_articulado": false, "id_norma": "154424", "numero_fuente": "32882", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-30", "vigencias": [{"desde": "1987-09-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-09-30", "fin_vigencia": "", "tipo_ve