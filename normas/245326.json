{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N&#xB0; 1235 </div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 1235, celebrada el 15 de diciembre de 2005, adopt&#xF3; el siguiente Acuerdo:</div><br></div>", "i": 6553784}, {"t": "<div><div class=\"p\">1235-06-051215 Tasa de inter&#xE9;s para pago diferido de derechos de Aduana.</div><br><div class=\"p\">Se acord&#xF3;, en conformidad con lo establecido en la letra c) del art&#xED;culo 10 de la Ley N&#xB0; 18.634, la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de derechos de aduana durante el semestre que expira el 30 de junio de 2006, ser&#xE1; de 6,8% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.</div><br></div>", "i": 6553785}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de diciembre de 2005.- Juan Esteban Laval Zald&#xED;var, Ministro de Fe (S) </div></div>", "i": 6553786}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1235", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1235"}, {"tipo": "5", "numero": "1235-6", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1235-6"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION Nº 1235", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BIENES DE CAPITAL", "DERECHOS ADUANEROS", "PAGO DIFERIDO", "TASA DE INTERES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-15", "doble_articulado": false, "id_norma": "245326", "numero_fuente": "38341", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-12-20", "vigencias": [{"desde": "