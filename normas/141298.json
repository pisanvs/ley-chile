{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6184996}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 4,29% durante el mes de agosto de 1987.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1 del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables de 90 a 365 d&#xED;as, correspondiente a la segunda quincena de agosto de 1987, fue de 4,34% anual. </div></div>", "i": 6184997}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 02 de septiembre de 1987.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6184998}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE HACIENDA", "BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-02", "doble_articulado": false, "id_norma": "141298", "numero_fuente": "32862", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-03", "vigencias": [{"desde": "1987-09-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-09-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ing