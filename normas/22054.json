{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ROMUALDO LILLO Lei n&#xFA;m. 196.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947117}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese por gracia a don Romualdo Lillo el derecho de jubilar con arreglo al sueldo de secretario del segundo Juzgado del Cr&#xED;men de Santiago.</div><br><br></div>", "i": 5947118}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 27 de Agosto de 1894.-JORGE MONTT.-C&#xE1;rlos Riesco.</div><br></div>", "i": 5947119}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "196", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-196"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "ROMUALDO LILLO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ROMUALDO LILLO", "JUBILACION", "CONCESION POR GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-08-27", "doble_articulado": false, "id_norma": "22054", "numero_fuente": "4903", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-08-29", "vigencias": [{"desde": "1894-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-08-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-08-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen