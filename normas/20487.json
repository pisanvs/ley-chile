{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 163 EXENTO, DE 1996 </div></div>", "i": 5942137}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 163, de 25 de marzo de 1996, se ha autorizado al Colegio &quot;Academia Iquique&quot;, de Iquique, para que, a contar del a&#xF1;o escolar 1996, introduzca modificaciones en el presente decreto.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio para las asignaturas de Computaci&#xF3;n para los cursos de 1&#xB0; a 8&#xB0; a&#xF1;o b&#xE1;sico y de Literatura para los cursos de 5&#xB0; a 8&#xB0; a&#xF1;o b&#xE1;sico.</div><br></div>", "i": 5942138}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 3 de abril de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5942139}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "163", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-163"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 163 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "COLEGIO ACADEMIA IQUIQUE", "IQUIQUE", "PRIMERA REGION", "PLANES ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-03-25", "doble_articulado": false, "id_norma": "20487", "numero_fuente": "35441", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-04-13", "vigencias": [{"desde": "1996-04-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-04-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-