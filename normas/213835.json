{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6436309}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.877, de 14 de agosto de 2003, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 2.413 de 2002, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a&nbsp; PESQUERA&nbsp; ARAUCANIA DOS S.A. para operar la nave &quot;Nautilius&quot;, respecto de los recursos Pez espada, en el &#xE1;rea mar&#xED;tima de la I a la X Regiones, y Bacalao de profundidad, en el &#xE1;rea mar&#xED;tima comprendida entre Punta Liles y el paralelo 47&#xB0; L.S., en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 6436310}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de agosto de 2003.- Edith Saa Collantes, Subsecretario de Pesca (S).</div><br></div>", "i": 6436311}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1877", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1877"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-14", "doble_articulado": false, "id_norma": "213835", "numero_fuente": "37640", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-08-21", "vigencias": [{"desde": "2003-08-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-08-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-08-21", "fin_vigencia": "",