{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Oficina Telegr&#xE1;fica de la Moneda Lei n&#xFA;m. 1,273.- Santiago, a 21 de Noviembre de 1899.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274225}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se declara que la Oficina telegr&#xE1;fica de la Moneda tendr&#xE1; la misma planta de empleados que en el a&#xF1;o 1898, con los sueldos fijados por la lei de presupuestos de 1897.</div><br><br></div>", "i": 8274226}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- R. Sotomayor.</div><br></div>", "i": 8274227}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1273", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1273"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "OFICINA TELEGRAFICA DE LA MONEDA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["OFICINA TELEGRAFICA DE LA MONEDA", "PLANTA", "PERSONAL", "FIJACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-11-21", "doble_articulado": false, "id_norma": "22522", "numero_fuente": "6454", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-11-22", "vigencias": [{"desde": "1899-11-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-11-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-11-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vin