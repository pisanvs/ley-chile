{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,228, que concede un suplemento al Presupuesto de Justicia para pago de empleados suplentes Lei n&#xFA;m. 2,228.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5953100}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de doce mil pesos ($ 12,000) al &#xED;tem 2,008, partida 10, del Presupuesto de Justicia, en vijencia que consigna fondos para pago de empleados suplentes.</div><br></div>", "i": 5953101}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 29 de Noviembre de 1909.- PEDRO MONTT.- Emiliano Figueroa.</div><br></div>", "i": 5953102}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2228", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2228"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "LEI NUM. 2,228, QUE CONCEDE UN SUPLEMENTO AL PRESUPUESTO DE JUSTICIA PARA PAGO DE EMPLEADOS SUPLENTES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1909", "MODIFICACION", "MINISTERIO", "JUSTICIA", "EMPLEADOS", "SUPLENTES", "PAGO", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1909-11-29", "doble_articulado": false, "id_norma": "23211", "numero_fuente": "9557", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1909-12-02", "vigencias": [{"desde": "1909-12-02", "hasta": "", "tipo