{"html": [{"t": "<div><div class=\"p\">AUTORIZA A SOCIEDAD PESQUERA EICOMAR S.A. PARA AMPLIAR ACTIVIDADES PESQUERAS </div></div>", "i": 6271995}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.413, de 30 de Noviembre de 1987, de esta Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Sociedad Pesquera Eicomar S.A., domiciliada en Santiago, para ampliar las actividades pesqueras que tiene autorizadas por resoluci&#xF3;n No. 630, de 1986, de esta Subsecretar&#xED;a, en el sentido que podr&#xE1; utilizar el arte de pesca espinel, en la operaci&#xF3;n de la embarcaci&#xF3;n &quot;Corfo I&quot;.</div><br></div>", "i": 6271996}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de Noviembre de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 6271997}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1413", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1413"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A SOCIEDAD PESQUERA EICOMAR S.A. PARA AMPLIAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-30", "doble_articulado": false, "id_norma": "167666", "numero_fuente": "32943", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-12", "vigencias": [{"desde": "1987-12-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-12", "fin_vigencia