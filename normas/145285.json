{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8351444}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.979, de 6 de octubre de 1999, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 1.423 de 1999, de esta Subsecretar&#xED;a, que fij&#xF3; la n&#xF3;mina de armadores y embarcaciones que cumplen con los requisitos legales para operar en la unidad de pesquer&#xED;a de Merluza com&#xFA;n, declarada en estado de plena explotaci&#xF3;n y sometida a dicho r&#xE9;gimen de administraci&#xF3;n, en el litoral de la IV Regi&#xF3;n al paralelo 41&#xB0;28,6&apos; L.S., en el &#xE1;rea se&#xF1;alada en sus respectivas autorizaciones, en orden a incluir lo siguiente:</div><br><div class=\"p\">QUEZADA BERNAL, TOMAS HUGO: T&#xED;o Tom&#xE1;s.</div><div class=\"p\">INVERSIONES DELFINES S.A. : Marlin I.</div><br></div>", "i": 8351445}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de octubre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8351446}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1979", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1979"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-06", "doble_articulado": false, "id_norma": "145285", "numero_fuente": "36488", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-10-14", "vigencias": [{"desde": "1999-10-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "v