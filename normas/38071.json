{"html": [{"t": "<div><div class=\"p\">AUMENTA NUMERO DE PASAJEROS EN SERVICIOS QUE INDICA </div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 40 exenta.- Puerto Montt, Junio 18 de 1993.- Visto: El art&#xED;culo 51&#xB0; del D.S. N&#xB0; 212/92 del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes.</div><div class=\"p\">&nbsp; &nbsp; Considerando: Las caracter&#xED;sticas geogr&#xE1;ficas de la X Regi&#xF3;n y la distribuci&#xF3;n de sus habitantes en zonas rurales.</div><br><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br><br><br><br></div>", "i": 8871679}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Autor&#xED;zase a los servicios de locomoci&#xF3;n colectiva rurales de la X Regi&#xF3;n, prestados con buses y minibuses cuyo recorrido sea superior a 50 Kms., a transportar un m&#xE1;ximo de 20 de pasajeros de pie.</div><br></div>", "i": 8871680}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Comun&#xED;quese, publ&#xED;quese y arch&#xED;vese.- Arturo Hern&#xE1;ndez Orellana, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 8871681}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "40 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-40 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "AUMENTA NUMERO DE PASAJEROS EN SERVICIOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LOCOMOCION COLECTIVA RURAL", "DECIMA REGION", "SERVICIO", "PUBLICO TRANSPORTE PASAJEROS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1993-06-18", "fecha_derogacion": "2004-02-17", "doble_articulado": false, "id_norma": "3807