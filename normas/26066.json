{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY 9,132 Por cuanto el Congreso Nacional ha tenido a bien prestar su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8278767}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Supr&#xED;mese en el art&#xED;culo 1&#xB0; de la ley N&#xB0; 9,132, de 27 de Octubre de 1948, la frase: &quot;calle de por medio&quot;.</div><div class=\"p\">&nbsp; &nbsp; Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 8278768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, catorce de Septiembre de mil novecientos cuarenta y nueve.- GABRIEL GONZALEZ VIDELA.- I. Holger T.</div><br></div>", "i": 8278769}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "9389", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-9389"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA LA LEY 9,132", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "LEY 9132", "FACULTAD", "MUNICIPALIDAD LA CALERA", "VENTA", "FABRICA CEMENTO EL MELON", "SERVICIO MUNICIPAL", "TERRENO", "BIEN RAIZ", "BIEN INMUEBLE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1949-09-14", "doble_articulado": false, "id_norma": "26066", "numero_fuente": "21460", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1949-09-23", "vigencias": [{"desde": "1949-09-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"