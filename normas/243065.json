{"html": [{"t": "<div><div class=\"p\">LEY NUM. 14.922</div><br><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DON GUMERSINDO NAVARRO PINTO</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6544562}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a don Gumersindo Navarro Pinto una pensi&#xF3;n mensual ascendente a E&#xBA; 50.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande el cumplimiento de la presente ley se imputar&#xE1; al &#xED;tem de pensiones del presupuesto del Ministerio de Hacienda.</div><br></div>", "i": 6544563}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a primero de Octubre de mil novecientos sesenta y dos.- JORGE ALESSANDRI RODRIGUEZ.- Luis Mackenna S.</div><br></div>", "i": 6544564}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14922", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14922"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DON GUMERSINDO NAVARRO\nPINTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1962-10-01", "doble_articulado": false, "id_norma": "243065", "numero_fuente": "25368", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1962-10-16", "vigencias": [{"desde": "1962-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}]