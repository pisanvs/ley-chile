{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO&nbsp; N&#xBA; 15 EXENTO, DE 1998 </div></div>", "i": 6091266}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 15 de 14 de enero de 1998, se ha derogado, a partir del a&#xF1;o escolar 1998, el decreto supremo exento de Educaci&#xF3;n N&#xBA; 570 de 1994, que aprob&#xF3; adecuaci&#xF3;n al plan de estudio de educaci&#xF3;n b&#xE1;sica, cursos 5&#xBA; y 6&#xBA; a&#xF1;o b&#xE1;sico, al Colegio &quot;Piamarta&quot; de la comuna de Estaci&#xF3;n Central, Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6091267}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de enero de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6091268}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "15 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-15 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 15 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "COLEGIO PIAMARTA", "ESTACION CENTRAL", "REGION METROPOLITANA", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-01-14", "doble_articulado": false, "id_norma": "92335", "numero_fuente": "35979", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-31", "vigencias": [{"desde": "1998-01-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-01-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vin