{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION No. 148 DE 17 DE JUNIO DE 1985 </div></div>", "i": 6255317}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado Planes y Programas Especiales de Estudio para Segundo Ciclo de la Educaci&#xF3;n Media T&#xE9;cnico - Profesional, a contar del a&#xF1;o escolar 1986 y hasta el a&#xF1;o escolar 1991, inclusive, para el Liceo Comercial San Jos&#xE9;, de Maip&#xFA;.</div><br><div class=\"p\">&nbsp; &nbsp;  ESPECIALIDADES:</div><br><div class=\"p\">&nbsp; &nbsp;  1.- Contabilidad.</div><div class=\"p\">&nbsp; &nbsp;  2.- Ventas y Publicidad.</div><div class=\"p\">&nbsp; &nbsp;  3.- Secretariado Administrativo.</div><div class=\"p\">&nbsp; &nbsp;  4.- Programaci&#xF3;n en Computaci&#xF3;n.</div><br></div>", "i": 6255318}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica Subrogante.</div><br></div>", "i": 6255319}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "148 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-148 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION No. 148\nDE 17 DE JUNIO DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-17", "doble_articulado": false, "id_norma": "162427", "numero_fuente": "32282", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-09-27", "vigencias": [{"desde": "1985-09-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vi