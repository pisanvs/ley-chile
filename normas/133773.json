{"html": [{"t": "<div><div class=\"p\">PROYECTO DE LEY QUE MODIFICA ARTICULO 26 DEL DECRETO LEY No.</div><div class=\"p\">3.063, DE 1979, Y OTORGA FACULTADES QUE INDICA AL PRESIDENTE DE LA REPUBLICA </div></div>", "i": 6160084}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Secretario del Tribunal Constitucional, quien suscribe, certifica que la H. Junta de Gobierno envi&#xF3; el proyecto de ley enunciado en el rubro a fin de que el Tribunal ejerciera el control de su constitucionalidad, y que por sentencia de 21 de junio de 1989, se declar&#xF3; que no le corresponde pronunciarse sobre el proyecto remitido por versar sobre materias que no son propias de ley org&#xE1;nica constitucional.</div><br></div>", "i": 6160085}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Rafael Larra&#xED;n Cruz, Secretario.</div><br></div>", "i": 6160086}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "22", "numero": "S/N", "abreviacion": "SEN", "descripcion": "Sentencia", "compuesto": "SEN-S/N"}], "organismos": ["TRIBUNAL CONSTITUCIONAL"], "titulo_norma": "PROYECTO DE LEY QUE MODIFICA ARTICULO 26 DEL DECRETO LEY No.\n3.063, DE 1979, Y OTORGA FACULTADES QUE INDICA AL PRESIDENTE\nDE LA REPUBLICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-07-26", "doble_articulado": false, "id_norma": "133773", "numero_fuente": "33446", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-08-11", "vigencias": [{"desde": "1989-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-08-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-08-11", "fin_vigencia": "", "tipo_version": "3"