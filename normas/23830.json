{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede fondos para la reconstruccion del cuartel del Rejimiento Llanquihue</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,228.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7166463}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Se autoriza al Presidente de la Rep&#xFA;blica para que invierta hasta la cantida de doscientos setenta mil pesos ($ 270,000) en los trabajos que demande la reconstrucci&#xF3;n del cuartel del Rejimiento Llanquihue, en Puerto Montt.</div><br></div>", "i": 7166464}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 7 de Febrero de 1917.- JUAN LUIS SANFUENTES.- Oscar Urz&#xFA;a.</div><br></div>", "i": 7166465}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3228", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3228"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "CONCEDE FONDOS PARA LA RECONSTRUCCION DEL CUARTEL DEL REJIMIENTO LLANQUIHUE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CUARTEL REGIMIENTO", "LLANQUIHUE", "RECONSTRUCCION", "FONDOS", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1917-02-07", "doble_articulado": false, "id_norma": "23830", "numero_fuente": "11694", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1917-02-08", "vigencias": [{"desde": "1917-02-08", "hasta": "", "tipo_ve