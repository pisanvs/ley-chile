{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DERECHO DE AGUAS EN COMUNA DE PERALILLO </div></div>", "i": 6025745}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Servicio Agr&#xED;cola y Ganadero, mediante Resoluci&#xF3;n Exenta N&#xB0; 2063 del 8 de Julio de 1996, conforme art&#xED;culo 5&#xB0; transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento de Aguas proporcionales que corresponden a las parcelas N&#xB0;s. 1 a 34, sitios N&#xB0;s. 35 al 71 y Bienes Comunes N&#xB0;s. 1, 2 y 3 del Proyecto de Parcelaci&#xF3;n de los Terrenos de la Cooperativa Campesina &quot;La Troya Limitada&quot;, formada por parte del predio &quot;Hijuela Tres Puquillay y Resto de la Hijuela Dos Peralillo&quot;, de la comuna de Peralillo, VI Regi&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Los derechos de aguas se extraen de los canales Lihueimo, Mait&#xE9;n y Sentado.</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n hecha conforme art&#xED;culo 13 Ley N&#xB0; 18.377.-</div><br></div>", "i": 6025746}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director Nacional.</div><br></div>", "i": 6025747}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2063", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2063"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHO DE AGUAS EN COMUNA DE PERALILLO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHO APROVECHAMIENTO AGUAS", "PERALILLO", "SEXTA REGION", "COOPERATIVA CAMPESINA LA TROYA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-07-08", "doble_articulado": false, "id_norma": "40061", "numero_fuente": "35531-1", "tipo_version": "3", "tipo_versio