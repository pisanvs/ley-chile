{"html": [{"t": "<div><br><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA</div></div>", "i": 9844080}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional de Temuco del SII, por resoluci&#xF3;n Ex. N&#xBA; 77317077718 de fecha 13.10.2017, deja sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=221123&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; Ex. 56 del 30.01.2004</a>, que otorga la calidad de agente retenedor de cambio de sujeto de derecho del Impuesto al Valor Agregado en las operaciones de contrato de instalaci&#xF3;n o confecci&#xF3;n de especialidades que contraten, a contar de la fecha de esta publicaci&#xF3;n, al contribuyente Jos&#xE9; Miguel Garc&#xED;a Echavarri, RUT N&#xBA; 6.747.949-1, conforme a lo establecido en la resoluci&#xF3;n Ex. N&#xBA; 142 de fecha 26.12.2005, de la Direcci&#xF3;n Nacional del Servicio, publicada en el Diario Oficial de fecha 29.12.2005.- </div><br></div>", "i": 9844081, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Carlos del Carmen Fuentes Salvo, Director Regional (S).</div></div>", "i": 9844082}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "77317077718 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-77317077718 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1294049", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-10-13", "doble_articulado": false, "id_norma": "1109849", "numero_fuente": "41894", "tipo_version": "3", "tipo_versio