{"html": [{"t": "<div><div class=\"p\">MODIFICA COMPENDIO DE NORMAS ADUANERAS Y MANUAL DE PAGOS</div></div>", "i": 10153324}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.575, de fecha 19.08.2020, del Director Nacional de Aduanas, se modific&#xF3; los Cap&#xED;tulos III y V, del <a href=\"https://www.leychile.cl/Navegar?idNorma=248540&amp;idParte=&amp;idVersion=\">Compendio de Normas Aduaneras</a> y los Cap&#xED;tulos II, III y IV del Manual de Pagos, conforme a la entrada en vigencia de las instrucciones relativas a la presentaci&#xF3;n electr&#xF3;nica total de las solicitudes de modificaci&#xF3;n al documento aduanero para las declaraciones de ingreso, tramitadas en el sistema Sicomexin.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10153325}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><div class=\"p\"> </div><br></div>", "i": 10153326}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2575 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2575 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA COMPENDIO DE NORMAS ADUANERAS Y MANUAL DE PAGOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1804452", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-08-19", "doble_articulado": false, "id_norma": "1148684", "numero_fuente": "42739", "tipo_version": "3", "tip