{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 5, DE 1989 </div></div>", "i": 6097393}, {"t": "<div><br><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 5 de 13 de enero de 1989 se ha aprobado a la Escuela Especial Particular N&#xB0; 924 de Renca, de la Regi&#xF3;n Metropolitana, un Plan de estudio especial de orientaci&#xF3;n laboral para alumnos discapacitados, que se desarrollar&#xE1; con car&#xE1;cter experimental por un periodo de 4 a&#xF1;os, a contar desde el a&#xF1;o escolar 1989.</div><div class=\"p\">Adem&#xE1;s, se aprueban programas de estudio correspondientes al plan que aprueba el presente decreto.</div><br></div>", "i": 6097394}, {"t": "<div><div class=\"p\">Santiago, 26 de Enero de 1989.- Adelchi Colombo Breschi, Subsecretario de Educaci&#xF3;n P&#xFA;blica Subrogante. </div></div>", "i": 6097395}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "5 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-5 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 5, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-01-13", "doble_articulado": false, "id_norma": "94551", "numero_fuente": "33305", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-02-22", "vigencias": [{"desde": "1989-02-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-02-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-02-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": []