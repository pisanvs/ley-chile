{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6343984}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA; 53, del 15 de junio del a&#xF1;o 2001, se autoriz&#xF3; la existencia y aprob&#xF3; el estatuto de la Cooperativa de Trabajo Para el Desarrollo Sustentable Territorio Sur, de nombre de fantas&#xED;a Territorio Sur, de la ciudad de Valpara&#xED;so, en los t&#xE9;rminos que da testimonio el acta constitutiva protocolizada con fecha 31 de enero del 2001, bajo el N&#xBA; 924/2001 al final de los registros del Notario de Valpara&#xED;so, don Marcos Andr&#xE9;s D&#xED;az Le&#xF3;n.- </div></div>", "i": 6343985}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6343986}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "53", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-53"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-06-15", "doble_articulado": false, "id_norma": "187963", "numero_fuente": "37020", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-07-25", "vigencias": [{"desde": "2001-07-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-07-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-07-