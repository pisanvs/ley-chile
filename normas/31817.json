{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6002044}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 2 de 30 de Marzo de 1994, se adjudica, a &quot;A. Denham y C&#xED;a. Ltda.&quot; la concesi&#xF3;n para operar, por un plazo de tres meses, un establecimiento destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de emisi&#xF3;n de contaminantes de buses inscritos en el Registro Nacional de Servicios de Transporte de Pasajeros de la Regi&#xF3;n Metropolitana y a aquellos que presten servicio privado de transporte de personas en dicha regi&#xF3;n en la forma y condiciones que se se&#xF1;ala en el contrato que se aprueba.-</div><br></div>", "i": 6002045}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Antonio Durthe Castrill&#xF3;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6002046}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION REVISION TECNICA", "PLANTA REVISION TECNICA", "VEHICULOS MOTORIZADOS", "A. DENHAM CIA LTDA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-30", "doble_articulado": false, "id_norma": "31817", "numero_fuente": "34871", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-05-23", "vigencias": [{"desde": "1994-05-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-05-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "19