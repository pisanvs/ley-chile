{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pago a la Compa&#xF1;&#xED;a Inglesa de Vapores Lei n&#xFA;m. 1,130.- Santiago, a 16 de Diciembre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br></div>", "i": 8274107}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza al Presidente de la Rep&#xFA;blica para pagar a la Compa&#xF1;&#xED;a Inglesa de Vapores la suma de veinticinco mil sesenta pesos veintiun centavos que se le adeuda por perjuicios sufridos con motivo del viaje directo que hizo el vapor Arequipa de Iquique a Valparaiso en Agosto de 1891.</div><br><br></div>", "i": 8274108}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C. Walker Mart&#xED;nez.</div><br></div>", "i": 8274109}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1130", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1130"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "PAGO A LA COMPAÑÍA INGLESA DE VAPORES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMPAÑIA INGLESA VAPORES", "PRESIDENTE REPUBLICA", "INDEMNIZACION", "PAGO", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-12-16", "doble_articulado": false, "id_norma": "22424", "numero_fuente": "6177", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-12-16", "vigencias": [{"desde": "1898-12-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigen