{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUAS EN COMUNA DE LA FLORIDA </div></div>", "i": 6089458}, {"t": "<div><div class=\"p\">Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No.</div><div class=\"p\">1.866 de fecha 28 de Agosto de 1981, ratificada por</div><div class=\"p\">Resoluci&#xF3;n Exenta No. 1.927 de fecha 09.11.89, conforme</div><div class=\"p\">art&#xED;culo 5&#xB0; transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos de Aprovechamiento de Aguas proporcionales que corresponden a las parcelas N&#xB0;s. 1 a la 7; Sitios N&#xB0;s. 1 al 8; Bien Com&#xFA;n No. 1, y Reserva Cora del Proyecto de Parcelaci&#xF3;n &quot;El Rinc&#xF3;n, formado por parte expropiada del Fundo &quot;El Rinc&#xF3;n, de la comuna de La Florida, Regi&#xF3;n Metropolitana. Los derechos de aguas se extraen del Canal La Florida. Publicaci&#xF3;n hecha conforme art&#xED;culo 13&#xB0; Ley No. 18.377. </div></div>", "i": 6089459}, {"t": "<div><div class=\"p\">Director Nacional (S).</div><br></div>", "i": 6089460}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1866", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1866"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO"], "titulo_norma": "DERECHOS DE AGUAS EN COMUNA DE LA FLORIDA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-08-28", "doble_articulado": false, "id_norma": "91632", "numero_fuente": "33522", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-11-15", "vigencias": [{"desde": "1989-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-11