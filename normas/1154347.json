{"html": [{"t": "<div><div class=\"p\">&#xFEFF;&nbsp; &nbsp;  Elaboracion de salitres</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago i Julio 2 de 1813.</div></div>", "i": 10196586}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Habiendo el Gobierno provocado a todos los habitantes del Estado a la libre elaboracion de Salitres cuyo trabajo es del mayor interes a la Patria, i deseando fomentarlo por todos los medios i quitar las trabas i obst&#xE1;culos que impidan la entera dedicacion a este j&#xE9;nero de industria, declara que todos los que se ejercitaren en la elaboracion de salitres del pais est&#xE1;n exentos de toda leva i servicio militar, &#xED;nterin permaneciesen en este &#xFA;til trabajo, i hagan constar que todas las cantidades que refinan las conduzcan a la casa f&#xE1;brica de P&#xF3;lvora.</div></div>", "i": 10196587}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  - Perez. - Infante. -Eyzaguirre. - Ega&#xF1;a, secretario.</div></div>", "i": 10196588}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTRO", "descripcion": "Otro", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Elaboracion de salitres", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1813-07-02", "doble_articulado": false, "id_norma": "1154347", "numero_fuente": "1813", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1813-07-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1813-07-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1813-07-02", "fin_vigencia": "", "tipo_version": "3