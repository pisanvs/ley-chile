{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8623978}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 3.410, de 30 de diciembre de 2008, de esta Subsecretar&#xED;a, decl&#xE1;rase que con fecha 20 de octubre de 2008 han quedado sin efecto las resoluciones exentas N&#xBA; 2.136 de 1999, N&#xBA; 95 de 2001 y N&#xBA; 1.657 de 2001, todas de esta Subsecretar&#xED;a, que autorizaron a PESQUERA PAC&#xCD;FICO SUR S.A. para desarrollar actividades extractivas con la nave &quot;Pac&#xED;fico I&quot;, matr&#xED;cula 1913, en virtud de lo dispuesto en el art&#xED;culo 9&#xBA; de la ley N&#xBA; 19.713 y en la escritura p&#xFA;blica citada en Visto de la resoluci&#xF3;n extractada.</div><br></div>", "i": 8623979}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de diciembre de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca. </div></div>", "i": 8623980}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3410", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3410"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-12-30", "doble_articulado": false, "id_norma": "284783", "numero_fuente": "39258", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-01-10", "vigencias": [{"desde": "2009-01-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-01-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-01-10", "fin_vigencia": "", "tipo_vers