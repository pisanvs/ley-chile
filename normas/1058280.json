{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">NOTIFICACIONES</div></div>", "i": 9400094}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Res. Ex. N&#xBA; 414 de 17/04/13: Vistos: Acta de Denuncia y Citaci&#xF3;n N&#xBA; 14517 de 31/03/2013, cursada a Edwin Guarachi Coyo, C.I. extranjero N&#xBA; 7019724, nacionalidad boliviano, domicilio desconocido, que indica: portar 1 Kg. de peras, 0,7 Kgs. de pl&#xE1;tanos y 0,9 Kg. de naranjas, sin declararlo. Considerando: 1.- Que se ha infringido el decreto ley N&#xBA; 3.557; 2.- Que el denunciado no compareci&#xF3; a prestar declaraci&#xF3;n en la fecha indicada; 3.- El informe de la Encargada Regional de Controles Fronterizos quien pondera el perjuicio de la infracci&#xF3;n al DL 3.557. Resuelvo: 1.- Absu&#xE9;lvase de los cargos.</div></div>", "i": 9400095}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Firma: Andr&#xE9;s Puiggros Vogel, Director SAG, Regi&#xF3;n de Arica y Parinacota.</div></div>", "i": 9400096}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "414 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-414 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO XV REGIÓN DE ARICA Y PARINACOTA"], "titulo_norma": "NOTIFICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-04-17", "doble_articulado": false, "id_norma": "1058280", "numero_fuente": "40757", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-01-15", "vigencias": [{"desde": "2014-01-15", "hasta": "", "tipo_version":