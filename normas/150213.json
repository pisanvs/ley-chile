{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6215530}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 3.416, de 29 de octubre de 1999, se expropiaron los lotes de terreno N&#xBA;s. 3-A, 29-B, 30-B, 33, 34-B, 41, 41-A y 43, superficies 180, 1.613, 339, 950, 1.793, 480, 930 y 1.090 M2., respectivamente, roles de aval&#xFA;os 1226-57, Comuna de Cabrero y 220-11, 220-23, 223-11 y 223-3, Comuna de Yumbel, obra Camino Ruta 0-60, sector Monteaguila-Yumbel y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Jaime Paredes Mu&#xF1;oz, V&#xED;ctor Paredes Matus, Ernaldo Mundaca Mu&#xF1;oz, Mar&#xED;a Betancur Cabezas y Francisco Melo Vega, ascendente a las cantidades de $395.388, $1.261.738, $409.588, $609.713, $516.724, $1.043.647 y $1.040.088.</div><br></div>", "i": 6215531}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6215532}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3416", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3416"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-29", "doble_articulado": false, "id_norma": "150213", "numero_fuente": "36552", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-01-03", "vigencias": [{"desde": "2000-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-01-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-01-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe