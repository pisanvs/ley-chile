{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8310011}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 179 de 26 de Febrero de 1992 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, cad&#xFA;case parcialmente la resoluci&#xF3;n No. 475, de 1989, de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a Compa&#xF1;&#xED;a Pesquera Camanchaca S.A., RUT. No. 93.711.000-6, domiciliada en Santiago, para operar tres naves en construcci&#xF3;n, en el litoral de las Regiones IV, V y VI, en virtud de lo dispuesto en el Art&#xED;culo 143, letra b) de la Ley 18.892, Ley General de Pesca y Acuicultura. </div></div>", "i": 8310012}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 26 de Febrero de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8310013}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "179", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-179"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-02-26", "doble_articulado": false, "id_norma": "79541", "numero_fuente": "34212", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-03-07", "vigencias": [{"desde": "1992-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-03-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-03-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACIO