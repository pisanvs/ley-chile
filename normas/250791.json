{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6574055}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.541, de 7 de junio de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a CENTRO LOGISTICO PESQUERO SANTIAGO S.A., para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Am&#xE9;rico Vespucio N&#xBA; 1500, sitio 4, Santiago, Regi&#xF3;n Metropolitana, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de cocido, fresco, enfriado, fresco refrigerado, congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6574056}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Valpara&#xED;so, 7 de junio de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6574057}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1541 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1541 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-07", "doble_articulado": false, "id_norma": "250791", "numero_fuente": "38497", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-06-24", "vigencias": [{"desde": "2006-06-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-06-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-06-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones