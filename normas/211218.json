{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6426810}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (Exento) N&#xBA; 389 de fecha 30 de abril del 2003, se expropi&#xF3; el lote de terreno N&#xBA;1, superficie 2.837m2, rol N&#xBA;264-94, comuna de Chanco, VII Regi&#xF3;n para la obra &quot;Camino Ruta M-450, Sector: Chanco - Empedrado (acceso a Pte. Rari), Tramo Km. 14,120 a Km.</div><div class=\"p\">14,925&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Francisco Segundo Castro Arroyo, ascendente a la cantidad de $618.707.-</div><br></div>", "i": 6426811}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6426812}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "389 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-389 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-04-30", "doble_articulado": false, "id_norma": "211218", "numero_fuente": "37585", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-17", "vigencias": [{"desde": "2003-06-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-06-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-06-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2003-06-17", "fecha_version": "2003-06-17", "fecha_actualizacion_texto": "2003-06-17", "tipo_tratado": ""}, "aler