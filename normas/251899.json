{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6578167}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.101, de 25 de julio</div><div class=\"p\">2006, de esta Subsecretar&#xED;a, modif&#xED;case el n&#xFA;meral 4&#xBA; de</div><div class=\"p\">la resoluci&#xF3;n N&#xBA; 1.998, de 2006, de esta Subsecretar&#xED;a,</div><div class=\"p\">que autoriz&#xF3; a RICARDO GABRIEL VEGA VERGARA para</div><div class=\"p\">efectuar una pesca de investigaci&#xF3;n de conformidad con</div><div class=\"p\">los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto</div><div class=\"p\">denominado &quot;Monitoreo de la pesquer&#xED;a pel&#xE1;gica</div><div class=\"p\">desarrollada por botes que operan en la V Regi&#xF3;n&quot;, en el</div><div class=\"p\">sentido de indicar que el nombre de la embarcaci&#xF3;n</div><div class=\"p\">artesanal autorizada a participar en la presente pesca de investigaci&#xF3;n corresponde a &quot;Nicole II&quot; y no &quot;Nicol II&quot;, como all&#xED; se indica.</div><br></div>", "i": 6578168}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de julio de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6578169}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2101 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2101 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-25", "doble_articulado": false, "id_norma": "251899", "numero_fuente": "38529", "tipo_versio