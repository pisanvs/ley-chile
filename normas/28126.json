{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; REHABILITA EN SU NACIONALIDAD CHILENA A DON NELSON PINOCHET YA&#xD1;EZ.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 8282169}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Rehabil&#xED;tase en su nacionalidad chilena a don Nelson Pinochet Y&#xE1;&#xF1;ez, quien la hab&#xED;a perdido por nacionalizaci&#xF3;n en pa&#xED;s extranjero&quot;. </div></div>", "i": 8282170}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diez de septiembre de mil novecientos sesenta y tres.- JORGE ALESSANDRI RODRIGUEZ.- S&#xF3;tero del R&#xED;o.</div><br></div>", "i": 8282171}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "15265", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-15265"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "REHABILITA EN SU NACIONALIDAD CHILENA A DON NELSON\nPINOCHET YAÑEZ.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REHABILITACION", "NACIONALIDAD CHILENA", "NELSON PINOCHET YA EZ"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1963-09-10", "doble_articulado": false, "id_norma": "28126", "numero_fuente": "25649", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1963-09-25", "vigencias": [{"desde": "1963-09-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1963-09-25", "fin_vigencia": ""}