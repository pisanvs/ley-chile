{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY</div><br><br></div>", "i": 7169582}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1.o Trasp&#xE1;sase a los &#xED;tem 08, 03, 04, c;</div><div class=\"p\">08, 02, 04, b; y 08, 10, 04, v del Presupuesto de 1929, respectivamente, las cantidades de dieciocho mil pesos ($ 18,000); diez mil pesos ($ 10,000) y veintid&#xF3;s mil pesos ($ 22,000) que se deducir&#xE1;n en la siguiente forma: doce mil pesos ($ 12,000) del &#xED;tem 08, 01, 04, a; y treinta y ocho mil pesos ($ 38,000) del &#xED;tem 08, 04, c. </div></div>", "i": 7169583}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2.o Esta Ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 7169584}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, cinco de Diciembre de mil novecientos veintinueve.- Carlos Ib&#xE1;&#xF1;ez C. Osvaldo Koch. </div></div>", "i": 7169585}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4711", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4711"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O", "1929", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-12-05", "doble_articulado": false, "id_norma": "24849", "numero_fuente": "15540", "tipo_version": "3", "tipo_versio