{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza la inversion de $ 25,000 en combatir la epidemia de viruelas</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,629.- Santiago, a 29 de Diciembre de 1903.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274500}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la cantidad de veinticinco mil pesos ($ 25,000) en combatir la epidemia de viruelas en la Rep&#xFA;blica.</div><br></div>", "i": 8274501}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Arturo Besa.</div><br></div>", "i": 8274502}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1629", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1629"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA LA INVERSION DE $ 25,000 EN COMBATIR LA EPIDEMIA DE VIRUELAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EPIDEMIAS", "VIRUELA", "PREVENCION", "FONDOS", "INVERSION", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1903-12-29", "doble_articulado": false, "id_norma": "22804", "numero_fuente": "7791", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1903-12-30", "vigencias": [{"desde": "1903-12-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "19