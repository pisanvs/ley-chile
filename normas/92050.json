{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 116, DE 1989 </div></div>", "i": 6090476}, {"t": "<div><div class=\"p\">Por Decreto supremo exento de Educaci&#xF3;n No. 116 de 3 de julio de 1989 se ha modificado, a contar del presente a&#xF1;o escolar 1989, el Decreto supremo exento de Educaci&#xF3;n No. 190 de 1981, que aprob&#xF3; plan de estudio especial al Colegio Saint John&apos;s Villa Academy, de Santiago, sustituy&#xE9;ndose el plan de estudio para 2&#xB0;, 3&#xB0; y 4&#xB0; a&#xF1;o medio human&#xED;stico - cient&#xED;fico. Adem&#xE1;s, se aprueban programas de estudio de algunas asignaturas del Plan Electivo de estos mismos cursos.</div><br></div>", "i": 6090477}, {"t": "<div><div class=\"p\">Santiago, 14 de Julio de 1989.- Georgina Bustamante Ortiz, Subsecretaria de Educaci&#xF3;n P&#xFA;blica Subrogante. </div></div>", "i": 6090478}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "116 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-116 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 116, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-07-03", "doble_articulado": false, "id_norma": "92050", "numero_fuente": "33432", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-07-26", "vigencias": [{"desde": "1989-07-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-07-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-07-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p