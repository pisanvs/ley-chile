{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6036682}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 182, de 28 de febrero de 1997, se expropiaron los lotes de terreno N&#xBA;s 2, 2-A, 10, 11, 25-A, 29 y 29-A, superficies 419, 350, 3.050, 85, 323, 160 y 74 M2., respectivamente, roles de aval&#xFA;os 1090-1, 1090-5, 1092-145 y 1092-115, comuna de Quill&#xF3;n, obra Camino Ruta N-78-0, sector Quill&#xF3;n Nueva Aldea y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Aldeas Infantiles S.O.S., Jorge Ortega Segura, Gonzalo Ruiz Osorio y otro y Jos&#xE9; Or&#xF3;stica Gonz&#xE1;lez y otro, ascendente a las cantidades de $2.781.800, $1.568.427, $550.524 y $473.648.-</div><br></div>", "i": 6036683}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6036684}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "182", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-182"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "QUILLON", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-02-28", "doble_articulado": false, "id_norma": "71329", "numero_fuente": "35766", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-15", "vigencias": [{"desde": "1997-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente