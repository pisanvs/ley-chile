{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7301734}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.323, de 23 de junio de 2003, de esta Subsecretar&#xED;a, modif&#xED;canse el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 1.155 de 1997 y el numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA; 637 de 2003, ambas de esta Subsecretar&#xED;a, que autorizaron a PESQUERA EL GOLFO S.A. a realizar actividades pesqueras extractivas con la nave &quot;Cobra&quot;, en el sentido de actualizar e incorporar, seg&#xFA;n corresponda, las siguientes caracter&#xED;sticas n&#xE1;uticas de &#xE9;sta:</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; 1489,37 m3</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 12,00 m</div><br><br></div>", "i": 7301735}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de junio de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7301736}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1323 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1323 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-06-23", "fecha_derogacion": "2009-06-30", "doble_articulado": false, "id_norma": "212672", "numero_fuente": "37612", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-07-18", "vigencias": [{"desde": "2009-06-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-07-18",