{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA</div><div class=\"p\">(Extracto) </div></div>", "i": 8348254}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 410, de 25 de Abril de 1988, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2&#xB0; de la resoluci&#xF3;n No. 518, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a do&#xF1;a Teresa del Carmen Reyes Paidanca, R.U.T.</div><div class=\"p\">No. 6.151.305-1,domiciliada en Manao, sector rural, Comuna de Ancud, Provincia de Chilo&#xE9;, X Regi&#xF3;n de Los Lagos, para instalar y operar un establecimiento de cultivo de alga del g&#xE9;nero Gracilaria, en un sector de Bah&#xED;a Manao de Ancud, en orden a reemplazar la expresi&#xF3;n &quot;3.750 m2 de fondo de mar&quot; por &quot;3.375 m2 de fondo de mar&quot;.</div><br></div>", "i": 8348255}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de Abril de 1988.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8348256}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "410", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-410"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-04-25", "doble_articulado": false, "id_norma": "140913", "numero_fuente": "33063", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-05-05", "vigencias": [{"desde": "1988-05-05", "hasta": "", "tipo_version": "3