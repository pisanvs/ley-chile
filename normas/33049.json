{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8290189}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 96, de 16 de enero de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, se deneg&#xF3; la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por el SINDICATO DE</div><div class=\"p\">TRABAJADORES INDEPENDIENTES, CULTIVADORES Y EXPLOTADORES</div><div class=\"p\">DE ALGAS &quot;FLOR DEL MAR&quot;, para un sector ubicado en el</div><div class=\"p\">Golfete de Quetalmahue, Comuna de Ancud, Provincia de</div><div class=\"p\">Chilo&#xE9;, X Regi&#xF3;n, en virtud de lo dispuesto en los</div><div class=\"p\">art&#xED;culos 76&#xB0;, 77&#xB0;, 78&#xB0; y 5&#xB0; transitorio inciso 6&#xB0;, de la Ley General de Pesca y Acuicultura y el art&#xED;culo 14&#xB0; del D.S. N&#xB0; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. Asimismo, se dej&#xF3; sin efecto la Resoluci&#xF3;n N&#xB0; 1114, de 1990, de esta Subsecretar&#xED;a. </div></div>", "i": 8290190}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 16 de enero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8290191}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "96", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-96"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "SINDICATO", "TRABAJADORES INDEPENDIENTES CULTIVADORES EXPLOTADORES", "ALGAS FLOR DEL MAR", "ANCUD", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratad