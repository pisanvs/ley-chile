{"html": [{"t": "<div><div class=\"p\">EXTRACTO&nbsp; DE&nbsp; DECRETO&nbsp; N&#xBA; 467&nbsp; EXENTO,&nbsp; DE 1997</div><br></div>", "i": 6038742}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto exento N&#xBA; 467 de fecha 21 de abril de 1997 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a la Sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica Centro Interamericano de Educaci&#xF3;n y Cultura CIDEC, para impartir plan y programas de estudio aprobado para la instituci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se se&#xF1;ala, a contar del a&#xF1;o 1997:</div><br><br><div class=\"p\">Sede N&#xBA; 12 - Curic&#xF3;</div><div class=\"p\">Carrera&nbsp;  :&nbsp; Asistente Judicial</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; :&nbsp; T&#xE9;cnico Asistente Judicial</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; (Decreto exento N&#xBA; 420 del 28.12.90)</div><br></div>", "i": 6038743}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de mayo de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6038744}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "467 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-467 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 467 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "CENTRO DE FORMACION TECNICA", "CENTRO INTERAMERICANO DE EDUCACION Y CULTURA CIDEC", "PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "CURICO", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-21", "doble_articulado": false, "id_norma": "7339