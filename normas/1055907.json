dr&#xE1;n consultar los documentos que los contribuyentes est&#xE1;n autorizados a emitir en forma electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de octubre de 2013.</div></div>", "i": 9382883}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "92 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-92 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISOR DE DOCUMENTOS TRIBUTARIOS ELECTRÓNICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-10-30", "doble_articulado": false, "id_norma": "1055907", "numero_fuente": "40700", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-11-07", "vigencias": [{"desde": "2013-11-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-11-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-11-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2013-11-07", "fecha_version": "2013-11-07", "fecha_actualizacion_texto": "2013-11-07", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9382882}, {"n": "Artículo", "i": 9382883, "t": 6}]}