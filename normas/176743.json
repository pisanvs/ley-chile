{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7277678}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.048, de 15 de septiembre de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a ILD YAMIL YURIE CHAHUAN, para ampliar actividades pesqueras de transformaci&#xF3;n autorizados por resoluci&#xF3;n N&#xBA; 336, de 1993, de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en la Cantera s/n&#xBA;, Pudeto, comuna de Ancud, provincia de Chilo&#xE9;, X Regi&#xF3;n, autorizada por la resoluci&#xF3;n se&#xF1;alada precedentemente, en las l&#xED;neas de elaboraci&#xF3;n de conserva y congelado el recurso hidrobiol&#xF3;gico Loco.</div><br></div>", "i": 7277679}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de septiembre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca. </div></div>", "i": 7277680}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2048", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2048"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-15", "doble_articulado": false, "id_norma": "176743", "numero_fuente": "36789", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-17", "vigencias": [{"desde": "2000-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-10-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-10-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendien