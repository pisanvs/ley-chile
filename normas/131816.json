{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8341080}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 282, de 3 de febrero de 1999, de esta Subsecretar&#xED;a, ampl&#xED;ase por 186 d&#xED;as a contar del 13 de diciembre de 1998, el plazo otorgado a PESQUERA LA PENINSULA S.A., en el numeral 5 de la resoluci&#xF3;n N&#xBA; 1.454 de 1996, de esta Subsecretar&#xED;a, para operar la nave &apos;&apos;Loa 4&apos;&apos;, en el litoral de la X Regi&#xF3;n en la captura de Jurel, Anchoveta, Sardina espa&#xF1;ola y fauna asociada, en raz&#xF3;n de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor.</div><br></div>", "i": 8341081}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de febrero de 1999.- Edith Saa Collantes, Subsecretario de Pesca (S).</div><br></div>", "i": 8341082}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "282", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-282"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-02-03", "fecha_derogacion": "2002-11-07", "doble_articulado": false, "id_norma": "131816", "numero_fuente": "36293", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-02-18", "vigencias": [{"desde": "2002-11-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-02-18", "hasta": "2002-11-06", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2002-11-07", "fin_vigencia": ""}, "vigencias_