{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,692.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6172869}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al teniente-coronel de Ej&#xE9;rcito, don Sinforoso Ledesma, para los efectos de su retiro, el abono de seis meses i siete dias que estuvo fuera del servicio del Ej&#xE9;rcito el a&#xF1;o 1881. </div></div>", "i": 6172870}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, cuatro de setiembre de mil novecientos doce.- Ramon Barros Luco.- Claudio Vicu&#xF1;a S.</div><br></div>", "i": 6172871}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2692", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2692"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-09-04", "doble_articulado": false, "id_norma": "137677", "numero_fuente": "10371", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-09-05", "vigencias": [{"desde": "1912-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-09-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-09-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "J