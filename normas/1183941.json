{"html": [{"t": "<div><div class=\"p\">DECLARA CADUCIDAD TOTAL DE RESOLUCIONES QUE INDICA</div></div>", "i": 10377586}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.188, de 28 de octubre de 2022, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la totalidad de las resoluciones que a continuaci&#xF3;n se se&#xF1;alan, s&#xF3;lo en cuanto autorizaron a Camanchaca S.A., para realizar actividades pesqueras extractivas con las naves que se indica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  a) &quot;Costa Grande 3&quot;, resoluciones exentas <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=171447&amp;idVersion=2022-11-07\">N&#xB0; 1.073 de 2000</a>, <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=231810&amp;idVersion=2022-11-07\">N&#xB0; 2.868 de 2004</a>, <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=238146&amp;idVersion=2022-11-07\">N&#xB0; 1.368</a> y <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=238147&amp;idVersion=2022-11-07\">N&#xB0; 1.369</a>, ambas de 2005, y <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=265452&amp;idVersion=2022-11-07\">N&#xB0; 2.786 de 2007</a>.</div><div class=\"p\">&nbsp; &nbsp;  b) &quot;Costa Grande 4&quot;, resoluciones exentas <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=171448&amp;idVersion=2022-11-07\">N&#xB0; 1.074 de 2000</a>, <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=231811&amp;idVersion=2022-11-07\">N&#xB0; 2.869 de 2004</a>, <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=238164&amp;idVersion=2022-11-07\">N&#xB0; 1.342</a> y <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=238165&amp;idVersion=2022-11-07\">N&#xB0; 1.343</a>, ambas de 2005 y <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=265449&amp;idVersion=2007-10-11\">N&#xB0; 2.783 de 2007</a>.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><br></div>", "i": 10377587, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de octubre de 2022.- Paulo Sep&#xFA;lveda Sep&#xFA;lveda, Subsecretario de Pesca y Acuicultura (S).</div><div class=\"p\"> </div><br></div>", "i": 10377588}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2188 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2188 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DECLARA CADUCIDAD TOTAL DE RESOLUCIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2211757", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-10-28", "doble_articulado": false, "id_norma": "1183941", "numero_fuente": "43394", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-11-07", "vigencias": [{"desde": "2022-11-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2022-11-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2022-11-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "1289", "fecha_ingreso": "2022-11-07", "fecha_version": "2022-11-07", "fecha_actualizacion_texto": "2022-11-07", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10377586}, {"n": "Artículo", "i": 10377587, "t": 6}, {"n": "Promulgación", "i": 10377588}]}