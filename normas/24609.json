{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Eleva pensi&#xF3;n de gracia de las personas que indica Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5958961}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. El&#xE9;vase, por gracia, a cien pesos, la pensi&#xF3;n mensual de que actualmente disfrutan do&#xF1;a Corina, do&#xF1;a Felisa, do&#xF1;a Elvira, do&#xF1;a Elisa, do&#xF1;a Eugenia, y do&#xF1;a Sof&#xED;a Menare&quot;.</div><br></div>", "i": 5958962}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintitr&#xE9;s de Enero de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- Enrique Balmaceda. </div></div>", "i": 5958963}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4258", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4258"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "ELEVA PENSION DE GRACIA DE LAS PERSONAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CORINA MENARE", "FELISA MENARE", "ELVIRA MENARE", "ELISA", "MENARE", "EUGENIA MENARE", "SOFIA MENARE", "PENSION GRACIA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-01-23", "doble_articulado": false, "id_norma": "24609", "numero_fuente": "15001", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-02-16", "vigencias": [{"desde": "1928-02-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig