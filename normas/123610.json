{"html": [{"t": "<div><div class=\"p\">DISPONE VENTA DE INMUEBLE QUE INDICA</div><br><br><br></div>", "i": 6127615}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se notifica a do&#xF1;a Josefina S&#xE1;nchez S&#xE1;nchez, que por resoluci&#xF3;n E N&#xBA; 3.580 de 7 de julio de 1998, de la Direcci&#xF3;n del Serviu Metropolitano, se dispuso la venta a do&#xF1;a Josefina S&#xE1;nchez S&#xE1;nchez de la vivienda ubicada en calle Germ&#xE1;n Ebbinghaus N&#xBA; 2907, comuna de Puente Alto, y que se encuentra extendida en la Notar&#xED;a de Santiago de don Pedro Ricardo Reveco Hormaz&#xE1;bal la correspondiente escritura de compraventa para que proceda a su firma dentro del plazo de 15 d&#xED;as a contar de esta fecha bajo apercibimiento de lo dispuesto en el art. 57 de la ley 18.591.</div><br></div>", "i": 6127616}, {"t": "<div><br><div class=\"p\">Serviu Metropolitano.</div><br></div>", "i": 6127617}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3580", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-3580"}, {"tipo": "3", "numero": "E-3580", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-E-3580"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "DISPONE VENTA DE INMUEBLE QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VENTA", "BIEN INMUEBLE", "PUENTE ALTO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-07", "doble_articulado": false, "id_norma": "123610", "numero_fuente": "36154", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-09-01", "vigencias": [{"desde": "1998-09-01", "hasta": "",