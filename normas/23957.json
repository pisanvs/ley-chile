{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,416, que concede fondos para reconstruir una Sala en el Hospital de Osorno.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,416.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente proyecto de lei:</div><br></div>", "i": 8276271}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que invierta hasta la suma de quince mil pesos ($15,000) en ayudar a la reconstruccion de la Sala de Maternidad del Hospital de Osorno.</div><br></div>", "i": 8276272}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a doce de Setiembre de mil novecientos dieciocho.- JUAN LUIS SANFUENTES.- Pedro Garcia de la Huerta.</div><br></div>", "i": 8276273}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3416", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3416"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 3,416, QUE CONCEDE FONDOS PARA RECONSTRUIR UNA SALA EN EL HOSPITAL DE OSORNO.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["OSORNO", "HOSPITAL", "MATERNIDAD", "RECONSTRUCCION", "PRESIDENTE DE LA REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1918-09-12", "doble_articulado": false, "id_norma": "23957", "numero_fuente": "12179", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1918-09-27", "vigencias": [{"desde": "1918-09-2