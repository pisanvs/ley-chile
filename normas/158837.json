{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6243196}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 217, de 14.03.85, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones, de la Regi&#xF3;n Metropolitana, se autoriza a don Javier Enrique Gui&#xF1;ez Castro, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6243197}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de Marzo de 1985.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6243198}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "217 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-217 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-03-14", "doble_articulado": false, "id_norma": "158837", "numero_fuente": "32134", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-29", "vigencias": [{"desde": "1985-03-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-03-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient