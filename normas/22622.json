{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 1,403.- Santiago, a 27 de Diciembre de 1900.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7163055}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de ciento cincuenta mil pesos al &#xED;tem 1 de la partida 7.a del presupuesto de Marina vijente para atender a las reparaciones e instalaciones en los buques de la Armada, Arsenales i demas departamentos de Marina, embarcaciones menores i adquisiciones de &#xE9;stas.</div><br><br></div>", "i": 7163056}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; FEDERICO ERRAZURIZ E.- Arturo Besa.</div><br></div>", "i": 7163057}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1403", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1403"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1900", "MODIFICACIONES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-12-27", "doble_articulado": false, "id_norma": "22622", "numero_fuente": "6778", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-12-28", "vigencias": [{"desde": "1900-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-12-28", "fin_vigencia": ""}, "vigencia