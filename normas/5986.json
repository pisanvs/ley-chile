{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; TRASPASA FONDOS</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 327.- Santiago, 29 de Julio de 1932.- He acordado y dicto el siguiente,</div><div class=\"p\">&nbsp; &nbsp; Decreto-ley:</div><br></div>", "i": 7123864}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; 1.o Trasp&#xE1;sase la suma de siete mil cuatrocientos veinticinco pesos ($ 7,425), de 07|01|01 a 07|06|01 del Presupuesto vigente.</div><div class=\"p\">&nbsp; &nbsp; 2.o Se declara que el cargo de contador administrador, grado 9.o, de la ex-Direcci&#xF3;n General de Educaci&#xF3;n F&#xED;sica, pasar&#xE1;, con el mismo grado y a contar desde el 16 de Julio en curso, a formar parte de la planta de la Escuela de Educaci&#xF3;n F&#xED;sica, dependiente de la Universidad de Chile.</div><br></div>", "i": 7123865}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de Leyes y Decretos del Gobierno.- CARLOS DAVILA.- C. Soto.</div><br></div>", "i": 7123866}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "327", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-327"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "TRASPASA FONDOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1932", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-07-29", "doble_articulado": false, "id_norma": "5986", "numero_fuente": "16356", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-08-23", "vigencias": [{"desde": "1932-08-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigen