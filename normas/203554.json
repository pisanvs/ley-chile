{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6399583}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA;1.231 de 30 de agosto de 2002, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA; del decreto MOP exento N&#xBA;284, de fecha 30 de marzo de 2001, en la parte que se refiere al Convenio Directo de Precio Ad Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote de terreno N&#xBA;99. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n fijada por la comisi&#xF3;n de peritos con fecha 10 de febrero del 2000, ascendente a la cantidad de $318.400.- la que se pagar&#xE1; al contado.</div><br></div>", "i": 6399584}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6399585}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1231 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1231 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-08-30", "doble_articulado": false, "id_norma": "203554", "numero_fuente": "37383", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-10-15", "vigencias": [{"desde": "2002-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-10-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacio