{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION&nbsp; N&#xBA;&nbsp; 1.133</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 1.133, celebrada el 3 de junio de 2004, adopt&#xF3; el siguiente Acuerdo:</div><br></div>", "i": 6482638}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1133-01-040603 - Modifica Anexo N&#xBA; 2 del Cap&#xED;tulo IV.B.8 del Compendio de Normas Financieras.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; incorporar al Anexo N&#xBA; 2 del Cap&#xED;tulo IV.B.8 del Compendio de Normas Financieras, los siguientes n&#xFA;meros:</div><br><div class=\"p\">&quot;9.&nbsp; Pagar&#xE9;s del Banco Central de Chile en D&#xF3;lares de los Estados Unidos de Am&#xE9;rica (P.C.X.).</div><br><div class=\"p\">10.&nbsp; Cupones de Emisi&#xF3;n del Banco Central de Chile en D&#xF3;lares de los Estados Unidos de Am&#xE9;rica (X.E.R.O.).</div><br><div class=\"p\">11.&nbsp; Bonos del Banco Central de Chile en D&#xF3;lares de los Estados Unidos de Am&#xE9;rica (B.C.X.)&quot;. </div></div>", "i": 6482639}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de junio de 2004.- Juan Esteban Laval Zald&#xED;var, Ministro de Fe (S).</div><br></div>", "i": 6482640}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1133", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1133"}, {"tipo": "5", "numero": "1133-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1133-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION Nº 1.133", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMPENDIO DE NORMAS FINANCIERAS", "MODIFICACION", "PAGARES", "CUPONES DE EMISION", "BONOS", "INCORPORACION"], "categorias_norma": [], "nombres_uso_comun": [], "pai