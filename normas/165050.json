{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXPROPIATORIO </div></div>", "i": 6263525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Decreto 13 del 22.01.85 se dispuso expropiaci&#xF3;n inmueble ubicado en Camino de Pencahue, en la localidad de Corinto de Sucesi&#xF3;n Garrido Carrasco inscrita a Fs.</div><div class=\"p\">2.402, N&#xB0; 790 del 11 de Abril de 1976 del Conservador de Bienes Ra&#xED;ces de Talca. Rol pago contribuciones 108-1 de 2.000 m2 deslinde Norte en 4 m. con FF.CC. del E. Sur en 4 m. con sucesi&#xF3;n Guti&#xE9;rrez. Este en 500 m. con Fundo Santa Florencia, Oeste en 500 m. con Sucesi&#xF3;n Garrido Carrasco.</div><div class=\"p\">&nbsp; &nbsp;  Se publica presente extracto de decreto referido para efectos decreto ley 2.186 de Junio de 1978. </div></div>", "i": 6263526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Osvaldo Hiriart Rodr&#xED;guez, Alcalde.</div><br></div>", "i": 6263527}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "13", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-13"}], "organismos": ["MUNICIPALIDAD DE PENCAHUE"], "titulo_norma": "EXTRACTO DE DECRETO EXPROPIATORIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-22", "doble_articulado": false, "id_norma": "165050", "numero_fuente": "32097", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-02-14", "vigencias": [{"desde": "1985-02-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-02-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-02-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos