{"html": [{"t": "<div><br><div class=\"p\">MODIFICA &quot;CARTILLA RADIOTELEF&#xD3;NICA DEL SERVICIO M&#xD3;VIL MAR&#xCD;TIMO&quot;</div></div>", "i": 9367082}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n DGTM y MM Ord. N&#xB0; 12.600/324 Vrs., del 12 de julio de 2013, se modifica la &quot;Cartilla Radiotelef&#xF3;nica del Servicio M&#xF3;vil Mar&#xED;timo&quot;, aprobada por <a href=\"https://www.leychile.cl/Navegar?idNorma=1005172&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n DGTM y MM Ord. N&#xB0; 12.600/587 Vrs., del 5 de agosto de 2009</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n modificatoria est&#xE1; publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl).</div></div>", "i": 9367083}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de julio de 2013.- Humberto Ram&#xED;rez Navarro, Contraalmirante, Director General.- Rodrigo Ram&#xED;rez Daneri, Capit&#xE1;n de Fragata JT, Jefe Depto. Jur&#xED;dico.</div></div>", "i": 9367084}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "324", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-324"}, {"tipo": "3", "numero": "12600/324", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-12600/324"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "MODIFICA \"CARTILLA RADIOTELEFÓNICA DEL SERVICIO MÓVIL MARÍTIMO\"", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-07-12", "d