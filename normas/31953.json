{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8037533}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 7 del 15 de Julio de 1993, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la IV Regi&#xF3;n se adjudic&#xF3; a don Angel Ugalde Flores, la concesi&#xF3;n para operar, por un plazo de cinco (5) a&#xF1;os a contar de la fecha de publicaci&#xF3;n del presente extracto, un establecimiento ubicado en calle David Perry N&#xB0; 771 de la comuna de Ovalle, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de emisi&#xF3;n de contaminantes de todo tipo de veh&#xED;culos motorizados, sus remolques y semirremolques, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 8037534}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Freddy Bonilla Torreblanca, Secretario Regional Ministerial IV Regi&#xF3;n de Coquimbo.</div><br></div>", "i": 8037535}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION REVISION TECNICA", "PLANTA REVISION TECNICA", "OVALLE", "CUARTA REGION", "VEHICULOS MOTORIZADOS", "ANGEL UGALDE FLORES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-07-15", "doble_articulado": false, "id_norma": "31953", "numero_fuente": "34703", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-10-29", "vigencias": [{"desde": "1993-10-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia