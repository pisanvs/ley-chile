{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 1.901 EXENTA, DE 2007 </div></div>", "i": 7354988}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.901, de fecha 11 de septiembre de 2007, de Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se aprueban Planes y Programas de la Escuela de Conductores Profesionales &quot;Instituto Nacional de Conductores Profesionales Limitada&quot; o &quot;Inacop Ltda.&quot;, representada legalmente por el se&#xF1;or Esteban Barrera Chac&#xF3;n, para impartir cursos conducentes a la obtenci&#xF3;n de licencia de conductor profesional Clases A2, A3 y A4. </div></div>", "i": 7354989}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Pablo Rodr&#xED;guez Olivares, Secretario Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana.</div><br></div>", "i": 7354990}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1901 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1901 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 1.901 EXENTA, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-09-11", "doble_articulado": false, "id_norma": "265217", "numero_fuente": "38876", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-10-02", "vigencias": [{"desde": "2007-10-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_