{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8344347}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;631, de 22 de abril de 1999, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la resoluci&#xF3;n 211 de 1990 de esta Subsecretar&#xED;a, que autoriz&#xF3; a HECTOR URRA SOTO, para operar la nave &apos;&apos;Victoria&apos;&apos;, en el litoral de las regiones II a la IX, respecto de los recursos Albacora o Pez espada, Congrio colorado, Congrio dorado y Congrio negro.</div><div class=\"p\">&nbsp; &nbsp;  Deni&#xE9;gase la solicitud presentada por don H&#xE9;ctor Urra Soto, en orden a otorgar Certificado de Transferencia para la nave &apos;&apos;Victoria&apos;&apos;.</div><br></div>", "i": 8344348}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de abril de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8344349}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "631", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-631"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-04-22", "doble_articulado": false, "id_norma": "135687", "numero_fuente": "36351", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-04-29", "vigencias": [{"desde": "1999-04-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-04-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-04-29", "fin_vigencia": "", "tipo_version"