{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6005647}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Certifico: Que por Resoluci&#xF3;n N&#xB0; 90, de fecha 18 de Julio de 1994, se aprob&#xF3; reforma de estatutos de la sociedad an&#xF3;nima &quot;Santiago S.A. Administradora de Fondos Mutuos&quot;, que consta de la escritura p&#xFA;blica de 6 de junio de 1994, otorgada en la Notar&#xED;a de Santiago de don Ra&#xFA;l Undurraga Laso.</div><div class=\"p\">&nbsp; &nbsp; La reforma consiste en aumentar el capital suscrito y pagado de $817.000.000.- dividido en 10.000 acciones a $1.419.470.000.- dividido en 20.000 acciones, dentro del plazo de diez d&#xED;as contado desde el 6 de junio de 1994.- Santiago, 18 de Julio de 1994.-</div><br></div>", "i": 6005648}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Rodrigo O. Costa Aranda, Secretario General. </div></div>", "i": 6005649}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "90", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-90"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REFORMA ESTATUTARIA", "ESTATUTOS", "SANTIAGO SA ADMINISTRADORA FONDOS MUTUOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-07-18", "doble_articulado": false, "id_norma": "33003", "numero_fuente": "34930", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-08-02", "vigencias": [{"desde": "1994-08-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-08-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-08-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos