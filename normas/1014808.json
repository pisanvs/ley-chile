{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N (M) N&#xBA; 1.684, DE 2009, QUE OTORG&#xD3; CONCESI&#xD3;N DE ACUICULTURA EN LA COMUNA DE CHAIT&#xC9;N</div></div>", "i": 8937016}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n N&#xBA; 2.454, de fecha 28 de diciembre de 2009, se procedi&#xF3; a modificar la <a href=\"https://www.leychile.cl/Navegar?idNorma=1007828&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 1.684, de fecha 17 de agosto de 2009, ambas del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina</a>, de acuerdo a lo siguiente:</div><div class=\"p\">&nbsp; &nbsp;  Reempl&#xE1;zase en el n&#xFA;meral 2.- de la parte resolutiva, v&#xE9;rtice D, de acuerdo a lo siguiente:</div><br><div class=\"p\">Donde dice: Long. 72&#xB0;50&apos;58,51&quot; W.</div><div class=\"p\">Debe decir: Long. 72&#xB0;50&apos;59,51&quot; W.</div></div>", "i": 8937017}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de mayo de 2010.- Por el Sr. Subsecretario, Felipe Garc&#xED;a-Huidobro Correa, Subjefe (M).</div></div>", "i": 8937018}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2454", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2454"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "RECTIFICA RESOLUCIÓN (M) Nº 1.684, DE 2009, QUE OTORGÓ CONCESIÓN DE ACUICULTURA EN LA COMUNA DE CHAITÉN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-28", "doble_articulado": false, "id_norma": "1014808", "numero_fuente": "39696", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2