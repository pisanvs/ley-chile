{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 630 EXENTO, DE 1995 </div></div>", "i": 5945596}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 630, de 15 de noviembre de 1995, se ha aprobado al Colegio &quot;Mar&#xED;a Auxiliadora&quot; de Santiago, un plan especial de estudio para los cursos de Ense&#xF1;anza Media Human&#xED;stico-Cient&#xED;fica, que se comenzar&#xE1;n a aplicar a partir del a&#xF1;o escolar 1996.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa de estudio para la asignatura de Computaci&#xF3;n.</div><br></div>", "i": 5945597}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 24 de Noviembre de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5945598}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "630 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-630 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 630 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO MARIA AUXILIADORA", "PLANES ESTUDIO", "A O", "ESCOLAR", "A O 1996"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-11-15", "doble_articulado": false, "id_norma": "21596", "numero_fuente": "35335", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-12-06", "vigencias": [{"desde": "1995-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-12-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-12-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe