{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N&#xBA; 816 </div><br></div>", "i": 6222233}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 816, celebrada el 20 de enero de 2000, adopt&#xF3; el siguiente Acuerdo:</div><br><div class=\"p\">816-03-000120 - Transbank - Autorizaci&#xF3;n para operar tarjeta de cr&#xE9;dito que indica.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; autorizar a Transbank para operar, seg&#xFA;n lo se&#xF1;alado en el punto 1.- del T&#xED;tulo IX del Cap&#xED;tulo III.J.1 del Compendio de Normas Financieras, la tarjeta de cr&#xE9;dito que se indica:</div><br><br><div class=\"p\">Entidad Operadora Tarjeta a operar&nbsp; Modalidad</div><br><div class=\"p\">Transbank&nbsp; &nbsp; &nbsp; &nbsp;  American Express&nbsp; Nacional e</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Internacional</div><br></div>", "i": 6222234}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de enero de 2000.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6222235}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "816", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-816"}, {"tipo": "5", "numero": "816-03-000120", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-816-03-000120"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION Nº 816", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-20", "doble_artic