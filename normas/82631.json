{"html": [{"t": "<div><div class=\"p\">DECLARA CADUCIDAD RESOLUCION QUE INDICA </div></div>", "i": 8313946}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 881 de 16 de Julio de 1990 de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad conforme con el</div><div class=\"p\">art&#xED;culo 7&#xB0; del Decreto Supremo No. 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, de la Resoluci&#xF3;n No. 277, de 1986, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don Alejandro Rodr&#xED;guez Cancino, R.U.T. No.</div><div class=\"p\">9.861.851-1, domiciliado en la Poblaci&#xF3;n Mirasol, calle Los Sauces No. 115, Puerto Montt, para desarrollar actividades pesqueras de cultivo.</div><br></div>", "i": 8313947}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 16 de Julio de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8313948}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "881", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-881"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "DECLARA CADUCIDAD RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-07-16", "doble_articulado": false, "id_norma": "82631", "numero_fuente": "33725", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-07-21", "vigencias": [{"desde": "1990-07-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-07-21