{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS Y CENTROS DE CULTIVO QUE INDICA</div></div>", "i": 9478502}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.396, de 23 de mayo de 2014, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1061879&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 1.148</a> de 2014, de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 3B, cambiando la situaci&#xF3;n de densidad y el n&#xFA;mero de ejemplares a ingresar del centro c&#xF3;digo 100189, en la forma se&#xF1;alada en la resoluci&#xF3;n extractada.</div></div>", "i": 9478503}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de mayo de 2014.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9478504}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1396 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1396 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS Y CENTROS DE CULTIVO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-05-23", "doble_articulado": false, "id_norma": "1063107", "numero_fuente": "40877", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-06-09", "