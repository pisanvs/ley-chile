{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LAS LEYES N&#xB0;.s 6.922 Y 10.343 Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8533295}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Der&#xF3;ganse los art&#xED;culos 2&#xB0;. de la ley N&#xB0;. 6.922, de 19 de Mayo de 1941, y 22&#xB0;. de la ley N&#xB0;. 10.343, de 23 de Mayo de 1952.&quot; </div></div>", "i": 8533296}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta de Septiembre de mil novecientos sesenta y seis.- EDUARDO FREI MONTALVA.- Bernardo Leighton G.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a U. para su conocimiento.- Dios gue. a U.- Enrique Krauss Rusque, Subsecretario del Interior interino.</div><br></div>", "i": 8533297}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "16564", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-16564"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA LAS LEYES NºS  6.922 Y 10.343", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DIPUTADOS", "SENADORES", "DIETA", "INASISTENCIA", "DESCUENTO", "COMISIONES", "CAMARAS", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1966-09-10", "doble_articulado": false, "id_norma": "28535", "numero_fuente": "26573", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1966-10-24", "vigencias": [{"desde": "1966-10-24", "hasta": "", "tipo_version": "3", "tipo_v