{"html": [{"t": "<div><div class=\"p\">EXTRACTO&nbsp; DE&nbsp; DECRETO&nbsp; N&#xBA; 581 EXENTO, DE 2000</div><br></div>", "i": 7281138}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 581, de fecha 28 de diciembre de 2000, del Ministerio de Educaci&#xF3;n, se modifica el decreto exento de Educaci&#xF3;n N&#xBA; 354 del 26 de diciembre de 1991, correspondiente a la Universidad Cat&#xF3;lica Cardenal Ra&#xFA;l Silva Henr&#xED;quez, en el sentido de precisar que la carrera aprobada por el Consejo Superior de Educaci&#xF3;n es la siguiente:</div><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Trabajo Social.</div><div class=\"p\">Grado acad&#xE9;mico&nbsp; &nbsp; : Licenciado en Trabajo Social.</div><div class=\"p\">T&#xED;tulo profesional : Asistente Social.</div><br></div>", "i": 7281139}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de diciembre de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7281140}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "581 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-581 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 581 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-12-28", "doble_articulado": false, "id_norma": "182681", "numero_fuente": "36908", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-09", "vigencias": [{"desde": "2001-03-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-09", "fin_vigencia": ""}, "v