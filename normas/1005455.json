{"html": [{"t": "<div><br><div class=\"p\">ASIGNA TESORERO PROVINCIAL SUBROGANTE</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 3.099.- Santiago, 10 de agosto de 2009.- Vistos: El art. 5&#xBA; del DFL N&#xBA; 1, de 1994, del Ministerio de Hacienda, sobre Estatuto Org&#xE1;nico del Servicio de Tesorer&#xED;as, el DH N&#xBA;1.257, de 2002; el art. 21&#xBA; N&#xBA; 1 de la ley N&#xBA; 19.738 y la resoluci&#xF3;n N&#xBA; 1.600, de 2008, de la Contralor&#xED;a General de la Rep&#xFA;blica, dicto lo siguiente,</div><br><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n:</div><br></div>", "i": 8773898}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  As&#xED;gnase al (los) siguiente(s) funcionario (s), a contar de la fecha que se indica, para desempe&#xF1;ar en calidad de subrogante la funci&#xF3;n que se se&#xF1;ala, en el orden establecido en la presente resoluci&#xF3;n:</div><br><div class=\"p\">Nombre&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  :&nbsp;  V&#xED;ctor Hugo Villar Burgos</div><div class=\"p\">RUT&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :&nbsp;  13.390.358-5</div><div class=\"p\">Ubicaci&#xF3;n&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :&nbsp;  Regi&#xF3;n Metropolitana - </div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Provincial La Florida - </div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Operaciones</div><div class=\"p\">Calidad jur&#xED;dica&nbsp;  :&nbsp;  Contrata</div><div class=\"p\">Estamento&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :&nbsp;  Profesional</div><div class=\"p\">Cargo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :&nbsp;  Profesional</div><div class=\"p\">Grado&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :&nbsp;  12 E.U.</div><div class=\"p\">Fecha inicio&nbsp; &nbsp; &nbsp;  :&nbsp;  10/08/2009</div><div class=\"p\">Funci&#xF3;n&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :&nbsp;  Tesorero Provincial </div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Subrogante.</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=1004846&amp;idParte=&amp;idVersion=2009-08-27\">resoluci&#xF3;n interna N&#xBA; 2.768 del 15 de julio de 2009</a>.</div><br><br></div>", "i": 8773899, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese y comun&#xED;quese.- Pamela Cuzmar Poblete, Tesorera General de la Rep&#xFA;blica.</div><br></div>", "i": 8773900}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3099", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-3099"}], "organismos": ["MINISTERIO DE HACIENDA", "TESORERÍA GENERAL DE LA REPÚBLICA"], "titulo_norma": "ASIGNA TESORERO PROVINCIAL SUBROGANTE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-08-10", "doble_articulado": false, "id_norma": "1005455", "numero_fuente": "39447", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-08-27", "vigencias": [{"desde": "2009-08-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-08-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-08-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "3721", "fecha_ingreso": "2009-08-27", "fecha_version": "2009-08-27", "actualizado_por": "3721", "fecha_actualizacion_texto": "2009-08-27", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado",