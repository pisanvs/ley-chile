{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 2,332.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6171527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a las hijas del ex-teniente-coronel de Ej&#xE9;rcito, don Juan Maruri, el goce de una pensi&#xF3;n anual de mil doscientos pesos ($ 1,200), de que disfrutar&#xE1;n con arreglo a las leyes militares, en vez de la que actualmente perciben. </div></div>", "i": 6171528}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica,</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, veintitres de julio de mil novecientos diez.- El&#xED;as Fern&#xE1;ndez Albano.- C&#xE1;rlos Larrain Claro. </div></div>", "i": 6171529}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2332", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2332"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-07-23", "doble_articulado": false, "id_norma": "137310", "numero_fuente": "9757", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-08-01", "vigencias": [{"desde": "1910-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1910-08-01", "fin_vigencia": "", "tipo_version": "3"}], 