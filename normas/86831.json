{"html": [{"t": "<div><div class=\"p\">RECTIFICA RESOLUCION EXENTA No. 872, DE 1991</div><br><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">N&#xFA;m. 1.316 exenta.- Santiago, 22 de Octubre de 1991.- Visto: La facultad establecida en el art&#xED;culo 3&#xB0; No. 26 de la Ley No. 18.410,</div><br><div class=\"p\">Resuelvo:</div><br></div>", "i": 8318194}, {"t": "<div><div class=\"p\">Rectif&#xED;case el Resuelvo 1&#xB0; de la Resoluci&#xF3;n Exenta SEC No. 872/9, publicada en el DO de 05.08.91, en el sentido que donde dice calle San Carlos No. 175, debe decir calle San Carlos No. 715.</div><br></div>", "i": 8318195}, {"t": "<div><div class=\"p\">An&#xF3;tese, notif&#xED;quese y publ&#xED;quese.- Gabriel Inostroza Reyes, Superintendente.</div><div class=\"p\">Lo que comunico a Ud. para su conocimiento.- Saluda atentamente a Ud.- Paulina Concha Gazmuri, Jefe Depto. Adm. y Finanzas.</div><br></div>", "i": 8318196}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1316 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1316 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUPERINTENDENCIA DE ELECTRICIDAD Y COMBUSTIBLES"], "titulo_norma": "RECTIFICA RESOLUCION EXENTA No. 872, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-10-22", "doble_articulado": false, "id_norma": "86831", "numero_fuente": "34106", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-02", "vigencias": [{"desde": "1991-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-11-02", "fin_vigencia": ""}, "vigencias_vers