{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8345499}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;918, de 18 de mayo de 1999, de esta Subsecretar&#xED;a, rectif&#xED;case el numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA;259 de 1999, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA ISLADAMAS S.A., para ampliar actividades pesqueras extractivas con la nave &apos;&apos;Eicomar I&apos;&apos;, matr&#xED;cula 2201, en el sentido de se&#xF1;alar que la interesada podr&#xE1; realizar adem&#xE1;s actividades pesqueras sobre el recurso hidrobiol&#xF3;gico Langostino colorado Pleuroncodes monodon, en el litoral de las regiones I a IV, por fuera del &#xE1;rea de reserva artesanal, con red de arrastre de fondo.</div><br></div>", "i": 8345500}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de mayo de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8345501}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "918", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-918"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-05-18", "fecha_derogacion": "2001-10-04", "doble_articulado": false, "id_norma": "137565", "numero_fuente": "36385", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-06-11", "vigencias": [{"desde": "2001-10-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-06-11", "hasta": "2001-10-03", "tipo_version": "0", "tipo_vers