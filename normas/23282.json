{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza la inversion de la suma de $ 300.000 en el aumento de las Polic&#xED;as de la Rep&#xFA;blica</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,382.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275235}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Se autoriza al Presidente de la Rep&#xFA;blica, con motivo de las fiestas del Centenario, para invertir la cantidad de trescientos mil pesos ($ 300.000) en el aumento de las polic&#xED;as de la Rep&#xFA;blica. </div></div>", "i": 8275236}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 7 de Setiembre de 1910.- EMILIANO FIGUEROA.- Luis Izquierdo.</div><br></div>", "i": 8275237}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2382", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2382"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Autoriza la inversion de la suma de $ 300.000 en el;aumento de las Policías de la República", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTENARIO INDEPENDENCIA NACIONAL", "POLICIAS DE LA", "REPUBLICA", "INVERSION", "DOTACION", "AUMENTO", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-09-07", "doble_articulado": false, "id_norma": "23282", "numero_fuente": "9790", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-09-10", "vi