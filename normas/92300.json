{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.407, DE 1989 </div></div>", "i": 6091167}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n Exenta No. 1.407 de fecha 11 de mayo de 1989 de la Subsecretaria de Educaci&#xF3;n P&#xFA;blica, se aprobaron las adecuaciones introducidas al plan y programas de estudio de la carrera Contabilidad y Auditor&#xED;a del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Nacional de Estudios Superiores de Santiago, las que podr&#xE1;n aplicarse a contar del a&#xF1;o 1989. </div></div>", "i": 6091168}, {"t": "<div><div class=\"p\">Santiago, 09 de Junio de 1989.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6091169}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1407 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1407 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.407, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-06-09", "doble_articulado": false, "id_norma": "92300", "numero_fuente": "33406", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-06-24", "vigencias": [{"desde": "1989-06-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-06-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-06-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1998-02-27", "fecha_version": "1989-06-