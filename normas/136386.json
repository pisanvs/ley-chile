{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 79.- Santiago, 16 de Agosto de 1893.- Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente </div><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6168620}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Los servicios prestados gratuitamente por do&#xF1;a Nieves Barrientos como ayudante de la escuela n&#xFA;m. 1 de Melipilla durante la guerra con Espa&#xF1;a y transcurridos desde el 5 de Octubre de 1865 hasta el 13 del mismo mes de 1869, le servir&#xE1;n de abono para los efectos de su jubilaci&#xF3;n.</div><br></div>", "i": 6168621}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, o&#xED;do el Consejo de Estado, he tenido &#xE1; bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese &#xE1; efecto como ley de la Rep&#xFA;blica.- JORGE MONTT.- J. Rodr&#xED;guez Rozas.</div><br></div>", "i": 6168622}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "79", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-79"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-08-16", "doble_articulado": false, "id_norma": "136386", "numero_fuente": "4597", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-08-17", "vigencias": [{"desde": "1893-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-08-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-08-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": 