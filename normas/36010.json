{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295195}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.006, de 27 de mayo de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por JORGE ALEJANDRO CARLOS JOSE OSSA ARANGUA, para operar un centro de cultivo ubicado en Isla Carmen, Islote Quemado, Comuna y Provincia de Ays&#xE9;n, XI Regi&#xF3;n, conforme lo dispuesto en el art&#xED;culo 78, inciso 2&#xB0;, de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8295196}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 27 de mayo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295197}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1006", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1006"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JORGE OSSA ARANGUA", "DECIMOPRIMERA REGION", "CONCESION", "ACUICULTURA", "AYSEN", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-27", "doble_articulado": false, "id_norma": "36010", "numero_fuente": "35482", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-06-03", "vigencias": [{"desde": "1996-06-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-06-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-06-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe