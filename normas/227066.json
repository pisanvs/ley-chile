{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6485628}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xB0; 809 de fecha 31 de mayo del 2004, se expropiaron los lotes de terreno N&#xB0;s 29 y 32, superficies 210 y 840 m2, respectivamente, Rol N&#xB0; 269101, comuna de San Javier, para la obra &quot;Camino Mejoramiento Ruta 126 Los Conquistadores, sector 2 Carrizal - Puente Belco, tramo Km. 17,34000 a Km.</div><div class=\"p\">23,51000, comuna de San Javier, Provincia de Linares&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Mario Antonio Campos Gonz&#xE1;lez, ascendente a las cantidades de $1.220.403.- para los lotes N&#xB0;s. 29 y 32.- </div></div>", "i": 6485629}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6485630}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "809 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-809 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-31", "doble_articulado": false, "id_norma": "227066", "numero_fuente": "37898", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-01", "vigencias": [{"desde": "2004-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_in