{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10185332}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.180, de 2 de diciembre de 2020, de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n total, conforme art&#xED;culo 51 Ley 16.391, de inmueble ubicado en 9 Norte 1151, Rol Aval&#xFA;o N&#xB0; 1063-3, comuna Talca, superficie 271 m2, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Quilodr&#xE1;n Maldonado Silvia del C. y otros. Comisi&#xF3;n integrada por peritos Patricio Dur&#xE1;n Marcos, Arquitecto; Rodrigo Silva Lazo, Constructor Civil, y Pedro Pablo Cruz Weston, Arquitecto, seg&#xFA;n informe de 25 noviembre 2020, fij&#xF3; monto provisional indemnizaci&#xF3;n en $43.360.000.- pagados al contado.- </div></div>", "i": 10185333}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Claudio Daneck Mu&#xF1;oz, Director (S) Serviu Regi&#xF3;n del Maule.</div><div class=\"p\"> </div><br></div>", "i": 10185334}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2180 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2180 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "VII REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1861594", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-12-02", "doble_articulado": false, "id_norma": "1153584", "numero_fuente": "42830", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-12-15", "vigencias": [{"desde": "2020-12-15", "has