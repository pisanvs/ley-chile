{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div></div>", "i": 10116160}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Con el objeto de combatir la epidemia de la viruela, se concede a las Juntas de Beneficencia de las ciudades que a continuaci&#xF3;n se espresan, las cantidades que en seguida se indican:</div><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/107372.jpg\">.</div><br><div class=\"p\">&nbsp; &nbsp;  Las Juntas de Beneficencia favorecidas por esta lei rendir&#xE1;n cuenta de las&nbsp; cantidades que reciban en la forma acostumbrada.</div></div>", "i": 10116161}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de agosto de 1890.- J. M. BALMACEDA.- B. Prats.</div><br></div>", "i": 10116162}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "33", "numero": "S/N", "abreviacion": "LEI", "descripcion": "Lei", "compuesto": "Lei-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1890-08-13", "doble_articulado": false, "id_norma": "1144327", "numero_fuente": "3964", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1890-08-16", "vigencias": [{"desde": "1890-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic