{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6386884}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.215, de 13 de junio de 2002, modif&#xED;case los numerales 3&#xBA; y 4&#xBA; de la resoluci&#xF3;n N&#xBA; 894, de 2002, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO, para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto denominado &quot;Esfuerzo de la pesca artesanal de merluza del sur en la zona Chilo&#xE9;-Palena, 2002&quot;, en el sentido de se&#xF1;alar que el l&#xED;mite de captura autorizado para el mes de junio se extraer&#xE1; entre los d&#xED;as 26 y el 30 de junio de 2002, ambas fechas inclusive.</div><br></div>", "i": 6386885}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de junio de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6386886}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1215", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1215"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-13", "doble_articulado": false, "id_norma": "199780", "numero_fuente": "37295", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-28", "vigencias": [{"desde": "2002-06-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-06-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-06-28"