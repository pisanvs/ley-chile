{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 4.086 EXENTA, DE 1999 </div><br></div>", "i": 6181471}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 4.086, de 6 de mayo de 1999, se ha aprobado al Instituto Hebreo de Santiago, un plan especial de estudio para primer a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 1999.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para primer a&#xF1;o de ense&#xF1;anza media de los subsectores que se indican en la presente resoluci&#xF3;n.</div><br></div>", "i": 6181472}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de julio de 1999.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6181473}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4086 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4086 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 4.086 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-05-06", "doble_articulado": false, "id_norma": "140274", "numero_fuente": "36433", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-08-07", "vigencias": [{"desde": "1999-08-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-08-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-08-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFI