{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 515 EXENTO, DE 1995</div><br><br></div>", "i": 7162007}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 515 de fecha 1 de septiembre de 1995 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Soeduc, las adecuaciones introducidas al plan y programas de estudio de la carrera Secretariado Ejecutivo en Computaci&#xF3;n, las que se insertaron en la Resoluci&#xF3;n Exenta del Ministerio de Educaci&#xF3;n N&#xB0; 1.003, de 1987. Dichas adecuaciones podr&#xE1;n aplicarse a contar de agosto de 1995.</div><br></div>", "i": 7162008}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 28 de septiembre de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7162009}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "515 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-515 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 515 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA SOEDUC", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-09-01", "doble_articulado": false, "id_norma": "21393", "numero_fuente": "35293", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-10-17", "vigencias": [{"desde": "1995-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-10-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-10-17", "fin_vigencia": "", "tipo_version