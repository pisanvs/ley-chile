{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 344, DE 1985 </div></div>", "i": 7265051}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 344, de 13 de diciembre de 1985 se ha declarado que el Colegio &quot;Enrique de Oss&#xF3;&quot; (Ex - Colegio Santa Teresa de Santiago), aplicar&nbsp; a contar del a&#xF1;o escolar 1986, desde 1&#xB0; a 4&#xB0; a&#xF1;o de ense&#xF1;anza media human&#xED;stico - cient&#xED;fica, el plan y los programas de estudio aprobados por el decreto supremo exento de Educaci&#xF3;n No. 300, de 1981 y sus modificaciones.</div><div class=\"p\">Asimismo, se deroga a contar del a&#xF1;o escolar 1986, el decreto supremo exento de Educaci&#xF3;n No. 116, de 1982. </div></div>", "i": 7265052}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de Enero de 1986.- Ren&#xE9; Salam&#xE9; Martin, </div><div class=\"p\">Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7265053}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "344 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-344 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 344, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-13", "doble_articulado": false, "id_norma": "160771", "numero_fuente": "32442", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-04-09", "vigencias": [{"desde": "1986-04-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-04-09", "fin_vigencia": ""}