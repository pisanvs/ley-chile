{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 15.673 EXENTA, DE 2002 </div></div>", "i": 6417801}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 15.673 de 30 de diciembre del a&#xF1;o 2002, se ha modificado la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 3.227 de 2002, que aprob&#xF3; plan y programas especiales de estudio para 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, al Instituto Santa Mar&#xED;a, comuna de &#xD1;u&#xF1;oa, de Santiago, en el sentido de sustituir, a contar del a&#xF1;o escolar 2002, en el art&#xED;culo 1&#xBA; del plan de estudio de 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, los Subsectores de Formaci&#xF3;n Diferenciada, por los que se indican en la presente resoluci&#xF3;n.</div><br></div>", "i": 6417802}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de enero de 2003.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6417803}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "15673 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-15673 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 15.673 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-30", "doble_articulado": false, "id_norma": "208579", "numero_fuente": "37512", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-03-18", "vigencias": [{"desde": "2003-03-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-03-18", "fin_vigencia": ""}, "vigencias_version_norm