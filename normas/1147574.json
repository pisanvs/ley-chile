{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xB0;1.559 EXENTA, DE 2020</div></div>", "i": 10136551}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 2.308, de fecha 13.07.2020, del Director Nacional de Aduanas, se agregan nuevos numerales III y IV a la <a href=\"https://www.leychile.cl/Navegar?idNorma=1144668&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 1.559, de 17 de abril de 2020</a>, estableciendo la posibilidad de los importadores micro, peque&#xF1;as y medianas empresas, que cumplan los requisitos que se indican, de diferir el pago del Impuesto al Valor Agregado que se cause en las declaraciones de importaci&#xF3;n que se acepten a tr&#xE1;mite en los meses de julio, agosto y septiembre de 2020.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).-</div></div>", "i": 10136552, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div></div>", "i": 10136553}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2308 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-2308 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCIÓN N°1.559 EXENTA, DE 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1785702", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-07-13", "doble_articulado": false, "id_norma": "1147574", "numero_fuente": "42707", "tipo_version": "3", "tipo_version_s": "Única"