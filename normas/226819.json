{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;355 EXENTO, DE 2004 </div></div>", "i": 6484888}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA;355 de 31 de mayo de 2004, se ha aprobado al Colegio Alem&#xE1;n de Santiago, en su calidad de Coordinador y en Representaci&#xF3;n de la Asociaci&#xF3;n de Colegios Alemanes de Chile, los siguientes programas de estudio para los cursos de 1&#xBA; a 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica, los que podr&#xE1;n ser aplicados por los colegios pertenecientes a la Asociaci&#xF3;n de Colegios Alemanes de Chile, a partir del a&#xF1;o escolar 2004.- </div></div>", "i": 6484889}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de junio de 2004.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6484890}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "355 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-355 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº355 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-31", "doble_articulado": false, "id_norma": "226819", "numero_fuente": "37896", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-29", "vigencias": [{"desde": "2004-06-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-06-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-06-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_