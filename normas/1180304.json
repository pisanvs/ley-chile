{"html": [{"t": "<div><div class=\"p\">MODIFICA EL ANEXO 18 DEL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10359606}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 2.195, de 16 de 08 de 2022, del Director Nacional de Aduanas, se modifica el Anexo 18 del <a href=\"https://www.leychile.cl/Navegar?idNorma=248540&amp;idParte=&amp;idVersion=\">Compendio de Normas Aduaneras</a>, en lo relativo a instrucciones sobre impuestos espec&#xED;ficos y adicionales y a ciertos &#xED;tems arancelarios actualizados seg&#xFA;n el Arancel Aduanero Nacional establecido mediante el <a href=\"https://www.leychile.cl/Navegar?idNorma=1169544&amp;idParte=&amp;idVersion=\">decreto de Hacienda N&#xB0; 473, de 26.10.2021</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).-</div></div>", "i": 10359607}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gustavo Poblete Morales, Director Nacional de Aduanas (S).</div></div>", "i": 10359608}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2195 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2195 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA EL ANEXO 18 DEL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2175051", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-08-16", "doble_articulado": false, "id_norma": "1180304", "numero_fuente": "43334", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-08-23", "vigencia