{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,634, que suplementa el Presupuesto de Marina</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,634.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 7166909}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dense los siguientes suplementos a los &#xED;tem que se indican del Presupuesto vijente de Marina:</div><div class=\"p\">&nbsp; Item 96.- La suma de ____________&nbsp; $&nbsp; 150,000.00 m/c</div><div class=\"p\">&nbsp; Item 738.- La suma de ___________&nbsp; &nbsp; &nbsp; 50,000.00&nbsp; &quot;</div><div class=\"p\">&nbsp; &nbsp; D&#xE9;jase sin invertir igual cantidad del &#xED;tem 813 del mismo Presupuesto.</div><br></div>", "i": 7166910}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veinticuatro de Julio de mil novecientos veinte.- JUAN LUIS SANFUENTES.- Ladislao Err&#xE1;zuriz. </div></div>", "i": 7166911}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3634", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3634"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "LEI NUM. 3,634, QUE SUPLEMENTA EL PRESUPUESTO DE MARINA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1920", "MODIFICACION", "MINISTERIO", "MARINA", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1920-07-24", "doble_articulado": false, "id_norma": "24129", "numer