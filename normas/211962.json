{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 7.589 EXENTA, DE 2003 </div></div>", "i": 6429750}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 7.589, de 23 de junio de 2003, del Servicio Nacional de Capacitaci&#xF3;n y Empleo, se revoc&#xF3; la autorizaci&#xF3;n otorgada al organismo t&#xE9;cnico de capacitaci&#xF3;n &quot;Corporaci&#xF3;n para el Desarrollo de la Regi&#xF3;n de Coquimbo&quot; (Corpadeco), RUT N&#xBA; 72.608.100-K, cancel&#xE1;ndose su inscripci&#xF3;n en el Registro Nacional correspondiente, atendido lo dispuesto en el art&#xED;culo 77, letra a) de la ley N&#xBA; 19.518.-</div><br></div>", "i": 6429751}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Eduardo Rodr&#xED;guez Olivares, Jefe Departamento de Capacitaci&#xF3;n en Empresas.</div><br></div>", "i": 6429752}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7589 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7589 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 7.589 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-23", "doble_articulado": false, "id_norma": "211962", "numero_fuente": "37598", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-02", "vigencias": [{"desde": "2003-07-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-07-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-07-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci