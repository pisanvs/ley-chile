{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6558685}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 58, del 4 de enero de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a MARCELA GARIN VARGAS, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Leonor de Corte N&#xBA; 5951, Quinta Normal, Santiago, Regi&#xF3;n Metropolitana, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco-Enfriado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6558686}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de enero de 2006.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6558687}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "58 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-58 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-04", "doble_articulado": false, "id_norma": "246693", "numero_fuente": "38370", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-01-23", "vigencias": [{"desde": "2006-01-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-01-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-01-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2006-01