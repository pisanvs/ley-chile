{"html": [{"t": "<div><div class=\"p\">AUTORIZA A PESQUERA CONO SUR LIMITADA PARA DESARROLLAR ACTIVIDAD PESQUERAS </div></div>", "i": 6238704}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xB0; 41, de 23 de Enero de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Pesquera Cono Sur Limitada, domiciliada en Talcahuano, para operar una planta procesadora de harina y aceite de pescado, en Pedro Montt 261, de San Vicente, Talcahuano, VIII Regi&#xF3;n, en la que podr&#xE1; utilizar como materia prima: sardina espa&#xF1;ola, sardina com&#xFA;n, jurel, caballa y anchoa.</div><br></div>", "i": 6238705}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de Enero de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6238706}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "41", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-41"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA CONO SUR LIMITADA PARA DESARROLLAR\nACTIVIDAD PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-23", "doble_articulado": false, "id_norma": "157498", "numero_fuente": "32382", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-01-27", "vigencias": [{"desde": "1986-01-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-01-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-01-27", "fin_vigencia": "", "tipo_version": "3"