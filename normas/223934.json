{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6474259}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 949, de 6 de abril de 2004, de</div><div class=\"p\">esta Subsecretar&#xED;a, autor&#xED;zase a ALIMENTOS MARINOS S.A.</div><div class=\"p\">&quot;Alimar&quot; para ampliar actividades pesqueras extractivas</div><div class=\"p\">con la nave &quot;Quilpolemu&quot;, en las &#xE1;reas que a</div><div class=\"p\">continuaci&#xF3;n se indican, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; capturar los siguientes recursos hidrobiol&#xF3;gicos: a) En el &#xE1;rea mar&#xED;tima correspondiente a las regiones V, VI, VII, VIII y X, con cerco: Jibia;</div><div class=\"p\">b) En el &#xE1;rea mar&#xED;tima correspondiente a las regiones V, VI, VII, VIII y X, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua: Jibia.</div><br></div>", "i": 6474260}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6474261}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "949", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-949"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-06", "doble_articulado": false, "id_norma": "223934", "numero_fuente": "37839", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-19", "vigencias": [{"desde": "2004-04-19", "hasta": "", "tipo_version": "3", "tipo_ve