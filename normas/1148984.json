{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10155028}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.060, de 21 de agosto de 2020, Serviu Regi&#xF3;n de Valpara&#xED;so, dispuesto expropiaci&#xF3;n conforme al art&#xED;culo 51 ley 16.391 y decreto ley 2.186, de 1978, del inmueble signado como lote 27, en el plano &quot;Proyecto de Expropiaciones DRS-P N&#xBA; 12624&quot; L&#xE1;mina 14 de 16, comuna de Conc&#xF3;n, para la Ejecuci&#xF3;n del Proyecto &quot;Mejoramiento Costero Re&#xF1;aca-Conc&#xF3;n Etapa I, comuna de Conc&#xF3;n&quot; de presunto dominio de varios propietarios, rol aval&#xFA;o desde el 3207-60 hasta el 3207-131. Comisi&#xF3;n Tasadora integrada por &#xC1;lvaro Verdejo Vidal; Jorge Giacaman Valle; e Ismael Allendes Mar&#xED;n, seg&#xFA;n informe de 2019 fij&#xF3; monto indemnizaci&#xF3;n provisional en $27.854.913, que ser&#xE1; pagada al contado.- </div></div>", "i": 10155029}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director Serviu.</div><br></div>", "i": 10155030}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4060 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4060 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "V REGIÓN DE VALPARAÍSO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1807929", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-08-21", "doble_articulado": false, "id_norma": "1148984", "numero_fuente": "42745", "tipo_version": "3", "tipo_version_s": "Única", "fecha_p