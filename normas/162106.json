{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6254316}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. N&#xBA; 134, de 14 de Mayo de 1985, se expropi&#xF3; el lote de terreno N&#xBA; 1, para Agua Potable de Molina, Aducci&#xF3;n El Pichingal, que figura a nombre de don H&#xE9;ctor Rivera Tejera, rol de aval&#xFA;o 632-7, superficie 30.000 m2., comuna de Molino, VII Regi&#xF3;n. La Comisi&#xF3;n de Peritos compuesta por los se&#xF1;ores Renato Guerra Est&#xE9;vez, Carlos Sottolichio D&#xED;az y Ren&#xE9; Ram&#xED;rez Valenzuela, fij&#xF3; con fecha 15 de Octubre de 1982, el valor provisional de la indemnizaci&#xF3;n en la cantidad de $ 120.000. La indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.- </div></div>", "i": 6254317}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6254318}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "134", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-134"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-14", "doble_articulado": false, "id_norma": "162106", "numero_fuente": "32197", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-15", "vigencias": [{"desde": "1985-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "198