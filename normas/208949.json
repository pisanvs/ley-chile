{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6419304}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 53, de 28 de febrero de 2003, se rectific&#xF3; el decreto MOP N&#xBA; 1.753 de 31 de diciembre de 2002, que orden&#xF3; la expropiaci&#xF3;n del lote de terreno N&#xBA; 39-D, en el sentido de indicar que el monto de la indemnizaci&#xF3;n es la suma de $1.148.275.- y no como en &#xE9;l se se&#xF1;ala. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.-</div><br></div>", "i": 6419305}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6419306}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "53", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-53"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-02-28", "doble_articulado": false, "id_norma": "208949", "numero_fuente": "37524", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-04-01", "vigencias": [{"desde": "2003-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "CNB", "fecha_ingreso": "2003-04-01", "fecha_version": "2003-04-01", "fecha_actualizacion_texto": "2003-04-01"