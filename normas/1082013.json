{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA A INSTITUCI&#xD3;N SIN FINES DE LUCRO, COMO RECEPTORA DE ALIMENTOS CUYA COMERCIALIZACI&#xD3;N SEA INVIABLE</div><div class=\"p\">&nbsp; </div></div>", "i": 9637559}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n Ex. del Servicio de Impuestos Internos, N&#xBA; 74 de 14 de septiembre de 2015, que autoriza a la Instituci&#xF3;n sin fines de lucro, Movimiento An&#xF3;nimo por la Vida, RUT N&#xBA; 71.414.100-7, como receptora en forma gratuita de alimentos, cuya comercializaci&#xF3;n sea inviable.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de septiembre de 2015.</div></div>", "i": 9637560}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "74 EXENTO", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-74 EXENTO"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A INSTITUCIÓN SIN FINES DE LUCRO, COMO RECEPTORA DE ALIMENTOS CUYA COMERCIALIZACIÓN SEA INVIABLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN; IdDO 946586"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-09-14", "doble_articulado": false, "id_norma": "1082013", "numero_fuente": "41262", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-09-21", "vigencias": [{"desde": "2015-09-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2015