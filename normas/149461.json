{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 544, DE 1987 </div></div>", "i": 7257574}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 544 de fecha 23 de marzo de 1987, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se modific&#xF3; el Art. 1&#xB0; de la resoluci&#xF3;n exenta de Educaci&#xF3;n No. 1.020 de 1985 del Centro de Formaci&#xF3;n T&#xE9;cnica CEDECOM, en el sentido de autorizar por una sola vez, plan especial de estudios a los alumnos ingresados durante 1983 y 1984 a la carrera Programaci&#xF3;n Computacional, a fin de regularizar las diferentes situaciones acad&#xE9;micas de los alumnos.</div><br></div>", "i": 7257575}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7257576}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "544 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-544 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N° 544, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-03-23", "doble_articulado": false, "id_norma": "149461", "numero_fuente": "32782", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-05-29", "vigencias": [{"desde": "1987-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-05-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-05-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu