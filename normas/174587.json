{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6297618}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;1.757, de 9 de agosto de 2000, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA; de la resoluci&#xF3;n N&#xBA;1.682, de 2000, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO, para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &apos;&apos;Pesquer&#xED;a Artesanal del Jurel en la VIII Regi&#xF3;n&apos;&apos;, en el sentido de incorporar la nave &apos;&apos;V&#xED;ctor Guillermo&apos;&apos; a la n&#xF3;mina de naves participantes en la se&#xF1;alada investigaci&#xF3;n.</div><br></div>", "i": 6297619}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de agosto de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6297620}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1757", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1757"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-08-09", "doble_articulado": false, "id_norma": "174587", "numero_fuente": "36747", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-24", "vigencias": [{"desde": "2000-08-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-08-24", "fin_vig