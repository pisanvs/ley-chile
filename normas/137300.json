{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 2,306.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6171497}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Joaquina Pinto, viuda del servidor p&#xFA;blico don Benjamin Vergara i a sus hijas solteras do&#xF1;a Mar&#xED;a, do&#xF1;a Adriana i do&#xF1;a Blanca Vergara Pinto, una pensi&#xF3;n de tres mil seiscientos pesos ($ 3,600) al a&#xF1;o que recibir&#xE1;n en conformidad a lei de montep&#xED;o militar&quot;.</div><br></div>", "i": 6171498}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiocho de junio de mil novecientos diez.- Pedro Montt.- C&#xE1;rlos Larrain Claro.</div><br></div>", "i": 6171499}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2306", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2306"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-06-28", "doble_articulado": false, "id_norma": "137300", "numero_fuente": "9738", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-07-09", "vigencias": [{"desde": "1910-07-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-07-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic