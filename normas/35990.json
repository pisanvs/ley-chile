{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295141}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 993, de 22 de mayo de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por AGUAS CLARAS</div><div class=\"p\">S.A., para un centro de cultivo ubicado en Farellones,</div><div class=\"p\">Marimeli, Estero Reloncav&#xED;, Comuna de Cocham&#xF3;, Provincia</div><div class=\"p\">de Llanquihue, X Regi&#xF3;n, conforme lo dispuesto en el</div><div class=\"p\">art&#xED;culo 78 inciso 2&#xB0; de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8295142}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 22 de mayo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295143}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "993", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-993"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "AGUAS CLARAS S.A.", "COCHAMO", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-22", "doble_articulado": false, "id_norma": "35990", "numero_fuente": "35478", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-05-29", "vigencias": [{"desde": "1996-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-05-29", "fin_vig