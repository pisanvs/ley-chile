{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 2.231 EXENTA, DE 2013</div></div>", "i": 9358669}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto resoluci&#xF3;n exenta N&#xBA; 2.231, de 24 de mayo de 2013, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, que produce efectos desde su fecha de dictaci&#xF3;n, proh&#xED;be el d&#xED;a 25 de mayo del presente a&#xF1;o, la circulaci&#xF3;n de veh&#xED;culos motorizados de cuatro o m&#xE1;s ruedas que se se&#xF1;alan en el presente cuadro, seg&#xFA;n tipo o servicio y &#xFA;ltimo d&#xED;gito de placa patente, en los horarios y per&#xED;metros que se indican, encontr&#xE1;ndose exceptuados de esta prohibici&#xF3;n todos los veh&#xED;culos aludidos en el resuelvo 4, de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1049677&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.352/2013</a>, de esta Secretar&#xED;a Regional Ministerial.</div><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/33281.jpg\"></div></div>", "i": 9358670}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Sergio Stephan Orellana, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div></div>", "i": 9358671}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2231 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2231 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL REGIÓN METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 2.231 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tra