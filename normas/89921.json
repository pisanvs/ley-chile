{"html": [{"t": "<div><div class=\"p\">DESIGNA SUBSECRETARIO DE TELECOMUNICACIONES</div><br><div class=\"p\">N&#xFA;m. 79.- Santiago, 11 de Marzo de 1990.- Visto: Lo dispuesto por el art&#xED;culo 32 No. 9 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica.</div><br><div class=\"p\">Decreto:</div><br></div>", "i": 6084100}, {"t": "<div><div class=\"p\">Art&#xED;culo &#xFA;nico: Des&#xED;gnase, a contar de esta fecha, a Don Roberto Jacobo Pliscoff V&#xE1;squez en el cargo de Subsecretario de Telecomunicaciones, quien por razones impostergables de buen servicio deber&#xE1; asumir de inmediato sus funciones. </div></div>", "i": 6084101}, {"t": "<div><div class=\"p\">An&#xF3;tese, t&#xF3;mese raz&#xF3;n, reg&#xED;strese y publ&#xED;quese.- PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Germ&#xE1;n Correa D&#xED;az, Ministro de Transportes y Telecomunicaciones. Lo que transcribo a Ud. para su conocimiento.- Saluda atentamente a Ud.- Roberto Pliscoff V&#xE1;squez, Subsecretario de Telecomunicaciones.</div><br></div>", "i": 6084102}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "79", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-79"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TELECOMUNICACIONES"], "titulo_norma": "DESIGNA SUBSECRETARIO DE TELECOMUNICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-11", "doble_articulado": false, "id_norma": "89921", "numero_fuente": "33635", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-31", "vigencias": [{"desde": "1990-03-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Únic