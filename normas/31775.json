{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE RESOLUCION </div></div>", "i": 6001912}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 1 de 29 de Abril de 1994, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la II Regi&#xF3;n, se adjudic&#xF3; a do&#xF1;a Nelly Amanda Flores Rebolledo, la concesi&#xF3;n para operar, hasta 1&#xB0; de Octubre de 1997, un establecimiento ubicado en calle Salar del Carmen N&#xB0; 560, comuna de Antofagasta, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de contaminantes de todo tipo de veh&#xED;culos motorizados, sus remolques y semiremolques, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 6001913}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Gast&#xF3;n Viveros Viveros, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n de Antofagasta.</div><br></div>", "i": 6001914}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REVISION TECNICA", "VEHICULOS MOTORIZADOS", "PLANTA REVISION TECNICA", "ANTOFAGASTA", "SEGUNDA REGION", "NELLY AMANDA FLORES REBOLLEDO", "CONCESION REVISION TECNICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-04-29", "doble_articulado": false, "id_norma": "31775", "numero_fuente": "34891", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-06-16", "vigencias": [{"desde": "1994-06-16", "hasta": "", "tipo_version"