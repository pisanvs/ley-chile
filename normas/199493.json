{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7292306}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.158, de 11 de junio de 2002, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 538 de 1989 de esta Subsecretar&#xED;a s&#xF3;lo en cuanto autoriz&#xF3; a SERGIO SANTA CRUZ GANDARILLAS, para instalar un centro de cultivo del recurso Osti&#xF3;n del Norte, ubicado en Bah&#xED;a Barnes, Comuna de Coquimbo, IV Regi&#xF3;n, en virtud de la renuncia presentada por su titular.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 938 de 1995, de esta Subsecretar&#xED;a, que aprob&#xF3; el Proyecto T&#xE9;cnico y Cronograma de Actividades para el centro de cultivo individualizado.</div><br></div>", "i": 7292307}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de junio de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7292308}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1158", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1158"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-11", "doble_articulado": false, "id_norma": "199493", "numero_fuente": "37288", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-20", "vigencias": [{"desde": "2002-06-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-06-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio