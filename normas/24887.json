{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n al ex-ingeniero de la Armada, don Pedro Kemner.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional a dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5960686}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. En atenci&#xF3;n a los servicios prestados por el se&#xF1;or ex-ingeniero mayor de segunda clase de la Armada, don Pedro Kemner Rodr&#xED;guez, conc&#xE9;desele, por gracia y a contar desde el 1.o de Enero de 1930, una pensi&#xF3;n de doce mil pesos ($12,000) anuales.</div><br></div>", "i": 5960687}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta y uno de Diciembre de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Carlos O. Frodden.</div><br></div>", "i": 5960688}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4754", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4754"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "CONCEDE PENSION AL EXINJENIERIO DE LA ARMADA, DON PEDRO KEMNER.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PEDRO KEMNER", "PENSION POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-12-31", "doble_articulado": false, "id_norma": "24887", "numero_fuente": "15578", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-01-22", "vigencias": [{"desde": "1930-01-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vi