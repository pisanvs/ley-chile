{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 3.589 EXENTA, DE 2002 </div></div>", "i": 6380372}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 3.589, de 28 de marzo de 2002, se ha aprobado al Lyce&#xE9; de L&apos;Alliance Fran&nbsp; &nbsp;  aise Antoine de Saint-Exup&#xE9;ry de Santiago y al resto de los colegios Alianza Francesa de Chile, un plan de estudio para 4&#xBA; a&#xF1;o de ense&#xF1;anza media, que se aplicar&#xE1; a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en la presente resoluci&#xF3;n.</div><br></div>", "i": 6380373}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de abril de 2002.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6380374}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3589 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3589 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 3.589 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-28", "doble_articulado": false, "id_norma": "197765", "numero_fuente": "37251", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-06", "vigencias": [{"desde": "2002-05-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen