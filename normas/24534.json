{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 7168275}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Apru&#xE9;base el traspaso de la cantidad de un mill&#xF3;n quinientos mil pesos ($ 1.500,000), del &#xED;tem 167, Cap&#xED;tulo IV, al &#xED;tem 26, Cap&#xED;tulo I, del Presupuesto de Obras P&#xFA;blicas vigente, traspaso que el Vice-Presidente de la Rep&#xFA;blica ha autorizado por decreto n&#xFA;mero 1,441, de 4 de Mayo en curso.&quot; </div></div>", "i": 7168276}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a dos de Septiembre de mil novecientos veintisiete.- Carlos Ib&#xE1;&#xF1;ez del Campo.- Ortiz Vega. </div></div>", "i": 7168277}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4172", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4172"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O", "1927", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1927-09-02", "doble_articulado": false, "id_norma": "24534", "numero_fuente": "14879", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1927-09-23", "vigencias": [{"desde": "1927-09-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1927-09-23", "fin_vigencia": ""}, "vigencias_v