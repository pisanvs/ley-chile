{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUAS EN COMUNA DE GRANEROS</div><br><br></div>", "i": 6061284}, {"t": "<div><br><div class=\"p\">Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 1221, de 20 de Agosto de 1990, conforme art&#xED;culo 5&#xB0; transitorio C&#xF3;digo Aguas complement&#xF3; Resoluci&#xF3;n Exenta No. 889 de 25 de Junio de 1987, en el sentido de determinar derechos aprovechamiento aguas proporcionales que corresponden a parcelas No. 16 a la 29 del Proyecto de Parcelaci&#xF3;n El Mait&#xE9;n, de la comuna de Graneros, VI Regi&#xF3;n. Los derechos de aguas se extraen de Pozo Profundo CELZAC No. 947 ubicado en parcela No. 16 del Proyecto El Mait&#xE9;n. Publicaci&#xF3;n hecha conforme art&#xED;culo 13 Ley No. 18.377.</div><br></div>", "i": 6061285}, {"t": "<div><div class=\"p\">- Director Nacional.</div><br></div>", "i": 6061286}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1221 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1221 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DERECHOS DE AGUAS EN COMUNA DE GRANEROS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-08-20", "doble_articulado": false, "id_norma": "82011", "numero_fuente": "33793", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-10-15", "vigencias": [{"desde": "1990-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-10-15", "fin_vigencia": "", "tipo_version": "3"}], "ev