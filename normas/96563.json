{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8327560}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xBA;. 187 de 31 de Enero de 1991, de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n, se declara la caducidad de las resoluciones</div><div class=\"p\">N&#xBA;. 962, de 1987, No. 643, de 1988 y No. 387, de 1989, todas</div><div class=\"p\">de esta Subsecretar&#xED;a, por las cuales se autoriz&#xF3; a SOCIEDAD</div><div class=\"p\">LEONEL POLGATTI Y CIA. LTDA., PESQUERA POLMAR LIMITADA,</div><div class=\"p\">R.U.T. N&#xBA;. 79.719.210-4 domiciliada en Santiago, para</div><div class=\"p\">iniciar y ampliar actividades pesqueras extractivas mediante</div><div class=\"p\">una nave en construcci&#xF3;n en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 7&#xB0; del DS N&#xBA;. 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8327561}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 31 de Enero de 1991.- Andr&#xE9;s Couve Rioseco Subsecretario de Pesca.</div><br></div>", "i": 8327562}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "187", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-187"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-31", "doble_articulado": false, "id_norma": "96563", "numero_fuente": "33896", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-02-16", "vigencias": [{"de