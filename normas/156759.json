{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6236645}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta N&#xB0; 21 de 11 de Enero de 1985, conforme Art. 5&#xB0; transitorio C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento de aguas proporcionales que corresponden a la Reserva y Sector expropiado Predio &quot;Las Vegas&quot; de la comuna de Los Angeles, VIII Regi&#xF3;n, y derechos de aprovechamiento de aguas que corresponden a las parcelas N&#xB0;s 1 a la 10, sitios N&#xB0;s 4 al 17 del proyecto de Parcelaci&#xF3;n &quot;Poder Campesino&quot; formado por el predio se&#xF1;alado. Los derechos de agua se extraen del Canal Laja y Estero Rarinco, Publicaci&#xF3;n hecha conforme Art. 13 Ley N&#xB0; 18.377.-</div><br></div>", "i": 6236646}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6236647}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "21 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-21 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-11", "doble_articulado": false, "id_norma": "156759", "numero_fuente": "32110", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-01", "vigencias": [{"desde": "1985-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-03-01", "fin_vigencia": "", "tipo_versio