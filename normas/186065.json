{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6337312}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 882, de 14 de mayo de 2001, de esta Subsecretar&#xED;a, autor&#xED;zase a la UNIVERSIDAD DE ANTOFAGASTA para efectuar una pesca de investigaci&#xF3;n de conformidad al Proyecto denominado &quot;Conservaci&#xF3;n y Protecci&#xF3;n de la Reserva Marina La Rinconada, Antofagasta&quot;, la que se realizar&#xE1; bajo las mismas condiciones y obligaciones previstas por las resoluciones N&#xBA;637, de 1999 y N&#xBA; 857 de 2000, ambas de esta Subsecretar&#xED;a, que autorizaron la primera etapa del proyecto citado.</div><br></div>", "i": 6337313}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de mayo de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6337314}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "882", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-882"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-14", "doble_articulado": false, "id_norma": "186065", "numero_fuente": "36977", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-06-02", "vigencias": [{"desde": "2001-06-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-06-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-06-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text":