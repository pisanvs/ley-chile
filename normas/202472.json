{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6396129}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;1.860, modif&#xED;case el numeral 3&#xBA; de la resoluci&#xF3;n N&#xBA;1.595, de 2002, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la UNIVERSIDAD CATOLICA DE VALPARAISO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto denominado &quot;Evaluaci&#xF3;n directa de langostino amarillo y langostino colorado, entre las Regiones V y VIII, 2002&quot;,&nbsp; en el sentido de se&#xF1;alar que la pesca de investigaci&#xF3;n se realizar&#xE1; entre el 1 de agosto y el 25 de septiembre de 2002, ambas fechas inclusive.</div><br></div>", "i": 6396130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so 30 de agosto de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6396131}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1860", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1860"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-08-30", "doble_articulado": false, "id_norma": "202472", "numero_fuente": "37358", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-09-12", "vigencias": [{"desde": "2002-09-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-09-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-09-12", "fin_vigencia": "", "tipo_ve