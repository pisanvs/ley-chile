{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8306934}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.298, de 2 de octubre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case&nbsp; la Resoluci&#xF3;n N&#xBA;&nbsp; 906, de 1997, de esta Subsecretar&#xED;a, que fij&#xF3; la n&#xF3;mima de armadores y embarcaciones que cumplen con los requisitos legales para operar en la unidad de pesquer&#xED;a de Camar&#xF3;n nailon, en el litoral de la II a la VIII Regiones, se&#xF1;alada en el art&#xED;culo 1&#xBA; del D.S. N&#xBA; 611 de 1995, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, en el &#xE1;rea se&#xF1;alada en sus respectivas autorizaciones, en el sentido de incorporar en el numeral 1&#xBA; lo siguiente: &quot;PESQUERA SANTA LUCIA S.A.: Walrus&quot;.</div><br></div>", "i": 8306935}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de octubre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8306936}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1298", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1298"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ARMADORES INDUSTRIALES", "NOMINA", "PESCA", "CAMARON NAILON", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-10-02", "fecha_derogacion": "1998-01-24", "doble_articulado": false, "id_norma": "76256", "numero_fuente": "35889", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_pub