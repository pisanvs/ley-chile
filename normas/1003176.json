{"html": [{"t": "<div><br><div class=\"p\">DEROGA AUTORIZACI&#xD3;N DE EMISORES ELECTR&#xD3;NICOS</div></div>", "i": 8677406}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 82, de 3 de junio de 2009, que deroga autorizaci&#xF3;n otorgada a contribuyentes para operar como emisores electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  A petici&#xF3;n de los contribuyentes RUT N&#xBA; 76.218.950-K, RUT N&#xBA; 99.535.380-6, RUT N&#xBA; 79.618.560-0 y RUT N&#xBA; 77.666.120-1, se deroga autorizaci&#xF3;n otorgada para operar como emisores de Documentos Tributarios Electr&#xF3;nicos.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de junio, de 2009.</div></div>", "i": 8677407}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "82 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-82 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEROGA AUTORIZACIÓN DE EMISORES ELECTRÓNICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-06-03", "doble_articulado": false, "id_norma": "1003176", "numero_fuente": "39380", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-06-06", "vigencias": [{"desde": "2009-06-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-06-06", "fin_vigencia": ""}