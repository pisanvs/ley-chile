{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 3.764 EXENTA, DE 2016, DE ESTA SUBSECRETAR&#xCD;A</div></div>", "i": 9822005}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.433, de 27 de julio de 2017, de esta Subsecretar&#xED;a, modif&#xED;quese el numeral 1&#xBA;.- de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1098126&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.764, de 2016</a>, en el sentido de se&#xF1;alar que la distribuci&#xF3;n de la fracci&#xF3;n artesanal de anchoveta de la III y IV Regiones, a&#xF1;o 2017, ascendente a 25.315 toneladas, se efectuar&#xE1; de la siguiente manera:</div><br><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/69099.jpg\"></div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\"> </div></div>", "i": 9822006}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de julio de 2017.- Pablo Berazaluce Maturana, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9822007}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2433 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2433 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 3.764 EXENTA, DE 2016, DE ESTA SUBSECRETARÍA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1251576; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_pr