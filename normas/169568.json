{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6278153}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;804, de 28 de abril de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a PRODUCTOS QUIMICOS ALGINA S.A., para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en Juan Williams N&#xBA;012812, Sector R&#xED;o Seco, comuna de Punta Arenas, provincia de Magallanes, XII Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos:</div><div class=\"p\">Lavado-Deshidratado: Luga Luga, Luga roja, Chasc&#xF3;n, Huiro y Cochayuyo.</div><br></div>", "i": 6278154}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de abril de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6278155}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "804", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-804"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-28", "doble_articulado": false, "id_norma": "169568", "numero_fuente": "36674", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-27", "vigencias": [{"desde": "2000-05-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente