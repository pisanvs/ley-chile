{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CERTIFICADO</div><br></div>", "i": 6445148}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n que suscribe, certifica que la Universidad del Mar inscrita bajo el n&#xFA;mero C- N&#xBA; 30 del Registro de Universidades del Ministerio de Educaci&#xF3;n, ha presentado los programas de estudios de la carrera de Contador Auditor conducente al t&#xED;tulo de Contador Auditor a la Universidad Arturo Prat quien lo ha aprobado y se ha constituido en entidad examinadora, de conformidad a lo establecido en acuerdo suscrito entre ambas instituciones con fecha 24 de septiembre de 1990.</div><div class=\"p\">&nbsp; &nbsp;  La carrera mencionada podr&#xE1; impartirse a contar desde 1991.</div><br></div>", "i": 6445149}, {"t": "<div><div class=\"p\">Santiago, 23 de julio de 1991.</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  RAUL ALLARD NEUMANN</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Subsecretario de Educaci&#xF3;n</div><br></div>", "i": 6445150}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-07-23", "doble_articulado": false, "id_norma": "216286", "numero_fuente": "34040", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-08-10", "vigencias": [{"desde": "1991-08-10", "hasta": "", "tipo_ver