{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A CONTRIBUYENTE QUE INDICA </div></div>", "i": 6558176}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La IV Direcci&#xF3;n Regional La Serena revoca la calidad de agente retenedor del Impuesto al Valor Agregado en las ventas que se indica, al contribuyente que se se&#xF1;ala:</div><br><div class=\"p\">Contribuyente&nbsp; R.U.T. N&#xBA;&nbsp; Res. N&#xBA;&nbsp; Fecha&nbsp; &nbsp;  Venta de</div><br><div class=\"p\">Christian</div><div class=\"p\">Patricio</div><div class=\"p\">Alfaro</div><div class=\"p\">Flores&nbsp; &nbsp; &nbsp; 11.422.251-8&nbsp;  1724&nbsp;  30-12-2005&nbsp; Harina</div><br><div class=\"p\">&nbsp; &nbsp;  A contar de la fecha de la publicaci&#xF3;n de este extracto en el Diario Oficial conforme a la facultad delegada en el dispositivo N&#xBA;17 de la resoluci&#xF3;n exenta N&#xBA;5.282 de 30/11/2000, emanada de la Direcci&#xF3;n Nacional de este Servicio.</div><br></div>", "i": 6558177}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Serena, treinta de diciembre de 2005.- Alonso Vergara Arce, Director Regional (S).</div><br></div>", "i": 6558178}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1724", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1724"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IV DIRECCIÓN REGIONAL LA SERENA"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A\nCONTRIBUYENTE QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-30", "doble_articulado": false, "id_norma": "246548", "numero_fuente": "38367", "tipo_version": "3", "t