{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A COMERCIALIZADORA DE SERVICIOS LIMITADA </div></div>", "i": 6389486}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional Santiago Poniente del SII, por resoluci&#xF3;n N&#xBA; Ex. 722 de 05 de julio de 2002 revoca la calidad de agente retenedor del Impuesto al Valor Agregado en las compras de carne y faenamiento de ganado concedida mediante certificado N&#xBA; 52 de 24.07.1998, de la Direcci&#xF3;n Metropolitana Santiago Centro, a la empresa Comercializadora de Servicios Limitada, RUT</div><div class=\"p\">78.518.730-K, con vigencia a contar del d&#xED;a 1&#xBA; del mes siguiente al de su publicaci&#xF3;n en el Diario Oficial. </div></div>", "i": 6389487}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jorge A. de Calisto Bravo, Director Regional. </div></div>", "i": 6389488}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "722 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-722 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO PONIENTE"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A COMERCIALIZADORA DE SERVICIOS LIMITADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-07-05", "doble_articulado": false, "id_norma": "200641", "numero_fuente": "37314", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-22", "vigencias": [{"desde": "2002-07-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-22", "fin_vigencia": ""}, "vig