{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 147 EXENTA, DE 2000 </div></div>", "i": 6317321}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Con fecha 26 de diciembre del a&#xF1;o 2000, la Secretar&#xED;a Regional Ministerial de Bienes Nacionales de la IX Regi&#xF3;n, dict&#xF3; resoluci&#xF3;n exenta N&#xBA; 147, por medio de la cual se le otorga al Consejo Comunal del Adulto Mayor de Curacaut&#xED;n, una Concesi&#xF3;n de Uso Gratuito del inmueble fiscal ubicado en calle Riquelme N&#xBA; 956, lote 3-a, Manzana N&#xBA; 69 de la ciudad de Curacaut&#xED;n, comuna del mismo nombre, provincia de Malleco, IX Regi&#xF3;n de la Araucan&#xED;a, por un plazo de 5 a&#xF1;os.</div><br></div>", "i": 6317322}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Adolfo de la Jara Dur&#xE1;n, Secretario Regional Ministerial de Bienes Nacionales IX Regi&#xF3;n.</div><br></div>", "i": 6317323}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "147 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-147 EXENTA"}], "organismos": ["MINISTERIO DE BIENES NACIONALES", "SECRETARÍA REGIONAL MINISTERIAL", "IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 147 EXENTA, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-12-26", "doble_articulado": false, "id_norma": "180489", "numero_fuente": "36865", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-18", "vigencias": [{"desde": "2001-01-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig