{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9285704}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (exento) N&#xBA;1189 de fecha 29 de junio de 2012, y de conformidad a lo dispuesto en el Art. 105 del DFL. MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;14, superficie 382 m2, rol N&#xBA;2113-107, para la obra &quot;Mejoramiento Ruta V-815, Tramo: Bif. Ilque-Cruce Ruta V-85&quot;, Comuna de Puerto Montt, X Regi&#xF3;n de Los Lagos. La Comisi&#xF3;n de Peritos integrada por Nelson Bernardo Turra Turra, Christian Emil Rauch Y&#xE1;&#xF1;ez y Nelson Fab&#xED;an Igor Flores, fij&#xF3; valor de tasaci&#xF3;n con fecha 25 de octubre de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario REN&#xC9; LUIS MANR&#xCD;QUEZ ENCINA, en la cantidad de $671.192, suma que se pagar&#xE1; al contado. </div></div>", "i": 9285705}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9285706}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1189 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1189 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-29", "doble_articulado": false, "id_norma": "1042448", "numero_fuente": "40326", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-08-01", "vigencias": [{"desde": "2012-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici