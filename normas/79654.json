{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8310150}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n N&#xB0;. 333, de 14 de Abril de 1992, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0;. 745, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don Jos&#xE9; Manuel Hugo M&#xE1;rquez Rojas, RUT N&#xB0;. 6.103.933-3, domiciliado en calle Ram&#xED;rez N&#xB0;. 479, Ancud y domicilio Postal Casilla N&#xB0;.</div><div class=\"p\">52, Ancud, X Regi&#xF3;n, para operar un establecimiento de cultivo, en Estero El Dique, sector Nal, Comuna de Ancud, Provincia de Chilo&#xE9;, X Regi&#xF3;n, por renuncia total de su titular, ya individualizado.</div><br></div>", "i": 8310151}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 14 de Abril de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8310152}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "333", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-333"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-04-14", "doble_articulado": false, "id_norma": "79654", "numero_fuente": "34252", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-04-27", "vigencias": [{"desde": "1992-04-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-04-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-04-27", "fin_vige