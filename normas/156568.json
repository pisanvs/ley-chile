{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6235986}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n, por resoluci&#xF3;n No. 9, de fecha 19.02. 88, ha autorizado a Buses B&#xED;o B&#xED;o Ltda., para efectuar toda clase de servicios de transporte de pasajeros, por calles y caminos dentro del territorio nacional, a expeci&#xF3;n de los servicios p&#xFA;blicos de locomoci&#xF3;n colectiva urbanos, de acuerdo a lo dispuesto en el DS 163/84. </div></div>", "i": 6235987}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Temuco, 19 de Febrero de 1986.- Oscar C&#xF3;rdova Jim&#xE9;nez, Secretario Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n.</div><br></div>", "i": 6235988}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-9"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-02-19", "doble_articulado": false, "id_norma": "156568", "numero_fuente": "32412", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-03-03", "vigencias": [{"desde": "1986-03-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-03-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-03-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi