{"html": [{"t": "<div><div class=\"p\">COMPLEMENTA DECRETO N.o 1.296, DE 1966</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 1.o de Julio de 1971.- Hoy se decret&#xF3; lo que sigue:</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 1.207.- Visto lo dispuesto en el art&#xED;culo 190 de la ley N.o 16.464 y sus modificaciones posteriores, </div><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 7289408}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Complem&#xE9;ntase el decreto de Hacienda N.o 1.296, de 11 de Mayo de 1966, en el sentido que se incluye exclusivamente en sus disposiciones la importaci&#xF3;n que efect&#xFA;e la Corporaci&#xF3;n &quot;Urracas&quot; con cargo a la resoluci&#xF3;n N.o 185 de 31 de Mayo de 1971, del Ministerio de Hacienda.</div><br></div>", "i": 7289409}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- S. ALLENDE G.- Am&#xE9;rico Zorrilla R.</div><br><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda atentamente a Ud.- Patricio Morales Salinas, Subsecretario de Hacienda.</div><br></div>", "i": 7289410}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1207", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1207"}], "organismos": ["MINISTERIO DE HACIENDA", "SUBSECRETARÍA DE HACIENDA"], "titulo_norma": "COMPLEMENTA DECRETO Nº 1.296, DE 1966", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1971-07-01", "doble_articulado": false, "id_norma": "194223", "numero_fuente": "27988", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1971-07-03", "vigencias": [{"desde": "1971-07-03