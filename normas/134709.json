{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 90 EXENTO, DE 1999</div><br><br></div>", "i": 6163229}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 90, de 5 de abril de 1999, se han validado los estudios realizados por los alumnos de los establecimientos que se rigen por las leyes N&#xBA;s. 14.037 y 15.348 y se otorgar&#xE1;n por los respectivos Secretarios Regionales Ministeriales de Educaci&#xF3;n las Licencias Medias y, seg&#xFA;n los casos, los t&#xED;tulos de t&#xE9;cnicos de nivel medio en la especialidad correspondiente.</div><br></div>", "i": 6163230}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de abril de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6163231}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "90 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-90 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 90 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-04-05", "doble_articulado": false, "id_norma": "134709", "numero_fuente": "36336", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-04-12", "vigencias": [{"desde": "1999-04-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-04-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-04-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-04-12", "fecha_ve