{"html": [{"t": "<div><div class=\"p\">APRUEBA ORDENANZA MUNICIPAL QUE INDICA </div></div>", "i": 6148380}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La I. Municipalidad de Molina mediante decreto exento No. 018/87, del 20.02.87, aprob&#xF3; la Ordenanza Municipal de Terminal de Locomoci&#xF3;n Colectiva No Urbana de Molina, la cual se encuentra a disposici&#xF3;n de los interesados en la Secretar&#xED;a Municipal y Departamento de Tr&#xE1;nsito y a sido notificada a la comunidad mediante carteles fijados en el hall del edificio Municipal.</div><br></div>", "i": 6148381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Gino Carpanetti Lanyon, secretario municipal. </div></div>", "i": 6148382}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "18", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-18"}, {"tipo": "2", "numero": "18/87", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-18/87"}], "organismos": ["MUNICIPALIDAD DE MOLINA"], "titulo_norma": "APRUEBA ORDENANZA MUNICIPAL QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-20", "doble_articulado": false, "id_norma": "129877", "numero_fuente": "33157", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-08-27", "vigencias": [{"desde": "1988-08-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-08-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-08-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-01-15", "fecha_version": "1988-08-2