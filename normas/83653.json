{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6065926}, {"t": "<div><div class=\"p\">Por Decreto Secc. 2da. No. 80, de fecha, 12 de Enero de 1990, Alcalde I. Municipalidad de Santiago, dispone expropiaci&#xF3;n parcial conforme DS No. 458 de Vivienda y Urbanismo, Decreto Ley 2.186 y Ley 18.695, inmueble Agustinas 2331-2333, Rol 332-4 Santiago, aparente dominio Mar&#xED;a Salinas Bouvret, superficie aproximada a expropiar 403 m2. Deslindes: Norte, 13,40 mts. con resto del predio; Sur, 13,60 mts. con calle Agustinas; Oriente, 29,70 mts. con otro propietario y Poniente, 30,00 mts. con otro propietario. Indemnizaci&#xF3;n provisional $ 8.003.000.- pagadera contado. </div></div>", "i": 6065927}, {"t": "<div><div class=\"p\">M&#xE1;ximo Honorato Alamos, Alcalde Santiago.</div><br></div>", "i": 6065928}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "80", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-80"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-12", "doble_articulado": false, "id_norma": "83653", "numero_fuente": "33585", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-01", "vigencias": [{"desde": "1990-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1998-01-09", "fecha_version": "1990-02-01", "fecha_actualiza