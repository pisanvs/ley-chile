{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6444177}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.405, de 8 de octubre de 2003,</div><div class=\"p\">de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las</div><div class=\"p\">resoluciones N&#xBA; 1.064 de 1992, N&#xBA; 1.141 de 1998, N&#xBA;</div><div class=\"p\">1.862 y N&#xBA; 2.384 de 2000, y N&#xBA; 1.146 de 2001, todas de</div><div class=\"p\">esta Subsecretar&#xED;a, y que autorizaron a don MARIO</div><div class=\"p\">FLORINDO GAJARDO VENEGAS para desarrollar actividades</div><div class=\"p\">pesqueras extractivas con la nave &quot;Noel I&quot;, matr&#xED;cula</div><div class=\"p\">2800, en virtud de lo dispuesto en la letra d) del</div><div class=\"p\">art&#xED;culo 143 de la Ley General de Pesca y Acuicultura. </div></div>", "i": 6444178}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de octubre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6444179}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2405", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2405"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-10-08", "fecha_derogacion": "2004-05-29", "doble_articulado": false, "id_norma": "216031", "numero_fuente": "37687", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-10-17", "vigencias": [{"desde": "2004-05-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desd