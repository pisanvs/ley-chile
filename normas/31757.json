{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA CONCESION DE ACUICULTURA OTORGADA AL SR. ALAND OCTAVIO FARAH MAFFEI, SEGUN D.S. (M) N&#xB0; 1.266, DE 1988 </div></div>", "i": 7193542}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; 1.- Modif&#xED;case el D.S. (M) N&#xB0; 1.266, de 18 de noviembre de 1988, en el sentido que se sustituye su p&#xE1;rrafo 2 por el siguiente:</div><div class=\"p\">&nbsp; &nbsp; &quot;2.- Dicha concesi&#xF3;n tiene una superficie de 5,87 hect&#xE1;reas y se encuentra delimitada por las siguientes coordenadas geogr&#xE1;ficas:</div><div class=\"p\"> V&#xE9;rtice A Lat. 27&#xB0;05&apos;14&quot; S. Long. 70&#xB0;50&apos;55&quot; W.</div><div class=\"p\"> V&#xE9;rtice B Lat. 27&#xB0;05&apos;22&quot; S. Long. 70&#xB0;50&apos;48&quot; W.</div><div class=\"p\"> V&#xE9;rtice C Lat. 27&#xB0;05&apos;26&quot; S. Long. 70&#xB0;50&apos;53&quot; W.</div><div class=\"p\"> V&#xE9;rtice D Lat. 27&#xB0;05&apos;19&quot; S. Long. 71&#xB0;51&apos;00&quot; W. </div></div>", "i": 7193543}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 14 de Noviembre de 1995.- Pablo Cabrera Gaete, Subsecretario de Marina.</div><br></div>", "i": 7193544}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-S/N"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "MODIFICA CONCESION DE ACUICULTURA OTORGADA AL SR. ALAND OCTAVIO FARAH MAFFEI, SEGUN D.S. (M) N° 1.266, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "CONCESION ACUICULTURA", "AALAND OCTAVIO", "FARAH MAFFEI"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-11-14", "doble_artic