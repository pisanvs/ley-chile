{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Club Aleman de Osorno Lei n&#xFA;m. 1,342.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7163015}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese al Club Aleman de Osorno el permiso especial, requerido por el art&#xED;culo 556 del C&#xF3;digo Civil, para que pueda conservar durante treinta a&#xF1;os la propiedad de los terrenos i edificios que posee en la calle Figueroa, en la ciudad de Osorno.</div><br><br></div>", "i": 7163016}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 19 de Julio de 1900.- El&#xED;as Fern&#xE1;ndez A.- Francisco J. Herboso.</div><br></div>", "i": 7163017}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1342", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1342"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "CLUB ALEMAN DE OSORNO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["OSORNO", "CLUB ALEMAN", "BIEN RAIZ", "POSESION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-07-19", "doble_articulado": false, "id_norma": "22574", "numero_fuente": "6651", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-07-24", "vigencias": [{"desde": "1900-07-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-07-24", "fin_vigencia": ""}, "vige