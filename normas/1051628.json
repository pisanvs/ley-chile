{"html": [{"t": "<div><br><div class=\"p\">INFORMA CONSTITUCI&#xD3;N LEGAL DEL PARTIDO IGUALDAD EN LA VIII REGI&#xD3;N DEL BIOB&#xCD;O</div></div>", "i": 9357056}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Roxana Miranda Meneses, Presidenta del Partido Igualdad, ha solicitado la constituci&#xF3;n legal del partido en la VIII Regi&#xF3;n del Biob&#xED;o. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de cinco mil cien (5.100) fichas de afiliaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la ley N&#xBA; 18.603, por resoluci&#xF3;n O-N&#xBA; 10.340, de fecha 30 de mayo de 2013.- </div></div>", "i": 9357057}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Elizabeth Cabrera Burgos, Directora (S).</div></div>", "i": 9357058}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10340", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-10340"}, {"tipo": "3", "numero": "O-10340", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-10340"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "INFORMA CONSTITUCIÓN LEGAL DEL PARTIDO IGUALDAD EN LA VIII REGIÓN DEL BIOBÍO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-05-30", "doble_articulado": false, "id_norma": "1051628", "numero_fuente": "40576", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-06-05", "vigencias": [{"desde": "2013-06-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-06-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_