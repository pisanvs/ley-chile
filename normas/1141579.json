{"html": [{"t": "<div><div class=\"p\">LICENCIAS PARA BUQUES.</div><br><div class=\"p\">&nbsp; &nbsp;  Valparaiso, Noviembre 12 de 1824.</div><br><div class=\"p\">&nbsp; &nbsp;  He acordado y decreto:</div></div>", "i": 10113831}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Las licencias para las salidas de los buques del puerto de Valparaiso, que se franqueaban por el Gobierno Supremo, se otorgar&#xE1;n por el Gobernador de dicho puerto. Comun&#xED;quese e ins&#xE9;rtese en el Boletin.</div></div>", "i": 10113832}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.&nbsp; ------&nbsp;  F. A. Pinto.</div></div>", "i": 10113833}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "LICENCIAS PARA BUQUES.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-11-12", "doble_articulado": false, "id_norma": "1141579", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-11-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-11-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-11-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2020-04-08", "fecha_version": "1824-11-12", "fecha_actualizacion_texto": "2020-04-08", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10113831}, {"n": "Artículo", "i": 10113832, "t": 6}, {"n": "P