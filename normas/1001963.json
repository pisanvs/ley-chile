{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8591033}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.596, de 30 de abril de 2009, de esta Subsecretar&#xED;a, decl&#xE1;rase que con fecha 30 de marzo de 2009 ha quedado sin efecto la resoluci&#xF3;n exenta N&#xBA; 2.542 de 2001, de esta Subsecretar&#xED;a, que autoriz&#xF3; a AGUA FR&#xCD;A S.A. para desarrollar actividades extractivas con la nave &quot;Dubrovnik II&quot;, matr&#xED;cula 1749 del Puerto de Coquimbo, en virtud de lo dispuesto en el art&#xED;culo 9&#xBA; de la Ley N&#xBA; 19.713 y en la escritura p&#xFA;blica citada en Visto de la resoluci&#xF3;n extractada.</div><br></div>", "i": 8591034, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de abril de 2009.- Mar&#xED;a &#xC1;ngela Barbieri Bellolio, Subsecretario de Pesca.</div><br></div>", "i": 8591035}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1596", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-1596"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-04-30", "doble_articulado": false, "id_norma": "1001963", "numero_fuente": "39356", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-05-08", "vigencias": [{"desde": "2009-05-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-05-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-05-08", "fin_vigencia": "", "tipo_version": "3"}],