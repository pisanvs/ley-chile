{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8845994}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.427, de 30 de diciembre de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA SUR AUSTRAL S.A. para realizar operaciones pesqueras a contar del 1&#xBA; de enero del a&#xF1;o 2010 y hasta el 31 de diciembre del mismo a&#xF1;o, ambas fechas inclusive, con la nave f&#xE1;brica denominada &quot;Ocean Dawn&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 47&#xB0; L.S. y 57&#xB0; L.S., por fuera de las l&#xED;neas de base recta, respecto de los recursos, en las &#xE1;reas y con las obligaciones establecidas en las respectivas autorizaciones.</div></div>", "i": 8845995}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de diciembre de 2009.- Germ&#xE1;n Loyola Bast&#xED;as, Subsecretario de Pesca (S).</div></div>", "i": 8845996}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4427 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4427 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-12-30", "doble_articulado": false, "id_norma": "1010277", "numero_fuente": "39563", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-01-18", "vigencias": [{"desde": "2010-01-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-01-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-01-18",