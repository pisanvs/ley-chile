{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;457 EXENTA, DE 2001 </div></div>", "i": 6320194}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;457 de 17 de enero del a&#xF1;o 2001, se ha aprobado al Colegio &apos;&apos;Isabel La Cat&#xF3;lica&apos;&apos;, comuna de &#xD1;u&#xF1;oa, de Santiago, un plan de estudio para 3er a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 6320195}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de enero de 2001.- Juan Ruz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6320196}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "457 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-457 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº457 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-01-17", "doble_articulado": false, "id_norma": "181256", "numero_fuente": "36879", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-02-03", "vigencias": [{"desde": "2001-02-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-02-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-02-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_p