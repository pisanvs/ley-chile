{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N N&#xBA; 3.543 EXENTA, DE 2011</div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9262448}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 4.235 de 25 noviembre 2011, rectifico <a href=\"https://www.leychile.cl/Navegar?idNorma=1032349&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 3.543 de 5 de octubre de 2011</a>, ambas de Serviu Regi&#xF3;n del Maule, en el sentido de que la superficie del inmueble expropiado ubicado en Avda. El Dique 1596, Rol Aval&#xFA;o N&#xB0; 1-8, comuna Constituci&#xF3;n, es de 305,55 m&#xB2; y no 182 m&#xB2;, propietario aparente Chamorro Concha Julio. Comisi&#xF3;n de peritos corrigi&#xF3; con fecha 17 de noviembre de 2011 su informe tasaci&#xF3;n, fijando monto provisional indemnizaci&#xF3;n en $18.382.500.- pagados al contado.-</div></div>", "i": 9262449}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Clarisa Ayala Arenas, Directora Serviu Regi&#xF3;n del Maule.</div></div>", "i": 9262450}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4235 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4235 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN VII REGIÓN DEL MAULE"], "titulo_norma": "RECTIFICA RESOLUCIÓN Nº 3.543 EXENTA, DE 2011; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-11-25", "doble_articulado": false, "id_norma": "1040684", "numero_fuente": "40276", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-01", "vigencias": [{"desde": "2