{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 534 EXENTO, DE 2002 </div></div>", "i": 6389675}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 534&nbsp; de fecha 20 de junio de 2002, de Educaci&#xF3;n, se declaran aprobadas al Instituto Profesional Cepech las modificaciones al plan y a los programas de estudio de la carrera de Ingenier&#xED;a de Ejecuci&#xF3;n en Inform&#xE1;tica.</div><br><div class=\"p\">&nbsp; &nbsp;  Asimismo, dichas modificaciones a la carrera que se imparte, en jornada diurna y vespertina, podr&#xE1;n ser implementadas a contar del segundo semestre del a&#xF1;o 2002.</div><br><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase presente para todos los efectos legales y administrativos.</div><br></div>", "i": 6389676}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de julio de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6389677}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "534 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-534 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 534 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-20", "doble_articulado": false, "id_norma": "200698", "numero_fuente": "37315", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-23", "vigencias": [{"desde": "2002-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-07-23", "fin_