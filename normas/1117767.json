{"html": [{"t": "<div><br><div class=\"p\">DEJA SIN EFECTO FACULTAD QUE INDICA</div></div>", "i": 9907826}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En virtud de lo dispuesto en las resoluciones exentas N&#xBA; 90, de 21-09-2004 y N&#xBA; 24, de 05-03-2018, ambas del Director del Servicio de Impuestos Internos, la suscrita ha dictado la resoluci&#xF3;n Ex. N&#xBA; 93, de 11-04-2018, en cuya virtud deja sin efecto facultad contenida en el resuelvo 1&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=232176&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 266</a>, de 21-10-2004, emitida por la XII Direcci&#xF3;n Regional del Servicio de Impuestos Internos.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se ha publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl).</div></div>", "i": 9907827}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Ana Mar&#xED;a Vargas C&#xE1;rdenas, Directora Regional.</div></div>", "i": 9907828}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "93 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-93 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL PUNTA ARENAS"], "titulo_norma": "DEJA SIN EFECTO FACULTAD QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1385882"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-04-11", "doble_articulado": false, "id_norma": "1117767", "numero_fuente": "42039", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-04-23", "vigencias": [{"desde": "2018-04-23", "hasta": "", "tipo_versi