{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6206781}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta No. 728 de 17 de Noviembre de 1986 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n, se autoriza a la L&#xED;nea No. 37 &quot;Lota - Colcura&quot; para efectuar el servicio de taxi colectivo urbano que se indica a continuaci&#xF3;n:</div><br><div class=\"p\">LINEA N &#xB0; 37 &quot;LOTA - COLCURA&quot; Ida: Calle Cousi&#xF1;o, Monsalves, Los Carrera, Ren&#xE9; Schneider, Valle de Colcura.</div><div class=\"p\">Regreso: Valle de Colcura, Ren&#xE9; Schneider, An&#xED;bal Pinto, terminal.</div><br></div>", "i": 6206782}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco Navarro Ruiz, Secretario Regional Ministerial Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6206783}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "728 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-728 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-11-17", "doble_articulado": false, "id_norma": "148078", "numero_fuente": "32771", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-05-15", "vigencias": [{"desde": "1987-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-05-15", "fin_vigencia": ""}