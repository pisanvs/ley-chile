{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7310660}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 950, de fecha 6 de abril de 2004, de esta Subsecretar&#xED;a, modif&#xED;case las resoluciones N&#xBA; 165 de 1997, N&#xBA; 1.456 de 2001 y N&#xBA; 1.650 de 2003, todas de esta Subsecretar&#xED;a, que autorizaron a ALIMENTOS MARINOS S.A. para desarrollar actividades pesqueras con la nave &quot;Quilpolemu&quot;, en el sentido de reemplazar las siguientes caracter&#xED;sticas n&#xE1;uticas como a continuaci&#xF3;n se indica:</div><br><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  50,28 m.</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp;  1.108,26 m&#xB3;</div><br></div>", "i": 7310661}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7310662}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "950", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-950"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-06", "doble_articulado": false, "id_norma": "223935", "numero_fuente": "37839", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-19", "vigencias": [{"desde": "2004-04-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-04-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-04-19", "fin_vigencia": "", "tipo_version