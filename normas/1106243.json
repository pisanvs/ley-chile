{"html": [{"t": "<div><br><div class=\"p\">DELEGACI&#xD3;N DE FACULTADES QUE INDICA</div></div>", "i": 9822878}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 69, de 2 de agosto de 2017, que establece:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Del&#xE9;gase en el Subdirector de Gesti&#xF3;n Estrat&#xE9;gica y Estudios Tributarios la facultad de autorizar la entrega de la informaci&#xF3;n requerida en el marco del cumplimiento de los convenios de cooperaci&#xF3;n interinstitucional que sean de inter&#xE9;s para el Servicio.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de agosto de 2017.</div></div>", "i": 9822879}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "69 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-69 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DELEGACIÓN DE FACULTADES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1254015; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2017-08-02", "fecha_derogacion": "2025-01-30", "doble_articulado": false, "id_norma": "1106243", "numero_fuente": "41830", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2017-08-09", "vigencias": [{"desde": "2025-01-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2017-08-09