{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 500 EXENTO, DE 2000 </div></div>", "i": 6315001}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 500, de fecha 9 de noviembre de 2000, del Ministerio de Educaci&#xF3;n, se aprob&#xF3; a la Universidad de San Andr&#xE9;s la carrera de Pedagog&#xED;a en Educaci&#xF3;n General B&#xE1;sica, conducente al grado acad&#xE9;mico de Licenciado en Educaci&#xF3;n y al t&#xED;tulo profesional de Profesor de Educaci&#xF3;n B&#xE1;sica, para ser impartida en jornada diurna, en su sede de la ciudad de Santiago, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6315002}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de noviembre de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6315003}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "500 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-500 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 500 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-11-09", "doble_articulado": false, "id_norma": "179714", "numero_fuente": "36854", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-05", "vigencias": [{"desde": "2001-01-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-01-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie