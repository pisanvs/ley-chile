{"html": [{"t": "<div><br><div class=\"p\">SOLICITA CONSTITUCI&#xD3;N LEGAL DE PARTIDO IGUALDAD EN REGI&#xD3;N QUE INDICA</div></div>", "i": 9262796}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Iv&#xE1;n Carrasco Mora, Secretario General de la Directiva Central del Partido Igualdad, ha solicitado la constituci&#xF3;n legal del partido en la V Regi&#xF3;n de Valpara&#xED;so. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de cuatro mil trescientas veintinueve (4.329) afiliaciones.</div><br><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la ley N&#xB0; 18.603, por resoluci&#xF3;n O-N&#xB0;1.054 de fecha 28 de mayo de 2012.- </div></div>", "i": 9262797}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div></div>", "i": 9262798}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1054", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1054"}, {"tipo": "3", "numero": "O-1054", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-1054"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCIÓN LEGAL DE PARTIDO IGUALDAD EN REGIÓN QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-28", "doble_articulado": false, "id_norma": "1040699", "numero_fuente": "40277", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-02", "vigencias": [{"desde": "2012-06-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-06-02", "fin_vigencia": ""}, "vigencias_