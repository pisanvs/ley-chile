{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291775}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n n&#xFA;mero 321 de 25 de Marzo de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el extracto de la Resoluci&#xF3;n N&#xB0; 788, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la EMPRESA PESQUERA PACTO S.A., para realizar actividades de acuicultura, reemplazando la longitud del v&#xE9;rtice D, donde dice 73&#xB0;39&apos;53,10&quot; W por 73&#xB0;39&apos;46,10&quot;W. </div></div>", "i": 8291776}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 25 de Marzo de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8291777}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "321", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-321"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EMPRESA PESQUERA PACTO S.A.", "ACUICULTURA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-03-25", "fecha_derogacion": "1994-09-26", "doble_articulado": false, "id_norma": "34308", "numero_fuente": "34835", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-04-09", "vigencias": [{"desde": "1994-09-26", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1994-04-09", "hasta": "1994-09-25", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1994-09-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-