{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6512158}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 3.727 exenta, de 31 de diciembre de 2004 de esta Subsecretar&#xED;a, autor&#xED;zase a la PESQUERA YELCHO S.A. para realizar operaciones pesqueras a contar del 1 de enero del a&#xF1;o 2005 y hasta el 31 de diciembre del mismo a&#xF1;o, ambas fechas inclusive, con la nave f&#xE1;brica denominada &quot;Ocean Dawn&quot;, en aguas exteriores, por fuera de las l&#xED;neas de base recta, entre los paralelos 47&#xB0; L.S. y 57&#xB0; L.S., respecto de los recursos y con las obligaciones establecidas en la resoluci&#xF3;n N&#xBA; 1.119 de 2004, de esta Subsecretar&#xED;a.</div><br></div>", "i": 6512159}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de diciembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6512160}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3727 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3727 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-12-31", "fecha_derogacion": "2005-12-17", "doble_articulado": false, "id_norma": "234400", "numero_fuente": "38053", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-01-06", "vigencias": [{"desde": "2005-12-17", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2005-01-06", "hasta": "2005-12-16", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "v