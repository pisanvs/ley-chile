{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 43 EXENTA, DE 2003 </div><br></div>", "i": 6436462}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n SII Ex. N&#xBA; 43, de 18 de agosto de 2003, se deleg&#xF3; en el Subdirector de Avaluaciones la facultad de firmar los oficios y otros documentos que deban dirigirse a los contribuyentes, relativos a la comunicaci&#xF3;n e implementaci&#xF3;n de planes de fiscalizaci&#xF3;n del Impuesto Territorial y de las viviendas acogidas al DFL N&#xBA; 2 de 1959, de tal forma de verificar si &#xE9;stas cumplen con los requisitos legales y reglamentarios, as&#xED; como con las caracter&#xED;sticas y condiciones con que fueron aprobadas.</div><br><div class=\"p\">&nbsp; &nbsp;  Copia &#xED;ntegra de la resoluci&#xF3;n se encuentra en la p&#xE1;gina web del Servicio de Impuestos Internos en Internet y se publicar&#xE1; en el Bolet&#xED;n Oficial, correspondiente al mes de agosto.</div><br></div>", "i": 6436463}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Juan Toro Rivera, Director.</div><br></div>", "i": 6436464}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "43 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-43 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 43 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VIVIENDAS DFL N° 2", "IMPUESTO TERRITORIAL", "SERVICIO DE IMPUESTOS INTERNOS", "VERIFICACION LEGALIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-18", "doble_articulado": false, "id_norma": "213884", "numero_fuente": "37641", "tipo_vers