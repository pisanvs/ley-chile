{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9560845}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 248, de 30 de enero de 2015, de esta Subsecretar&#xED;a, establece que los centros de cultivo integrantes de la agrupaci&#xF3;n de concesiones 48 A deber&#xE1;n someterse a la densidad de cultivo establecida por resoluci&#xF3;n N&#xBA; 1.449, de 2009, del Servicio Nacional de Pesca y Acuicultura, o la resoluci&#xF3;n que la reemplace, en virtud del art&#xED;culo 5&#xBA; transitorio del DS N&#xBA; 4, de 2013, de este Ministerio.</div></div>", "i": 9560846}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de enero de 2015.- Paolo Trejo Carmona, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9560847}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "248 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-248 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-01-30", "doble_articulado": false, "id_norma": "1074603", "numero_fuente": "41078", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-02-09", "vigencias": [{"desde": "2015-02-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2015-02-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2015-02-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2015-