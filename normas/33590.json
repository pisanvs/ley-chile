{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8290887}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 177, de 28 de Febrero de 1995, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, se deneg&#xF3; la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por don JUAN</div><div class=\"p\">BENJAMIN FUENTEALBA COLLADO, para un sector ubicado en</div><div class=\"p\">Caleta Mora, sector Ramada, comuna de Caldera, Provincia</div><div class=\"p\">de Copiap&#xF3;, III Regi&#xF3;n, en virtud de lo dispuesto en los</div><div class=\"p\">art&#xED;culos 76&#xB0;, 77&#xB0;, 78&#xB0; y 5&#xB0; transitorio inciso 6&#xB0; de la Ley General de Pesca y Acuicultura y el art&#xED;culo 14&#xB0; del D.S. N&#xB0; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. Asimismo, se dej&#xF3; sin efecto la Resoluci&#xF3;n N&#xB0; 23, de 1991, de esta Subsecretar&#xED;a. </div></div>", "i": 8290888}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 28 de Febrero de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8290889}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "177", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-177"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "ACUICULTURA", "JUAN BENJAMIN FUENTEALBA", "COLLADO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-02-28", "doble_articulado": false, "id_norma": "33590", "