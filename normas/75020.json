{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8305654}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.102, de 1 de agosto de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, cad&#xFA;case parcialmente la Resoluci&#xF3;n N&#xBA; 1.721, de 1989, de esta Subsecretar&#xED;a que autoriz&#xF3; a Pesquera BahIa Inglesa S.A., para operar la nave &quot;Mat&#xED;as&quot;, solo en cuanto se refiere a la III y IV Regiones, respecto de los siguientes recursos hidrobiol&#xF3;gicos: Agujilla, Anchoveta, Jurel, Machuelo o tritre, Sardina espa&#xF1;ola, Sardina com&#xFA;n, conforme lo dispuesto en el art&#xED;culo 143, letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8305655}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de agosto de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8305656}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1102", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1102"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA BAHIA INGLESA S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-08-01", "doble_articulado": false, "id_norma": "75020", "numero_fuente": "35844", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-08-18", "vigencias": [{"desde": "1997-08-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-08-18", "fin_vigencia": ""}, "vi