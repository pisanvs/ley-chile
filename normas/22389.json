{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Abogados de la Compa&#xF1;&#xED;a de Salitres de Antofagasta Lei N&#xFA;m. 1,064.- Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948309}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que, con la cantidad de veinte mil pesos, cancele el saldo de los honorarios a los abogados que defendieron al Fisco en el juicio con la &quot;Compa&#xF1;&#xED;a de Salitres de Antofagasta.&quot;</div><br><br></div>", "i": 5948310}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 31 de Agosto de 1898.- FEDERICO ERRAZURIZ.- R. Sotomayor.</div><br></div>", "i": 5948311}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1064", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1064"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ABOGADOS DE LA COMPAÑÍA DE SALITRES DE ANTOFAGASTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMPA IA SALITRES", "ANTOFAGASTA", "ABOGADOS", "DEFENSA", "FONDOS", "DESTINACION", "PRESIDENTE REPUBLICA", "HONORARIOS", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-08-31", "doble_articulado": false, "id_norma": "22389", "numero_fuente": "6093", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-09-03", "vigencias": [{"desde": "1898-09-03", "hasta": "", "tipo_version": "3", "tipo_versio