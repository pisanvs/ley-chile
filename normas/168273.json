{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA </div></div>", "i": 6274153}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n 118, de fecha 15 de junio de 1990, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la personalidad jur&#xED;dica de la Asociaci&#xF3;n de Funcionarios de la Universidad de Magallanes Asociaci&#xF3;n Gremial, inscrita bajo el No. 21-12 del Registro que para tal efecto lleva este Ministerio, por haberse configurado respecto de ella la causal de cancelaci&#xF3;n contemplada en el art&#xED;culo 5&#xB0;, en relaci&#xF3;n con el art&#xED;culo 18 No. 2 letra a) del DL No. 2.757, de 1979.-</div><br></div>", "i": 6274154}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jorge Marshall Rivera, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6274155}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "118", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-118"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-06-15", "doble_articulado": false, "id_norma": "168273", "numero_fuente": "33935", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-05", "vigencias": [{"desde": "1991-04-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-04-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "