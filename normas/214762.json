{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6440148}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP. N&#xBA; 826 de 31 de julio de 2003, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA;, del decreto MOP.</div><div class=\"p\">N&#xBA; 3.418 de fecha 31 de julio de 2000, en la parte que se refiere al Convenio Directo de Precio Ad Refer&#xE9;ndum, a la suscripci&#xF3;n de escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote de terreno N&#xBA; 85-B. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n del lote N&#xBA; 85-B, fijada por la Comisi&#xF3;n de Peritos con fecha 19 de febrero de 1999, ascendente a la cantidad de $70.000. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.-</div><br></div>", "i": 6440149}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6440150}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "826", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-826"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-07-31", "doble_articulado": false, "id_norma": "214762", "numero_fuente": "37661", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-15", "vigencias": [{"desde": "2003-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-15", "fin_vigencia": ""}, "vigencias_version_norma"