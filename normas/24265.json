{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,813, que concede derecho a jubilar a don Sebastian Acevedo</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,813.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8276748}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Conc&#xE9;dese, por gracia, al Mayordomo del Congreso Nacional, don Sebasti&#xE1;n Acevedo, el derecho a jubilar con una pension equivalente al sueldo &#xED;ntegro asignado a su empleo.</div><br></div>", "i": 8276749}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 29 de Noviembre de 1921.- ARTURO ALESSANDRI.- Ismael Tocornal.</div><br></div>", "i": 8276750}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3813", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3813"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 3,813, QUE CONCEDE DERECHO A JUBILAR A DON SEBASTIAN ACEVEDO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SEBASTIAN ACEVEDO", "JUBILACION POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1921-11-29", "doble_articulado": false, "id_norma": "24265", "numero_fuente": "13154", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1921-12-20", "vigencias": [{"desde": "1921-12-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia"