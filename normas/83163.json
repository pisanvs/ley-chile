{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION No. 3.315 EXENTA, DE 1989 </div></div>", "i": 6064588}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta No. 3.315 de fecha 28 de diciembre de 1989 de la Subsecretaria de Educaci&#xF3;n P&#xFA;blica, se aprobaron las adecuaciones introducidas al plan y programas de estudio de la carrera T&#xE9;cnico Pesquero del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto de Educaci&#xF3;n Zipter, y se autoriz&#xF3; a la Sede No. 1 de la ciudad de Santiago, de esta instituci&#xF3;n, para impartir la carrera y t&#xED;tulo t&#xE9;cnico que se se&#xF1;ala: Carrera: T&#xE9;cnico en Alimentos</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico en Alimentos.</div><br></div>", "i": 6064589}, {"t": "<div><div class=\"p\">Santiago, 03 de Mayo de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6064590}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3315 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3315 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION No. 3.315 EXENTA, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-12-28", "doble_articulado": false, "id_norma": "83163", "numero_fuente": "33670", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-05-15", "vigencias": [{"desde": "1990-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-05-15", "fin_vigencia": "", "tipo