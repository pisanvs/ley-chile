{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 6.454 EXENTA, DE 28 DE DICIEMBRE DE 2010</div></div>", "i": 9130496}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente se han aprobado nuevos programas de estudios que se incorporan, cada uno con 2 Hrs. semanales, al Plan de Diferenciado de 3&#xBA; y de 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, establecidos por resoluciones exentas N&#xBA;s <a href=\"https://www.leychile.cl/Navegar?idNorma=182652&amp;idParte=0&amp;idVersion=\">455</a> y 14.08, ambas del 2001 y de este Ministerio de Educaci&#xF3;n y sus modificaciones, que aprobaron planes y programas especiales de estudio para dichos grados al Colegio Tabancura, de la comuna de Vitacura, provincia de Santiago, Regi&#xF3;n Metropolitana.- </div></div>", "i": 9130497}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Ver&#xF3;nica Abud Cabrera, Jefa Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 9130498}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6454 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6454 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 6.454 EXENTA, DE 28 DE DICIEMBRE DE 2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-28", "doble_articulado": false, "id_norma": "1024265", "numero_fuente": "39928", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-04-05", "vigencias": [{"desde": "2011-04-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-04-05", "fin_vigencia": ""}, "vigencias_versi