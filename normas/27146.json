{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 12,510</div><br><div class=\"p\">MODIFICA EL CODIGO ORGANICO DE TRIBUNALES </div><br><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7174654}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Substit&#xFA;yense, en el inciso segundo del <a href=\"https://www.leychile.cl/Navegar?idNorma=1095205&amp;idParte=9783226&amp;idVersion=\">art&#xED;culo 280</a> del <a href=\"https://www.leychile.cl/Navegar?idNorma=1095205&amp;idParte=&amp;idVersion=\">C&#xF3;digo Org&#xE1;nico de Tribunales</a>, agregado por el art&#xED;culo 19, letra c), de la ley N.o 11,986, las palabras &quot;provincias de Aysen y Magallanes&quot;, por las siguientes: &quot;provincias de Chilo&#xE9;, Aysen y Magallanes&quot;.</div><br><br></div>", "i": 7174655, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecisiete de Agosto de mil novecientos cincuenta y siete.- FRANCISCO O&apos;RYAN O.- Arturo Z&#xFA;&#xF1;iga Latorre.</div><br></div>", "i": 7174656}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "12510", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-12510"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "MODIFICA EL CODIGO ORGANICO DE TRIBUNALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CHILOE", "AYSEN", "MAGALLANES", "TIEMPO SERVIDO", "ANTIGUEDAD", "FUNCIONARIOS", "COMPUTACION DOBLE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita":