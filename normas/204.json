{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xB0; 364</div><div class=\"p\">&nbsp; &nbsp; 364-03-940728 - Modifica Cap&#xED;tulo III.B.2 del Compendio de Normas Financieras.</div><br></div>", "i": 5843673}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Se acord&#xF3; efectuar la siguiente modificaci&#xF3;n en el Cap&#xED;tulo III.B.2 del Compendio de Normas Financieras:</div><br><div class=\"p\"> 1.&nbsp;  Eliminar en el primer p&#xE1;rrafo del N&#xB0; 5, la expresi&#xF3;n: &quot;con la sola exclusi&#xF3;n del saldo de su Posici&#xF3;n de Cambios Internacionales,&quot;.</div><br><div class=\"p\"> 2.&nbsp;  La presente modificaci&#xF3;n comenzar&#xE1; a regir a contar del primer d&#xED;a del mes subsiguiente de aqu&#xE9;l en que se publique este acuerdo. </div></div>", "i": 5843674}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 28 de julio de 1994.- V&#xED;ctor Vial del R&#xED;o, Ministro de Fe.</div><br></div>", "i": 5843675}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "364", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-364"}, {"tipo": "5", "numero": "364-03", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-364-03"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE\nCHILE EN SU SESION N° 364\n364-03-940728 - Modifica Capítulo III.B.2 del\nCompendio de Normas Financieras.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "COMPENDIO NORMAS FINANCIERAS", "BANCO CENTRAL DE CHILE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-07-28", "doble_articulado": false, "id_norma": "204", "