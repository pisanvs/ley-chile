{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; AVISO</div><br></div>", "i": 6453587}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Con fecha 22 de Febrero de 1988, se dict&#xF3; la Ordenanza para al Cobranza de Patentes, Derechos y Contribuciones que se encuentran morosas, mediante el Decreto Alcaldicio N&#xBA; 178, cuya entrada en vigencia ser&#xE1; a contar del 1&#xBA; de Marzo de 1988.</div><div class=\"p\">&nbsp; &nbsp;  Dicha Ordenanza contiene las normas sobre el cobro administrativo, judicial y convenios de pago sobre contribuciones, patentes y derechos municipales atrasados.</div><div class=\"p\">&nbsp; &nbsp;  El texto de la referida Ordenanza puede consultarse en la Secretar&#xED;a Municipal y se encuentra a la venta en la Municipalidad.</div><br></div>", "i": 6453588}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  PEDRO RETAMAL ACU&#xD1;A</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Secretario Municipal (S).</div><br></div>", "i": 6453589}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "AVI-S/N"}], "organismos": ["MUNICIPALIDAD DE RANCAGUA"], "titulo_norma": "AVISO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-02-22", "doble_articulado": false, "id_norma": "218724", "numero_fuente": "33006", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-26", "vigencias": [{"desde": "1988-02-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic