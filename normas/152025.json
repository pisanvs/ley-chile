{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8357186}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 115, de 18 de enero de 2000, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.431, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Compa&#xF1;&#xED;a Pesquera San Pedro S.A.C.I., hoy PESQUERA CORONEL S.A., para operar la nave &apos;&apos;Don Nordlund&apos;&apos;, por no haber iniciado operaciones de pesca dentro del plazo legal, sobre la especie Machuelo o tritre en el litoral comprendido entre las Regiones I a la VII y entre la IX y la XI, conforme lo dispuesto en el art&#xED;culo 143 letra b), de la Ley General de Pesca y Acuicultura. </div></div>", "i": 8357187}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de enero de 2000.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8357188}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "115", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-115"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-18", "doble_articulado": false, "id_norma": "152025", "numero_fuente": "36570", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-01-24", "vigencias": [{"desde": "2000-01-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-01-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-01-24", "fin_vigencia": "", "tipo_version": "3"}], "ev