{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5845218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de enero de 1995, fue de 5,86% anual.</div><br></div>", "i": 5845219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, enero 20 de 1995.- Jorge Carrasco V&#xE1;squez, Ministro de Fe (S).</div><br></div>", "i": 5845220}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA INTERES PROMEDIO", "OPERACIONES CREDITO DINERO", "CAPTACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-01-20", "doble_articulado": false, "id_norma": "1815", "numero_fuente": "35074", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-01-23", "vigencias": [{"desde": "1995-01-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-01-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-01-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1995-01-23", "fecha_actualizacion_texto": "1995-01-23", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 5845218}, {"n": "Artículo 1", "i": 5845219,