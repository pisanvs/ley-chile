{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8868044}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 656, de 27 de febrero de 2004, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 572 de 1994, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA POLAR S.A. para realizar actividades pesqueras con la nave &quot;Polar Mist&quot;, en el &#xE1;rea mar&#xED;tima de la XII Regi&#xF3;n, sobre los recursos Centolla y Centoll&#xF3;n, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley&nbsp; General de Pesca y Acuicultura.</div><br></div>", "i": 8868045}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de febrero de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 8868046}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "656 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-656 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-27", "doble_articulado": false, "id_norma": "222153", "numero_fuente": "37806", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-09", "vigencias": [{"desde": "2004-03-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-03-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-03-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresa