{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A ALFREDO GABRIEL AGUAYO GAME </div></div>", "i": 6532879}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional del SII, por resoluci&#xF3;n exenta N&#xBA; 221 de 5 de julio de 2005, deroga la calidad de agente retenedor del Impuesto al Valor Agregado en las operaciones de venta de harina de trigo, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n al contribuyente Alfredo Gabriel Aguayo Game, RUT N&#xBA; 08.079.275-1, conforme a lo establecido en el dispositivo 17 de la resoluci&#xF3;n N&#xBA; 5.282 exenta de 30.11.2000.</div><br></div>", "i": 6532880}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Ren&#xE9; Cornejo C&#xE1;ceres, Director Regional. </div></div>", "i": 6532881}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "221 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-221 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A ALFREDO\nGABRIEL AGUAYO GAME", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-07-05", "doble_articulado": false, "id_norma": "240050", "numero_fuente": "38210", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-14", "vigencias": [{"desde": "2005-07-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-07-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pend