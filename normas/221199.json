{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACION PARCIAL DE INMUEBLE</div><br><br></div>", "i": 6464387}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 495 de 23 de diciembre de 2003 de Serviu Metropolitano, ordenose expropiaci&#xF3;n, conforme D.L. N&#xBA; 2.186 de 1978, inmueble ubicado en San Vicente N&#xBA; 711 presunto rol de aval&#xFA;o N&#xBA; 929-2, comuna de Santiago aparente dominio de Sara Moncada Beltr&#xE1;n. Comisi&#xF3;n integrada por peritos Deborah Kuky Pereira, arquitecto, Eric Prenzel Leupolt, ingeniero civil, Luis Rojas Quezada, Constructor Civil, seg&#xFA;n informe de 28 de junio de 2002, fijo monto provisional indemnizaci&#xF3;n en $22.972.500.- (veinte y dos millones novecientos setenta y dos mil quinientos pesos) pagadera al contado. </div></div>", "i": 6464388}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Directora, Serviu Metropolitano.</div><br></div>", "i": 6464389}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "495", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-495"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACION PARCIAL DE INMUEBLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-23", "doble_articulado": false, "id_norma": "221199", "numero_fuente": "37787", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-16", "vigencias": [{"desde": "2004-02-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-02-16", "fin_vigencia": ""}, "vigencias_version_norma