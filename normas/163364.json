{"html": [{"t": "<div><div class=\"p\">AUTORIZA A DON WILDO ANTONIO GARCIA TORREJON PARA DESARROLLAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 6258196}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 320, de 07 de Junio de 1985 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a don Wildo Antonio Garc&#xED;a Torrej&#xF3;n, RUT. 6.607.299-1, domiciliado en Tongoy, calle Punta Arenas s/n., para instalar y operar un establecimiento de cultivo de algas Gracilaria spp., en un sector del muelle de la Bah&#xED;a de Tongoy, comuna de Coquimbo, provincia de Elqui, IV Regi&#xF3;n, en una extensi&#xF3;n de 12.672 m2. de fondo de mar. </div></div>", "i": 6258197}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 07 de Junio de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6258198}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "320", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-320"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A DON WILDO ANTONIO GARCIA TORREJON PARA DESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1985-06-07", "fecha_derogacion": "1989-05-04", "doble_articulado": false, "id_norma": "163364", "numero_fuente": "32207", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1985-06-27", "vigencias": [{"desde": "1989-05-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1985-06-27", "hasta": "1989-05-03", "tipo_versio