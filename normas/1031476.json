{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9197509}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 2.482, de 16 de septiembre de 2011, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1022213&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.956 de 2010</a>, de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a don PATRICIO TORRES HEVIA para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Determinaci&#xF3;n de taxones de par&#xE1;sitos de peces introducidos y nativos en cuerpos de agua de la XIV Regi&#xF3;n de Los R&#xED;os&quot;, en el sentido de ampliar en 4 meses el plazo de ejecuci&#xF3;n de la citada pesca de investigaci&#xF3;n.</div></div>", "i": 9197510}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de septiembre de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9197511}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2482 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2482 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-09-16", "doble_articulado": false, "id_norma": "1031476", "numero_fuente": "40090", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-10-20", "vigencias": [{"desde": "2011-10-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenci