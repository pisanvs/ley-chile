{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6429920}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.410, de 26 de junio de 2003, de esta Subsecretar&#xED;a, modif&#xED;case la resoluci&#xF3;n N&#xBA; 875 de 2003, de esta Subsecretar&#xED;a de Pesca, que aprob&#xF3; el plan de manejo y explotaci&#xF3;n correspondiente al sector denominado Chaiguaco, X Regi&#xF3;n, presentado por la ASOCIACION GREMIAL PESCADORES ARTESANALES DE QUENUIR, en el sentido de reemplazar en el Visto y Considerando la expresi&#xF3;n &quot;Chaiguaco, X Regi&#xF3;n&quot; por &quot;Cullinco, X Regi&#xF3;n&quot;; y en el numeral 1.- de la misma, reemplazar la expresi&#xF3;n &quot;Chaiguaco, X Regi&#xF3;n, individualizada en el art&#xED;culo 1&#xBA;, N&#xBA; 5)&quot; por &quot;Cullinco, X Regi&#xF3;n, individualizada en el art&#xED;culo 1&#xBA;, N&#xBA; 6)&quot;.</div><br></div>", "i": 6429921}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de junio de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6429922}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1410 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1410 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-26", "doble_articulado": false, "id_norma": "212013", "numero_fuente": "37599", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-03", "vigencias": [{"desde": "2003-07-03", "hasta": "", "tipo_version": "3", "tipo_ver