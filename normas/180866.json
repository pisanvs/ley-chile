{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A 29 DE MAYO S.A.</div><br></div>", "i": 6318825}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 1.- Certifico que 29 de Mayo S.A., RUT 96.918.970-4, cumple los requisitos establecidos en la resoluci&#xF3;n exenta N&#xBA; 3.722 del 28 de julio publicada en el Diario Oficial del 1.08.2000 y que en consecuencia tiene la calidad de agente retenedor del Impuesto al Valor Agregado en las ventas de carne y servicios de faenamiento de ganado que efect&#xFA;e a contar del mes siguiente de la publicaci&#xF3;n de este certificado en el Diario Oficial.</div><br></div>", "i": 6318826}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  San Miguel, 24 de enero de 2001.- Alejandro Ossand&#xF3;n Tamayo, Director Regional.</div><br></div>", "i": 6318827}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "1", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-1"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA", "SANTIAGO SUR"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A 29 DE MAYO S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-01-24", "doble_articulado": false, "id_norma": "180866", "numero_fuente": "36876", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-31", "vigencias": [{"desde": "2001-01-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-01-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos