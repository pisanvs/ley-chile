{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 78, DE 2005</div><br><br></div>", "i": 6519730}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 78, de 8 de marzo de 2005, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la IV Regi&#xF3;n de Coquimbo, se dispuso el inicio de la marcha blanca de las Plantas de Revisi&#xF3;n T&#xE9;cnica de la Concesi&#xF3;n Dos, con una planta revisora Clase AB, en la comuna de Coquimbo, y una Planta Revisora Clase AB, en la comuna de Illapel, ambas concesionadas a la empresa &quot;Revisiones Guayac&#xE1;n Limitada&quot;.-</div><br></div>", "i": 6519731}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Claudio M&#xE9;ndez Olave, Secretario Regional Ministerial de Transportes y Telecomunicaciones, IV Regi&#xF3;n de Coquimbo.</div><br></div>", "i": 6519732}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "78", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-78"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SECRETARÍA REGIONAL MINISTERIAL IV REGIÓN COQUIMBO"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 78, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-03-08", "doble_articulado": false, "id_norma": "236486", "numero_fuente": "38115", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-03-19", "vigencias": [{"desde": "2005-03-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-03-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-03-19", "fin_vigencia": "", "tipo_ver