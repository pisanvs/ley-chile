{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8311092}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 863 de 02 de Julio de 1991 de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n, se prorroga por 30 d&#xED;as a contar de la fecha</div><div class=\"p\">de la presente resoluci&#xF3;n, el plazo otorgado en el numeral</div><div class=\"p\">4&#xB0; de la resoluci&#xF3;n No. 388, de 1991, de esta Subsecretar&#xED;a,</div><div class=\"p\">al SINDICATO DE TRABAJADORES INDEPENDIENTES PESCADORES</div><div class=\"p\">ARTESANALES ALGUEROS &quot;LA ESPERANZA&quot;, domiciliado en Changue, direcci&#xF3;n postal Correo de Maull&#xED;n, en raz&#xF3;n de haberse acreditado la existencia de una fuerza mayor. </div></div>", "i": 8311093}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 26 de Julio de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8311094}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "863", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-863"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-07-02", "fecha_derogacion": "1996-04-11", "doble_articulado": false, "id_norma": "80521", "numero_fuente": "34051", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-08-24", "vigencias": [{"desde": "1996-04-11", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1991-08-24", "hasta": "1996-04-1