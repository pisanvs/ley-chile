{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 7.286 EXENTA, DE 2008 </div></div>", "i": 6933514}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 7.286, de fecha 14 de octubre de 2008 del Ministerio de Educaci&#xF3;n, se aprueba el plan y programas de estudio al Centro de Formaci&#xF3;n T&#xE9;cnica Juan Bohon, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartido a contar del a&#xF1;o 2008, en la Sede Central de La Serena:</div><br><div class=\"p\">Carrera :&nbsp; &nbsp; &nbsp; Administraci&#xF3;n y Soporte de Redes</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Computacio-nales.</div><div class=\"p\">T&#xED;tulo&nbsp; :&nbsp; &nbsp; &nbsp; T&#xE9;cnico de Nivel Superior en</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Administraci&#xF3;n y Soporte de Redes</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Computacionales.</div><br><br></div>", "i": 6933515}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de diciembre de 2008.- Cristi&#xE1;n Mart&#xED;nez Ahumada, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 6933516}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7286 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7286 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 7.286 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-10-14", "doble_articulado": false, "id_norma": "285130", "numero_fuente": "39263", "tipo_version": "3", "tipo_version_s": "Única", "fe