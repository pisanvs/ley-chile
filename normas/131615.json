{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A OSCAR MAURICIO CORREA CASTILLO</div><br><br></div>", "i": 6153839}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional del SII, por resoluci&#xF3;n DRE09.00 N&#xBA; Ex. 29, de fecha 27 de enero de 1999, otorga, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n a Oscar Mauricio Correa Castillo, Rut. N&#xBA; 8.094.319-9, la calidad de Agente Retenedor del Impuesto al Valor Agregado del cambio de sujeto en las operaciones de ganado vivo, establecido en la resoluci&#xF3;n N&#xBA; Ex 2.379/98 de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del d&#xED;a 24/04/98, modificada por resoluci&#xF3;n N&#xBA; Ex. 3.785 de 25/06/98, publicada en el Diario Oficial del 30/06/98.</div><br></div>", "i": 6153840}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Octavio Sep&#xFA;lveda Becker, Director Regional (S). </div></div>", "i": 6153841}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "29 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-29 EXENTA"}, {"tipo": "3", "numero": "DRE-09-00-29 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-09-00-29 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A OSCAR MAURICIO CORREA CASTILLO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-01-27", "doble_articulado": false, "id_norma": "131615", "numero_fuente": "36288", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion