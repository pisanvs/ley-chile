{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;2.314 EXENTO, DE 14 DE DICIEMBRE DE 2010</div></div>", "i": 9088928}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento que se indica del Ministerio de Educaci&#xF3;n, se deroga el<a href=\"https://www.leychile.cl/Navegar?idNorma=159906&amp;idParte=0&amp;idVersion=\"> decreto exento de Educaci&#xF3;n N&#xBA;248 de fecha 1 de octubre de 1990</a> modificado por decreto exento de Educaci&#xF3;n N&#xBA;280 de fecha 8 de abril de 2002, que aprueba el plan y programas de estudio de la carrera de Laboratorista Dental para el Centro de Formaci&#xF3;n T&#xE9;cnica CEPONAL, a petici&#xF3;n de la propia entidad, dado que no registra matr&#xED;cula de alumnos y no la continuar&#xE1; impartiendo.</div><br></div>", "i": 9088929, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de diciembre de 2010.- Fernando Rojas Ochagav&#xED;a, Subsecretario de Educaci&#xF3;n.</div></div>", "i": 9088930}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2314 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2314 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº2.314 EXENTO, DE 14 DE DICIEMBRE DE 2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-14", "doble_articulado": false, "id_norma": "1021608", "numero_fuente": "39846", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-12-29", "vigencias": [{"desde": "2010-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-12-29", "fin_v