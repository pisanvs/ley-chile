{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9293071}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (Exento) N&#xBA;1463, de fecha 31 de julio de 2012, y de conformidad a lo dispuesto en el art.105 del DFL MOP N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;9, superficie 127 m2, rol N&#xBA;2113-114, para la obra &quot;MEJORAMIENTO RUTA V-815, TRAMO BIF. ILQUE &#x2013; CRUCE RUTA V-85&quot;, Comuna de Puerto Montt, X Regi&#xF3;n. La Comisi&#xF3;n de Peritos integrada por Nelson Bernardo Turra Turra, Christian Emil Rauch Y&#xE1;&#xF1;ez y Nelson Fabi&#xE1;n Igor Flores, fij&#xF3; el valor de tasaci&#xF3;n con fecha 25 de octubre de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietaria AUGUSTA ELENA OLIVARES ROSAS, en la cantidad de $1.187.558, suma que se pagar&#xE1; al contado.- </div></div>", "i": 9293072}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9293073}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1463 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1463 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-31", "doble_articulado": false, "id_norma": "1043417", "numero_fuente": "40352", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-09-01", "vigencias": [{"desde": "2012-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vige