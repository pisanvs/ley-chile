{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,539.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6172216}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al teniente de guardias nacionales movilizadas, retirado absolutamente e inv&#xE1;lido relativo de la campa&#xF1;a del Pac&#xED;fico, don Eduardo P&#xE9;rez R., derecho a gozar de su pension de retiro militar como inv&#xE1;lido absoluto, en vez de la de relativo de que actualmente disfruta. </div></div>", "i": 6172217}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiseis de agosto de mil novecientos once.- Ramon Barros Luco.- Alejandro Huneeus. </div></div>", "i": 6172218}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2539", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2539"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-08-26", "doble_articulado": false, "id_norma": "137475", "numero_fuente": "10067", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-08-28", "vigencias": [{"desde": "1911-08-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-08-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-08-28", "fin_v