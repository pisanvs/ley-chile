{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 1,039.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br></div>", "i": 9042092}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Conc&#xE9;dese un suplemento de 3 millones de pesos al &#xED;tem 35 de la partida 21 del presupuesto de Guerra vijente.</div><br></div>", "i": 9042093}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 8 de Junio de 1898.- FEDERICO ERRAZURIZ.- V. Blanco.</div><br></div>", "i": 9042094}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1039", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1039"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "Suplemento", "fuente": "Boletin de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1898", "MODIFICACION", "MINISTERIO", "GUERRA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["ESTA LEY NO HA SIDO PUBLICADA EN EL DIARIO OFICIAL"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-06-08", "doble_articulado": false, "id_norma": "22365", "numero_fuente": "SUPLEMENTO A O 1898, PAGINA N 424", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1898-06-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-06-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-06-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu