{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6127651}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 98, de 14 de agosto de 1998, Serviu II Regi&#xF3;n dispuso conforme D.L. 2186 de 1978, y para ejecuci&#xF3;n proyecto Mejoramiento Acceso Puerto de Antofagasta, expropiaci&#xF3;n parcial del inmueble ubicado en calle Maip&#xFA; N&#xBA; 210, esq. Avda. Balmaceda, rol aval&#xFA;o N&#xBA; 786-3, comuna de Antofagasta, superficie 16,20 M2, de aparente dominio de don Dusko Kuljis Munitic. Comisi&#xF3;n Tasadora integrada por peritos Sr. Alejandro Bargsted B., Sra. Eleonora Rom&#xE1;n L., Arquitectos, y Sr. H&#xE9;ctor Villegas G., Constructor Civil, seg&#xFA;n informe de 22 de julio de 1998, fij&#xF3; monto provisional indemnizaci&#xF3;n&nbsp; en $8.079.836.- pagadera al contado.</div><br></div>", "i": 6127652}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu II Regi&#xF3;n.</div><br></div>", "i": 6127653}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "98", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-98"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN II REGIÓN DE ANTOFAGASTA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "ANTOFAGASTA", "SEGUNDA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-14", "doble_articulado": false, "id_norma": "123622", "numero_fuente": "36154", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-09-01", "vigencias": [{"desde": "1998-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-09-01",