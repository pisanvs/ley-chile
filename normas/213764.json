{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO&nbsp; DE&nbsp; RESOLUCION&nbsp; N&#xBA; 9.464&nbsp; EXENTA,DE 2003</div><br></div>", "i": 6436042}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 9.464 de fecha 31 de julio de 2003 del Ministerio de Educaci&#xF3;n, se ampl&#xED;a el per&#xED;odo de acreditaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica Crecic por un per&#xED;odo de dos a&#xF1;os, a contar de junio del a&#xF1;o 2003.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, se requiere del Centro de Formaci&#xF3;n T&#xE9;cnica Crecic el cumplimiento de acciones dentro del plazo determinado en la misma resoluci&#xF3;n exenta, lo que ser&#xE1; verificado por la Divisi&#xF3;n de Educaci&#xF3;n Superior del Ministerio de Educaci&#xF3;n, como condici&#xF3;n previa para la obtenci&#xF3;n de la Plena Autonom&#xED;a, correspondiendo al Ministerio de Educaci&#xF3;n la verificaci&#xF3;n de su desarrollo. </div></div>", "i": 6436043}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago,&nbsp; 12&nbsp; de agosto&nbsp; de 2003.- Mar&#xED;a Ariadna</div><div class=\"p\">Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 6436044}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9464 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-9464 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 9.464 EXENTA, DE 2003", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-07-31", "fecha_derogacion": "2016-12-31", "doble_articulado": false, "id_norma": "213764", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "20