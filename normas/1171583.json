{"html": [{"t": "<div><br><div class=\"p\">Decreto con fuerza de ley N.o 48</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 48.- Santiago, 18 de Marzo de 1931.- En uso de las facutlades que me otorga la ley n&#xFA;mero 4,915, de 6 de Febrero de 1931,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div></div>", "i": 10303368}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1.o Reempl&#xE1;zanse las palabras &quot;seg&#xFA;n la fecha de emisi&#xF3;n&quot;, que aparecen al final del segundo inciso del <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=214624&amp;idParte=9052901&amp;idVersion=1931-03-20\">art&#xED;culo 10</a> del <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=214624&amp;idVersion=1931-03-20\">decreto con fuerza de ley n&#xFA;mero 12</a>, de 24 de Febrero de 1931, por las siguientes, &quot;de acuerdo con los respectivos contratos de emisi&#xF3;n&quot;.</div><br></div>", "i": 10303369, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  2.o Siempre que en la <a href=\"https://www.leychile.cl/Navegar?idNorma=24953&amp;idParte=&amp;idVersion=\">ley n&#xFA;mero 4,863, de 21 de Julio de 1930</a>, y en el <a href=\"https://www.leychile.cl/Navegar?idNorma=214624&amp;idParte=&amp;idVersion=\">decreto con fuerza de ley n&#xFA;mero 12, de 24 de Febrero de 1931</a>, se mencione la moneda legal de Chile, se entender&#xE1; moneda legal de oro del peso y fino se&#xF1;alados en el art&#xED;culo 1.o del decreto-ley n&#xFA;mero 606, de 14 de Octubre de 1925.</div><br></div>", "i": 10303370, "v": ["CONCORDANCIA"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comuniquese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- C. IBA&#xD1;EZ C.- Carlos Castro Ruiz.</div><br></div>", "i": 10303371}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "48", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "Decreto con Fuerza de Ley-48"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "Decreto con fuerza de ley N.o 48", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-03-18", "doble_articulado": false, "id_norma": "1171583", "numero_fuente": "0", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-03-20", "vigencias": [{"desde": "1931-03-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1931-03-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1931-03-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}, {"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresado_por": "17616", "fecha_ingreso": "2022-01-20", "fecha_version": "1931-03-20", "fecha_actualizacion_texto": "2022-01-20", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10303368}, {"n": "Artículo 1", "i": 10303369, "t": 6}, {"n": "Artículo 2", "i": 10303370, "t": 6}, {"n": "Promulgación", "i": 10303371}]}