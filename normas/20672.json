{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 211 EXENTO, DE 1994 </div></div>", "i": 7161149}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 211 de fecha 10 de mayo de 1994 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Esucomex las adecuaciones introducidas al Plan y Programas de Estudios de la Carrera de Secretariado Ejecutivo Computacional, las que se insertaron en el Decreto Exento de Educaci&#xF3;n N&#xB0; 497 de 1993. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1994.</div><br></div>", "i": 7161150}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 2 de agosto de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161151}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "211 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-211 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 211 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "MODIFICACION", "CENTRO FORMACION TECNICA ESUCOMEX"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-05-10", "doble_articulado": false, "id_norma": "20672", "numero_fuente": "34937", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-08-10", "vigencias": [{"desde": "1994-08-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-08-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-08-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vin