{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;32, DE 2004 </div></div>", "i": 6505692}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n Ministerial T.R. N&#xBA; 32, de 20 de</div><div class=\"p\">octubre de 2004, se cancel&#xF3; la personalidad jur&#xED;dica de</div><div class=\"p\">la entidad denominada &quot;Asociaci&#xF3;n Gremial de</div><div class=\"p\">Comerciantes de Feria Persa de Valpara&#xED;so&quot;, inscrita</div><div class=\"p\">bajo el N&#xBA; 134-5, por haberse configurado la causal</div><div class=\"p\">contemplada en las letras b), c) y d) del N&#xBA; 2 del</div><div class=\"p\">art&#xED;culo 18 del decreto ley N&#xBA; 2.757, de 1979. </div></div>", "i": 6505693}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Javiera Estrada Quezada, Jefa Unidad Asociaciones Gremiales y Martilleros.</div><br></div>", "i": 6505694}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "32", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-32"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº32, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-20", "doble_articulado": false, "id_norma": "232697", "numero_fuente": "38014", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-11-18", "vigencias": [{"desde": "2004-11-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-11-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-11-18", "fin_vigencia":