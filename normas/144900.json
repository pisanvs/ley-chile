{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6195776}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 27, de 19 de Febrero de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la XII Regi&#xF3;n, Magallanes y Ant&#xE1;rtica Chilena, se autoriza a Arturo Porfirio Monsalves Aravena para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos de locomoci&#xF3;n colectiva urbana de pasajeros.</div><br></div>", "i": 6195777}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Urbano Peralta, Secretario </div></div>", "i": 6195778}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "27 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-27 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XII REGIÓN DE MAGALLANES Y ANTÁRTICA CHILENA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-19", "doble_articulado": false, "id_norma": "144900", "numero_fuente": "32708", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-02-26", "vigencias": [{"desde": "1987-02-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-02-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-02-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado