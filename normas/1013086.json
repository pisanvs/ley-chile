{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div><br></div>", "i": 8916574}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA; 39.628 de 6 de abril de 2010, se public&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1012241&amp;idParte=&amp;idVersion=2010-05-07\">Resoluci&#xF3;n N&#xBA; 449 Exenta</a>, que Autoriza Colecta Regional a la Liga Chilena Contra el Mal de Parkinson, con los errores que se salvan a continuaci&#xF3;n: en el sumario, primera columna y p&#xE1;gina trece, segunda columna, donde dice &quot; ... MINISTERIO DEL INTERIOR - Subsecretar&#xED;a del Interior ...&quot; debe decir &quot;... MINISTERIO DEL INTERIOR - Subsecretar&#xED;a del Interior - Intendencia Regi&#xF3;n Metropolitana de Santiago ...&quot;.</div><br><br></div>", "i": 8916575, "v": ["RECTIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "129", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-129"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARÍA DEL INTERIOR", "INTENDENCIA REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1013086", "numero_fuente": "39654", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-05-07", "vigencias": [{"desde": "2010-05-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-05-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-05-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text"