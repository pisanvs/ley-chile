{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div><br></div>", "i": 9961110}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n Ex. N&#xBA; 3.307, de fecha 18/10/2018, conforme al art&#xED;culo 48 y 62 ley 19.880, de Serviu Regi&#xF3;n de la Araucan&#xED;a, se orden&#xF3; la rectificaci&#xF3;n de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1124028&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n ex. N&#xBA; 3.174</a>, de fecha 3174 de fecha 5 de octubre de Serviu Araucan&#xED;a, que orden&#xF3; la expropiaci&#xF3;n del Lote 116-0, en el sentido que por un error involuntario se se&#xF1;al&#xF3; en su resuelvo N&#xBA; 1, lo siguiente: &quot;Superficie aproximada total a expropiar; 75,46 metros cuadrados&quot; correspondiendo expresar correctamente, lo siguiente: &quot;Superficie aproximada total a expropiar; 227,37 metros cuadrados&quot;.- </div></div>", "i": 9961111}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n de la Araucan&#xED;a. </div></div>", "i": 9961112}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3307 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3307 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1485414", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-10-18", "doble_articulado": false, "id_norma": "1124815", "numero_fuente": "42195", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-11-03", "vigencias": [{"desde": "2018-11-03", "hasta": "", "tipo_version": "3",