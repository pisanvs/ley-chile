{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294655}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 873 de 11 de Noviembre de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por diez meses, contados desde el 1&#xB0; de noviembre de 1993, el plazo conferido a PESQUERA FRIOSUR S.A., R.U.T. N&#xB0; 86.577.500-8, para reiniciar operaciones con la nave &quot;Friosur III&quot;, autorizada por Resoluci&#xF3;n N&#xB0; 326, de 1987, de esta Subsecretar&#xED;a, en virtud de haberse acreditado la ocurrencia de una fuerza mayor, de conformidad con lo dispuesto en la letra b) del art&#xED;culo 143 de la Ley N&#xB0; 18.892 y sus modificaciones. </div></div>", "i": 8294656}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 11 de Noviembre de 1993.- Alvaro Briones Ram&#xED;rez, Subsecretario de Pesca Subrogante.</div><br></div>", "i": 8294657}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "873", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-873"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AMPLIACION", "PESCA", "PESQUERA FRIOSUR S.A.", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-11-11", "doble_articulado": false, "id_norma": "35767", "numero_fuente": "34726", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-11-26", "vigencias": [{"desde": "1993-11-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-11-26", "fin_vigencia": "