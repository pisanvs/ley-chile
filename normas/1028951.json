{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 7.144 EXENTA, DE 2011</div><br></div>", "i": 9171460}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 7.144, de 12 de agosto de 2011, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;BPI Capacitaci&#xF3;n Limitada&quot; (BPI), RUT 76.842.320-2, contenida en la resoluci&#xF3;n exenta N&#xBA; 2.453, de 22 de abril de 2009, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.- </div></div>", "i": 9171461}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Miguel Bergu&#xF1;o Ca&#xF1;as, Director Nacional.</div></div>", "i": 9171462}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7144 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-7144 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 7.144 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-08-12", "doble_articulado": false, "id_norma": "1028951", "numero_fuente": "40047", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-08-29", "vigencias": [{"desde": "2011-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-08-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-08-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci