{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6605670}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 179 de 22 de febrero de 2007, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme D.L. N&#xBA; 2.186 de 1978, del Lote N&#xBA; 49, correspondiente a parte del inmueble ubicado en Lira 601, Rol de Aval&#xFA;o N&#xBA; 685-1, Comuna de Santiago, aparente dominio de Ugrin Bode Mar&#xED;a Elena Concepci&#xF3;n. Comisi&#xF3;n integrada por peritos se&#xF1;ores Mar&#xED;a Isabel R&#xED;os Marcuello, Arquitecto; Miguel Juan Fern&#xE1;ndez C&#xE1;diz, Constructor Civil; y Francisco Emilio Recabarren Solar, Ingeniero Civil. Seg&#xFA;n informe de 12 de octubre de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $26.290.000, pagadera al contado.</div><br></div>", "i": 6605671}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6605672}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "179", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-179"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACION PARCIAL DE INMUEBLES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-02-22", "doble_articulado": false, "id_norma": "259548", "numero_fuente": "38729", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-04-02", "vigencias": [{"desde": "2007-04-02", "hasta": "", "tipo_version": "3", "tip