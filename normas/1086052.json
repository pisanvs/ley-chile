{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">LETRA A) DEL ART&#xCD;CULO 14 TER DE LA LEY DE IMPUESTO A LA RENTA</div></div>", "i": 9660886}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 107 del 24 de diciembre de 2015.</div><div class=\"p\">&nbsp; &nbsp;  Establece obligaci&#xF3;n de presentar Declaraci&#xF3;n Jurada de contribuyentes acogidos a las disposiciones de la letra A) del art&#xED;culo 14 ter de la Ley sobre Impuesto a la Renta, por rentas o cantidades que correspondan a sus due&#xF1;os, socios, comuneros o accionistas e informar y certificar lo que se indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de diciembre de 2015.</div></div>", "i": 9660887}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "107 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-107 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "LETRA A) DEL ARTÍCULO 14 TER DE LA LEY DE IMPUESTO A LA RENTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 983023", "EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-12-24", "doble_articulado": false, "id_norma": "1086052", "numero_fuente": "41347", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-01-04", "vigencias": [{"desde": "2016-01-04", "hast