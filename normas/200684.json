{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br></div>", "i": 6389617}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta N&#xB0; 1.340, de 12 de Diciembre de 1988, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se modifica la Resoluci&#xF3;n N&#xB0; 133/88 en el sentido de dejar establecido que la Sociedad de Transporte Cordillera Nevada Limitada, efectuar&#xE1; el servicio de transporte internacional terrestre de pasajeros entre Santiago - Valpara&#xED;so - Vi&#xF1;a del Mar - Mendoza, con 8 frecuencias diarias de ida y vuelta en autom&#xF3;viles y un viaje diario, de ida o de vuelta, utilizando un minib&#xFA;s.- </div></div>", "i": 6389618}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Manuel G&#xE1;rate Meneses, Coronel, Subsecretario de Transportes.</div><br></div>", "i": 6389619}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1340 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1340 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-12", "doble_articulado": false, "id_norma": "200684", "numero_fuente": "33303", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-02-20", "vigencias": [{"desde": "1989-02-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-02-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-02-20", "fin_vigencia": "", "tipo_version"