{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA A INSTITUCI&#xD3;N SIN FINES DE LUCRO, COMO RECEPTORA DE ALIMENTOS CUYA COMERCIALIZACI&#xD3;N SEA INVIABLE</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 9624555}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n Ex. del Servicio de Impuestos Internos N&#xBA; 64, de 22 de julio de 2015, que autoriza a la instituci&#xF3;n sin fines de lucro, Agrupaci&#xF3;n de Padres de Ni&#xF1;os Discapacitados, RUT N&#xBA; 71.618.200-2, como receptora en forma gratuita de alimentos, cuya comercializaci&#xF3;n sea inviable.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de julio de 2015.</div></div>", "i": 9624556}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "64 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-64 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A INSTITUCIÓN SIN FINES DE LUCRO, COMO RECEPTORA DE ALIMENTOS CUYA COMERCIALIZACIÓN SEA INVIABLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-07-22", "doble_articulado": false, "id_norma": "1079921", "numero_fuente": "41218", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-07-28", "vigencias": [{"desde": "2015-07-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2015-07-28", "fin_vi