{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xBA; 1035</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 1035, celebrada el 20 de enero de 2003, adopt&#xF3; el siguiente Acuerdo:</div><br><br></div>", "i": 6411127}, {"t": "<div><div class=\"p\">1035-01-030120 - Modifica Cap&#xED;tulo III.J.2 del Compendio de Normas Financieras.</div><br><div class=\"p\">Se acord&#xF3; modificar el Cap&#xED;tulo III.J.2 del Compendio de Normas Financieras, de la siguiente forma:</div><br><div class=\"p\">1.&nbsp;  En el N&#xBA; 1 del T&#xED;tulo I, eliminar la expresi&#xF3;n &quot;operada sin libreta&quot;.</div><div class=\"p\">2.&nbsp;  En el N&#xBA; 5 del T&#xED;tulo V, eliminar la expresi&#xF3;n &quot;operadas sin libreta&quot;.</div><div class=\"p\">3.&nbsp;  En el N&#xBA; 2 del T&#xED;tulo VIII, eliminar la expresi&#xF3;n &quot;operada sin libreta&quot;.</div><br></div>", "i": 6411128}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de enero de 2003.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6411129}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1035", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1035"}, {"tipo": "5", "numero": "1035-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1035-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION Nº 1035", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-20", "doble_articulado": false, "id_norma": "206992