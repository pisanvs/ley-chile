{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6241898}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 493, de 4 de Julio de 1985, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se renueva la concesi&#xF3;n otorgada al se&#xF1;or Walter Roth Minte (Andina del Sud), por resoluciones No.s. 1398/75 y 579/83, ambas del Ministerio de Transportes y Telecomunicaciones, para efectuar servicio regular de transporte internacional terrestre de pasajeros entre Peulla (Chile) y Lago Fr&#xED;as (Argentina) por Paso Vicente P&#xE9;rez Rosales, efectuando cinco frecuencias semanales. </div></div>", "i": 6241899}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 9 de 1985.- Enrique Y&#xE1;var Martin, Coronel de Ej&#xE9;rcito, Subsecretario de Transportes. </div></div>", "i": 6241900}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "493 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-493 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-07-04", "doble_articulado": false, "id_norma": "158448", "numero_fuente": "32225", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-07-18", "vigencias": [{"desde": "1985-07-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-07-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-07-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "