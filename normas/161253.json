{"html": [{"t": "<div><div class=\"p\">AUTORIZA A PESQUERA IQUIQUE S.A. PARA AMPLIAR ACTIVIDADES PESQUERAS </div></div>", "i": 8537714}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 182 del 03 de Abril de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Pesquera Iquique S.A., domiciliada en Santiago, para operar la embarcaci&#xF3;n &quot;Gualp&#xE9;n&quot; en el litoral comprendido entre la V y la X Regi&#xF3;n, en faenas extractivas de jurel, sardina espa&#xF1;ola, caballa y anchoa.</div><br></div>", "i": 8537715}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 03 de Abril de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 8537716}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "182", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-182"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA IQUIQUE S.A. PARA AMPLIAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-04-03", "doble_articulado": false, "id_norma": "161253", "numero_fuente": "32151", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-04-20", "vigencias": [{"desde": "1985-04-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-04-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-04-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "m