{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,109.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6168072}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese a la sucesion del ex-Gobernador de Magall&#xE1;nes, contra-almirante don Manuel Se&#xF1;oret, la propiedad del lote n&#xFA;mero 21 de seis mil quinientas hect&#xE1;reas de superficie del plano de la rejion de Ultima Esperanza.</div><br></div>", "i": 6168073}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veinte de julio de mil novecientos ocho.- Pedro Montt.- F. Puga Borne.</div><br></div>", "i": 6168074}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2109", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2109"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1908-07-20", "doble_articulado": false, "id_norma": "136250", "numero_fuente": "9142", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1908-07-23", "vigencias": [{"desde": "1908-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1908-07-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1908-07-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p