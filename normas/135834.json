{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8344473}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 613, de 20 de abril de 1999, de</div><div class=\"p\">esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA QUINTERO S.A.,</div><div class=\"p\">para realizar actividades pesqueras con la nave &apos;&apos;Don</div><div class=\"p\">Stefan&apos;&apos; en el litoral comprendido entre los paralelos</div><div class=\"p\">24&#xB0; a 35&#xB0; de Latitud Sur, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; capturar con red de arrastre los recursos hidrobiol&#xF3;gicos Gamba Hymenopenaeus diomedeae, Congrio colorado Genypterus chilensis; Congrio dorado Genypterus blacodes y Congrio negro Genypterus maculatus.</div><br></div>", "i": 8344474}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de abril de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8344475}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "613", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-613"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-04-20", "doble_articulado": false, "id_norma": "135834", "numero_fuente": "36355", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-05-05", "vigencias": [{"desde": "1999-05-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-05-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"ini