{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO SUPREMO N&#xBA; 326, DE 1977</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 2 de Diciembre de 1982.- Hoy se decret&#xF3; lo que sigue:</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 1.657.- Visto: Lo dispuesto en la Ley N&#xBA; 17.105, de 1969, que refrend&#xF3; las disposiciones sobre alcoholes y bebidas alcoh&#xF3;licas,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 8375253}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, t&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- AUGUSTO PINOCHET UGARTE, General de Ej&#xE9;rcito, Presidente de la Rep&#xFA;blica.- Enrique Montero Marx, General de Brigada A&#xE9;rea (J); Ministro del Interior.</div><br><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Ram&#xF3;n Su&#xE1;rez Gonz&#xE1;lez, Subsecretario del Interior.</div><br></div>", "i": 8375254}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1657", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1657"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA DECRETO SUPREMO Nº 326, DE 1977", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1982-12-02", "doble_articulado": false, "id_norma": "258227", "numero_fuente": "31457", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1983-01-04", "vigencias": [{"desde": "1983-01-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1983-01-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1983-01-04", "fin_vigencia": "", "tipo_