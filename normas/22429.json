{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Adoquinado obligatorio de la ciudad de Concepcion Lei n&#xFA;m.1,145.- Santiago, a 9 de Enero de 1899.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274119}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se hace estensivo a la pavimentacion de calles con piedra de rio el art. 1.&#xB0; de la lei de 11 de Setiembre de 1879 sobre adoquinado obligatorio de la ciudad de Concepcion.</div><br><br></div>", "i": 8274120}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C. Walker Mart&#xED;nez.</div><br></div>", "i": 8274121}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1145", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1145"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "ADOQUINADO OBLIGATORIO DE LA CIUDAD DE CONCEPCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCEPCION", "ADOQUINADO OBLIGATORIO", "PAVIMENTACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-01-09", "doble_articulado": false, "id_norma": "22429", "numero_fuente": "6196", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-01-09", "vigencias": [{"desde": "1899-01-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-01-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-01-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie