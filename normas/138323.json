{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SESION N&#xBA; 764E </div><br></div>", "i": 6175064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 764E, celebrada el 30 de junio de 1999, adopt&#xF3; el siguiente Acuerdo:</div><br><div class=\"p\">&nbsp; &nbsp;  764E-01-990630 - Modifica Cap&#xED;tulo III.B.2 del Compendio de Normas Financieras.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; efectuar la siguiente modificaci&#xF3;n en el Cap&#xED;tulo III.B.2 del Compendio de Normas Financieras:</div><br><div class=\"p\">-&nbsp; &nbsp;  Reemplazar en el N&#xBA; 3 de las &apos;&apos;Disposiciones Transitorias&apos;&apos; la expresi&#xF3;n &apos;&apos;30 de junio de 1999&apos;&apos; por &apos;&apos;31 de agosto de 1999&apos;&apos;.</div><br></div>", "i": 6175065}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de junio de 1999.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6175066}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "764", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-764"}, {"tipo": "5", "numero": "764-E-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-764-E-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SESION Nº 764E", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-06-30", "doble_articulado": false, "id_norma": "138323", "numero_fuente": "36401", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-07-01", "vigencias": [{"desde": "1999-07-01", "hasta": "", "tipo_vers