{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7214056}, {"t": "<div><div class=\"p\">Por Decreto Exento No. 87 de fecha 10 de Abril de 1992 del Ministerio de Educaci&#xF3;n, se aprobaron las modificaciones introducidas al plan y programas de estudio al Centro de Formaci&#xF3;n T&#xE9;cnica Escuela de Altos Estudios de la Comunicaci&#xF3;n y Educaci&#xF3;n EACE, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar del a&#xF1;o 1992 en la ciudad de Santiago, con la siguiente denominaci&#xF3;n:</div><div class=\"p\">Carrera: Animaci&#xF3;n y Locuci&#xF3;n Deportiva, cambia por: Carrera: Animaci&#xF3;n T.V., Locuci&#xF3;n y Relatos Deportivos.</div><div class=\"p\">T&#xED;tulo : T&#xE9;cnico en Animaci&#xF3;n T.V., Locuci&#xF3;n y Relatos Deportivos.</div><br></div>", "i": 7214057}, {"t": "<div><div class=\"p\">Santiago, 08 de Junio de 1992.-, Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7214058}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "87 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-87 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1992-04-10", "fecha_derogacion": "2007-08-17", "doble_articulado": false, "id_norma": "79120", "numero_fuente": "34300", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1992-06-25", "vigencias": [{"desde": "2007-08-17", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1992-06-25", "hasta": "2007-08-16"