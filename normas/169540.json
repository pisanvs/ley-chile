{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 7270333}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.537, de 18.11.87, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana, se autoriza a la Asociaci&#xF3;n Gremial de Transportes Pe&#xF1;alol&#xE9;n Quilicura para efectuar servicio p&#xFA;blico urbano de locomoci&#xF3;n colectiva en los recorridos de las Variantes N&#xB0;s. 100-3 &quot;San Luis de Macul - Huechuraba&quot;, y 100-6 &quot;Pablo de Rocka - Quilicura&quot;, de la L&#xED;nea de Buses N&#xB0; 100 &quot;Pe&#xF1;alol&#xE9;n - Mapocho - Quilicura&quot;, cuyos trazados se encuentran autorizados por resoluciones N&#xB0;s. 970, de 31.07.78 y 2.286, de 30.11.79, de esta Secretar&#xED;a Regional.</div><br></div>", "i": 7270334}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 18.11.87.- Ramiro Camero Weir, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana, subrogante.</div><br></div>", "i": 7270335}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1537 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1537 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-18", "doble_articulado": false, "id_norma": "169540", "numero_fuente": "32932", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-28", "vigen