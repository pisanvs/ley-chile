{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 236, DE 1986</div><br><br></div>", "i": 6223386}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 236 de 23 de junio de 1986, se ha autorizado al Liceo Polit&#xE9;cnico B No. 9, de Calama, para que a contar del a&#xF1;o escolar de 1986 y hasta el a&#xF1;o escolar de 1990, aplique planes y programas especiales de estudio aprobados mediante el decreto supremo exento de Educaci&#xF3;n No. 207, de 17 de junio de 1985.</div><br></div>", "i": 6223387}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de Junio de 1986.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6223388}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "236 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-236 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 236, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-23", "doble_articulado": false, "id_norma": "152508", "numero_fuente": "32511", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-07-02", "vigencias": [{"desde": "1986-07-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-07-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-07-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2000-01-27", "fecha_version": "1986-07-02", "fech