{"html": [{"t": "<div><br><div class=\"p\">ART&#xCD;CULOS 3, 10, 11, 14, 21, 38, 58, 59, 60, 62, 63, 74, 79, 82 Y 101 DE LA LEY SOBRE IMPUESTO A LA RENTA</div></div>", "i": 9952794}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; Extracto de resoluci&#xF3;n exenta SII N&#xBA; 88, de 28 de septiembre de 2018, que establece:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp; &nbsp; Complementa la obligaci&#xF3;n de presentar declaraci&#xF3;n jurada anual sobre operaciones en Chile por medio de formulario N&#xB0; 1946; y modifica la <a href=\"https://www.leychile.cl/Navegar?idNorma=1110101&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n Ex. SII N&#xB0; 107 de 2017</a>.</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII de septiembre de 2018. </div></div>", "i": 9952795}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "88 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-88 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ARTÍCULOS 3, 10, 11, 14, 21, 38, 58, 59, 60, 62, 63, 74, 79, 82 Y 101 DE LA LEY SOBRE IMPUESTO A LA RENTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1472383", "EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-09-28", "doble_articulado": false, "id_norma": "1123581", "numero_fuente": "42172", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-10-04", "vigencias"