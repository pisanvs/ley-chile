{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6065881}, {"t": "<div><div class=\"p\">Por Decreto Secc. 2da. No. 65, de fecha 12 de Enero de 1990, Alcalde I. Municipalidad de Santiago, dispone expropiaci&#xF3;n parcial conforme DS No. 458 de Vivienda y Urbanismo, Decreto Ley 2.186 y Ley 18.695, inmueble Agustinas No. 2351, Rol 332-7. Santiago, aparente dominio Manuel Cornejo Valenzuela, superficie aproximada a expropiar 242 m2. Deslindes: Norte, 8,00 mts. con resto del predio; Sur. 7,00 mts. calle Agustinas; Oriente, 32,00 mts. con otro propietario y Poniente, 32,50 mts. con otro propietario. Indemnizaci&#xF3;n provisional $ 4.832.000.- pagadera contado.</div><br></div>", "i": 6065882}, {"t": "<div><div class=\"p\">M&#xE1;ximo Honorato Alamos, Alcalde Santiago.</div><br></div>", "i": 6065883}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "65", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-65"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-12", "doble_articulado": false, "id_norma": "83637", "numero_fuente": "33585", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-01", "vigencias": [{"desde": "1990-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1998-01-09", "fecha_version": "1990-02-01", "fecha_actualizacion_