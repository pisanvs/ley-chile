{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9213467}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.131, de 29 noviembre de 2011, de esta Subsecretar&#xED;a, ampl&#xED;ese por ocho meses, a contar del 1&#xBA; de diciembre de 2011, el plazo otorgado por el numeral 4.- inciso 1&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1020504&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.553 de 2010</a>, de esta Subsecretar&#xED;a, a PESQUERA OMEGA LIMITADA para iniciar actividades pesqueras extractivas con la nave &quot;Tami&apos;s&quot; en el &#xE1;rea mar&#xED;tima comprendida entre la XV a X Regiones, Islas de Pascua, Salas y G&#xF3;mez, Desventuradas y Archipi&#xE9;lago de Juan Fern&#xE1;ndez, por fuera del &#xE1;rea de reserva artesanal, con palangre y enmalle, sobre Albacora o Pez Espada y su fauna acompa&#xF1;ante, en virtud de haberse acreditado una circunstancia de fuerza mayor.</div><br></div>", "i": 9213468}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de noviembre de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9213469}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3131 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3131 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2011-11-29", "fecha_derogacion": "2011-12-31", "doble_articulado": false, "id_norma": "1034072", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2011-12-12", "vi