{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291472}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 262, de 10 de Marzo de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2&#xB0; de la Resoluci&#xF3;n N&#xB0; 183, de 1992, de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a Empresa Nacional de Pesca, R.U.T.</div><div class=\"p\">N&#xB0; 96.540.500-3, y cuya continuadora legal es PESQUERA SANTO TOMAS S.A., R.U.T. N&#xB0; 96.711.400-6, para operar una nave en construcci&#xF3;n, en el sentido de indicar que su nombre es &quot;Galletue&quot; y se&#xF1;alar sus actuales caracter&#xED;sticas n&#xE1;uticas.</div><div class=\"p\">&nbsp; &nbsp; D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 38, de 1995, de esta Subsecretar&#xED;a, en virtud de la presente Resoluci&#xF3;n. </div></div>", "i": 8291473, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 10 de Marzo de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8291474}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "262", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-262"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA SANTO TOMAS S.A.", "PESCA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-03-10", "doble_articulado": false, "id_norma": "34042", "numero_fuente": "35120", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-03-17", "vigencias": [