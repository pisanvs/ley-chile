{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.179 EXENTO, DE 2002 </div><br></div>", "i": 6408266}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.179 de fecha 27 de noviembre de 2002, de Educaci&#xF3;n, se autoriza al Instituto Profesional Agrario Adolfo Matthei para impartir la siguiente carrera y t&#xED;tulo profesional que se indica, a contar del a&#xF1;o 2003.</div><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  : Ingenier&#xED;a de Ejecuci&#xF3;n en</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Agronegocios</div><div class=\"p\">T&#xED;tulo profesional: Ingeniero de Ejecuci&#xF3;n en</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Agronegocios</div><br><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase presente para todos los efectos legales y administrativos.</div><br></div>", "i": 6408267}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de diciembre de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6408268}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1179 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1179 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.179 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-11-27", "doble_articulado": false, "id_norma": "206267", "numero_fuente": "37446", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-30", "vigencias": [{"desde": "2002-12-30", "hasta": "", "tip