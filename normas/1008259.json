{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8802189}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.747 de 12 de noviembre de 2009, de esta Subsecretar&#xED;a, rectif&#xED;case el numeral 1&#xBA; y el extracto de la resoluci&#xF3;n exenta N&#xBA; 3.677 de 2009, de esta Subsecretar&#xED;a que autoriz&#xF3; a PESQUERA ENFEMAR LIMITADA para ampliar actividades pesqueras extractivas, en el sentido de se&#xF1;alar que la nave autorizada se denomina &quot;Mar&#xED;a Emperatriz III&quot; y no como all&#xED; se indica.</div></div>", "i": 8802190}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de noviembre de 2009.- Mar&#xED;a &#xC1;ngela Barbieri Bellolio, Subsecretaria de Pesca (S).</div></div>", "i": 8802191}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3747 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3747 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-11-12", "doble_articulado": false, "id_norma": "1008259", "numero_fuente": "39515", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-11-19", "vigencias": [{"desde": "2009-11-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-11-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-11-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "in