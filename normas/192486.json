{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6361087}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.404 de 4 de diciembre de 2001 de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA SAN JOSE S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluciones citadas en Visto, en orden a incorporar a la planta ubicada en Avenida Pedro Aguirre Cerda N&#xBA; 719, Coronel, VIII Regi&#xF3;n, en las l&#xED;neas de proceso que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Conserva: At&#xFA;n aleta amarilla, At&#xFA;n aleta larga, At&#xFA;n ojos grandes, Alfonsino, Orange roughy, Salm&#xF3;n plateado, Salm&#xF3;n del Atl&#xE1;ntico, Salm&#xF3;n rey, Salm&#xF3;n keta, Salm&#xF3;n rosado, Trucha arcoiris, Jibia y Lapa; Congelado: Orange roughy y Lapa.</div><br></div>", "i": 6361088}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de diciembre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6361089}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2404", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2404"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-04", "doble_articulado": false, "id_norma": "192486", "numero_fuente": "37134", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-12-13", "vigencias": [{"desde": "2001-12-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-12-13", "f