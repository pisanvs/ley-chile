{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294232}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 792, de 6 de mayo de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a CULTIVOS MARINOS FLAMENCO S.A., para ampliar actividades pesqueras, en orden a incorporar a la planta ubicada en Panamericana Norte, Kil&#xF3;metro 940, Cha&#xF1;aral, III Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de Congelado, los siguientes recursos hidrobiol&#xF3;gicos: Camar&#xF3;n nailon, Langostino amarillo y Langostino colorado.</div><br></div>", "i": 8294233}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 6 de mayo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294234}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "792", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-792"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CULTIVOS MARINOS FLAMENCO S.A.", "PESCA", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-06", "doble_articulado": false, "id_norma": "35586", "numero_fuente": "35475", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-05-25", "vigencias": [{"desde": "1996-05-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-05-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-05-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1996-05