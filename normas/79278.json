{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 313, DE 1991 </div></div>", "i": 7214227}, {"t": "<div><div class=\"p\">Por Decreto Exento No. 313 de fecha 26 de noviembre de 1991 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Osorno, los planes y programas de estudios de las carreras y t&#xED;tulos t&#xE9;cnicos de nivel superior que se indican, para ser impartidas a contar del a&#xF1;o acad&#xE9;mico 1992, en la ciudad de Osorno.</div><br><div class=\"p\">Carrera: Contabilidad Computacional con menci&#xF3;n en Auditor&#xED;a </div><div class=\"p\">T&#xED;tulo: Contador General con menci&#xF3;n en Auditor&#xED;a </div><div class=\"p\">Carrera: Administraci&#xF3;n de Empresas</div><br><div class=\"p\">T&#xED;tulo: T&#xE9;cnico en Administraci&#xF3;n de Empresas </div></div>", "i": 7214228}, {"t": "<div><div class=\"p\">Santiago, 13 de Abril de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7214229}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "313 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-313 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 313, DE 1991", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-11-26", "fecha_derogacion": "2015-06-25", "doble_articulado": false, "id_norma": "79278", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1992-05-07", "vigencias": [{"desde": "2015-06-25", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1992-05-07", "hasta": "2015-06-24