{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,505.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6172164}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- La autorizacion conferida por el art&#xED;culo 3.o de la lei de 23 de enero de 1908, para arrendar las l&#xED;neas f&#xE9;rreas fiscales intermedias entre Ligua i Cha&#xF1;aral a los contratistas del ferrocarril lonjitudinal, no rejir&#xE1; con la red del ferrocarril de Copiap&#xF3;.</div><br></div>", "i": 6172165}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiocho de junio de mil novecientos once.- Ram&#xF3;n Barros Luco.- Javier Gandarillas. </div></div>", "i": 6172166}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2505", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2505"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-06-28", "doble_articulado": false, "id_norma": "137455", "numero_fuente": "10021", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-07-04", "vigencias": [{"desde": "1911-07-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-07-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-07-04", "fin_vigencia