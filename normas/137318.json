{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,355.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6171550}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se autoriza al Presidente de la Rep&#xFA;blica para invertir la suma de quinientas libras esterlinas ( L 500) en los gastos que exija La concurrencia de Chile a los Congresos Internacionales de Riego, de Pueblo, Estado de Colorado; i de Secano, en Spocane, del Estado de W&#xE1;shington.</div><br></div>", "i": 6171551}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, diecisiete de agosto de mil novecientos diez.- El&#xED;as Fern&#xE1;ndez Albano.- Fidel Mu&#xF1;oz Rodr&#xED;guez. </div></div>", "i": 6171552}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2355", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2355"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-08-17", "doble_articulado": false, "id_norma": "137318", "numero_fuente": "9772", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-08-19", "vigencias": [{"desde": "1910-08-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-08-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1910-08-19"