{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Liberacion de Derechos de Aduana para el Algodon Lei n&#xFA;m.1,164.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br><br></div>", "i": 5948473}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese por el t&#xE9;rmino de diez a&#xF1;os a contar desde la promulgacion de la presente lei, liberacion de derechos de Aduana para el algodon en rama o en bruto i para las maquinarias que se destinen a la fabricacion de telas de algodon.</div><br><br></div>", "i": 5948474}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 9 de Enero de 1899.- FEDERICO ERRAZURIZ.- R. Sotomayor.</div><br><br><br></div>", "i": 5948475}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1164", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1164"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LIBERACION DE DERECHOS DE ADUANA PARA EL ALGONDON", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ALGODON", "DERECHOS", "ADUANA", "LIBERACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-01-09", "doble_articulado": false, "id_norma": "22441", "numero_fuente": "6196", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-01-09", "vigencias": [{"desde": "1899-01-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-01-09", "fin