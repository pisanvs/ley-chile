{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.108 EXENTA, DE 2014</div></div>", "i": 9485922}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  La VI Direcci&#xF3;n Regional Rancagua del SII, por resoluci&#xF3;n Ex. N&#xBA; 3.108 de fecha 24.06.2014, otorga la calidad de Agente Retenedor del Impuesto al Valor Agregado en los contratos de instalaci&#xF3;n o confecci&#xF3;n de especialidades, a Ingenier&#xED;a y Construcci&#xF3;n Inmobiliaria S.A., RUT N&#xBA; 96.711.230-5. Dicho acto de autoridad regir&#xE1; a contar del d&#xED;a primero del mes siguiente al de esta publicaci&#xF3;n, de acuerdo a lo establecido en la resoluci&#xF3;n exenta SII N&#xBA; 142, del 26.12.2005, de la Direcci&#xF3;n Nacional.</div></div>", "i": 9485923}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Rancagua, 24 de junio de 2014.- Luis Aguirre P&#xE9;rez, Director Nacional.</div></div>", "i": 9485924}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3108 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3108 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VI DIRECCIÓN REGIONAL RANCAGUA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.108 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-06-24", "doble_articulado": false, "id_norma": "1064076", "numero_fuente": "40900", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-07-05", "vigencias": [{"desde": "2014-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigen