{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 9.898 EXENTA, DE 1999 </div><br></div>", "i": 6201375}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 9.898, de 18 de octubre de 1999, se ha aprobado al Colegio Apoquindo Ni&#xF1;as, comuna Lo Barnechea, de Santiago, un plan de estudio para segundo a&#xF1;o Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2000.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para segundo a&#xF1;o de Ense&#xF1;anza Media de los subsectores de Biolog&#xED;a y Qu&#xED;mica.</div><br></div>", "i": 6201376}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de octubre de 1999.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6201377}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9898 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-9898 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-18", "doble_articulado": false, "id_norma": "146496", "numero_fuente": "36505", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-11-04", "vigencias": [{"desde": "1999-11-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-11-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-11-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1