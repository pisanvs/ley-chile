{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6287171}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.327, de 4 de julio de 2000, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 1.859, de 1998, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA DELFIN LIMITADA, para desarrollar actividades pesqueras con la nave &apos;&apos;Bill&apos;&apos;, matr&#xED;cula N&#xBA; 1988, en el sentido de actualizar las caracter&#xED;sticas n&#xE1;uticas de &#xE9;sta, en los t&#xE9;rminos que se indica:</div><br><div class=\"p\">Potencia motor principal&nbsp; &nbsp; &nbsp; 425,0 hp</div><div class=\"p\">Potencia motor auxiliar&nbsp; &nbsp; &nbsp;  4,3 hp</div><div class=\"p\">Arte de pesca&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Cerco, arrastre, espinel y</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Trampa</div><br></div>", "i": 6287172}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de julio de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6287173}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1327", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1327"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-07-04", "doble_articulado": false, "id_norma": "172327", "numero_fuente": "36712", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "200