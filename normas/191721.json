{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6357626}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA;1.402, de fecha 28 de septiembre de 2001, se expropiaron los lotes de terreno N&#xBA;s. 10-A y 10-L, superficies 2.305,55 m&#xB2; y 411,45 m&#xB2;, respectivamente, rol de aval&#xFA;o 65-44, comuna de Teno, VII Regi&#xF3;n, para la obra &apos;&apos;Camino Ruta J-25, Sector Cruce Longitudinal-La Monta&#xF1;a, Km. 0,22000 al 25,00000&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario don Jos&#xE9; del Carmen Aliaga Castro, ascendente a la cantidad de $3.127.029.</div><br></div>", "i": 6357627}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6357628}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1402 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1402 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-09-28", "doble_articulado": false, "id_norma": "191721", "numero_fuente": "37111", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-15", "vigencias": [{"desde": "2001-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2001-11-15", "fecha_version": "2001-11-15", "fecha_actual