{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 491 EXENTO, DE 1998 </div></div>", "i": 6109824}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 491 de 6 de abril de 1998, se ha aprobado al Colegio &apos;&apos;Campvs College&apos;&apos; de Santiago, para que, a partir del a&#xF1;o escolar 1998, aplique un plan de estudio especial biling&#xFC;e para los cursos de 1&#xBA; a 4&#xBA; a&#xF1;o b&#xE1;sico (NB.1 y NB.2).</div><br><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio especiales biling&#xFC;es para los subsectores y cursos de 1 a 4&#xBA; a&#xF1;o de ense&#xF1;anza b&#xE1;sica (NB.1. y NB.2) del plan de estudio aprobado en el art&#xED;culo anterior.</div><br><br></div>", "i": 6109825}, {"t": "<div><div class=\"p\">Santiago, 14 de abril de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br><br></div>", "i": 6109826}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "491 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-491 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 491 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIO CAPVS COLLEGE", "SANTIAGO", "REGION METROPOLITANA", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["extracto"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-06", "doble_articulado": false, "id_norma": "98672", "numero_fuente": "36056", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-05-05", "vigencias": [{"desde": "1998-05-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenci