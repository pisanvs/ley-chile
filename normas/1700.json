{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CERTIFICADO </div></div>", "i": 5844902}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 5.31% anual durante el mes de junio de 1991.</div><div class=\"p\">&nbsp; &nbsp; Asimismo, en conformidad a lo dispuesto en el N&#xB0; 5 del Capitulo IV.B.8.1, del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de junio de 1991, fue de 5,26% anual. </div></div>", "i": 5844903}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 3 de Julio de 1991.- V&#xED;ctor Vial del R&#xED;o, Secretario General.</div><br></div>", "i": 5844904}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA INTERES PROMEDIO", "TIP", "JUN 1991", "OPERACIONES CREDITO DINERO", "CAPTACIONES", "OPERACIONES REAJUSTABLES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-07-03", "doble_articulado": false, "id_norma": "1700", "numero_fuente": "34009", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-07-05", "vigencias": [{"desde": "1991-07-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-07-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-07-05