{"html": [{"t": "<div><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DON MIGUEL FIGUEROA FUENTEALBA</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br><br><br></div>", "i": 6430261}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, una pensi&#xF3;n de $ 10.000 mensuales al se&#xF1;or Miguel Figueroa Fuentealba.</div><div class=\"p\">&nbsp; &nbsp;  El mayor gasto que importe la aplicaci&#xF3;n de esta ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda.</div><br></div>", "i": 6430262}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a catorce de Octubre de mil novecientos cincuenta y ocho.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Eduardo Urz&#xFA;a Merino.</div><br></div>", "i": 6430263}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13109", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13109"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DON MIGUEL FIGUEROA FUENTEALBA", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": ["CONCEDE PENSION", "POR GRACIA", "A DON MIGUEL FIGUEROA FUENTEALBA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1958-10-14", "doble_articulado": false, "id_norma": "212119", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1958-10-24", "vigencias": [{"desde": "1958-10-24", "hasta": "", "tipo_version": "3", "tipo_version_s