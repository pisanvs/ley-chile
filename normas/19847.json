{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 37 EXENTO, DE 1996 </div></div>", "i": 7160179}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 37 de 22 de enero de 1996, se ha aprobado al Colegio &quot;Nuestra Se&#xF1;ora del Huerto&quot; de Quillota, un plan especial de estudio para el segundo ciclo de la Educaci&#xF3;n B&#xE1;sica y para la Educaci&#xF3;n Media, los cuales se aplicar&#xE1;n a partir del a&#xF1;o escolar 1996.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio para las asignaturas que se indican en el presente decreto. </div></div>", "i": 7160180}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 21 de Febrero de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160181}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "37 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-37 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 37 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIO", "COLEGIO NUESTRA SE ORA DEL HUERTO", "QUILLOTA", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-01-22", "doble_articulado": false, "id_norma": "19847", "numero_fuente": "35403", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-02-27", "vigencias": [{"desde": "1996-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-02-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-02-27", "fin_vigencia": "", "tipo