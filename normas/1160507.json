{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10230551}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xBA; 471 del 10 de mayo de 2021, Serviu Regi&#xF3;n de &#xD1;uble orden&#xF3; expropiaci&#xF3;n Parcial de inmueble ubicado en Huambal&#xED; N&#xBA; 58 B LT 2, comuna de Chill&#xE1;n, Rol de Aval&#xFA;o N&#xBA; 00680-00023, de aparente dominio de Congregaci&#xF3;n Cristiana en Chile. La parte afecta a expropiaci&#xF3;n parcial de terreno es de 154,69 m2 (Lote 15) y 41,00 m2 total de edificaci&#xF3;n cuyos linderos particulares, enmarcados en el plano S16R-022, para el proyecto &quot;Mejoramiento Avenida Huambal&#xED; Chill&#xE1;n&quot;, conforme art&#xED;culo 51 ley 16.391 y DL 2.186. Comisi&#xF3;n Peritos integrada por el arquitecto Mario Fabrizzio Bellolio Bostica, Constructor Civil &#xCD;talo Renzo Zerga Arancibia y por el Ingeniero Civil Orlando Javier Paredes V&#xE1;squez, que fij&#xF3; el monto de la indemnizaci&#xF3;n provisional por la expropiaci&#xF3;n, en la suma de $47.550.792.- </div></div>", "i": 10230552}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n de &#xD1;uble.</div><div class=\"p\"> </div><br></div>", "i": 10230553}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "471 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-471 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DE ÑUBLE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1951697", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promul