{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO ALCALDICIO No. E-217, DE 1990 </div></div>", "i": 7222579}, {"t": "<div><div class=\"p\">Complementa la Ordenanza No. 1/90 de fecha 29 de Enero de 1990 y fija los valores a cobrar por concepto de arancel por los servicios que presta el Cementerio Municipal de Colina.</div><br><div class=\"p\">El texto del presente Decreto se encuentra a disposici&#xF3;n del p&#xFA;blico y para su conocimiento en la Oficina Encargada de la Administraci&#xF3;n del Cementerio Municipal de Colina.- </div></div>", "i": 7222580}, {"t": "<div><div class=\"p\">Ciro Guti&#xE9;rrez Simonielle, Alcalde, I. Municipalidad de Colina.</div><br></div>", "i": 7222581}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "217", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-217"}, {"tipo": "2", "numero": "E-217", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-E-217"}], "organismos": ["MUNICIPALIDAD DE COLINA"], "titulo_norma": "EXTRACTO DE DECRETO ALCALDICIO No. E-217, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-29", "doble_articulado": false, "id_norma": "87967", "numero_fuente": "33834", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-12-03", "vigencias": [{"desde": "1990-12-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-12-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-12-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "PMB", "fec