{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293071}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 548, de 21 de Marzo de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n; decl&#xE1;rase la caducidad de la</div><div class=\"p\">Resoluci&#xF3;n N&#xB0; 911, de 1988, de esta Subsecretar&#xED;a, que</div><div class=\"p\">autoriz&#xF3; a PESQUERA ACUARIO LIMITADA, para desarrollar</div><div class=\"p\">actividades pesqueras extractivas con la nave &quot;Don Juan</div><div class=\"p\">II&quot;, por haberse configurado la causal prevista en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley N&#xB0; 18.892 y sus modificaciones.</div><br></div>", "i": 8293072}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 21 de Marzo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293073}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "548", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-548"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA ACUARIO LIMITADA", "PESCA", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-03-21", "doble_articulado": false, "id_norma": "35084", "numero_fuente": "35429", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-03-28", "vigencias": [{"desde": "1996-03-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-03-28", "fin_vigencia": "