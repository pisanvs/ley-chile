{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 4.697 EXENTA, DE 2012</div></div>", "i": 9258419}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 4.697, de 9 de mayo de 2012, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Rub&#xE9;n Domingo Rojas &#xC1;lvarez Capacitaci&#xF3;n E.I.R.L. (Instituto Emprender E.I.R.L.)&quot;, RUT 76.380.670-7, contenida en la resoluci&#xF3;n exenta N&#xBA; 1.461, de 26 de julio de 2006, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del art. 21 de la Ley 19.518.- </div></div>", "i": 9258420}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (PT).</div></div>", "i": 9258421}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4697 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4697 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 4.697 EXENTA, DE 2012", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2012-05-09", "fecha_derogacion": "2012-07-25", "doble_articulado": false, "id_norma": "1040231", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2012-05-19", "vigencias": [{"desde": "2012-07-25", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2012-05-19", "hasta": "2012-07-24", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2012-07-25", "fin_vigenci