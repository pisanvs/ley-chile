{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6225345}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 152 de 20 de enero de 2000, de esta Subsecretar&#xED;a, se rechaza la solicitud de concesi&#xF3;n de acuicultura N&#xBA; 96103184, presentada por ERASMO DEL CARMEN VARGAS VERA, para operar un centro de cultivo ubicado en Ensenada Detico, comuna de Queil&#xE9;n, provincia de Chilo&#xE9;, X Regi&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 456 de 1999, de esta Subsecretar&#xED;a, en virtud de lo indicado en el numeral 1&#xBA; de esta resoluci&#xF3;n.</div><br></div>", "i": 6225346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de enero de 2000.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 6225347}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "152", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-152"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-20", "doble_articulado": false, "id_norma": "153171", "numero_fuente": "36576", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-01-31", "vigencias": [{"desde": "2000-01-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-01-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-01-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "M