{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6059509}, {"t": "<div><div class=\"p\">Por Decreto MOP No. 242, de 30 de Octubre de 1990, se expropiaron los lotes del Tramo A N&#xB0;s. 1, 7 y 19 y lotes del Tramo C 15 y 16 superficies 5.218 m2., 1.600 m2., 2.580 m2. y 576 m2., roles de aval&#xFA;os 201-24, 225-16, 225-02 y 221-030, respectivamente, todos de la Comuna de Santa B&#xE1;rbara, para la obra Tramo A, B y C, Camino de Acceso y de la Red Vial Interna de la Central Pangue y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios Tito A. Borcosky M&#xE9;ndez, Sara Jara P&#xE9;rez y otros, Quillermina Castillo Uribe y Rina Salamanca Escobar, ascendente a las cantidades de $ 1.137.441, $ 864.663 $ 3.296.435 y $ 231.548.</div><br></div>", "i": 6059510}, {"t": "<div><div class=\"p\">- Fiscal del Ministerio de Obras P&#xFA;blicas.</div><div class=\"p\">(1&#xB0;) </div></div>", "i": 6059511}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "242", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-242"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-10-30", "doble_articulado": false, "id_norma": "81335", "numero_fuente": "33833", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-12-01", "vigencias": [{"desde": "1990-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": []