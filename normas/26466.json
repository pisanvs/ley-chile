{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CONDONA LOS IMPUESTOS QUE SE&#xD1;ALA IMPAGOS A LA PROMULGACION DE ESTA LEY.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5968645}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Condon&#xE1;nse los impuestos de quinta categor&#xED;a que estuvieren impagos al promulgarse esta ley y cuya retenci&#xF3;n hubiera debido practicarse por algunas de las instituciones a que se refiere el art&#xED;culo 1.o de la ley N.o 8,834, de 14 de Agosto de 1947&quot;.</div><br></div>", "i": 5968646, "v": ["CONCORDANCIA"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a seis de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Ignacio Lorca G.</div><br></div>", "i": 5968647}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10682", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10682"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONDONA LOS IMPUESTOS QUE SEÑALA IMPAGOS A LA\nPROMULGACION DE ESTA LEY.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONDONACION", "IMPUESTO", "RETENCION", "PERSONA JURIDICA", "DEPORTE", "CULTURA FISICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-06", "doble_articulado": false, "id_norma": "26466", "numero_fuente": "22383", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-10-24", "vigencias": [{