{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CONCEDE AMNISTIA AL EX SARGENTO SEGUNDO DE EJERCITO DON CARLOS SOTO M.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5967154}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese amnist&#xED;a al ex Sargento Segundo de Ej&#xE9;rcito, don Carlos Soto Morales, por el delito a que fu&#xE9; condenado por el Segundo Juzgado Militar de Santiago, con fecha 20 de Julio de 1943.</div><div class=\"p\">&nbsp; &nbsp; Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el &quot;Diario Oficial&quot;.</div><br></div>", "i": 5967155}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.-</div><div class=\"p\">&nbsp; &nbsp; GABRIEL GONZALEZ VIDELA.- Juan B. Rossetti. </div></div>", "i": 5967156}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "9415", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-9415"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDE AMNISTIA AL EX SARGENTO SEGUNDO DE EJERCITO\nDON CARLOS SOTO M.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AMNISTIA", "SARGENTO SEGUNDO", "EJERCITO", "CARLOS SOTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1949-09-26", "doble_articulado": false, "id_norma": "26082", "numero_fuente": "21484", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1949-10-22", "vigencias": [{"desde": "1949-10-22", "hasta": "", "tipo_version": "3", "tipo_