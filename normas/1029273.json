{"html": [{"t": "<div><br><div class=\"p\">MODIFICA CONCESI&#xD3;N DE ACUICULTURA</div></div>", "i": 9176520}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1.- Modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=253179&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n 842, del 6 de julio de 2006, del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina</a>, que otorg&#xF3; concesi&#xF3;n de acuicultura, a Empresas Aquachile S.A., sociedad chilena, RUT 86.247.400-7, con domicilio en Cardonal s/n, Puerto Montt.</div><div class=\"p\">&nbsp; &nbsp;  2.- Reempl&#xE1;zase el p&#xE1;rrafo 4.- del resuelvo por el siguiente:</div><div class=\"p\">&nbsp; &nbsp;  &quot;El concesionario deber&#xE1; dar cabal cumplimiento al proyecto t&#xE9;cnico y cronograma de actividades, aprobado por resoluci&#xF3;n exenta 931, del 1 de abril de 2005, modificada por resoluci&#xF3;n exenta 116, del 7 de enero de 2010, ambas del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, Subsecretar&#xED;a de Pesca.</div></div>", "i": 9176521}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de agosto de 2011.- Por orden del Subsecretario para las Fuerzas Armadas, Gonzalo Fuenzalida del Solar, Divisi&#xF3;n Jur&#xED;dica.</div></div>", "i": 9176522}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "S/N", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-S/N"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS"], "titulo_norma": "MODIFICA CONCESIÓN DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-08-10", "doble_articulado": false, "id_nor