{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 2.353 DE 2010, QUE ESTABLECE LA METODOLOG&#xCD;A PARA LA DETERMINACI&#xD3;N DE BANCO NATURAL DE RECURSOS HIDROBIOL&#xD3;GICOS</div></div>", "i": 9405737}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 387, de 30 de enero de 2014<span class=\"n\" id=\"n_0\"><a href=\"navegar?idNorma=1060164&amp;idParte=9413924&amp;idVersion=2014-03-08\">Rectificaci&#xF3;n 452<br>D.O. 08.03.2014</a></span>, de esta Subsecretar&#xED;a, modif&#xED;case resoluci&#xF3;n N&#xBA; 2.353 de 2010, de esta Subsecretar&#xED;a, eliminando el recurso hidrobiol&#xF3;gico jaiba, en todas sus especies, publicada &#xED;ntegramente en www.subpesca.cl y www.sernapesca.cl.</div><br></div>", "i": 9405738, "v": ["MODIFICACION", "RECTIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de enero de 2014.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9405739}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "3", "numero": "387 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-387 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 2.353 DE 2010, QUE ESTABLECE LA METODOLOGÍA PARA LA DETERMINACIÓN DE BANCO NATURAL DE RECURSOS HIDROBIOLÓGICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-01-30", "doble_articulado": false, "id_norma": "1059314", "numero_fuente": "40776", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion