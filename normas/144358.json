{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6193949}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xB0; 230, de 05.02.87, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se autoriza a don Eliseo Pino Olave para trasladar la ubicaci&#xF3;n de la Planta Revisora de la Clase A desde Camino Constituci&#xF3;n - San Javier Km. 05 S/N&#xB0; de la comuna de Constituci&#xF3;n a Camino Constituci&#xF3;n - San Javier Km. 07 S/N&#xB0; de la misma comuna. </div></div>", "i": 6193950}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jorge Ibacache Aravena, Secretario Regional Ministerial (S) de Transportes y Telecomunicaciones Regi&#xF3;n del Maule.</div><br></div>", "i": 6193951}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "230", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-230"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-05", "doble_articulado": false, "id_norma": "144358", "numero_fuente": "32694", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-02-10", "vigencias": [{"desde": "1987-02-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-02-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-02-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAS