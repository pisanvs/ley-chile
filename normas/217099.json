{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.534 EXENTA DEL 31 DE OCTUBRE DEL A&#xD1;O 2003 </div></div>", "i": 6447997}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modifica la resoluci&#xF3;n N&#xBA; 1.232 del 17 de septiembre del 2003, en el sentido de ampliar el plazo de postulaci&#xF3;n al programa de Viviendas Social Din&#xE1;mica sin Deuda, hasta el 28 de noviembre del 2003 y definir un nuevo per&#xED;odo de suspensi&#xF3;n de inscripciones en los registros del Serviu Metropolitano, entre el 29 y 30 de noviembre del 2003.</div><br></div>", "i": 6447998}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Secretario Ministerial Metropolitano de Vivienda y Urbanismo. </div></div>", "i": 6447999}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1534 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1534 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SECRETARÍA REGIONAL MINISTERIAL REGIÓN METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.534 EXENTA DEL 31 DE OCTUBRE\nDEL AÑO 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-31", "doble_articulado": false, "id_norma": "217099", "numero_fuente": "37709", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-11-13", "vigencias": [{"desde": "2003-11-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-11-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-11-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion