{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AUTORIZA EL TRASLADO DE LOS RESTOS DE DON ENRIQUE MOLINA GARMENDIA</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 8929093}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Autor&#xED;zase el traslado de los restos de don Enrique Molina Garmendia y su inhumaci&#xF3;n en los terrenos de la Ciudad Universitaria, perteneciente a la Universidad de Concepci&#xF3;n&quot;. </div></div>", "i": 8929094}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; EDUARDO FREI MONTALVA.- Juan G&#xF3;mez.</div><br></div>", "i": 8929095}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "15908", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-15908"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "AUTORIZA EL TRASLADO DE LOS RESTOS DE DON ENRIQUE\nMOLINA GARMENDIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TRASLADO RESTOS", "ENRIQUE MOLINA GARMENDIA", "INHUMACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "28309", "numero_fuente": "26000", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1964-11-26", "vigencias": [{"desde": "1964-11-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1964-11-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1964-11-26", "fin_vigencia": "", "tipo