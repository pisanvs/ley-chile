{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6445880}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.370, de 8 de octubre de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA EL GOLFO S.A.&nbsp; para ampliar actividades pesqueras extractivas, en&nbsp; orden a realizar actividades pesqueras con la nave &quot;Pelikan&quot;, en el Archipi&#xE9;lago de Juan Fern&#xE1;ndez, Isla de Pascua, Islas Sala y G&#xF3;mez e Islas Desventuradas, por fuera del &#xE1;rea de reserva artesanal, con palangre, donde podr&#xE1; capturar los recursos que a continuaci&#xF3;n se se&#xF1;alan: At&#xFA;n aleta amarilla, At&#xFA;n aleta larga, At&#xFA;n ojos grandes, Bonito, Marrajo o tibur&#xF3;n, Tollo, At&#xFA;n chauchera, Marlin rayado, At&#xFA;n aleta azul, Azulejo, Marlin trompa corta, Marlin negro, Marlin azul o zuncho.</div><br></div>", "i": 6445881}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de octubre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6445882}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2370 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2370 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-08", "doble_articulado": false, "id_norma": "216446", "numero_fuente": "37698", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-10-30", "vigencias": [{"desde": "2003-10-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "