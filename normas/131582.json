{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8340793}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 249 de 3 de febrero de 1999, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las resoluciones N&#xBA; 970 y N&#xBA; 1.775 de 1989 y N&#xBA; 98 de 1990, de esta Subsecretar&#xED;a, que autorizaron a don RICARDO BORN LUNECKE, para operar la nave &apos;&apos;Pamar I&apos;&apos;, en virtud de lo dispuesto en el art&#xED;culo 143 letras b) y d) del D.S. N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8340794}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de febrero de 1999.- Edith Saa Collantes, Subsecretario de Pesca (S).</div><br></div>", "i": 8340795}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "249", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-249"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-02-03", "doble_articulado": false, "id_norma": "131582", "numero_fuente": "36287", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-02-11", "vigencias": [{"desde": "1999-02-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-02-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-02-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "MEM", "fecha