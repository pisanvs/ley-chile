{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6546258}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 958 de fecha 29 de septiembre del 2005, se expropi&#xF3; el lote de terreno N&#xBA;4-</div><div class=\"p\">C, superficie 786 m2, rol N&#xBA; S/R, comuna de Pitrufqu&#xE9;n, IX Regi&#xF3;n para la obra &quot;Dise&#xF1;o Definitivo de la Red Secundaria y Terciaria de Canales de Riego Proyecto Faja Mais&#xE1;n, Canal Monte Canelo&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Agnes Corina Torres Cuevas, ascendente a la cantidad de $718.076.- para el lote N&#xBA;4-C.</div><br></div>", "i": 6546259}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6546260}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "958 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-958 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-29", "doble_articulado": false, "id_norma": "243425", "numero_fuente": "38301", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-11-02", "vigencias": [{"desde": "2005-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2005-11-02", "fecha_version": "2005-11-02", "fecha_act