{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 1.290.- Santiago, 18 de junio de 1920.- Vistos estos antecedentes y de acuerdo con el Consejo de Estado,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 6332729}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1&#xBA; Conc&#xE9;dese personalidad jur&#xED;dica a la corporaci&#xF3;n denominada &quot;Asociaci&#xF3;n de Damas Protectoras del Obrero&quot;, del departamento de Santiago; y</div><br><div class=\"p\">&nbsp; &nbsp;  2&#xBA; Apru&#xE9;banse los estatutos por que ha de rejirse dicha corporaci&#xF3;n, que constan de la escritura p&#xFA;blica adjunta, otorgada antes el notario p&#xFA;blico de ese departamento, don Jos&#xE9; Vicente Fabres, el ocho de mayo de mil novecientos veinte.</div><br></div>", "i": 6332730}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el &quot;Bolet&#xED;n de las Leyes y Decretos del Gobierno&quot;.- Sanfuentes.- Javier Gandarillas.</div><br></div>", "i": 6332731}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1290", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1290"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1920-06-18", "refundido_por": "DTO-870", "doble_articulado": false, "id_norma": "184705", "numero_fuente": "12701", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1920-06-22", "vigencias": [{"desde": "1920-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1920-06-22", "fin_vigenc