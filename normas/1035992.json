{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.667 EXENTA, DE 2011</div></div>", "i": 9225851}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.667, de 7 de diciembre de 2011, del Ministerio de Transportes y Telecomunicaciones, se modific&#xF3; la <a href=\"https://www.leychile.cl/Navegar?idNorma=1031516&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.984, de 2011</a>, de la misma autoridad, autorizando la incorporaci&#xF3;n de dos buses adicionales de 77 plazas cada uno, para el prestador de servicios de la Unidad de Negocio Alimentadora N&#xBA; 6, Comercial Nuevo Milenio S.A. Texto &#xED;ntegro se encuentra en la p&#xE1;gina web www.transantiago.gob.cl.-</div></div>", "i": 9225852}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Pedro Pablo Err&#xE1;zuriz Dom&#xED;nguez, Ministro de Transportes y Telecomunicaciones.</div></div>", "i": 9225853}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3667 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3667 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.667 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-12-07", "doble_articulado": false, "id_norma": "1035992", "numero_fuente": "40157", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-01-10", "vigencias": [{"desde": "2012-01-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-01-10", "fin_vigencia": ""}, "vige