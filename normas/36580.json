{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8296590}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.247, de 29 de Diciembre de 1994, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a PESQUERA MARVESA S.A., R.U.T. N&#xB0; 96.550.700-0, para ampliar actividades pesqueras autorizadas por Resoluci&#xF3;n N&#xB0; 635, de 1991. El peticionario podr&#xE1; incorporar a los recursos hidrobiol&#xF3;gicos ya autorizados, en la l&#xED;nea de elaboraci&#xF3;n de Semi-conserva y deshidratado, los siguientes: Anchoa o anchoveta, Sardina espa&#xF1;ola. Modif&#xED;case el numeral 2&#xB0; de la Resoluci&#xF3;n N&#xB0; 635, de 1991, de esta Subsecretar&#xED;a, en el sentido de se&#xF1;alar que la planta estar&#xE1; ubicada en Barros Arana N&#xB0; 2298, Arica.</div><br></div>", "i": 8296591}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 29 de Diciembre de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8296592}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1247", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1247"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA MARVESA S.A.", "PESCA", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-12-29", "fecha_derogacion": "2003-10-07", "doble_articulado": false, "id_norma": "36580", "numero_fuente": "35065", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1995-01-12", "vigencias": [{"desde": "2003-10-07", "hasta": ""