{"html": [{"t": "<div><div class=\"p\">ACUERDO DE CLASIFICACION </div></div>", "i": 6280155}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Vistos: Lo dispuesto en el Decreto Ley N&#xB0; 3.500, de 1980, en las Leyes N&#xB0;s. 18.398, 18.420, y en los Decretos Supremos N&#xB0;s. 31, 35 y 63, de 1985, 54 y 74, de 1986 y 19, de 1987, del Ministerio del Trabajo y Previsi&#xF3;n Social.</div><div class=\"p\">La Comisi&#xF3;n Clasificadora de Riesgo acord&#xF3;, en la Novena sesi&#xF3;n extraordinaria, autorizar la inversi&#xF3;n de los recursos de los Fondos de Pensiones en acciones de la siguiente Sociedad An&#xF3;nima Abierta: Empresa Nacional de Electricidad S.A.</div><br></div>", "i": 6280156}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 09 de Noviembre de 1987. Juan Arizt&#xED;a Matte, Superintendente, Presidente de la Comisi&#xF3;n Clasificadora de Riesgo.</div><br></div>", "i": 6280157}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "S/N", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-S/N"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARIA DE PREVISION SOCIAL"], "titulo_norma": "ACUERDO DE CLASIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-09", "doble_articulado": false, "id_norma": "170307", "numero_fuente": "32916", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-10", "vigencias": [{"desde": "1987-11-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-11-10", "fin_vigencia": "", "tipo_version": "3"