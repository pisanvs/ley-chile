{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6367334}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 156 de 17 de enero de 2002 de esta Subsecretar&#xED;a, modif&#xED;case el numeral 6&#xBA; de la resoluci&#xF3;n N&#xBA; 37 de 2002, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO, para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto denominado &apos;&apos;Distribuci&#xF3;n espacio temporal de las capturas de jurel en la I y II Regi&#xF3;n (Primera Etapa, 2002)&apos;&apos;, en el sentido de reemplazar la nave &apos;&apos;Patillos&apos;&apos; por la nave &apos;&apos;Eperva 56&apos;&apos;, ambas de propiedad de Corpesca S.A., de la n&#xF3;mina de naves participantes en la se&#xF1;alada pesca de investigaci&#xF3;n.</div><br></div>", "i": 6367335}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de enero de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6367336}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "156", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-156"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-01-17", "doble_articulado": false, "id_norma": "194124", "numero_fuente": "37171", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-28", "vigencias": [{"desde": "2002-01-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-28", "fin_vig