{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6237184}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta N&#xB0; 333 de fecha Diciembre 24 de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la II Regi&#xF3;n, se autoriza a don Guillermo Gueny Az&#xF3;car para efectuar todo tipo de servicio de transporte de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6237185}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - James Brown Rojas, SEREMI Subrogante de Transportes y Telecomunicaciones II Regi&#xF3;n.</div><br></div>", "i": 6237186}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "333 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-333 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-24", "doble_articulado": false, "id_norma": "156947", "numero_fuente": "32366", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-01-08", "vigencias": [{"desde": "1986-01-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-01-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-01-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2000-02-25", "fecha_vers