{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 15.259 EXENTA, DE 2004 </div></div>", "i": 6514649}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 15.259 de 29 de diciembre de 2004, se han aprobado al Liceo Isidora Ramos, de la comuna de Lebu, de la Regi&#xF3;n del B&#xED;o B&#xED;o, un plan de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2005.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio de los Subsectores que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 6514650}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de enero de 2005.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6514651}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "15259 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-15259 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 15.259 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-29", "doble_articulado": false, "id_norma": "235111", "numero_fuente": "38074", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-01-31", "vigencias": [{"desde": "2005-01-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-01-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-01-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFI