{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PENSION Lei n&#xFA;m. 295.- Santiago, a 4 de Setiembre de 1895.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947436}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, a do&#xF1;a Mercedes Henr&#xED;quez, hija del teniente de Ej&#xE9;rcito don Manuel Henr&#xED;quez, el derecho de percibir la pension de montep&#xED;o militar de que disfrut&#xF3; su se&#xF1;ora madre do&#xF1;a Mar&#xED;a Garc&#xED;a.</div><br><br></div>", "i": 5947437}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- Jorje Montt.- Ismael Valdes Valdes.</div><br></div>", "i": 5947438}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "295", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-295"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MERCEDES HENRIQUEZ", "MONTEPIO MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-09-04", "doble_articulado": false, "id_norma": "22146", "numero_fuente": "5206", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-09-07", "vigencias": [{"desde": "1895-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-09-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1895-09-07", "fin_vigencia": "", "tipo_version": "3"}], 