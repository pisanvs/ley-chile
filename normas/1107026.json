{"html": [{"t": "<div><br><div class=\"p\">DECLARA T&#xC9;RMINO DE GIRO SEG&#xDA;N LO DISPUESTO EN EL INCISO FINAL DEL <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=8573402&amp;idVersion=\">ARTICULO 69</a> DEL <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=0&amp;idVersion=\">C&#xD3;DIGO TRIBUTARIO</a> A LOS CONTRIBUYENTES QUE INDICA</div></div>", "i": 9828460}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 78, de 23 de agosto 2017, que establece:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n se informa que en la p&#xE1;gina web del Servicio se encuentra la N&#xF3;mina con la individualizaci&#xF3;n de personas, entidades y agrupaciones, a quienes se les declara el t&#xE9;rmino de giro o cese de sus actividades.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes agosto de 2017.</div></div>", "i": 9828461}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "78 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-78 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DECLARA TÉRMINO DE GIRO SEGÚN LO DISPUESTO EN EL INCISO FINAL DEL ARTICULO 69 DEL CÓDIGO TRIBUTARIO A LOS CONTRIBUYENTES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1264156", "EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false,