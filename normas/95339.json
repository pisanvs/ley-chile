{"html": [{"t": "<div><div class=\"p\">PRORROGA RESOLUCIONES QUE INDICA </div></div>", "i": 8325975}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No.1.116, de 23 de Agosto de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por 6 meses a contar de esta fecha la autorizaci&#xF3;n otorgada a don Carlos Raby Rodewald, R.U.T. No. 1.137.656-9, domiciliado en la ciudad de Valpara&#xED;so, calle Prat No.827, Of. No.802, para empezar a operar los establecimientos de cultivo autorizados por las Resoluciones No.757, No.1097 y No.1098, todas de 1988, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de fuerza mayor.</div><br></div>", "i": 8325976}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 23 de Agosto de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8325977}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1116", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1116"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "PRORROGA RESOLUCIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-08-23", "doble_articulado": false, "id_norma": "95339", "numero_fuente": "33467", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-09-06", "vigencias": [{"desde": "1989-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-09-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-09-06", "fin_vigencia": "", "tipo_versi