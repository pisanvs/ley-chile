{"html": [{"t": "<div><br><div class=\"p\">Ley N&#xFA;m. 5.480</div><br><div class=\"p\">DECLARA FERIADO NACIONAL EL LUNES 17 DE SEPTIEMBRE DE 1934</div><br><br><div class=\"p\">&nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp;  Proyecto de ley:</div></div>", "i": 9639639}, {"t": "<div><br><div class=\"p\">&nbsp;  Art&#xED;culo &#xFA;nico. Decl&#xE1;rase feriado nacional el d&#xED;a lunes 17 de Septiembre de 1934.</div><br><div class=\"p\">&nbsp;  Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 9639640}, {"t": "<div><br><div class=\"p\">&nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto pr&#x43E;m&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp;  Santiago, once de Septiembre de mil novecientos treinta y cuatro.- ARTURO ALESSANDRI.- Luis Salas R.</div><br></div>", "i": 9639641}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "5480", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "Ley-5480"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DECLARA FERIADO NACIONAL EL LUNES 17 DE SEPTIEMBRE DE 1934", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1934-09-11", "doble_articulado": false, "id_norma": "1082216", "numero_fuente": "15775", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1934-09-12", "vigencias": [{"desde": "1934-09-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1934-09-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1934