{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; REHABILITA SU CALIDAD DE CHILENO A DON FELIX ALBAGLY HAIM</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8278492}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Rehabil&#xED;tase en su calidad de chileno a don F&#xE9;lix Albagly Haim.</div><div class=\"p\">&nbsp; &nbsp; La presente ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 8278493}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta de Septiembre de mil novecientos cuarenta y ocho.- GABRIEL GONZALEZ VIDELA.- I. Holger T. </div></div>", "i": 8278494}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "9098", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-9098"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "REHABILITA SU CALIDAD DE CHILENO A DON FELIX ALBAGLY\nHAIM", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REHABILITACION", "NACIONALIDAD", "FELIX ALBAGLY HAIM"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1948-09-30", "doble_articulado": false, "id_norma": "25914", "numero_fuente": "21176", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1948-10-13", "vigencias": [{"desde": "1948-10-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1948-10-13", "fin_vigencia": ""}, "vigencias_version_no