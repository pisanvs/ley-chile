{"html": [{"t": "<div><div class=\"p\">ESTANCO.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Setiembre 15 de 1824.</div><br><div class=\"p\">&nbsp; &nbsp;  El Gobierno ha acordado y decreta:</div></div>", "i": 10097656}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Que en observancia del art. 9 da la contrata sobre estancos de varias esp&#xE9;cies, se ordene a las Aduanas; y demas a quienes corresponda su cumplimiento, que los subhastadores del estanco, quedan exentos del derecho de p&#xF3;liza prevenido para internacion en el art. 14 de la ampliacion al Reglamento de comercio de 1813, siempre que los efectos internados sean de los contenidos en la contrata, a excepcion de los licores, que deber&#xE1;n pagarlo como siempre.</div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, trascr&#xED;base e impr&#xED;mase.</div></div>", "i": 10097657}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Diego Jos&#xE9; Benavente.</div></div>", "i": 10097658}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "ESTANCO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-09-15", "doble_articulado": false, "id_norma": "1141035", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-09-15", "fin_vigencia": "", "tipo