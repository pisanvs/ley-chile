{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6312948}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;4.583 de fecha 29 de Septiembre del 2000, se expropi&#xF3; el lote de terreno N&#xBA;2, superficie 7.479 m2., rol de aval&#xFA;o 157-17, comuna de Pemuco, para la obra &apos;&apos;Proyecto Laja - Diguill&#xED;n, Arca de Riego Pemuco, Canal San Ram&#xF3;n Km. 0,000 al km. 6,637, Canal San Ram&#xF3;n Ramal N&#xBA;1 Km. 0,003 al Km. 0,224, Red Terciaria Canal San Ram&#xF3;n Ramal N&#xBA;2 Km. 0,003 al Km.</div><div class=\"p\">1,348 y Red Terciaria Canal San Ram&#xF3;n Ramal N&#xBA;3 Km.</div><div class=\"p\">0.003 al Km. 0,259&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Julio C&#xE9;sar Ocampo Salinas, ascendente a la cantidad de $3.178.425.- </div></div>", "i": 6312949}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6312950}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "4583", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-4583"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-29", "doble_articulado": false, "id_norma": "179199", "numero_fuente": "36838", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-12-15", "vigencias": [{"desde": "2000-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-12-15", "fin_vigencia": "", "tip