{"html": [{"t": "<div><div class=\"p\">RECTIFICA EXTRACTO DE RESOLUCION No. 726, DE 1992 </div><div class=\"p\">(Extracto) </div></div>", "i": 8307836}, {"t": "<div><br><div class=\"p\">Por resoluci&#xF3;n No. 895 de 16 de Septiembre de 1992 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, rectif&#xED;case el extracto de la Resoluci&#xF3;n No. 726, de 1992, de esta Subsecretar&#xED;a, en el sentido de que donde dice &quot;su RUT No. 86.347.400-7&quot; debe decir &quot;su RUT No.</div><div class=\"p\">86.247.400-7.</div><br></div>", "i": 8307837}, {"t": "<div><div class=\"p\"> Valpara&#xED;so, 16 de Septiembre de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8307838}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "895", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-895"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "RECTIFICA EXTRACTO DE RESOLUCION Nº. 726, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-09-16", "doble_articulado": false, "id_norma": "77334", "numero_fuente": "34377", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-09-29", "vigencias": [{"desde": "1992-09-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-09-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-09-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "PMB",