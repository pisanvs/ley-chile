{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6537819}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.447, de 3 de agosto de 2005, de esta Subsecretar&#xED;a, prorr&#xF3;gase la vigencia de la resoluci&#xF3;n N&#xBA; 1.118 de 2005, que modific&#xF3; la resoluci&#xF3;n N&#xBA; 1.050 de 2005, ambas de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a CONSULTORA PUPELDE LIMITADA para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto denominado &quot;Bases T&#xE9;cnicas para el Plan de Manejo Pesquer&#xED;as Bent&#xF3;nicas Zona Contigua Regiones X y XI&quot;, hasta el 14 de octubre de 2005.</div><br></div>", "i": 6537820}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de agosto de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6537821}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2447 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2447 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-08-03", "doble_articulado": false, "id_norma": "241340", "numero_fuente": "38246", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-08-26", "vigencias": [{"desde": "2005-08-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-08-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-08-26", "fin_vigencia": "", "tipo_ve