{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6097011}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 236 de feeha 27 de Julio de 1989, SERVIU</div><div class=\"p\">IX Regi&#xF3;n dispuso expropiaci&#xF3;n inmueble ubicado en calle</div><div class=\"p\">Claro Solar No. 1296, ciudad Temuco, Rol Aval&#xFA;o No. 163-2,</div><div class=\"p\">Temuco, de aparente dominio de Fisco de Chile, conforme al</div><div class=\"p\">art&#xED;culo 51 Ley No. 16391 de 1965 y DS No. 181 de 1988 de Vivienda y Urbanismo. Informe Tasaci&#xF3;n Expropiaci&#xF3;n fecha 28.11.88 Comisi&#xF3;n Peritos se&#xF1;ores Jos&#xE9; M&#xE9;ndez Manr&#xED;quez, ingeniero civil, Mario Molina Ramwell constructor civil, y Pablo Reidel Wanner, arquitecto. Monto provisional indemnizaci&#xF3;n suma $ 30.476.760.- incluido reajuste legal art&#xED;culo 5&#xB0; DL No. 2.186 de 1978, pagadero al contado. </div></div>", "i": 6097012}, {"t": "<div><div class=\"p\">Director Regional.</div><br></div>", "i": 6097013}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "236", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-236"}], "organismos": ["SERVICIO DE VIVIENDA Y URBANIZACION IX REGIÓN DE LA ARAUCANIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-07-27", "doble_articulado": false, "id_norma": "94412", "numero_fuente": "33449", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-08-16", "vigencias": [{"desde": "1989-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigen