{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PARTIDO SOCIALISTA DE CHILE, SOLICITUD DE CONSTITUCION LEGAL </div></div>", "i": 6015845}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Camilo Escalona Medina e Isabel Allende Bussi, Presidente y Secretario General, respectivamente, en representaci&#xF3;n del &quot;Partido Socialista de Chile&quot;, han solicitado la constituci&#xF3;n legal del Partido en la XI Regi&#xF3;n de &quot;Ays&#xE9;n del General Carlos Ib&#xE1;&#xF1;ez del Campo&quot;, acompa&#xF1;ando 256 fichas de afiliaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la Ley N&#xB0; 18.603, por Resoluci&#xF3;n O-N&#xB0; 1302 de fecha 02 de Diciembre de 1994. </div></div>", "i": 6015846}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 2 de Diciembre de 1994.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6015847}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1302", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1302"}, {"tipo": "3", "numero": "O-1302", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-1302"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO SOCIALISTA DE CHILE, SOLICITUD DE CONSTITUCION LEGAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO SOCIALISTA CHILE", "CONSTITUCION LEGAL DECIMO PRIMERA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-12-02", "doble_articulado": false, "id_norma": "36661", "numero_fuente": "35073", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-01-21", "vigencias": [{"desde": "1995-01-2