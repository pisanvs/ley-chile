{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8309175}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.581, de 18 de noviembre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xBA; 166 de 1990 y N&#xBA; 599 de 1995, de esta Subsecretar&#xED;a, que autorizaron a&nbsp; PESQUERA CALIPSO S.A., para operar cuatro naves en construcci&#xF3;n, en virtud de lo se&#xF1;alado en el Art&#xED;culo 143 letra b), del D.S. N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8309176}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de noviembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8309177}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1581", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1581"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA CALIPSO S.A.", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-11-18", "doble_articulado": false, "id_norma": "78697", "numero_fuente": "35927", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-11-27", "vigencias": [{"desde": "1997-11-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-11-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-11-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pend