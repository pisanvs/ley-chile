{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8277775}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Agr&#xE9;gase al art&#xED;culo 6 de la ley n&#xFA;mero 5,005, de 24 de Noviembre de 1931, el siguiente inciso:</div><div class=\"p\">&nbsp; &nbsp; &quot;g) Las del Cuerpo de Carabineros de Chile&quot;.</div><br><br></div>", "i": 8277776}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a treinta de Diciembre de mil novecientos treinta y uno.- JUAN E. MONTERO.- Marcial Mora M. </div></div>", "i": 8277777}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "5023", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-5023"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ADMINISTRACION PUBLICA", "SERVICIOS", "VACANTES", "PROVEIMIENTO", "CUERPO CARABINEROS CHILE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-12-30", "doble_articulado": false, "id_norma": "25002", "numero_fuente": "16166", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-01-06", "vigencias": [{"desde": "1932-01-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1932-01-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1932-01-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": []