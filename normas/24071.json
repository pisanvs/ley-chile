{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,562, que suplementa el Presupuesto de Guerra.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,562.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 7166813}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese un suplemento de nueve mil pesos ($ 9,000) al &#xED;tem 106 de la partida 4.a del Presupuesto de Guerra vijente.</div><div class=\"p\">&nbsp; &nbsp; El gasto se deducir&#xE1; del &#xED;ten 101 del mismo Presupuesto, para cuyo efecto se rebaja este &#xED;tem en la cantidad indicada.</div><br></div>", "i": 7166814}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintinueve de Noviembre de mil novecientos diecinueve.- JUAN LUIS SANFUENTES.- Jerman Riesco.</div><br></div>", "i": 7166815}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3562", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3562"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "LEI NÚM. 3,562, QUE SUPLEMENTA EL PRESUPUESTO DE GUERRA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1919", "MODIFICACION", "MINISTERIO", "GUERRA SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1919-11-29", "doble_articulado": false, "id_norma": "24071", "numero_fuente": "12535", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1919-12-02", "vigencias": [{"desde": "