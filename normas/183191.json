{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 6327619}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 460, de 09 de Marzo de 1990 de esta Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 1&#xB0; de la Resoluci&#xF3;n No. 223, de 1990, de esta Subsecretar&#xED;a de Pesca, en el sentido de sustituir la expresi&#xF3;n &quot;para ampliar actividades pesqueras, que tiene autorizadas por Resoluci&#xF3;n No. 213, de 1981, de esta Subsecretaria&quot;, por la siguiente: &quot;para iniciar actividades pesqueras&quot;.</div><br></div>", "i": 6327620}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 09 de Marzo de 1990.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 6327621}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "460", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-460"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-09", "doble_articulado": false, "id_norma": "183191", "numero_fuente": "33624", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-19", "vigencias": [{"desde": "1990-03-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-03-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-03-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "i