{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6266677}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 114, de 12 Junio 1984, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se autoriza al se&#xF1;or Jos&#xE9; Manuel Hern&#xE1;ndez Ram&#xED;rez, para efectuar todo tipo de transporte de pasajeros por calles y campos dentro del territorio nacional, a excepci&#xF3;n del servicio urbano de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6266678}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Manuel Coloma Amaro, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n del Maule. </div></div>", "i": 6266679}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "114", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-114"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-06-12", "doble_articulado": false, "id_norma": "166082", "numero_fuente": "32079", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-01-24", "vigencias": [{"desde": "1985-01-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-01-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-01-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMZ", "fech