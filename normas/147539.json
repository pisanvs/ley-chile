{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6204768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n. Exenta No. 462 de 23 de Abril de 1987, conforme Art. 5&#xB0; Transitorio C&#xF3;digo- de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a Sector Excluido y Sector Expropiado Predio: &quot;Resto del Fundo Tabal&#xED;&quot; de la comuna de Punitaqui, IV Regi&#xF3;n, y Derechos Aprovechamiento Aguas que corresponden a parcelas N&#xB0;s. 1 a la 5 del Proyecto de Parcelaci&#xF3;n &quot;Tabal&#xED;&quot;, formado por predio se&#xF1;alado. Los derechos de agua se extraen de los canales Barraza Alto derivado del R&#xED;o Limar&#xED;, Tabal&#xED; o Tabal&#xED; Bajo derivado del R&#xED;o Limar&#xED; y Tabal&#xED; Alto o Tomilla -Tabal&#xED;. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.</div><br></div>", "i": 6204769}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6204770}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "462 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-462 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-04-23", "doble_articulado": false, "id_norma": "147539", "numero_fuente": "32760", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-05-02", "vigencias": [{"desde": "1987-05-02", "hasta": "", "tipo_version"