{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8312839}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.655, de 2 de diciembre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad total de la Resoluci&#xF3;n N&#xBA; 356, de 1985 y parcial de la Resoluci&#xF3;n N&#xBA; 8 de 1987, ambas de esta Subsecretar&#xED;a, respecto de su numeral 1&#xBA;, letra b), que autorizaron a don JUAN AGUSTIN NEIRA ALTAMIRANO, para desarrollar actividades pesqueras extractivas con la nave &quot;Calypso II&quot;, por haberse configurado, en ambas la causal prevista en el art&#xED;culo 143, letra b) de la Ley General N&#xBA; 18.892 y sus modificaciones, citada en Visto. </div></div>", "i": 8312840}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de diciembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8312841}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1655", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1655"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "PESCA", "JUAN AGUSTIN NEIRA ALTAMIRANO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-02", "doble_articulado": false, "id_norma": "81759", "numero_fuente": "35936", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-12-09", "vigencias": [{"desde": "1997-12-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-12-09", "fin_v