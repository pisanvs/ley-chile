{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7316362}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.310, de 17 de noviembre de 2004, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de las resoluciones N&#xBA; 984 de 1989 y N&#xBA; 1.835 de 1997, el numeral 6&#xBA; de la resoluci&#xF3;n N&#xBA; 2.945 y el numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA; 2.946 de 2002, todas de esta Subsecretar&#xED;a, que autorizaron a PESQUERA MAR PROFUNDO S.A., para desarrollar actividades pesqueras extractivas con la nave &quot;Arauco I&apos;&apos;, en el sentido de actualizar la siguiente caracter&#xED;stica n&#xE1;utica de la nave:</div><br><div class=\"p\">&nbsp; &nbsp;  Capacidad de bodega&nbsp; &nbsp; 1.271,00 m&#xB3;.</div><br></div>", "i": 7316363}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de noviembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7316364}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3310 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3310 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-17", "doble_articulado": false, "id_norma": "232916", "numero_fuente": "38022", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-11-27", "vigencias": [{"desde": "2004-11-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-11-27", "fin_vigencia": ""}, "vigencias_version_no