{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6025683}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n Exenta N&#xB0; 2.002, de 11 de Diciembre de 1995, se autoriz&#xF3; a la empresa Sociedad de Transportes Andina del Sud Limitada (Transportes Andina del Sud Ltda.) para efectuar servicio de transporte internacional terrestre de pasajeros entre Peulla (Chile) y Puerto Fr&#xED;as (Argentina) utilizando el paso fronterizo Vicente P&#xE9;rez Rosales con dos frecuencias semanales en el per&#xED;odo comprendido entre el 16 de marzo y el 14 de noviembre de cada a&#xF1;o y siete frecuencias semanales en el per&#xED;odo comprendido entre el 15 de noviembre y 15 de marzo de a&#xF1;o siguiente.</div><div class=\"p\">&nbsp; &nbsp; La empresa podr&#xE1; distribuir las frecuencias autorizadas dentro de la semana calendario, conforme a la demanda de los usuarios.-</div><br></div>", "i": 6025684}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Claudio Hohmann Barrientos, Subsecretario de Transportes </div></div>", "i": 6025685}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2002 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2002 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD TRANSPORTES ANDINA SUD LIMITADA", "TRANSPORTE", "TERRESTRE", "TRANSPORTE INTERNACIONAL", "CHILE", "ARGENTINA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-12-11", "doble_articulado": false, "id_norma": "40041", "numero_fuente": "35367", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicaci