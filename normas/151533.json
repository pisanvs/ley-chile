{"html": [{"t": "<div><div class=\"p\">DISPONE EXPROPIACION PARCIAL DE PREDIO QUE INDICA </div></div>", "i": 6220035}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto N&#xB0; 361, Secci&#xF3;n Segunda, de fecha 04.09.86, Alcalde I. Municipalidad de Macul dispone expropiaci&#xF3;n parcial, conforme DFL N&#xB0; 458/76, DL N&#xB0; 2.186/78 y DL N&#xB0; 1.289/76, predio dominio aparente Comunidad Jorge Hasb&#xFA;n Connell y otros, objeto ensanche Avda. Pedro de Valdivia N&#xB0; 6080. Indemnizaci&#xF3;n $ 116.920, que se pagar&#xE1; con compensaci&#xF3;n derechos de construcci&#xF3;n.-</div><br></div>", "i": 6220036}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Manuel Matte Rodr&#xED;guez, Alcalde Municipalidad de Macul.- Patricio Cordero Barrera, Secretario Municipal.- Macul, Septiembre 23de 1986 </div></div>", "i": 6220037}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "361", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-361"}], "organismos": ["MUNICIPALIDAD DE MACUL"], "titulo_norma": "EXTRACTO DE DECRETO EX. QUE ORDENA EL ESTUDIO DE\nEXPROPIACION DE FRANJA DE TERRENO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-09-04", "doble_articulado": false, "id_norma": "151533", "numero_fuente": "32.585", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-10-01", "vigencias": [{"desde": "1986-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-10-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vin