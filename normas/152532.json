{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xB0; 303, DE 1986 </div></div>", "i": 8357651}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 690, de 25 de Septiembre de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n N&#xB0; 303, de 1986, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a la Sociedad &quot;Lastra y Compa&#xF1;&#xED;a Limitada&quot; para elaborar recursos hidrobiol&#xF3;gicos en la l&#xED;nea de congelado en las instalaciones de Comercial Mesa S.A., Concepci&#xF3;n y en la l&#xED;nea de conserva en calle 11 Norte 186, Poblaci&#xF3;n Esmeralda de Talcahuano, en orden a incluir en el numeral 3&#xB0;, entre los recursos que podr&#xE1; utilizar como materia prima, el denominado loco.</div><br><br></div>", "i": 8357652}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de Septiembre de 1986.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8357653}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "690", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-690"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION N° 303, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-09-25", "doble_articulado": false, "id_norma": "152532", "numero_fuente": "32.599", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-10-17", "vigencias": [{"desde": "1986-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"in