{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6486901}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.749 de 30 de junio de 2004, de esta Subsecretar&#xED;a de Pesca, modif&#xED;case el numeral 3&#xBA; de la resoluci&#xF3;n N&#xBA; 1.491 de 2004, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto FIP 2004-06 denominado &quot;Evaluaci&#xF3;n hidroac&#xFA;stica de recurso jurel entre la V y X Regiones, a&#xF1;o 2004&quot;, en el sentido de se&#xF1;alar que la pesca de investigaci&#xF3;n se extender&#xE1; hasta el 31 de julio de 2004, inclusive.</div><br></div>", "i": 6486902}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de junio de 20 04.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6486903}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1749 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1749 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-06-30", "doble_articulado": false, "id_norma": "227406", "numero_fuente": "37907", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-12", "vigencias": [{"desde": "2004-07-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-07-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-07