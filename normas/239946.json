{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6532441}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.952, de 23 de junio de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA SANTA MARTA LIMITADA para ampliar actividades pesqueras de transformaci&#xF3;n en orden a incorporar a la planta ubicada en Andina esquina El Tofo s/n, Barrio Industrial, Puerto Montt, X Regi&#xF3;n, en las l&#xED;neas de proceso de Fresco enfriado, Fresco refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6532442}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de junio de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6532443}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1952 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1952 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-23", "doble_articulado": false, "id_norma": "239946", "numero_fuente": "38205", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-08", "vigencias": [{"desde": "2005-07-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-07-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2005-07-08", "fec