{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6484867}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.607, de 10 de junio de</div><div class=\"p\">2004, de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; ARICA</div><div class=\"p\">SEAFOODS PRODUCER S.A. para continuar desarrollando</div><div class=\"p\">actividades pesqueras extractivas con una nave en</div><div class=\"p\">construcci&#xF3;n, autorizada para operar por resoluci&#xF3;n N&#xBA;</div><div class=\"p\">1.608 de 2003, de la Subsecretar&#xED;a de Pesca, quien podr&#xE1;</div><div class=\"p\">operar en el &#xE1;rea mar&#xED;tima correspondiente a las</div><div class=\"p\">Regiones I y II, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; capturar, con red de cerco, los recursos hidrobiol&#xF3;gicos Jurel, Sardina espa&#xF1;ola y Anchoveta.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1.608 de 2003, de la Subsecretar&#xED;a de Pesca.</div><br></div>", "i": 6484868}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de junio de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6484869}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1607 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1607 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-06-10", "fecha_derogacion": "2005-02-16", "doble_articulado": false, "id_norma": "226812", "numero_fuente": "