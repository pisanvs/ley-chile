{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8306313}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.210 de 29 de agosto de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la autorizaci&#xF3;n solicitada por SARPESCA S.A., para ampliar actividades pesqueras extractivas con las naves &quot;Puyuguapi&quot; y &quot;Tuamapu&quot;, en las aguas interiores de la X, XI y XII Regiones, por verificarse la causal denegatoria prevista en el art&#xED;culo 19 letra e) en relaci&#xF3;n a los art&#xED;culos 23 y 47 de la Ley N&#xBA; 18.892 y sus modificaciones. </div></div>", "i": 8306314}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de agosto de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8306315}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1210", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1210"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SARPESCA S.A.", "PESCA", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-08-29", "doble_articulado": false, "id_norma": "75540", "numero_fuente": "35860", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-09-05", "vigencias": [{"desde": "1997-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-09-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-09-05", "fin_vigencia": "", "tipo_version": "3"}], "evento