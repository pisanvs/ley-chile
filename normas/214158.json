{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6437587}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 698 de fecha 30 de junio del 2003, se expropi&#xF3; el lote de terreno N&#xBA; 20-A, superficie 552,0 m&#xB2;, rol N&#xBA; 559-7, comuna de Linares, VII regi&#xF3;n para la obra &quot;Camino Ruta L-45, Sector: Linares - Llepo, Tramo: Km. 2,750.2 a Km. 13,147&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Elba o Elva Castro Baham&#xF3;ndez, ascendente a la cantidad de $18.949.068. </div></div>", "i": 6437588}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6437589}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "698", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-698"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-30", "doble_articulado": false, "id_norma": "214158", "numero_fuente": "37649", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-01", "vigencias": [{"desde": "2003-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2003-09-01", "fecha_version": "2003-09-01", "fecha_actualizacion_texto": "2003-09-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "En