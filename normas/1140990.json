{"html": [{"t": "<div><div class=\"p\">DELEGA FACULTADES Y ASIGNA FUNCIONES, EN LA JEFATURAS Y MATERIAS QUE INDICA</div></div>", "i": 10092533}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 1, del 2 de enero de 2020, que establece:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Delega facultades y asigna funciones, en materias relativas a adquisici&#xF3;n de bienes muebles y contrataci&#xF3;n de servicios; adquisici&#xF3;n, arrendamiento y comodato de bienes inmuebles; y finanzas, en las jefaturas de la Direcci&#xF3;n Nacional, Direcciones Regionales y Direcci&#xF3;n de Grandes Contribuyentes que indica.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en &quot;www.sii.cl&quot;.</div><br></div>", "i": 10092534}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DELEGA FACULTADES Y ASIGNA FUNCIONES, EN LA JEFATURAS Y MATERIAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1708654; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2020-01-02", "fecha_derogacion": "2020-12-03", "doble_articulado": false, "id_norma": "1140990", "numero_fuente": "42551", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2020-01-13", "vigencias": [{"desde": "2020-12-03", "hasta": "", "tipo_ver