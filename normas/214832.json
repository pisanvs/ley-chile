{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7303792}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.987, de 21 de agosto de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 874 de 1993 y el numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA; 504 de 1997, ambas de esta Subsecretar&#xED;a, que autorizaron a PESQUERA BIO BIO S.A. para realizar actividades pesqueras extractivas con la nave &quot;Lascar&quot;, en el sentido de incorporar y actualizar, seg&#xFA;n corresponda, las siguientes caracter&#xED;sticas n&#xE1;uticas de &#xE9;sta:</div><br><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  23,41 m</div><div class=\"p\">TRG (Internacional)&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 98,35</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 6,67 m</div><br><br></div>", "i": 7303793}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7303794}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1987 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1987 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-08-21", "fecha_derogacion": "2004-12-07", "doble_articulado": false, "id_norma": "214832", "numero_fuente": "37662", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-09-16", "