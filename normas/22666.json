{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Ferrocarril que una a Chillan con Tom&#xE9; i Penco. Estudios</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,459.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949226}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza al Presidente de la Rep&#xFA;blica para que invierta hasta la suma de cincuenta mil pesos en hacer los estudios definitivos de un ferrocarril que una a la ciudad de Chillan con Tom&#xE9; i Penco.</div><br></div>", "i": 5949227}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 8 de Febrero de 1901.- FEDERICO ERRAZURIZ E.- Manuel A. Covarrubias.</div><br></div>", "i": 5949228}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1459", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1459"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "FERROCARRIL QUE UNA A CHILLAN CON TOME I PENCO. ESTUDIOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CHILLAN", "TOME", "PENCO", "FERROCARRIL", "INVERSION", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-02-08", "doble_articulado": false, "id_norma": "22666", "numero_fuente": "6820", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-02-16", "vigencias": [{"desde": "1901-02-16", "hasta": "", "tipo_version":