{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO</div></div>", "i": 9886931}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (Exento) N&#xB0; 13 de 24 de enero de 2018, se modific&#xF3; el numeral segundo del <a href=\"https://www.leychile.cl/Navegar?idNorma=1067388&amp;idParte=&amp;idVersion=\">Decreto MOP (Exento) N&#xB0; 745 de 15 de septiembre de 2014</a>, que orden&#xF3; la expropiaci&#xF3;n del Lote N&#xB0; 1, en la parte que se refiere al nombre del propietario y rol de aval&#xFA;o, seg&#xFA;n certificado de aval&#xFA;o emitido por el Servicio de Impuestos Internos, quedando como a continuaci&#xF3;n se indica: LOTE 1, GAJARDO SANTANDER MARTA ROSA Y OTRO, superficie 60 m2., rol de aval&#xFA;o 604-20, Comuna de Molina. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xB0; del decreto ley N&#xB0; 2186, de 1978. </div></div>", "i": 9886932}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "13 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-13 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1352417", "NORMA SIN PROMULGACIÓN", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-01-24", "doble_articulado": false, "id_norma": "1115092", "numero_fuente": "41984", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-02-15", "vigencias": [{"desde": "2018-02-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2018-02-15", "fin_vigencia": ""}, "vigencias_version