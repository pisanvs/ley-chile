{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO DE EDUCACION No. 211 DE 17 DE JUNIO DE 1985 </div></div>", "i": 6257577}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado Planes y Programas Especiales de Estudio para Segundo Ciclo de la Educaci&#xF3;n Media T&#xE9;cnico-Profesional, a contar del a&#xF1;o escolar 1985 y hasta el a&#xF1;o escolar 1990, inclusive, para el Liceo Industrial A- No. 7, de Coquimbo.</div><br><div class=\"p\">&nbsp; &nbsp;  ESPECIALIDADES:</div><br><div class=\"p\"> 1.- Pesquer&#xED;a e Industrias Pesqueras con Menci&#xF3;n en Pesquer&#xED;a.</div><div class=\"p\"> 2.- Pesquer&#xED;a e Industrias Pesqueras con Menci&#xF3;n en Industrias Pesqueras.</div><br></div>", "i": 6257578}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; 28 de Junio de 1985.- Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica Subrogante. </div></div>", "i": 6257579}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "211 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-211 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO DE EDUCACION No. 211 DE 17 DE JUNIO DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-17", "doble_articulado": false, "id_norma": "163165", "numero_fuente": "32317", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-11-09", "vigencias": [{"desde": "1985-11-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-11-09", "fin_vigencia": ""},