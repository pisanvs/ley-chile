{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6182558}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. No. 346, de 28 de Noviembre de 1986, se expropiaron los lotes N&#xB0;s. 4 y 5, cuyas superficies son 2.411 m2. y 4.785 m2., roles de aval&#xFA;o 1021-95 y 1021-96, Comuna La Serena, para la obra Agua Potable de La Serena y Coquimbo, Mejoramiento de la fuente y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios don Julio S. G&#xF3;mez Pereira y don Hugo del Rosario Barahona, ascendentes a $ 65.332 y $ 129.662. </div></div>", "i": 6182559}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. (2) </div></div>", "i": 6182560}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "346", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-346"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-11-28", "doble_articulado": false, "id_norma": "140571", "numero_fuente": "32661", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-01-02", "vigencias": [{"desde": "1987-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1999-08-17", "fecha_version": "1987-01-02", "fecha_actualizacion_texto": "1987-01-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "e