{"html": [{"t": "<div><br><br><div class=\"p\">ORDENA EXPROPIACI&#xD3;N DE INMUEBLE QUE SE&#xD1;ALA</div><br><div class=\"p\">NOTIFICACI&#xD3;N</div><br><br><br></div>", "i": 9633176}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.567 de 8 de junio de 2015 de Serviu Regi&#xF3;n de Antofagasta, se dispuso la expropiaci&#xF3;n de parte del inmueble ubicado en Avenida Balmaceda N&#xBA; 1085 y 1815, Calama, de propiedad de la sociedad Hima Ltda, inscrito en el Registro de Propiedad del Conservador de Bienes Ra&#xED;ces de El Loa Calama a fojas 1.889 N&#xBA; 1.606 del a&#xF1;o 2006, rol de aval&#xFA;o N&#xBA; 01000-27. Monto indemnizaci&#xF3;n provisoria fijada en la suma de $9.665.747- (nueve millones seiscientos sesenta y cinco mil setecientos cuarenta y siete pesos). </div></div>", "i": 9633177}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n Antofagasta.</div><br></div>", "i": 9633178}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1567 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-1567 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN II REGIÓN DE ANTOFAGASTA"], "titulo_norma": "ORDENA EXPROPIACIÓN DE INMUEBLE QUE SEÑALA; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 939758", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-06-08", "doble_articulado": false, "id_norma": "1081109", "numero_fuente": "41247", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-09-01", "vigencias": [{"desde": "2015-09-01", "hasta": "", "tipo_vers