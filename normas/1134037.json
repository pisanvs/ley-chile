{"html": [{"t": "<div><br><div class=\"p\">SUPRESION DE LA CAPELLANIA DE LA CAMARA DE JUSTICIA.</div><br><br><div class=\"p\">&nbsp; &nbsp;  EL DIRECTOR SUPREMO DEL ESTADO &amp;a.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto de acuerdo con el Senado Conservador he decretado:</div></div>", "i": 10042703}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Que en atencion a los graves apuros del Erario, que exijen se supriman los empleos no absolutamente necesarios, se suprime la capellan&#xED;a de la Camara de Justicia.</div><br><div class=\"p\">&nbsp; &nbsp;  Por tanto, ordeno que se publique por lei insertandose en el Boletin. Dado en el Palacio Directorial de Santiago a 3 de Junio de 1823.</div><br></div>", "i": 10042704}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Mariano de Ega&#xF1;a.</div></div>", "i": 10042705}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "SUPRESION DE LA CAPELLANIA DE LA CAMARA DE JUSTICIA", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-06-03", "doble_articulado": false, "id_norma": "1134037", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-06-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-06-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-06-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_po