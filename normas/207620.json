{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6414342}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;386, de 31 de enero de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA COLOMBO LIMITADA para ampliar las actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en Panamericana Norte Km. 668, Vallenar, III Regi&#xF3;n, donde podr&#xE1; procesar, en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Picado y Molienda: Chasc&#xF3;n Lessonia nigrescens, Chasc&#xF3;n Lessonia flavicans, Chasc&#xF3;n Lessonia trabeculata, Chasc&#xF3;n Lessonia fuscences, Huiro Macrocystis integrifolia, Huiro Macrocystis pyrifera, y&nbsp; Cochayuyo.</div><div class=\"p\">&nbsp; &nbsp;  La materia prima deber&#xE1; provenir de pescadores artesanales, debidamente autorizados.</div><br></div>", "i": 6414343}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de enero de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6414344}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "386", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-386"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-31", "doble_articulado": false, "id_norma": "207620", "numero_fuente": "37483", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-02-12", "vigencias": [{"desde": "2003-02-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni