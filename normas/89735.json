{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 8683509}, {"t": "<div><div class=\"p\">El Banco Central de Chile, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de mayo de 1990, fue de 11,03% anual.</div><br></div>", "i": 8683510}, {"t": "<div><div class=\"p\">Santiago 18 de mayo de 1990.- V&#xED;ctor Vial del R&#xED;o, Secretario General Interino.</div><br></div>", "i": 8683511}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-05-18", "doble_articulado": false, "id_norma": "89735", "numero_fuente": "33674", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-05-19", "vigencias": [{"desde": "1990-05-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-05-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-05-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMZ", "fecha_ingreso": "1998-02-17", "fecha_version": "1990-05-19", "fecha_actualizacion_texto": "1990-05-19", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8683509}, {"n": "Artículo", "i": 8683510, "t": 6}, {"n": "