{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10192466}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.341 de 23 de diciembre 2020 de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n parcial, conforme art&#xED;culo 51 ley 16.391, del inmueble ubicado/nombre Canal San Rafael, Rol de Aval&#xFA;o N&#xB0; 1000-1 Comuna San Rafael, superficie 150 metros cuadrados de terreno para Lote 3 y 206 metros cuadrados de terreno para Lote 4, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Asociaci&#xF3;n de Canalistas del Canal San Rafael. Comisi&#xF3;n integrada por peritos Mar&#xED;a Carolina Letelier Bopp, arquitecto; &#xC1;lvaro Hern&#xE1;n Vergara Mej&#xED;as, ingeniero civil industrial; y Claudia Poblete Ram&#xED;rez, arquitecto; seg&#xFA;n informe de tasaci&#xF3;n evacuado con fecha 10 de diciembre de 2020, fij&#xF3; monto provisional indemnizaci&#xF3;n en $9.454.000.- pagados al contado.- </div></div>", "i": 10192467}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Claudio Daneck Mu&#xF1;oz, Director (S) Serviu Regi&#xF3;n del Maule.</div><br></div>", "i": 10192468}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2341 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2341 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "VII REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1878642", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-12-23", "doble_articulado": false, "id_norma": "