{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 2.844 EXENTA, DE 2010</div><br></div>", "i": 8903333}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.844, de 22 de marzo de 2010, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispuso el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n a las entidades.</div><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/11102.jpg\"></div><br><div class=\"p\">&nbsp; &nbsp;  Por haber dejado de cumplir el requisito establecido en el n&#xFA;mero 2 del art&#xED;culo 21 de la ley N&#xBA; 19.518.- </div><br></div>", "i": 8903334}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Manuel Castro Rebolledo, Director Nacional Subrogante.</div><br></div>", "i": 8903335}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2844 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2844 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 2.844 EXENTA, DE 2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-03-22", "doble_articulado": false, "id_norma": "1012146", "numero_fuente": "39625", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-03-31", "vigencias": [{"desde": "2010-03-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-03-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-03-31", "fin_vigencia": "", "tipo_version": "3"}], "eve