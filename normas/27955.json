{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ESTABLECE QUE LA ESCUELA N&#xB0; 20 DE RANCAGUA SE DENOMINARA &quot;ESCUELA BERNARDO O&apos;HIGGINS&quot;.</div><div class=\"p\">&nbsp; &nbsp; El Congreso Nacional ha tenido a bien prestar su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5975019}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. La Escuela N&#xB0; 20 de Rancagua, se denominar&#xE1; en lo sucesivo &quot;Escuela Bernardo O&apos;Higgins&quot;.&quot; </div></div>", "i": 5975020}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecisiete de agosto de mil novecientos sesenta y dos.- JORGE ALESSANDRI RODRIGUEZ.- Patricio Barros.</div><br></div>", "i": 5975021}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14881", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14881"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "ESTABLECE QUE LA ESCUELA N° 20 DE RANCAGUA SE DENOMINARA ESCUELA BERNARDO O'HIGGINS.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMBRE", "ESCUELA BERNARDO O'HIGGINS", "RANCAGUA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1962-08-17", "doble_articulado": false, "id_norma": "27955", "numero_fuente": "25330", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1962-08-29", "vigencias": [{"desde": "1962-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1962-08-29", "fin_vigencia": ""}, "vige