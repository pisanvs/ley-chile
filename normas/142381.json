{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6188082}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.988, de 30 de julio de 1999, se expropiaron los lotes de terreno N&#xBA;s. 44, 49, 49-A y 85, superficies 5.000, 8.446, 7.554 y 28.000 m2, rol de aval&#xFA;o, 250-3, comuna de Salamanca, para la obra Embalse Corrales y sus obras complementarias, Zona de Inundaci&#xF3;n, y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Jos&#xE9; Zu&#xE1;res Ibacache, Jos&#xE9; Moyano Valencia, Nela del Rosario Valencia y Mart&#xED;n V&#xE1;squez D&#xED;az, ascendentes a las cantidades de $1.009.106 el lote N&#xBA; 44, $1.159.442 el lote N&#xBA; 49, $12.234.072 el lote N&#xBA; 49-A, y $18.314.244 el lote N&#xBA; 85.-</div><br></div>", "i": 6188083}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6188084}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1988", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1988"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-07-30", "doble_articulado": false, "id_norma": "142381", "numero_fuente": "36454", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-01", "vigencias": [{"desde": "1999-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac