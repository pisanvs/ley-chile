{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 17B</div></div>", "i": 9832195}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.860, de 30 de agosto de 2017, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1102091&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xB0; 1.229, de 2017</a>, de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 17B, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para el centro de cultivo que indica en la resoluci&#xF3;n extractada.</div></div>", "i": 9832196}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de agosto de 2017.- Pablo Berazaluce Maturana, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9832197}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2860 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2860 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 17B", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1268532; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-08-30", "doble_articulado": false, "id_norma": "1107712", "numero_fuente": "41855", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-09-08", "vigencias": [{"desde": "2017-09-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia