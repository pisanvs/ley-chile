{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Santiago, Diciembre 10 de 1822. &#x2013; </div></div>", "i": 10244628}, {"t": "<div><div class=\"p\">De acuerdo con la Excma. Corte de Representantes nombro por consultores conjueces para el juzgado de miner&#xED;a a don Manuel Salas, don Jos&#xE9; Mar&#xED;a Tocornal, doctor don Juan Ega&#xF1;a, doctor don Juan Jos&#xE9; Echevarr&#xED;a, don Carlos Infante, don Toribio Mujica, don Antonio Palazuelos, don Cipriano P&#xE9;rez, Don Jos&#xE9; Antonio V&#xE1;rgas, don Antonio del Castillo, don Juan Guerrero i don Benito V&#xE1;rgas, quienes aceptar&#xE1;n i ejercer&#xE1;n el cargo conforme a la Ordenanza sin escusa alguna que no ser&#xE1; admitida.</div></div>", "i": 10244629}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Comun&#xED;quese al p&#xFA;blico por la Gaceta Ministerial. &#x2013; O&apos;Higgins. &#x2013; Echeverr&#xED;a.</div></div>", "i": 10244630}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1822-12-10", "doble_articulado": false, "id_norma": "1160603", "numero_fuente": "1822", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1822-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1822-12-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1822-12-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "f