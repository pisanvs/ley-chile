{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10162768}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xBA; 3.422 de 25 de agosto de 2020, instruye a titulares de registros sanitarios, y a los solicitantes de dichos registros, declarar la especie vegetal del almid&#xF3;n utilizado como excipiente en los productos farmac&#xE9;uticos que lo contienen en su formulaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10162769}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Heriberto Garc&#xED;a Escorza, Director (S) Instituto de Salud P&#xFA;blica de Chile.</div><div class=\"p\"> </div><br></div>", "i": 10162770}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3422 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3422 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1823614", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-08-25", "doble_articulado": false, "id_norma": "1149877", "numero_fuente": "42768", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-09-30", "vigencias": [{"desde": "2020-09-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2020-09-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2020-09-30", "fin_vigencia": "", "tipo_version": "3"}]