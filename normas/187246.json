{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 337 EXENTO, DE 2001</div><br><br><br></div>", "i": 6341149}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 337 de 7 de junio del a&#xF1;o 2001, se ha aprobado al Liceo Experimental Art&#xED;stico de Santiago, comuna de Santiago, Regi&#xF3;n Metropolitana, un plan de estudio para S&#xE9;ptimo a&#xF1;o de ense&#xF1;anza B&#xE1;sica (NB.5), el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio correspondientes a los Planes Complementarios, que se se&#xF1;alan en la presente resoluci&#xF3;n.</div><br></div>", "i": 6341150}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de junio de 2001.- Patricio Vilaplana Barberis, Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 6341151}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "337 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-337 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 337 EXENTO, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-06-07", "fecha_derogacion": "2002-12-14", "doble_articulado": false, "id_norma": "187246", "numero_fuente": "37002", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2001-07-04", "vigencias": [{"desde": "2002-12-14", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2001-07-04", "hasta": "2002-12-13", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "200