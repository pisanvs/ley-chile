{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6375011}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 266, de 31 de enero del 2002, se expropiaron los lotes de terreno N&#xBA;s 61, 62, 63, 65 y 66, superficies 797, 805, 850, 924, 975 m2., rol de aval&#xFA;o 103-16, comuna de Curacav&#xED;, para la obra Concesi&#xF3;n Internacional Interconexi&#xF3;n Vial Santiago Valpara&#xED;so Vi&#xF1;a del Mar Tramo 6B: Kms. 34.660,00 al 38.660,00, Regi&#xF3;n Metropolitana y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Mar&#xED;a Josefina Marta del Sagrado Coraz&#xF3;n Hurtado Hurtado, ascendente a la cantidad de $51.343.999.- para los lotes N&#xBA;s. 61, 62, 63, 65 y 66.</div><br></div>", "i": 6375012}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6375013}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "266", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-266"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-01-31", "doble_articulado": false, "id_norma": "196232", "numero_fuente": "37223", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-01", "vigencias": [{"desde": "2002-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fec