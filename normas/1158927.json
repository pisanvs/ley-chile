{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Presidente del Congreso nacional me ha comunicado lo que sigue--</div></div>", "i": 10244696}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Estando reunidas ambas C&#xE1;maras en sesion de hoi, y finalizada la ceremonia con que se habia acordado que debian concluir las funciones del cuerpo lejislativo, el Presidente declar&#xF3;, que el Congreso nacional instalado el 25 de febrero de 1828, despues de haber dado la Constitucion de la Rep&#xFA;blica, y dictado las leyes principales para su planteamiento, cerraba sus sesiones.</div><div class=\"p\">&nbsp; &nbsp;  Por tanto ordeno que se cumpla, comunic&#xE1;ndose a quienes corresponda e insert&#xE1;ndose en el Boletin. Dado en la Sala de Gobierno en Santiago de Chile a 2 de Febrero de 1829.</div></div>", "i": 10244697}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  PINTO</div><div class=\"p\">&nbsp; &nbsp; &nbsp;  Rodr&#xED;guez.</div></div>", "i": 10244698}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1829-02-02", "doble_articulado": false, "id_norma": "1158927", "numero_fuente": "", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1829-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1829-02-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1829-02-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingr