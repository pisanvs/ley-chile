{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6281002}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.001 de 14 de diciembre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a H&#xE9;ctor Sol&#xED;s P&#xE9;rez para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea N&#xBA; 45 &quot;Corvi - Centro&quot; de Valdivia, cuyo trazado fue autorizado por resoluci&#xF3;n exenta N&#xBA; 021 de 14 de enero de 1985 y modificado por resoluciones N&#xBA;s. 337 de 19 de agosto de 1985 y 643 de 03 de agosto de 1987, todas de esta Secretar&#xED;a Regional.-</div><br></div>", "i": 6281003}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6281004}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1001 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1001 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-12-14", "doble_articulado": false, "id_norma": "170578", "numero_fuente": "32967", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-01-12", "vigencias": [{"desde": "1988-01-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-01-12", "fin_vigencia": ""}, "vigencias_version_norma":