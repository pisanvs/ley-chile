{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6528804}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.507, de 19 de mayo de 2005, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 2.584 de 2000 de esta Subsecretar&#xED;a, que autoriz&#xF3; a COMPA&#xD1;IA PESQUERA CAMANCHACA S.A., para sustituir 5 naves por la nave &quot;Atacama III&quot;, en el sentido de actualizar las siguientes caracter&#xED;sticas n&#xE1;uticas de la nave:</div><br><div class=\"p\">Eslora de arqueo&nbsp; &nbsp;  34.74 m.</div><div class=\"p\">TRG (Nacional)&nbsp; &nbsp; &nbsp;  244.79</div><div class=\"p\">Capacidad de bodega&nbsp; 343.49 m3</div><br><br></div>", "i": 6528805}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de mayo de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6528806}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1507 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1507 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-05-19", "fecha_derogacion": "2008-03-29", "doble_articulado": false, "id_norma": "238924", "numero_fuente": "38180", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-06-08", "vigencias": [{"desde": "2008-03-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2005-06-08", "hasta": "2008-03-28", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "v