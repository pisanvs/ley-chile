{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7317252}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.633, de 23 de diciembre de 2004, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 700 de 1995, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Pesquera Friosur S.A., hoy PESQUERA FRIOSUR VIII S.A., para desarrollar actividades pesqueras extractivas con la nave &quot;Friosur VIII&quot;, en el sentido de actualizar e incorporar las siguientes caracter&#xED;sticas n&#xE1;uticas:</div><div class=\"p\"> Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 47,80 m.</div><div class=\"p\">T.R.G. (Internacional)&nbsp; &nbsp; &nbsp; 930,00</div><div class=\"p\">Potencia motor principal&nbsp; &nbsp; 2193,80 HP</div><div class=\"p\">Potencia motor auxiliar&nbsp; &nbsp;  676,30 HP</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp;  537,22 m3</div><br><br></div>", "i": 7317253}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de diciembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7317254}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3633 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3633 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-12-23", "fecha_derogacion": "2020-04-17", "doble_articulado": false, "id_norma": "234141", "numero_fuente": "38049", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_public