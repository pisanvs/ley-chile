{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pension de Gracia a do&#xF1;a Belarmina J. del C. Herrera Lei n&#xFA;m. 936.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947961}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, a do&#xF1;a Belarmina Josefa del C&#xE1;rmen Herrera, ex-cantinera del Ej&#xE9;rcito espedicionario al Per&#xFA; i Bolivia, una pension vitalicia de quince pesos mensuales</div><br><br></div>", "i": 5947962}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 24 de Agosto de 1897.- FEDERICO ERRAZURIZ.- C&#xE1;rlos A. Palacios Z.</div><br></div>", "i": 5947963}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "936", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-936"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION DE GRACIA A DOÑA BELARMINA J. DEL C. HERRERA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BELARMINA JOSEFA DEL CARMEN HERRERA", "PENSION GRACIA", "PERU", "BOLIVIA", "GUERRA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-08-24", "doble_articulado": false, "id_norma": "22283", "numero_fuente": "5793", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1897-08-31", "vigencias": [{"desde": "1897-08-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1897-08-31", "fin_vigencia": ""}, "vigencias_ver