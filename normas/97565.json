{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8328919}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;21, de fecha 24 de febrero de 1998, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se ha rechazado el recurso de reclamaci&#xF3;n interpuesto por Pacific Fisheries S.A., Rut:</div><div class=\"p\">96.543.140-3 y confirmada la resoluci&#xF3;n N&#xBA;1.581, de 1997 de la Subsecretar&#xED;a de Pesca que declar&#xF3; la caducidad de las resoluciones N&#xBA;166 de 1990 y N&#xBA;599 de 1995, ambas de esa Subsecretar&#xED;a, que autorizaron la operaci&#xF3;n de cuatro naves en construcci&#xF3;n a dicha sociedad.- </div></div>", "i": 8328920}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Oscar Landerretche Gacit&#xFA;a, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8328921}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "21 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-21 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECURSO DE RECLAMACION", "PACIFIC FISHERIES S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-02-24", "doble_articulado": false, "id_norma": "97565", "numero_fuente": "36013", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-03-12", "vigencias": [{"desde": "1998-03-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-03-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998