{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6458352}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.364, de 16 de diciembre de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a INVERSIONES ERRAZURIZ LIMITADA para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Janequeo N&#xBA; 160, Chonchi, X Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de cocido, fresco-enfriado y fresco-refrigerado, congelado y seco-salado, los recursos hidrobiol&#xF3;gico individualizados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6458353}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de diciembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6458354}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3364 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3364 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-12-16", "fecha_derogacion": "2004-06-29", "doble_articulado": false, "id_norma": "219977", "numero_fuente": "37756", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-01-10", "vigencias": [{"desde": "2004-06-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-01-10", "hasta": "2004-06-28", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2004-06-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vi