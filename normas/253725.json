{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6584517}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 641, de fecha 31 de julio de 2006, se expropi&#xF3; el lote de terreno N&#xBA; 132, superficie 357,04m2., rol en tr&#xE1;mite, comuna de Salamanca, para la obra &quot;Mejoramiento Ruta D-825, Limahuida - Almendrillo, sector Tahuinco - Salamanca, Km. 13,14000 a Km.</div><div class=\"p\">23,49783, III Etapa&quot;, IV Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Reinaldo Enrique Hidalgo Brice&#xF1;o, ascendente a la cantidad de $9.468.448. </div></div>", "i": 6584518}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6584519}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "641", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-641"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-31", "doble_articulado": false, "id_norma": "253725", "numero_fuente": "38578", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-10-02", "vigencias": [{"desde": "2006-10-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-10-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-10-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2006-10-02", "fecha_version": "2006-10-02", "fecha_actualizacion_texto": "2006-10-02", "tipo_tratad