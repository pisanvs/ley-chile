{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9268569}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En conformidad a los <a href=\"https://www.leychile.cl/Navegar?idNorma=9583&amp;idParte=0&amp;idVersion=\">decretos supremos Nos 121, de 1967</a>, y <a href=\"https://www.leychile.cl/Navegar?idNorma=230618&amp;idParte=0&amp;idVersion=\">808, de 1969 (V. y U.)</a>, f&#xED;janse los siguientes valores, por el per&#xED;odo que se indica:</div><br><div class=\"p\">a)&nbsp;  Valor Oficial de la Cuota de Ahorro en $1.185,79 (un mil ciento ochenta y cinco pesos y setenta y nueve centavos).</div><div class=\"p\">&nbsp; &nbsp;  Per&#xED;odo de vigencia: 11 de julio de 2012 al 10 de julio de 2013.</div><br><div class=\"p\">b)&nbsp;  Valor Provisional de la Cuota de Ahorro en $1.185,79 (un mil ciento ochenta y cinco pesos y setenta y nueve centavos).</div><div class=\"p\">&nbsp; &nbsp;  Per&#xED;odo de vigencia: 11 de julio de 2012 al 10 de agosto de 2012.</div><br><div class=\"p\">c)&nbsp;  Valor Provisional de la Unidad Reajustable en $162,57 (ciento sesenta y dos pesos y cincuenta y siete centavos).</div><div class=\"p\">&nbsp; &nbsp;  Per&#xED;odo de vigencia: 1 de julio de 2012 al 31 de julio de 2012.</div></div>", "i": 9268570}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "Aviso-S/N"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SUBSECRETARÍA DE VIVIENDA Y URBANISMO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN FECHA DE PROMULGACIÓN; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1041234", "numero_fuente": "4