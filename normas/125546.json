{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  EXTRACTO DE RESOLUCION No. 1.992, DE 1988 </div></div>", "i": 6134023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.992 de 11 de Noviembre de 1988, de este Servicio Nacional, se revoc&#xF3; la autorizaci&#xF3;n otorgada a la sociedad Brito y Dalmazzo Limitada o Instituto Superior de Capacitaci&#xF3;n Valpara&#xED;so Limitada, para actuar como organismo t&#xE9;cnico de ejecuci&#xF3;n al amparo del decreto ley 1.446, de 1976, y su Reglamento. Santiago, 18 de Noviembre de 1988.</div><br></div>", "i": 6134024}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Wilfredo Y&#xE1;&#xF1;ez Gonz&#xE1;lez, Jefe Depto. Administrativo y Secretar&#xED;a General Subrogante.</div><br></div>", "i": 6134025}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1992", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1992"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCION No. 1.992, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-11-11", "doble_articulado": false, "id_norma": "125546", "numero_fuente": "33234", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-11-30", "vigencias": [{"desde": "1988-11-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-11-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-11-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "19