{"html": [{"t": "<div><br><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A COMERCIAL SANTA FILOMENA LIMITADA</div><br></div>", "i": 9152585}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del SII, por resoluci&#xF3;n DRE. 08 Ex. N&#xBA; 5.244, de fecha 27/05/2011, otorga a Comercial Santa Filomena Limitada, RUT N&#xBA; 77.120.370-1, a partir del d&#xED;a 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las adquisiciones de productos de madera, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 17 de la resoluci&#xF3;n Ex. N&#xBA; 4.916, del 31.10.2000, de la Direcci&#xF3;n Nacional.- </div><br></div>", "i": 9152586}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Flores Guti&#xE9;rrez, Director Regional.</div></div>", "i": 9152587}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5244 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5244 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A COMERCIAL SANTA FILOMENA LIMITADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-05-27", "doble_articulado": false, "id_norma": "1026832", "numero_fuente": "39994", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-06-24", "vigencias": [{"desde": "2011-06-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-06-24", "fin_vigenci