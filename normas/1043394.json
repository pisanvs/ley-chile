{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9292966}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xBA;1440 de 31 de julio de 2012, de conformidad lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;21, superficie 215,72 m2, rol de Aval&#xFA;o N&#xBA;429-39, comuna de Ancud, para la obra &quot;AMPLIACI&#xD3;N REPOSICI&#xD3;N RUTA 5 CHILO&#xC9;, SECTOR BIF. PUENTE BICENTENARIO &#x2013; BIF. PUPELDE TRAMO 8 VARIANTE ANCUD X REGI&#xD3;N&quot;. La Comisi&#xF3;n de peritos, integrada por SONIA CATALINA GALLEGOS BLANCH, PATRICIO FERNANDO CASAGRANDE ULLOA Y NORMAN ESTANISLAO CALDER&#xD3;N PONTIGGIA, fij&#xF3; el valor de tasaci&#xF3;n con fecha 8 de septiembre de 2008, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario JOS&#xC9; MOIS&#xC9;S GARC&#xCD;A BARR&#xCD;A, en la cantidad de $25.155.654.-, suma que se pagar&#xE1; al contado. </div></div>", "i": 9292967}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9292968}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1440 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1440 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-31", "doble_articulado": false, "id_norma": "1043394", "numero_fuente": "40352", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-09-01", "vigencias": [{"desde": "2012-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"