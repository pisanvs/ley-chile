{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza a la Municipalidad de Rancagua para cambiar el nombre de las calles Peilla e Independencia.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8277431}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Autor&#xED;zase a la Municipalidad de Rancagua para cambiar el nombre de las calles &quot;Peilla&quot; e &quot;Independencia&quot;, desde la Plaza de los H&#xE9;roes al Oriente, de esa ciudad, por los de &quot;Jos&#xE9; Victorino Lastarria&quot; y &quot;Germ&#xE1;n Riesco&quot;, respectivamente. </div></div>", "i": 8277432}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veinticuatro de Julio de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- Guillermo Edwards Matte. </div></div>", "i": 8277433}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4353", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4353"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA A LA MUNICIPALIDAD DE RANCAGUA PARA CAMBIAR EL NOMBRE DE LAS CALLES PEILLA E INDEPENDENCIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RANCAGUA", "CALLES", "DENOMINACION", "CALLE PEILLA", "CALLE", "INDEPENDENCIA", "CALLE JOSE VICTORINO LASTARRIA", "CALLE", "GERMAN RIESCO", "MUNICIPALIDAD", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-07-24", "doble_articulado": false, "id_norma": "24681", "numero_fuente": "15133", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-07-26", "vigencias": [{"desde": "1928-07-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-07-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1928-07-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-03-09", "fecha_version": "1928-07-26", "fecha_actualizacion_texto": "1928-07-26", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8277431}, {"n": "Artículo UNICO", "i": 8277432, "t": 6}, {"n": "Promulgación", "i": 8277433}]}