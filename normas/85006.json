{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 28, DE 1990 </div></div>", "i": 6069338}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 28, de 19 de enero de 1990, se ha aprobado a contar del a&#xF1;o escolar 1990, a la Escuela F No. 349 de Coihueco, comuna de Lautaro provincia de Caut&#xED;n, IX Regi&#xF3;n de La Araucania, un plan especial de estudio para el 2&#xB0; ciclo de Educaci&#xF3;n General B&#xE1;sica, el que se aplicar&#xE1; en todos los cursos indicados simult&#xE1;neamente. Adem&#xE1;s, se aprueban programas de estudio para los cursos de 5&#xB0;, 6&#xB0;, 7&#xB0; y 8&#xB0; a&#xF1;o con sus objetivos correspondientes.-</div><br></div>", "i": 6069339}, {"t": "<div><div class=\"p\">Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6069340}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "28 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-28 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO\nEXENTO No. 28, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-19", "doble_articulado": false, "id_norma": "85006", "numero_fuente": "33604", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-23", "vigencias": [{"desde": "1990-02-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-23", "fin_vigencia": "", "tipo_version": "3"}], "e