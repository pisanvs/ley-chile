{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8319417}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 117, de 23 de enero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de las resoluciones N&#xBA; 1.114, N&#xBA; 1.115 y N&#xBA; 1.116, todas de 1994, de esta Subsecretar&#xED;a, que autorizaron a PESQUERA SANTA LUCIA S.A., para ampliar actividades pesqueras extractivas, con las naves &quot;Marleen&quot;, &quot;Orka&quot; y &quot;Walvis&quot;, por no haber iniciado operaciones dentro del plazo autorizado, esto es, antes del 29 de diciembre de 1996, verific&#xE1;ndose la causal de caducidad prevista en el art&#xED;culo 143 letra b), de la Ley N&#xBA; 18.892 y sus modificaciones.</div><br></div>", "i": 8319418}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de enero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8319419}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "117", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-117"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA SANTA LUCIA S.A.", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-01-23", "doble_articulado": false, "id_norma": "90338", "numero_fuente": "35981", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-02-03", "vigencias": [{"desde": "1998-02-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vi