{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 383 EXENTA, DE 15 DE ENERO DE 2020</div></div>", "i": 10109512}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por la presente, se ha modificado, a contar del a&#xF1;o escolar 2020, la <a href=\"https://www.leychile.cl/Navegar?idNorma=1103959&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 2.066, de 2017</a>, del Ministerio de Educaci&#xF3;n, que aprob&#xF3; planes y programas especiales de estudio de 3&#xB0; y 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media, al establecimiento educacional The Mackay School, RBD 1788-4, comuna de Vi&#xF1;a del Mar, Regi&#xF3;n de Valpara&#xED;so, en el sentido de sustituir el plan de estudio de 3&#xB0; a&#xF1;o de Educaci&#xF3;n Media.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10109513}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Figueroa Salas, Subsecretario de Educaci&#xF3;n.</div><div class=\"p\"> </div><br></div>", "i": 10109514}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "383 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-383 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 383 EXENTA, DE 15 DE ENERO DE 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1740946; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-01-15", "doble_articulado": false, "id_norma": "1143602", "numero_fuente": "42608", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-03-19", "vigencias": [{"desde": "2020-03-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vig