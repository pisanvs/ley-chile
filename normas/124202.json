{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6129970}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1129 de 14.11.88 de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n conforme DL 2186 de 1987, parte inmueble ubicado en calles San Pablo No. 5201 y Sergio Valdovinos N&#xB0;s 1106 y 1110, presunto rol aval&#xFA;os No.</div><div class=\"p\">11.637-1 comuna Lo Prado aparentemente dominio de don Clotario Garc&#xED;a y otros. Comisi&#xF3;n integrada por peritos Roberto Correa Bezanilla y Eduardo Su&#xE1;rez Su&#xE1;rez, arquitectos y Pablo Risopatr&#xF3;n Garmendia, ingeniero civil, seg&#xFA;n informe de 25 de julio de 1988, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 7.825.500, pagadera al contado. </div></div>", "i": 6129971}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director SERVIU Metropolitano.</div><br></div>", "i": 6129972}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1129", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1129"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN REGIÓN METROPOLITANA"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-11-14", "doble_articulado": false, "id_norma": "124202", "numero_fuente": "33235", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-12-01", "vigencias": [{"desde": "1988-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-12-01", "fin_vigencia": ""}, "vigencias