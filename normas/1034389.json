{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9217570}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;4543, de 30 de noviembre de 2011, se complementa el numeral tercero del <a href=\"https://www.leychile.cl/Navegar?idNorma=1029784&amp;idParte=0&amp;idVersion=\">Decreto Exento MOP. N&#xBA;1839, de 25 de agosto de 2011</a>, en el sentido que con fecha 8 de septiembre de 2008 la comisi&#xF3;n de peritos fijo el monto de la indemnizaci&#xF3;n provisional en la cantidad de $194.226.000.-, la cual fue complementada por acta de fecha 15 de julio de 2009, en la cantidad de $5.906.500.-. Cons&#xED;gnese judicialmente el monto complementario. </div><br></div>", "i": 9217571}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9217572}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "4543 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-4543 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-11-30", "doble_articulado": false, "id_norma": "1034389", "numero_fuente": "40135", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-12-15", "vigencias": [{"desde": "2011-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-12-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "conco