{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6437689}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA;730 de fecha 31 de julio de 2003, se expropi&#xF3; el lote de terreno N&#xBA;48-E, superficie 781,2 m&#xB2;, rol en tr&#xE1;mite, comuna de Linares, VII Regi&#xF3;n, para la obra &quot;Camino Ruta L-45, Sector: Linares-Llepo, Tramo: Km. 2,750.2 a Km. 13,147&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Ra&#xFA;l Antonio Bravo V&#xE1;squez, ascendente a la cantidad de $979.807.</div><br></div>", "i": 6437690}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6437691}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "730 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-730 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-07-31", "doble_articulado": false, "id_norma": "214192", "numero_fuente": "37649", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-01", "vigencias": [{"desde": "2003-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2003-09-01", "fecha_version": "2003-09-01", "fecha_actualizacion_texto": "2003-09-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "