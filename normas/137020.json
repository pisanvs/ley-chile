{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,243.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170632}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.-&nbsp; En atencion a los importantes i dilatados servicios prestados al pais por el se&#xF1;or doctor don Adolfo Valderrama, as&#xED;gnase a su viuda, la se&#xF1;ora Felipa T&#xE9;llez v. de Valderrama, una pension anual de dos mil cuatrocientos pesos.</div><br></div>", "i": 6170633}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veinticuatro de enero de mil novecientos diez.-&nbsp; Pedro Montt.-&nbsp; E. Figueroa.</div><br></div>", "i": 6170634}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2243", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2243"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-01-24", "doble_articulado": false, "id_norma": "137020", "numero_fuente": "9614", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-02-11", "vigencias": [{"desde": "1910-02-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-02-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1910-02-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen