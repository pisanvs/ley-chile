{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7268674}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 256 de 4 de Marzo de 1991 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por 6 meses a contar de esta fecha, el plazo otorgado a SALMONES HUILLINCO S.A. R.U.T.</div><div class=\"p\">No. 96.527.250-K, domiciliada en la ciudad de Santiago, en el numeral 5&#xB0; de la resoluci&#xF3;n No. 1.396, de 1989, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 7268675}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de Marzo de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 7268676}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "256", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-256"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-03-04", "doble_articulado": false, "id_norma": "167550", "numero_fuente": "33924", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-03-21", "vigencias": [{"desde": "1991-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-03-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-03-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresad