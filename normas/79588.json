{"html": [{"t": "<div><div class=\"p\">EXTRACTO DECRETO EXPROPIATORIO No. 189-92</div><br><br></div>", "i": 6055269}, {"t": "<div><div class=\"p\">Con fecha, 14 de febrero de 1992, de acuerdo a art&#xED;culo 27 de la Ley No. 18.695, I. Municipalidad de Rancagua expropi&#xF3; franja de terreno de 27,67 m2., ubicado en calle Independencia No. 778 al 780, Rol de aval&#xFA;os No. 68-2, inscrito a fojas 2831 vta. N&#xB0;1718 Registro de Propiedad a&#xF1;o 1987 Conservador de Bienes Ra&#xED;ces de Rancagua, perteneciente Carlos Galilea Alvarez, monto previsional $ 839.342., compensa derechos edificaci&#xF3;n ascendentes a $ 551.494., saldo favor Galilea Alvarez $ 287.848., pago contado.- </div></div>", "i": 6055270}, {"t": "<div><div class=\"p\">Secretario Municipal (s) </div></div>", "i": 6055271}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "189", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-189"}, {"tipo": "2", "numero": "189-92", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-189-92"}], "organismos": ["MUNICIPALIDAD DE RANCAGUA"], "titulo_norma": "EXTRACTO DECRETO EXPROPIATORIO No. 189-92", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-02-14", "doble_articulado": false, "id_norma": "79588", "numero_fuente": "34207", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-03-02", "vigencias": [{"desde": "1992-03-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-03-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-03-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes