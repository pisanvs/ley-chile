{"html": [{"t": "<div><div class=\"p\">APRUEBA ORDENANZA SOBRE ENTREGA DE SUBVENCIONES MUNICIPALES </div></div>", "i": 6460448}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La I. Municipalidad de R&#xED;o Hurtado pone en conocimiento de la comunidad que por decreto alcaldicio exento N&#xBA; 13 de fecha 15 de enero de 2004, fue aprobada la Ordenanza del Registro de Personas Jur&#xED;dicas Receptoras de Fondos P&#xFA;blicos.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de la citada ordenanza se informa que est&#xE1; a disposici&#xF3;n de quien lo solicite en el Departamento de Administraci&#xF3;n y Finanzas, Edificio Consistorial de R&#xED;o Hurtado, calle &#xFA;nica, localidad de Samo Alto.</div><br></div>", "i": 6460449}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jaime Gary Valenzuela Rojas, Alcalde.</div><br></div>", "i": 6460450}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "13 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-13 EXENTO"}], "organismos": ["MUNICIPALIDAD DE RÍO HURTADO"], "titulo_norma": "APRUEBA ORDENANZA SOBRE ENTREGA DE SUBVENCIONES\nMUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-15", "doble_articulado": false, "id_norma": "220382", "numero_fuente": "37766", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-01-22", "vigencias": [{"desde": "2004-01-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-01-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-01-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "in