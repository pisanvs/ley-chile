{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xB0; 730, DE 1985</div><br><br></div>", "i": 7262289}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xB0; 50, de 14 de Enero de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modifica la Resoluci&#xF3;n N&#xB0; 730, de 06 de Noviembre de 1985, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a Sociedad Pesquera Eicomar Limitada para operar una planta elaboradora de recursos hidrobiol&#xF3;gicos en Chinquihue, en orden a incluir en el numeral 3&#xB0;, entre los recursos hidrobiol&#xF3;gicos que dicha sociedad puede utilizar como materia prima en la planta se&#xF1;alada, los siguientes: loco y erizo.</div><br></div>", "i": 7262290}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de Enero de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7262291}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "50", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-50"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION N° 730, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-01-14", "doble_articulado": false, "id_norma": "157341", "numero_fuente": "32376", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-01-20", "vigencias": [{"desde": "1986-01-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-01-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia