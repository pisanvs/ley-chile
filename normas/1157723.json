{"html": [{"t": "<div><div class=\"p\">BLANQUEO DE LAS CASAS.</div></div>", "i": 10229404}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  D. Santiago Echevers teniente asesor letrado de la intendencia jeneral y Gobernador interino por ausencia del se&#xF1;or propietario.- Estando decidido en junta de M&#xE9;dicos, que el primer ant&#xED;doto contra el mal conocido bajo el nombre de erispela negra que ya va haciendose epid&#xE9;mico, es la cal, todos los vecinos de esta corte en el t&#xE9;rmino perentorio de ocho dias blanquearan el exterior de sus casas bajo la multa de doce pesos, por cuanto asi lo tengo ordenado por decreto de esta fecha.</div></div>", "i": 10229405}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, Mayo 27 de 1823.- Santiago Echevers.</div></div>", "i": 10229406}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["INTENDENCIA DE SANTIAGO"], "titulo_norma": "BLANQUEO DE LAS CASAS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-05-27", "doble_articulado": false, "id_norma": "1157723", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-05-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-05-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-05-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2021-05-25", "fecha_version": "1823-05-27", "fecha_actualizacion_texto": "1823