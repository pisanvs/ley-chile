{"html": [{"t": "<div><br><div class=\"p\">POL&#xCD;TICA CONTRA LA DISCRIMINACI&#xD3;N</div><br></div>", "i": 9324924}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de circular del Servicio de Impuestos Internos N&#xBA; 59, del 31 de diciembre de 2012, que establece:</div><div class=\"p\">&nbsp; &nbsp;  Pol&#xED;tica contra la Discriminaci&#xF3;n, que entrega lineamientos de actuaci&#xF3;n para todos los funcionarios del Servicio de Impuestos Internos, en el marco de las estipulaciones de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1042092&amp;idParte=0&amp;idVersion=\">ley N&#xBA; 20.609</a>, que establece medidas contra la discriminaci&#xF3;n arbitraria.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta circular est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de diciembre de 2012.</div></div>", "i": 9324925}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "59", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-59"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "POLÍTICA CONTRA LA DISCRIMINACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-12-31", "doble_articulado": false, "id_norma": "1047832", "numero_fuente": "40451", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-01-05", "vigencias": [{"desde": "2013-01-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-01-05", "fin