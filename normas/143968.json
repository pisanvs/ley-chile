{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xBA; 215, DE 1981</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 251.- Santiago, 11 de agosto de 1999.- Vistos: Lo dispuesto en el Art. 11 del decreto ley N&#xBA; 2.974, de 1979.</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br><br><br></div>", "i": 6192783}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case la resoluci&#xF3;n N&#xBA; 215, de 4.11.81, que design&#xF3; Receptores Judiciales y Ministros de Fe en la forma que se indica:</div><br><div class=\"p\">Se elimina al se&#xF1;or:</div><div class=\"p\">Pedro Segundo Silva Silva </div></div>", "i": 6192784}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Luis Marambio Canales, Director Nacional.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Encargado Oficina de Partes.</div><br></div>", "i": 6192785}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "251", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-251"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCION Nº 215, DE 1981", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-08-11", "doble_articulado": false, "id_norma": "143968", "numero_fuente": "36471", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-23", "vigencias": [{"desde": "1999-09-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-23", "fin_vigencia": "