{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,474.- Santiago, 12 de setiembre de 1901.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6163514}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- El&#xE9;vase, por gracia, a cincuenta pesos la pension mensual de que actualmente disfruta el soldado Francisco Gonz&#xE1;lez, que hizo la campa&#xF1;a de la Restauracion al Per&#xFA; en los a&#xF1;os 1838 i 39.</div><br></div>", "i": 6163515}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- ANIBAL ZA&#xD1;ARTU.-</div><div class=\"p\">W. B&#xFA;lnes.</div><br></div>", "i": 6163516}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1474", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1474"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-09-12", "doble_articulado": false, "id_norma": "134812", "numero_fuente": "7000", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-09-13", "vigencias": [{"desde": "1901-09-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1901-09-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1901-09-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-04-13", "fecha_vers