{"html": [{"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">NOTIFICACIONES</div></div>", "i": 9400073}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Res. Ex. N&#xBA; 326 de 20/03/13: Vistos: Acta de Denuncia y Citaci&#xF3;n N&#xBA; 14510 de 04/03/13, cursada a Armando Choque Vargas, C.l. N&#xBA; 6033552, nacionalidad boliviano, domicilio desconocido, que indica: portar 0,8 Kg. de durazno, sin declararlo. Considerando: 1.- Que se ha infringido el decreto ley N&#xBA; 3.557; 2.- Declaraci&#xF3;n del denunciado, quien reconoce los hechos, pero que al ser extranjero no conoc&#xED;a de la normativa infringida; 3.- El informe de la Encargada Regional de Controles Fronterizos quien pondera los hechos. Resuelvo. 1.- Absu&#xE9;lvase de los cargos. </div></div>", "i": 9400074}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Firma: Andr&#xE9;s Puiggros Vogel, Director SAG, Regi&#xF3;n de Arica y Parinacota.</div></div>", "i": 9400075}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "326 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-326 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO XV REGIÓN DE ARICA Y PARINACOTA"], "titulo_norma": "NOTIFICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-03-20", "doble_articulado": false, "id_norma": "1058273", "numero_fuente": "40757", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-01-15", "vigencias": [{"desde": "2014-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic