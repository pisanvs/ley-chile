{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9163617}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.047, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1021817&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.944, de 2010</a>, modificada mediante resoluci&#xF3;n exenta N&#xBA; 648, N&#xBA; 789, N&#xBA; 1.351, N&#xBA; 2.038, todas de 2011, de esta Subsecretar&#xED;a de Pesca, que estableci&#xF3; la distribuci&#xF3;n de la fracci&#xF3;n artesanal de Merluza com&#xFA;n de la IV, V, VI, VII y VIII Regiones por &#xC1;reas, en el sentido que a continuaci&#xF3;n se indica:</div><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/19902.jpg\"></div><br></div>", "i": 9163618}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de julio de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9163619}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2047 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2047 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-07-29", "doble_articulado": false, "id_norma": "1028405", "numero_fuente": "40028", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-08-05", "vigencias": [{"desde": "2011-08-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-08-05", "fin_