{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A MAURICIO BARRIOS LIMITADA</div><br><br></div>", "i": 6468610}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La VI Direcci&#xF3;n Regional Rancagua del Servicio de Impuestos Internos, por resoluci&#xF3;n Ex. N&#xBA; 61, de fecha 19 de febrero de 2004, otorga la calidad de &apos;&apos;Agente Retenedor de IVA en la actividad de la construcci&#xF3;n&apos;&apos;, a Mauricio Barrios Limitada, RUT N&#xBA; 77.605.980-3.</div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n que entrar&#xE1; en vigencia a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n de acuerdo a lo establecido por la resoluci&#xF3;n Ex. N&#xBA; 46 del 1 septiembre del 2003, de la Direcci&#xF3;n Nacional.-</div><br></div>", "i": 6468611}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Aguilar Z&#xFA;&#xF1;iga, Director Regional (S). </div></div>", "i": 6468612}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "61 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-61 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VI DIRECCIÓN REGIONAL DE RANCAGUA"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A MAURICIO BARRIOS LIMITADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-19", "doble_articulado": false, "id_norma": "222350", "numero_fuente": "37809", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-12", "vigencias": [{"desde": "2004-03-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-03-12", "fin_vige