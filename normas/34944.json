{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292747}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 486, de 15 de marzo de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la</div><div class=\"p\">Resoluci&#xF3;n N&#xB0; 1.053, de 1988, de esta Subsecretar&#xED;a, que</div><div class=\"p\">autoriz&#xF3; a don BRANCO VALCIC VALCIC, para iniciar</div><div class=\"p\">actividades pesqueras extractivas con la nave &quot;Armi&#xF1;o&quot;,</div><div class=\"p\">por haberse configurado la causal prevista en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley N&#xB0; 18.892 y sus modificaciones.</div><br></div>", "i": 8292748}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 15 de marzo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292749}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "486", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-486"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BRANCO VALCIC VALCIC", "CADUCIDAD", "AUTORIZACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-03-15", "doble_articulado": false, "id_norma": "34944", "numero_fuente": "35424", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-03-22", "vigencias": [{"desde": "1996-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-03-22", "fin_vigencia": ""},