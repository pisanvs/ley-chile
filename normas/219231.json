{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 923 EXENTO, DE 2003 </div></div>", "i": 6455313}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 923 de fecha 17 de noviembre de 2003, de Educaci&#xF3;n, se declara aprobada a la Universidad de Puerto Varas la siguiente carrera y grado acad&#xE9;mico que se indica:</div><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  : Ingenier&#xED;a en Acuicultura.</div><div class=\"p\">Grado Acad&#xE9;mico&nbsp;  : Licenciado en Ciencias de la</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Acuicultura.</div><div class=\"p\">Titulo Profesional: Ingeniero en Acuicultura.</div><br><div class=\"p\">&nbsp; &nbsp;  Dicha carrera podr&#xE1; ser impartida en jornada diurna en su Sede de la ciudad de Puerto Varas, a contar del primer semestre del a&#xF1;o 2004.</div><br></div>", "i": 6455314}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 2 de diciembre de 2003.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6455315}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "923 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-923 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 923 EXENTO, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-17", "doble_articulado": false, "id_norma": "219231", "numero_fuente": "37740", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-20", "vigencias": [{"desde": "2003-12-20", "hasta": "", "tipo_version": "3", "tipo_ve