{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.048 EXENTA, DE 2007 </div></div>", "i": 7345808}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 1.048, de 22 de enero de 2007, se han modificado, a partir del a&#xF1;o escolar 2007, las resoluciones exentas de Educaci&#xF3;n N&#xBA;s.</div><div class=\"p\">4.085 y 8.038, ambas de 1999, que aprobaron planes y programas de estudio para 1&#xBA; y 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media al Colegio &quot;Santiago College&quot;, comuna de Providencia, de Santiago, en el sentido de sustituir el plan de estudio para 1&#xBA; y 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media, por el que se indica en la presente resoluci&#xF3;n.</div><br></div>", "i": 7345809}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jaime Veas S&#xE1;nchez, Jefe Divisi&#xF3;n de Educaci&#xF3;n General (S).</div><br></div>", "i": 7345810}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1048 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1048 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.048 EXENTA, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-01-22", "doble_articulado": false, "id_norma": "261974", "numero_fuente": "38793", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-06-20", "vigencias": [{"desde": "2007-06-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-06-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-06-20", "fin_vigencia": "", "tipo