{"html": [{"t": "<div><br><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA</div></div>", "i": 9650364}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional de Temuco del SII, por resoluci&#xF3;n Ex. N&#xBA; 1.122 de fecha 17 de noviembre de 2015, deja sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=120657&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n Ex. N&#xBA; 212 de fecha 22.07.1998</a>, que otorga la calidad de agente retenedor de cambio de sujeto de derecho del Impuesto al Valor Agregado en las operaciones de venta de ganado vivo, a contar de la fecha de esta publicaci&#xF3;n, al contribuyente Leonardo Garc&#xED;a Sabugal, RUT N&#xBA; 2.143.028-5, conforme a lo establecido en la res. Ex. N&#xBA; 3.721, de fecha 28.07.2000, de la Direcci&#xF3;n Nacional del Servicio, publicada en el Diario Oficial del d&#xED;a 01.08.2000.</div><br></div>", "i": 9650365, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lidia Castillo Alarc&#xF3;n, Directora Regional.</div></div>", "i": 9650366}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1122 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1122 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 968266", "EXTRACTO", "La fecha de promulgación norma modificada es 22.06.1998 y no 22.07.1998"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-11-17", "doble_articulado": false, "id_norma": "1084172", "numero_fuente": "41312