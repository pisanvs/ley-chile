{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6294678}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.662, de 27 de julio de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la resoluci&#xF3;n N&#xBA; 99 de 1990, de esta Subsecretar&#xED;a, en cuanto autoriz&#xF3; a don SERGIO TORO SOTO, para operar la nave &apos;&apos;Do&#xF1;a Olivia&apos;&apos;, por haber suspendido actividades por m&#xE1;s de 12 meses sucesivos y encontrarse en mora del pago de la patente &#xFA;nica pesquera, configur&#xE1;ndose las causales previstas en las letras b) y d) del art&#xED;culo 143 del DS N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6294679}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de julio de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6294680}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1662", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1662"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-07-27", "doble_articulado": false, "id_norma": "173743", "numero_fuente": "36729", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-02", "vigencias": [{"desde": "2000-08-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-08-02", "fin_vigencia": "", "tipo_