{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N.o 7,367, QUE AUTORIZA CONMEMORAR EL 1.er CENTENARIO DE LA MUERTE DE DON BERNARDO O&apos;HIGGINS.</div><div class=\"p\">&nbsp; &nbsp; El Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5965584}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.o Substit&#xFA;yese en el inciso tercero del art&#xED;culo 7.o de la Ley N.o 7,367, de 20 de Noviembre de 1942, la fecha 1.o de Julio de 1944, por esta otra: &quot;30 de Junio de 1945&quot;.</div><br></div>", "i": 5965585, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2.o La presente ley regir&#xE1; desde el 1.o de Julio de 1944.</div><br></div>", "i": 5965586}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 4 de Enero de 1945.- J. A. RIOS M.- E. L. Marshall.</div><br></div>", "i": 5965587}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "8054", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-8054"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "MODIFICA LA LEY N.o 7,367, QUE AUTORIZA CONMEMORAR\nEL 1.er CENTENARIO DE LA MUERTE DE DON BERNARDO\nO'HIGGINS.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BERNARDO O'HIGGINS", "PRIMER CENTENARIO", "MUERTE", "CONMEMORACION", "ESCRITORES CHILENOS", "BIOGRAFIA", "CONCURSO", "PLAZO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1945-01-04", "doble_articulado": false, "id_norma"