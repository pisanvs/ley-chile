{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8333160}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.140 de 6 de agosto de 1998, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.064 de 1992, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don MARIO GAJARDO VENEGAS, para desarrollar actividades pesqueras con la nave Noel I, respecto de las siguientes &#xE1;reas y especies:</div><br><div class=\"p\">a)&nbsp;  Litoral de las regiones III y IV respecto de: Palometa, Dorado, Lisa y Machuelo.</div><div class=\"p\">b)&nbsp;  Litoral de las regiones II y III respecto de: Cabrilla, Cabrilla Com&#xFA;n, Chancharro, Merluza com&#xFA;n, Pejegallo y Tollo con espinel.</div><br></div>", "i": 8333161}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de agosto de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8333162}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1140", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1140"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "REGISTRO ARTESANAL", "INSCRIPCION", "JUREL", "SUSPENSION", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-06", "doble_articulado": false, "id_norma": "123015", "numero_fuente": "36140", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-08-14", "vigencias": [{"desde": "1998-08-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-08-14",