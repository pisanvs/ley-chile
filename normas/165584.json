{"html": [{"t": "<div><div class=\"p\">MODIFICA LA RESOLUCION No. 575, DE 1984 </div></div>", "i": 7267629}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 834, de 13 de Diciembre de 1985 de la Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n 575, de 1084, de la Subsecretaria de Pesca, que autoriz&#xF3; a Pesquera Manquehue Sociedad An&#xF3;nima, para operar las embarcaciones denominadas &quot;Llaima&quot; y &quot;Sotavento&quot;, en orden a incluir en el numeral 5&#xB0;, entre las especies que la sociedad puede extraer con dichas embarcaciones el recurso bonito, que deber&#xE1; destinar a su industrializaci&#xF3;n para consumo humano directo. La embarcaci&#xF3;n deber&#xE1; contar a bordo, con sistemas adecuados de preservaci&#xF3;n de la materia prima. </div></div>", "i": 7267630}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de Diciembre de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7267631}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "834", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-834"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA LA RESOLUCION No. 575, DE 1984", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-13", "doble_articulado": false, "id_norma": "165584", "numero_fuente": "32352", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-20", "vigencias": [{"desde": "1985-12-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], 