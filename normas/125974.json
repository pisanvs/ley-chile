{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CERTIFICADO</div><br></div>", "i": 6135222}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 dias, fue de 4.71 % anual durante el mes de noviembre de 1988.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad a lo dispuesto en el No. 5 del Capitulo IV.B.8.1 del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quineenal de captaci&#xF3;n para operaciones reajustables de 90 a 365 dias, correspondiente a la segunda quincena de noviembre de 1988, fue de 4.66% anual.</div><br></div>", "i": 6135223}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 05.12.88.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6135224}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-05", "doble_articulado": false, "id_norma": "125974", "numero_fuente": "33239", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-12-06", "vigencias": [{"desde": "1988-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-12-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-12-06", "fin_vigencia": "", "tipo_version": "