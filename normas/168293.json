{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 2.557, DE 1987 </div></div>", "i": 6274211}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 2.557, de fecha 05 de noviembre de 1987, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se autoriz&#xF3; a las siguientes sedes del Centro de Formaci&#xF3;n T&#xE9;cnica &quot;Instituto AIEP&quot;, para impartir planes y programas de estudios aprobados para la instituci&#xF3;n de las carreras y t&#xED;tulos t&#xE9;cnicos que se se&#xF1;alan:</div><br><div class=\"p\">- Sede No. 3 - Vi&#xF1;a del Mar Carrera: Auxiliar de Arquitectura.</div><div class=\"p\">T&#xED;tulo: Auxiliar de Arquitecto.</div><div class=\"p\">- Sede No. 6 - San Fernando Carrera: Administraci&#xF3;n de Empresas.</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico en Administraci&#xF3;n de Empresas. </div></div>", "i": 6274212}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6274213}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2557 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2557 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 2.557, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-05", "doble_articulado": false, "id_norma": "168293", "numero_fuente": "32958", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-31", "vigencias": [{"desde": "1987-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}],