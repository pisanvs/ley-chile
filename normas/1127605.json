{"html": [{"t": "<div><div class=\"p\">DECLARA NO APTAS PLAYAS DE LA CAPITAN&#xCD;A DE PUERTO DE SAN VICENTE</div></div>", "i": 9987173}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n C.P. San Vicente Ord. N&#xBA; 12000/350, de fecha 28 de diciembre de 2018, declara playas aptas y no aptas para el ba&#xF1;o las playas emplazadas en la jurisdicci&#xF3;n de la Capitan&#xED;a de Puerto de San Vicente, por el per&#xED;odo estival 2018/2019.</div><br><div class=\"p\">&nbsp; &nbsp;  Los textos &#xED;ntegros de estas resoluciones est&#xE1;n publicados en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante www.directemar.cl - usuario mar&#xED;timo - resoluciones locales.</div></div>", "i": 9987174}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Talcahuano, 4 de enero de 2019.- Germ&#xE1;n Llanos Silva, Capit&#xE1;n de Nav&#xED;o LT, Gobernador Mar&#xED;timo de Talcahuano.</div></div>", "i": 9987175}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "350", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-350"}, {"tipo": "3", "numero": "12000/350", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-12000/350"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "DECLARA NO APTAS PLAYAS DE LA CAPITANÍA DE PUERTO DE SAN VICENTE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1527394", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-12-28", "doble_articulado": false, "id_norma": "112760