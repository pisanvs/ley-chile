{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 745 EXENTO, DE 2002 </div></div>", "i": 6395587}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 745 de fecha 21 de agosto de 2002, de Educaci&#xF3;n, se revoca el reconocimiento oficial del Instituto Profesional Zipter organizado por la Sociedad Instituto Profesional Zipter Limitada y elim&#xED;nase a dicha entidad del Registro de Institutos Profesionales en que se encuentra inscrita con el N&#xBA; 53.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, se deroga el decreto exento de Educaci&#xF3;n N&#xBA; 156 del 19 de octubre de 1989, que autoriz&#xF3; el funcionamiento al Instituto Profesional Zipter. </div></div>", "i": 6395588}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 2 de septiembre de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6395589}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "745 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-745 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 745 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-08-21", "doble_articulado": false, "id_norma": "202348", "numero_fuente": "37353", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-09-06", "vigencias": [{"desde": "2002-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-09-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-09-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendien