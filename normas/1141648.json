{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 243, DE 15 ENERO 2020, DE LA DIRECCI&#xD3;N NACIONAL DE ADUANAS, QUE MODIFICA EL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10096190}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 243, de 15 de enero de 2020, del Director Nacional de Aduanas, se elimin&#xF3; al Sr. Pedro Fica Tolosa, Agente de Aduana c&#xF3;digo C-40 del listado contenido en el Anexo 51-3, del Compendio de Normas Aduaneras.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10096191}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de enero de 2020.- Gustavo Poblete Morales, Director Nacional de Aduanas (S).</div><br></div>", "i": 10096192}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "243 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-243 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 243, DE 15 ENERO 2020, DE LA DIRECCIÓN NACIONAL DE ADUANAS, QUE MODIFICA EL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1717499", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-01-15", "doble_articulado": false, "id_norma": "1141648", "numero_fuente": "42564", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-01-28", "vigencias": [{"desde": "2020-01-28", "hasta": "", "tipo_vers