{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCION</div></div>", "i": 8505872}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 229, de 23 de Agosto de 1984, la Subsecretar&#xED;a de Telecomunicaciones estableci&#xF3; las especificaciones t&#xE9;cnicas que regir&#xE1;n la asignaci&#xF3;n de canales y niveles m&#xE1;ximos de radiaci&#xF3;n admisibles en el servicio limitado de televisi&#xF3;n por cable (SLTVC). La Subsecretar&#xED;a de Telecomunicaciones proporcionar&#xE1; ejemplares de la citada resoluci&#xF3;n a los organismos fiscales y semifiscales y a las instituciones o personas particulares que tengan relaci&#xF3;n con la materia de que trata.</div></div>", "i": 8505873}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Italo Seccatore G&#xF3;mez, Teniente Coronel, Subsecretario de Telecomunicaciones.</div></div>", "i": 8505874}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "229 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-229 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TELECOMUNICACIONES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-08-23", "doble_articulado": false, "id_norma": "288639", "numero_fuente": "31988", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1984-10-04", "vigencias": [{"desde": "1984-10-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1984-10-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1984-10-04", "fin_vigencia"