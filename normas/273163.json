{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7373727}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 322, de fecha 30 de abril de 2008, se expropi&#xF3; el lote de terreno N&#xBA; 1, superficie 47.160 m2, rol N&#xBA; 158-247, comuna de Cocham&#xF3;, X Regi&#xF3;n, para la obra &quot;Camino Puelo - Paso El Bols&#xF3;n, sector Llanada Grande - Segundo Corral, tramo R&#xED;o Mapocho - Primer Corral&quot;, Provincia de Llanquihue, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria, Mirta Eliana Delgado Vel&#xE1;squez, ascendente a la cantidad de $17.577.856, para el lote N&#xBA;1.</div><br></div>", "i": 7373728}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 7373729}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "322", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-322"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-04-30", "doble_articulado": false, "id_norma": "273163", "numero_fuente": "39101", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-07-01", "vigencias": [{"desde": "2008-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2008-07-01", "fecha_version": "2008-07-01", "fecha_actualizacion_texto": "2