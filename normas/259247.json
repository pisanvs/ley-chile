{"html": [{"t": "<div><div class=\"p\">INFORMA NUEVA COMPOSICION DE DIRECTIVA CENTRAL DEL PARTIDO HUMANISTA </div></div>", "i": 6604719}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Efr&#xE9;n Osorio Jara, Presidente de la Directiva Central, y Jos&#xE9; Gabriel Feres Nazarala, Presidente del Tribunal Supremo, del Partido Humanista, respectivamente, comunican la nueva composici&#xF3;n de la Directiva Central de dicho partido:</div><div class=\"p\">Directiva Central:</div><br><div class=\"p\">Presidenta&nbsp; &nbsp; &nbsp; &nbsp;  :&nbsp; Maril&#xE9;n Cabrera Olmos.</div><div class=\"p\">Secretaria General :&nbsp; Gloria Susana C&#xF3;rdova Rodr&#xED;guez.</div><div class=\"p\">Tesorero&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  :&nbsp; Juan Enrique Prieto Urz&#xFA;a.</div><br><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada en virtud de lo establecido en el Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por resoluci&#xF3;n O-N&#xBA; 652, de fecha 5 de marzo de 2007.</div><br></div>", "i": 6604720}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director. </div></div>", "i": 6604721}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "652", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-652"}, {"tipo": "3", "numero": "O-652", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-652"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "INFORMA NUEVA COMPOSICION DE DIRECTIVA CENTRAL DEL\nPARTIDO HUMANISTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO HUMANISTA", "DIRECTIVA CENTRAL", "INTEGRANTES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_pro