{"html": [{"t": "<div><div class=\"p\">MODIFICA EL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10274746}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.308, de 30.09.2021, del Director Nacional de Aduanas, del Servicio Nacional de Aduanas, se autoriza la notificaci&#xF3;n de las respuestas a solicitudes de los Agentes de Aduanas, por correo electr&#xF3;nico, cuando as&#xED; haya sido requerido, y que las presentaciones ante la Direcci&#xF3;n Nacional de Aduanas, Direcciones Regionales y Administraciones de Aduanas, puedan efectuarse a los correos electr&#xF3;nicos que se indican.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10274747}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><br></div>", "i": 10274748}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2308 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2308 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA EL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2020688", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-09-30", "doble_articulado": false, "id_norma": "1166122", "numero_fuente": "43071", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-10-06", "vigencias": [{"desde": "2021-10-06", "hasta