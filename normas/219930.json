{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6458151}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.520 de 30 de diciembre de 2003 de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA SURIBERICA S.A., para realizar operaciones pesqueras, a contar del 1&#xBA; de enero del a&#xF1;o 2004 y hasta el 31 de diciembre del mismo a&#xF1;o, ambas fechas inclusive, con el barco f&#xE1;brica denominado &quot;Isla Camila&quot;, en aguas exteriores, por fuera de las l&#xED;neas de base recta, al sur del paralelo 47&#xB0; L.S., respecto de los recursos y con las obligaciones establecidas en su respectiva autorizaci&#xF3;n.</div><br></div>", "i": 6458152}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de diciembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6458153}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3520 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3520 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-30", "doble_articulado": false, "id_norma": "219930", "numero_fuente": "37755", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-01-09", "vigencias": [{"desde": "2004-01-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-01-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-01-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu