{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 996 EXENTO, DE 2004 </div></div>", "i": 6547535}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 996, de fecha 22 de noviembre de 2004, de Educaci&#xF3;n, se declara aprobada a la Universidad Regional San Marcos, la siguiente carrera y grado acad&#xE9;mico que se indica:</div><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  :&nbsp;  Ingenier&#xED;a Comercial.</div><div class=\"p\">Grado Acad&#xE9;mico&nbsp;  :&nbsp;  Licenciado en Ciencias en la</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Administraci&#xF3;n de Empresas.</div><div class=\"p\">T&#xED;tulo Profesional :&nbsp; Ingeniero Comercial.</div><br><div class=\"p\">&nbsp; &nbsp;  Dicha carrera ser&#xE1; impartida en jornada diurna en la ciudad de Concepci&#xF3;n, a contar del primer semestre del a&#xF1;o 2005.</div><br></div>", "i": 6547536}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de marzo de 2005.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6547537}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "996 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-996 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 996 EXENTO, DE 2004", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-11-22", "fecha_derogacion": "2012-02-10", "doble_articulado": false, "id_norma": "243779", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-11-09", "vigencias": [{"desde": "2012-02-10", "hasta": "", "