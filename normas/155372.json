{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 187, DE 1986 </div></div>", "i": 8930387}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado Planes y Programas Especiales de Estudio para Segundo Ciclo de la Educaci&#xF3;n Media T&#xE9;cnico - Profesional, a contar del a&#xF1;o escolar 1986 y hasta el a&#xF1;o escolar 1991, inclusive, para la Escuela T&#xE9;cnica Femenina Avenida Recoleta, de Conchal&#xED;.</div><div class=\"p\">Especialidades:</div><div class=\"p\">1. Atenci&#xF3;n de P&#xE1;rvulos con menci&#xF3;n en Sala Cuna.</div><div class=\"p\">2. Atenci&#xF3;n de P&#xE1;rvulos con menci&#xF3;n en Educaci&#xF3;n Diferencial.</div><div class=\"p\">3. Vestuario con menci&#xF3;n en Dise&#xF1;o.</div><div class=\"p\">4. Vestuario con menci&#xF3;n en Confecci&#xF3;n Industrial.- </div></div>", "i": 8930388}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 8930389}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "187 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-187 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 187, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO. NO TIENE FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "155372", "numero_fuente": "32509", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-06-30", "vigencias": [{"desde": "1986-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenc