{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6232040}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 165, de 20.02.86, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana, se autoriza a don Pedro Guzm&#xE1;n Barrera, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6232041}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, Febrero 25 de 1986.- Ramiro Camero Weir, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana, subrogante. </div></div>", "i": 6232042}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "165 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-165 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-02-25", "doble_articulado": false, "id_norma": "155438", "numero_fuente": "32620", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-11-12", "vigencias": [{"desde": "1986-11-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-11-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-11-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi