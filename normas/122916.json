{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO NUMERO 786 EXENTO, DE 1998 </div><br><br><br></div>", "i": 6125053}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 786 de 29 de julio de 1998, se ha aprobado, a contar del a&#xF1;o escolar 1998, al Liceo Industrial &apos;&apos;Eulogio Gordo Moneo&apos;&apos; (Ex A N&#xBA; 16) de Antofagasta, un plan de estudio para la ense&#xF1;anza media t&#xE9;cnico-profesional de adultos, en las especialidades de Mec&#xE1;nica Automotriz y Electricidad Industrial, conducentes a los t&#xED;tulos de t&#xE9;cnico de nivel medio que en cada caso se se&#xF1;ala. </div></div>", "i": 6125054}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 6 de agosto de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6125055}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "786 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-786 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO NUMERO 786 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "LICEO INDUSTRIAL EULOGIO GORDO MONEO", "ANTOFAGASTA", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-29", "doble_articulado": false, "id_norma": "122916", "numero_fuente": "36137", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-08-11", "vigencias": [{"desde": "1998-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-08-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-08-11", "fin_vigencia": "