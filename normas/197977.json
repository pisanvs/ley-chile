{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 280 EXENTO, DE 2002 </div></div>", "i": 7291642}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento N&#xBA; 280 de fecha 08 de abril de 2002 del Ministerio de Educaci&#xF3;n, se aprueban las adecuaciones al plan y programas de estudios de la carrera de Laboratorista Dental del Centro de Formaci&#xF3;n T&#xE9;cnica CEPONAL, que se encuentran anexas y forman parte del Decreto. Modif&#xED;case, en consecuencia, el Decreto Exento del Ministerio de Educaci&#xF3;n N&#xBA; 248 del 1 de octubre de 1990, en el sentido de incorporar dichas adecuaciones.</div><div class=\"p\">&nbsp; &nbsp;  Las adecuaciones que se aprueban mediante este Decreto, podr&#xE1;n aplicarse a contar del a&#xF1;o 2002. </div></div>", "i": 7291643}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de abril de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7291644}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "280 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-280 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 280 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-08", "doble_articulado": false, "id_norma": "197977", "numero_fuente": "37258", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-14", "vigencias": [{"desde": "2002-05-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "20