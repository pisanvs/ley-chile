{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 152 EXENTO, DE 1996 </div></div>", "i": 5942000}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 152 de 19 de marzo de 1996, se ha aprobado un plan especial de estudio para 7&#xB0; y 8&#xB0; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica y para todos los cursos de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, al Liceo de Ni&#xF1;as de Vi&#xF1;a del Mar, V Regi&#xF3;n de Valpara&#xED;so, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 1996.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa de Computaci&#xF3;n para los cursos de 7&#xB0; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica a 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica.</div><br></div>", "i": 5942001}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 3 de abril de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5942002}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "152", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-152"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 152 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIO", "LICEO NI AS VI A DEL MAR", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-03-19", "doble_articulado": false, "id_norma": "20442", "numero_fuente": "35438", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-04-10", "vigencias": [{"desde": "1996-04-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia"