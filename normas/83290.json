{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA </div></div>", "i": 9049191}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xB0;.&nbsp; 44 de fecha 26 de Febrero de 1990, del</div><div class=\"p\">Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3;</div><div class=\"p\">la personalidad jur&#xED;dica de la Asociaci&#xF3;n Gremial de Due&#xF1;os</div><div class=\"p\">de Camiones de Lontu&#xE9;, inscrita bajo el n&#xFA;mero 1.048 del</div><div class=\"p\">registro que lleva este Ministerio, por haberse configurado</div><div class=\"p\">respecto de ella la causal de cancelaci&#xF3;n contemplada en el</div><div class=\"p\">art&#xED;culo 18 N&#xB0;. 2 letra D) del DL 2.757 de 1979.- </div></div>", "i": 9049192}, {"t": "<div><div class=\"p\">Jorge Marshall Rivera, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 9049193}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "44", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-44"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-02-26", "doble_articulado": false, "id_norma": "83290", "numero_fuente": "33663", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-05-07", "vigencias": [{"desde": "1990-05-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-05-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"