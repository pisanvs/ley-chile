{"html": [{"t": "<div><br><div class=\"p\">PARTIDO EVOLUCI&#xD3;N POL&#xCD;TICA</div></div>", "i": 9698952}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Los se&#xF1;ores Felipe Kast Sommerhoff y Jorge Saint Jean Domic, Presidente y Secretario General, respectivamente, de la Directiva Central Provisional del Partido Evoluci&#xF3;n Pol&#xED;tica, con fecha 18 de abril de 2016, han solicitado la Constituci&#xF3;n Legal del Partido en las regiones I de Tarapac&#xE1; y III de Atacama. La solicitud de inscripci&#xF3;n se&#xF1;ala acompa&#xF1;ar la cantidad de afiliados, que se indica:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  I Regi&#xF3;n&nbsp; : 491</div><div class=\"p\">&nbsp; &nbsp;  III Regi&#xF3;n: 296</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xBA; de la ley N&#xBA; 18.603, por resoluci&#xF3;n O-N&#xB0; 121 de fecha 20 de abril de 2016.- </div><br></div>", "i": 9698953}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Elizabeth Cabrera Burgos, Directora(S).</div><br></div>", "i": 9698954}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "121", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-121"}, {"tipo": "3", "numero": "O-121", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-121"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO EVOLUCIÓN POLÍTICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1018354"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-04-20", "doble_articulado": false, "id_norma": "1089822", "numero_fuente": "41443", "tipo_version": "3", "tipo_version_s": "Única"