{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 272.- Santiago, 15 de febrero de 1923.- Vistos estos antecedentes, y de acuerdo con el Consejo de Estado,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 9048590}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.&#xBA; Conc&#xE9;dese personalidad jur&#xED;dica a la corporaci&#xF3;n denominada &quot;Sociedad Italiana Femenina de Beneficencia&quot;, del departamento de Santiago; y </div><div class=\"p\">&nbsp; &nbsp;  2.&#xBA; Apru&#xE9;banse los estatutos por que ha de rejirse dicha corporaci&#xF3;n, que constan de la escritura p&#xFA;blica adjunta, otorgada ante el notario de esta ciudad, don Javier Echeverr&#xED;a Vial, el cuatro de diciembre de mil novecientos veintidos.</div><br></div>", "i": 9048591}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- Alessandri.- C. A. Ruiz B.</div><br></div>", "i": 9048592}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "272", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-272"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PERSONALIDAD JURIDICA", "SOCIEDAD ITALIANA FEMENINA DE BENEFICENCIA", "SANTIAGO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1923-02-15", "doble_articulado": false, "id_norma": "75197", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1923-02-19", "vigencias": [{"desde": "1923-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1923-02-19", "fin_vigencia": ""},