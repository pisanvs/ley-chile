{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6270685}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 953 de 23 de noviembre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Xa. Regi&#xF3;n, se autoriza a F&#xE9;lix Yunge Yunge para efectuar el servicio de taxi colectivo de la L&#xED;nea No. 1 &quot;Bellavista - Techo para Todas&quot; de Puerto Montt, cuyo trazado. fue autorizado por resoluci&#xF3;n No. 082 de 07 de junio de 1984 y modificado por resoluci&#xF3;n No. 694 de 20 de agosto de 1987, de esta Secretaria Regional. </div></div>", "i": 6270686}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial Transportes y Telecomunicaciones Xa. Regi&#xF3;n. </div></div>", "i": 6270687}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "953 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-953 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-23", "doble_articulado": false, "id_norma": "167237", "numero_fuente": "32936", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-03", "vigencias": [{"desde": "1987-12-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-03", "fin_vigencia": "", "ti