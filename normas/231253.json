{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6500560}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.786, de 1 de octubre de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a DISTRIBUIDORA DE PRODUCTOS DEL MAR RIMAR LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Trinidad Ram&#xED;rez N&#xBA; 0241, La Cisterna, Santiago, donde podr&#xE1; procesar, en las l&#xED;neas de elaboraci&#xF3;n de Fresco Enfriado, Fresco Refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6500561}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de octubre de 2004.- Edith Saa Collantes, Subsecretario de Pesca (S).</div><br></div>", "i": 6500562}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2786 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2786 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-01", "doble_articulado": false, "id_norma": "231253", "numero_fuente": "37984", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-10-13", "vigencias": [{"desde": "2004-10-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-10-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-10-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado