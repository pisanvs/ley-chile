{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N&nbsp; N&#xBA;3.639 EXENTA, DE 2014</div></div>", "i": 9609761}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;1.531, de 9 de junio de 2015 de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1073319&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA;3.639 de 2014</a>, que estableci&#xF3; la distribuci&#xF3;n de la fracci&#xF3;n artesanal de Merluza del sur en la X Regi&#xF3;n de Los Lagos, correspondiente al &#xC1;rea Chilo&#xE9; B, sometida al R&#xE9;gimen Artesanal de Extracci&#xF3;n, a&#xF1;o 2015, en sentido de adelantar el 100% de la cuota autorizada para el periodo septiembre -diciembre al periodo enero - julio.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n extractada se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de esta Subsecretar&#xED;a y del Servicio Nacional de Pesca y Acuicultura.</div><br></div>", "i": 9609762}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de junio de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9609763}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1531 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1531 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº3.639 EXENTA, DE 201", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-06-09", 