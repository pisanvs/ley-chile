{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CIRCULAR N&#xBA; 71, DE 2001</div><br><br></div>", "i": 6353069}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Nacional del Servicio de Impuestos Internos ha dictado con fecha 11 de octubre de 2001, la Circular N&#xBA; 71 mediante la cual, teniendo presente lo dispuesto en los N&#xBA;s. 1 y 2 de la letra A) y en el N&#xBA; 1 de la letra B) de art&#xED;culo 6&#xBA; del C&#xF3;digo Tributario, se instruye sobre el tratamiento que debe darse a las consultas que formulen funcionarios y contribuyentes sobre la aplicaci&#xF3;n e interpretaci&#xF3;n de las normas tributarias, regulando entre otras materias, la competencia para absorberlas, la publicidad de las respuestas en su caso, y las normas de coordinaci&#xF3;n interna. El texto &#xED;ntegro de esta Circular se encuentra incluido en la p&#xE1;gina web del Servicio de Impuestos Internos en Internet, cuya direcci&#xF3;n es http://www.sii.cl y adem&#xE1;s se publicar&#xE1; en el Bolet&#xED;n del Servicio del mes de octubre de 2001.-</div><br></div>", "i": 6353070}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Javier Etcheberry Celhay, Director.</div><br></div>", "i": 6353071}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "71", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "CIR-71"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE CIRCULAR Nº 71, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONTRIBUYENTES", "REFORMA TRIBUTARIA", "APLICACION", "INTERPRETACION", "SERVICIO DE IMPUESTOS INTERNOS", "INSTRUCCIONES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "200