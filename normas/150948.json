{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6217852}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 319, de 11 de Junio de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se autoriza a don Juan Manuel Lagos Lagos para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6217853}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lucia M. Leiva Madariaga, Secretario Regional Ministerial de Transportes y Telecomunicaciones VIII Regi&#xF3;n subrogante.</div><br></div>", "i": 6217854}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "319 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-319 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.003, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-11", "doble_articulado": false, "id_norma": "150948", "numero_fuente": "32807", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-30", "vigencias": [{"desde": "1987-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-06-30", "fin_vigencia": "", "tipo_