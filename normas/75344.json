{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6044540}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xB0;561 , de 30 de junio de 1997, se expropiaron los lotes de terreno N&#xB0;s. 16, 17, 18, 19-A, 36 y 39 , superficies 562 m2., 72 m2., 227 m2., 1.898 m2., 841 m2., y 602 m2., roles de aval&#xFA;o 213-31, 213-63, 213-30, 213-4, 219-6, 219-5, comuna de Santa Juana, para la obra Camino de la Madera, sector Bifurcaci&#xF3;n Diuqu&#xED;n - Santa Juana, y se acord&#xF3; el valor de la indemnizaci&#xF3;n con sus propietarios Juan Cuevas Neira, Abel Navarrete Garc&#xE9;s, Pedro Mart&#xED;nez Cuevas, Idilio Cuevas Araneda, Polisario Vallejos Vallejos, y Alejandro Palma Riffo, ascendente a la cantidades de $133.434.-; $31.500.-; $54.936.-; $899.262.-; $263.088.- y $451.836.-, respectivamente.</div><br></div>", "i": 6044541}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas </div></div>", "i": 6044542}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "561", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-561"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SANTA JUANA", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-06-30", "doble_articulado": false, "id_norma": "75344", "numero_fuente": "35843", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-08-16", "vigencias": [{"desde": "1997-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-08-16", "fin_vigencia": ""}, "vigencias_vers