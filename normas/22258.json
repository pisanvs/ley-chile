{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pension de Gracia a la Madre pol&#xED;tica i Hermanas de don M. A. Matta.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 910.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273985}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se concede a do&#xF1;a Rosario de Matta, madre pol&#xED;tica de don Manuel A. Matta, i a sus tres hermanas solteras, una pension de tres mil pesos anuales, que gozar&#xE1;n en conformidad a la lei de montep&#xED;o militar.</div><br><br></div>", "i": 8273986}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 6 de Febrero de 1897.- FEDERICO ERRAZURIZ.- C&#xE1;rlos Ant&#xFA;nez.</div><br></div>", "i": 8273987}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "910", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-910"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "PENSION DE GRACIA A LA MADRE POLITICA I HERMANAS DE DON M. A . MATTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ROSARIO DE MATTA", "MONTEPIO MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-02-06", "doble_articulado": false, "id_norma": "22258", "numero_fuente": "5624", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1897-02-06", "vigencias": [{"desde": "1897-02-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}]