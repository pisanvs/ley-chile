{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6455965}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.323, de 10 de diciembre de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a ANDESPA&#xD1;A CHILE S.A. para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Chinquihue Km. 11, N&#xBA; 9.000, Puerto Montt, X Regi&#xF3;n, en la l&#xED;nea de elaboraci&#xF3;n de Fresco-enfriado, Fresco-refrigerado y Congelado, el recurso Juliana.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2.449 de 2003, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6455966}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de diciembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6455967}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3323 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3323 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-10", "doble_articulado": false, "id_norma": "219420", "numero_fuente": "37745", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-27", "vigencias": [{"desde": "2003-12-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-12-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-12-27", "fin_vigencia": "", "ti