{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7317249}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.611, de 22 de diciembre de 2004, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 721 de 1996, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Pesquera Friosur S.A., hoy PESQUERA FRIOSUR IX S.A., para desarrollar actividades pesqueras extractivas con la nave &quot;Friosur IX&quot;, en el sentido de incorporar y actualizar las siguientes caracter&#xED;sticas n&#xE1;uticas:</div><div class=\"p\"> Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  47,80 m.</div><div class=\"p\">T.R.G. (Internacional)&nbsp; &nbsp; &nbsp;  930,00</div><div class=\"p\">Potencia principal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  2225,00 HP</div><div class=\"p\">Potencia auxiliar&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 720,00 HP</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 537,22 m3</div><br><br></div>", "i": 7317250}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de diciembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7317251}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3611 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3611 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-22", "doble_articulado": false, "id_norma": "234139", "numero_fuente": "38049", "tipo_version": "3", "tipo_version_s": "Única", "fec