{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 109, DE 1986 </div></div>", "i": 6229804}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 109 de 11 de junio de 1986 se han aprobado para el Liceo C N&#xB0; 11, d&#xE9; la comuna de Panguipulli, provincia de Valdivia, X Regi&#xF3;n de Los Lagos, planes y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad</div><div class=\"p\">T&#xE9;cnico-Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar 1986, hasta el a&#xF1;o escolar de 1989, conducente al T&#xED;tulo de T&#xE9;cnico Forestal en la Especialidad de Silvicultura.</div><br></div>", "i": 6229805}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de Junio de 1986.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6229806}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "109 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-109 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 109, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-11", "doble_articulado": false, "id_norma": "154702", "numero_fuente": "32505", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-06-25", "vigencias": [{"desde": "1986-06-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-06-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-06-25", "fin_vigencia": "", "ti