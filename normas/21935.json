{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pension de Montep&#xED;o Lei n&#xFA;m. 62.- Santiago, a 7 de Agosto de 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946649}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, a la viuda e hijos de don Luis Borgo&#xF1;o la pension de montep&#xED;o correspondiente al empleo de coronel, debiendo gozarla con arreglo a la lei de montep&#xED;o militar.</div><br><br></div>", "i": 5946650}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- V. D&#xE1;vila Larrain.</div><br></div>", "i": 5946651}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "62", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-62"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION DE MONTEPIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LUIS BORGO O", "VIUDA", "HIJOS", "MONTEPIO MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-08-07", "doble_articulado": false, "id_norma": "21935", "numero_fuente": "4594", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-08-12", "vigencias": [{"desde": "1893-08-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-08-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-08-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacio