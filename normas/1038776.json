{"html": [{"t": "<div><br><div class=\"p\">Ley n&#xFA;m. 6,490</div><br><div class=\"p\">RESTABLECE EL DEPARTAMENTO DE FREIRINA</div><br><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente </div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div></div>", "i": 9247112}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo 1.o Restabl&#xE9;cese el departamento de Freirina con los deslindes correspondientes a las comunas de Freirina y de Huasco.</div><div class=\"p\">&nbsp; &nbsp;  Su cabecera ser&#xE1; la ciudad de Freirina.</div></div>", "i": 9247113}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo 2.o Esta ley comenzar&#xE1; a regir desde el 1.o de Enero de 1940&quot; </div><br></div>", "i": 9247114}, {"t": "<div><div class=\"p\">Y, por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, diez de Enero de mil novecientos cuarenta.- PEDRO AGUIRRE CERDA.- Guillermo Labarca H.</div><br></div>", "i": 9247115}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "6490", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "Ley-6490"}], "organismos": ["MINISTERO DEL INTERIOR"], "titulo_norma": "RESTABLECE EL DEPARTAMENTO DE FREIRINA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1940-01-10", "doble_articulado": false, "id_norma": "1038776", "numero_fuente": "18572", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1940-01-24", "vigencias": [{"desde": "1940-01-01", "hasta": "", "tipo_version": "3", "tipo_versio