{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8305275}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.081, de 31 de julio de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad parcial, de la Resoluci&#xF3;n N&#xBA; 356 de 1989, de esta Subsecretar&#xED;a, en cuanto autoriz&#xF3; a SOCIEDAD PESQUERA COLOSO S.A., para operar la nave &quot;Intr&#xE9;pido&quot;, en el litoral de la V a la X Regi&#xF3;n, en la captura de los recursos hidrobiol&#xF3;gicos At&#xFA;n aleta amarilla, Congrio colorado, Congrio dorado, Congrio negro, Merluza com&#xFA;n, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) del D.S. N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8305276}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de julio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8305277}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1081", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1081"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD PARCIAL", "SOCIEDAD PESQUERA COLOSO S.A.", "AUTORIZACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-07-31", "fecha_derogacion": "1999-10-18", "doble_articulado": false, "id_norma": "74798", "numero_fuente": "35838", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-08-09", "vigencias": [{"desde": "1999-10-18", "