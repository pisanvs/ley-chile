{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 2.609 EXENTA, DE 2005 </div></div>", "i": 6534118}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.609, de 14 de junio de 2005, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se dispuso el inicio de la puesta en marcha definitiva de la Concesi&#xF3;n Cinco, adjudicada a &quot;Revisiones T&#xE9;cnicas King Limitada&quot;, para operar en la comuna de Melipilla una Planta Revisora Clase B, con cuatro (4) l&#xED;neas de revisi&#xF3;n livianas, a contar del 14 de junio de 2005.-</div><br></div>", "i": 6534119}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Silvio Albarr&#xE1;n Alb&#xE1;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6534120}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2609 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2609 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 2.609 EXENTA, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-14", "doble_articulado": false, "id_norma": "240392", "numero_fuente": "38218", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-23", "vigencias": [{"desde": "2005-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-23", "fin_vigencia": ""}, "vigencias_v