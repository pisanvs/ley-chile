{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SOLICITA CONSTITUCION LEGAL DEL PARTIDO &quot;RENOVACION NACIONAL&quot; EN LA VIII REGION </div></div>", "i": 6016748}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Andr&#xE9;s Allamand Zavala y Rodrigo Ubilla Mackenney, Presidente y Secretario General, respectivamente, en representaci&#xF3;n del partido &quot;Renovaci&#xF3;n Nacional&quot;, han solicitado con fecha 21 de diciembre de 1995 la constituci&#xF3;n legal del partido en la VIII Regi&#xF3;n del B&#xED;o-B&#xED;o, acompa&#xF1;ando 5.334 fichas de afiliaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la Ley N&#xB0; 18.603, por Resoluci&#xF3;n O-N&#xB0; 1.444 de fecha 27 de diciembre de 1995. </div></div>", "i": 6016749}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 27 de diciembre de 1995.- Andr&#xE9;s Merino Espi&#xF1;eira, Director Subrogante.</div><br></div>", "i": 6016750}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1444", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1444"}, {"tipo": "3", "numero": "O-1444", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-1444"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCION LEGAL DEL PARTIDO RENOVACION NACIONAL EN LA VIII REGION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONSTITUCION LEGAL", "OCTAVA REGION", "PARTIDOS POLITICOS", "PARTIDO RENOVACION NACIONAL", "SOLICITUD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-12-27", "doble_articulado": false, "id_norma": "36985", "numero_fuente": "35359", "tipo_version": "3", "tipo_version_s": "Única", "fe