{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8300522}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 4, de 9 de enero de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, rectif&#xED;quese la Resoluci&#xF3;n N&#xBA; 1.318, de 1996, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA SAN JOSE S.A., para sustituir las naves &quot;Bandurria&quot;, &quot;Don Mateo&quot;, y &quot;El Conquistador&quot;, en el sentido de se&#xF1;alar que el nombre correcto de esta &#xFA;ltima nave corresponde al de &quot;Conquistador&quot; y no al se&#xF1;alado en dicha Resoluci&#xF3;n.</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xBA; 1.878, de 1996 de esta Subsecretar&#xED;a en virtud de lo dispuesto en la presente Resoluci&#xF3;n.</div><br></div>", "i": 8300523}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Valpara&#xED;so, 9 de enero de 1997.-</div><br><div class=\"p\">&nbsp; &nbsp;  Juan Manuel Cruz&nbsp; S&#xE1;nchez, Subsecretario de Pesca. </div></div>", "i": 8300524}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECTIFICACION", "AUTORIZACION", "PESQUERA SAN JOSE S.A.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["extracto"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-01-09", "doble_articulado": false, "id_norma": "60173", "numero_fuente": "35669", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-01-18", "vigencias":