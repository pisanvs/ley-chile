{"html": [{"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">AMPL&#xCD;A PLAZO QUE INDICA</div><div class=\"p\">&nbsp;  </div></div>", "i": 9660286}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.337, de 7 de diciembre de 2015, de esta Subsecretar&#xED;a, ampl&#xED;ese por doce meses, a contar del 27 de octubre de 2015, el plazo otorgado en el numeral 5&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1084117&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.848 de 2015</a>, que autoriz&#xF3; a Pesquera Omega Limitada, para realizar actividades pesqueras extractivas con la nave Dubrovnick II, en el &#xE1;rea mar&#xED;tima de la XV a X Regiones, Isla de Pascua, Salas y G&#xF3;mez, Desventuradas y Archipi&#xE9;lago de Juan Fern&#xE1;ndez, por fuera del &#xE1;rea de reserva artesanal, con palangre y enmalle, sobre Albacora o Pez espada y su fauna acompa&#xF1;ante, en virtud de haberse acreditado una circunstancia de fuerza mayor.</div><br></div>", "i": 9660287}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de diciembre de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9660288}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3337 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3337 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "AMPLÍA PLAZO QUE INDICA", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2015-12-07", "fecha_derogacion": "2016-04-06", "doble_articulado": false, "id_norma": "1085900", "tip