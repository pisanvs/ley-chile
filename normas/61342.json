{"html": [{"t": "<div><div class=\"p\">COMPLEMENTA&nbsp; RESOLUCION&nbsp; NUMERO 1.732 EXENTA, DE 1981</div><br></div>", "i": 6031424}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n exenta N&#xBA; 317 del 6 de Febrero de 1997, conforme art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, complement&#xF3; Resoluci&#xF3;n exenta del Servicio Agr&#xED;cola y Ganadero N&#xBA; 1.732 del 7 de Agosto de 1981 que determin&#xF3; Derechos de Aprovechamiento de Aguas proporcionales que corresponden a las parcelas 1 a 9 y sitios A al I del Proyecto de Parcelaci&#xF3;n &quot;La Gloria&quot; de la Comuna de Rancagua, VI Regi&#xF3;n, formado por el predio &quot;Hijuela Segunda de Santa Carlota&quot;.</div><br><div class=\"p\">&nbsp; &nbsp;  Los derechos de agua se extraen de los canales Hijuelas y Vicu&#xF1;ano.</div><br></div>", "i": 6031425}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13&#xBA; Ley N&#xBA; 18.377.- Director Nacional.</div><br></div>", "i": 6031426}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "317 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-317 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "COMPLEMENTA RESOLUCION NUMERO 1.732 EXENTA, DE 1981", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHO DE APROVECHAMIENTO DE AGUAS", "RANCAGUA. SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-02-06", "doble_articulado": false, "id_norma": "61342", "numero_fuente": "35705", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-