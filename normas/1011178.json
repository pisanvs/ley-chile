{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8885632}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 757, de 12 de febrero de 2010, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las siguientes resoluciones de esta Subsecretar&#xED;a, conforme lo dispuesto en art&#xED;culo 7&#xBA; del D.S. N&#xBA; 175 de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, que autorizaron para operar plantas procesadoras de recursos hidrobiol&#xF3;gicos: 1) N&#xBA; 2063 de 2004, que autoriz&#xF3; a SOCIEDAD COMERCIALIZADORA DE PRODUCTOS DEL MAR SIFROMAR SOCIEDAD AN&#xD3;NIMA; 2) N&#xBA; 418 y N&#xBA; 2448, ambas de 2003 y N&#xBA; 1006 de 2005, que autorizaron a Productos del Mar Tenglofish Limitada.</div><br></div>", "i": 8885633, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de febrero de 2010.- Germ&#xE1;n Loyola Bast&#xED;as, Subsecretario de Pesca (S).</div><br></div>", "i": 8885634}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "757", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-757"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-02-12", "doble_articulado": false, "id_norma": "1011178", "numero_fuente": "39591", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-02-19", "vigencias": [{"desde": "2010-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-02-19", "fin_vigencia": ""}, "vigencias_version_