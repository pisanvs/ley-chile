{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 298, DE 1999</div><br><br></div>", "i": 6183347}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA; 298 de 16 de julio de 1999, se ha aprobado el convenio de fecha 12 de junio de 1999, celebrado entre el Ministerio de Educaci&#xF3;n y la I. Municipalidad de Mariquina, que rectifica el convenio de traspaso del Liceo C N&#xBA; 8 de Mariquina, traspasado a dicha Corporaci&#xF3;n, por convenio aprobado por decreto supremo de Educaci&#xF3;n N&#xBA; 3.410 del 19 de junio de 1981.</div><br></div>", "i": 6183348}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de agosto de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6183349}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "298", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-298"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 298, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-07-16", "doble_articulado": false, "id_norma": "140802", "numero_fuente": "36443", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-08-19", "vigencias": [{"desde": "1999-08-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-08-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-08-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-08-19", "fecha_version": "1999-08-19", "fecha_actuali