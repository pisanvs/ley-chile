{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6496851}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n N&#xBA; 1.984 de 23 de agosto de 2004, Serviu, Regi&#xF3;n Valpara&#xED;so dispuso expropiaci&#xF3;n parcial, conforme art&#xED;culo 87 ley 8.946 y decreto ley 2.186 de 1978, de inmueble ubicado en calle Baden Powell 375, rol aval&#xFA;o 3303-8, comuna de Quilpu&#xE9;, de dominio de Agnes Ver&#xF3;nica Miethe Dienethal. Comisi&#xF3;n Tasadora integrada por Sres. Osvaldo Mu&#xF1;oz Quintana, arquitecto, Alvaro Verdejo Vidal ingeniero constructor, y Pablo Caria Giurici, constructor civil, seg&#xFA;n informe de fecha 25 de junio de 2004 fij&#xF3; monto provisional indemnizaci&#xF3;n en $229.950.- que ser&#xE1; pagada al contado.</div><br></div>", "i": 6496852}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n Valpara&#xED;so.</div><br></div>", "i": 6496853}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1984", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1984"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAISO"], "titulo_norma": "ORDENAN EXPROPIACIONES DE INMUEBLES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-08-23", "doble_articulado": false, "id_norma": "230250", "numero_fuente": "37963", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-09-15", "vigencias": [{"desde": "2004-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic