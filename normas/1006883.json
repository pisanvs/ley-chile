{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8787600}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.216, de 24 de septiembre de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA GENMAR LIMITADA para ampliar actividades pesqueras extractivas con la nave &quot;Don Chelo I&quot; en el &#xE1;rea mar&#xED;tima de la VIII Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, con red de arrastre, sobre los siguientes recursos hidrobiol&#xF3;gicos: Besugo y Alfonsino.</div></div>", "i": 8787601}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de septiembre de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8787602}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3216 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-3216 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-09-24", "doble_articulado": false, "id_norma": "1006883", "numero_fuente": "39477", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-10-03", "vigencias": [{"desde": "2009-10-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-10-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-10-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "1289", "fecha_ingreso