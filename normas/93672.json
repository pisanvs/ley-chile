{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION QUE INDICA </div></div>", "i": 8323437}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 315 de 13 de Marzo de 1989 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deroga las siguientes autorizaciones por renuncia de su titular: Decreto No. 109, de 1974, del Ministerio de Agricultura, resoluci&#xF3;n No. 64, de 1979 y resoluci&#xF3;n No. 522, de 1984, ambas de esta Subsecretar&#xED;a, que autorizaron a don Fernando L&#xF3;pez Herrero, RUT No.</div><div class=\"p\">2.866.997-6, domiciliado en calle Condell No. 2624, Antofagasta, para desarrollar actividades pesqueras de cultivo.</div><br></div>", "i": 8323438}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 13 de Marzo de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8323439}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "315", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-315"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "DEROGA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-03-13", "doble_articulado": false, "id_norma": "93672", "numero_fuente": "33333", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-03-29", "vigencias": [{"desde": "1989-03-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-03-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-03-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi