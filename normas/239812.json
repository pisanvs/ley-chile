{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6531870}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.753, de 8 de junio de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a SERVICIOS ASOCIADOS A.M. LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en sector Comi&#xF1;a s/n a 2,5 Km. de Pica, provincia de Iquique, I Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de extracto en aceite y polvo de microalgas, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6531871}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de junio de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6531872}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1753 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1753 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-08", "doble_articulado": false, "id_norma": "239812", "numero_fuente": "38200", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-02", "vigencias": [{"desde": "2005-07-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-07-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fe