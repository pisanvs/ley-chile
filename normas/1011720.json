{"html": [{"t": "<div><br><div class=\"p\">DERECHOS DE AGUAS COMUNA DE OVALLE</div></div>", "i": 8892297}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero, mediante resoluci&#xF3;n exenta N&#xBA; 794, de 8 de febrero de 2010, conforme art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, complement&#xF3; resoluci&#xF3;n exenta del Servicio Agr&#xED;cola y Ganadero N&#xBA; 1.491, de fecha 7 de noviembre de 1986, que aprob&#xF3; el Estudio T&#xE9;cnico de Divisi&#xF3;n de los Derechos de Aprovechamiento de Aguas del predio &quot;Hijuela Uno del Fundo Santa Catalina&quot; y del Proyecto de Parcelaci&#xF3;n &quot;Santa Catalina&quot;, ubicados en la comuna de Ovalle, Regi&#xF3;n de Coquimbo, en el sentido de establecer que los derechos de aprovechamiento de aguas son consuntivos, de ejercicio permanente y continuo.</div><div class=\"p\">Publicaci&#xF3;n hecha conforme art&#xED;culo 13&#xBA; de la ley N&#xBA; 18.377.- </div></div>", "i": 8892298}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Nacional.</div></div>", "i": 8892299}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "794 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-794 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUAS COMUNA DE OVALLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-02-08", "doble_articulado": false, "id_norma": "1011720", "numero_fuente": "39611", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-03-15", "vigencias": [{"desde": "2010-03-15", "hasta": "", "tipo