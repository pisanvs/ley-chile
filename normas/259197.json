{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 382 EXENTO, DE 2007 </div></div>", "i": 7338083}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 382, de 22 de enero de 2007, se han modificado los decretos exentos de Educaci&#xF3;n N&#xBA;s. 388 de 1997 y 394 de 1998, que aprobaron planes y programas de estudio para los cursos de 1&#xBA; a 4&#xBA; a&#xF1;o y de 5&#xBA; a 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica, respectivamente, al Colegio &quot;The Wessex School&quot;, de Concepci&#xF3;n, en el sentido de sustituir sus planes de estudio por los que se indican en el presente decreto. </div></div>", "i": 7338084}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de enero de 2007.- Juan Cavada Artigues, Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 7338085}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "382 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-382 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 382 EXENTO, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-01-22", "doble_articulado": false, "id_norma": "259197", "numero_fuente": "38715", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-03-16", "vigencias": [{"desde": "2007-03-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-03-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-03-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACIO