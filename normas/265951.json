{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 153 EXENTA, DE 2007 </div></div>", "i": 6627855}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 153, de 13 de agosto de 2007, de la Secretar&#xED;a Regional Ministerial de la Regi&#xF3;n del B&#xED;o B&#xED;o, se dispuso el inicio de la puesta en marcha blanca de la Concesi&#xF3;n Tres, adjudicada a &quot;Revisiones B&#xED;o B&#xED;o Limitada&quot;, para operar en la comuna de Lota, una Planta Revisora Clase AB, con una (1) l&#xED;nea de revisi&#xF3;n liviana y una (1) l&#xED;nea de revisi&#xF3;n pesada, a contar del d&#xED;a 14 de agosto de 2007.</div><br></div>", "i": 6627856}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Claudio V&#xE1;squez Fern&#xE1;ndez, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6627857}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "153 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-153 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 153 EXENTA, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-08-13", "doble_articulado": false, "id_norma": "265951", "numero_fuente": "38896", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-10-26", "vigencias": [{"desde": "2007-10-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-10-26", "fin_vigencia": "