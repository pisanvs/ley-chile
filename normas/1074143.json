{"html": [{"t": "<div><br><br><div class=\"p\">Ley n&#xFA;m. 4.986</div><br><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div></div>", "i": 9571102}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Se declara en estado de sitio el territorio de la Rep&#xFA;blica, por el t&#xE9;rmino de un mes, de acuerdo con lo dispuesto en el n&#xFA;mero 17 del art&#xED;culo 72 de la Constituci&#xF3;n Pol&#xED;tica.</div><br><div class=\"p\">&nbsp; &nbsp;  La presente ley comenzar&#xE1; a regir desde su publicaci&#xF3;n en el Diario Oficial.</div><br><div class=\"p\">&nbsp; &nbsp;  I por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div></div>", "i": 9571103}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, a cinco de Septiembre de mil novecientos treinta y uno.- MANUEL TRUCCO.- Marcial Mora M.</div><br><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a U. para su conocimiento.</div><br><div class=\"p\">&nbsp; &nbsp;  Dios guarde a U.- C&#xE9;sar Le&#xF3;n.</div></div>", "i": 9571104}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4986", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "Ley-4986"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-09-05", "doble_articulado": false, "id_norma": "1074143", "numero_fuente": "16067", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-09-05", "vigencias": [{"desde": "1931-