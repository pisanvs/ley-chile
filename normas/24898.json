{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede abono de tiempo de servicios al se&#xF1;or Ram&#xF3;n Luis Valderrama</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional a dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br><br></div>", "i": 5960717}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Ab&#xF3;nase, por gracia, para los efectos de su jubilaci&#xF3;n, al se&#xF1;or Ram&#xF3;n Luis Valderrama Silva, el tiempo de catorce a&#xF1;os que sirvi&#xF3; como profesor en los Seminarios de Talca y Santiago.</div><div class=\"p\">&nbsp; &nbsp; Esta ley comenzar&#xE1; a regir desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 5960718}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, ocho de Enero de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Rodolfo Jaramillo B.</div><br></div>", "i": 5960719}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4768", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4768"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE ABONO DE TIEMPO DE SERVICIOS AL SEÑOR RAMON LUIS VALDERRAMA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RAMON LUIS VALDERRAMA SILVA", "JUBILACION", "ABONO TIEMPO", "CONCESION", "RECONOCIMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-01-08", "doble_articulado": false, "id_norma": "24898", "numero_fuente": "15576", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-01-18"