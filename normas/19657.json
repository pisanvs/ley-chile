{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 14 EXENTO, DE 1996 </div></div>", "i": 8667292}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 14, de 15 de enero de 1996, se ha derogado, a partir del a&#xF1;o escolar 1996, el decreto supremo exento de Educaci&#xF3;n N&#xB0; 312, de 1986, que aprob&#xF3; plan especial de estudio para Educaci&#xF3;n Media, al Liceo &quot;Isaura Dinator de Guzm&#xE1;n&quot; (ex A N&#xB0; 4 de Ni&#xF1;as), de Santiago.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se declara que el Liceo aplicar&#xE1;, a partir de esa misma fecha, los planes y programas oficiales de estudio aprobados por decreto supremo exento de Educaci&#xF3;n N&#xB0; 300, de 1981.</div><br></div>", "i": 8667293}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 24 de enero de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8667294}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "14 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-14 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 14 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LICEO ISAURA DINATOR DE GUZMAN", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-01-15", "doble_articulado": false, "id_norma": "19657", "numero_fuente": "35378", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-01-29", "vigencias": [{"desde": "1996-01-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_