{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6133582}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP. No. 969, de 30 de julio de 1998, se expropiaron los lotes de terreno No. s. 32, 39, 41, 54 y 81 superficies 441, 50, 60, 533 y 203 m2 . respectivamente, roles de aval&#xFA;o 60-36, 60-38, 60-39, 59-23 y 58-8, comuna de Ch&#xE9;pica, para la obra Camino Ch&#xE9;pica - Bif. Teno, Sector Cuesta El Peral - Ch&#xE9;pica y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Carmen D&#xED;az Mor&#xE1;n, Fresia Gonz&#xE1;lez Mej&#xED;as, Manuel Gonz&#xE1;lez Donoso, Rosa Castro Olivares y Juan Lobos Moreno, ascendentes a las cantidades de $ 444.469.- para el lote 32, $ 465.080.- para el lote 39, $ 443.940.- para el lote 41, $ 794.336.- para el lote 54 y $ 4.441.303.- para el lote 81.</div><br></div>", "i": 6133583}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6133584}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "969", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-969"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "CHEPICA", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-30", "doble_articulado": false, "id_norma": "125385", "numero_fuente": "36177", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-10-01", "vigencias": [{"desde": "1998-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-10-01", "fin_vigencia": ""}, "vigencias_versio