{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 522 EXENTO, DE 1994 </div></div>", "i": 5945046}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 522 de 4 de noviembre de 1994, se ha modificado y complementado el decreto supremo exento de Educaci&#xF3;n N&#xB0; 13 de 1989, que aprob&#xF3; planes y programas especiales de estudio al Colegio &quot;La Dehesa&quot; de Santiago, para la ense&#xF1;anza media, en la forma que indica el citado decreto. </div></div>", "i": 5945047}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 16 de Noviembre de 1994.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5945048}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "522", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-522"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 522 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "COLEGIO DEHESA", "SANTIAGO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-11-11", "doble_articulado": false, "id_norma": "21405", "numero_fuente": "35024", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-11-24", "vigencias": [{"desde": "1994-11-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-11-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-11-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1994-11-24", "fecha_actualizacion_texto": "1994-11-2