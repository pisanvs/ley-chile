{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8783883}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.009, de 10 de septiembre de 2009, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=153549&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 37, de 2000</a> y el numeral 2&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=263354&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.277, de 2007</a>, ambas de esta Subsecretar&#xED;a de Pesca que autorizaron a CORPESCA S.A. para realizar actividades pesqueras extractivas con la nave &quot;San Jorge I&quot;, en el sentido de actualizar las siguientes caracter&#xED;sticas n&#xE1;uticas de la nave:</div><br><div class=\"p\">Eslora de Arqueo :&nbsp; 33,85 m</div><div class=\"p\">TRG (Nacional)&nbsp;  :&nbsp; 287,00</div><br></div>", "i": 8783884, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de septiembre de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 8783885}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3009 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-3009 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-09-10", "doble_articulado": false, "id_norma": "1006348", "numero_fuente": "39465", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-09-17",