{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 4.982 EXENTA, DE 2006 </div></div>", "i": 7330850}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 4.982, de 22 de junio del 2006, se ha aprobado plan y programas especiales de estudio para 1&#xBA; y 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media T&#xE9;cnico-Profesional al Liceo Forestal &quot;Los Alamos&quot;, de la Provincia de Arauco, Regi&#xF3;n del B&#xED;o-B&#xED;o, en la Formaci&#xF3;n Complementaria, el cual se aplicar&#xE1; a contar del a&#xF1;o escolar 2007.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas especiales de estudio para los Subsectores de Formaci&#xF3;n Personal, Tecnolog&#xED;a Aplicada y Sistemas Productivos de la Formaci&#xF3;n Complementaria para 1&#xBA; y 2&#xBA; a&#xF1;o medio.</div><br></div>", "i": 7330851}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de julio de 2006.- Carlos Concha Albornoz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 7330852}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4982 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4982 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 4.982 EXENTA, DE 2006", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-22", "doble_articulado": false, "id_norma": "251065", "numero_fuente": "38507", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-07-07", "vigencias": [{"desde": "2006-07-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio