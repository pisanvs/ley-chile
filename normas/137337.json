{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,402.- Por cuanto el Congreso Nacional ha dado su aprobacion&nbsp; al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6171668}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al teniente-coronel retirado de Ej&#xE9;rcito, don Herm&#xF3;jenes C&#xE1;mus, para los efectos de su retiro, el abono de tiempo servido como Intendente de las provincias de Llanquihue i Curic&#xF3;, desde el 4 de diciembre de 1897 hasta el 2 de octubre de 1901.</div><br></div>", "i": 6171669}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, doce de setiembre de mil novecientos diez.- Emiliano Figueroa.- C&#xE1;rlos Larrain Claro. </div></div>", "i": 6171670}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2402", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2402"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-09-12", "doble_articulado": false, "id_norma": "137337", "numero_fuente": "9793", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-09-14", "vigencias": [{"desde": "1910-09-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-09-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1910-09-14", "fin_vigencia": "", "tipo_version