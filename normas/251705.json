{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6577493}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.969, de 11 de julio de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a FILOMENA TERAN CRUZ ELABORADORA Y COMERCIALIZADORA E.I.R.L., para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Avenida Brasil N&#xBA; 65, sector La Vega, Calbuco, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Fresco enfriado, Fresco refrigerado, Congelado y Fresco salado los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6577494}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de julio de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6577495}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1969 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1969 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-11", "doble_articulado": false, "id_norma": "251705", "numero_fuente": "38525", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-07-28", "vigencias": [{"desde": "2006-07-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-07-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-07-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul