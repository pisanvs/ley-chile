{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTOS DE RESOLUCIONES </div></div>", "i": 8288712}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 589, de 22 de Mayo de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por seis meses a contar de la fecha de la presente resoluci&#xF3;n, el plazo otorgado en el numeral 5&#xB0; de la resoluci&#xF3;n N&#xB0; 1.819, de 1989, de esta Subsecretar&#xED;a, a don RAFAEL PUEBLA RODRIGUEZ, R.U.T. N&#xB0; 8.326.840-9, domiciliado en calle Edwards N&#xB0; 1002, Caldera, en raz&#xF3;n de haberse acreditado la existencia de una fuerza mayor.</div><br></div>", "i": 8288713}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 22 de Mayo de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8288714}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "589", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-589"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "EXTRACTOS DE RESOLUCIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RAFAEL PUEBLA RODRIGUEZ", "PESCA", "PLAZO", "PRORROGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-05-22", "doble_articulado": false, "id_norma": "31547", "numero_fuente": "33989", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-06-11", "vigencias": [{"desde": "1991-06-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-06-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-06-11", "fin_vigencia": "", "tipo_version": "3"}