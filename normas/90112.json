{"html": [{"t": "<div><div class=\"p\">RECTIFICA ORDENANZA LOCAL</div><br><div class=\"p\">N&#xFA;m. 130 exento.- Licant&#xE9;n, 09 de Abril de 1990.- Vistos:</div><div class=\"p\">a) Decreto Alcaldicio No. 28 del 30.01.90.</div><div class=\"p\">b) El art. 43 y dem&#xE1;s pertinentes al DL No. 3.063/79. sobre Rentas Municipales, y teniendo presente las facultades No.</div><div class=\"p\">18.695, Org&#xE1;nica Constitucional de Municipalidades y modificada por la Ley 18.702, ambas de 1988.</div><br><div class=\"p\">Decreto:</div><br><br></div>", "i": 6084659}, {"t": "<div><div class=\"p\">1.- D&#xED;ctase, la siguiente rectificaci&#xF3;n a la Ordenanza local como se indica: T&#xED;tulo X Art&#xED;culo 18 No. 11 Dice:</div><div class=\"p\">11) Extracci&#xF3;n de &#xE1;ridos por cada M3 30% UTM Debe decir:</div><div class=\"p\">11) Extracci&#xF3;n de &#xE1;ridos por cada M3 0,6% UTM </div></div>", "i": 6084660}, {"t": "<div><div class=\"p\">An&#xF3;tese, comun&#xED;quese, publ&#xED;quese y arch&#xED;vese.- Enrique Rivera Ortiz, Alcalde.- Oscar Orellana Astudillo, Secretario Municipal (S) </div></div>", "i": 6084661}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "130 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-130 EXENTO"}], "organismos": ["MUNICIPALIDAD DE LICANTÉN"], "titulo_norma": "RECTIFICA ORDENANZA LOCAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-04-09", "doble_articulado": false, "id_norma": "90112", "numero_fuente": "33652", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-04-23", "vigencias": [{"desde": "1990-04-23", "hasta": "", "tipo_version": "3", "tipo_version_