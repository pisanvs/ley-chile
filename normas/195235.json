{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO MINISTROS DE FE A FUNCIONARIOS QUE INDICA </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 85.- Santiago, 29 de enero de 2002.- Vistos: Lo dispuesto en el art. 4&#xBA; del decreto ley N&#xBA;2.974 de 1979.</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br></div>", "i": 6371655}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Ministros de Fe para actuar en las localidades ubicadas en la IV Regi&#xF3;n, en que no hayan Notarios ni Oficiales del Registro Civil, a los siguientes funcionarios:</div><br><div class=\"p\">&nbsp; &nbsp;  - Constantino Vega Maturana</div><div class=\"p\">&nbsp; &nbsp;  - Jaime Pe&#xF1;aloza Carrasco</div><div class=\"p\">&nbsp; &nbsp;  - Eduardo Ignacio Carvajal Carre&#xF1;o.</div><br></div>", "i": 6371656}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Ricardo Halabi Caffena, Director Nacional.</div><br></div>", "i": 6371657}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "85", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-85"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO MINISTROS DE FE A FUNCIONARIOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-01-29", "doble_articulado": false, "id_norma": "195235", "numero_fuente": "37202", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-03-05", "vigencias": [{"desde": "2002-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"i