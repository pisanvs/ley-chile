{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5845224}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 5,86% anual durante el mes de enero de 1995.</div><div class=\"p\">&nbsp; &nbsp; Asimismo, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de enero de 1995, fue de 5,85% anual. </div></div>", "i": 5845225}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, Febrero 3 de 1995.- V&#xED;ctor Vial del R&#xED;o, Ministro de Fe.</div><br></div>", "i": 5845226}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA INTERES PROMEDIO", "OPERACIONES CREDITO DINERO", "CAPTACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-02-03", "doble_articulado": false, "id_norma": "1817", "numero_fuente": "35086", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-02-06", "vigencias": [{"desde": "1995-02-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-02-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-02-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu