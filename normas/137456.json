{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,511.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6172167}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese a la viuda e hijos del ex-juez de letras de Quillota, don Ramon Araya A., una pension de gracia de seis mil pesos anuales ($ 6,000), de la que disfrutar&#xE1;n con arreglo a la lei de montep&#xED;o militar, i desde el dia siguiente al de la muerte del se&#xF1;or Araya.</div><br></div>", "i": 6172168}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, doce de julio de mil novecientos once.- Ramon Barros Luco.- An&#xED;bal Letelier.</div><br></div>", "i": 6172169}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2511", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2511"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-07-12", "doble_articulado": false, "id_norma": "137456", "numero_fuente": "10035", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-07-20", "vigencias": [{"desde": "1911-07-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-07-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-07-20", "fin_vigencia": "", "tipo_version": "