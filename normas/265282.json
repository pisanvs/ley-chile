{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7355226}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.605, de 30 de agosto de 2007, de esta Subsecretar&#xED;a autor&#xED;zase a ALIMENTOS DEL NORTE LIMITADA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Ger&#xF3;nimo M&#xE9;ndez N&#xBA; 1851, Galp&#xF3;n 2, Barrio Industrial Pe&#xF1;uelas, Coquimbo, IV Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Fresco-Enfriado, Fresco-Refrigerado, Congelado, Seco-Salado, Ahumado, Conserva y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 7355227}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de agosto de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7355228}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2605 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2605 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-08-30", "doble_articulado": false, "id_norma": "265282", "numero_fuente": "38879", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-10-05", "vigencias": [{"desde": "2007-10-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-10-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-10-05", "fin_vigencia": "", "