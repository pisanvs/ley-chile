{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8959220}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.309, de 30 de julio de 2010, de esta Subsecretar&#xED;a, inval&#xED;dese el proceso de postulaciones cargo de consejero del Consejo Zonal de Pesca V, VI, VII, VIII y IX Regiones e Islas Oce&#xE1;nicas representante de las organizaciones gremiales de tripulantes de naves especiales per&#xED;odo 2010-2014.</div><br><div class=\"p\">&nbsp; &nbsp;  Decl&#xE1;rase vacante el cargo de consejero del Consejo Zonal de Pesca V, VI, VII, VIII y IX Regiones e Islas Oce&#xE1;nicas representante de las organizaciones gremiales de tripulantes de naves especiales per&#xED;odo 2010-2014.</div></div>", "i": 8959221}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de julio de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 8959222}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2309 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2309 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-07-30", "doble_articulado": false, "id_norma": "1015988", "numero_fuente": "39729", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-08-06", "vigencias": [{"desde": "2010-08-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-08-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-08-06", "fin_vigencia": "", "ti