{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8308107}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 691, de 24 de Julio de 1992, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por un a&#xF1;o a contar del 29 de Mayo de 1992, el plazo otorgado a do&#xF1;a NEVENKA SIMUNOVIC MERCADO, R.U.T. No. 4.514.067-9, domiciliada en Regimiento Coquimbo No. 210, Coquimbo, para reiniciar operaciones con la nave &quot;Patricia&quot; individualizada y autorizada por resoluciones No.</div><div class=\"p\">83, de 1979 y No. 437, de 1980, ambas de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor.</div><br></div>", "i": 8308108}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 24 de Julio de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8308109}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "691", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-691"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO DE RESOLUCION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-07-24", "doble_articulado": false, "id_norma": "77698", "numero_fuente": "34346", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-08-20", "vigencias": [{"desde": "1992-08-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-08-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-08-20", "fin_vigencia": "", "tipo