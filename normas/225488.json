{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 6.414 EXENTA, DE 2004 </div></div>", "i": 6480181}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 6.414, de 30 de abril de 2004, se ha aprobado al &quot;Colegio San Ignacio El Bosque&quot;, de la comuna de Providencia, Regi&#xF3;n Metropolitana, un plan especial de estudio para 1&#xBA; y 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media Human&#xED;stico-Cient&#xED;fica, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2004.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio para el Subsector de &quot;Formaci&#xF3;n Teol&#xF3;gica&quot; del Sector de Filosof&#xED;a y Psicolog&#xED;a para 1&#xBA; y 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media.</div><br></div>", "i": 6480182}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de mayo de 2004.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6480183}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6414 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-6414 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 6.414 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-30", "doble_articulado": false, "id_norma": "225488", "numero_fuente": "37866", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-05-22", "vigencias": [{"desde": "2004-05-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-05-22", "fin_vigencia": ""}, "vigencias_versi