{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6251885}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 195, de 31 de enero de 2000, se expropiaron los lotes de terreno N&#xBA;s. 87 y 88, superficies 1.750 m&#xB2;. y 869 m&#xB2;., rol de aval&#xFA;o 604-10, comuna de Mulch&#xE9;n,&nbsp; para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: Chill&#xE1;n-Collipulli, Octava Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Florinda Poblete Conejeros, ascendente a la cantidad total de $1.395.527.</div><br></div>", "i": 6251886}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6251887}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "195", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-195"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-31", "doble_articulado": false, "id_norma": "161368", "numero_fuente": "36614", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-15", "vigencias": [{"desde": "2000-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2000-03-17", "fecha_version": "2000-03-15", "fecha_actualizacion_texto": "2000-03-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "e