{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8336724}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.561, de 13 de noviembre de 1998, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 39, de 1991 de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA EPERVA S.A., para operar la nave &apos;&apos;Eperva 63&apos;&apos;, s&#xF3;lo en lo relativo a las especies Anchoveta, Caballa, Jurel, Sardina com&#xFA;n y Sardina espa&#xF1;ola, en el litoral de la III Regi&#xF3;n, por haber suspendido actividades por m&#xE1;s de 12 meses sucesivos, configur&#xE1;ndose la causal prevista en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8336725}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de noviembre de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8336726}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1561", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1561"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA EPERVA S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-13", "doble_articulado": false, "id_norma": "127328", "numero_fuente": "36218", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-11-19", "vigencias": [{"desde": "1998-11-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-11-19", "fin_vigencia": ""}, "vigencias_version_norma":