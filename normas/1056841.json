{"html": [{"t": "<div><br><div class=\"p\">DISPONE EXPROPIACI&#xD3;N QUE SE&#xD1;ALA</div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9388911}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 6.472 de 7 noviembre 2013, Serviu Regi&#xF3;n Valpara&#xED;so, dispuso expropiaci&#xF3;n Lote 1, de una superficie de 2.350 m2, conforme art&#xED;culo 51 ley 16.391 y decreto ley 2.186 de 1978, dominio Obispado de Valpara&#xED;so, rol aval&#xFA;o 197-6 (parte) ubicado calle Vicu&#xF1;a Mackenna N&#xBA; 18, Quillota. Comisi&#xF3;n Tasadora integrada por Enrique Ramos Guzm&#xE1;n (arquitecto), Irma D&#xED;az Riveros (constructor civil) y Hugo Fuentes Jara (constructor civil), seg&#xFA;n informe septiembre 2013 fij&#xF3; monto indemnizaci&#xF3;n provisional en $92.211.831.-, que ser&#xE1; pagada de contado.</div></div>", "i": 9388912}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Directora.</div></div>", "i": 9388913}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6472", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6472"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAÍSO"], "titulo_norma": "DISPONE EXPROPIACIÓN QUE SEÑALA; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-11-07", "doble_articulado": false, "id_norma": "1056841", "numero_fuente": "40721", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-12-02", "vigencias": [{"desde": "2013-12-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-12-02", "fin_vig