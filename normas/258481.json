{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA </div></div>", "i": 6601895}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n ministerial T.R. N&#xBA; 71, de fecha 27 de diciembre de 2006, se cancel&#xF3; la personalidad jur&#xED;dica de la entidad denominada &quot;Asociaci&#xF3;n de Consumidores de Independientes y Pensionados de Carabineros - Acondip&quot;, inscrita bajo el N&#xBA; 16-AC, por haberse configurado la causal contemplada en el art&#xED;culo 18&#xBA; n&#xFA;mero 2 letra a) del decreto ley N&#xBA; 2.757, de 1979 y la ley 19.496, modificada por la ley 19.955. </div></div>", "i": 6601896}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Javiera Estrada Quezada, Jefe Unidad Asociaciones Gremiales y Martilleros.</div><br></div>", "i": 6601897}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "71", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-71"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-12-27", "doble_articulado": false, "id_norma": "258481", "numero_fuente": "38694", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-02-20", "vigencias": [{"desde": "2007-02-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-02-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-02-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [],