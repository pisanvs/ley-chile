{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6366483}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de enero de 2002, fue de 5,96 % anual.</div><br></div>", "i": 6366484}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, enero 17 de 2002.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6366485}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-01-17", "doble_articulado": false, "id_norma": "193940", "numero_fuente": "37163", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-18", "vigencias": [{"desde": "2002-01-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2002-01-22", "fecha_version": "2002-01-18", "fecha_actualizacion_texto": "2002-01-18", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6366483}, {"n": "Artículo", "i": 63664