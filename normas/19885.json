{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 44 EXENTO, DE 1995 </div></div>", "i": 5940229}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 44 de 11 de Enero de 1995, se ha aprobado, a contar del a&#xF1;o 1995, un plan de estudio especial a la Escuela Particular Adventista N&#xB0; 60 de la comuna de La Cisterna, Regi&#xF3;n Metropolitana, el que se aplicar&#xE1; en todos los cursos de 1&#xB0; a 8&#xB0; a&#xF1;o b&#xE1;sico.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio para las asignaturas que se se&#xF1;alan en el presente decreto. </div></div>", "i": 5940230}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 23 de Enero de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5940231}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "44", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-44"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 44 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ESCUELA PARTICULAR ADVENTISTA N 60", "LA CISTERNA", "PLANES ESTUDIO", "PROGRAMA ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-01-11", "doble_articulado": false, "id_norma": "19885", "numero_fuente": "35080", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-01-30", "vigencias": [{"desde": "1995-01-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-01-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-01-30", "fin_vigencia"