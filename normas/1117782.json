{"html": [{"t": "<div><div class=\"p\">DELEGA FACULTADES QUE INDICA</div></div>", "i": 9908036}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  En virtud de lo dispuesto en la resoluci&#xF3;n exenta N&#xBA; 48, de 28.04.2006, del Director del Servicio de Impuestos Internos, el suscrito ha dictado la resoluci&#xF3;n exenta N&#xBA; 233, del 29.03.2018, delegando en los funcionarios indicados en lo resolutivo, la facultad de autorizar a contribuyentes que lo soliciten, el pago diferido de los impuestos, de la Ley de la Renta.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se ha publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl).</div></div>", "i": 9908037}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y notif&#xED;quese.- Vania Uarac Senn, Directora Regional XIX Direcci&#xF3;n Regional Santiago Norte, Servicio de Impuestos Internos.</div></div>", "i": 9908038}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "233 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-233 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL SANTIAGO NORTE"], "titulo_norma": "DELEGA FACULTADES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1386598", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-03-29", "doble_articulado": false, "id_norma": "1117782", "numero_fuente": "42040", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-04-24", "vigencias": [{"desde": "2018-04-24", "hasta": "", "tipo_version": "3", "tipo_version_s"