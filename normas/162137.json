{"html": [{"t": "<div><div class=\"p\">AUTORIZA A DON ALEJANDRO DEL RIO OTTO PARA DESARROLLAR ACTIVIDADES PESQUERAS</div><br><br><br></div>", "i": 7265984}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 296, de 27 de Mayo de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a don Alejandro del Rio Otto, RUT. 7.166.690-5, domiciliado en Concepci&#xF3;n. calle Bulnes 1284, Depto. 304, para elaborar en la linea de congelado en las instalaciones de Comercial Alesa S.A. Frigor&#xED;fico Concepci&#xF3;n, ubicadas en Las Heras 2241, Concepci&#xF3;n, los siguientes recursos hidrobiol&#xF3;gicos: loco, merluza com&#xFA;n, congrio negro, congrio dorado y erizo.</div><br></div>", "i": 7265985}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de Mayo de 1985.- Roberto Verdugo Gormaz. Subsecretario de Pesca.</div><br></div>", "i": 7265986}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "296", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-296"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A DON ALEJANDRO DEL RIO OTTO PARA DESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1985-05-27", "fecha_derogacion": "2000-01-06", "doble_articulado": false, "id_norma": "162137", "numero_fuente": "32198", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1985-06-17", "vigencias": [{"desde": "2000-01-06", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1985-06-17", "hasta": "2