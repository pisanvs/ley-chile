{"html": [{"t": "<div><div class=\"p\">&#xFEFF;&nbsp; &nbsp;  LICENCIA TEMPORAL A OFICIALES JENERALES.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Octubre 2 de 1826.</div></div>", "i": 10235115}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Decl&#xE1;rase por punto jeneral que los oficiales desde la clase de Brigadier inclusive, cuando obtengan licencia temporal, no les corresponde el decreto 14 de diciembre&nbsp; pr&#xF3;ximo pasado relativo al de 18 de noviembre de 1820 sobre descuentos de medias pagas; en su virtud le ser&#xE1;n abonados &#xED;ntegramente segun el esp&#xED;ritu de las supremas resoluciones de 17 de febrero de 1787, las de junio y julio del mismo a&#xF1;o, y la de 10 de abril de 88. T&#xF3;mese razon y trascr&#xED;base a la Comandancia jeneral de armas. </div></div>", "i": 10235116}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  EIZAGUIRRE</div><br><div class=\"p\">&nbsp; &nbsp;  Cruz</div></div>", "i": 10235117}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DE LA GUERRA"], "titulo_norma": "LICENCIA TEMPORAL A OFICIALES JENERALES.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1826-10-02", "doble_articulado": false, "id_norma": "1152540", "numero_fuente": "1826", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1826-10-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1826-10-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1826-10-02", "fin_vigencia": "", "tipo_version": "3