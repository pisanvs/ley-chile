{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8344664}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 665, de 22 de abril de 1999, de esta Subsecretar&#xED;a, autor&#xED;zase a GUILLERMO HUMBERTO MARIN ESTEVEZ, para liberar los ejemplares de la especie Esturi&#xF3;n blanco de California, cuyo cultivo experimental fue aprobado por resoluci&#xF3;n N&#xBA; 1.090, de 1998, de esta Subsecretar&#xED;a, desde el corral donde se encuentran actualmente confinados, conforme el numeral 6&#xBA; de la citada resoluci&#xF3;n, hacia el tranque individualizado en el numeral 2&#xBA; de la misma.</div><br></div>", "i": 8344665}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de abril de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8344666}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "665", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-665"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-04-22", "doble_articulado": false, "id_norma": "136089", "numero_fuente": "36358", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-05-08", "vigencias": [{"desde": "1999-05-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-05-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-05-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modif