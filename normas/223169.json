{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6471769}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA; 296, de 11 de febrero de 2004, se rectific&#xF3; el decreto MOP exento N&#xBA; 1.203, de 15 de octubre de 2003, en lo que respecta al nombre del expropiado de los lotes de terreno N&#xBA; s. 67 y 68, el que debe decir, Soldado Millaqueo Bernardo y no como se indic&#xF3;. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.-</div><br></div>", "i": 6471770}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6471771}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "296 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-296 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-11", "doble_articulado": false, "id_norma": "223169", "numero_fuente": "37826", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-01", "vigencias": [{"desde": "2004-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "DVG", "fecha_ingreso": "2004-04-01", "fecha_version": "2004-04-01", "fecha_actualizacion_texto": "2004-04-01", "tipo_