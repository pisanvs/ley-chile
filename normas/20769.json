{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 239 EXENTO, DE 1996 </div></div>", "i": 5943059}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 239, de fecha 24 de abril de 1996 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a la sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica Centro Interamericano de Educaci&#xF3;n y Cultura Cidec, para impartir plan y programas de estudios aprobados para la instituci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, a partir del a&#xF1;o 1996.</div><div class=\"p\">&nbsp; &nbsp; - Sede N&#xB0; 4 de Vi&#xF1;a del Mar Carrera: Electr&#xF3;nica menci&#xF3;n Sistemas de Sonido, Recepci&#xF3;n y Video Recepci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; T&#xED;tulo: T&#xE9;cnico en Electr&#xF3;nica menci&#xF3;n Sistemas de Sonido, Recepci&#xF3;n y Video Recepci&#xF3;n.</div><br></div>", "i": 5943060}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 11 de junio de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943061}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "239", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-239"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 239 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA", "CENTRO INTERAMERICANO EDUCACION CULTURA CIDEC", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "VI A DEL MAR", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-04-24", "doble_articulado": false, "id_norma": "20769", "numero_fuente": "35508", "tipo_version": "3", "ti