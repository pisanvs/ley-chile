{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6566765}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 914, de 27 de marzo de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a INVERSIONES ALIZE CHILE LIMITADA, para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Ruta 226, kil&#xF3;metro 13,7, camino a Las Quemas, Puerto Montt, X Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de cocido, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6566766}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de marzo de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6566767}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "914 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-914 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-03-27", "doble_articulado": false, "id_norma": "248863", "numero_fuente": "38438", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-04-12", "vigencias": [{"desde": "2006-04-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-04-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-04-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2006-04-12", "fecha_version