{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6065938}, {"t": "<div><div class=\"p\">Por Decreto Secc. 2da. No. 83, de fecha 12 de Enero de 1990, Alcalde I. Municipalidad de Santiago, dispone expropiaci&#xF3;n parcial conforme DS No. 458 de Vivienda y Urbanismo, Decreto Ley 2.186 y Ley 18.695, inmueble Agustinas No. 2373-2377, Rol 332-10 Santiago, aparente dominio Alicia Ca&#xF1;as y Otra, superficie aproximada a expropiar 480 m2. Deslindes: Norte 13,25 mts. con resto predio; Sur, 14,60 mts. con calle Agustinas; Oriente, 34,00 mts. otro propietario y Poniente, 35,00 mts. otro propietario. Indemnizaci&#xF3;n provisional $ 8.428.000.- pagadera contado.</div><br></div>", "i": 6065939}, {"t": "<div><div class=\"p\">M&#xE1;ximo Honorato Alamos, Alcalde Santiago.</div><br></div>", "i": 6065940}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "83", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-83"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-12", "doble_articulado": false, "id_norma": "83657", "numero_fuente": "33585", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-01", "vigencias": [{"desde": "1990-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1998-01-09", "fecha_version": "1990-02-01", "fecha_actualizacion_tex