{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA</div><br><br><br></div>", "i": 8334636}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.270, de 23 de Noviembre de 1988, de esta Subsecretaria de Pesca del Ministerio Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 2&#xB0; de la Resoluci&#xF3;n No. 332, de 1988, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Pesquera San Sebasti&#xE1;n Limitada RUT No.</div><div class=\"p\">79.731.090-5, domiciliada en Santiago, para desarrollar actividades pesqueras de transformaci&#xF3;n, en orden a reemplazar la expresi&#xF3;n &quot;Playa Lota. Coronel VIII Regi&#xF3;n&quot; por &quot;Caleta Lota, Comuna de Lota, Lota. Provincia de Concepci&#xF3;n, Octava Regi&#xF3;n&apos;&apos;.</div><br></div>", "i": 8334637}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de Noviembre de 1988.- Roberto Cabezas Bello. Subsecretario de Pesca.</div><br></div>", "i": 8334638}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1270", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1270"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1988-11-23", "fecha_derogacion": "1992-05-26", "doble_articulado": false, "id_norma": "124629", "numero_fuente": "33240", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1988-12-07", "vigencias": [{"desde": "1992-05-26", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1988-12-07", "hasta":