{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  RECTIFICACI&#xD3;N</div><br></div>", "i": 9156267}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n N&#xBA; 30324, del d&#xED;a 26 de Marzo de 1979, aparece publicado el <a href=\"https://www.leychile.cl/Navegar?idNorma=272590&amp;idParte=0&amp;idVersion=\">decreto 29, de 1979</a>, con el error de transcripci&#xF3;n que se salva a continuaci&#xF3;n:</div><div class=\"p\">&nbsp; &nbsp;  P&#xE1;gina tres, primera columna, l&#xED;neas n&#xFA;mero 9 y 10 dice:</div><div class=\"p\">&nbsp; &nbsp;  &quot;Para los efectos de la aplicaci&#xF3;n del art&#xED;culo N&#xBA; 5, el tramo superior del primero ser&#xE1; de un 13%&quot;.</div><br><div class=\"p\">&nbsp; &nbsp;  Debe decir:</div><div class=\"p\">&nbsp; &nbsp;  &quot;Para los efectos de la aplicaci&#xF3;n del art&#xED;culo N&#xBA; 5, el tramo superior del primero ser&#xE1; de un 130%&quot;.</div><br></div>", "i": 9156268, "v": ["RECTIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "166", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-166"}], "organismos": ["MINISTERIO DE MINERÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1027474", "numero_fuente": "30326", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1979-03-28", "vigencias": [{"desde": "1979-03-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1979-03-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1979-03-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes":