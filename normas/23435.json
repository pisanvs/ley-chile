{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Dispone que la comuna de Frutillar se denominar&#xE1; Puerto Varas</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,706.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275495}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- El territorio municipal de Frutillar, creado por Decreto Supremo de 22 de Diciembre de 1891, se denominar&#xE1; Puerto Varas.</div><br></div>", "i": 8275496}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, ha tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 11 de Setiembre de 1912.- RAMON BARROS LUCO.- Guillermo Barros.</div><br></div>", "i": 8275497}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2706", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2706"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DISPONE QUE LA COMUNA DE FRUTILLAR SE DENOMINARA PUERTO VARAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PUERTO VARAS", "FRUTILLAR", "DENOMINACION", "COMUNA", "CAMBIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-09-11", "doble_articulado": false, "id_norma": "23435", "numero_fuente": "10389", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-09-30", "vigencias": [{"desde": "1912-09-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-09-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"in