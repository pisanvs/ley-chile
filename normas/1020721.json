{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 5.760 EXENTA, DE 1 DE DICIEMBRE DE 2010</div></div>", "i": 9075872}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por la presente se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=236211&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 14.695, de 2004</a>, del Ministerio de Educaci&#xF3;n, que aprobaron planes y programas especiales de estudios de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Colegio Cumbres, comuna de Las Condes, provincia de Santiago, Regi&#xF3;n Metropolitana.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio para el Subsector de &quot;Taller de Redacci&#xF3;n&quot; para 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media del Plan de Formaci&#xF3;n Diferenciada.</div><br></div>", "i": 9075873}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 2 de diciembre de 2010.- Ver&#xF3;nica Abud Cabrera, Jefa Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 9075874}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5760 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-5760 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 5.760 EXENTA, DE 1 DE DICIEMBRE DE 2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-01", "doble_articulado": false, "id_norma": "1020721", "numero_fuente": "39835", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-12-15", "vigencias": [{"desde": "2010-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"