{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION 279, DE 1984</div><br><br></div>", "i": 9048238}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 110 de 25 de Febrero de 1985 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n 279, de 11 de Junio de 1984, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a Industria Pesquera Yagana Importadora, Exportadora y Comercializadora Limitada para operar una planta de congelado en Punta Arenas, en orden a incluir entre las especies que puede utilizar como materia prima, en la elaboraci&#xF3;n del producto se&#xF1;alado, los siguientes recursos: loco, chorito, erizo, jaiba, sardina espa&#xF1;ola, sardina com&#xFA;n y pejerrey de mar. </div></div>", "i": 9048239}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago 25 de Febrero de 1985.- Jorge Valenzuela Dur&#xE1;n, Coronel de Ej&#xE9;rcito, Subsecretario de Pesca subrogante.</div><br></div>", "i": 9048240}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "110", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-110"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION 279, DE 1984", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "INDUSTRIA PESQUERA YAGANA IMPORTADORA", "EXPORTADORA Y COMERCIALIZADORA LIMITADA", "AUTORIZACION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1985-02-25", "fecha_derogacion": "1997-02-13", "doble_articulado": false, "id_norma": "73352", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1985-03-27