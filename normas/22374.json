{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Sociedad de Artesanos de Taltal Lei n&#xFA;m. 1,048.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948248}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese a la Sociedad de Artesanos de Taltal el permiso requerido por el art&#xED;culo 556 del C&#xF3;digo Civil, para conservar, durante treinta a&#xF1;os, el bien raiz que posee en dicho puerto.</div><br><br></div>", "i": 5948249}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 5 de Julio de 1898.- FEDERICO ERRAZURIZ.- C&#xE1;rlos A. Palacios Z.</div><br></div>", "i": 5948250}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1048", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1048"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "SOCIEDAD DE ARTESANOS DE TALTAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD ARTESANOS", "TALTAL", "BIEN RAIZ", "POSESION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-07-05", "doble_articulado": false, "id_norma": "22374", "numero_fuente": "6042", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-07-06", "vigencias": [{"desde": "1898-07-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-07-06", "fin_vigencia": ""}, "vigen