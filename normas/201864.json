{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6393866}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. N&#xB0; 782, de 30 de septiembre de 1996, se expropi&#xF3; el lote de terreno N&#xB0; 6, superficie 147 m2., rol de aval&#xFA;o 593-45, comuna de Cerrillos, para la obra Camino Autopista Santiago-San Antonio, sector Empalme Isabel Riquelme-Bif. Malloco (Sector Urbano-Carlos Valdovinos-P.A. Cerda), y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Alejandro Le&#xF3;n Rojas y otros, ascendente a la cantidad de $30.346.680.-</div><br></div>", "i": 6393867}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal el Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6393868}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "782", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-782"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-09-30", "doble_articulado": false, "id_norma": "201864", "numero_fuente": "35605", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-11-02", "vigencias": [{"desde": "1996-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PSO", "fecha_ingreso": "2002-08-23", "fecha_version": "1996-11-02", "fecha_actualizacion_texto": "1996-11-02", "tipo_tratado": ""}, "alertas": [], "alerta_global