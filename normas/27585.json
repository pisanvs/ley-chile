{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA EL NOMBRE DE LA CALLE QUE INDICA DE LA LOCALIDAD DE PUERTO SAAVEDRA, POR EL QUE SE&#xD1;ALA Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8281073}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. La calle denominada actualmente &quot;Miguel Anzorena&quot; de la localidad de Puerto Saavedra llevar&#xE1; en lo sucesivo el nombre de &quot;Poeta Augusto Winter&quot;.</div><br></div>", "i": 8281074}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, nueve de junio de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- S&#xF3;tero del R&#xED;o. </div></div>", "i": 8281075}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13949", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13949"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA EL NOMBRE DE LA CALLE QUE INDICA DE LA\nLOCALIDAD DE PUERTO SAAVEDRA, POR EL QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "CALLE POETA AUGUSTO WINTER", "PUERTO SAAVEDRA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-06-09", "doble_articulado": false, "id_norma": "27585", "numero_fuente": "24675", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-06-23", "vigencias": [{"desde": "1960-06-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1960-06-23", "fin_vig