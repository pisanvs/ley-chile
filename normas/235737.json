{"html": [{"t": "<div><div class=\"p\">PRORROGA PLAZO PARA PUBLICAR EXTRACTO</div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n (M) 1.624, de 1 de octubre de 2004, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div><br></div>", "i": 6516777}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ampl&#xED;ase por 45 d&#xED;as, contados desde el tercer d&#xED;a h&#xE1;bil siguiente a aquel en que la carta que transcribe la presente resoluci&#xF3;n sea depositada en el correo, el plazo para publicar en el Diario Oficial el extracto de la resoluci&#xF3;n 1.252, de 6 de junio de 2003, transcrito mediante oficio S.S.M. ordinario 12210/3280 Int., de 8 de agosto de 2003, en raz&#xF3;n de haberse acreditado la ocurrencia de fuerza mayor.</div><br></div>", "i": 6516778}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 5 de enero de 2005.- Por el Subsecretario, Jaime Bravo Busquet, Subjefe Subsecretar&#xED;a de Marina Subrogante.</div><br></div>", "i": 6516779}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1624", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1624"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "PRORROGA PLAZO PARA PUBLICAR EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-01", "doble_articulado": false, "id_norma": "235737", "numero_fuente": "38094", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-02-23", "vigencias": [{"desde": "2005-02-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-02-23", "fin_vigencia"