{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7342961}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.535, de 18 de mayo de 2007, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 5&#xBA; de la resoluci&#xF3;n N&#xBA; 698, modificada mediante resoluciones N&#xBA; 1.123, N&#xBA; 1.351 y N&#xBA; 1.399, todas de 2007, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del proyecto denominado &quot;Caracterizaci&#xF3;n y cuantificaci&#xF3;n de la fauna acompa&#xF1;ante en las capturas de cerco, I y II Regiones&quot;, en el sentido de incorporar a la embarcaci&#xF3;n artesanal &quot;Jehosua Maschiaj&quot; (RPA N&#xBA; 914149), al listado de naves autorizadas para participar en la presente pesca de investigaci&#xF3;n.</div><br></div>", "i": 7342962}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de mayo de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7342963}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1535 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1535 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-05-18", "doble_articulado": false, "id_norma": "261211", "numero_fuente": "327", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-05-30", "vigencias": [{"desde": "2007-05-30", "hasta": "", "tipo_v