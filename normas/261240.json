{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6611457}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.607, de 23 de mayo de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BIO BIO S.A. para realizar actividades extractivas en alta mar con la nave &quot;Biomar IV&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; CB-5301</div><div class=\"p\">Puerto de Matr&#xED;cula&nbsp; &nbsp;  Valpara&#xED;so</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  2846</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; 50,78 m.</div><div class=\"p\">T.R.G. (Internacional)&nbsp; 1037,00</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  11,00 m.</div><div class=\"p\">Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 7,35 m.</div><br></div>", "i": 6611458}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de mayo de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6611459}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1607 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1607 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2007-05-23", "fecha_derogacion": "2016-11-23", "doble_articulado": false, "id_norma": "261240", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2007-05-31", "v