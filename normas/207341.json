{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 20 EXENTO, DE 2003 </div></div>", "i": 6412678}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 20 de fecha 9 de enero de 2003 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a las sedes que se indican del Centro de Formaci&#xF3;n T&#xE9;cnica Salesianos Don Bosco, para impartir planes y programas de estudios antes aprobados para la instituci&#xF3;n, de las carreras y t&#xED;tulos t&#xE9;cnicos de nivel superior que se se&#xF1;alan, a partir del a&#xF1;o 2003:</div><br><div class=\"p\">SEDES N&#xBA; 1 - LA SERENA, N&#xBA; 4 - TALCA Y N&#xBA; 7 -PUERTO MONTT</div><br><div class=\"p\">Carrera : Mec&#xE1;nica Automotriz.</div><div class=\"p\">T&#xED;tulo&nbsp; : T&#xE9;cnico de Nivel Superior en Mec&#xE1;nica</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Automotriz</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; (Dex. N&#xBA; 639 de 11.09.01).</div><br><div class=\"p\">SEDE N&#xBA; 6 - CONCEPCION</div><br><div class=\"p\">Carrera : Electricidad Industrial.</div><div class=\"p\">T&#xED;tulo&nbsp; : T&#xE9;cnico de Nivel Superior en Electricidad</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Industrial</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; (Dex. N&#xBA; 639 de 11.09.01).</div><br></div>", "i": 6412679}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de enero de 2003.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6412680}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "20 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-20 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 20 EXENTO, DE 2003", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [