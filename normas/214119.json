{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6437479}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;67, de 25 julio 2003, Serviu Regi&#xF3;n Tarapac&#xE1;, conforme D.L. N&#xBA;1.523/1976; N&#xBA;2.186/1978 y D.S.</div><div class=\"p\">N&#xBA;355/76, 131 de 2002, y 71/2003, todos de Vivienda y Urbanismo, dispuso expropiaci&#xF3;n parte del inmueble ubicado en Iquique, calle Las Cabras N&#xBA;13, rol aval&#xFA;o 11-06, de presunto dominio de Juan Negr&#xF3;n Iturra. Comisi&#xF3;n integrada por peritos H&#xE9;ctor Ruiz Le-Beuffe, arquitecto y se&#xF1;ores Gast&#xF3;n Gonz&#xE1;lez Kemnis y Oscar Esc&#xE1;rate Arancibia, Constructores Civiles, seg&#xFA;n informe tasaci&#xF3;n de 24 julio 2003, fij&#xF3; monto provisional de indemnizaci&#xF3;n en $8.000.000 pagadera al contado.</div><br></div>", "i": 6437480}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Dina Tarraza Lovazzano, Directora Serviu Regi&#xF3;n de Tarapac&#xE1;.</div><br></div>", "i": 6437481}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "67", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-67"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DISPONE EXPROPIACIONES DE INMUEBLES QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-07-25", "doble_articulado": false, "id_norma": "214119", "numero_fuente": "37649", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-01", "vigencias": [{"desde": "2003-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-01", "fin_vigencia": ""}, "vigencias_version_nor