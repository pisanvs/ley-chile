{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6583525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.531, de 29 de agosto de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a RIGOBERTO FRANCISCO VARNET BARRIENTOS, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Avenida Mocopulli, Km. 1.8 (rural), Dalcahue, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco Enfriado, Fresco Refrigerado, Congelado, Seco Salado, Ahumado, Conserva y Alga Seca los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1.968 de 2006, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6583526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de agosto de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6583527}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2531 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2531 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-08-29", "doble_articulado": false, "id_norma": "253464", "numero_fuente": "38569", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-09-21", "vigencias": [{"desde": "2006-09-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia