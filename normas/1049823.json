{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9341355}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 812, de 25 de marzo de 2013, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la <a href=\"https://www.leychile.cl/Navegar?idNorma=188298&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.598, de 2001</a>, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA CONCEPCI&#xD3;N LTDA., para ampliar actividades pesqueras extractivas con la nave &quot;Hecht&quot;, respecto del recurso hidrobiol&#xF3;gico Jibia en el &#xE1;rea mar&#xED;tima comprendida entre la IV Regi&#xF3;n y el paralelo 41&#xB0;28,6&apos; L.S., en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum citado en Visto de la resoluci&#xF3;n extractada.</div></div>", "i": 9341356}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de marzo de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9341357}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "812 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-812 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-03-25", "doble_articulado": false, "id_norma": "1049823", "numero_fuente": "40523", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-04-02", "vigencias": [{"desde": "2013-04-02", "hasta": "", "tipo_version": "3", "