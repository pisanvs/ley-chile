{"html": [{"t": "<div><div class=\"p\">PARTIDO DEMOCRATA CRISTIANO </div></div>", "i": 6043123}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Enrique Krauss Rusque y Rafael Moreno Rojas, Presidente y Secretario, respectivamente, en representaci&#xF3;n del Partido Dem&#xF3;crata Cristiano, y Christi&#xE1;n Acu&#xF1;a Fern&#xE1;ndez, Secretario del Tribunal Supremo de la colectividad, han informado el nombramiento como Tesorero del partido del se&#xF1;or Jorge Mac-Ginty Gaete, en reemplazo del se&#xF1;or Antonio Mahana Lues.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada en virtud de lo establecido en el Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por Resoluci&#xF3;n O-N&#xBA; 0713 de fecha 12 de agosto de&nbsp; 1997.</div><br></div>", "i": 6043124}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de agosto de 1997.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6043125}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "713", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-713"}, {"tipo": "3", "numero": "O-0713", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-0713"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO DEMOCRATA CRISTIANO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO DEMOCRATA CRISTIANO", "JORGE MAC-GINTY GAETE", "TESORERO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-08-12", "doble_articulado": false, "id_norma": "74911", "numero_fuente": "35842", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-08-14", "vigencias": [{"desde": "1997-08-14", "hasta": ""