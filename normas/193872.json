{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6366245}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 41, de 9 de enero de 2002, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las resoluciones N&#xBA; 275 de 1997 y N&#xBA; 1.131 de 2001, ambas de esta Subsecretar&#xED;a, que autorizaron a don MARIO ORELLANA PALMA, para operar la nave &quot;Claevelkaren&quot;, matr&#xED;cula 340, en virtud de lo se&#xF1;alado en el Art. 143 letra b) del D.S. N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6366246}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de enero de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6366247}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "41", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-41"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-01-09", "doble_articulado": false, "id_norma": "193872", "numero_fuente": "37162", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-17", "vigencias": [{"desde": "2002-01-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JRC", "fecha_ingreso":