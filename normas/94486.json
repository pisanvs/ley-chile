{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.342, DE 1989 </div></div>", "i": 7228736}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n Exenta No. 1.342 de fecha 05 de mayo de 1989 de la Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica, se aprobaron las modificaciones introducidas al siguiente plan y programas de estudio del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto de Electr&#xF3;nica Gamma de Santiago, de la carrera y t&#xED;tulo t&#xE9;cnico que se indica, para impartirse a contar del a&#xF1;o 1989:</div><div class=\"p\">Carrera: Electr&#xF3;nica</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico Superior en Electr&#xF3;nica con menci&#xF3;n en:</div><div class=\"p\">- Sonido y Recepci&#xF3;n AM FM - TV</div><div class=\"p\">- Microcomputadores</div><div class=\"p\">- Video</div><div class=\"p\">- Sistemas Microcomputadores de Inform&#xE1;tica y Control.</div><br><br></div>", "i": 7228737}, {"t": "<div><div class=\"p\">Santiago, 01 de Junio de 1989.- Mar&#xED;a, Sixtina Barriga Guzm&#xE1;n, Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 7228738}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1342 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1342 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.342, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-05", "doble_articulado": false, "id_norma": "94486", "numero_fuente": "33395", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-06-12", "vigencias":