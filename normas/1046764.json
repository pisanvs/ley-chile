{"html": [{"t": "<div><br><div class=\"p\">ACOGE RECURSO QUE INDICA</div></div>", "i": 9319582}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por R. M. Ex. N&#xBA; 204, de 5 de noviembre de 2012, de este Ministerio, ac&#xF3;gese el recurso extraordinario de revisi&#xF3;n interpuesto por don Jerisvaldo Leonel Godoy Almonacid, en contra de la R. Ex. N&#xBA; 2.005 de 2011, de la entonces Subsecretar&#xED;a de Pesca.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la caducidad declarada por la <a href=\"https://www.leychile.cl/Navegar?idNorma=1027384&amp;idParte=&amp;idVersion=\">R. Ex. N&#xBA; 1.314, de 2011</a>, del entonces Servicio Nacional de Pesca, &#xFA;nicamente respecto de la inscripci&#xF3;n en el Registro Pesquero Artesanal de la embarcaci&#xF3;n &quot;Scarlett II&quot;, RPA918169, matr&#xED;cula MAU-4118, armador Jerisvaldo Leonel Godoy Almonacid, RUT 13.122.684-5.</div><br></div>", "i": 9319583, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 5 de noviembre de 2012.- Pablo Longueira Montes, Ministro de Econom&#xED;a, Fomento y Turismo.</div></div>", "i": 9319585}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "204 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-204 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE ECONOMÍA Y EMPRESAS DE MENOR TAMAÑO"], "titulo_norma": "ACOGE RECURSO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-11-05", "doble_articulado": false, "id_norma": "1046764", "numero_fuente": "40435", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "