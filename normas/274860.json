{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESI&#xD3;N ORDINARIA N&#xBA; 1.425</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n Ordinaria N&#xBA; 1.425, celebrada el 24 de julio de 2008, adopt&#xF3; el siguiente Acuerdo:</div><br><div class=\"p\">1425-01-080724 - Comisi&#xF3;n Chilena del Cobre (COCHILCO) - Designa representante del Banco Central de Chile.</div><br></div>", "i": 8437372}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Designar a don Felipe Jaque Sarro, como Representante del Banco Central de Chile ante el Consejo de la Comisi&#xF3;n Chilena del Cobre, todo ello en conformidad al Art&#xED;culo 4&#xB0; del D.L. N&#xBA; 1.349, de 1976, a contar del 25 de julio de 2008 y hasta el 21 de octubre de 2008.</div><br></div>", "i": 8437373}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de julio de 2008.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 8437374}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1425", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1425"}, {"tipo": "5", "numero": "1425-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1425-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESIÓN\nORDINARIA Nº 1.425", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-07-24", "doble_articulado": false, "id_norma": "274860", "numero_fuente": "39122", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-07-26", "vigencias": [{"desde": "2008-07-26", "hasta": "", "tipo_version": "3", "