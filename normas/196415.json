{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6375613}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA; 09, de fecha 20 de enero de 2000, se aprob&#xF3; la disoluci&#xF3;n voluntaria de la Cooperativa de Vivienda y Servicios Habitacionales El Toro Limitada, de Talca, que consta en la escritura p&#xFA;blica suscrita con fecha 23 de agosto y 16 de noviembre de 1999, ante el Notario P&#xFA;blico de Talca, don H&#xE9;ctor Manuel Ferrada.</div><br></div>", "i": 6375614}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Subsecretario, Cecilia Gonz&#xE1;lez Mart&#xED;nez, Jefe Departamento de Cooperativas Subrogante, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n . </div></div>", "i": 6375615}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-9"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-20", "doble_articulado": false, "id_norma": "196415", "numero_fuente": "37227", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-05", "vigencias": [{"desde": "2002-04-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-04-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-04-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu