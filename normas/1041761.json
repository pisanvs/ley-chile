{"html": [{"t": "<div><br><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESI&#xD3;N N&#xB0; 1684</div></div>", "i": 9273996}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile, en su Sesi&#xF3;n N&#xB0; 1684, celebrada el 14 de junio de 2012, adopt&#xF3; el siguiente Acuerdo:</div><br><div class=\"p\">Acuerdo N&#xB0; 1684-01-120614 &#x2013; Designaci&#xF3;n de Ministro de Fe Subrogante reca&#xED;da en el Abogado Jefe de Servicios Legales se&#xF1;or Javier Allard Soto.</div><br><div class=\"p\">&nbsp; &nbsp;  Designar, a contar del 11 de julio de 2012, en el cargo de Ministro de Fe Subrogante al se&#xF1;or Javier Allard Soto.</div></div>", "i": 9273997}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de julio de 2012.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div></div>", "i": 9273998}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1684", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1684"}, {"tipo": "5", "numero": "1684-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1684-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESIÓN N° 1684", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-11", "doble_articulado": false, "id_norma": "1041761", "numero_fuente": "40311", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-07-13", "vigencias": [{"desde": "2012-07-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-07-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v