{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.265 EXENTO, DE 1997 </div></div>", "i": 7224560}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 1.265 de 31 de diciembre de 1997, se ha modificado el Decreto Supremo Exento de Educaci&#xF3;n N&#xBA; 597 de 1993, que aprob&#xF3; planes y programas de estudio a la Escuela Especial Diferencial &quot;Juan Sandoval Carrasco&quot; (Ex F N&#xBA; 86) de la Regi&#xF3;n Metropolitana, dependiente de la Ilustre Municipalidad de Santiago, en el sentido de sustituir el plan de estudio por el que se indica en el presente decreto.</div><br></div>", "i": 7224561}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de enero de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7224562}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1265 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1265 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.265 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PROGRAMAS DE ESTUDIO", "PLANES DE ESTUDIO", "ESCUELA ESPECIAL DIFERENCIAL JUAN SANDOVAL CARRASCO", "REGION METROPOLITANA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-31", "doble_articulado": false, "id_norma": "89933", "numero_fuente": "35976", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-28", "vigencias": [{"desde": "1998-01-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici