{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 7</div></div>", "i": 9851003}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.647, de 8 de noviembre de 2017, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1101754&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 1.185, de 2017</a>, de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 7, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para el centro de cultivo que se indica en la resoluci&#xF3;n extractada.</div></div>", "i": 9851004}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de noviembre de 2017.- Paolo Trejo Carmona, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9851005}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3647 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3647 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 7", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; CVE 1304355"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-11-08", "doble_articulado": false, "id_norma": "1111041", "numero_fuente": "41911", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-11-18", "vigencias": [{"desde": "2017-11-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"