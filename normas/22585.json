{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Declara libres de derechos de internacion ciertos art&#xED;culos</div><div class=\"p\">&nbsp; &nbsp; Ley 1355</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br><br><br></div>", "i": 5948965}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se declaran libres de derechos de internacion los frascos de vidrio con tapa de metal o de goma automatica i los tapones de goma.</div><br></div>", "i": 5948966}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 20 de Agosto de 1900.- ELIAS FERNANDEZ A.- Manuel Salinas.</div><br></div>", "i": 5948967}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1355", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1355"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "Que declara libres de derechos de internacion;ciertos artículos", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FRASCO VIDRIO TAPA METALICA", "DERECHOS", "INTERNACION", "FRASCO VIDRIO TAPA GOMA AUTOMATICA", "EXENCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["LA PRESENTE LEY HA SIDO PUBLICADA EN EL D. OFICIAL CON EL Nº 1455"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-08-20",