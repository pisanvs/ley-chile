{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 96,DE 1990 </div></div>", "i": 6067006}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 96 de 07 de marzo de 1990 se ha aprobado, a partir del a&#xF1;o escolar 1990, un plan especial de estudio al Colegio del Sagrado Coraz&#xF3;n Apoquindo, de Santiago, para la Educaci&#xF3;n Media Human&#xED;stico Cient&#xED;fica, el que se aplicar&#xE1; simult&#xE1;neamente en todos los cursos del nivel se&#xF1;alado.</div><br></div>", "i": 6067007}, {"t": "<div><div class=\"p\">Santiago, 09 de Marzo de 1990.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6067008}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "96 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-96 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO\nEXENTO No. 96,DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-07", "doble_articulado": false, "id_norma": "84133", "numero_fuente": "33626", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-21", "vigencias": [{"desde": "1990-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-03-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-03-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MNV", "fecha_ingreso": "1998-01-12", "fecha_version": "1990-03-21", "fecha_actualizacion_t