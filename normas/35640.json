{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294367}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 819, de 6 de mayo de 1996, de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por MARINE FARMS</div><div class=\"p\">CHILE S.A., para un centro de cultivo ubicado en Weste</div><div class=\"p\">Isla Guar, comuna de Puerto Montt, provincia de</div><div class=\"p\">Llanquihue, X Regi&#xF3;n, por no dar cumplimiento el</div><div class=\"p\">respectivo proyecto t&#xE9;cnico a lo dispuesto en los</div><div class=\"p\">art&#xED;culos 77&#xB0; y 87&#xB0; de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8294368}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 6 de mayo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294369}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "819", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-819"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "MARINE FARMS CHILE S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-06", "doble_articulado": false, "id_norma": "35640", "numero_fuente": "35464", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-05-11", "vigencias": [{"desde": "1996-05-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_