{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9317907}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.146, de 3 de diciembre de 2012, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las resoluciones exentas N&#xBA; 2.510 de 2001 y <a href=\"https://www.leychile.cl/Navegar?idNorma=214954&amp;idParte=&amp;idVersion=\">N&#xBA; 1.959 de 2003</a>, s&#xF3;lo en cuanto autorizaron a SOCIEDAD PESQUERA GENMAR LIMITADA para ampliar actividades pesqueras extractivas con la nave &quot;Don Chelo I&quot;, respecto del recurso hidrobiol&#xF3;gico Jibia Dosidicus gigas en el &#xE1;rea mar&#xED;tima correspondiente a la VIII Regi&#xF3;n, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura, y lo informado mediante memor&#xE1;ndum citado en Visto de la resoluci&#xF3;n extractada.</div><br></div>", "i": 9317908, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de diciembre de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9317909}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3146 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3146 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2012-12-03", "fecha_derogacion": "2013-01-25", "doble_articulado": false, "id_norma": "1046623", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2012-12-10", "vigencias": [{"desde": "2013-01-25", "hasta": "",