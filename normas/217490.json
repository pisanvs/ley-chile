{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6449281}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de noviembre de 2003, fue de 3,28% anual.</div><br></div>", "i": 6449282}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, noviembre 17 de 2003.- Miguel Angel Nacrur Gazali, Ministro de Fe </div></div>", "i": 6449283}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "MODIFICA DECRETO Nº 511 EXENTO, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-11-17", "doble_articulado": false, "id_norma": "217490", "numero_fuente": "37714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-11-19", "vigencias": [{"desde": "2003-11-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-11-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-11-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2003-11-19", "fecha_version": "2003-11-19", "fecha_actualizacion_texto": "2003-11-19", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6449281