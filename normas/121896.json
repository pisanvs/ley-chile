{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  EXCEPCIONA DEL REGIMEN DE CAMBIO DE SUJETO DEL IVA A RENE FERNANDEZ DIEZ</div><br><br><br></div>", "i": 6121357}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional del SII, por resoluci&#xF3;n DRE09.00 N&#xBA;Ex. 281 de fecha 7 de julio de 1998, excepciona, a contar del 1&#xBA; del mes siguiente&nbsp; al de esta publicaci&#xF3;n y hasta el 31 de julio de 1999, a Ren&#xE9; Fern&#xE1;ndez Diez, Rut N&#xBA;2.219.240-K, del r&#xE9;gimen de cambio de sujeto del Impuesto al Valor Agregado, en las operaciones de ganado vivo, establecido en la resoluci&#xF3;n N&#xBA;Ex. 2.379/98 de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del 24/04/98, Diario Oficial del d&#xED;a 30.06.98. El peticionario excepcionado pasa a tener la calidad de retenedor del Impuesto al Valor Agregado en sus operaciones de ganado vivo.-</div><br></div>", "i": 6121358}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Cornejo C&#xE1;ceres, Director Regional. </div></div>", "i": 6121359}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "281 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-281 EXENTA"}, {"tipo": "3", "numero": "DRE-09-00-281 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-09-00-281 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "EXCEPCIONA DEL REGIMEN DE CAMBIO DE SUJETO DEL IVA A RENE FERNANDEZ DIEZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO DE SUJETO DE DERECHO", "IMPUESTO AL VALOR AGREGADO", "GANADO VIVO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promul