{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6656063}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP. N&#xBA; 417 de 30 de junio de 2008, y en base a la facultad otorgada por el art&#xED;culo 105 del D.F.L. M.O.P. N&#xBA; 850 de 1997, que fij&#xF3; el texto actualizado de la ley N&#xBA; 15.840, se expropi&#xF3; el lote de terreno N&#xBA; 36, para la ejecuci&#xF3;n de la obra &quot;Canal Nuevo Cocinera&quot;, comuna de Illapel, Provincia de Choapa, Regi&#xF3;n de Coquimbo, que figura a nombre de Cooperativa Agr&#xED;cola de Coloni, rol de aval&#xFA;o 419-6, superficie 134.240 m2. La Comisi&#xF3;n de Peritos, fij&#xF3; con fecha 21 de abril de 2008, en la cantidad de $33.836.000. La indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.</div><br></div>", "i": 6656064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6656065}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "417", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-417"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-06-30", "doble_articulado": false, "id_norma": "275136", "numero_fuente": "39127", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-08-01", "vigencias": [{"desde": "2008-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-08-01", "fin_vigencia": ""}, "vigen