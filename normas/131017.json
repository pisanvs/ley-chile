{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8910258}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;108, de 21 de enero de 1999, de</div><div class=\"p\">esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las</div><div class=\"p\">resoluciones N&#xBA;1.404, N&#xBA;1.405 y N&#xBA;1.406, todas de 1992,</div><div class=\"p\">de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD PESQUERA</div><div class=\"p\">MAMI&#xD1;A S.A., para operar las naves &apos;&apos;Octopus&apos;&apos;,</div><div class=\"p\">&apos;&apos;Tacora&apos;&apos; y &apos;&apos;Mami&#xF1;a&apos;&apos;, por haber suspendido</div><div class=\"p\">actividades por m&#xE1;s de 12 meses sucesivos y encontrarse</div><div class=\"p\">en mora del pago de la patente &#xFA;nica pesquera,</div><div class=\"p\">configur&#xE1;ndose las causales de caducidad previstas en el</div><div class=\"p\">art&#xED;culo 143 letras b) y d) de la Ley General de Pesca y Acuicultura, respectivamente.</div><br></div>", "i": 8910259}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de enero de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8910260}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "108", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-108"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-01-21", "doble_articulado": false, "id_norma": "131017", "numero_fuente": "36278", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "