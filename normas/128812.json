{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.180 EXENTA, DE 1998 </div><br></div>", "i": 6144963}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.180 de fecha 2 de</div><div class=\"p\">noviembre de 1998 se ordena publicar delegaci&#xF3;n de</div><div class=\"p\">funciones Director Nacional Servicio M&#xE9;dico Legal de</div><div class=\"p\">visar y firmar informes de alcoholemia, exigido por</div><div class=\"p\">art&#xED;culo 122 de la Ley de Alcoholes y 190 de la Ley de Tr&#xE1;nsito en el Jefe del Departamento de Laboratorios del Servicio M&#xE9;dico Legal o en la Qu&#xED;mico Farmac&#xE9;utico Legista Sara Gatica Inostroza o Encargados Regionales del Servicio, de la manera y en la forma se&#xF1;alada en la resoluci&#xF3;n exenta indicada precedentemente.</div><br></div>", "i": 6144964}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jos&#xE9; Luis V&#xE1;squez Fern&#xE1;ndez, Director Nacional (S).</div><br></div>", "i": 6144965}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1180 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1180 EXENTA"}], "organismos": ["SERVICIO MÉDICO LEGAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.180 EXENTA, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-02", "doble_articulado": false, "id_norma": "128812", "numero_fuente": "36252", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-12-31", "vigencias": [{"desde": "1998-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-12-31", "fin_vigencia": ""}, "vigencias_versio