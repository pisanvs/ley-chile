{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6330771}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 276, de 28 de febrero de 2001, se expropi&#xF3; el lote de terreno N&#xBA; 194-3, superficie 887 m2., rol de aval&#xFA;o 179-338, comuna de Nogales, para la obra Camino Ruta 5 Norte. Tramo: Santiago-Los Vilos, Quinta Regi&#xF3;n, y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Silvia Elena Olivares Villal&#xF3;n y otro, ascendente a la cantidad de $21.840.402.-</div><br></div>", "i": 6330772}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6330773}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "276", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-276"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-28", "doble_articulado": false, "id_norma": "184130", "numero_fuente": "36938", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-04-16", "vigencias": [{"desde": "2001-04-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-04-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-04-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2001-04-17", "fecha_version": "2001-04-16", "fecha_actualizacion_texto": "2001-04-16", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 63307