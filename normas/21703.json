{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 693 EXENTO, DE 1993 </div></div>", "i": 7162226}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0;693 de 27 de diciembre de 1993 se ha modificado el decreto supremo exento de Educaci&#xF3;n N&#xB0; 361 de 1990, que aprob&#xF3; un plan especial de estudio al Liceo &quot;Miguel Luis Amun&#xE1;tegui&quot;, de Santiago.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio para las asignaturas de Dactilograf&#xED;a y de Computaci&#xF3;n. </div></div>", "i": 7162227}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 30 de Diciembre de 1993.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7162228}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "693 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-693 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 693 EXENTO, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "LICEO MIGUEL LUIS AMUNATEGUI", "SANTIAGO", "REGION METROPOLITANA", "PROGRAMAS ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-12-27", "doble_articulado": false, "id_norma": "21703", "numero_fuente": "34761", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-01-11", "vigencias": [{"desde": "1994-01-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-01-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-01-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient