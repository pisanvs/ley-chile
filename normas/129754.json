{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6147933}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as fue de 4.91% anual durante el mes de julio de 1988.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1 del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables de 90 a 365 d&#xED;as, correspondiente a la segunda quincena de julio de 1988, fue de 4.72% anual. </div></div>", "i": 6147934}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 02 de agosto de 1988.- Loreto Moya Gonz&#xE1;lez, Secretario General Subrogante.</div><br></div>", "i": 6147935}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-02", "doble_articulado": false, "id_norma": "129754", "numero_fuente": "33137", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-08-03", "vigencias": [{"desde": "1988-08-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-08-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-08-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT