{"html": [{"t": "<div><div class=\"p\">MODIFICA ORDENANZA No. 1 DE 1988 </div></div>", "i": 8930656}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case la Ordenanza No. 1 de 30.12.88, sobre Derechos Municipales de la Comuna de San Miguel, a regir en 1989, en el sentido siguiente:</div><br><div class=\"p\">- El T&#xED;tulo V, Art. 12, No. 5, dice&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &quot;50% UTM&quot;.</div><div class=\"p\"> debe decir&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  &quot; 5% UTM&quot;.</div><div class=\"p\">- El T&#xED;tulo VI, Art. 13, No. 5, dice&nbsp; &nbsp; &quot;por Trimestre o</div><div class=\"p\"> fracci&#xF3;n, por metro ocupado (o fracci&#xF3;n)&quot;, debe decir</div><div class=\"p\"> &quot;por semestre o fracci&#xF3;n, por metro ocupado (o</div><div class=\"p\"> fracci&#xF3;n)&quot;.</div><div class=\"p\">- El T&#xED;tulo VII, Art. 15, No. 1, Letra a. dice &quot;85% UTM&quot;</div><div class=\"p\"> debe decir&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  &quot;50% UTM&quot;</div><div class=\"p\"> Letra b. dice&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &quot;80% UTM&quot;</div><div class=\"p\"> debe decir&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  &quot;50% UTM&quot;</div><div class=\"p\"> Letra c. dice,&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  &quot;35% UTM&quot;</div><div class=\"p\"> debe decir&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  &quot;25% UTM&quot;</div><div class=\"p\">- El T&#xED;tulo VII, Art. 15, No. 2 dice&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  &quot;25% UTM&quot;</div><div class=\"p\">&nbsp; debe decir&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  &quot;20% UTM&quot;</div><div class=\"p\">- El T&#xED;tulo VII, Art. 15 No. 5, se elimina por completo.-</div><br></div>", "i": 8930658}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Alcalde.</div><br></div>", "i": 8930659}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "S/N", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "ORZ-S/N"}], "organismos": ["MUNICIPALIDAD DE SAN MIGUEL"], "titulo_norma": "MODIFICA ORDENANZA No. 1 DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "182062", "numero_fuente": "33286", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-01-31", "vigencias": [{"desde": "1989-01-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-01-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-01-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2001-02-21", "fecha_version": "1989-01-31", "fecha_actualizacion_texto": "1989-01-31", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8930656}, {"n": "Artículo", "i": 8930658, "t": 6}, {"n": "Promulgación", "i": 8930659}]}