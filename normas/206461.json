{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6409143}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.946 de 20 de diciembre de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA MAR PROFUNDO S.A. para realizar actividades extractivas en aguas internacionales con la nave &quot;Arauco I&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  2621</div><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; CB-4071</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 54,29 m</div><div class=\"p\">T.R.G. (Internacional)&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 802,87</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  1201,92 m3</div><div class=\"p\">Potencia Motor principal&nbsp; &nbsp; &nbsp; &nbsp; 1750,00 Hp</div><div class=\"p\">Potencia Motor auxiliar&nbsp; &nbsp; &nbsp; &nbsp;  101,00 Hp</div><br></div>", "i": 6409144}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de diciembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6409145}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2946", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2946"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-20", "doble_articulado": false, "id_norma": "206461", "nume