{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6553931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.923, de 18 de noviembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a WALTERIO ARAUCO SALINAS, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en el sector La Ensenada, Km. 2,5 del camino Licanray - Co&#xF1;aripe, comuna de Villarrica, IX Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Ahumado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6553932}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de noviembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6553933}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3923 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3923 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-18", "doble_articulado": false, "id_norma": "245366", "numero_fuente": "38342", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-12-21", "vigencias": [{"desde": "2005-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-12-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-12-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingre