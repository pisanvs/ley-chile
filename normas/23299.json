{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza la cancelacion de cuentas pendientes del Ministerio de Justicia</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,425.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5953395}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que invierta hasta ciento viente mil pesos en la cancelacion de cuentas anteriores que existen pendientes en el Ministerio de Justicia. </div></div>", "i": 5953396}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se prom&#xFA;lgue i ll&#xE9;ve a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 12 de Diciembre de 1910.- EMILIANO FIGUEROA.- Carlos Balmaceda S.</div><br></div>", "i": 5953397}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2425", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2425"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "AUTORIZA LA CANCELACION DE CUENTAS PENDIENTES DEL MINISTERIO DE JUSTICIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MINISTERIO JUSTICIA", "CUENTAS PENDIENTES", "CANCELACION", "FONDOS", "INVERSION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-12-12", "doble_articulado": false, "id_norma": "23299", "numero_fuente": "9854", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-12-14", "vigencias": [{"desde": "1910-12-14", "hasta": "", "tipo_version": "3", "tipo_vers