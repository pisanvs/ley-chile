{"html": [{"t": "<div><div class=\"p\">RECTIFICA DECRETO EXENTO No. 100, DE 1990</div><br><div class=\"p\">N&#xFA;m. 125 exento.- Santiago, 09 de Abril de 1990.- Visto: Lo dispuesto en el decreto ley No. 3.541 de 1980, DFL No. 5 de 1981 y decreto exento No. 100 de 1990 del Ministerio de Educaci&#xF3;n.</div><br><div class=\"p\">Decreto:</div><br></div>", "i": 7224331}, {"t": "<div><div class=\"p\">Art&#xED;culo &#xFA;nico.- Rectif&#xED;case decreto exento No. 100 de 07 de Marzo de 1990 en su art&#xED;culo &#xFA;nico en el siguiente sentido: dice: ciudad de Talca, calle Uno Oriente No. 1372 debe decir: ciudad de Talca, calle Uno Oriente No. 1342 </div></div>", "i": 7224332, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">An&#xF3;tese, publ&#xED;quese en el Diario Oficial con cargo al interesado.- Ricardo Lagos Escobar, Ministro de Educaci&#xF3;n P&#xFA;blica.</div><div class=\"p\">Lo que transcribo a usted para su conocimiento.- Saluda atentamente a usted.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7224333}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "125 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-125 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "RECTIFICA DECRETO EXENTO No. 100, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-04-09", "doble_articulado": false, "id_norma": "89638", "numero_fuente": "33663", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-05-07", "vigencias": [{"desde": "1990-05-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni