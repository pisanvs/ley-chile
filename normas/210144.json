{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6423395}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 847, de 16 de abril de 2003, de</div><div class=\"p\">esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; PESQUERA LOTA VEDDE</div><div class=\"p\">S.A. SANTA MARIA Y COMPA&#xD1;IA COMANDITA POR ACCIONES para</div><div class=\"p\">ampliar actividades pesqueras extractivas con una nave</div><div class=\"p\">en construcci&#xF3;n autorizada por resoluci&#xF3;n N&#xBA; 2.869, de</div><div class=\"p\">2002, de esta Subsecretar&#xED;a, en la V a VII Regiones, y</div><div class=\"p\">en la IX Regi&#xF3;n, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, con cerco, donde podr&#xE1; capturar el recurso hidrobiol&#xF3;gico Vinciguerria Vincigerria sp </div></div>", "i": 6423396}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de abril de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6423397}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "847", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-847"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-04-16", "fecha_derogacion": "2003-08-29", "doble_articulado": false, "id_norma": "210144", "numero_fuente": "37554", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-05-09", "vigencias": [{"desde": "2003-08-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-05-09", "hasta": "20