{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6009373}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 334 de fecha 9 de Diciembre 1993, del SERVIU V Regi&#xF3;n Valpara&#xED;so, se dispuso expropiaci&#xF3;n conforme art&#xED;culo 87 Ley N&#xB0; 8.946; D.L. N&#xB0; 2.186, de 1978, de dos franjas denominadas B1 y B2 de inmueble de dominio Empresa de los Ferrocarriles del Estado, rol aval&#xFA;o 95101-1, entre calles Bohn, Alvarez y Plaza Sucre, comuna Vi&#xF1;a del Mar. Comisi&#xF3;n tasadora integrada por Sres. Alvaro Verdejo Vidal, Pablo Caria Giurici, constructores civiles, y y Osvaldo Mu&#xF1;oz Quintana, arquitecto, seg&#xFA;n Informe de fecha 15 de Noviembre de 1993, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 14.500.000.- que ser&#xE1; pagada de contado.</div><br></div>", "i": 6009374}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director SERVIU V Regi&#xF3;n.</div><br></div>", "i": 6009375}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "334", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-334"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DECRETO EXPROPIATORIO", "EXPROPIACION", "BIEN INMUEBLE", "BIEN RAIZ", "VI A DEL MAR", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-12-09", "doble_articulado": false, "id_norma": "34356", "numero_fuente": "34754-2", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-01-03", "vigencias": [{"desde": "1994-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-01-03", "fin_vigencia": ""}, "vigencias_v