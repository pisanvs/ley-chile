{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10326866}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 31, de 11 de abril de 2022, que establece: El Servicio de Impuestos Internos autoriza a Edenred Chile S.A. y a Esmax Distribuci&#xF3;n SpA, para operar en conjunto un sistema de intermediaci&#xF3;n de venta de combustibles y lubricantes, denominado &quot;Ticket Car&quot;, el cual operar&#xE1; supeditado al cumplimiento de requisitos establecidos.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl).- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10326867}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Hern&#xE1;n Frigolett C&#xF3;rdova, Director.</div><div class=\"p\"> </div><br></div>", "i": 10326868}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "31 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-31 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2113862", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-04-11", "doble_articulado": false, "id_norma": "1174723", "numero_fuente": "43229", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-04-14", "vigencias": [{"desde": "2022-04-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2022-04-14", "fin_vigencia": ""},