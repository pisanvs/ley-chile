{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6267873}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.908, de Diciembre 28 de 1984, de la Secretar&#xED;a regi&#xF3;nal Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana, se autoriza a don Antonio Petrillo Ovidiano, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6267874}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, Enero 07 de 1985.Carlos Rom&#xE1;n Toro, Secretario regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6267875}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1908 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1908 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-12-28", "doble_articulado": false, "id_norma": "166403", "numero_fuente": "32082", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-01-28", "vigencias": [{"desde": "1985-01-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-01-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-01-28", "fin_vigencia": "", "tipo_version"