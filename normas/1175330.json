{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10329232}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xB0; 356, de 1 de marzo de 2022, deroga la <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=1160858&amp;idVersion=2022-04-26\">resoluci&#xF3;n exenta N&#xB0; 988, de fecha 28 de mayo de 2021</a>, y sus modificaciones posteriores, las que determinaron el listado de prestaciones del Instituto de Salud P&#xFA;blica de Chile que se mantendr&#xE1;n suspendidas mientras durase la alerta sanitaria decretada por la pandemia del virus SARS-Cov-2.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.-</div><div class=\"p\">&nbsp; &nbsp;  </div><br></div>", "i": 10329233, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Heriberto Garc&#xED;a Escorza, Director (S), Instituto de Salud P&#xFA;blica de Chile.</div><br></div>", "i": 10329234}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "356 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-356 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": ["CORONAVIRUS COVID-19", "CORONAVIRUS", "COVID-19"], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2119265", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-03-01", "doble_articulado": false, "id_norma": "1175330", "numero_fuente": "43237", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-04-26", "vigencias": [{"desde": "2022-04-26", "hasta":