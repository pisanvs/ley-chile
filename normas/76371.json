{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUAS EN COMUNA DE PERALILLO </div></div>", "i": 6047574}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n</div><div class=\"p\">exenta N&#xBA; 2.964 de 6 de octubre de 1997, conforme</div><div class=\"p\">art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, determin&#xF3; Derechos Aprovechamiento de Aguas proporcionales que corresponden a las&nbsp; Parcelas N&#xBA;s. 7, 15, 16, 17 y 18; parte de las Parcelas N&#xBA;s. 4, 6, 8, 9, 10, 11, 12, 13 y 14 y Sitio N&#xBA; 20 del Proyecto de Divisi&#xF3;n de los Terrenos de la Cooperativa de Reforma Agraria Asignataria El Barco Limitada, de la comuna de Palmilla, VI Regi&#xF3;n.</div><br><div class=\"p\">&nbsp; &nbsp;  Los derechos de agua se extraen del Canal El Alto, proveniente de derrames de la antigua&nbsp; Hacienda Colchagua.</div><br></div>", "i": 6047575}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13 Ley N&#xBA; 18.377.- Director Nacional.</div><br></div>", "i": 6047576}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2964 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2964 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUAS EN COMUNA DE PERALILLO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHOS DE AGUA", "PERALILLO", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-10-06", "doble_articulado": false, "id_norma": "76371", "numero_fuente": "35891", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-10-15