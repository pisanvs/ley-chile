{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Montepio Lei n&#xFA;m. 138.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto del Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI</div><br><br><br></div>", "i": 5946889}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese a do&#xF1;a Eulalia del C&#xE1;rmen ydo&#xF1;a Eugenia Rosa Plaza, nietas leg&#xED;timas del sarjento mayor graduado de la independencia don Jos&#xE9; Plaza, el montep&#xED;o correspondiente al empleo de sarjento mayor, que gozar&#xE1;n en conformidad al montep&#xED;o militar.</div><br></div>", "i": 5946890}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 2 de Enero de 1894.- JORJE MONTT.- Juan Antonio Orrego.</div><br><br><br></div>", "i": 5946891}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "138", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-138"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "MONTEPIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EULALIA PLAZA", "ROSA PLAZA", "MONTEPIO MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-01-02", "doble_articulado": false, "id_norma": "22000", "numero_fuente": "4708", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-01-03", "vigencias": [{"desde": "1894-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-01-03", "fin_vigencia": ""}, "vigenci