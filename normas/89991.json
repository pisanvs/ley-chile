{"html": [{"t": "<div><div class=\"p\">APRUEBA REFORMA DE ESTATUTOS DE &quot;COMPA&#xD1;IA DE SEGUROS AETNA CHILE S.A.&quot; </div></div>", "i": 6084296}, {"t": "<div><div class=\"p\">Certifico: Que por Resoluci&#xF3;n No.082, de fecha 8 de mayo de 1990, se aprob&#xF3; reforma de estatutos de la sociedad an&#xF3;nima &quot;Compa&#xF1;&#xED;a de Seguros Aetna Chile S.A.&quot;, que consta de la escritura p&#xFA;blica de 26 de abril de 1990, otorgada en la Notar&#xED;a de Santiago de don Ra&#xFA;l Undurraga Laso. La reforma consiste en:</div><div class=\"p\">Modificar el nombre de la sociedad, el cual ser&#xE1;, en lo sucesivo, &quot;Aetna Chile Seguros Generales S.A.&quot;. </div></div>", "i": 6084297}, {"t": "<div><div class=\"p\">Santiago, 8 de mayo de 1990.- Rodrigo O. Costa Aranda, Secretario General.</div><br></div>", "i": 6084298}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "82", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-82"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "APRUEBA REFORMA DE ESTATUTOS DE COMPAÑIA DE SEGUROS AETNA CHILE S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-05-08", "doble_articulado": false, "id_norma": "89991", "numero_fuente": "33669", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-05-14", "vigencias": [{"desde": "1990-05-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-05-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-05-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vin