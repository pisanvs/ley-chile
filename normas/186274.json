{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6338237}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Luis Ossa Bulnes y Bruno Baranda Ferran, Presidente y Secretario del Tribunal Supremo del partido, respectivamente, y Rodrigo Hinzpeter Kirberg, Secretario General de la Directiva Central del partido Renovaci&#xF3;n Nacional, han informado la nueva composici&#xF3;n de la Directiva Central de dicho partido:</div><br><br><div class=\"p\">Directiva Central:</div><br><div class=\"p\">Presidente&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Sebasti&#xE1;n Pi&#xF1;era Echenique</div><div class=\"p\">1&#xBA; Vicepresidente&nbsp;  : Daniel Platovsky Turek</div><div class=\"p\">2&#xBA; Vicepresidente&nbsp;  : Vacante</div><div class=\"p\">3&#xBA; Vicepresidente&nbsp;  : Vacante</div><div class=\"p\">Secretario General&nbsp; : Rodrigo Hinzpeter Kirberg</div><div class=\"p\">Tesorero&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Roberto Palumbo Ossa</div><br></div>", "i": 6338238}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada en virtud de lo establecido en el Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por resoluci&#xF3;n O N&#xBA; 357 de fecha 31 de mayo de 2001.-</div><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director. </div></div>", "i": 6338239}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "357", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-357"}, {"tipo": "3", "numero": "O-357", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-357"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO RENOVACION NACIONAL", "DIRECTIVA CENTRAL", "SEBASTIAN PIÑERA ECHENIQUE", "PRESIDENTE"], "categorias_norma": [], "no