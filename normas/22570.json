{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Agua Potable de Pe&#xF1;uelas Lei n&#xFA;m. 1,338.- Santiago, a 14 de Julio de 1900.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br></div>", "i": 8274266}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se autoriza al Presidente de la Rep&#xFA;blica para invertir, conforme a lo dispuesto en la lei n&#xFA;m. 1,011, de 23 de Enero de 1898, hasta la cantidad de un millon quinientos sesenta i cuatro mil setecientos noventa i dos pesos en la conclusion de los trabajos de agua potable de Pe&#xF1;uelas.</div><br></div>", "i": 8274267}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- El&#xED;as Fern&#xE1;ndez A.- Rafael Err&#xE1;zuriz Urmeneta.</div><br></div>", "i": 8274268}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1338", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1338"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AGUA POTABLE DE PEÑUELAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGUA POTABLE", "PEÑUELAS", "FONDOS", "INVERSION", "PRESIDENTE DE LA REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-07-14", "doble_articulado": false, "id_norma": "22570", "numero_fuente": "6643", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-07-14", "vigencias": [{"desde": "1900-07-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-07-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1900-07-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-02-01", "fecha_version": "1900-07-14", "fecha_actualizacion_texto": "1900-07-14", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8274266}, {"n": "Artículo UNICO", "i": 8274267, "t": 6}, {"n": "Promulgación", "i": 8274268}]}