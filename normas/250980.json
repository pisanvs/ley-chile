{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6574647}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.483, de 2 de junio de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a COMPA&#xD1;IA PESQUERA CAMANCHACA S.A. para realizar por el per&#xED;odo de tres a&#xF1;os, contados desde la fecha de la presente resoluci&#xF3;n, actividades experimentales de acuicultura sobre el recurso hidrobiol&#xF3;gico Merluza del sur, en la concesi&#xF3;n de acuicultura otorgada mediante resoluci&#xF3;n N&#xBA; 763 de 1995, de la Subsecretar&#xED;a de Marina, ubicada en sector Pe&#xF1;asco, canal San Antonio, X Regi&#xF3;n. </div></div>", "i": 6574648}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Valpara&#xED;so, 2 de junio de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6574649}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1483 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1483 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-02", "doble_articulado": false, "id_norma": "250980", "numero_fuente": "38504", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-07-04", "vigencias": [{"desde": "2006-07-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-07-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-07-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul