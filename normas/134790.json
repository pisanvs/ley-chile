{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,363.- Santiago, 6 de setiembre de 1900.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br><br><br></div>", "i": 6163455}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Ab&#xF3;nase, por gracia, al teniente-coronel don Ezequiel Fuentes, para los efectos de su retiro, un a&#xF1;o y veintinueve dias que le faltan para completar cuarenta a&#xF1;os de servicio.&quot; </div></div>", "i": 6163456}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- ELIAS FERNANDEZ A.- Ricardo Matte P&#xE9;rez.</div><br></div>", "i": 6163457}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1363", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1363"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-09-06", "doble_articulado": false, "id_norma": "134790", "numero_fuente": "6690", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-09-10", "vigencias": [{"desde": "1900-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-09-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1900-09-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-04-13", "fecha_version": "1900-09-10",