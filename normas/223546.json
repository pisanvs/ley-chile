{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6472996}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 886, de 30 de marzo de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a SOUTHPACIFIC KORP S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Cullinto&quot;, pudiendo capturar los siguientes recursos hidrobiol&#xF3;gicos: a) En el &#xE1;rea mar&#xED;tima correspondiente a las Regiones VII, IX y X, con cerco: Jibia; b) En el &#xE1;rea mar&#xED;tima correspondiente a las Regiones VII, IX y X, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua: Jibia. </div></div>", "i": 6472997}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de marzo de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6472998}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "886 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-886 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-30", "doble_articulado": false, "id_norma": "223546", "numero_fuente": "37834", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-13", "vigencias": [{"desde": "2004-04-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-04-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-04-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "J