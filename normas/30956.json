{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA ORDENANZA N&#xB0; 02, DE 1990 </div></div>", "i": 5998921}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; La Ilustre Municipalidad de Coyhaique con fecha 22</div><div class=\"p\">de Febrero de 1993, dict&#xF3; la Ordenanza N&#xB0; 03 que</div><div class=\"p\">modifica la Ordenanza N&#xB0; 02 de fecha 06 de Febrero de</div><div class=\"p\">1990, sobre circulaci&#xF3;n y estacionamiento de veh&#xED;culos</div><div class=\"p\">de gran tonelaje en la ciudad de Coyhaique en lo</div><div class=\"p\">siguiente:</div><div class=\"p\">&nbsp; &nbsp; 1&#xB0;.- Modif&#xED;quese, la Ordenanza N&#xB0; 02 de fecha</div><div class=\"p\">08.02.90 en el siguiente art&#xED;culo:</div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo N&#xB0; 1:</div><div class=\"p\">&nbsp; &nbsp; Agr&#xE9;guense las siguientes letras a continuaci&#xF3;n de la letra u):</div><div class=\"p\">&nbsp; &nbsp; v) Freire entre P. Aguirre Cerda y Sargento Aldea.</div><div class=\"p\">&nbsp; &nbsp; w) Lautaro desde Magallanes hasta Eusebio Lillo.</div><div class=\"p\">&nbsp; &nbsp; x) Err&#xE1;zuriz desde Magallanes hasta Eusebio Lillo.</div><div class=\"p\">&nbsp; &nbsp; 2&#xB0;.- Ampl&#xED;ase, restricci&#xF3;n estipulada en el Art. N&#xB0; 1 en las siguientes calles:</div><div class=\"p\">&nbsp; &nbsp; f) 21 de Mayo desde Sargento Aldea hasta Ej&#xE9;rcito.</div><div class=\"p\">&nbsp; &nbsp; l) Moraleda entre Carrera y Eusebio Lillo.- </div></div>", "i": 5998922}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Eduardo Santelices Puelma, Alcalde.</div><br></div>", "i": 5998923}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "3", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "ORZ-3"}], "organismos": ["MUNICIPALIDAD DE COYHAIQUE"], "titulo_norma": "MODIFICA ORDENANZA N° 02, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materia