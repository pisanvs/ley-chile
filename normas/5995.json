{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ESTABLECE NORMAS ESPECIALES DE ORGANIZACION, ADMINISTRACION DE FONDOS Y REGIMEN DE BIENES Y SERVICIOS PARA EL DEPARTAMENTO DE BIENESTAR DE CARABINEROS DE CHILE</div><div class=\"p\">&nbsp; &nbsp; Santiago, 25 de Febrero de 1974.- La Junta de Gobierno de la Rep&#xFA;blica de Chile decret&#xF3; hoy lo siguiente:</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 337.- Vistos: las necesidades institucionales de Carabineros de Chile, en cuanto a mejorar el Servicio de Bienestar para su personal, y lo dispuesto en los decretos leyes N&#xB0;s 1 y 128, de 1973,</div><div class=\"p\">&nbsp; &nbsp; La Junta de Gobierno de la Rep&#xFA;blica de Chile ha acordado dictar el siguiente</div><div class=\"p\">&nbsp; &nbsp; Decreto ley:</div><br></div>", "i": 8989568}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo 1&#xB0;.- DEROGADO<span class=\"n\" id=\"n_0\">LEY 18713<br>Art. 17<br>D.O. 04.06.1988</span> </div><br><br></div>", "i": 8989569, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp;  Art&#xED;culo 2&#xB0;.- DEROGADO<span class=\"n\" id=\"n_1\">LEY 18713<br>Art. 17<br>D.O. 04.06.1988</span> </div><br><br></div>", "i": 8989570, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp;  Art&#xED;culo 3&#xB0;.- DEROGADO<span class=\"n\" id=\"n_2\">LEY 18713<br>Art. 17<br>D.O. 04.06.1988</span> </div><br><br></div>", "i": 8989571, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 4&#xB0;.- DEROGADO<span class=\"n\" id=\"n_3\">LEY 18713<br>Art. 17<br>D.O. 04.06.1988</span> </div><br></div>", "i": 8989572, "v": ["MODIFICACION", "CONCORDANCIA"]}, {"t": "<div><div class=\"p\">&nbsp;  Art&#xED;culo 5&#xB0;.- DEROGADO<span class=\"n\" id=\"n_4\">LEY 18713<br>Art. 17<br>D.O. 04.06.1988</span> </div><br><br></div>", "i": 8989573, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp;  Art&#xED;culo 6&#xB0;.- DEROGADO<span class=\"n\" id=\"n_5\">LEY 18713<br>Art. 17<br>D.O. 04.06.1988</span> </div><br><br></div>", "i": 8989574, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp;  Art&#xED;culo 7&#xB0;.- DEROGADO<span class=\"n\" id=\"n_6\">LEY 18713<br>Art. 17<br>D.O. 04.06.1988</span> </div><br><br></div>", "i": 8989575, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp;  Art&#xED;culo 8&#xB0;.- DEROGADO<span class=\"n\" id=\"n_7\">LEY 18713<br>Art. 17<br>D.O. 04.06.1988</span> </div><br><br></div>", "i": 8989576, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; Art&#xED;culo 9&#xB0;.- DEROGADO<span class=\"n\" id=\"n_8\">LEY 18713<br>Art. 17<br>D.O. 04.06.1988</span> </div><br><br></div>", "i": 8989577, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp;  Art&#xED;culo 10&#xB0;.- DEROGADO<span class=\"n\" id=\"n_9\">LEY 18713<br>Art. 17</span> D.O. 04.06.1988</div><br><br></div>", "i": 8989578, "v": ["MODIFICACION", "CONCORDANCIA"]}, {"t": "<div><div class=\"p\">&nbsp;  Art&#xED;culo 11&#xB0;.- DEROGADO<span class=\"n\" id=\"n_10\">LEY 18713<br>Art. 17<br>D.O. 04.06.1988</span> </div><br><br></div>", "i": 8989581}, {"t": "<div><div class=\"p\">&nbsp;  Art&#xED;culo 12&#xB0;.- DEROGADO<span class=\"n\" id=\"n_11\">LEY 18713<br>Art. 17<br>D.O. 04.06.1988</span> </div><br><br></div>", "i": 8989582}, {"t": "<div><div class=\"p\">&nbsp; Art&#xED;culo 13&#xB0;.- DEROGADO<span class=\"n\" id=\"n_12\">LEY 18713<br>Art. 17<br>D.O. 04.06.1988</span> </div><br><br></div>", "i": 8989583}, {"t": "<div><div class=\"p\">&nbsp;  Art&#xED;culo 14&#xB0;.- DEROGADO<span class=\"n\" id=\"n_13\">LEY 18713<br>Art. 17<br>D.O. 04.06.1988</span> </div><br><br></div>", "i": 8989584}, {"t": "<div><div class=\"p\">&nbsp;  Art&#xED;culo 15&#xB0;.- DEROGADO<span class=\"n\" id=\"n_14\">LEY 18713<br>Art. 17<br>D.O. 04.06.1988</span> </div><br><br></div>", "i": 8989585}, {"t": "<div><div class=\"p\">&nbsp;  Art&#xED;culo 16&#xB0;.- DEROGADO<span class=\"n\" id=\"n_15\">LEY 18713<br>Art. 17<br>D.O. 04.06.1988</span> </div><br><br></div>", "i": 8989586}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo transitorio.- Decl&#xE1;rase que los bienes y servicios pertenecientes al Departamento de Bienestar, de Carabineros de Chile, ser&#xE1;n aquellos que dentro de noventa d&#xED;as, a contar de la publicaci&#xF3;n del presente decreto ley, sean asignados a su patrimonio de afectaci&#xF3;n, por decreto o resoluci&#xF3;n interna. </div></div>", "i": 8989579}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Reg&#xED;strese en la Contralor&#xED;a General de la Rep&#xFA;blica, publ&#xED;quese en el Diario Oficial e ins&#xE9;rtese en el Bolet&#xED;n Oficial de Carabineros y en la Recopilaci&#xF3;n Oficial de dicha Contralor&#xED;a.- AUGUSTO PINOCHET UGARTE, General de Ej&#xE9;rcito, Presidente de la Junta de Gobierno.- JOSE T. MERINO CASTRO, Almirante, Comandante en Jefe de la Armada.- GUSTAVO LEIGH GUZMAN, General del Aire, Comandante en Jefe de la Fuerza A&#xE9;rea de Chile.- CESAR MENDOZA DURAN, General Director de Carabineros.- Oscar Bonilla Bradanovic, General de Divisi&#xF3;n, Ministro del Interior.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda atentamente a Ud.- Enrique Montero Marx, Subsecretario del Interior.</div><br></div>", "i": 8989580}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "15", "numero": "337", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-337"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "ESTABLECE NORMAS ESPECIALES DE ORGANIZACION, ADMINISTRACION DE FONDOS Y REGIMEN DE BIENES Y SERVICIOS PARA EL DEPARTAMENTO DE BIENESTAR DE CARABINEROS DE CHILE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CARABINEROS DE CHILE", "DEPARTAMENTO BIENESTAR", "ORGANIZACION", "ADMINISTRACION FONDOS", "REGIMEN", "BIENES", "SERVICIOS", "NORMAS"], "categorias_norma": [], "nombres_uso_comun": [], "p