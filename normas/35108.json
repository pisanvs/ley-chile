{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293125}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 556, de 22 de marzo de 1996, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por LEFERSA ALIMENTOS S.A., para un centro de cultivo ubicado en Estero Pichicolo, comuna de Hualaihue, provincia de Palena, X Regi&#xF3;n, por no dar cumplimiento el respectivo proyecto t&#xE9;cnico a lo dispuesto en los art&#xED;culos 77&#xB0; y 87&#xB0; de la Ley General de Pesca y Acuicultura. </div></div>", "i": 8293126}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 22 de marzo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293127}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "556", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-556"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION ACUICULTURA", "LEFERSA ALIMENTOS S.A"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-03-22", "doble_articulado": false, "id_norma": "35108", "numero_fuente": "35431", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-03-30", "vigencias": [{"desde": "1996-03-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-03-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-03-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci