{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7292159}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;1.107, de 5 de junio de 2002, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA;311, de 1982, de esta Subsecretar&#xED;a, solo en cuanto autoriz&#xF3; a MARIO MOROZIN YURESIC, para operar la nave &quot;Maor&#xED;&quot; respecto del recurso Merluza com&#xFA;n y Langostino amarillo entre el paralelo 29&#xBA; L.S. y 35&#xBA; L.S., por no haber operado dentro del plazo establecido en la resoluci&#xF3;n citada, de conformidad con lo establecido en la letra b) del art&#xED;culo 143, del D.S. N&#xBA;430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 7292160}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de junio de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7292161}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1107", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1107"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-05", "doble_articulado": false, "id_norma": "199081", "numero_fuente": "37281", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-12", "vigencias": [{"desde": "2002-06-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-06-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-06-12", "