{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6281717}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 4,28% durante el mes de julio de 1987.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad a lo dispuesto en el No.5 del Cap&#xED;tulo IV.B.8.1 del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables de 90 a 365 d&#xED;as, correspondiente a la segunda quincena de julio de 1987, fue de 4,24% anual.</div><br></div>", "i": 6281718}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de agosto de 1987.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6281719}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-04", "doble_articulado": false, "id_norma": "170803", "numero_fuente": "32838", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-05", "vigencias": [{"desde": "1987-08-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-08-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-08-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "