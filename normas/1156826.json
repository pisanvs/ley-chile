{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 10B</div></div>", "i": 10208528}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 645, de 5 de marzo de 2021, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1149290&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta digital N&#xB0; 12, de 2020</a>, y de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 10B, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para los centros de cultivo que se indican en la resoluci&#xF3;n extractada.</div><br></div>", "i": 10208529, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de marzo de 2021.- Alicia Gallardo Lagno, Subsecretaria de Pesca y Acuicultura.</div><br></div>", "i": 10208530}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "645 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-645 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 10B", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1907630", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-03-05", "doble_articulado": false, "id_norma": "1156826", "numero_fuente": "42902", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-03-11", "vigencias": [{"desde": "2021-03-11", "hasta": "", "tipo_versio