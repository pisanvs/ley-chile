{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6203093}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 55 de fecha 14.04.87, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones XI Regi&#xF3;n, se autoriza al St. Pedro Mu&#xF1;oz Mu&#xF1;oz, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del terr&#xED;torio nacional a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6203094}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Coyhaique, 14 de Abril de 1987.- Ra&#xFA;l Castillo Ceardi, Secretario Regional Ministerial de Transportes y Telecomunicaciones XI Regi&#xF3;n.</div><br></div>", "i": 6203095}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "55 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-55 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XI REGIÓN DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-04-14", "doble_articulado": false, "id_norma": "147073", "numero_fuente": "32754", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-04-24", "vigencias": [{"desde": "1987-04-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-04-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-04-24", "fin_vigencia": "", "tipo_version