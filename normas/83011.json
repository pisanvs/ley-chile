{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 133, DE 1990 </div></div>", "i": 7218118}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 133 de 16 de abril de 1990 se han aprobado al Colegio Brit&#xE1;nico St. Margaret&apos;s de Vi&#xF1;a del Mar, planes y programas especiales de estudio para Educaci&#xF3;n General B&#xE1;sica y Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica, que se aplicar&#xE1;n simult&#xE1;neamente a partir del a&#xF1;o escolar 1990, en todos los cursos de los citados niveles educativos.</div><br></div>", "i": 7218119}, {"t": "<div><div class=\"p\">Santiago, 20 de Abril de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7218120}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "133 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-133 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 133, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-04-16", "doble_articulado": false, "id_norma": "83011", "numero_fuente": "33688", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-06-06", "vigencias": [{"desde": "1990-06-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-06-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-06-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "PMB", "fech