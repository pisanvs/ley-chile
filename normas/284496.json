{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7417863}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.206, de 10 de</div><div class=\"p\">diciembre de 2008, de esta Subsecretar&#xED;a, modif&#xED;case</div><div class=\"p\">el numeral 3.- de la resoluci&#xF3;n exenta N&#xB0; 3.182 de</div><div class=\"p\">2008, de esta Subsecretar&#xED;a, que autoriz&#xF3; a</div><div class=\"p\">CONSULTORES PESQUEROS MARACTIVO LTDA., para efectuar</div><div class=\"p\">una pesca de investigaci&#xF3;n de conformidad con los</div><div class=\"p\">T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto</div><div class=\"p\">denominado &quot;Caracterizaci&#xF3;n de zonas de pesca</div><div class=\"p\">artesanal de Anchoveta y Sardina com&#xFA;n en las costas de la Novena Regi&#xF3;n&quot;, en el sentido de extender el periodo de ejecuci&#xF3;n de la pesca de investigaci&#xF3;n, hasta el 31 de diciembre de 2008.</div><br></div>", "i": 7417864}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de diciembre de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca. </div></div>", "i": 7417865}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3206 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3206 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-12-10", "doble_articulado": false, "id_norma": "284496", "numero_fuente": "39254", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-01-06", "vigencias