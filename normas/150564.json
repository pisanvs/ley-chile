{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6216485}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 460 de 27 de mayo de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Xa. Regi&#xF3;n, se autoriza a Ra&#xFA;l Arias Gallardo, Efra&#xED;n Ponce Banda, Juan Traimante Guerrero y Eduvino Gallardo Vel&#xE1;squez para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 2 &quot;Manuel Montt - Costanera - Angelm&#xF3;&quot; de Puerto Montt, cuyo trazado fue autorizado por resoluci&#xF3;n No. 120 de 28 de junio de 1984, de esta Secretar&#xED;a Regional.-</div><br></div>", "i": 6216486}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Enrique Brintrup Barrera, Secretario Regional Ministerial Transp. y Telec. Xa. Regi&#xF3;n subrogante. </div></div>", "i": 6216487}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "460 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-460 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-05-27", "doble_articulado": false, "id_norma": "150564", "numero_fuente": "32786", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-03", "vigencias": [{"desde": "1987-06-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vi