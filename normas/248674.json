{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7328771}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 938, de 29 de marzo de</div><div class=\"p\">2006, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad</div><div class=\"p\">parcial de la resoluci&#xF3;n N&#xBA; 589, de 1996, de esta</div><div class=\"p\">Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a Sociedad</div><div class=\"p\">Pesquera Viento Sur Limitada, hoy SOCIEDAD PESQUERA</div><div class=\"p\">VIENTO SUR S.A., para realizar actividades pesqueras</div><div class=\"p\">extractivas con la nave &quot;Sunnan III&quot;, entre la VIII</div><div class=\"p\">Regi&#xF3;n y el paralelo 41&#xB0;28,6&apos; L.S., sobre el recurso</div><div class=\"p\">hidrobiol&#xF3;gico Raya, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7328772}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de marzo de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7328773}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "938 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-938 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-03-29", "doble_articulado": false, "id_norma": "248674", "numero_fuente": "38431", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-04-04", "vigencias": [{"desde": "2006-04-04", "hasta": "", "t