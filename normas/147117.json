{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6203210}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 90, de 21 de Abril de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la XIIa Regi&#xF3;n, Magallanes y Ant&#xE1;rtica Chilena, se autoriza a An&#xED;bal Alidor Mu&#xF1;oz P&#xE9;rez para efectuar todo tipo de servicio de transporte de Pasajeros por Calles y Caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos de locomoci&#xF3;n colectiva urbana de pasajeros. </div></div>", "i": 6203211}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mario Salgado Jim&#xE9;nez, Secretario Regional Ministerial de Transportes y Telecomunicaciones XIIa Regi&#xF3;n, subrogante.</div><br></div>", "i": 6203212}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "90 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-90 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XII REGIÓN DE MAGALLANES Y ANTÁRTICA CHILENA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-04-21", "doble_articulado": false, "id_norma": "147117", "numero_fuente": "32758", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-04-29", "vigencias": [{"desde": "1987-04-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-04-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-04-29", "fin_vige