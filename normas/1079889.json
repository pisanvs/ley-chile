{"html": [{"t": "<div><div class=\"p\">&nbsp; \t</div><div class=\"p\">INFORMA NOMBRAMIENTO EN PARTIDO ALIANZA DEMOCR&#xC1;TICA NACIONAL</div></div>", "i": 9624382}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Do&#xF1;a Mar&#xED;a Ang&#xE9;lica Basualdo L&#xF3;pez y don Jorge Manr&#xED;quez Silva, Presidenta de la Directiva Central provisional y Secretario del Tribunal Supremo provisional, del partido Alianza Democr&#xE1;tica Nacional, respectivamente, han informado el nombramiento como Secretaria General de la colectividad, a do&#xF1;a Silvia Ver&#xF3;nica Monardes Ponce. </div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada en virtud de lo dispuesto en el <a href=\"https://www.leychile.cl/Navegar?idNorma=29951&amp;idParte=8638369&amp;idVersion=\">art&#xED;culo 68</a> letras h) y k) de la <a href=\"https://www.leychile.cl/Navegar?idNorma=29951&amp;idParte=&amp;idVersion=\">ley N&#xBA; 18.556</a> y Auto Acordado de fecha 27 de junio de 1988, del Tribunal Calificador de Elecciones. </div></div>", "i": 9624383}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n O-N&#xBA; 93 de fecha 19 de mayo de 2015.- Elizabeth Cabrera Burgos, Directora (S)</div></div>", "i": 9624384}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "93", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-93"}, {"tipo": "3", "numero": "O-93", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-O-93"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "INFORMA NOMBRAMIENTO EN PARTIDO ALIANZA DEMOCRÁTICA NACIONAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacit