{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Asignatarios forzosos del injeniero I.&#xB0; del blindado &quot;Blanco Encalada&quot; don B. Trewhela</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 12.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7162401}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Los asignatarios forzosos del injeniero 1.&#xB0; del blindado Blanco Encalda don Benjamin Trewhela ser&#xE1;n considerados, por gracia, como si el citado injeniero hubiera muerto en el empleo de capitan de fragata.</div><br><br></div>", "i": 7162402}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 25 de Enero de 1893.- JORJE MONTT.- Francisco A. Pinto.</div><br></div>", "i": 7162403}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "12", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-12"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "ASIGNATARIOS FORZOSOS DEL INJENIERO I.° DEL BLINDADO BLANCO ENCALADA DON B. TREWHELA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BENJAMIN TREWHELA", "ASIGNATARIOS FORZOSOS", "ASCENSO", "POR GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-01-25", "doble_articulado": false, "id_norma": "21887", "numero_fuente": "4432", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-01-25", "vigencias": [{"desde": "1893-01-25", "hasta": "", "tipo