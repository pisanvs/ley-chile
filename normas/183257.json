{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 854 EXENTA, DE 2001 </div></div>", "i": 6327835}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 854, de 7 de febrero del a&#xF1;o 2001, se ha aprobado a la Scuola Italiana &apos;&apos;Vittorio Montiglio&apos;&apos;, comuna de Las Condes, Regi&#xF3;n Metropolitana, un plan de estudio para 3&#xBA; a&#xF1;o de ense&#xF1;anza media human&#xED;stico-cient&#xED;fica, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se se&#xF1;alan en la presente resoluci&#xF3;n. </div></div>", "i": 6327836}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de marzo de 2001.- Javier San Miguel Bertr&#xE1;n, Jefe Divisi&#xF3;n de Educaci&#xF3;n General (S). </div></div>", "i": 6327837}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "854 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-854 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 854 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-07", "doble_articulado": false, "id_norma": "183257", "numero_fuente": "36923", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-27", "vigencias": [{"desde": "2001-03-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-03-27", "fin_vigencia": "", "tipo_version": "3