{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7269766}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 840 de 5 de mayo de 2000, de esta</div><div class=\"p\">Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la</div><div class=\"p\">resoluci&#xF3;n N&#xBA; 1.386, de 1996, de esta Subsecretar&#xED;a,</div><div class=\"p\">s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA ITATA S.A., para</div><div class=\"p\">ampliar sus actividades extractivas con la nave &apos;&apos;Yelcho</div><div class=\"p\">I&apos;&apos; sobre los recursos hidrobiol&#xF3;gicos Anchoveta y</div><div class=\"p\">Sardina espa&#xF1;ola, en el litoral de la III y IV Regiones,</div><div class=\"p\">de conformidad con lo establecido en la letra b) del</div><div class=\"p\">art&#xED;culo 143 del D.S. N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 7269767}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de mayo de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7269768}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "840", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-840"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-05", "doble_articulado": false, "id_norma": "168610", "numero_fuente": "36662", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-13", "vigencias": [{"desde": "2000-05-13", "hasta": "", "tipo_version": "3", "tipo_