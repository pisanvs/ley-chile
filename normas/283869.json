{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACI&#xD3;N DE EMISOR ELECTR&#xD3;NICO</div><br><br></div>", "i": 7382478}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 164, de 17 de diciembre de 2008, que deroga autorizaci&#xF3;n otorgada a contribuyente para operar como emisor electr&#xF3;nico.</div><div class=\"p\">Se deroga autorizaci&#xF3;n otorgada para operar como emisor de documentos tributarios electr&#xF3;nicos al contribuyente RUT N&#xB0; 76.018.311-3.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el bolet&#xED;n del SII del mes de diciembre de 2008.</div><br></div>", "i": 7382479}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "164 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-164 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEROGA AUTORIZACIÓN DE EMISOR ELECTRÓNICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-12-17", "doble_articulado": false, "id_norma": "283869", "numero_fuente": "39242", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-12-20", "vigencias": [{"desde": "2008-12-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-12-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-12-20", "fin_vigencia": "", "tipo_version": "