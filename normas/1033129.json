{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 10.659 EXENTA, DE 2011</div></div>", "i": 9207190}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 10.659, de 14 de noviembre de 2011, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Capacitaciones del B&#xED;o B&#xED;o Limitada&quot;, RUT 76.414.350-7, contenida en la resoluci&#xF3;n exenta N&#xBA; 7.394, de 4 de agosto de 2010, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.- </div></div>", "i": 9207191}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Francisco Ag&#xFC;ero Larrondo, Director Nacional Subrogante.</div></div>", "i": 9207192}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10659 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-10659 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 10.659 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-11-14", "doble_articulado": false, "id_norma": "1033129", "numero_fuente": "40120", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-11-26", "vigencias": [{"desde": "2011-11-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-11-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-11-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie