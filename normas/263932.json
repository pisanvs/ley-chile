{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 4.451 EXENTA, DE 2007 </div></div>", "i": 6620893}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.451 de fecha 24 de mayo de 2007 del Ministerio de Educaci&#xF3;n, se ampl&#xED;a el per&#xED;odo de acreditaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica ESI, por cinco a&#xF1;os, a contar de noviembre del a&#xF1;o 2006.</div><div class=\"p\">&nbsp; &nbsp;  Requi&#xE9;rase del Centro de Formaci&#xF3;n T&#xE9;cnica ESI el cumplimiento de acciones dentro del plazo precedentemente se&#xF1;alado, lo que ser&#xE1; verificado por la Divisi&#xF3;n de Educaci&#xF3;n Superior, como condici&#xF3;n previa para la obtenci&#xF3;n de la Plena Autonom&#xED;a, correspondiendo al Ministerio de Educaci&#xF3;n la verificaci&#xF3;n de su desarrollo.</div><br></div>", "i": 6620894}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de agosto de 2007.- Pilar Romaguera Gracia, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 6620895}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4451 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4451 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 4.451 EXENTO, DE 2007", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2007-05-24", "fecha_derogacion": "2009-10-05", "doble_articulado": false, "id_norma": "263932", "numero_fuente": "38840", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2007-08-17", "vigencias": [{"desde": "2009-10-05", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"},