{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9161648}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.001, de 22 de julio de 2011, de esta Subsecretar&#xED;a, rech&#xE1;zanse las solicitudes de concesi&#xF3;n de acuicultura n&#xFA;meros 204103090, 205101036, 207106003, 207103016, 207106060, 207111077, 207104090, 207103123, 208103204, 210103007, 210103006 y 210103010, se&#xF1;aladas en la resoluci&#xF3;n extractada, y publicada &#xED;ntegramente en la p&#xE1;gina web www.subpesca.cl, en virtud del art&#xED;culo 78 de la Ley General de Pesca y Acuicultura y art&#xED;culo 14 del DS N&#xBA; 290 de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 9161649}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de julio de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9161650}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2001 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2001 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-07-22", "doble_articulado": false, "id_norma": "1028138", "numero_fuente": "40023", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-07-30", "vigencias": [{"desde": "2011-07-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-07-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-07-30", "fin_vigencia": "", "t