{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 21 EXENTO, DE 1994 </div></div>", "i": 5939644}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 21 de 20 de enero de 1994 se ha autorizado a la Escuela Particular N&#xB0; 328 &quot;Hogar Espa&#xF1;ol&quot; de la comuna de Las Condes, para que a partir del a&#xF1;o escolar 1994 imparta la asignatura de Computaci&#xF3;n de 1&#xB0; a 8&#xB0; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica. Adem&#xE1;s, se aprueba programa de estudio de la citada asignatura.</div><br></div>", "i": 5939645}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 28 de Febrero de 1994.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5939646}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "21", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-21"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 21 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ESCUELA PARTICULAR 328 HOGAR ESPA OL", "PROGRAMAS ESTUDIOS", "COMPUTACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-01-20", "doble_articulado": false, "id_norma": "19698", "numero_fuente": "34810", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-03-09", "vigencias": [{"desde": "1994-03-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-03-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-03-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1994-03-09", "f