{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8328853}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;167, de 30 de enero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto las resoluciones N&#xBA;431 de 1986 y N&#xBA; 130 de 1990, ambas de esta Subsecretar&#xED;a, que autorizaron a EMPRESA PESQUERA ALERCE S.A., para instalar y operar el centro de cultivo ubicado en un Sector de R&#xED;o Quillaipe, comuna de Puerto Montt, provincia de Llanquihue, X Regi&#xF3;n, por haber vencido el respectivo decreto de concesi&#xF3;n de acuicultura.</div><br></div>", "i": 8328854}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de enero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8328855}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "167", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-167"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "EMPRESA PESQUERA ALERCE S.A.", "PUERTO MONTT", "DECIMA REGION", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-01-30", "doble_articulado": false, "id_norma": "97507", "numero_fuente": "36017", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-03-17", "vigencias": [{"desde": "1998-03-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-03-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-