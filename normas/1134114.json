{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 17B</div></div>", "i": 10040866}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.508, de 11 de julio de 2019, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1129518&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xB0; 760 de 2019</a>, de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 17B, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para el centro de cultivo que indica en la resoluci&#xF3;n extractada.</div></div>", "i": 10040867}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de julio de 2019.- Rom&#xE1;n Zelaya R&#xED;os, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 10040868}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2508 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2508 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 17B", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1623611", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-07-11", "doble_articulado": false, "id_norma": "1134114", "numero_fuente": "42409", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-07-22", "vigencias": [{"desde": "2019-07-22", "hasta": "", "tipo_