{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6498680}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 2.713, de 21 de septiembre</div><div class=\"p\">de 2004 de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA SAN</div><div class=\"p\">JOSE S.A. para ampliar actividades pesqueras extractivas</div><div class=\"p\">con la nave &quot;Ventisquero&quot;, en las &#xE1;reas mar&#xED;timas que en</div><div class=\"p\">cada caso se indican, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; capturar el recurso hidrobiol&#xF3;gico que a continuaci&#xF3;n se se&#xF1;ala: a) En el Archipi&#xE9;lago de Juan Fern&#xE1;ndez, Isla de Pascua, Isla Sala y G&#xF3;mez e Islas Desventuradas, con cerco: Jurelillo de Juan Fern&#xE1;ndez; b) en el Archipi&#xE9;lago de Juan Fern&#xE1;ndez, Isla de Pascua, Sala y G&#xF3;mez e Islas Desventuradas, con arrastre de media agua: Jurelillo de Juan Fern&#xE1;ndez.</div><br></div>", "i": 6498681}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Valpara&#xED;so, 21 de septiembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6498682}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2713 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2713 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-09-21", "doble_articulado": false, "id_norma": "230746", "numero_fuente": "37974", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion":