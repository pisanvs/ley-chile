{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A PESQUERA CHIVILINGO S.A.</div><br></div>", "i": 6479023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del SII, por resoluci&#xF3;n DRE08/N&#xBA; Ex-955, de fecha 7 de mayo de 2004, revoca, a Pesquera Chivilingo S.A., RUT. N&#xBA;</div><div class=\"p\">96.508.710-9, a contar de la fecha de esta publicaci&#xF3;n la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las adquisiciones de especies hidrobiol&#xF3;gicas, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 18 de la resoluci&#xF3;n N&#xBA; Ex. 3.311 de 30-06-2000, de la Direcci&#xF3;n Nacional. </div></div>", "i": 6479024}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Sergio Flores Guti&#xE9;rrez, Director Regional. </div></div>", "i": 6479025}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "955 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-955 EXENTA"}, {"tipo": "3", "numero": "DRE-08-955 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-955 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A PESQUERA\nCHIVILINGO S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-07", "doble_articulado": false, "id_norma": "225154", "numero_fuente": "37862", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-05-17", "vigencias": [{"desde": "2004-05-17", "hasta": "", "tipo_versio