{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.696 EXENTO, DE 2005 </div></div>", "i": 7326262}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.696 de fecha 14 de noviembre de 2005 del Ministerio de Educaci&#xF3;n, se deja sin efecto la aprobaci&#xF3;n del plan y programas de estudio de la carrera de T&#xE9;cnico en Farmacia del Centro de Formaci&#xF3;n T&#xE9;cnica Centro de Estudios Param&#xE9;dicos de Santiago - CEPSA, otorgada mediante resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 2.873 del 24 de octubre de 1988, a petici&#xF3;n de la propia entidad, en raz&#xF3;n que determin&#xF3; no abrir su oferta a partir del a&#xF1;o 2004.</div><br></div>", "i": 7326263}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 13 de diciembre de 2005.- Pedro Montt Leiva, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7326264}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1696 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1696 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.696 EXENTO, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-14", "doble_articulado": false, "id_norma": "245279", "numero_fuente": "38339", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-12-17", "vigencias": [{"desde": "2005-12-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-12-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-12-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "