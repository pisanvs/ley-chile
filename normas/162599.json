{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO ALCALDICIO EXENTO No. 29, DE 1985 </div><div class=\"p\">&nbsp; &nbsp;  Puerto Saavedra, 22 de Abril de 1985.- La Alcald&#xED;a decret&#xF3; hoy lo que sigue:</div><div class=\"p\">&nbsp; &nbsp;  No. 57 exento.- Vistos:</div><div class=\"p\">&nbsp; &nbsp;  1.- El Decreto Alcaldicio Exento No. 29 de fecha 18.09.85 de esta Municipalidad.</div><div class=\"p\">&nbsp; &nbsp;  2.- Las facultades que me confiere el DL 1.289 &quot;Org&#xE1;nico de Municipios y Administraci&#xF3;n Comunal&quot;.</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 8682171}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.- Modif&#xED;case el Decreto Alcaldicio No. 29 se&#xF1;alado en el vistos No. 1, en su art. 13 punto No. 2, el que a contar de esta fecha quedar&#xE1; de la siguiente manera:</div><div class=\"p\">&nbsp; &nbsp;  Matanza por lanar c/u $ 150,00 (ciento cincuenta </div></div>", "i": 8682172}, {"t": "<div><div class=\"p\">pesos c/u). An&#xF3;tese, comun&#xED;quese y arch&#xED;vese.- Juan Enrique L&#xFC;er MacKay, Alcalde.- Marcelo Novoa Manosalva, Secretario.</div><br></div>", "i": 8682173}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "57 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-57 EXENTO"}], "organismos": ["MUNICIPALIDAD DE PUERTO SAAVEDRA"], "titulo_norma": "MODIFICA DECRETO ALCALDICIO EXENTO No. 29, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-04-22", "doble_articulado": false, "id_norma": "162599", "numero_fuente": "32159", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-04-30", "vigencias": [{"d