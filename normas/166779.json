{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6269164}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.292, de Septiembre 24 de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a la Asociaci&#xF3;n Gremial de Transporte Intercomunal San Bernardo La Cisterna para efectuar el servicio p&#xFA;blico urbano de locomoci&#xF3;n colectiva en la L&#xED;nea de Buses No. 75 &quot;Intercomunal San Bernardo La Cisterna&quot;, cuyo trazado se encuentra autorizado por resoluci&#xF3;n exenta No. 251, de marzo 27 de 1985.</div><br></div>", "i": 6269165}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de Septiembre de 1987.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6269166}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1292 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1292 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-24", "doble_articulado": false, "id_norma": "166779", "numero_fuente": "32884", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-10-02", "vigencias": [{"desde": "1987-10-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-10-02", "fin_vigencia": ""}, "vige