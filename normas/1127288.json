{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO</div></div>", "i": 9984849}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xBA; 1748 de 6 de diciembre de 2018, se tuvo por desistida la expropiaci&#xF3;n de los lotes de terreno N&#xBA;s 2 y 6, ordenada por Decretos MOP N&#xBA;s <a href=\"https://www.leychile.cl/Navegar?idNorma=1046404&amp;idParte=&amp;idVersion=\">2653</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1046388&amp;idParte=&amp;idVersion=\">2633</a>, de 14 y 12 de noviembre de 2012, para la obra &quot;Ruta 66 - Camino de La Fruta. Sector 2: Variante Peumo - Las Cabras - El Manzano. Subtramo C&quot;, Regi&#xF3;n del Lib. Gral. Bdo. O&apos;Higgins, comuna de Peumo en ambos casos. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA; 2186, de 1978. </div><br><br></div>", "i": 9984850, "v": ["MODIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1748 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1748 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1519104; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-12-06", "doble_articulado": false, "id_norma": "1127288", "numero_fuente": "42243", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-01-02", "vigencias": [{"desde": "2019-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-01-02", "fin_vigencia": ""}, "v