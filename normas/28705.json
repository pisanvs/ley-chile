{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DENOMINA &quot;CORINA URBINA VILLANUEVA&quot; AL LICEO DE NI&#xD1;AS DE SAN FELIPE</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha tenido a bien prestar su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7177905}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Denom&#xED;nase &quot;Corina Urbina Villanueva&quot; al Liceo de Ni&#xF1;as de San Felipe. </div></div>", "i": 7177906}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintiocho de Agosto de mil novecientos sesenta y ocho.- EDUARDO FREI MONTALVA.- M&#xE1;ximo Pacheco G&#xF3;mez.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Patricio Rojas Saavedra, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7177907}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "16924", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-16924"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "DENOMINA CORINA URBINA VILLANUEVA AL LICEO DE NIÑAS DE SAN FELIPE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "LICEO", "SAN FELIPE", "CORINA URBINA VILLANUEVA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1968-08-28", "doble_articulado": false, "id_norma": "28705", "numero_fuente": "27141", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1968-09-10", "vigencias": [{"desde": "1968-09-10", "has