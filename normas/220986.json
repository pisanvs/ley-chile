{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6462743}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 156, de 20 de enero de 2004, de esta Subsecretar&#xED;a, pr&#xF3;rrogase hasta el 31 de octubre de 2004, el plazo otorgado en el N&#xBA; 1.- de la resoluci&#xF3;n N&#xBA; 578 de 2003, de esta Subsecretar&#xED;a, que autoriz&#xF3; a CULTIVOS MARE APERTO S.A., para instalar colectores de choritos (Mytilus chilensis) en el sector denominado Bah&#xED;a Ilke, comuna de Puerto Montt, provincia de Llanquihue, X Regi&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2.269 de 2003, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6462744}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de enero de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6462745}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "156 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-156 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-20", "doble_articulado": false, "id_norma": "220986", "numero_fuente": "37780", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-07", "vigencias": [{"desde": "2004-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004