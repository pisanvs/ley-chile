{"html": [{"t": "<div><div class=\"p\">MODIFICA EL CAP&#xCD;TULO V DEL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10162635}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.870 de 25.09.2020, del Director Nacional de Aduanas, se modific&#xF3; el Cap&#xED;tulo V del <a href=\"https://www.leychile.cl/Navegar?idNorma=248540&amp;idParte=&amp;idVersion=\">Compendio de Normas Aduaneras</a> conforme a la entrada en vigencia de las instrucciones relativas a la presentaci&#xF3;n electr&#xF3;nica de las solicitudes de modificaci&#xF3;n al documento aduanero -SMDA- para las declaraciones de salida en estado AT, con autorizaci&#xF3;n de salida.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10162636}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de septiembre de 2020.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><br></div>", "i": 10162637}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2870 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2870 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA EL CAPÍTULO V DEL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1823618", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-09-25", "doble_articulado": false, "id_norma": "1149873", "numero_fuente": "42768", "tipo_version": "3", "tipo_version_s": "Única", "fecha_