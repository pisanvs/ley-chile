{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6176273}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP No. 1.029, de 29 de abril de 1999, se expropiaron los lotes No. s 35, 37, 56 y 57, superficies 1.410, 1.245, 1.206 y 2.322 M2., roles de aval&#xFA;o 426-18 y 427-35, comuna de Cauquenes, para la obra Camino Cauquenes-L&#xED;mite Regional-Quirihue, Sector Cauquenes L&#xED;mite Regional y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Humberto Arturo Vergara del R&#xED;o y otros y Olga Ximena Lazo Fritz, ascendente a la cantidad de $ 508.406, para el lote No. 35, $ 675.903, para el lote No. 37 y $ 1.477.057, para los lotes No. s 56 y 57.-</div><br></div>", "i": 6176274}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6176275}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1029", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1029"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-04-29", "doble_articulado": false, "id_norma": "138721", "numero_fuente": "36401", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-07-01", "vigencias": [{"desde": "1999-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-07-09", "fecha