{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que dispone que la emision de los Bancos se rejir&#xE1; por una lei especial</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949362}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. La emision de los Bancos se rejir&#xE1; por una lei especial.</div><div class=\"p\">&nbsp; &nbsp; La presente lei i la que aplaza hasta el 1.&#xB0; de Enero de 1905 la fecha se&#xF1;alada por la lei n&#xFA;m. 1,054, de 31 de Julio de 1898, para iniciar la conversion met&#xE1;lica, rejir&#xE1;n desde su publicacion en el Diario Oficial.</div><br></div>", "i": 5949363, "v": ["CONCORDANCIA"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 31 de Diciembre de 1901.- JERMAN RIESCO.- Enrique Villegas.</div><br></div>", "i": 5949364}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1510", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1510"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "QUE DISPONE QUE LA EMISION DE LOS BANCOS SE REJIRA POR UNA LEI ESPECIAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BANCOS", "EMISION", "CONVERSION METALICA", "PLAZO", "AUMENTA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-12-31", "doble_articulado": false, "id_norma": "22706", "numero_fuente": "7110", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-12-31", "vigencias": [{"desde": "1901-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1901-12-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1901-12-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresado_por": "JAM", "fecha_ingreso": "1999-02-02", "fecha_version": "1901-12-31", "fecha_actualizacion_texto": "1901-12-31", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 5949362}, {"n": "Artículo UNICO", "i": 5949363, "t": 6}, {"n": "Promulgación", "i": 5949364}]}