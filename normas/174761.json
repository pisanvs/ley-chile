{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7276319}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.841, de 18 de agosto de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 835 de 1992, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriza a PESQUERA EL GOLFO S.A., para operar la nave &apos;&apos;Crist&#xF3;bal Col&#xF3;n&apos;&apos;, en las &#xE1;reas y recursos que a continuaci&#xF3;n se indica: a) En el &#xE1;rea mar&#xED;tima de la VII y IX Regiones, sobre los recursos Jurel, Machuelo o tritre, Sardina com&#xFA;n y Sardina espa&#xF1;ola; b) En el &#xE1;rea mar&#xED;tima comprendida entre la VII y IX Regiones, sobre los recursos Agujilla, Dorado, Cojinoba del norte y Camar&#xF3;n nailon.</div><br></div>", "i": 7276320}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de agosto de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7276321}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1841", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1841"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-08-18", "doble_articulado": false, "id_norma": "174761", "numero_fuente": "36753", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-31", "vigencias": [{"desde": "2000-08-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-31", "fin_vigencia": ""}, "vigencias_