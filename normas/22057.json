{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MONTEPIO Lei n&#xFA;m. 199.- Santiago, a 25 de Agosto de 1894.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947127}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese por gracia a do&#xF1;a Catalina Candia, viuda de Mu&#xF1;oz, la pension de montep&#xED;o que le corresponder&#xED;a si su marido, el teniente don Jacinto Mu&#xF1;oz, hubiera obtenido el permiso necesario para contraer matrimonio.</div><br><br></div>", "i": 5947128}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORGE MONTT.-S. Aldunate B.</div><br></div>", "i": 5947129}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "199", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-199"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "MONTEPIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CATALINA CANDIA VIUDA DE MU OZ", "MONTEPIO MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-08-25", "doble_articulado": false, "id_norma": "22057", "numero_fuente": "4910", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-09-06", "vigencias": [{"desde": "1894-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-09-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-09-06", "fin_vigencia": "", "tipo_version": "3"}], "eve