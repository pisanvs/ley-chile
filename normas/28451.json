{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AUTORIZA TRANSFERIR LOS TERRENOS QUE SE&#xD1;ALA Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5977675}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- La Corporaci&#xF3;n de la Vivienda transferir&#xE1;, a t&#xED;tulo gratuito, los terrenos de la poblaci&#xF3;n &quot;Libertad&quot; de Puerto Montt a sus actuales ocupantes.</div><br></div>", "i": 5977676}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a doce de Enero de mil novecientos sesenta y seis.- EDUARDO FREI MONTALVA.- Modesto Collados N&#xFA;&#xF1;ez.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a U. para su conocimiento.- Dios guarde a U.- J. Eduardo Truyol D&#xED;az, Subsecretario de la Vivienda y Urbanismo.</div><br></div>", "i": 5977677}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "16417", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-16417"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "AUTORIZA TRANSFERIR LOS TERRENOS QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FACULTAD", "TRANSFERENCIA", "DONACION", "TERRENO", "BIEN RAIZ", "INMUEBLE", "POBLACION LIBERTAD", "PUERTO MONTT", "CORPORACION VIVIENDA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1966-01-12", "doble_articulado": false, "id_norma": "28451", "numero_fuente": "26350", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1966-