{"html": [{"t": "<div><div class=\"p\">MODIFICA DESIGNACION DE RECEPTORES JUDICIALES </div><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 85.- Santiago, 21 de Julio de 1987.- Vistos: Lo dispuesto en el Art. 11 del Decreto Ley No. 2.974 de 1979,</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 7254528}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modificase la resoluci&#xF3;n No. 183 de 18 de Abril de 1980 y resoluci&#xF3;n 25 de 13 de Mayo de 1983, que designan Receptores Judiciales en la forma que se indica:</div><div class=\"p\">I-II Regi&#xF3;n Se elimina a don Jos&#xE9; Jara Mu&#xF1;oz, nombrado por resoluci&#xF3;n 183 y a don Roberto Cerda Canobra, nombrado por resoluci&#xF3;n 25.</div><br></div>", "i": 7254529}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Sergio Retamal Iglesias, Vicepresidente Ejecutivo.</div><br></div>", "i": 7254530}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "85", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-85"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "MODIFICA DESIGNACION DE RECEPTORES JUDICIALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-21", "doble_articulado": false, "id_norma": "145162", "numero_fuente": "32870", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-14", "vigencias": [{"desde": "1987-09-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09-14", "fin_vig