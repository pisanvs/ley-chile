{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 53 EXENTA DE 2004 </div></div>", "i": 6482233}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 53 del 31/05/04, que actualiza requisitos para vales emitidos en reemplazo de boletas.</div><br><div class=\"p\">&nbsp; &nbsp;  Deroga Res. Ex. N&#xBA; 21 del 01.06.01.</div><div class=\"p\">1.&nbsp; &nbsp; Indica requisitos m&#xED;nimos que deben contener</div><div class=\"p\">&nbsp; &nbsp;  los vales emitidos por m&#xE1;quinas registradoras,</div><div class=\"p\">&nbsp; &nbsp;  terminales de punto de venta o impresoras</div><div class=\"p\">&nbsp; &nbsp;  fiscales, previamente autorizados por el</div><div class=\"p\">&nbsp; &nbsp;  Servicio de Impuestos Internos, para</div><div class=\"p\">&nbsp; &nbsp;  reemplazar a las boletas.</div><div class=\"p\">2.&nbsp; &nbsp; Dispone un per&#xED;odo de tres meses para</div><div class=\"p\">&nbsp; &nbsp;  ajustarse a la norma.</div><div class=\"p\">3.&nbsp; &nbsp; Deroga Res. Ex. N&#xBA; 21 del 01.06.2001.</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio Web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en mayo, de 2004.</div><br></div>", "i": 6482234}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "53 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-53 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 53 EXENTA DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MAQUINAS REGISTRADORAS FISCALES", "EMISION DE VALES", "REQUISITOS MINIMOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-31", "doble_articulado": false, "id_norma": "226051", "numero_fuente": "37877", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-04", "vigencias": [{"desde": "2004-06-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-06-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-06-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}, {"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresado_por": "DVG", "fecha_ingreso": "2004-06-04", "fecha_version": "2004-06-04", "fecha_actualizacion_texto": "2004-06-04", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6482233}, {"n": "Artículo", "i": 6482234, "t": 6}]}