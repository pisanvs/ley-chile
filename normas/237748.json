{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A ARLAVAN S.A.</div><br></div>", "i": 6524927}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La XV Direcci&#xF3;n Regional Metropolitana Santiago Oriente del SII, por resoluci&#xF3;n Ex. N&#xBA; 179, de fecha 27 de abril de 2005, otorga a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, a Arlavan S.A. RUT N&#xBA; 88.983.400-5, la calidad de Agente Retenedor del Impuesto al Valor Agregado en las ventas de Berries que realice de acuerdo con lo establecido en la resoluci&#xF3;n Ex. N&#xBA; 26 de 24.02.2005 de la Direcci&#xF3;n Nacional. </div></div>", "i": 6524928}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Bernardo Seaman Gonz&#xE1;lez, Director Regional. </div></div>", "i": 6524929}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "179 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-179 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "XIV DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO ORIENTE"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A ARLAVAN\nS.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-04-27", "doble_articulado": false, "id_norma": "237748", "numero_fuente": "38156", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-05-09", "vigencias": [{"desde": "2005-05-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-05-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-05-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient