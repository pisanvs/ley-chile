{"html": [{"t": "<div><div class=\"p\">ESTABLECE LO QUE INDICA</div></div>", "i": 10117910}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 45, del 24 de abril de 2020, establece la forma en que los contribuyentes podr&#xE1;n acogerse al r&#xE9;gimen de depreciaci&#xF3;n instant&#xE1;nea establecida en los art&#xED;culos <a href=\"https://www.leychile.cl/Navegar?idNorma=1142667&amp;idParte=10103271&amp;idVersion=\">vig&#xE9;simo primero transitorio</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1142667&amp;idParte=10103272&amp;idVersion=\">vig&#xE9;simo segundo transitorio</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1142667&amp;idParte=&amp;idVersion=\">ley N&#xBA; 21.210</a> que moderniza la legislaci&#xF3;n tributaria.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento, est&#xE1; publicado en &quot;www.sii.cl&quot;.</div><div class=\"p\"> </div><br></div>", "i": 10117911}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "45 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-45 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ESTABLECE LO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1756787; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-04-24", "doble_articulado": false, "id_norma": "1144786", "numero_fuente": "42645", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-05-02", "vigencias": [{"desde": "2020-05-02", "hasta": "", "tipo_version": "3