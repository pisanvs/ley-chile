{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8323365}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 283, de 27 de Febrero de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 2&#xB0; de la Resoluci&#xF3;n No. 350, de 1981, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Pesquera El Golfo S.A., R.U.T. No. 96.237.000-4, domiciliada en Talcahuano, para ampliar las actividades pesqueras de extracci&#xF3;n, en orden a incorporar en las embarcaciones Pigargo, Phoenix, Mait&#xE9;n y Quillay, el arte de pesca Espinel.</div><br></div>", "i": 8323366}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 27 de Febrero de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8323367}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "283", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-283"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-02-27", "doble_articulado": false, "id_norma": "93629", "numero_fuente": "33328", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-03-21", "vigencias": [{"desde": "1989-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-03-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-03-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICA