{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 382.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado el siguiente PROYECTO DE LEI:</div><br></div>", "i": 7162689}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de doscientos mil pesos al &#xED;tem 3 de la partida 36 del presupuesto de Hacienda para la construccion del malecon en Iquique i trabajos de union de la isla con el continente .</div><br><br></div>", "i": 7162690}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, lo he aprobado y sancionado; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 14 de Setiembre de 1896.- JORJE MONTT.-</div><div class=\"p\">H. P&#xE9;rez de Arce.</div><br></div>", "i": 7162691}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "382", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-382"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1896", "MODIFICACION", "MINISTERIO DE", "HACIENDA", "MALECON IQUIQUE", "CONSTRUCCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-09-14", "doble_articulado": false, "id_norma": "22231", "numero_fuente": "5506", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1896-09-14", "vigencias": [{"desde": "1896-09-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1896-09-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1896-09-14", "fin_vigencia": "", "tipo_versi