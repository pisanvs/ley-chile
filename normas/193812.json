{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6366004}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.961, de 30 de noviembre de 2001, se expropi&#xF3; el lote de terreno N&#xBA;3, superficie 4.770 m2., rol de aval&#xFA;o S/R, comuna de Quilpu&#xE9;, para la obra Concesi&#xF3;n Internacional Interconexi&#xF3;n Vial Santiago-Valpara&#xED;so-Vi&#xF1;a del Mar. Troncal Sur. Tramo 4A:</div><div class=\"p\">Km. 99.600,00 al Km. 101.720,00, V Regi&#xF3;n, se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietaria Astrit del Rosario Silva Zapata y otras, ascendente a la cantidad de $15.760.805.</div><br></div>", "i": 6366005}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6366006}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1961", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1961"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-30", "doble_articulado": false, "id_norma": "193812", "numero_fuente": "37160", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-15", "vigencias": [{"desde": "2002-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2002-01-16", "fecha_version": "2002-01-15", "fecha_actualizacion_te