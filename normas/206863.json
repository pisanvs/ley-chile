{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.247 EXENTO, DE 2002 </div></div>", "i": 6410664}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.247 de fecha 11 de diciembre de 2002, de Educaci&#xF3;n, se autoriza al Instituto Profesional Andali&#xE9;n para impartir la siguiente carrera y t&#xED;tulo profesional que se indica, a contar del a&#xF1;o 2001:</div><br><div class=\"p\">Carrera: Comunicaci&#xF3;n Audiovisual con menci&#xF3;n en Direcci&#xF3;n y Comunicaci&#xF3;n Social (liberada por decreto N&#xBA; 972 del 13 de noviembre de 1987)</div><div class=\"p\">T&#xED;tulo Profesional: Comunicador Audiovisual con menci&#xF3;n en Direcci&#xF3;n y Comunicaci&#xF3;n Social.</div><br><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase presente para todos los efectos legales y administrativos.</div><br></div>", "i": 6410665}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de diciembre de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6410666}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1247 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1247 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.247 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-11", "doble_articulado": false, "id_norma": "206863", "numero_fuente": "37461", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-01-17", "vigencias": [{"desde": "2003-01-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-0