{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6618000}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.067, de 18 de julio de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a SALMONES AUCAR LIMITADA para ampliar las actividades pesqueras de transformaci&#xF3;n, autorizadas por las resoluciones citadas en Visto, en orden a incorporar a la planta ubicada en Aucar s/n, comuna de Quemchi, provincia de Chilo&#xE9;, X Regi&#xF3;n, en las l&#xED;neas de proceso de Cocido, Fresco-Enfriado, Fresco-Refrigerado y Congelado, el recurso hidrobiol&#xF3;gico indicado en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6618001}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de julio de 2007.- Mar&#xED;a Angela Barbieri Bellolio, Subsecretaria de Pesca (S). </div></div>", "i": 6618002}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2067 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2067 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-07-18", "doble_articulado": false, "id_norma": "263009", "numero_fuente": "38823", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-07-27", "vigencias": [{"desde": "2007-07-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-07-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-07-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [