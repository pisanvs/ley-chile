{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n a do&#xF1;a Mar&#xED;a Luisa Sep&#xFA;lveda V. de Bustos</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 8277559}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a do&#xF1;a Mar&#xED;a Luisa Sep&#xFA;lveda, viuda del ex-intendente de Colchagua, don Rub&#xE9;n Bustos S., y a sus hijos menores, el derecho a gozar de una pensi&#xF3;n anual de tres mil seiscientos pesos&quot;.</div><br></div>", "i": 8277560}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta de Julio de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Guillermo Edwards Matte. </div></div>", "i": 8277561}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4625", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4625"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE PENSION A DOÑA MARIA LUISA SEPULVEDA V. DE BUSTOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LUISA SEPULVEDA VIUDA DE BUSTOS", "PENSION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-07-30", "doble_articulado": false, "id_norma": "24783", "numero_fuente": "15438", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-08-02", "vigencias": [{"desde": "1929-08-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenc