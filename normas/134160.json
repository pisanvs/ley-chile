{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,050.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6161505}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Proh&#xED;bese la pesca con dinamita bajo la pena de cincuenta a quinientos pesos de multa o de cuarenta a sesenta dias de prision.</div><br></div>", "i": 6161506}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuando, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a seis de julio de mil ochocientos noventa i ocho.- FEDERICO ERRAZURIZ.- Emilio Bello C. </div></div>", "i": 6161507}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1050", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1050"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-07-06", "doble_articulado": false, "id_norma": "134160", "numero_fuente": "6044", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-07-08", "vigencias": [{"desde": "1898-07-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-07-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-07-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-03-30", "fecha_version":