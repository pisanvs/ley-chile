{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6334936}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 846, de 11 de mayo de 2001, de esta Subsecretar&#xED;a, rectif&#xED;case el numeral 22 de la resoluci&#xF3;n N&#xBA; 70 de 2001, que declar&#xF3; la caducidad parcial de la resoluci&#xF3;n N&#xBA; 861 de 1997, ambas de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA TRAVESIA S.A. para realizar actividad extractiva con la nave &quot;Mar&#xED;a Jos&#xE9;&quot;, matr&#xED;cula N&#xBA; 2914, sobre los recursos Anchoveta y Sardina com&#xFA;n, en el &#xE1;rea mar&#xED;tima de la V a VII y IX Regiones, en el sentido de se&#xF1;alar que el &#xE1;rea mar&#xED;tima cuya caducidad se declara corresponde a la V a VII, IX y X Regiones.</div><br></div>", "i": 6334937}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de mayo de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6334938}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "846", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-846"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-11", "doble_articulado": false, "id_norma": "185299", "numero_fuente": "36965", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-18", "vigencias": [{"desde": "2001-05-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-05-18", "fin_vigencia": ""}, "vigencias_version