{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6087378}, {"t": "<div><div class=\"p\">Por Decreto MOP N&#xBA; 297 de 14 de septiembre de 1989, se expropiaron los lotes N&#xB0;s. 38, 51, 52, 53 y 54, superficies 270 m2., 306 m2., 306 m2., 303 m2. y 298 m2., roles de aval&#xFA;o 2938-17, 3338-40, 3338-39, 3338-24 y 3338-25, respectivamente, Comuna de La Cisterna, para Avda. Am&#xE9;rico Vespucio, sector Gran Avenida Ochagav&#xED;a y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios, don Francisco Quintana Morales y Julia Figueroa Figueroa; do&#xF1;a Marianne Wagner Reichinger y don Heinz Lustig Schatz, ascendente a $ 6.336.000. para el lote 38; $ 14.300.000.- para los lotes 51 52 y 53 y $ 5.700.000. para el lote 54.</div><br></div>", "i": 6087379}, {"t": "<div><div class=\"p\">Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 6087380}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "297", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-297"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-09-14", "doble_articulado": false, "id_norma": "90923", "numero_fuente": "33486", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-10-02", "vigencias": [{"desde": "1989-10-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-10-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-10-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por"