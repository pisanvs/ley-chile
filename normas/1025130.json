{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9137874}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.120, 2 de mayo de 2011, de esta Subsecretar&#xED;a, rech&#xE1;zanse las solicitudes de concesi&#xF3;n de acuicultura n&#xFA;meros 203041002, 206101129, 205101196, 206101016, 208111464, 206101021, 206101116, 204111090, 207111180, 202101010, 206103329, 207106002, 206111232, 208101015, 208101014, 206111181, 207091007 y 209111303, se&#xF1;aladas en la resoluci&#xF3;n extractada, y publicada &#xED;ntegramente en la p&#xE1;gina web www.subpesca.cl, en virtud del art&#xED;culo 78 de la Ley General de Pesca y Acuicultura y art&#xED;culo 14 del DS N&#xBA; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 9137875}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de mayo de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9137876}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1120 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1120 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-05-02", "doble_articulado": false, "id_norma": "1025130", "numero_fuente": "39953", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-05-06", "vigencias": [{"desde": "2011-05-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-05-06", "fin_vigencia": ""}, "vigencias_version_norma