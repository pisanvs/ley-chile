{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10093041}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta 3.710, 31 de diciembre 2019, Serviu Regi&#xF3;n del Biob&#xED;o orden&#xF3; expropiaci&#xF3;n parcial de un inmueble ubicado en El Mait&#xE9;n HJ2 LT B, Rol de Aval&#xFA;o N&#xB0; 1228-136, comuna de Cabrero, de aparente dominio de Luis Arturo Arroyo Arroyo, superficie de 69,65 m2 de terreno (Lote 61) y 0 m2 de edificaci&#xF3;n, linderos se&#xF1;alados plano de expropiaci&#xF3;n S8R-35.929-2, para la ejecuci&#xF3;n de las obras del proyecto &quot;Construcci&#xF3;n Ciclov&#xED;a Ruta Q-60-0, Cabrero-Monte&#xE1;guila&quot;, conforme art&#xED;culo 51 ley N&#xB0; 16.391 y DL N&#xB0; 2.186. Comisi&#xF3;n Peritos integrada por constructor civil Roxana Abarz&#xFA;a Gajardo, ingeniero civil Carlos Montecinos Galleguillos y arquitecto Alberto Vallette Isla, seg&#xFA;n informe de fecha 09.12.2019, fij&#xF3; monto provisional indemnizaci&#xF3;n en $824.062. </div></div>", "i": 10093042}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n del Biob&#xED;o.</div><br></div>", "i": 10093043}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3710 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3710 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1709591", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-12-31", "doble_articulado": false, "id_norma": "1141218", "numero_fuente": "425