{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A PESQUERA CABOSUR S.A.</div><br><br><br></div>", "i": 6132591}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La V Direcci&#xF3;n Regional del Servicio de Impuestos Internos, por resoluci&#xF3;n Ex. N&#xBA;22, de fecha 15 de septiembre de 1998, concede la calidad de Agente Retenedor del IVA a contar del primer d&#xED;a del mes siguiente al de esta publicaci&#xF3;n y hasta el 30 de junio de 1999, a Pesquera Cabosur S.A., RUT 96.805.200-4, por las adquisiciones de especies hidrobiol&#xF3;gicas que efect&#xFA;e, de acuerdo con lo establecido en la Res.</div><div class=\"p\">N&#xBA;Ex.3.839/98 de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial el d&#xED;a 01.07.98.-</div><br></div>", "i": 6132592}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco C&#xE1;rcamo Avenda&#xF1;o, Director Regional. </div></div>", "i": 6132593}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "22 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-22 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL DE VALPARAÍSO"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A PESQUERA\nCABOSUR S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "PESQUERA CABOSUR S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-09-15", "doble_articulado": false, "id_norma": "125039", "numero_fuente": "36175", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-09-29", "vigencias": [{"desde": "1998-09-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única