{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION QUE INDICA </div></div>", "i": 8314643}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 680 de 24 de Mayo de 1990 de este Servicio Nacional de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, der&#xF3;gase la resoluci&#xF3;n No. 770, de 1988, de este Servicio, que autoriz&#xF3; a inscribir a nombre de don Eduardo Jaime Ruiz Guti&#xE9;rrez, R.U.T. No. 6.055.499-4, domiciliado en la ciudad de Puerto Montt, No. 55, Pelluco, Casilla Postal No. 597 de Puerto Montt, en el Registro correspondiente, el vivero ubicado en Bah&#xED;a Chincui, Comuna de Puerto Montt, Provincia de Llanquihue, X Regi&#xF3;n, en un &#xE1;rea de 12.000 m2., por renuncia de su titular. </div></div>", "i": 8314644}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 24 de Mayo de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8314645}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "680", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-680"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "DEROGA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-05-24", "doble_articulado": false, "id_norma": "83062", "numero_fuente": "33684", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-06-01", "vigencias": [{"desde": "1990-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-06-01", "fin_vigenci