{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10298220}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n Ex. N&#xBA; 3.976, de fecha 06/12/2021, conforme al art&#xED;culo 51 ley 16.391, DL 2.186/1978 y DS 1.128/2012 de Vivienda y Urbanismo, para destinarlo al Proyecto &quot;Mejoramiento Acceso La Lancha de Angol&quot;, Serviu Regi&#xF3;n de la Araucan&#xED;a orden&#xF3; la expropiaci&#xF3;n parcial del bien ra&#xED;z denominado Inmueble ubicado en el lugar denominado Los Perales, comuna de Angol, provincia de Malleco, Novena Regi&#xF3;n, Rol de aval&#xFA;o: 1466-38, comuna de Angol. La superficie a expropiar aproximada es de 247,20 metros cuadrados, de aparente dominio de Julio de la Rosa Flores Silva. Comisi&#xF3;n de Peritos integrada por don Claudio Romo Sanhueza, Constanza Mihoevic Gonz&#xE1;lez y Marcela Melo Rodr&#xED;guez, fij&#xF3; monto de indemnizaci&#xF3;n provisional en $25.603.734 seg&#xFA;n informe N&#xBA; 06-0, de fecha 04.12.2021, pagadero contado.- </div></div>", "i": 10298221}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n de la Araucan&#xED;a.</div><div class=\"p\"> </div><br></div>", "i": 10298222}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3976 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3976 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2063093", "EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2021-12-0