{"html": [{"t": "<div><div class=\"p\">AUTORIZA A PESQUERA INDO S.A. PARA AMPLIAR SUS ACTIVIDADES PESQUERAS </div></div>", "i": 7267589}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 379 de 28 de Diciembre de 1982 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Pesquera Indo S.A., para operar las embarcaciones gemelas &quot;EPESA 1&quot;, &quot;EPESA 2&quot; y &quot;EPESA 3&quot;, en el litoral comprendido entre la I y la II Regi&#xF3;n, en labores extractivas de anchoveta, sardina espa&#xF1;ola, jurel, caballa, roncacho y machuelo.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de Diciembre de 1982.-</div><br></div>", "i": 7267590}, {"t": "<div><div class=\"p\">Roberto Verdugo Gormaz, Subsecretario de Pesca. </div></div>", "i": 7267591}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "379", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-379"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA INDO S.A. PARA AMPLIAR SUS\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1982-12-28", "doble_articulado": false, "id_norma": "165439", "numero_fuente": "31459", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1983-01-06", "vigencias": [{"desde": "1983-01-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1983-01-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1983-01-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos