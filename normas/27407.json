{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA EL NOMBRE DE LA CALLE QUE INDICA DE LA COMUNA DE &#xD1;U&#xD1;OA, DE LA CIUDAD DE SANTIAGO.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Honorable Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8280668}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. La calle Nueva &#xD1;u&#xF1;oa de la comuna de &#xD1;u&#xF1;oa de la ciudad de Santiago se denominar&#xE1; en lo sucesivo &quot;Calle Rep&#xFA;blica de Israel&quot;.&quot; </div></div>", "i": 8280669}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecinueve de mayo de mil novecientos cincuenta y nueve.- JORGE ALESSANDRI RODRIGUEZ.- S&#xF3;tero del R&#xED;o.</div><br></div>", "i": 8280670}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13316", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13316"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA EL NOMBRE DE LA CALLE QUE INDICA DE LA COMUNA\nDE ÑUÑOA, DE LA CIUDAD DE SANTIAGO.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "CALLE REPUBLICA ISRAEL", "U OA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1959-05-19", "doble_articulado": false, "id_norma": "27407", "numero_fuente": "24356", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1959-06-02", "vigencias": [{"desde": "1959-06-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"i