{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10266162}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xBA; 815, de 4 agosto 2021, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos que indica en condiciones que se&#xF1;ala, relativas a celebraci&#xF3;n D&#xED;a del Ni&#xF1;o en Poblaci&#xF3;n Villa Divisadero, y autoriz&#xF3; a Junta de Vecinos Villa Patagonia de Coyhaique para realizar siguientes intervenciones en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - corte total de pasaje Paihuen, entre calle Ollagua y pasaje Antupir&#xE9;n, con motivo de la celebraci&#xF3;n del D&#xED;a del Ni&#xF1;o el d&#xED;a domingo 08-08-2021 entre las 15:00 y 18:00 hrs.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10266163}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andrea Mac&#xED;as Palma, Gobernadora Regional de Ays&#xE9;n.- Javier Gonz&#xE1;lez Jara, Asesor Jur&#xED;dico, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10266164}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "815 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-815 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2006597", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-08-04", "doble_articulado": false, "id_norma": "1164749", "numero_fuente": "43050", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-09-09", "vigencias": [{"desde": "2021-09-09", "hasta": "", "tipo_v