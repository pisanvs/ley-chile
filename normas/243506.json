{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6546501}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA; 1.019 de 11 de octubre de 2005, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA; del decreto MOP exento N&#xBA; 1.561 de 28 de noviembre de 2003, en la parte que se refiere al Convenio Directo de Precio ad refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n del lote N&#xBA; 290, fijada por la Comisi&#xF3;n de Peritos, con fecha 20 de julio de 2001, ascendente a la cantidad de $502.800.</div><br></div>", "i": 6546502}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6546503}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1019 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1019 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-10-11", "doble_articulado": false, "id_norma": "243506", "numero_fuente": "38301", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-11-02", "vigencias": [{"desde": "2005-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part":