{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 10,825</div><br><div class=\"p\">ABONA EL TIEMPO QUE INDICA A DON JUVENAL TORO N.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 7342470}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Recon&#xF3;cese y ab&#xF3;nase, por gracia, para todos los efectos legales, un a&#xF1;o, ocho meses y veinticinco d&#xED;as de servicios que sirvi&#xF3; en la Municipalidad de Coquimbo a don Juvenal Toro Narbona. </div></div>", "i": 7342471}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a diecisiete de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Ignacio Lorca G.</div><br></div>", "i": 7342472}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10825", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10825"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ABONA EL TIEMPO QUE INDICA A DON JUVENAL TORO N.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-17", "doble_articulado": false, "id_norma": "261033", "numero_fuente": "22403", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-11-19", "vigencias": [{"desde": "1952-11-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1952-11-19", "fin_vigencia": ""}, "vigencias_version_norma":