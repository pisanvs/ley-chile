{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CERTIFICADO</div><br><br></div>", "i": 6588865}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Banco Central de Chile ha resuelto modificar las Disposiciones Generales del Cap&#xED;tulo XIV del Manual de Procedimientos y Formularios de Informaci&#xF3;n del Compendio de Normas de Cambios Internacionales, de la siguiente forma:</div><br><div class=\"p\">-&nbsp; &nbsp; En el numeral 1.1 y 2.1, agregar como tercer y &#xFA;ltimo p&#xE1;rrafo, respectivamente, la siguiente expresi&#xF3;n:</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;La obligaci&#xF3;n de informar en la forma establecida en el Anexo N&#xBA; 1 podr&#xE1; ser cumplida completando debidamente el formulario disponible en la secci&#xF3;n &quot;Otros Servicios&quot; en la direcci&#xF3;n Internet www.bcentral.cl&quot;.</div><br></div>", "i": 6588866}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de noviembre de 2006.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6588867}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMPENDIO DE NORMAS DE CAMBIOS INTERNACIONALES", "MANUAL DE PROCEDIMIENTOS Y FORMULARIOS DE INFORMACION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-11-08", "doble_articulado": false, "id_norma": "255009", "numero_fuente": "38610", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-11-10", "vigencias": [{"desde": "