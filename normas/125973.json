{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA A LA CIA. PESQUERA CAMANCHACA S.A. PARA AMPLIAR SUS ACTIVIDADES PESQUERAS</div><br></div>", "i": 8335843}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 201, de 15 de Junio de 1981, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a la C&#xED;a. Pesquera Camanchaca S.A., para operar una embarcaci&#xF3;n en el litoral comprendido entre Coquimbo y Corral, destinada a la pesca de cerco y extracci&#xF3;n de los mismos recursos que tiene autorizados por resoluciones 11 y 514, de 1980, de la Subsecretar&#xED;a de Pesca.</div><br></div>", "i": 8335844}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Roberto Verdugo Gormaz, Subsecretario de Pesca. </div></div>", "i": 8335845}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "201", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-201"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A LA CIA. PESQUERA CAMANCHACA S.A. PARA AMPLIAR SUS\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1981-06-15", "fecha_derogacion": "1998-02-14", "doble_articulado": false, "id_norma": "125973", "numero_fuente": "31009", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1981-07-07", "vigencias": [{"desde": "1998-02-14", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1981-07-07", "hasta": "1998-02-13", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1998-02-