{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SOLICITA CONSTITUCION LEGAL DEL &quot;PARTIDO POR LA DEMOCRACIA&quot; EN LA XI REGION </div></div>", "i": 7200761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Erich Schnacke Silva y Sergio Bitar Chacra, en representaci&#xF3;n del Partido Por la Democracia, han solicitado la constituci&#xF3;n legal del Partido en la XI Regi&#xF3;n de Ays&#xE9;n del General Carlos Ib&#xE1;&#xF1;ez del Campo, acompa&#xF1;ando 243 fichas de afiliaciones.</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la Ley N&#xB0; 18.603. Por Resoluci&#xF3;n Exenta N&#xB0; O-16 de fecha 10 de Enero de 1992. </div></div>", "i": 7200762}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 10 de Enero de 1992.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 7200763}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "16 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-16 EXENTA"}, {"tipo": "3", "numero": "O-16 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-16 EXENTA"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCION LEGAL DEL PARTIDO POR LA DEMOCRACIA EN LA XI REGION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONSTITUCION LEGAL", "PARTIDO POR LA DEMOCRACIA", "XI", "REGION", "SOLICITUD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-01-10", "doble_articulado": false, "id_norma": "37904", "numero_fuente": "34178", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-01-28", "vigencias": [{"desde": "1992-01-28", "hasta": "", "tipo_version": "3", "t