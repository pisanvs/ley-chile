{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ESTABLECE QUE LA ESCUELA GRANJA N&#xB0; 107, DE SANTA CRUZ, SE DENOMINARA &quot;ADEODATO GARCIA VALENZUELA&quot; El Congreso Nacional ha tenido a bien en prestar su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5973566}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. La Escuela-Granja n&#xFA;mero 107 de Santa Cruz, dentro de la provincia de Colchagua, se denominar&#xE1; en lo sucesivo &quot;Escuela Granja Adeodato Garc&#xED;a Valenzuela&quot;.</div><br></div>", "i": 5973567}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecis&#xE9;is de Julio de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- Francisco Cereceda.</div><br></div>", "i": 5973568}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13973", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13973"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "ESTABLECE QUE LA ESCUELA GRANJA N° 107, DE SANTA CRUZ, SE DENOMINARA ADEODATO GARCIA VALENZUELA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMBRE", "ESCUELA GRANJA ADEODATO GARCIA VALENZUELA", "SANTA CRUZ"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-07-16", "doble_articulado": false, "id_norma": "27607", "numero_fuente": "24704", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-07-28", "vigencias": [{"desde": "1960-07-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenci