{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 2.256 EXENTO, DE 2005 </div><br></div>", "i": 6566561}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 2.256, de 30 de diciembre de 2005, se han aprobado programas de Religi&#xF3;n Cat&#xF3;lica para todos los cursos de 1&#xBA; a 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica y de 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, ambas modalidades, y deroga decretos exentos que indica. </div></div>", "i": 6566562}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de marzo de 2006.- Pedro Montt Leiva, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6566563}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2256 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2256 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 2.256 EXENTO, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PROGRAMAS DE ESTUDIO", "RELIGION CATOLICA", "EDUCACION BASICA", "EDUCACION MEDIA", "ESTABLECIMIENTOS EDUCACIONALES", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-30", "doble_articulado": false, "id_norma": "248809", "numero_fuente": "38435", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-04-08", "vigencias": [{"desde": "2006-04-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-04-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-04-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingres