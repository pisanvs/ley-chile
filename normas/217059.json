{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6447883}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.675, de 29 de octubre de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD RUBIO Y MAUAD LIMITADA&nbsp; para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en Ger&#xF3;nimo M&#xE9;ndez N&#xBA; 1841, Galp&#xF3;n N&#xBA; 37, Coquimbo, IV Regi&#xF3;n, donde podr&#xE1; elaborar, en las l&#xED;neas de proceso que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Cocido, Fresco-Enfriado, Fresco-Refrigerado y Congelado: Osti&#xF3;n del norte, Cholga, Macha, Ostra chilena, Loco, Lapa, Camar&#xF3;n nailon, Jaiba lim&#xF3;n, Jaiba marmola, Jaiba peluda o pachona, Jaiba reina, Langostino amarillo, Langostino colorado.</div><br></div>", "i": 6447884}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de octubre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6447885}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2675", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2675"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-29", "doble_articulado": false, "id_norma": "217059", "numero_fuente": "37708", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-11-12", "vigencias": [{"desde": "2003-11-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-11-12", "fin_vigencia": ""