{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9090460}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.764 de 16 de diciembre de 2010, de esta Subsecretaria, modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1015987&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2255 de 2010</a>, de esta Subsecretaria, que autoriz&#xF3; al INSTITUTO DE INVESTIGACI&#xD3;N PESQUERA para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Estado reproductivo y Monitoreo de las capturas de los recursos pel&#xE1;gicos sardina com&#xFA;n (Strangomera bentincki) y anchoveta (Engraulis ringens) en la IX y XIV Regi&#xF3;n&quot;, en el sentido de extender el per&#xED;odo hasta el d&#xED;a 31 de diciembre de 2010, inclusive y en los dem&#xE1;s t&#xE9;rminos se&#xF1;alados en la resoluci&#xF3;n extractada.</div></div>", "i": 9090461}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de diciembre de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9090462}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3764 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3764 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO."], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-16", "doble_articulado": false, "id_norma": "1021633", "numero_fuente": "39847", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-12-30", "vigencias": [{"