{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6410298}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 3.013, de 27 de diciembre de 2002, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto las resoluciones N&#xBA; 276, N&#xBA;277, N&#xBA; 279, modificadas por resoluciones N&#xBA; 1.791, N&#xBA;1.792 y N&#xBA; 1.793, todas de 1995, de esta Subsecretar&#xED;a, que otorgaron a EMPRESA DE CONSTRUCCION Y CARPINTERIA NAVAL CONCAR S.A. permisos extraordinarios de pesca para la unidad de pesquer&#xED;a del recurso hidrobiol&#xF3;gico Bacalao de profundidad. </div></div>", "i": 6410299}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de diciembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6410300}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3013", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3013"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-27", "doble_articulado": false, "id_norma": "206740", "numero_fuente": "37459", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-01-15", "vigencias": [{"desde": "2003-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "IMH