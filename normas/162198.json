{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xBA; 37, DE 1985 </div></div>", "i": 8526691}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 330, de 10 de Junio de 1985 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n N&#xBA; 37, de 1985, de la misma Subsecretar&#xED;a, que autoriz&#xF3; a la Empresa de Desarrollo Pesquero de Chile Ltda., para operar la nave factor&#xED;a &quot;Fuji&quot; en labores extractivas y de procesamiento de krill, en orden a sustituir la zona de operaci&#xF3;n fijada en el numeral 1&#xBA;, por la siguiente:</div><div class=\"p\">&quot;en las aguas cubiertas por el Tratado Ant&#xE1;rtico y la Convenci&#xF3;n para la Conservaci&#xF3;n de los Recursos Vivos Marinos Ant&#xE1;rticos&quot;.</div><br></div>", "i": 8526692}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de Junio de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 8526693}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "330", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-330"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION Nº 37, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-10", "doble_articulado": false, "id_norma": "162198", "numero_fuente": "32199", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-18", "vigencias": [{"desde": "1985-06-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-06