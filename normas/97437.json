{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8328740}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;397, de 20 de marzo de 1998, de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de</div><div class=\"p\">acuicultura N&#xBA;95103198, presentada por PESQUERA Y COMERCIAL</div><div class=\"p\">RIO PEULLA S.A., para operar un centro de cultivo ubicado en</div><div class=\"p\">Tubildad, frente a Punta Pirquen, comuna de Quemchi,</div><div class=\"p\">provincia de Chilo&#xE9;, X Regi&#xF3;n, conforme lo dispuesto en los</div><div class=\"p\">art&#xED;culos 78 y 88 de la Ley General de Pesca y Acuicultura. </div></div>", "i": 8328741}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de marzo de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8328742}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "397", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-397"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "QUEMCHI", "PESQUERA Y COMERCIAL RIO PEULLA S.A.", "DECIMA REGION", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-03-20", "doble_articulado": false, "id_norma": "97437", "numero_fuente": "36028", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-03-30", "vigencias": [{"desde": "1998-03-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Únic