{"html": [{"t": "<div><div class=\"p\">Liberacion de derechos de las lanas cardadas i sin cardar.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, diciembre 16 de 1870.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha aprobado el siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI</div></div>", "i": 10062791}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  ARTICULO 1.&#xB0;</div><br><div class=\"p\">&nbsp; &nbsp;  Las Lanas cardadas i sin cardar podr&#xE1;n introducirse al pais, sin pagar derechos de internacion.</div></div>", "i": 10062792}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. 2.&#xB0;</div><br><div class=\"p\">&nbsp; &nbsp;  Esta lei surtir&#xE1; sus efectos desde el dia de su promulgacion.</div></div>", "i": 10062793}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, lo he aprobado i sancionado; por tanto, ordeno se promulgue i lleve a efecto en todas sus partes como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  JOS&#xC9; JOAQUIN P&#xC9;REZ</div><br><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; A. Gandarillas</div></div>", "i": 10062794}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "S/N", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "Ley-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Liberacion de derechos de las lanas cardadas i sin cardar.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1870-12-16", "doble_articulado": false, "id_norma": "1137244", "numero_fuente": "1870", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1870-12-16", "hasta": "", "tipo_versi