{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 183 EXENTO, DE 1994 </div></div>", "i": 7161029}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 183 de fecha 22 de Abril de 1994 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; al Centro de Formaci&#xF3;n T&#xE9;cnica Instituto de Massachussets, el plan y programas de estudios de la Carrera y T&#xED;tulo T&#xE9;cnico de Nivel Superior que se indica, para ser impartida en la Casa Central de Talca, Sede N&#xB0; 1 de Curic&#xF3; y Sede N&#xB0; 2 de Linares, a contar del a&#xF1;o 1994:</div><div class=\"p\"> Carrera : Administraci&#xF3;n de Empresas menci&#xF3;n Personal o</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Marketing.</div><div class=\"p\"> T&#xED;tulo&nbsp; : T&#xE9;cnico en Administraci&#xF3;n de Empresas, o</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  T&#xE9;cnico en Administraci&#xF3;n de Empresas menci&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Personal o Marketing.</div><br></div>", "i": 7161030}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 26 de Agosto de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161031}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "183 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-183 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_derogacion": "2024-01-31", "doble_articulado": false, "id_norma": "20583", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-09-07", "vigencias": [{"des