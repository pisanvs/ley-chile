{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,798, que concede fondos para combatir la viruela en Quillota.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,798.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 8276723}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para conceder un ausilio estraordinario de quince mil pesos ($15,000) a la Junta de Beneficencia de Quillota para combatir la epidemia de viruela. </div></div>", "i": 8276724}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a trece de Setiembre de mil novecientos veintiuno.- ARTURO ALESSANDRI.-H&#xE9;ctor Arancibia Laso. </div></div>", "i": 8276725}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3798", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3798"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NÚM. 3.798, QUE CONCEDE FONDOS PARA COMBATIR LA VIRUELA EN QUILLOTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUNTA BENEFICENCIA DE QUILLOTA", "FONDOS", "CONCESION", "VIRUELA", "PROFILAXIS", "PRESIDENTE DE LA REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1921-09-13", "doble_articulado": false, "id_norma": "24255", "numero_fuente": "13079", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1921-09-21", "vigencias": [{"desde": "1921-09-21", "ha