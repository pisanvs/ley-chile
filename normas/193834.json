{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6366070}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.995, de 30 de noviembre de 2001, se expropi&#xF3; el lote de terreno N&#xBA;23-H1, superficie 735 m2., rol de aval&#xFA;o en tr&#xE1;mite, comuna de Purranque, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: R&#xED;o Bueno Puerto Montt. Sector: poblaci&#xF3;n Dollinco de Km. 957,100 a Km. 957,400 D&#xE9;cima Regi&#xF3;n, se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Olegario Nahuelcheo Nahuelhuen, ascendente a la cantidad de $25.097.120.</div><br></div>", "i": 6366071}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6366072}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1995", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1995"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-30", "doble_articulado": false, "id_norma": "193834", "numero_fuente": "37160", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-15", "vigencias": [{"desde": "2002-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2002-01-16", "fecha_version": "2002-01-15", "fecha_actualizacion_texto": "2002-01-15", "tipo_tra