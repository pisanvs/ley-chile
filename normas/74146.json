{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 541 EXENTO, DE 1996 </div></div>", "i": 6040983}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 541 de fecha 25 de septiembre de 1996 del Ministerio de Educaci&#xF3;n, se declararon aprobadas para todos los efectos legales las carreras que se indican, para las Sedes y fechas que se se&#xF1;alan del Centro de Formaci&#xF3;n T&#xE9;cnica Inacap:</div><br><br><br><div class=\"p\">Sede N&#xBA; 25 - Calama</div><br><div class=\"p\">Carrera : Mec&#xE1;nica Automotriz.</div><div class=\"p\">T&#xED;tulo&nbsp; : T&#xE9;cnico en Mec&#xE1;nica Automotriz.</div><div class=\"p\">Fecha&nbsp;  : A contar del a&#xF1;o 1988.</div><br><br><div class=\"p\">Sede N&#xBA; 18 - Temuco</div><br><div class=\"p\">Carrera : Turismo</div><div class=\"p\">T&#xED;tulo&nbsp; : T&#xE9;cnico en Turismo Fecha&nbsp;  : a contar del a&#xF1;o 1992.</div><br></div>", "i": 6040984}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de octubre de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6040985}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "541 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-541 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 541 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["APROBACION", "CENTRO DE FORMACION TECNICA INACAP", "PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "CALAMA", "TEMUCO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-09-25", "doble_articulado": false, "id_norma": "74146", "numero_fuente": "35811", "tipo_version": "3", "tipo_version_s":