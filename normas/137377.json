{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.142 EXENTO, DE 1998 </div><br></div>", "i": 7249319}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 1.142 de 30 de diciembre de 1998, se ha modificado el plan de estudio para 7&#xBA; y 8&#xBA; a&#xF1;o b&#xE1;sico aprobado por decreto supremo exento de Educaci&#xF3;n N&#xBA; 573 de 1993, al Colegio Internacional SEK de Santiago, en el sentido de suprimir, en ambos cursos, la asignatura de Franc&#xE9;s, a partir del a&#xF1;o escolar 1999. Dicha carga horaria ser&#xE1; destinada a complementar el n&#xFA;mero de clases semanales de la asignatura de Ingl&#xE9;s.</div><br></div>", "i": 7249320}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de enero de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7249321}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1142 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1142 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.142 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-12-30", "doble_articulado": false, "id_norma": "137377", "numero_fuente": "36380", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-06-05", "vigencias": [{"desde": "1999-06-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-06-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-06-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincula