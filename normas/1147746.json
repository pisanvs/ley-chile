{"html": [{"t": "<div><div class=\"p\">IMPARTE INSTRUCCIONES SOBRE DECLARACI&#xD3;N Y PAGO DE IMPUESTO QUE INDICA</div></div>", "i": 10138412}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de circular del Servicio de Impuestos Internos N&#xBA; 49, de fecha 20 de julio de 2020, que Imparte instrucciones sobre declaraci&#xF3;n y pago del denominado impuesto a las fuentes fijas contaminantes, contenido en el art&#xED;culo 8&#xBA; de la ley N&#xBA; 20.780, modificado por las leyes N&#xBA; 20.899, que simplifica el sistema de tributaci&#xF3;n a la renta y perfecciona otras disposiciones legales, y N&#xBA; 21.210, que moderniza la legislaci&#xF3;n tributaria. Deja sin efecto <a href=\"https://www.leychile.cl/navegar?idNorma=1092664&amp;idVersion=2020-07-24\">circular N&#xBA; 47, de 2016</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta circular est&#xE1; publicado en la p&#xE1;gina web del Servicio de Impuestos Internos (www.sii.cl).- </div><br></div>", "i": 10138413, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fernando Javier Barraza Luengo, Director Nacional.</div><div class=\"p\"> </div></div>", "i": 10138414}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "49", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-49"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "IMPARTE INSTRUCCIONES SOBRE DECLARACIÓN Y PAGO DE IMPUESTO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1788950", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-07-20", "doble_articulado": false, "id_norma": "1147746", "numero_fuente": "42713", "tip