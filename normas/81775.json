{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8312866}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xB0;. 917. de 13 de Agosto de 1991. de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n. decl&#xE1;rase la caducidad de conformidad con el</div><div class=\"p\">art&#xED;culo 7&#xB0; del DS N&#xB0;. 175. de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, de la Resoluci&#xF3;n N&#xB0;. 1445, de 1987, de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a don JOSE LUIS GARCIA GONZALEZ, R.U.T. N&#xB0;.</div><div class=\"p\">3.189.300-3, domiciliado en calle Las Hualtatas N&#xB0;. 6672, Las Condes, Santiago, para ampliar actividades pesqueras. </div></div>", "i": 8312867}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 13 de Agosto de 1991. Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8312868}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "917", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-917"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-08-13", "doble_articulado": false, "id_norma": "81775", "numero_fuente": "34072", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-09-21", "vigencias": [{"desde": "1991-09-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-09-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-09