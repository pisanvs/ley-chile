{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6410478}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n, que suscribe, certifica que la carrera de &quot;Pedagog&#xED;a en Ingl&#xE9;s&quot; que ofrece el Instituto Profesional Instituto Chileno Brit&#xE1;nico de Cultura, autorizada seg&#xFA;n Certificado N&#xBA; 169 de fecha 17 de Marzo de 1983, ha cumplido con los requisitos establecidos en el art&#xED;culo 14&#xBA; del DFL. N&#xBA; 5 de 1981 del Ministerio de Educaci&#xF3;n, seg&#xFA;n lo certifica la Universidad de Santiago de Chile, quien actu&#xF3; como entidad examinadora de los alumnos de dicha carrera .</div><div class=\"p\">&nbsp; &nbsp;  El Instituto Profesional Instituto Chileno Brit&#xE1;nico de Cultura est&#xE1; en condiciones de otorgar independientemente el t&#xED;tulo correspondiente a la carrera de &quot;Pedagog&#xED;a en Ingl&#xE9;s&quot;, a contar del a&#xF1;o 1990.</div><br></div>", "i": 6410479}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de Enero de 1991.</div><div class=\"p\">&nbsp; &nbsp;  RAUL ALLARD NEUMANN Subsecretario de Educaci&#xF3;n </div></div>", "i": 6410480}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-24", "doble_articulado": false, "id_norma": "206804", "numero_fuente": "33899", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-02-20", "vigencias": [{"desde": "