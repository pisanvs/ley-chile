{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 969 EXENTO, DE 2007</div><br><br><br></div>", "i": 7345578}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 969 de 24 de mayo de 2007, se ha aprobado al Colegio Alem&#xE1;n de Santiago, en representaci&#xF3;n de la Asociaci&#xF3;n de Colegios Alemanes de Chile, planes de estudio de 1&#xBA; a 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica para los Colegios Alemanes que se individualizan en el art&#xED;culo 1&#xBA; del presente decreto, los que ser&#xE1;n aplicados a contar del a&#xF1;o escolar 2007.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los cursos de 1&#xBA; a 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica. </div></div>", "i": 7345579}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de junio de 2007.- Pilar Romaguera Gracia, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 7345580}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "969 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-969 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 969 EXENTO, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO ALEMAN", "SANTIAGO", "PLANES DE ESTUDIO", "ENSEÑANZA BASICA", "APRUEBA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-05-24", "doble_articulado": false, "id_norma": "261931", "numero_fuente": "38792", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-06-19", "vigencias": [{"desde": "2007-06-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-0