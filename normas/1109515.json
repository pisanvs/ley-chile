{"html": [{"t": "<div><br><div class=\"p\">DECLARACI&#xD3;N JURADA N&#xBA; 1924</div></div>", "i": 9842236}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta SII N&#xBA; 100, del 13 de octubre de 2017, que establece:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1086052&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta SII N&#xBA; 107, de 2015</a>, reemplazando resolutivo N&#xBA; 1, disponiendo la obligaci&#xF3;n de presentar Declaraci&#xF3;n Jurada N&#xBA; 1924 a los empresarios individuales.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de octubre de 2017. </div></div>", "i": 9842237}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "100 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-100 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DECLARACIÓN JURADA Nº 1924", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1289071; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-10-13", "doble_articulado": false, "id_norma": "1109515", "numero_fuente": "41887", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-10-19", "vigencias": [{"desde": "2017-10-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-10-19", "fin_vigencia": ""}, "vigencias_version_norma":