{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6236672}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xB0; 48 de 17 de Enero de 1985, conforme Art. 5&#xB0; transitorio C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento de aguas proporcionales que corresponden a las parcelas N&#xB0;s 1 a la 10 y sitios N&#xB0;s 1 al 13 del Proyecto de Parcelaci&#xF3;n &quot;Nueva Aurora&quot; formado por el predio &quot;Mauco&quot; de la comuna de Quintero, V Regi&#xF3;n. Los de rechos de agua se extraen de los Canales Colono y Mauco, Publicaci&#xF3;n hecha conforme Art. 13, Ley N&#xB0; 18.377.-</div><br></div>", "i": 6236673}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6236674}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "48 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-48 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-17", "doble_articulado": false, "id_norma": "156770", "numero_fuente": "32110", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-01", "vigencias": [{"desde": "1985-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-03-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2000-02-25", "fecha_ver