{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8305013}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 910 de 30 de junio de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 1&#xBA; de la Resoluci&#xF3;n N&#xBA; 925, de 1995, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD ARMADORES PESQUEROS PORVENIR LTDA., para sustituir la nave &quot;Isla L&#xF3;pez&quot;, en el sentido de actualizar las caracter&#xED;sticas n&#xE1;uticas de esta &#xFA;ltima, en los t&#xE9;rminos que se indican:</div><br><br><div class=\"p\">Nombre&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &quot;Isla L&#xF3;pez&quot;</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  1869</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 22,1 m.</div><div class=\"p\">T.R.G. (Nacional)&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  83 t.</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp;  114,4 m3.</div><div class=\"p\">Arte de pesca&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Cerco.</div><br></div>", "i": 8305014}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de junio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8305015}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "910", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-910"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "SOCIEDAD PESQUEROS PORVENIR LTDA.", "PESCA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [],