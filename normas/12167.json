{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ACEPTA RENUNCIA VOLUNTARIA A MINISTRO DE ESTADO Santiago, 10 de Marzo de 1994.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 304.- Visto: Lo dispuesto en el art&#xED;culo 32&#xB0;, N&#xB0; 9, de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile,</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 8261298}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Ac&#xE9;ptase la renuncia voluntaria a contar del 11 de Marzo de 1994, presentada a su cargo de Ministro de Estado en la Cartera de Interior por don Enrique Krauss Rusque.</div><br></div>", "i": 8261299}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Enrique Krauss Rusque, Ministro del Interior.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud., para su conocimiento.- Saluda a Ud., Belisario Velasco Baraona, Subsecretario del Interior.</div><br></div>", "i": 8261300}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "304", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-304"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "ACEPTA RENUNCIA VOLUNTARIA A MINISTRO DE ESTADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RENUNCIA VOLUNTARIA", "MINISTRO ESTADO", "MINISTERIO INTERIOR", "ENRIQUE KRAUSS RUSQUE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-10", "doble_articulado": false, "id_norma": "12167", "numero_fuente": "34818", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-03-18", "vigencias": [{"desde": "1994-03-18", "