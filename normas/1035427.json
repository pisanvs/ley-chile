{"html": [{"t": "<div><br><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A DON REN&#xC9; OCTAVIO CORVAL&#xC1;N CORREA</div></div>", "i": 9220904}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La VI Direcci&#xF3;n Regional Rancagua del SII, por resoluci&#xF3;n exenta N&#xBA; 6.518, de fecha 30.11.2011, otorga la calidad de Agente Retenedor del Impuesto al Valor Agregado en los contratos de instalaci&#xF3;n o confecci&#xF3;n de especialidades, a don Ren&#xE9; Octavio Corval&#xE1;n Correa, RUT N&#xBA; 5.897.630-K. Dicho acto de autoridad regir&#xE1; a contar del d&#xED;a primero del mes siguiente al de esta publicaci&#xF3;n, de acuerdo a lo establecido en la resoluci&#xF3;n exenta SII N&#xBA; 142, de 26.12.2005, de la Direcci&#xF3;n Nacional.- </div></div>", "i": 9220905}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Luis Aguirre P&#xE9;rez, Director Regional.</div></div>", "i": 9220906}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6518 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6518 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VI DIRECCIÓN REGIONAL RANCAGUA"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A DON RENÉ OCTAVIO CORVALÁN CORREA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-11-30", "doble_articulado": false, "id_norma": "1035427", "numero_fuente": "40145", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-12-27", "vigencias": [{"desde": "2011-12-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-12-27", "fin_vigencia