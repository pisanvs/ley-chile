{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 3.269 EXENTA, DE 2002 </div></div>", "i": 7291608}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 3.269, de 20 de marzo del a&#xF1;o 2002, se ha aprobado al Colegio San Ignacio El Bosque, comuna de Las Condes, Regi&#xF3;n Metropolitana, un plan de estudio para 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; simult&#xE1;neamente en todos los cursos a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en la presente resoluci&#xF3;n.</div><br></div>", "i": 7291609}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de marzo de 2002.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 7291610}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3269 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3269 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 3.269 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-20", "doble_articulado": false, "id_norma": "197920", "numero_fuente": "37256", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-11", "vigencias": [{"desde": "2002-05-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "