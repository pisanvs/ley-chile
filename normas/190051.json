{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6351458}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.181, de 31 de julio de 2001, se expropiaron los lotes de terreno Nos 59-L, 59-M, 59-N, 59-&#xD1;, 59-O y 59-P, superficies 132 m&#xB2;, 147 m&#xB2;, 150 m&#xB2;, 141 m&#xB2;, 141 m&#xB2; y 147 m&#xB2;, rol de aval&#xFA;o 375-2, comuna de El Quisco, para la obra Red Vial Litoral Central. Sector 2: Camino Algarrobo - Casablanca (Ruta F-90), Quinta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Alberto Gaspar Melkonian Pereira y otros, ascendente a la cantidad total de $4.420.765. </div></div>", "i": 6351459}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6351460}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1181", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1181"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-07-31", "doble_articulado": false, "id_norma": "190051", "numero_fuente": "37074", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-10-01", "vigencias": [{"desde": "2001-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-10-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JRC", "fecha_ingreso": "20