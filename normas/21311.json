{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 471 EXENTO, DE 1993</div><br><br></div>", "i": 7161910}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto supremo exento de Educaci&#xF3;n N&#xB0; 471 de 10 de septiembre de 1993 se ha aprobado un plan especial de estudio para el Colegio &quot;The Angel&apos;s School&quot;, de Santiago, para Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, que se aplicar&#xE1; simult&#xE1;neamente en todos los cursos, a contar del a&#xF1;o escolar 1993.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban los programas para la asignatura de Filosof&#xED;a de 1&#xB0; a 4&#xB0; a&#xF1;o medio.</div><br></div>", "i": 7161911}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 1 Octubre 1993.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161912}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "471 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-471 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 471 EXENTO, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "COLEGIO THE", "ANGEL`S SCHOOL", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-09-10", "doble_articulado": false, "id_norma": "21311", "numero_fuente": "34689", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-10-13", "vigencias": [{"desde": "1993-10-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-10-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "19