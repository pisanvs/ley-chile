{"html": [{"t": "<div><div class=\"p\">AUTORIZA A PESQUERA PACIFICO NORTE LTDA., PARA DESARROLLAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 7275492}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 500, de 26 de Octubre de 1984, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Pesquera Pac&#xED;fico Norte Ltda., domiciliada en la ciudad de Iquique, para operar las embarcaciones de cerco denominadas &quot;Granada&quot; y &quot;Valencia&quot;, en la zona del litoral comprendida entre la I y la II Regi&#xF3;n, en labores extractivas de jurel, sardina espa&#xF1;ola, caballa y anchoa.</div><br></div>", "i": 7275493}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Octubre de 1984.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7275494}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "500", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-500"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA PACIFICO NORTE LTDA., PARA\nDESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-10-26", "doble_articulado": false, "id_norma": "173893", "numero_fuente": "32012", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1984-11-03", "vigencias": [{"desde": "2001-05-25", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2000-06-24", "hasta": "2001-05-24", "tipo_version": "1", "tipo_version_s": "Intermedio"}, {"desde": "1984-11-03", "hasta