{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8296659}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.261, de 5 de julio de 1996, de esta Subsecretar&#xED;a del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por un a&#xF1;o, a contar de la fecha de la presente resoluci&#xF3;n, el plazo otorgado a PESQUERA TERRANOVA S.A., para continuar operaciones pesqueras con la nave &quot;Isla Tab&#xF3;n&quot;, autorizadas por las Resoluciones N&#xB0; 248 de 1990, N&#xB0; 536 y N&#xB0; 1.838 de 1995, todas de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor.</div><br></div>", "i": 8296660}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 5 de julio de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8296661}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1261", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1261"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA TERRANOVA S.A", "PESCA", "PRORROGA", "PLAZO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-07-05", "fecha_derogacion": "1997-12-10", "doble_articulado": false, "id_norma": "36606", "numero_fuente": "35533", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-08-03", "vigencias": [{"desde": "1997-12-10", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1996-08-03", "hasta": "1997-12-09", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "