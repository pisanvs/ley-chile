{"html": [{"t": "<div><div class=\"p\">EXTRACTO DECRETO EXENTO No. 150, DE 1990 </div></div>", "i": 6063397}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 150, de 16 de mayo de 1990, se ha modificado a contar del a&#xF1;o lectivo 1990, decreto supremo exento de Educaci&#xF3;n No. 283/81, que aprob&#xF3; Plan Especial de Estudio para Educaci&#xF3;n Media modalidad Human&#xED;stico - Cient&#xED;fica para el Colegio Bautista de Temuco, IX Regi&#xF3;n de La Araucan&#xED;a, sustituyendo el m&#xF3;dulo de plan fijo para 1&#xB0; a 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media, progresivamente en la forma que se indica.</div><br></div>", "i": 6063398}, {"t": "<div><div class=\"p\">Santiago, 06 de Junio de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6063399}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "150 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-150 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DECRETO EXENTO No. 150, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-05-16", "doble_articulado": false, "id_norma": "82840", "numero_fuente": "33703", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-06-25", "vigencias": [{"desde": "1990-06-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-06-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-06-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_p