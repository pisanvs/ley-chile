{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESIGNA COMO MINISTRO DE FE A FUNCIONARIOS QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; Santiago, 1 de Agosto de 1995.- N&#xFA;m. 107.- Vistos: Lo dispuesto en el Art. 4&#xB0; del Decreto Ley N&#xB0; 2.974 de 1979.</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 9001294}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Des&#xED;gnase como Ministro de Fe para actuar en las localidades ubicadas en la VIII Regi&#xF3;n, en que no haya Notarios ni Oficiales del Registro Civil, a los siguientes funcionarios:</div><div class=\"p\"> - ELIMINADO<span class=\"n\" id=\"n_0\">RES 71, AGRICULTURA<br>D.O. 30.04.2005</span></div><div class=\"p\"> - Remberto Contreras Santander</div><div class=\"p\"> - Mario Quappe de la Maza</div><div class=\"p\"> - M&#xE1;ximo Sep&#xFA;lveda Silva</div><br></div>", "i": 9001295}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Luis Marambio Canales, Director Nacional.</div><br></div>", "i": 9001296}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "3", "numero": "107", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-107"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "DESIGNA COMO MINISTRO DE FE A FUNCIONARIOS QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMBRAMIENTO", "MINISTRO FE", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-06-25", "doble_articulado": false, "id_norma": "33148", "numero_fuente": "35254", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1995-08-28", "vigencias": [{"desde": "2005-04-30", "hasta": "