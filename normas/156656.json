{"html": [{"t": "<div><div class=\"p\">DEROGA DECRETO N&#xB0; 1.062, DE 1977</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 868.- Santiago, 26 de Octubre de 1984.- Vistos: Estos antecedentes; y teniendo presente: Lo dispuesto en el Art. 4&#xB0; del decreto de Hacienda N&#xB0; 10, de 1967,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 6236422}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Der&#xF3;gase el decreto de Hacienda N&#xB0; 1.062, de 10 de Noviembre de 1977, publicado en el Diario Oficial del 17 de Diciembre de 1977.</div><br></div>", "i": 6236423}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- AUGUSTO PINOCHET UGARTE, General de Ej&#xE9;rcito, Presidente de la Rep&#xFA;blica.- Luis Escobar Cerda, Ministro de Hacienda.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda atentamente a Ud.- Manuel Concha Mart&#xED;nez, Coronel de Ej&#xE9;rcito, Subsecretario de Hacienda. </div></div>", "i": 6236424}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "868", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-868"}], "organismos": ["MINISTERIO DE HACIENDA", "SUBSECRETARÍA DE HACIENDA"], "titulo_norma": "DEROGA DECRETO N° 1.062, DE 1977", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-10-26", "doble_articulado": false, "id_norma": "156656", "numero_fuente": "32.067", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-01-10", "vigencias": [{"desde": "1985-01-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-01-10", "fi