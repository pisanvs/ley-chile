{"html": [{"t": "<div><br><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR EN CONSTRUCCI&#xD3;N</div></div>", "i": 9347827}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La VII Direcci&#xF3;n Regional Talca del SII, por Res. Ex. N&#xBA; 2.124 de 4 de abril 2013, otorga la calidad de agente retenedor a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n a Constructora Osvaldo Bustamante Ugas SpA, RUT N&#xBA; 79.905.700-K, del r&#xE9;gimen de cambio de sujeto del Impuesto al Valor Agregado, que afecta a los contratos de instalaci&#xF3;n o confecci&#xF3;n de especialidades a las empresas constructoras, que efect&#xFA;e con contribuyentes obligados a retener seg&#xFA;n lo establecido en la Res. Ex. N&#xBA; 142/2005, de la Direcci&#xF3;n Nacional.- </div></div>", "i": 9347828}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Sergio Flores Guti&#xE9;rrez, Director Regional.</div></div>", "i": 9347829}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2124 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2124 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VII DIRECCIÓN REGIONAL TALCA"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR EN CONSTRUCCIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-04-04", "doble_articulado": false, "id_norma": "1050426", "numero_fuente": "40544", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-04-26", "vigencias": [{"desde": "2013-04-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-04-26", "fin_vigencia": ""}, "vigencias