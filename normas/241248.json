{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7322259}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.629, de 18 de agosto de 2005, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 341, de 1982, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA ITATA S.A. para ampliar actividades pesqueras con la nave &quot;Atacama V&quot;, en el &#xE1;rea mar&#xED;tima correspondiente a la X Regi&#xF3;n, sobre el recurso Anchoveta, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura, y lo informado en Informe T&#xE9;cnico citado en Visto.</div><br></div>", "i": 7322260}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de agosto de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7322261}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2629 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2629 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-08-18", "doble_articulado": false, "id_norma": "241248", "numero_fuente": "38243", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-08-23", "vigencias": [{"desde": "2005-08-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-08-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-08-23", "fin_vigencia": "", "tipo_version": "3"}], "evento