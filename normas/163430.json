{"html": [{"t": "<div><div class=\"p\">NOTIFICACION </div></div>", "i": 6258388}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 1051 de 30 de Octubre de 1985 del SERVIU Metropolitano, se orden&#xF3; expropiaci&#xF3;n, conforme DL No. 2186 de 1978, inmueble ubicado en calle Jos&#xE9; Alfonso No.</div><div class=\"p\">76, presunto rol de aval&#xFA;os 303-93 comuna de Santiago, aparentemente de dominio de Calani y Banegas Ltda. Comisi&#xF3;n integrada por peritos Pastor Correa Prats, arquitecto, Luis Rojas Quezada, constructor civil y Jorge Cavagnaro Michelis, ingeniero civil, seg&#xFA;n informe de fecha 30 de Septiembre de 1985, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 15.268,000.-, pagadera al contado.</div><br></div>", "i": 6258389}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director SERVIU Metropolitano.</div><br></div>", "i": 6258390}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1051", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1051"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-10-30", "doble_articulado": false, "id_norma": "163430", "numero_fuente": "32322", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-11-15", "vigencias": [{"desde": "1985-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "