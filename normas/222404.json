{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACIONES QUE INDICAN</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6468787}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 95, de 27 de febrero de 2004, de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xBA; 2.186 de 1978, parte inmueble ubicado en Arica N&#xBA; 3540, presunto rol de aval&#xFA;o N&#xBA; 935-31, comuna de Estaci&#xF3;n Central, aparente dominio de Garc&#xED;a Schneider Mar&#xED;a Fr. y otro. Comisi&#xF3;n integrada por peritos Roberto Correa Bezanilla, Arquitecto; Armando Antonio Pinochet Landero, Constructor Civil, y Germ&#xE1;n Alessandri Fabres, Ingeniero Civil. Seg&#xFA;n informe de 25 de octubre de 2003, fij&#xF3; monto provisional indemnizaci&#xF3;n en $24.189.450 pagadera al contado.-</div><br></div>", "i": 6468788}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Directora Serviu Metropolitano.</div><br></div>", "i": 6468789}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "95", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-95"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "ORDENA EXPROPIACIONES QUE INDICAN; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-27", "doble_articulado": false, "id_norma": "222404", "numero_fuente": "37811", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-15", "vigencias": [{"desde": "2004-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vige