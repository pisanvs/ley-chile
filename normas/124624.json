{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; EXTRACTO DE RESOLUCION No. 108, DE 1988 </div></div>", "i": 8334630}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 108, de fecha 26 de Octubre de 1988 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la personalidad jur&#xED;dica de la &quot;Asociaci&#xF3;n Gremial C&#xE1;mara de la Industria Vin&#xED;cola&quot;, inscrita bajo el n&#xFA;mero 520, del Registro que lleva este Ministerio. por haberse configurado respecto de ella la causal de cancelaci&#xF3;n contemplada en el Art&#xED;culo 18 No. 2 letra c) del DL 2.757 de 1979.-</div><br></div>", "i": 8334631}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Norman Bull de la Jara, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8334632}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "108", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-108"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION"], "titulo_norma": "EXTRACTO DE RESOLUCION No. 108, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-10-26", "doble_articulado": false, "id_norma": "124624", "numero_fuente": "33240", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-12-07", "vigencias": [{"desde": "1988-12-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-12-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-12-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi