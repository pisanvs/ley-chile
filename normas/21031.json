{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 340 EXENTO, DE 1996 </div></div>", "i": 7161648}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto exento N&#xB0; 340, de fecha 18 de junio de 1996, del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Vipro Ltda., las adecuaciones a los planes y programas de estudios de las carreras de Gr&#xE1;fica Publicitaria y de Dise&#xF1;o de Vestuario, modific&#xE1;ndose, en consecuencia, las resoluciones exentas de Educaci&#xF3;n N&#xB0; 1.879 de 1986 y N&#xB0; 296 de 1987. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1996.</div><br></div>", "i": 7161649}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 9 de Julio de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161650}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "340 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-340 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 340 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA VIPRO LTDA.", "PROGRAMAS", "ESTUDIO", "PLANES ESTUDIO", "MODIFICACION."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-06-18", "doble_articulado": false, "id_norma": "21031", "numero_fuente": "35525", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-07-25", "vigencias": [{"desde": "1996-07-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-07-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-07-25", "fin_vigen