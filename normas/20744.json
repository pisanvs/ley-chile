{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N. 231 EXENTO DE 1996 </div></div>", "i": 8667336}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 231, de fecha 24 de abril de 1996, del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Centro de Estudios Tur&#xED;sticos CET, las adecuaciones a los planes y programas de estudios de las carreras de Turismo y de Administraci&#xF3;n de Hoteles y Restoranes, modific&#xE1;ndose, en consecuencia, el Decreto Exento N&#xB0; 516 de 1995 y Decreto Exento N&#xB0; 86 de 1994, respectivamente. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1996. </div></div>", "i": 8667337, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 11 de junio de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8667338}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "231 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-231 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N. 231 EXENTO DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA", "CENTRO ESTUDIOS TURISTICOS", "CET", "MODIFICACION", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-04-24", "doble_articulado": false, "id_norma": "20744", "numero_fuente": "35560", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-09-05", "vigencias": [{"desde": "1996-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-09-05", "fin_vigencia": ""}, "vige