{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 212, DE 1988 </div></div>", "i": 6095846}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 212 de 30 de diciembre de 1988 se ha modificado, a contar del a&#xF1;o escolar 1988, el decreto supremo exento de Educaci&#xF3;n N&#xB0; 190 de 1982, que aprob&#xF3; plan especial de estudio al Colegio del Sagrado Coraz&#xF3;n, Apoquindo, de Santiago.-</div><br></div>", "i": 6095847}, {"t": "<div><div class=\"p\">Paulina Dittborn Cordua, Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6095848}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "212 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-212 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 212, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-30", "doble_articulado": false, "id_norma": "93990", "numero_fuente": "33289", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-02-03", "vigencias": [{"desde": "1989-02-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-02-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-02-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CQA", "fecha_ingreso": "1998-03-05", "fecha_version": "1989-02-03", "fecha_actualizacion_texto": "1989-02-03", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6095846}, {"n": "Art