{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,684.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6172832}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados al pais por el jeneral de brigada don Jos&#xE9; Domingo Amun&#xE1;tegui Borgo&#xF1;o, se aumenta, por gracia, a cuatrocientos pesos la pension mensual de que disfruta su viuda, do&#xF1;a Antonia Rivera de Amun&#xE1;tegui.</div><br></div>", "i": 6172833}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiocho de agosto de mil novecientos doce.- Ramon Barros Luco.- Claudio Vicu&#xF1;a S. </div></div>", "i": 6172834}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2684", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2684"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-08-28", "doble_articulado": false, "id_norma": "137665", "numero_fuente": "10365", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-08-29", "vigencias": [{"desde": "1912-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-08-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-08-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "