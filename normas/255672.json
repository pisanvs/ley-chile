{"html": [{"t": "<div><div class=\"p\">COMPLEMENTA EXTRACTO DE DECRETO N&#xBA; 564 EXENTO, DE 2006 </div></div>", "i": 6591252}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.571, fecha 11 de octubre de 2006 del Ministerio de Educac&#xED;&#xF3;n, se complementa extracto del decreto exento de Educaci&#xF3;n N&#xBA; 564 de fecha 15 de mayo de 2006, que reemplaza a contar del a&#xF1;o 2006, las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n De Enac, publicado en el Diario Oficial N&#xBA; 38.537 del 11 de agosto de 2006, p&#xE1;gina 7, en el sentido de incorporar al final del T&#xED;tulo XII las normas de titulaci&#xF3;n.-</div><br></div>", "i": 6591253}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de noviembre de 2006.- Pilar Romaguera Gracia, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 6591254}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1571 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1571 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "COMPLEMENTA EXTRACTO DE DECRETO Nº 564 EXENTO, DE 2006", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-10-11", "doble_articulado": false, "id_norma": "255672", "numero_fuente": "38627", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-11-30", "vigencias": [{"desde": "2006-11-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-11-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-11-30", "fin_vigencia": "", "tipo_version": "3"}], "evento