{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA CAMBIO DE SUJETO DE DERECHO DEL IVA EN LAS VENTAS DE BERRIES</div></div>", "i": 9972292}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La XV Direcci&#xF3;n Regional Metropolitana Santiago Oriente del SII, por resoluci&#xF3;n Ex. N&#xB0; 4.258, de fecha 23 de noviembre de 2018, autoriza, a contar del 1&#xB0; del mes siguiente al de esta publicaci&#xF3;n, a Agr&#xED;cola Agroberries Limitada, RUT N&#xB0; 76.169.449-9, a obtener la calidad de Agente Retenedor del IVA en las Ventas de Berries, conforme a lo establecido en la Res. Ex. SII N&#xB0; 55, de 02.06.2005, modificada por Res. Ex. SII N&#xB0; 58, de 19.05.2006.- </div><br></div>", "i": 9972293}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Paola Gonz&#xE1;lez Quezada, Directora Regional (S). Resoluci&#xF3;n exenta RA N&#xB0; 246/530/2018, de 12/07/2018. </div></div>", "i": 9972294}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4258 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4258 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL SANTIAGO ORIENTE"], "titulo_norma": "AUTORIZA CAMBIO DE SUJETO DE DERECHO DEL IVA EN LAS VENTAS DE BERRIES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1503769; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-11-23", "doble_articulado": false, "id_norma": "1126010", "numero_fuente": "42218", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-11-30", "vigencias": [{"desde": "2018-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2018-12-01", "fin_vigencia":