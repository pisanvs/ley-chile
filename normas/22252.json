{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pension de Gracia Lei n&#xFA;m. 904.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7162710}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, a la viuda e hijas solteras de don Jos&#xE9; Mar&#xED;a Barcel&#xF3;, el goce de una pension vitalicia de cinco mil pesos anuales ($ 5,000), de que disfrutar&#xE1;n con arreglo a la lei de montep&#xED;o militar.</div><br><br></div>", "i": 7162711}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 3 de Febrero de 1897.- FEDERICO ERRAZURIZ.- F. Puga Borne.</div><br></div>", "i": 7162712}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "904", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-904"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "PENSION DE GRACIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JOSE MARIA BARCELO", "MONTEPIO MILITAR", "CONCESION", "VIUDA HIJAS SOLTERAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-02-03", "doble_articulado": false, "id_norma": "22252", "numero_fuente": "5621", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1897-02-03", "vigencias": [{"desde": "1897-02-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1897-02-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "