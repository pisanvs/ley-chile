{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACION DE RECEPTOR ELECTRONICO</div><br><br><br></div>", "i": 7344139}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 67 de 6 de junio de 2007, que deroga autorizaci&#xF3;n otorgada a contribuyente para operar como receptor electr&#xF3;nico.</div><div class=\"p\">&nbsp; &nbsp;  A petici&#xF3;n del contribuyente RUT N&#xBA; 61.103.014-2, se deroga autorizaci&#xF3;n otorgada como receptor de Documentos Tributarios Electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de junio, de 2007.</div><br></div>", "i": 7344140}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "67 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-67 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEROGA AUTORIZACION DE RECEPTOR ELECTRONICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECEPTOR ELECTRONICO", "DOCUMENTOS TRIBUTARIOS ELECTRONICOS", "AUTORIZA", "DEROGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-06", "doble_articulado": false, "id_norma": "261550", "numero_fuente": "38785", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-06-11", "vigencias": [{"desde": "2007-06-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-06-11", "fin_vigencia": ""},