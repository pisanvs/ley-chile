{"html": [{"t": "<div><div class=\"p\">FIJA N&#xD3;MINAS DE AGENTES RETENEDORES Y DE CONTRIBUYENTES SUJETOS A RETENCI&#xD3;N</div></div>", "i": 9930986}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 54, de 29 de junio de 2018, que se&#xF1;ala:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Fija n&#xF3;minas de agentes retenedores y de contribuyentes sujetos a retenci&#xF3;n, conforme a resoluci&#xF3;n Ex. SII N&#xB0; 42, de 30 de abril de 2018, que dispuso el cambio de sujeto para el cumplimiento de IVA.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes junio de 2018.</div></div>", "i": 9930987}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "54 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-54 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "FIJA NÓMINAS DE AGENTES RETENEDORES Y DE CONTRIBUYENTES SUJETOS A RETENCIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1427360", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-06-29", "doble_articulado": false, "id_norma": "1120593", "numero_fuente": "42104", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-07-11", "vigencias": [{"desde": "2018-07-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2018-07-11", "fin_vigencia": ""}, "vigencia