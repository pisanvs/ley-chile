{"html": [{"t": "<div><div class=\"p\">ESTABLECE CUOTA ANUAL DE CAPTURA DEL RECURSO ERIZO EN &#xC1;REA QUE INDICA</div></div>", "i": 10213514}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xB0; 202100035, de 24 de marzo de 2021 de este Ministerio, f&#xED;jase para el a&#xF1;o 2021 una cuota anual de captura de 14.000 toneladas del recurso erizo, a ser extra&#xED;das en el &#xE1;rea mar&#xED;tima de las regiones de Los Lagos y de Ays&#xE9;n del General Carlos Ib&#xE1;&#xF1;ez del Campo, fraccionada de la siguiente forma:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/123457.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10213515}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de marzo de 2021.- Alicia Gallardo Lagno, Subsecretaria de Pesca y Acuicultura.</div><div class=\"p\"> </div><br></div>", "i": 10213516}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "202100035 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-202100035 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "ESTABLECE CUOTA ANUAL DE CAPTURA DEL RECURSO ERIZO EN ÁREA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1920920", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion