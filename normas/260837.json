{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7341875}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA;126 de fecha 30 de marzo del 2007, se expropi&#xF3; el lote de terreno N&#xBA;93-B, superficie 1.228 m&#xB2;, Rol N&#xBA;305-262, comuna de Melipeuco, IX Regi&#xF3;n para la obra &quot;Camino Ruta S-61, sector Cunco Melipeuco, tramo Km. 55,000 al Km. 87,46783, correspondiente al Sub-Tramo III Km. 76,068 al Km.</div><div class=\"p\">87,443&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Julia del Carmen Carrera, ascendente a la cantidad de $1.170.727.- para el lote N&#xBA;93-B. </div></div>", "i": 7341876}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 7341877}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "126 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-126 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-03-30", "doble_articulado": false, "id_norma": "260837", "numero_fuente": "38763", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-05-15", "vigencias": [{"desde": "2007-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2007-05-15", "fecha_version": "2007-05-15", "fec