{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9312050}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP Exento N&#xBA;2391 de 25 de octubre de 2012, de conformidad a lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;4-A, superficie 212 m2, rol de Aval&#xFA;o N&#xBA;236-49, comuna de Coelemu, para la obra &quot;CAMINO RUTA 126, SECTOR COELEMU &#x2013; RAFAEL &#x2013; TOM&#xC9;, TRAMO I, KM. 0,00000 A KM. 20,30000&quot;, VIII Regi&#xF3;n. La Comisi&#xF3;n de peritos, integrada por ROXANA CECILIA ABARZ&#xDA;A GAJARDO, CLAUDIO CASTRO GUTI&#xC9;RREZ Y MAR&#xCD;A ALEJANDRA GUTI&#xC9;RREZ FLORES, fij&#xF3; el valor de tasaci&#xF3;n con fecha 13 de junio de 2012, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario don JOS&#xC9; ORLANDO CHAND&#xCD;A CARTES, en la cantidad de $533.604.-, suma que se pagar&#xE1; al contado. </div></div>", "i": 9312051}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9312052}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2391 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2391 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-10-25", "doble_articulado": false, "id_norma": "1045664", "numero_fuente": "40410", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-11-15", "vigencias": [{"desde": "2012-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012