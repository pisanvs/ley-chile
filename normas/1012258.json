{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 10.258 EXENTA, DE 30 DE DICIEMBRE DE 2009</div><br></div>", "i": 8905172}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente se han modificado las resoluciones exentas de Educaci&#xF3;n <a href=\"https://www.leychile.cl/Navegar?idNorma=196554&amp;idParte=&amp;idVersion=2002-04-10\">N&#xBA;s. 16.289, de 2001</a>; <a href=\"https://www.leychile.cl/Navegar?idNorma=208212&amp;idParte=&amp;idVersion=2003-03-06\">14.123, de 2002</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=274755&amp;idParte=&amp;idVersion=2008-07-19\">4.515, de 2008</a>, que aprobaron planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Colegio Redland School, comuna de Las Condes, de Santiago. Adem&#xE1;s, se aprueban programas de estudio para los sectores que se indican en la presente resoluci&#xF3;n.</div><br></div>", "i": 8905173, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de enero de 2010.- Jaime Veas S&#xE1;nchez, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 8905174}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10258 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-10258 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 10.258 EXENTA, DE 30 DE DICIEMBRE DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-12-30", "doble_articulado": false, "id_norma": "1012258", "numero_fuente": "39628", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-04-06