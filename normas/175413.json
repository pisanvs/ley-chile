{"html": [{"t": "<div><div class=\"p\">EXTRACTOS DE RESOLUCIONES N&#xBA;s. 1.214 Y 1.215, DE 2000 </div><br></div>", "i": 7276618}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Con fecha 31 de agosto de 2000, la Secretar&#xED;a Regional Ministerial de la V Regi&#xF3;n, dict&#xF3; la resoluci&#xF3;n N&#xBA; 1.214, por medio de la cual se le otorg&#xF3; al &apos;&apos;Centro de Abstemios Los Gallos&apos;&apos;, una concesi&#xF3;n de uso gratuito del inmueble ubicado en Av. Washington N&#xBA; 80 de la comuna y provincia de Valpara&#xED;so, por un plazo de 5 a&#xF1;os.-</div><br></div>", "i": 7276619}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Edmundo A. Bustos Az&#xF3;car, Secretario Regional Ministerial V Regi&#xF3;n.</div><br></div>", "i": 7276620}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1214", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1214"}], "organismos": ["MINISTERIO DE BIENES NACIONALES", "DIVISIÓN DE BIENES NACIONALES", "DEPARTAMENTO DE ADQUISICIÓN Y ADMINISTRACIÓN DE BIENES CONFISCADOS", "SECRETARÍA REGIONAL MINISTERIAL", "V REGIÓN DE VALPARAÍSO"], "titulo_norma": "EXTRACTOS DE RESOLUCIONES NºS 1.214 Y 1.215, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-08-31", "doble_articulado": false, "id_norma": "175413", "numero_fuente": "36765", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-15", "vigencias": [{"desde": "2000-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-09-15", "fin_vigencia": "", "tipo_vers