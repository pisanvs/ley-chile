{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CONCEDE SUPLEMENTO AL PRESUPUESTO DE JUSTICIA.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1770.-Santiago, a 23 de Noviembre de 1905.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5951152}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.-Conc&#xE9;dese un suplemento de cincuenta mil pesos al &#xED;tem 1896 de la partida 22 del presupuesto de Justicia, para cubrir el mayor gasto que se ocasione en los diferentes servicios de los establecimientos penales.</div><br></div>", "i": 5951153}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JERMAN RIESCO.-Guillermo Pinto Ag&#xFC;ero.</div><br></div>", "i": 5951154}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1770", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1770"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDE SUPLEMENTO AL PRESUPUESTO DE JUSTICIA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1905", "MODIFICACION", "MINISTERIO", "JUSTICIA", "ESTABLECIMIENTOS PENALES", "SERVICIOS", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-11-23", "doble_articulado": false, "id_norma": "22904", "numero_fuente": "8363", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-11-23", "vigencias": [{"desde": "1905-11-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"ini