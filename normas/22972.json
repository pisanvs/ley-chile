{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,871 que rehabilita al capitan don Ricardo Jervis Villagran</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,871.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5952296}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Rehabil&#xED;tase, por gracia, al capitan de ej&#xE9;rcito don Ricardo Jervis Villagran, para que pueda iniciar su espediente de invalidez. </div></div>", "i": 5952297}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 31 de julio de 1906.- JERMAN RIESCO.- Salvador Vergara A.</div><br></div>", "i": 5952298}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1871", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1871"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "LEI NUM. 1,871 QUE REHABILITA AL CAPITAN DON RICARDO JERVIS VILLAGRAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RICARDO JERVIS VILLAGRAN", "REHABILITACION POR GRACIA", "EXPEDIENTE INVALIDEZ"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-07-31", "doble_articulado": false, "id_norma": "22972", "numero_fuente": "8609", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1906-09-26", "vigencias": [{"desde": "1906-09-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1906-09-26", "fin_vig