{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8327318}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n 179 de fecha 30 de Noviembre de 1990 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la personalidad jur&#xED;dica de la Asociaci&#xF3;n Gremial de Productores Agr&#xED;colas de Paine inscrita bajo el No. 890 del registro que para tal efecto lleva este Ministerio, por haberse configurado respecto de ella, la causal de cancelaci&#xF3;n contemplada en el art&#xED;culo 18 No. 2&#xB0; letra c) del DL 2.757 de 1979.-</div><br></div>", "i": 8327319}, {"t": "<div><div class=\"p\">Jorge Marshall Rivera Subsecretario de Econom&#xED;a Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8327320}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "179", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-179"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-11-30", "doble_articulado": false, "id_norma": "96397", "numero_fuente": "33885", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-02-04", "vigencias": [{"desde": "1991-02-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-02-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-02-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1998-03-26", "fecha_version": "1991-02-04", "fecha_actu