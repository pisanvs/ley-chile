{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7269802}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 342 de 27 de Marzo de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica numeral 3&#xB0; de la resoluci&#xF3;n No.</div><div class=\"p\">1.354, de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don CARLOS GARCIA ALVAREZ, RUT No. 4.490.903-0, domiciliado en calle Blanco No. 423, Lebu, para iniciar actividades pesqueras, en el sentido de incluir la captura del recurso albacora o pez espada, (Xiphias gladius), en el litoral de las Regiones I a X, con el arte de pesca enmalle y arp&#xF3;n. </div></div>", "i": 7269803}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de Marzo de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 7269804}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "342", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-342"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-03-27", "doble_articulado": false, "id_norma": "168760", "numero_fuente": "33945", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-17", "vigencias": [{"desde": "1991-04-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-04-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-04-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie