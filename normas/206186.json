{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7296307}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.833, de 11 de diciembre de 2002, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 1.376, de 1996, numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 1.645, de 1997, y numeral 7&#xBA; de la resoluci&#xF3;n N&#xBA; 1.635, de 2001, todas de esta Subsecretar&#xED;a, que autorizaron a ALIMENTOS MARINOS S.A. para desarrollar actividades pesqueras con la nave &quot;Ogri&quot;, en el sentido de actualizar e incorporar las siguientes caracter&#xED;sticas n&#xE1;uticas de &#xE9;sta:</div><br><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; 28,14 m</div><div class=\"p\">TRG (Internacional)&nbsp;  208,18</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  6,87 m</div><br></div>", "i": 7296308}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de diciembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7296309}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2833", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2833"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-11", "doble_articulado": false, "id_norma": "206186", "numero_fuente": "37444", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-27", "vigencias": [{"desde": "2002-12-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vige