{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6559884}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.863, de 16 de noviembre</div><div class=\"p\">de 2005, de esta Subsecretar&#xED;a, apru&#xE9;base el proyecto de</div><div class=\"p\">manejo y explotaci&#xF3;n de recursos bent&#xF3;nicos del &#xE1;rea de</div><div class=\"p\">manejo correspondiente al sector denominado Matanzas</div><div class=\"p\">Sector C, VI Regi&#xF3;n, individualizada en el art&#xED;culo 1&#xBA;</div><div class=\"p\">N&#xBA; 3 del DS N&#xBA; 332, de 2000, del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, presentado por la</div><br><div class=\"p\">ORGANIZACION COMUNITARIA FUNCIONAL DE PESCADORES</div><div class=\"p\">ARTESANALES BUZOS MARISCADORES Y ALGUEROS DE MATANZAS Y LA VEGA DE PUPUYA.</div><br></div>", "i": 6559885}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 16 de noviembre de 2005.- Edith Saa Collantes, Subsecretario de Pesca (S).</div><br></div>", "i": 6559886}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3863 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3863 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-11-16", "fecha_derogacion": "2009-12-04", "doble_articulado": false, "id_norma": "246962", "numero_fuente": "38379", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2006-02-02", "vigencias": [{"desde": "2009-12-04", "hasta": "", "tipo_version": "2", "tipo_vers