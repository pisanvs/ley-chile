{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza la ereccion en la ciudad de Santiago de un monumento a los h&#xE9;roes de la Concepcion</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,619.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275411}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Autor&#xED;zase la ereccion, en la ciudad de Santiago, de un monumento costeado por erogaciones populares i destinado a conmemorar el sacrificio de los setenta i siete h&#xE9;roes de la Concepcion.</div><br></div>", "i": 8275412}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 24 de Enero de 1912.- RAMON BARROS LUCO.- Ismael Tocornal.</div><br></div>", "i": 8275413}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2619", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2619"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA LA ERECCIÓN EN LA CIUDAD DE SANTIAGO DE UN MONUMENTO A LOS HÉROES DE LA CONCEPCIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SANTIAGO", "HEROES CONCEPCION", "MONUMENTO", "ERECCION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-01-24", "doble_articulado": false, "id_norma": "23390", "numero_fuente": "10193", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-01-31", "vigencias": [{"desde": "1912-01-31", "hasta": "", "tipo_ve