{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6497520}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n N&#xBA; 2.551, de 8 de septiembre de</div><div class=\"p\">2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA CHILE</div><div class=\"p\">S.A., para ampliar actividades pesqueras extractivas con</div><div class=\"p\">la nave &quot;Puerto Ballena&quot;, en las &#xE1;reas mar&#xED;timas que en</div><div class=\"p\">cada caso se indican, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; capturar, en calidad de fauna acompa&#xF1;ante de los recursos Merluza del sur y Congrio dorado, seg&#xFA;n corresponda, los recursos hidrobiol&#xF3;gicos que a continuaci&#xF3;n se se&#xF1;alan: a) Entre el paralelo 44&#xB0;30&apos; LS y 47&#xB0; LS, con palangre: Jibia; b) Entre el paralelo 47&#xB0; LS y 57&#xB0; LS, con palangre: Jibia. </div></div>", "i": 6497521}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de septiembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6497522}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2551", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2551"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-09-08", "fecha_derogacion": "2013-04-26", "doble_articulado": false, "id_norma": "230465", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-09-20", "vigencias": [{"desde": "2013-04-26", "hasta": "", "tipo_version": "2", "tipo_version