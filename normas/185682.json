{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A PANELES ARAUCO S.A.</div><br></div>", "i": 6336219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE 08/N&#xBA; Ex. 894, de fecha 26 de abril de 2001, revoca a Paneles Arauco S.A., RUT N&#xBA; 96.768.760-K, a partir del d&#xED;a 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, la calidad de agente retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las prestaciones de madera, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 18 de la resoluci&#xF3;n Ex.</div><div class=\"p\">N&#xBA; 4.916/2000, de la Direcci&#xF3;n Nacional.</div><br></div>", "i": 6336220}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 26 de abril de 2001.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6336221}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "894 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-894 EXENTA"}, {"tipo": "3", "numero": "DRE-08-894 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-894 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A PANELES\nARAUCO S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-26", "doble_articulado": false, "id_norma": "185682", "numero_fuente": "36972", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-28", "vigencias": [{"desde": "2001-05