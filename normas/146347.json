{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 35 EXENTA, DE&nbsp; 1999 </div><br></div>", "i": 6200685}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 35, del 23 de agosto de 1999, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la I Regi&#xF3;n Tarapac&#xE1;, se aprob&#xF3; el Contrato de Concesi&#xF3;n, adjudicada mediante resoluci&#xF3;n exenta N&#xBA; 34/99 de la misma Secretar&#xED;a Regional, a &apos;&apos;Securitas Test Car S.A.&apos;&apos;, para operar, por un plazo de seis a&#xF1;os, una planta revisora t&#xE9;cnica para veh&#xED;culos, ubicada en&nbsp; V&#xED;a 1, Lote N&#xBA; 3, Sitio A, Manzana J, Bajo Molle, Iquique. </div></div>", "i": 6200686}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Iquique, agosto de 1999.- Eduardo Salas Cerda, Secretario Regional Ministerial Transportes y Telecomunicaciones, I Regi&#xF3;n Tarapac&#xE1;.</div><br></div>", "i": 6200687}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "35 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-35 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL", "I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 35 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-08-23", "doble_articulado": false, "id_norma": "146347", "numero_fuente": "36502", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-10-30", "vigencias": [{"desde": "1999-10-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}