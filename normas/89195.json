{"html": [{"t": "<div><div class=\"p\">AUTORIZA DEMOLICION QUE INDICA</div><br><div class=\"p\">(Extracto)</div><br><div class=\"p\">Decreto No. 08 del Departamento de Cementerios de fecha 27 de Junio de 1990.</div><div class=\"p\">La alcald&#xED;a con esta fecha decret&#xF3; lo que sigue: </div></div>", "i": 6081788}, {"t": "<div><div class=\"p\">1.- Autor&#xED;zase la demolici&#xF3;n total de 47,60 Mts. lineales de nichos, ubicados en el Cementerio de Nacimiento por encontrarse en total deterioro.</div><div class=\"p\">2.- Para proceder a la exhumaci&#xF3;n interna de cad&#xE1;veres existentes en los nichos, se otorgar&#xE1; un plazo de 90 d&#xED;as a contar de la publicaci&#xF3;n de este, para todas aquellas personas que tengan alg&#xFA;n parentesco con los restos existentes en ellos.</div><br></div>", "i": 6081789}, {"t": "<div><div class=\"p\">Nacimiento, 03 de Agosto de 1990.- Ra&#xFA;l Neira Fuentealba, Secretario Municipal.-</div><div class=\"p\">Mar&#xED;a Teresa Klapp M., Alcalde.</div><br></div>", "i": 6081790}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "8", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-8"}], "organismos": ["MUNICIPALIDAD DE NACIMIENTO"], "titulo_norma": "AUTORIZA DEMOLICION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-06-27", "doble_articulado": false, "id_norma": "89195", "numero_fuente": "33746", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-08-16", "vigencias": [{"desde": "1990-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-08-16", "fin_vigencia": ""}, "vigencias_version_norm