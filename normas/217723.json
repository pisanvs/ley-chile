{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6450085}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.928, de 19 de noviembre</div><div class=\"p\">de 2003, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad</div><div class=\"p\">de la resoluci&#xF3;n N&#xBA; 427 de 1997, modificada por</div><div class=\"p\">resoluci&#xF3;n N&#xBA; 536 de 1997, ambas de esta Subsecretar&#xED;a,</div><div class=\"p\">que autorizaron a ROBERTO FERNANDOIS GATICA para operar</div><div class=\"p\">la nave &quot;To-nyn&quot;, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra d) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 6450086}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de noviembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6450087}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2928 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2928 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-11-19", "doble_articulado": false, "id_norma": "217723", "numero_fuente": "37719", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-11-25", "vigencias": [{"desde": "2003-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-11-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-11-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen