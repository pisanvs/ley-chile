{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294994}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 960 de 18 de Octubre de 1994 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 3&#xB0; de la Resoluci&#xF3;n N&#xB0; 150, de 1992, de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a SOCIEDAD PESCA MARINA LTDA., R.U.T. N&#xB0; 89.389.200-1, para operar la nave &quot;Gringo&quot;, en el sentido de agregar el siguiente inciso:</div><div class=\"p\">&nbsp; &nbsp; &quot;Adem&#xE1;s la interesada podr&#xE1; capturar en el litoral de la IV Regi&#xF3;n, con red de arrastre, los siguientes recursos hidrobiol&#xF3;gicos: Camar&#xF3;n nailon y Langostino amarillo.</div><br></div>", "i": 8294995}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 18 de Octubre de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294996}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "960", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-960"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-10-18", "fecha_derogacion": "2007-01-26", "doble_articulado": false, "id_norma": "35933", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-11-03", "vigencias": [{"desde": "2007-01-26", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2005-02-03", "hasta": "2007-01-25", "tipo_version": "1", "tipo_version_s": "Intermedio"}, {"desd