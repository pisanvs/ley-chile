{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6357287}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.471, de 28 de septiembre de 2001, se expropi&#xF3; el lote de terreno N&#xBA; 38-1, superficie 138 m2., rol de aval&#xFA;o 595-12, comuna de Estaci&#xF3;n Central, para la obra Sistema Norte-Sur. Tramo G: Nudo Alameda. Sector: Km. 1.700,00 al Km. 1.900,00, Regi&#xF3;n Metropolitana se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietaria Graciela del Tr&#xE1;nsito Morales Morales, ascendente a la cantidad de $65.620.322.</div><br></div>", "i": 6357288}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6357289}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1471", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1471"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-09-28", "doble_articulado": false, "id_norma": "191606", "numero_fuente": "37111", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-15", "vigencias": [{"desde": "2001-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2001-11-15", "fecha_version": "2001-11-15", "fecha_actualizacion_texto": "2001-11-15", "tipo_tratado": ""}, "alertas": [], "alerta_g