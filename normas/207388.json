{"html": [{"t": "<div><div class=\"p\">Certificado </div></div>", "i": 6412866}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 6,66% anual durante el mes de julio de 1989.</div><br><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de julio de 1989, fue de 6,86% anual. </div></div>", "i": 6412867}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 07 de agosto de 1989.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6412868}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE HACIENDA", "BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-08-07", "doble_articulado": false, "id_norma": "207388", "numero_fuente": "33443", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-08-08", "vigencias": [{"desde": "1989-08-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-08-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-08-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "