{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DEROGA ARTICULO 28&#xB0; DEL DFL. N&#xB0; 274, DE 1960 Santiago, 15 de Octubre de 1979.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp; DFL. N&#xB0; 22-2.345.- Vistos: La facultad conferida por el art&#xED;culo 7&#xB0; del decreto ley N&#xB0; 2.345, de 1978.</div><div class=\"p\">&nbsp; &nbsp; Decreto con fuerza de ley:</div><br></div>", "i": 8253778}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1&#xB0;.- Der&#xF3;gase el art&#xED;culo 28&#xB0; del decreto con fuerza de ley N&#xB0; 274, de 1960.</div><br></div>", "i": 8253779}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese y publ&#xED;quese.- AUGUSTO PINOCHET UGARTE, General de Ej&#xE9;rcito, Presidente de la Rep&#xFA;blica.- Sergio Fern&#xE1;ndez Fern&#xE1;ndez, Ministro del Interior.- Roberto T. Kelly V., Ministro de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Enrique Montero Marx, Coronel de Aviaci&#xF3;n (J), Subsecretario del Interior.</div><br></div>", "i": 8253780}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "22", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-22"}, {"tipo": "13", "numero": "22-2345", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-22-2345"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DEROGA ARTICULO 28° DEL DFL. N° 274, DE 1960", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1979-10-15", "doble_articulado": false, "id_norma": "4042", "numero_fuente": "30518", "tipo_version": "3", "tipo_version