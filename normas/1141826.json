{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 144 EXENTA, DE 2019</div></div>", "i": 10097081}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 12, del 24 de enero de 2020, que modifica la resoluci&#xF3;n exenta N&#xBA; 144, de 2019.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Se modifica la <a href=\"https://www.leychile.cl/Navegar?idNorma=1140745&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 144, de 2019</a>, que fija valores de terrenos y construcciones para el reaval&#xFA;o de los bienes ra&#xED;ces de la primera serie agr&#xED;cola, reemplazando el anexo N&#xBA; 3, de dicha resoluci&#xF3;n, y actualizando a $24.222.145, para el primer semestre de 2020, el monto de aval&#xFA;o exento de Impuesto Territorial para los predios de la primera serie agr&#xED;cola.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento est&#xE1; publicado en www.sii.cl.</div><br></div>", "i": 10097082}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "12 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-12 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 144 EXENTA, DE 2019", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1719813", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-01-24", "doble_articulado": false, "id_norma": "1141826", "numero_fuente": "42567", "tipo_version": "3", "tipo_versi