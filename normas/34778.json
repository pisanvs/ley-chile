{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292456}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 435, de 26 Abril de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por un a&#xF1;o, a contar del 30 de Abril de 1994, el plazo otorgado a SOCIEDAD PESQUERA TEL LIMITADA, R.U.T. N&#xB0; 88.729.500-K, para operar la nave &quot;Venus&quot;, autorizada por Resoluci&#xF3;n N&#xB0; 111, de 1982, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado una circunstancia de fuerza mayor. </div></div>", "i": 8292457}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 26 de Abril de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292458}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "435", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-435"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD PESQUERA TEL LIMITADA", "PLAZO", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-04-26", "doble_articulado": false, "id_norma": "34778", "numero_fuente": "35162", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-05-09", "vigencias": [{"desde": "1995-05-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-05-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-05-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_par