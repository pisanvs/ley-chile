{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 233 EXENTO, DE 1997 </div></div>", "i": 7206334}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Supremo exento de Educaci&#xF3;n N&#xBA; 233 de 18 de febrero de 1997, se ha modificado y complementado el Decreto Supremo exento de Educaci&#xF3;n N&#xBA; 46 de 1995 que aprob&#xF3; plan especial de estudio para el Colegio &quot;Hrvatska Skola&quot;, de Antofagasta, II Regi&#xF3;n para la Educaci&#xF3;n B&#xE1;sica y Media Human&#xED;stico-Cient&#xED;fica.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba Programa de Estudio para Educaci&#xF3;n B&#xE1;sica y Media de la asignatura de Inform&#xE1;tica. </div></div>", "i": 7206335}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 5 de marzo de 1997.- Ra&#xFA;l Allard Neumann, Subsecretario de Educacion (S).</div><br></div>", "i": 7206336}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "233 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-233 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 233 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "COLEGIO HRVATSKA SKOLA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-15", "doble_articulado": false, "id_norma": "70963", "numero_fuente": "35754", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-30", "vigencias": [{"desde": "1997-04-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-04-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-04-30", "fin_vigencia