{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 149, DE 1986 </div></div>", "i": 6249589}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta, No. 149 de fecha 15 de Enero de 1986 del Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante, se aprobaron las modificaciones introducidas a los planes y programas de estudios al Centro de Formaci&#xF3;n T&#xE9;cnica VIPRO Limitada, de las carreras y t&#xED;tulos t&#xE9;cnicos que se indican para, impartirse a contar de 1985:</div><div class=\"p\">Carrera: Sonido</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico en Sonido Carrera:. Traducci&#xF3;n e Interpretaci&#xF3;n de contacto Biling&#xFC;e Ingl&#xE9;s - Espa&#xF1;ol</div><div class=\"p\">T&#xED;tulo : Traductor e Int&#xE9;rprete de contacto Biling&#xFC;e Ingl&#xE9;s - Espa&#xF1;ol.</div><br></div>", "i": 6249590}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Marzo de 1986.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6249591}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "149 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-149 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 149, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-01-15", "doble_articulado": false, "id_norma": "160684", "numero_fuente": "32439", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-04-05", "vigencias": [{"desde": "1986-04-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "v