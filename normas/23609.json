{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Libera de derechos de internacion al perclorato de amonio</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,935.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5954475}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Se declara libre de derechos de internacion el perclorato de amonio.</div><br></div>", "i": 5954476}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 12 de Setiembre de 1914.- RAMON BARROS LUCO.- Enrique Oyarzun.</div><br></div>", "i": 5954477}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2935", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2935"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LIBERA DE DERECHOS DE INTERNACION AL PERCLORATO DE AMONIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PERCLORATO AMONIO", "DERECHOS INTERNACION", "EXENCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1914-09-12", "doble_articulado": false, "id_norma": "23609", "numero_fuente": "10971", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1914-09-15", "vigencias": [{"desde": "191