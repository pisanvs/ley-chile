{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 4,838</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 7299577}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Der&#xF3;gase el art&#xED;culo 16 de la ley n&#xFA;mero 4,321, de 27 de Febrero de 1928.</div><br></div>", "i": 7299578, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y, por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a diecinueve de Febrero de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Mariano Navarrete C.</div><br></div>", "i": 7299579}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4838", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4838"}], "organismos": ["MINISTERIO DE HACIENDA", "SECRETARIA DE HACIENDA"], "titulo_norma": "LEY NUM. 4,838", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-02-19", "doble_articulado": false, "id_norma": "210429", "numero_fuente": "15608", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-02-25", "vigencias": [{"desde": "1930-02-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1930-02-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1930-02-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_