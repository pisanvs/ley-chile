{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n, por gracia, al ex-guardi&#xE1;n de la polic&#xED;a de Yumbel, don Jos&#xE9; Carrero.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8277449}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, al ex-guardi&#xE1;n de la polic&#xED;a de Yumbel, don Jos&#xE9; Carrero, el goce de una pensi&#xF3;n mensual de veinticinco pesos ($ 25).</div><br></div>", "i": 8277450}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 7 de Agosto de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- Guillermo Edwards Matte. </div></div>", "i": 8277451}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4379", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4379"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, AL EX-GUARDIAN DE LA POLICIA DE YUMBEL, DON JOSE CARRERO.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JOSE CARRERO", "PENSION GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-08-07", "doble_articulado": false, "id_norma": "24696", "numero_fuente": "15150", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-08-16", "vigencias": [{"desde": "1928-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-08-16", "fin_vigencia": ""}, "vig