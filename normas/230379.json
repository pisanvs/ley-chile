{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION&nbsp; N&#xBA; 1150 </div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 1150, celebrada el 9 de septiembre de 2004, adopt&#xF3; el siguiente Acuerdo:</div><br></div>", "i": 6497268}, {"t": "<div><div class=\"p\">1150-02-040909-Banco Par&#xED;s-Autorizaci&#xF3;n para emitir tarjeta de cr&#xE9;dito que indica.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; autorizar a Banco Par&#xED;s para emitir la tarjeta de cr&#xE9;dito Mastercard, en su modalidad nacional e internacional, a contar de la fecha en que la Superintendencia de Bancos e Instituciones Financieras otorgue al mismo la autorizaci&#xF3;n de funcionamiento contemplada en el art&#xED;culo 31 de la Ley General de Bancos.</div><br></div>", "i": 6497269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de septiembre de 2004.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6497270}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1150", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1150"}, {"tipo": "5", "numero": "1150-02", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1150-02"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION Nº 1150", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BANCO PARIS", "TARJETA DE CREDITO MASTERCARD", "EMISION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-09-09", "doble_articulado": false, "id_norma": "230379", "numero_fuente": "37964", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-09-16", "vigen