{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 1.960 EXENTA, DE 2014</div></div>", "i": 9450024}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 1.960, de&nbsp; 22 de abril de 2014, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Servicios de Capacitaci&#xF3;n Nexo Limitada (Nexo Capacitaci&#xF3;n Limitada)&quot;, RUT 77.600.020-5 contenida en la resoluci&#xF3;n exenta N&#xBA; 837 de 13 de febrero de 2007, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.</div></div>", "i": 9450025}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp; &nbsp; Marcia Pardo Gonz&#xE1;lez, Jefa Dpto. de Evaluaci&#xF3;n y Organismos (PT).</div></div>", "i": 9450026}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1960 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1960 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 1.960 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-04-22", "doble_articulado": false, "id_norma": "1062193", "numero_fuente": "40853", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-05-10", "vigencias": [{"desde": "2014-05-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-05-10", "fin_vigencia": ""}