{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que concede fondos para combatir la epidemia de viruelas i otras enfermedades infecciosas</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. I667.- Santiago, a 8 de Agosto de 1904.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente:</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274583}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la suma de cincuenta mil pesos en atender a las necesidades orijinadas por la epidemia de viruelas i otras enfermedades infecciosas. </div></div>", "i": 8274584}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- M. E. Ballesteros.</div><br></div>", "i": 8274585}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1667", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1667"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "QUE CONCEDE FONDOS PARA COMBATIR LA EPIDEMIA DE VIRUELAS I OTRAS ENFERMEDADES INFECCIOSAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VIRUELAS", "ENFERMEDADES INFECCIOSAS", "PROFILAXIS", "INVERSION", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-08-08", "doble_articulado": false, "id_norma": "22831", "numero_fuente": "7974", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1904-08-08", "vigencias": [{"desde": "1904-08-08", "hasta": "", "tipo_version