{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7293278}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.433, de 18 de julio de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA ITATA S.A., RUT N&#xBA; 80.860.400-0, con domicilio en Avenida 11 de Septiembre N&#xBA; 2353, piso 7&#xBA;, Providencia, Santiago, para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluciones N&#xBA; 144 de 1985, N&#xBA; 327 de 1989, N&#xBA; 106 de 1992 y N&#xBA; 854 de 2002, todas de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Bah&#xED;a Coronel, Coronel, VIII Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de Harina y Aceite, los siguientes recursos hidrobiol&#xF3;gicos: Bacaladillo o mote, Jurel fino, Machuelo o tritre, Anchoveta blanca, Sardina redonda, Vinciguerria.</div><br></div>", "i": 7293279}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de julio de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7293280}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1433", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1433"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-07-18", "doble_articulado": false, "id_norma": "201077", "numero_fuente": "37324", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-08-02", "vigencias": [{"desde": "2002-08-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vige