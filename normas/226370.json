{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACION DE INMUEBLES QUE INDICA</div><br><div class=\"p\">NOTIFICACION </div></div>", "i": 6483201}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 237 de 11 de mayo de 2004 de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xBA; 2.186 de 1978, del Lote N&#xBA; 303 correspondiente al inmueble ubicado en Santa Rosa 3993, presunto rol de aval&#xFA;o N&#xBA; 3440-6, comuna de San Miguel, aparente dominio de Rodr&#xED;guez Baeza Elena. Comisi&#xF3;n integrada por peritos Jorge Santib&#xE1;&#xF1;ez Sandoval, Constructor Civil; Enzo Bertolini Cepeda, Arquitecto y N&#xE9;stor Peralta Toro, Ingeniero Civil. Seg&#xFA;n informe de 1 de octubre de 2003, fij&#xF3; monto provisional indemnizaci&#xF3;n en $56.083.000 pagadera al contado.</div><br></div>", "i": 6483202}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 6483203}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "237", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-237"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "ORDENA EXPROPIACION DE INMUEBLES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-11", "doble_articulado": false, "id_norma": "226370", "numero_fuente": "37885", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-15", "vigencias": [{"desde": "2004-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci