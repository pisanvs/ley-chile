{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291217}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 227, de 6 de febrero de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a NATIONAL FISHERIES PRODUCTS LTDA., para ampliar actividades pesqueras, en orden a incorporar a la planta ubicada en Avenida Baquedano N&#xB0; 802, Coquimbo, IV Regi&#xF3;n, en la l&#xED;nea de elaboraci&#xF3;n de Congelado, el recurso hidrobiol&#xF3;gico Loco Concholepas concholepas.</div><div class=\"p\">&nbsp; &nbsp; Cad&#xFA;case la Resoluci&#xF3;n N&#xB0; 1.534, de 1995, de esta Subsecretar&#xED;a, conforme lo dispuesto en el art&#xED;culo 6&#xB0;, del D.S. N&#xB0; 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8291218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 6 de febrero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8291219}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "227", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-227"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "AMPLIACION", "PESCA", "NATIONAL FISHERIES", "PRODUCTS LTDA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-02-06", "fecha_derogacion": "2006-03-22", "doble_articulado": false, "id_norma": "33843", "numero_fuente": "35396", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-02-19", "vigencias": [{"desde": "2006-03-22", "hasta":