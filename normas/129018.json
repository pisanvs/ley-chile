{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6145742}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 2.221, de 30 de octubre de 1998, se expropiaron los lotes de terreno N&#xBA; s. 36-C, 90-A y 91, superficies 3.224, 420 y 2.652 m2. respectivamente, roles de aval&#xFA;o 24-31 y 38-24, comuna de Navidad, para la obra Camino Ruta G-880, Sector Rapel - Navidad - La Boca y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Lidia Olgu&#xED;n Catal&#xE1;n y Ram&#xF3;n Ria&#xF1;o Jeria, ascendentes a las cantidades de $ 8.298.640.- para el lote 36-C y $ 3.455.075.- para los lotes 90-A y 91. </div></div>", "i": 6145743}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6145744}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2221", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2221"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-10-30", "doble_articulado": false, "id_norma": "129018", "numero_fuente": "36253", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-01-02", "vigencias": [{"desde": "1999-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-01-06", "fecha_version": "1999-01-02", "fecha_actualizacion_text