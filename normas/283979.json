{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7417194}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;3.184, de 9 de diciembre de 2008, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xB0; de la resoluci&#xF3;n exenta N&#xB0; 2.354 de 2008, rectificada mediante resoluci&#xF3;n exenta N&#xB0; 2.445 de 2008, ambas de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a la PONTIFICIA UNIVERSIDAD CAT&#xD3;LICA DE VALPARA&#xCD;SO para efectuar una pesca de investigaci&#xF3;n de conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del proyecto &quot;Evaluaci&#xF3;n de Langostino colorado en la unidad de pesquer&#xED;a sur, a&#xF1;o 2008&quot;, en el sentido de se&#xF1;alar que la pesca de investigaci&#xF3;n se extender&#xE1; hasta el 31 de diciembre de 2008, inclusive.</div><br></div>", "i": 7417195}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de diciembre de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7417196}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3184 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3184 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-12-09", "doble_articulado": false, "id_norma": "283979", "numero_fuente": "39246", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-12-26", "vigencias": [{"desde": "2008-12-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inici