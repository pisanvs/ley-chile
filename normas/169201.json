{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6276910}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 741, de 07 de Septiembre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Orlando Lagos Alarc&#xF3;n para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea N&#xB0; 1 &quot;Francke - Centro - Rahue Alto&quot; de Osorno, cuyo trazado fue autorizado por resoluci&#xF3;n N&#xB0; 90, de 12 de Junio de 1984 y modificado por resoluci&#xF3;n exenta N&#xB0; 464, de 16 de Septiembre de 1986, de esta Secretar&#xED;a Regional.</div><br></div>", "i": 6276911}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6276912}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "741 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-741 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-07", "doble_articulado": false, "id_norma": "169201", "numero_fuente": "32917", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-11", "vigencias": [{"desde": "1987-11-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vige