{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 989 EXENTO, DE 1997</div><br><br><br></div>", "i": 6137103}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 989 de&nbsp; fecha 30 de septiembre de 1997 del Ministerio de Educaci&#xF3;n, se declar&#xF3; aprobada a la Universidad Santo Tom&#xE1;s, inscrita en el Registro de Universidades bajo el Folio C-N&#xBA; 16 del a&#xF1;o 1988, la carrera de Enfermer&#xED;a conducente al T&#xED;tulo Profesional de Enfermero(a), para ser impartida en su Sede en la ciudad de Santiago, de conformidad al acuerdo adoptado por el Consejo Superior de Educaci&#xF3;n, quien llevar&#xE1; a efecto la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6137104}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 21 de octubre de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6137105}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "989 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-989 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 989 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["UNIVERSIDAD SANTO TOMAS", "CARRERAS PROFESIONALES", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-09-30", "doble_articulado": false, "id_norma": "126493", "numero_fuente": "36199", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-10-28", "vigencias": [{"desde": "1998-10-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-10-28", "fin_vigencia": ""}, "vigencias_version