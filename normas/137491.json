{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,551.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6172262}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados en la ense&#xF1;anza por do&#xF1;a C&#xE1;rmen Aguirre, aum&#xE9;ntase, por gracia, a la cantidad de mil doscientos pesos ($ 1,200) la pension anual de jubilacion de que disfruta.</div><br></div>", "i": 6172263}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto en todas sus partes como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, treinta de agosto de mil novecientos once.- Ramon Barros Luco.- Benjamin Montt.</div><br></div>", "i": 6172264}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2551", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2551"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-08-30", "doble_articulado": false, "id_norma": "137491", "numero_fuente": "10081", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-09-13", "vigencias": [{"desde": "1911-09-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-09-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-09-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v