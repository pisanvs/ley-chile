{"html": [{"t": "<div><br><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA A CAMANCHACA PESCA SUR S.A.</div></div>", "i": 9236487}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del SII, por resoluci&#xF3;n DRE.08 Ex. N&#xBA;917, de fecha 28 de enero de 2012, otorga a Camanchaca Pesca Sur S.A., RUT: 76.143.821-2, a partir del d&#xED;a 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de Sujeto en las adquisiciones de Productos Hidrobiol&#xF3;gicos, de acuerdo a la facultad establecida en el dispositivo N&#xBA;16 de la resoluci&#xF3;n Ex. N&#xBA;3.311 del 30.06.2000, de la Direcci&#xF3;n Nacional.</div></div>", "i": 9236488}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  - Teresa Conejeros Pe&#xF1;a, Directora Regional.</div></div>", "i": 9236489}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "917 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-917 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA A CAMANCHACA PESCA SUR S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-01-28", "doble_articulado": false, "id_norma": "1037166", "numero_fuente": "40184", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-02-10", "vigencias": [{"desde": "2012-02-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-02-10", "fin_vigencia": ""}, "vigencias_versio