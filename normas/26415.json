{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA NOMBRE A LA ACTUAL CALLE COMERCIO DE LA COMUNA DE LOTA</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8278980}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. La calle Comercio de la comuna de Lota se denominar&#xE1; Pedro Aguirre Cerda&quot;.</div><br></div>", "i": 8278981}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, primero de Septiembre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- C. Torres H. </div></div>", "i": 8278982}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10501", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10501"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA NOMBRE A LA ACTUAL CALLE COMERCIO DE LA\nCOMUNA DE LOTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "CALLE PEDRO AGUIRRE CERDA", "LOTA."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-09-01", "doble_articulado": false, "id_norma": "26415", "numero_fuente": "22370", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-10-09", "vigencias": [{"desde": "1952-10-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1952-10-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1952-10-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie