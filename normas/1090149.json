{"html": [{"t": "<div><br><div class=\"p\">PARTIDO AMPLITUD</div></div>", "i": 9700257}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Los se&#xF1;ores Joaqu&#xED;n Godoy Ib&#xE1;&#xF1;ez y Pedro Browne Urrejola, presidente y secretario general de la directiva central provisional del Partido Amplitud, con fecha 15 de abril de 2016, han solicitado la constituci&#xF3;n legal del partido en la Regi&#xF3;n XI de Ais&#xE9;n del General Carlos Ib&#xE1;&#xF1;ez del Campo. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de 106 afiliaciones.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el <a href=\"https://www.leychile.cl/Navegar?idNorma=29994&amp;idParte=8285857&amp;idVersion=\">art&#xED;culo 17&#xBA;</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=29994&amp;idParte=0&amp;idVersion=\">ley N&#xBA; 18.603</a>, por resoluci&#xF3;n O - N&#xBA;0120, de fecha 20 de abril de 2016.- </div></div>", "i": 9700258}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Elizabeth Cabrera Burgos, Directora (S).</div></div>", "i": 9700259}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "120", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-120"}, {"tipo": "3", "numero": "O-120", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-120"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO AMPLITUD", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1021374; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-04-20", "doble_articulado": false, "id_norma": "1090149", "numero_fuente": "41451", "tipo_version": "3", "tipo_version_s": "Única", "fecha_p