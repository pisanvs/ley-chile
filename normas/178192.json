{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION N&#xBA; 8.656 EXENTA, DE 1999 </div></div>", "i": 6309760}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; Ex. 5.186 de 22 de noviembre de 2000, de la Direcci&#xF3;n Nacional del Servicio de Impuestos Internos, se derog&#xF3;, a contar de esa fecha, la Res. N&#xBA; Ex. 8.656, de 28 de diciembre de 1999, que reglament&#xF3; el sistema de venta de informaci&#xF3;n de bienes ra&#xED;ces al sector privado y al sector p&#xFA;blico no municipal, sin perjuicio de la entrega de esta informaci&#xF3;n a las entidades de la Administraci&#xF3;n del Estado que &#xE9;stas requieran para el cumplimiento de sus fines propios. </div></div>", "i": 6309761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Javier Etcheberry Celhay, Director.</div><br></div>", "i": 6309762}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5186 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5186 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEROGA RESOLUCION Nº 8.656 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-11-22", "doble_articulado": false, "id_norma": "178192", "numero_fuente": "36821", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-11-24", "vigencias": [{"desde": "2000-11-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-11-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-11-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient