{"html": [{"t": "<div><div class=\"p\">MODIFICA ORDENANZA No. 206, DE 1985</div><br><div class=\"p\">Anexo:</div><br></div>", "i": 8924802}, {"t": "<div><div class=\"p\">&quot;Modif&#xED;case Ordenanza No. 206 de fecha 03 de Diciembre de 1985&quot; ins&#xE9;rtese al Art&#xED;culo S&#xE9;ptimo, el inciso segundo que dice a la letra:</div><div class=\"p\">&quot;Sin perjuicio de lo anterior, ser&#xE1; facultad del Alcalde de la Comuna, previo informe social o del que &#xE9;ste determine, rebajar los valores por concepto de Derecho de Sepultaci&#xF3;n, hasta un tope del 70% de los valores consignados en la presente Ordenanza, para instituciones de Jubilados y Montepiados que cuenten con personalidad jur&#xED;dica al d&#xED;a&quot;. </div></div>", "i": 8924803}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  EL ALCALDE</div><br></div>", "i": 8924804}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "S/N", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "ORZ-S/N"}], "organismos": ["MUNICIPALIDAD DE TOCOPILLA"], "titulo_norma": "MODIFICA ORDENANZA NO. 206, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "88466", "numero_fuente": "33873", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-01-21", "vigencias": [{"desde": "1991-01-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-01-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-01-21", "fin_vige