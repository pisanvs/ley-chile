{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10042607}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 3.301, de 24 de julio 2019, de este Servicio, se establece fecha de inicio para la certificaci&#xF3;n de desembarques en la macrozona sur, por parte del Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n indicada, se encuentra publicado con esta fecha en el sitio de dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y de la Subsecretar&#xED;a de Pesca y Acuicultura.</div></div>", "i": 10042608}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  En Valpara&#xED;so, a 24 de julio de 2019.- Alicia Gallardo Lagno, Directora Nacional, Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 10042609}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3301 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3301 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1629491"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-07-24", "doble_articulado": false, "id_norma": "1134381", "numero_fuente": "42417", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-07-31", "vigencias": [{"desde": "2019-07-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-07-31", "fin_vigencia": ""}, "vigencias_version_no