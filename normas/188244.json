{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6344832}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico: Que por resoluci&#xF3;n exenta N&#xBA; 233, de 25 de julio de 2001, se aprob&#xF3; reforma de estatutos de la sociedad an&#xF3;nima &quot;Compa&#xF1;&#xED;a de Seguros Generales Cardif S.A.&quot;, acordada en junta extraordinaria de accionistas de 29 de junio de 2001, cuya acta consta de la escritura p&#xFA;blica de igual fecha otorgada ante el Notario de Santiago don Juan Ricardo San Mart&#xED;n Urrejola.</div><div class=\"p\">&nbsp; &nbsp;  La reforma consiste en aumentar el capital de $3.011.226.125.- dividido en 2.740 acciones sin valor nominal a $5.011.226.125.- dividido en 4.740 acciones sin valor nominal, dentro del plazo de 3 a&#xF1;os contado desde el 29 de junio de 2001.</div><br><br></div>", "i": 6344833}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de julio de 2001.- Carmen Undurraga Mart&#xED;nez, Secretario General.</div><br></div>", "i": 6344834}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "233 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-233 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-07-25", "doble_articulado": false, "id_norma": "188244", "numero_fuente": "37028", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-08-03", "vigencias": [{"desde": "2001-08-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-08-03", "fin_vigen