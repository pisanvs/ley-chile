{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; CERTIFICADO</div><br></div>", "i": 6437009}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n, que suscribe, certifica que la Universidad Leonardo Da Vinci, inscrita bajo el n&#xFA;mero C-18 del Registro del Ministerio de Educaci&#xF3;n, ha modificado los planos y programas de la carrera de Ingenier&#xED;a Civil Industrial, conducente al t&#xED;tulo de Ingeniero Civil Industrial y al grado de Licenciado en Ciencias de la Ingenier&#xED;a, los que han sido aprobados por la Universidad de Antofagasta como entidad examinadora.</div><div class=\"p\">&nbsp; &nbsp;  La carrera modificada podr&#xE1; impartirse por la Universidad Leonardo Da Vinci a contar desde 1991. </div></div>", "i": 6437010}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de Octubre de 1991.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; GASTON GILBERT BAETTING</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp;  Subsecretario de Educaci&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Subrogante</div><br></div>", "i": 6437011}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-10-23", "doble_articulado": false, "id_norma": "213979", "numero_fuente": "34114", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-12", "vigencias": [{"de