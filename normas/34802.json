{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8949296}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 441, de 6 de Mayo de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2&#xB0; de la Resoluci&#xF3;n N&#xB0; 126, de 1994, de esta Subsecretar&#xED;a, que autoriz&#xF3; a AQUACHILE S.A., R.U.T. N&#xB0; 79.800.600-2, para ampliar actividades pesqueras de procesamiento, en el sentido de incorporar en su texto el siguiente p&#xE1;rrafo 4&#xB0;:</div><div class=\"p\">&nbsp; &nbsp; &quot;Los recursos Salm&#xF3;n del atl&#xE1;ntico, Salm&#xF3;n plateado, Salm&#xF3;n rey, Salm&#xF3;n cereza, Trucha arco iris, Trucha caf&#xE9;, Turbot, Osti&#xF3;n del norte y Ostra del pac&#xED;fico, deber&#xE1;n provenir de centros de cultivo autorizados&quot;. </div></div>", "i": 8949297}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 6 de Mayo de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8949298}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "441", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-441"}], "organismos": ["MINISTERIO DE ECONOMÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AQUACHILE S.A.", "AMPLIACION", "PESCA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-05-06", "fecha_derogacion": "1994-12-22", "doble_articulado": false, "id_norma": "34802", "numero_fuente": "34868", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-05-18", "vigencias": [{"desde": "1994-12-22", "hasta": "", "tipo_version": "2", "tipo_version_s": "Últim