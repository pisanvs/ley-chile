{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 116, DE 1988 </div></div>", "i": 6149129}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Supremo Exento de Educaci&#xF3;n No. 116, de 24 de junio de 1988 se ha declarado v&#xE1;lida la aplicaci&#xF3;n de la asignatura de Alem&#xE1;n, durante los a&#xF1;os escolares de 1984, 1985 y 1986, en el Liceo Industrial A No. 60 de &#xD1;u&#xF1;oa, Regi&#xF3;n Metropolitana, impartida en reemplazo de la asignatura de Ingl&#xE9;s, seg&#xFA;n planes de estudio para la Ense&#xF1;anza Industrial Vespertina aprobado por Decreto Supremo de Educaci&#xF3;n No. 687, de 1974.</div><br></div>", "i": 6149130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 05 de Julio de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6149131}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "116 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-116 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 116, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-06-24", "doble_articulado": false, "id_norma": "130140", "numero_fuente": "33118", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-07-11", "vigencias": [{"desde": "1988-07-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-07-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-07-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacione