{"html": [{"t": "<div><div class=\"p\">COMPLEMENTA DECRETO N&#xBA; 1.296, DE 1966</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de Octubre de 1968.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 2.098.- Vistos, la facultad que me confiere el art&#xED;culo 190, letra d) de la ley 16.464, modificada por la ley 16.840,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 7268433}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Complem&#xE9;ntase el decreto de este Ministerio N&#xBA; 1.296, de 11 de Mayo de 1966, en el sentido de incluir en sus disposiciones las importaciones que se indican a continuaci&#xF3;n:</div><br><div class=\"p\">&nbsp; &nbsp;  44.- Las mercanc&#xED;as que se importen al amparo de las franquicias liberatorias se&#xF1;aladas en el art&#xED;culo 242, letra e) de la ley 16.840.</div><br></div>", "i": 7268434}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- E. FREI M.- Andr&#xE9;s Zald&#xED;var Larra&#xED;n.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Dios guarde a Ud.- Jos&#xE9; F. Guzm&#xE1;n C., Subsecretario de Hacienda.</div><br></div>", "i": 7268435}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2098", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2098"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "COMPLEMENTA DECRETO Nº 1.296, DE 1966", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1968-10-31", "doble_articulado": false, "id_norma": "167161", "numero_fuente": "27192", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1968-11-13", "vigencias": [{"desde": "1968-11-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1968-11-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1968-11-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "CAL", "fecha_ingreso": "2000-04-27", "fecha_version": "1968-11-13", "fecha_actualizacion_texto": "1968-11-13", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 7268433}, {"n": "Artículo", "i": 7268434, "t": 6}, {"n": "Promulgación", "i": 7268435}]}