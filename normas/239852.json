{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6532029}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.995, de 29 de junio de 2005, de esta Subsecretar&#xED;a, rectif&#xED;case el numeral 2&#xBA; letra c) de la resoluci&#xF3;n N&#xBA; 831 de 2004, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA ISLA QUIHUA S.A. para desarrollar actividades pesqueras extractivas con la nave &quot;Terranova&quot;, en el sentido de indicar que la peticionaria podr&#xE1; desarrollar actividades extractivas con la embarcaci&#xF3;n individualizada precedentemente sobre el recurso Merluza de cola, con cerco y arrastre, por fuera del &#xE1;rea de reserva artesanal, s&#xF3;lo en el &#xE1;rea mar&#xED;tima comprendida entre la V a IX regiones, y no como all&#xED; se indica.</div><br></div>", "i": 6532030}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de junio de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6532031}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1995 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1995 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-29", "doble_articulado": false, "id_norma": "239852", "numero_fuente": "38203", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-06", "vigencias": [{"desde": "2005-07-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-06", "fin_vigencia