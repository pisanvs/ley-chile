{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6253975}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto No. 199, de 25 de Julio de 1985, se expropiaron los lotes Nos.. 2 y 3, cuyas superficies son 3.806 m&#xB2;, y 1.371 m&#xB2;., roles de aval&#xFA;os 1.539-7 y 1.539-60, comuna de Santa B&#xE1;rbara, para la obra Puente Cholguague, camino Los Angeles, Santa B&#xE1;rbara, y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios do&#xF1;a Ursula Fiebig Baier y don Roberto Molina Sagredo, ascendente a las cantidades de $ 182.673 y $ 83. 801. </div></div>", "i": 6253976}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. (2) </div></div>", "i": 6253977}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "199", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-199"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-07-25", "doble_articulado": false, "id_norma": "161993", "numero_fuente": "32263", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-09-02", "vigencias": [{"desde": "1985-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-09-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2000-03-22", "fecha_version": "1985-09-02", "fecha_actualizacion_texto": "1985-09-02", "tipo_tratado": ""}, "alertas": [], "alert