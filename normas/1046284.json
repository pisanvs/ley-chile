{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9315867}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. (EXENTO) N&#xBA;2465 de 25 de octubre de 2012, se dej&#xF3; sin efecto el Decreto MOP N&#xBA;2697 de 11 de noviembre de 2010, que orden&#xF3;, la expropiaci&#xF3;n del lote N&#xB0;1, por no ser necesaria para la obra, por haberse constituido servidumbre de acueducto de agua potable voluntaria, onerosa, continua, aparente e irrevocable de la obra p&#xFA;blica &quot;Proyecto Refuerzo A.P. Quilicura Traspaso desde Renca&quot; Regi&#xF3;n Metropolitana. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xB0; del Decreto Ley N&#xBA;2186, de 1978. </div></div>", "i": 9315868}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9315869}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2465 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2465 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-10-25", "doble_articulado": false, "id_norma": "1046284", "numero_fuente": "40424", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-12-01", "vigencias": [{"desde": "2012-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresad