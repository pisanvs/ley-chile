{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6211959}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.481, de 31 de agosto de 1999, se expropiaron los lotes de terreno N&#xBA;s. 1, 2, 4, 9 y 16, superficies 130, 123, 255, 254 y 46 m&#xB2;, respectivamente, roles de aval&#xFA;os en tr&#xE1;mite, comuna de Monte Patria, obra Camino Ruta D-55, sector Pte. La Ligua-Bif. San Lorenzo, Variante Cha&#xF1;aral Alto y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Adri&#xE1;n Castillo Araya, Mar&#xED;a G&#xF3;mez Castillo, Francisco Manzano Araya, Iv&#xE1;n Lagunas Chelen y Julia Alvarez Collado, ascendente a las cantidades de $2.755.360;</div><div class=\"p\">$749.620; $586.324; $2.682.095 y $243.019.-</div><br></div>", "i": 6211960}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6211961}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2481", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2481"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-08-31", "doble_articulado": false, "id_norma": "149350", "numero_fuente": "36539", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-12-15", "vigencias": [{"desde": "1999-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-12-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones"