{"html": [{"t": "<div><div class=\"p\">AUTORIZA A SUBSECRETAR&#xCD;A DE ENERG&#xCD;A EN LO QUE INDICA</div></div>", "i": 10133387}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n Ex. del Servicio de Impuestos Internos N&#xB0; 69, de 30 de junio de 2020, establece que:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Autoriza a la Subsecretar&#xED;a de Energ&#xED;a, RUT N&#xB0; 61.979.830-9, como receptor de documentos tributarios electr&#xF3;nicos, debiendo ajustarse a las instrucciones dispuestas en la <a href=\"https://www.leychile.cl/Navegar?idNorma=227838&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 63, de 2004</a>, modificada por la resoluci&#xF3;n exenta N&#xB0; 91, de 2017.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl).</div><br></div>", "i": 10133388}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "69 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-69 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A SUBSECRETARÍA DE ENERGÍA EN LO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1780530", "EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-06-30", "doble_articulado": false, "id_norma": "1147203", "numero_fuente": "42696", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-07-03", "vigencias": [{"desde": "2020-07-03", "hasta": "", "tipo_version": "3", "