{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8337597}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.748, de 9 de diciembre de 1998, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD ALGAS DEL PACIFICO LIMITADA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en calle Humberto Ossand&#xF3;n N&#xBA; 509, Vallenar-Km. 665, Panamericana Norte, IV Regi&#xF3;n, donde podr&#xE1; procesar en la l&#xED;nea de elaboraci&#xF3;n que se indica, los siguientes recursos hidrobiol&#xF3;gicos: Molienda: Cochayuyo, Chasc&#xF3;n, Chicorea de mar, Huiro, Palo, Pelillo, Luche, Luga y Chasca.</div><br></div>", "i": 8337598}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de diciembre de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8337599}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1748", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1748"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-12-09", "doble_articulado": false, "id_norma": "128571", "numero_fuente": "36243", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-12-19", "vigencias": [{"desde": "1998-12-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-12-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-12-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [