{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7358352}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP. N&#xBA; 639, de 25 de octubre de 2007, y en base a la facultad otorgada por el art&#xED;culo 105 del D.F.L. M.O.P. N&#xBA; 850 de 1997, que fij&#xF3; el texto actualizado de la ley N&#xBA; 15.840, se expropi&#xF3; el lote de terreno N&#xBA; A, para la ejecuci&#xF3;n de la obra &quot;Pozo San Miguel 2, Valle de Azapa - Arica&quot;, que figura a nombre de Universidad de Tarapac&#xE1;, Rol de aval&#xFA;o: 3420-67, comuna de Arica, superficie 110,24 M2. La Comisi&#xF3;n de Peritos, fij&#xF3; el 24 de julio de 2007, en la cantidad de $2.279.700. La indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.</div><br><br></div>", "i": 7358353}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br><br></div>", "i": 7358354}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "639 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-639 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-10-25", "doble_articulado": false, "id_norma": "266540", "numero_fuente": "38912", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-11-15", "vigencias": [{"desde": "2007-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-11-15", "fin_vigencia": ""}, "vigencias_v