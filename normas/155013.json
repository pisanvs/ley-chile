{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6230761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 153, de 19 de agosto de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Atacama, se autoriza a Dora Araya Escobar, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.- </div></div>", "i": 6230762}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Antonio Acevedo Oyarce, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de Atacama.</div><br></div>", "i": 6230763}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "153 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-153 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-08-19", "doble_articulado": false, "id_norma": "155013", "numero_fuente": "32.573", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-09-15", "vigencias": [{"desde": "1986-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci