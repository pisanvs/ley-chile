{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 2.358 EXENTA, DE 2011</div><br></div>", "i": 9187703}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.358 de fecha 12 de agosto de 2011, el Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, autoriz&#xF3; complementariamente a la empresa peruana &quot;Transportes Cruz del Sur S.A.C.&quot;, para efectuar servicio de transporte terrestre internacional de pasajeros entre Per&#xFA; y Chile y viceversa, atendiendo el servicio Lima (Per&#xFA;) / Santiago (Chile), utilizando los pasos fronterizos Concordia con dos (2) frecuencias semanales de ida y vuelta.- </div><br></div>", "i": 9187704}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Enrique L. Arce Klein, Unidad de Permisos Internacionales, Subsecretar&#xED;a de Transportes.</div></div>", "i": 9187705}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2358 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2358 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 2.358 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-08-12", "doble_articulado": false, "id_norma": "1030201", "numero_fuente": "40069", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-09-24", "vigencias": [{"desde": "2011-09-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-09-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "