{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede abono de tiempo de servicios al ex-cirujano de la Armada Nacional, don Godofredo Berm&#xFA;dez.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5960342}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, y para los efectos del montep&#xED;o a que haya lugar, un abono de seis meses de servicios al ex-Cirujano de la Armada Nacional, don Godofredo Berm&#xFA;dez.</div><br></div>", "i": 5960343}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecinueve de Agosto de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Carlos O. Frodden. </div></div>", "i": 5960344}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4641", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4641"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "CONCEDE ABONO DE TIEMPO DE SERVICIOS AL EX-CIRUJANO DE LA ARMADA NACIONAL, DON GODOFREDO BERMUDEZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["GODOFREDO BERMUDEZ", "PENSION POR GRACIA", "ANTICIPO", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-08-19", "doble_articulado": false, "id_norma": "24797", "numero_fuente": "15458", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-08-27", "vigencias": [{"desde": "1929-08-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenc