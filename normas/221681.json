{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; EXTRACTO</div><br><br></div>", "i": 6466206}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En cumplimiento de lo dispuesto en los decretos del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, N&#xBA; 291, de 11 de junio de 1999 y N&#xBA; 868, de 16 de noviembre de 1999, certifico que por resoluci&#xF3;n (A) N&#xBA; 20, de 27 de enero de 2004, del se&#xF1;or Vicepresidente Ejecutivo, totalmente tramitada, se modific&#xF3; la resoluci&#xF3;n (A) N&#xBA; 262, de 2003 que puso en ejercicio el Acuerdo de Consejo N&#xBA; 2285, de 2003, relativo a la composici&#xF3;n del Comit&#xE9; de Asignaci&#xF3;n de Fondos, CAF. El texto completo de la antes referida resoluci&#xF3;n, estar&#xE1; a disposici&#xF3;n de los usuarios en la Secretar&#xED;a General de la Corporaci&#xF3;n y en las Direcciones Regionales.</div><br></div>", "i": 6466207}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de febrero de 2004.-&nbsp; Alicia Ruiz Sep&#xFA;lveda, Secretario General (S).</div><br></div>", "i": 6466208}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "20", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-20"}, {"tipo": "3", "numero": "A-20", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-A-20"}], "organismos": ["CORPORACIÓN DE FOMENTO DE LA PRODUCCIÓN"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-27", "doble_articulado": false, "id_norma": "221681", "numero_fuente": "37796", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-26", "vigenci