{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA DE ASOCIACION GREMIAL QUE INDICA </div></div>", "i": 6232298}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 108, de 14 de Noviembre de 1985,</div><div class=\"p\">del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se</div><div class=\"p\">cancel&#xF3; la personalidad jur&#xED;dica de la &quot;Asociaci&#xF3;n</div><div class=\"p\">Gremial de Funcionarios No-Acad&#xE9;micos de la Facultad de</div><div class=\"p\">Medicina de la Universidad de Chile&quot;, inscrita bajo el</div><div class=\"p\">N&#xB0; 1.352 del Registro de Asociaciones Gremiales que</div><div class=\"p\">lleva este Ministerio, por haberse configurado respecto</div><div class=\"p\">de ella la causal de cancelaci&#xF3;n contemplada en el</div><div class=\"p\">art&#xED;culo 18 N&#xB0; 2, letra a), del DL 2.757.</div><br></div>", "i": 6232299}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  - Jorge Valenzuela Dur&#xE1;n, Coronel de Ej&#xE9;rcito, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 6232300}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "108", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-108"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA DE\nASOCIACION GREMIAL QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-11-14", "doble_articulado": false, "id_norma": "155509", "numero_fuente": "32398", "tipo_version": "3",