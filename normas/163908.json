{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 1.722</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Comit&#xE9; Ejecutivo de este Banco Central de Chile en su Sesi&#xF3;n No. 1.722, celebrada el 09 de abril de 1986, adopt&#xF3; los siguientes acuerdos: </div></div>", "i": 6259844}, {"t": "<div><div class=\"p\">1722-08-860409 - Casa de Cambios Tanner S.A.- Revoca autorizaci&#xF3;n otorgada para operar como tal.</div><div class=\"p\">Se acord&#xF3;, a pedido de los interesados, revocar la autorizaci&#xF3;n No. 81 concedida a Casa de Cambios Tanner S.A., para operar como tal en su local de Nueva York No. 44, Santiago.</div><br></div>", "i": 6259845}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 09 de abril de 1986.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6259846}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1722", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1722"}, {"tipo": "5", "numero": "1722-08", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1722-08"}], "organismos": ["MINISTERIO DE HACIENDA", "BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO\nCENTRAL DE CHILE EN SU SESION No. 1.722", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-04-09", "doble_articulado": false, "id_norma": "163908", "numero_fuente": "32444", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-04-11", "vigencias": [{"desde": "1986-04-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vi