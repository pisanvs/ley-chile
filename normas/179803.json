{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6315261}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;4.047, de 31 de agosto de 2000, se expropi&#xF3; el lote de terreno N&#xBA;13-B, superficie 82,50 m&#xB2;, rol de aval&#xFA;o 1103-40, comuna de Pichidegua, para la obra Camino Pichidegua - Marchig&#xFC;e, Sector Marchig&#xFC;e - La Esperanza, Km.</div><div class=\"p\">43.600 a Km. 69.237,91 y se acord&#xF3; precio de la indemnizaci&#xF3;n con su propietario Ram&#xF3;n Antonio Salas Herrera, ascendente a la cantidad de $516.570. </div></div>", "i": 6315262}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6315263}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "4047", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-4047"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-08-31", "doble_articulado": false, "id_norma": "179803", "numero_fuente": "36851", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-02", "vigencias": [{"desde": "2001-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2001-01-05", "fecha_version": "2001-01-02", "fecha_actualizacion_texto": "2001-01-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estr