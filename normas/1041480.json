{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9270775}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento N&#xBA;946, de 31 de mayo de 2012, se modific&#xF3; el numeral primero del <a href=\"https://www.leychile.cl/Navegar?idNorma=1002928&amp;idParte=0&amp;idVersion=\">decreto MOP (E) N&#xB0;653, de 30 de abril de 2009</a>, en el sentido de que se autoriz&#xF3; nuevo plano y cuadro de expropiaci&#xF3;n respecto de la expropiaci&#xF3;n del lote de terreno N&#xB0;1, correspondiente a la obra p&#xFA;blica &quot;Construcci&#xF3;n y Conservaci&#xF3;n Peque&#xF1;o Aer&#xF3;dromo Yendegaia&quot;. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA;2186, de 1978. </div></div>", "i": 9270776}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9270777}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "946 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-946 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-31", "doble_articulado": false, "id_norma": "1041480", "numero_fuente": "40302", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-07-03", "vigencias": [{"desde": "2012-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-07-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-07-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vi