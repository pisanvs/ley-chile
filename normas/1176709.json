{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10337777}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  La Secretar&#xED;a Regional Ministerial de Vivienda y Urbanismo del Maule informa que, con fecha 24 de mayo de 2022, se ha emitido resoluci&#xF3;n exenta N&#xBA; 394, que indica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Dispone Llamado a postulaci&#xF3;n en condiciones especiales para el desarrollo de proyectos del Programa de Mejoramiento de Viviendas y Barrios, Cap&#xED;tulo Tercero: Proyectos para Condominios de Viviendas, para la Regi&#xF3;n del Maule.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Dicha resoluci&#xF3;n, se encuentra disponible en dependencias de la Secretar&#xED;a Regional Ministerial de Vivienda y Urbanismo del Maule, ubicada en 2 Norte 720, Talca.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10337778}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rodrigo Hern&#xE1;ndez Fern&#xE1;ndez, Secretario Regional Ministerial de Vivienda y Urbanismo Regi&#xF3;n del Maule.</div><div class=\"p\"> </div><br></div>", "i": 10337779}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "394 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-394 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SECRETARÍA REGIONAL MINISTERIAL REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2135859", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-05-24", "doble_articulado": false, "id_norma": "1176709", "numero_fuente": "43266", "tipo_version": "3", "tipo_