{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 88, DE 2005 </div></div>", "i": 6518706}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 88 de 1 de marzo de 2005, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la III Regi&#xF3;n de Atacama, se dispuso el inicio de la Puesta en Marcha definitiva de la Concesi&#xF3;n Dos, adjudicada a &quot;Revisiones Atacama Limitada&quot;, para operar en la comuna de Copiap&#xF3;, una Planta Revisora Clase B, con tres (3) l&#xED;neas de revisi&#xF3;n livianas, y para operar en la comuna de Vallenar, una Planta Revisora Clase AB, con una (1) l&#xED;nea de revisi&#xF3;n liviana y una (1) l&#xED;nea de revisi&#xF3;n pesada, a contar del 1&#xBA; de marzo de 2005.-</div><br></div>", "i": 6518707}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Illanes Rojas, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Tercera Regi&#xF3;n de Atacama.</div><br></div>", "i": 6518708}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "88", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-88"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 88, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-03-01", "doble_articulado": false, "id_norma": "236283", "numero_fuente": "38109", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-03-12", "vigencias": [{"desde": "2005-03-12", "hasta": "", "tipo_version": "3", "tipo_