{"html": [{"t": "<div><div class=\"p\">AUTORIZA A DON EUGENIO RAUL YOKOTA BEURET PARA AMPLIAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 7285461}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 190, de 03 de Marzo de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a don Eugenio Ra&#xFA;l Yokota Beuret, R.U.T. 6.850.865-7, domiciliado en Chorrillos 1451, Puerto Montt, para instalar y operar un establecimiento de cultivo de ostra, en Poza Pureo, Isla Quihua, Comuna de Calbuco, Provincia de Llanquihue, X Regi&#xF3;n en un &#xE1;rea de 60.000 m2 (L.S. 41&#xB0;47&apos;31&quot;, L.W.</div><div class=\"p\">73&#xB0;13&apos;15&quot;).</div><br></div>", "i": 7285462}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 03 de Marzo de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7285463}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "190", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-190"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A DON EUGENIO RAUL YOKOTA BEURET PARA AMPLIAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-03-03", "fecha_derogacion": "1986-09-24", "doble_articulado": false, "id_norma": "188920", "numero_fuente": "32432", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-03-26", "vigencias": [{"desde": "1986-09-24", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1986-03-26", "hasta": "1986-