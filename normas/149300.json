{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 4,577</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6211821}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.&nbsp; Ab&#xF3;nase al Juez de Letras de Ca&#xF1;ete, don Manuel Alvarez, por gracia, y para los efectos de su jubilaci&#xF3;n, tres a&#xF1;os, siete meses y veinticinco d&#xED;as, durante los cuales sirvi&#xF3; en propiedad el cargo de Secretario del Juzgado de Letras de Maipo, y el de igual categor&#xED;a, en el Segundo Juzgado de Letras de Caupolic&#xE1;n. </div></div>", "i": 6211822}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a treinta y uno de Enero de mil novecientos veintinueve.-&nbsp; Carlos Ib&#xE1;&#xF1;ez del Campo.-&nbsp; Pablo Ram&#xED;rez.</div><br></div>", "i": 6211823}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4577", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4577"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-01-31", "doble_articulado": false, "id_norma": "149300", "numero_fuente": "15295", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-02-09", "vigencias": [{"desde": "1929-02-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-02-09