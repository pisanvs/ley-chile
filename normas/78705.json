{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8309196}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.584, de 18 de noviembre de</div><div class=\"p\">1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de</div><div class=\"p\">Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la</div><div class=\"p\">autorizaci&#xF3;n solicitada por don LUIS CARRERE VERA, para</div><div class=\"p\">sustituir la nave &quot;Reina IV&quot;, autorizada por la</div><div class=\"p\">Resoluci&#xF3;n N&#xBA; 1.691 de 1989, de esta Subsecretar&#xED;a, por</div><div class=\"p\">la nave &quot;Don Miguel&quot;, en virtud de lo dispuesto en el</div><div class=\"p\">Art&#xED;culo 143 letra b), del D.S. N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8309197}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de noviembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8309198}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1584", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1584"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "LUIS CARRERE VERA", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-11-18", "doble_articulado": false, "id_norma": "78705", "numero_fuente": "35927", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-11-27", "vigencias": [{"desde": "1997-11-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"in