{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 8.664 EXENTA, DE 14 DE DICIEMBRE DE 2009</div></div>", "i": 8818975}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=262244&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 5.095, de 2007</a>, que aprob&#xF3; planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Colegio Alem&#xE1;n de Santiago, en representaci&#xF3;n de la Asociaci&#xF3;n de Colegios Alemanes de Chile.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio de &quot;Ingl&#xE9;s Avanzado&quot; (3&#xBA; a&#xF1;o), &quot;Ingl&#xE9;s Comercial&quot; (4&#xBA; a&#xF1;o) e &quot;Historia de las Religiones&quot; (3&#xBA; o 4&#xBA; a&#xF1;o), para agregar en el listado de Formaci&#xF3;n Diferenciada de 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, seg&#xFA;n art&#xED;culo 6&#xBA; letra c) de la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 5.095, de 2007.</div></div>", "i": 8818976}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de diciembre de 2009.- Jaime Veas S&#xE1;nchez, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 8818977}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5095 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5095 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 8.664 EXENTA, DE 14 DE DICIEMBRE DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-12-14",