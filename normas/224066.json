{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 111 EXENTO, DE 2004</div><br><br></div>", "i": 6474698}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por&nbsp; decreto&nbsp; exento de Educaci&#xF3;n&nbsp; N&#xBA;&nbsp; 111&nbsp; de&nbsp; 02 de marzo de 2004, se ha modificado el decreto exento de Educaci&#xF3;n N&#xBA; 58 de 1999, que aprob&#xF3; plan y programa de estudio biling&#xFC;e de 1&#xBA; a 6&#xBA; a&#xF1;o Ense&#xF1;anza B&#xE1;sica al Colegio &quot;Orchard College&quot; de Curic&#xF3;, en el sentido de reemplazar el plan de estudio para los cursos correspondientes al NB.1 y NB.2 de Ense&#xF1;anza B&#xE1;sica.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s se aprueban programas de estudio para los subsectores y cursos que se se&#xF1;alan.</div><br></div>", "i": 6474699}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Santiago,&nbsp; 31&nbsp; de&nbsp; marzo de 2004.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 6474700}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "111 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-111 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 111 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-02", "doble_articulado": false, "id_norma": "224066", "numero_fuente": "37841", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-21", "vigencias": [{"desde": "2004-04-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-04-21", "fin_vigencia": ""}, "vigencias_