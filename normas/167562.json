{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6271679}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 839, de 14 de Octubre de 1987, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Jos&#xE9; Godoy Ascencio para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6271680}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Enrique Brintrup Barrera, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n subrogante.</div><br></div>", "i": 6271681}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "839 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-839 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-10-14", "doble_articulado": false, "id_norma": "167562", "numero_fuente": "32902", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-10-24", "vigencias": [{"desde": "1987-10-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-10-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-10-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [],