{"html": [{"t": "<div><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10019584}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xBA; 1.143, de fecha 16 de abril de 2019, que rectifica la <a href=\"https://www.leychile.cl/Navegar?idNorma=1125446&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta 3.533 de 6 de noviembre de 2018</a>, Serviu Regi&#xF3;n del Biob&#xED;o orden&#xF3; expropiaci&#xF3;n total de un inmueble ubicado en Monte &#xC1;guila, comuna de Cabrero, de aparente dominio de Suc. Castillo Briones Rosalba, publicada el 15 de noviembre de 2018 en Diario Oficial y diario La Tribuna de Los &#xC1;ngeles, en dicho extracto se indic&#xF3; err&#xF3;neamente en el resuelvo primero la superficie a expropiar, en circunstancias que la superficie correcta es de 35,13 m2 expropiaci&#xF3;n parcial de terreno y 20,13 m2 expropiaci&#xF3;n total de edificaci&#xF3;n, para la ejecuci&#xF3;n del proyecto &quot;Construcci&#xF3;n Ciclov&#xED;a Ruta 060 Cabrero - Monteaguila&quot;, de la comuna de Cabrero, en el resto rige el extracto publicado en la fecha antedicha. </div></div>", "i": 10019585}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n del Biob&#xED;o.</div></div>", "i": 10019586}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1143 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1143 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1582562", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-04-16"