{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div><br></div>", "i": 8786147}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA; 39.471 de 26 de Septiembre del 2009, se public&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1006524&amp;idParte=&amp;idVersion=2009-09-30\">Decreto N&#xFA;m. 3.459 exento.- de 11 de septiembre de 2009</a>, que Aprueba Reformas de Estatutos a &quot;Asociaci&#xF3;n Nacional de F&#xFA;tbol Amateur de Chile&quot;, con el error que se salva a continuaci&#xF3;n: p&#xE1;gina once, primera columna, donde dice &quot;... , de 2003, publicado en el Diario Oficial de 6 de noviembre de 2008, ...&quot; debe decir &quot;... , de 2003, publicado en el Diario Oficial de 13 de febrero de 2004; en la Resoluci&#xF3;n N&#xBA; 1600, de 2008, publicada en el Diario Oficial de 6 de noviembre de 2008, ...&quot;.</div><br><br></div>", "i": 8786148, "v": ["RECTIFICACION"]}, {"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8786149}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "59", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-59"}], "organismos": ["MINISTERIO DE JUSTICIA", "SUBSECRETARÍA DE JUSTICIA"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1006662", "numero_fuente": "39474", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-09-30", "vigencias": [{"desde": "2009-09-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-09-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia":