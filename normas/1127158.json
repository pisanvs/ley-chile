{"html": [{"t": "<div><br><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA A WALMART CHILE S.A.</div></div>", "i": 9982630}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  La DGC del SII, por resoluci&#xF3;n Ex. N&#xB0;239, de fecha 3 de diciembre de 2018, deja sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=1085850&amp;idVersion=2018-12-27\">resoluci&#xF3;n N&#xB0; Ex. 17.500 N&#xB0;180 del 04.12.2015</a>, que otorga la calidad de agente retenedor de cambio de sujeto de derecho del Impuesto al Valor Agregado en las operaciones de ventas de especies hidrobiol&#xF3;gicas, a contar de la fecha de esta publicaci&#xF3;n, al contribuyente Walmart Chile S.A., RUT N&#xB0;76.042.014-K, de acuerdo a la facultad establecida en el dispositivo N&#xB0; 18&#xB0; de la resoluci&#xF3;n Ex. N&#xB0;3.311/2000, de la Direcci&#xF3;n Nacional.- </div><br></div>", "i": 9982631, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Bernardo Seaman Gonz&#xE1;lez, Director de Grandes Contribuyentes.</div></div>", "i": 9982632}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "239 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-239 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN DE GRANDES CONTRIBUYENTES"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA A WALMART CHILE S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1518267", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-12-03", "doble_articulado": false, "id_norma": "1127158", "numero_fuente": "42239", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018