{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,885 que consulta fondos para el saneamiento i limpia de cauces en Valparaiso</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,885.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274804}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se autoriza al Presidente de la Rep&#xFA;blica, para que invierta hasta la suma de doscientos mil pesos en el saneamiento i limpia de cauces en la ciudad de Valparaiso.</div><br></div>", "i": 8274805}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 28 de noviembre de 1906.- PEDRO MONTT.-</div><div class=\"p\">V. Santa Cruz.</div><br></div>", "i": 8274806}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1885", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1885"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NÚM. 1.885 QUE CONSULTA A FONDOS PARA EL SANEAMIENTO I LIMPIA DE CAUCES EN VALPARAÍSO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VALPARAISO", "LIMPIEZA", "PRESIDENTE REPUBLICA", "AUTORIZACION", "INVERSION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-11-28", "doble_articulado": false, "id_norma": "22982", "numero_fuente": "8662", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1906-11-28", "vigencias": [{"desde": "1906-11-28", "hasta": "", "tipo_version":