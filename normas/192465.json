{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 8.872 EXENTA, DE 2001 </div></div>", "i": 6361030}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 8.872, de 26 de julio del a&#xF1;o 2001, se ha aprobado al Liceo Experimental Manuel de Salas, Comuna de &#xD1;u&#xF1;oa, Regi&#xF3;n Metropolitana, el siguiente plan de estudio para 3&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio oficiales del Ministerio de Educaci&#xF3;n para los Subsectores de Formaci&#xF3;n General.</div><br></div>", "i": 6361031}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de julio de&nbsp; 2001.- Juan Ruz Ruz, Jefe Divisi&#xF3;n Educaci&#xF3;n General.</div><br></div>", "i": 6361032}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8872 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8872 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 8.872 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-07-26", "doble_articulado": false, "id_norma": "192465", "numero_fuente": "37133", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-12-12", "vigencias": [{"desde": "2001-12-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-12-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-12-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [