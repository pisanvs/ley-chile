{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10213900}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xB0;490, de 23 de marzo de 2021, determina las prestaciones del Instituto de Salud P&#xFA;blica de Chile que se mantendr&#xE1;n vigentes mientras dura la alerta sanitaria y pandemia por Covid-19 en el pa&#xED;s y deja sin efecto resoluciones que indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10213901}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Heriberto Garc&#xED;a Escorza, Director (S), Instituto de Salud P&#xFA;blica de Chile.</div><br></div>", "i": 10213902}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "490 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-490 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": ["CORONAVIRUS COVID-19", "CORONAVIRUS", "COVID-19"], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1921524", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-03-23", "doble_articulado": false, "id_norma": "1157820", "numero_fuente": "42922", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-04-06", "vigencias": [{"desde": "2021-04-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2021-04-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2021-04-06", "fin_vigencia": "", "tipo_version":