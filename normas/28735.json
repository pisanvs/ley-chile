{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N&#xB0; 16.617 Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7177949}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Agr&#xE9;gase al art&#xED;culo 212 de la ley N&#xB0; 16.617, de 31 de Enero de 1967, el siguiente inciso:</div><div class=\"p\">&nbsp; &nbsp; &quot;Del mismo beneficio gozar&#xE1;n todas las Instituciones de profesores jubilados que cuenten con personalidad jur&#xED;dica otorgada por el Ministerio de Justicia&quot;. </div></div>", "i": 7177950, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a dos de Octubre de mil novecientos sesenta y ocho.- EDUARDO FREI MONTALVA.- Andr&#xE9;s Zald&#xED;var L.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a U. para su conocimiento.- Dios guarde a U.- Jos&#xE9; F. Guzm&#xE1;n C., Subsecretario de Hacienda.</div><br></div>", "i": 7177951}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "16978", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-16978"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA LA LEY N° 16.617", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUCIONES PROFESORES JUBILADOS", "BIENES RAICES", "SEDES SOCIALES", "CONTRIBUCIONES", "EXENCION", "DESTINACION", "PROFESORES JUBILADOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1968-10-02", "doble_articulado": false, "id_norma": "28735", "numero_fuente": "27165", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1968-10-10", "vigencias": [{"desde": "1968-10-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1968-10-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1968-10-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "fecha_version": "1968-10-10", "fecha_actualizacion_texto": "1968-10-10", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 7177949}, {"n": "Artículo 1", "i": 7177950, "t": 6}, {"n": "Promulgación", "i": 7177951}]}