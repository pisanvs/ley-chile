{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SULFATO DE FIERRO COMERCIAL Lei n&#xFA;m. 373.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947762}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se declara libre de derechos de importacion el sulfato de fierro comercial.</div><div class=\"p\">&nbsp; &nbsp; Esta lei rejir&#xE1; sesenta dias despues de su publicacion en el Diario Oficial.</div><br><br></div>", "i": 5947763}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, o&#xED;do el Consejo de Estado, lo he aprobado i sancionado; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 10 de Agosto de 1896.- JORJE MONTT.- Herm&#xF3;jenes P&#xE9;rez de Arce.</div><br></div>", "i": 5947764}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "373", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-373"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "SULFATO DE FIERRO COMERCIAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SULFATO FIERRO COMERCIAL", "DERECHOS IMPORTACION", "LIBERACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-08-10", "doble_articulado": false, "id_norma": "22223", "numero_fuente": "5483", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1896-08