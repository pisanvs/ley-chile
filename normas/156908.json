{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION N&#xB0; 260 DE 17 DE JUNIO DE 1985 </div></div>", "i": 6237065}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado Planes y Programas Especiales de Estudio para Segundo Ciclo de la Educaci&#xF3;n Media T&#xE9;cnico - Profesional, a contar del a&#xF1;o escolar 1985 y hasta el a&#xF1;o escolar 1988, inclusive, para el Liceo Polit&#xE9;cnico A-46, de Lota.</div><br><div class=\"p\">&nbsp; &nbsp;  ESPECIALIDADES:</div><br><div class=\"p\">1.- Proyectos de Instalaciones Domiciliarias.</div><div class=\"p\">2.- Mec&#xE1;nica de M quinas Herramientas.</div><div class=\"p\">3.- Mantenci&#xF3;n Mec&#xE1;nica.</div><div class=\"p\">4.- Electricidad Industrial.</div><div class=\"p\">5.- Construcci&#xF3;n de Interiores.</div><div class=\"p\">6.- Construcci&#xF3;n Estructural.</div><div class=\"p\">7.- Atenci&#xF3;n de P&#xE1;rvulos.</div><br></div>", "i": 6237066}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  28 de Junio de 1985.- Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica, subrogante.</div><br></div>", "i": 6237067}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "260 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-260 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION N° 260\nDE 17 DE JUNIO DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-17", "doble_articulado": false, "id_norma": "156908", "numero_fuente": "32364", "tipo_version": "3", "tipo_version_s": "