{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">NOTIFICACIONES</div></div>", "i": 9400067}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Res. Ex. N&#xBA; 304 de 12/03/13: Vistos: Acta de Denuncia y Citaci&#xF3;n N&#xBA; 3321 de 25/02/13, cursada a Juana Roca Carlos, Documento Nacional de Identidad N&#xBA; 09039491, nacionalidad peruana, domicilio desconocido, que indica: portar 3 Kg. de papa cruda y 1,5 Kg. de lentejas, sin declararlo. Considerando: 1.- Que se ha infringido el art&#xED;culo 22 del decreto ley N&#xBA; 3.557; 2.- La Res. Ex. N&#xBA; 860/12, de esta Direcci&#xF3;n Regional; 3.- Que la denunciada no compareci&#xF3; a la audiencia decretada; 4.- El informe de la Encargada Regional de Controles Fronterizos quien pondera los hechos. Resuelvo: 1.- Absu&#xE9;lvase de los cargos.</div></div>", "i": 9400068}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Firma: Andr&#xE9;s Puiggros Vogel, Director SAG, Regi&#xF3;n de Arica y Parinacota.</div></div>", "i": 9400069}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "304 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-304 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO XV REGIÓN DE ARICA Y PARINACOTA"], "titulo_norma": "NOTIFICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-03-12", "doble_articulado": false, "id_norma": "1058271", "numero_fuente": "40757", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-01-15", "vigencias": [{"desde": "2014-01-15", "hasta": "",