{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6034338}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 169 de 28 de febrero de 1997, se expropiaron los lotes de terreno N&#xBA;s 8, 16, 19 y 30, superficies 8.200; 2.120; 5.160 y 127.000 m2, roles de aval&#xFA;o 403-2; 403-11; 403-12 y 403-18 comuna de Vicu&#xF1;a, para la obra Proyecto Embalse Puclaro Sector La Polvada II Etapa y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Florencio Labarca Mu&#xF1;oz, Manuel G. Traslavi&#xF1;a, Felipe C&#xE1;ceres C&#xE1;ceres y Jos&#xE9; Silva Rodr&#xED;guez ascendente a las cantidades de $6.488.922, para el lote N&#xBA; 8; $14.120.617; para el lote N&#xBA; 16;</div><div class=\"p\">$17.391.038; para el lote N&#xBA; 19 y $47.302.675, para el lote N&#xBA; 30.-</div><br></div>", "i": 6034339}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6034340}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "169", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-169"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "VICU A", "CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-02-28", "doble_articulado": false, "id_norma": "70644", "numero_fuente": "35741", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-15", "vigencias": [{"desde": "1997-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio