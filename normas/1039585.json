{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9253964}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (exento) N&#xBA;619 de fecha 30 de marzo de 2012, y de conformidad a lo dispuesto en el Art. 105 del DFL. MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;1-B, superficie 2.706 m2, rol N&#xBA;185-40, para la obra &quot;Reparaci&#xF3;n Inf. Vial C y Ptes. En P-22, 24, 40; Rutas 126, 160 y otras, Sector Bifurcaci&#xF3;n Curaquilla - Tubul&quot;, Comuna y Provincia de Arauco. La Comisi&#xF3;n de Peritos integrada por Adriana Fasce Casanueva, Ricardo Echeverr&#xED;a Hohmann y Oscar Ch&#xE1;vez Alca&#xED;no, fij&#xF3; valor de tasaci&#xF3;n con fecha 21 de febrero de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario CARLOS RUBEN ULLOA ALVIAL Y OTRAS, en la cantidad de $2.831.558, suma que se pagar&#xE1; al contado. </div><br></div>", "i": 9253965}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9253966}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "619 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-619 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-03-30", "doble_articulado": false, "id_norma": "1039585", "numero_fuente": "40251", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-05-02", "vigencias": [{"desde": "2012-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-05-02", "fin_vigencia": ""}, "vig