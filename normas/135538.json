{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m.&nbsp; 1,577.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6165727}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Ab&#xF3;nase, por gracia, al ministro de la Corte de Apelaciones de Talca, don Jos&#xE9; Miguel Gaete, el tiempo que le falta para enterar cuarenta a&#xF1;os de servicios, con derecho a jubilacion.</div><br></div>", "i": 6165728}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, de acuerdo con el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese&nbsp; i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de enero de 1903.- JERMAN RIESCO.-</div><div class=\"p\">J.D. Amunategui Rivera.</div><br></div>", "i": 6165729}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1577", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1577"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1903-01-13", "doble_articulado": false, "id_norma": "135538", "numero_fuente": "7484", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1903-08-25", "vigencias": [{"desde": "1903-08-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1903-08-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1903-08-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "