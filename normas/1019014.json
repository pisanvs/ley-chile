{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9028681}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA;2061 de fecha 14 de octubre de 2010, se modific&#xF3; el <a href=\"https://www.leychile.cl/Navegar?idNorma=1015860&amp;idParte=0&amp;idVersion=\">decreto (exento) MOP N&#xBA;854 de 30 de junio de 2010</a>, en lo que se refiere al segundo apellido de la propietaria de los lotes de terreno N&#xB0;s 18, 19, 20, 21 y 23, debiendo decir SAAVEDRA y no como se menciona en dicho acto administrativo.</div></div>", "i": 9028682}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9028683}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2061 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2061 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-10-14", "doble_articulado": false, "id_norma": "1019014", "numero_fuente": "39799", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-11-02", "vigencias": [{"desde": "2010-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "362", "fecha_ingreso": "2010-11-03", "fecha_version": "2010-11-02", "actualizado_por": "362", "fecha_actualizacion_text