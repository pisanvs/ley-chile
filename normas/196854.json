{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;275, DE 2002 </div></div>", "i": 6377298}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n N&#xBA;275 del 1 de abril del a&#xF1;o 2002, dictada por el Secretario Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana que prorroga hasta el 31 de julio del a&#xF1;o 2002, el segundo per&#xED;odo de capacitaci&#xF3;n, fijado anteriormente por resoluci&#xF3;n N&#xBA;223/2001 de esta Secretar&#xED;a Regional, en el marco de programas anuales de capacitaci&#xF3;n obligatoria del personal de conducci&#xF3;n de veh&#xED;culos que presten servicios urbanos de transporte p&#xFA;blico remunerado de pasajeros, mediante buses, en v&#xED;as de Santiago, en el proceso denominado Licitaci&#xF3;n de V&#xED;as 1998.-</div><br></div>", "i": 6377299}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fernando Orellana Astorga, Secretario Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6377300}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "275", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-275"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº275, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-01", "doble_articulado": false, "id_norma": "196854", "numero_fuente": "37237", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-17", "vigencias": [{"desde": "2002-04-17",