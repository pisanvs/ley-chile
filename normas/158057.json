{"html": [{"t": "<div><div class=\"p\">MODIFICA ARANCEL ADUANERO</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 61.- Santiago, 22 de Enero de 1986.- Vistos: Lo dispuesto en el art&#xED;culo 4&#xB0; del decreto de Hacienda No. 10, de 1967,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 6240625}, {"t": "<div><div class=\"p\">Der&#xF3;gase a contar de la fecha de publicaci&#xF3;n del presente decreto en el Diario Oficial, la sobretasa arancelaria de 8% que afecta a la importaci&#xF3;n de las mercanc&#xED;as que se clasifican en la posici&#xF3;n 84.15.01.00 del Arancel Aduanero.</div><br></div>", "i": 6240626}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- AUGUSTO PINOCHET UGARTE, General de Ej&#xE9;rcito, Presidente de la Rep&#xFA;blica.- Manuel Concha Mart&#xED;nez, Coronel de Ej&#xE9;rcito, Ministro de Hacienda subrogante.</div><div class=\"p\">Lo que transcribo a Ud. para su conocimiento.- Saluda atentamente a Ud.- Manuel Concha Mart&#xED;nez, Coronel de Ej&#xE9;rcito, Subsecretario de Hacienda.</div><br></div>", "i": 6240627}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "61", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-61"}], "organismos": ["MINISTERIO DE HACIENDA", "SUBSECRETARÍA DE HACIENDA"], "titulo_norma": "MODIFICA ARANCEL ADUANERO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-01-22", "doble_articulado": false, "id_norma": "158057", "numero_fuente": "32423", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-03-15", "vigencias": [{"desde": "1986-03-15", "hasta": "", "tipo_version": "3", "ti