{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,092.- Santiago, 14 de octubre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 8342799}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- As&#xED;gnase, por gracia, a la viuda e hijo de don Nicolas Pe&#xF1;a Vicu&#xF1;a, la pension anual de mil doscientos pesos, de que gozar&#xE1;n con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 8342800}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C. Walker Mart&#xED;nez.</div><br></div>", "i": 8342801}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1092", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1092"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-10-14", "doble_articulado": false, "id_norma": "134175", "numero_fuente": "6125", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-10-14", "vigencias": [{"desde": "1898-10-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-10-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-10-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-03-30", "fecha_version": "1898-10-14"