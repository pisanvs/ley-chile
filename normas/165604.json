{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION No. 252 DE 17 JUNIO DE 1985 </div></div>", "i": 6265141}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado Planes y Programas Especiales de Estudio para Segundo Ciclo de la Educaci&#xF3;n Media T&#xE9;cnico-Profesional, a contar del a&#xF1;o escolar 1985 y hasta el a&#xF1;o escolar 1990, inclusive, para el Liceo Industrial &quot;A&quot; No. 16, de Antofagasta.</div><br><div class=\"p\">&nbsp; &nbsp;  ESPECIALIDADES:</div><br><div class=\"p\">&nbsp; &nbsp;  1.- Construcci&#xF3;n Habitacional.</div><div class=\"p\">&nbsp; &nbsp;  2.- Mec&#xE1;nica de Combusti&#xF3;n Interna y Automotriz con Menci&#xF3;n en Mec&#xE1;nica Diesel.</div><div class=\"p\">&nbsp; &nbsp;  3.- Mec&#xE1;nica de M&#xE1;quinas Herramientas.</div><div class=\"p\">&nbsp; &nbsp;  4.- Electricidad Industrial. 5.- Radio y Televisi&#xF3;n.</div><br></div>", "i": 6265142}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  28 de junio de 1985.- Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica. subrogante.</div><br></div>", "i": 6265143}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "252 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-252 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION No. 252\nDE 17 JUNIO DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-17", "doble_articulado": false, "id_norma": "165604", "numero_fuente": "32354", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publ