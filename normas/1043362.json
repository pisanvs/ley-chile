{"html": [{"t": "<div><br><div class=\"p\">ORDENAN EXPROPIACI&#xD3;N DE LOTES QUE INDICAN</div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9292908}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente se rectifica publicaci&#xF3;n efectuada con fecha 16 de agosto de 2012, de extracto de <a href=\"https://www.leychile.cl/Navegar?idNorma=1042853&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 4.782, de fecha 10 de agosto de 2012</a>, de la Direcci&#xF3;n de Serviu RM, que orden&#xF3; la expropiaci&#xF3;n del denominado Lote Rol N&#xBA; 6401-61, del programa &quot;Plan Chile Unido Reconstruye Mejor &quot;Villa Salvador Cruz Gana&quot;, en el sentido de se&#xF1;alar que el monto de la indemnizaci&#xF3;n por causa de expropiaci&#xF3;n se fij&#xF3; en $24.345.555. En lo no rectificado rige publicaci&#xF3;n de fecha 16 de agosto de 2012.-</div><br></div>", "i": 9292909, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div></div>", "i": 9292910}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "Aviso-S/N"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN REGIÓN METROPOLITANA"], "titulo_norma": "ORDENAN EXPROPIACIÓN DE LOTES QUE INDICAN; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1043362", "numero_fuente": "40352", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-09-01", "vigencias": [{"desde": "2012-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inici