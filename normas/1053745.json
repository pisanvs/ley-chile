{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 6.066 EXENTA, DE 2013</div></div>", "i": 9371180}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta n&#xFA;mero 6.066, de 9 de agosto de 2013, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Icontec Capacita S.A. (Icontec Capacita S.A.)&quot;, R.U.T. 76.141.589-1 contenida en la resoluci&#xF3;n exenta N&#xBA; 5.614 de 15 de junio de 2012, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.- </div><br></div>", "i": 9371181}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (S).</div></div>", "i": 9371182}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6066 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6066 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 6.066 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-08-09", "doble_articulado": false, "id_norma": "1053745", "numero_fuente": "40641", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-08-23", "vigencias": [{"desde": "2013-08-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-08-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-08-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc