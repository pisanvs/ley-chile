{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6445666}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.538, de 16 de octubre de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 834 de 2001, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Pesquera Ligure S.A., hoy SOUTHPACIFIC KORP S.A., para realizar actividades pesqueras extractivas con la nave &quot;Guanaye 3&quot;, en el sentido de incorporar y actualizar, seg&#xFA;n corresponda, las siguientes caracter&#xED;sticas n&#xE1;uticas de &#xE9;sta:</div><br><br><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 589,31 m&#xB3;</div><div class=\"p\">T.R.G. (Internacional)&nbsp; &nbsp; &nbsp;  525,10</div><div class=\"p\">Potencia principal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  1774,00 Hp</div><div class=\"p\">Potencia auxiliar&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 475,00 Hp</div><br><br></div>", "i": 6445667}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de octubre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6445668}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2538 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2538 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-16", "doble_articulado": false, "id_norma": "216392", "numero_fuente": "37697", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-10-29", "vigencias": [{"desd