{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION No. 35, DE 1982 </div></div>", "i": 8349835}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 18, de 06 de Enero de 1987 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deroga a petici&#xF3;n del interesado, la resoluci&#xF3;n No. 35, de 1989, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; al Sr. Stig Blomstrom Persson, para realizar actividades de cultivo de trucha arco iris en la Piscicultura de Polcura, ubicada en la VIII Regi&#xF3;n.</div><br></div>", "i": 8349836}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 06 de Enero de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8349837}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "18", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-18"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "DEROGA RESOLUCION No. 35, DE 1982", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-01-06", "doble_articulado": false, "id_norma": "143185", "numero_fuente": "32675", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-01-19", "vigencias": [{"desde": "1987-01-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-01-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-01-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAS", "fecha_ingreso": "1999-09-13", "fecha_versio