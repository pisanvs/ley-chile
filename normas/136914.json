{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SESION N&#xBA; 756 </div></div>", "i": 6170288}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su sesi&#xF3;n N&#xBA; 756, celebrada el 20 de mayo de 1999, adopt&#xF3; el siguiente acuerdo:</div><br><div class=\"p\">&nbsp; &nbsp;  756-01-990520 - Autoriza a Corpbanca para emitir tarjeta de cr&#xE9;dito que se indica.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; autorizar a Corpbanca para emitir la tarjeta de cr&#xE9;dito que se indica:</div><br><div class=\"p\">Entidad Emisora&nbsp; &nbsp;  Tarjeta a emitir&nbsp; &nbsp;  Modalidad</div><br><div class=\"p\">Corpbanca&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Mastercard&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Nacional e Internacional</div><br></div>", "i": 6170289}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de mayo de 1999.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6170290}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "756", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-756"}, {"tipo": "5", "numero": "756-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-756-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SESION Nº 756", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-05-20", "doble_articulado": false, "id_norma": "136914", "numero_fuente": "36372", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-05-26", "vigencias": [{"desde": "1999-05-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Únic