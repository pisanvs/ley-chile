{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 753 EXENTO, DE 2002 </div></div>", "i": 6397917}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 753 de fecha 22 de agosto de 2002, del Ministerio de Educaci&#xF3;n, se deja sin efecto el decreto exento de Educaci&#xF3;n N&#xBA; 68 del 4 de abril de 1989, que autoriz&#xF3; el funcionamiento de la Sede N&#xBA; 1 del Centro de Formaci&#xF3;n T&#xE9;cnica Massachusetts de la ciudad de Curic&#xF3;, en raz&#xF3;n a que dicha sede ha dejado de funcionar, a petici&#xF3;n de la propia instituci&#xF3;n. </div></div>", "i": 6397918}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de septiembre de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6397919}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "753 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-753 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 753 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-08-22", "doble_articulado": false, "id_norma": "203050", "numero_fuente": "37373", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-10-02", "vigencias": [{"desde": "2002-10-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-10-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-10-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "IMH", "