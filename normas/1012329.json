{"html": [{"t": "<div><br><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N (M) N&#xBA; 124, DE 2007</div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n (M) N&#xBA; 2.459, de 28 de diciembre de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3; lo siguiente:</div></div>", "i": 8906687}, {"t": "<div><div class=\"p\">&nbsp; Modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=260201&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n 124, de 19 de enero de 2007, del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina</a>, en la siguiente forma:</div><br><div class=\"p\">&nbsp; &nbsp;  Donde dice: &quot;Landcatch Chile Limitada&quot;</div><div class=\"p\">&nbsp; &nbsp;  Debe decir: &quot;Landcatch Chile S.A.&quot;</div></div>", "i": 8906688}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de marzo de 2010.- Por la Sra. Subsecretaria, Felipe Garc&#xED;a-Huidobro Correa, Subjefe Subsecretar&#xED;a de Marina.</div></div>", "i": 8906689}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2459", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2459"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "MODIFICA RESOLUCIÓN (M) Nº 124, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-12-28", "doble_articulado": false, "id_norma": "1012329", "numero_fuente": "39631", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-04-09", "vigencias": [{"desde": "2010-04-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-04-09", "fi