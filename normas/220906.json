{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6462445}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 277 de 22 de enero de 2004 de esta Subsecretar&#xED;a, autor&#xED;zase a COMERCIAL Y PESQUERA SOUTH WIND S.A, para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Los Industriales N&#xBA; 668, Huechuraba, Regi&#xF3;n Metropolitana, en las l&#xED;neas de elaboraci&#xF3;n Fresco Refrigerado, las ovas del recurso hidrobiol&#xF3;gico individualizado en la resoluci&#xF3;n extractada. </div></div>", "i": 6462446}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de enero de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6462447}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "277 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-277 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-22", "doble_articulado": false, "id_norma": "220906", "numero_fuente": "37778", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-05", "vigencias": [{"desde": "2004-02-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-02-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-02-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2004-02-05", "fecha_version": "2004-