{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PENSION Lei n&#xFA;m. 191.-Santiago, a 20 de Agosto de 1894.-Por cuanto el Congreso Nacional ha aprobado el siguiente PROYECTO DE LEI:</div><br></div>", "i": 5947105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Consid&#xE9;rase que el sarjento Juan Jesus Bravo fu&#xE9; muerto a consecuencia de una accion de guerra, i as&#xED;gnase a su viuda e hijos lej&#xED;timos la pension que se&#xF1;ala el art&#xED;culo 13 de la lei de 22 de Diciembre de 1881, la que gozar&#xE1;n en conformidad a las prescripciones de dicha lei.</div><br><br></div>", "i": 5947106}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORGE MONTT.-S. Aldunate B.</div><br></div>", "i": 5947107}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "191", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-191"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUAN JESUS BRAVO", "PENSION", "BENEFICIARIOS", "ASIGNACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-08-20", "doble_articulado": false, "id_norma": "22050", "numero_fuente": "4900", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-08-25", "vigencias": [{"desde": "1894-08-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-08-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-08-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes"