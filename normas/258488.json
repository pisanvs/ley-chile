{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 9.544 EXENTA, DE 2006 </div></div>", "i": 6601916}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 9.544, de fecha 29 de diciembre de 2006, del Ministerio de Educaci&#xF3;n, se ampl&#xED;a el per&#xED;odo de acreditaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica UDA por cinco a&#xF1;os, a contar de diciembre del a&#xF1;o 2006.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo se requiere del Centro de Formaci&#xF3;n T&#xE9;cnica UDA el cumplimiento de acciones dentro del plazo se&#xF1;alado, lo que ser&#xE1; verificado por la Divisi&#xF3;n de Educaci&#xF3;n Superior del Ministerio de Educaci&#xF3;n, como condici&#xF3;n previa para la obtenci&#xF3;n de la Plena Autonom&#xED;a, correspondiendo al Ministerio de Educaci&#xF3;n la verificaci&#xF3;n de su desarrollo.</div><br></div>", "i": 6601917}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de febrero de 2007.- Juan Cavada Artigues, Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 6601918}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9544 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-9544 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 9.544 EXENTA, DE 2006", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2006-12-29", "fecha_derogacion": "2018-12-31", "doble_articulado": false, "id_norma": "258488", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2007-02-20", "vigencias": [{"desde": "2018-12-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"de