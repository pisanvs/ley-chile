{"html": [{"t": "<div><div class=\"p\">ORDENANZA LOCAL SOBRE PERMISOS Y CONCESIONES PARA LA EXTRACCION DE ARIDOS EN EL RIO MAIPO, COMUNA DE SAN BERNARDO</div><br><br></div>", "i": 7192576}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Veintisiete de junio de 1994 se dict&#xF3; Ordenanza N&#xB0; 15 sobre Permisos y Concesiones para la Extracci&#xF3;n de Aridos en el R&#xED;o Maipo, Comuna de San Bernardo, riguiendo 15 d&#xED;as despu&#xE9;s fecha de esta publicaci&#xF3;n. Contiene normas sobre permisos, concesiones, extracci&#xF3;n de materiales &#xE1;ridos, zonificaci&#xF3;n del R&#xED;o Maipo, fiscalizaci&#xF3;n, infracciones, normas generales y disposiciones transitorias.</div><div class=\"p\">&nbsp; &nbsp; Se exhibe en el Hall Central del Edificio Consistorial, Eyzaguirre N&#xB0; 450.-</div><br><br></div>", "i": 7192577, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Luis Navarro Avil&#xE9;s, Alcalde.</div><br></div>", "i": 7192578}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "15", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "ORZ-15"}], "organismos": ["MUNICIPALIDAD DE SAN BERNARDO"], "titulo_norma": "ORDENANZA LOCAL SOBRE PERMISOS Y CONCESIONES PARA LA;EXTRACCION DE ARIDOS EN EL RIO MAIPO, COMUNA DE SAN;BERNARDO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ORDENANZA MUNICIPAL", "MUNICIPALIDAD SAN BERNARDO", "EXTRACCION ARIDOS", "RIO MAIPO", "PERMISOS MUNICIPALES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-06-27", "doble_articulado": false, "id_norma": "31043", "numero_fuente": "34913", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-07-13", "vigencias": [{"desde": "1994-07-13", "hasta": "", "tipo_versi