{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6175703}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 91, de 09 de Febrero de 1988, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o Bio, se autoriza a Ninette del Carmen Ruiz Salgado para efectuar todo tipo de servicio de transportes de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6175704}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gast&#xF3;n Alvarez Briones, Secretario Regional Ministerial Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6175705}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "91 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-91 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-02-09", "doble_articulado": false, "id_norma": "138546", "numero_fuente": "32998", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-17", "vigencias": [{"desde": "1988-02-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-02-17", "fin_vigencia": "", "tipo_version": "3"}], "evento