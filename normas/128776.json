{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SESION N&#xBA;724 </div><br></div>", "i": 6144692}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA;724, celebrada el 24 de diciembre de 1998, adopt&#xF3; el siguiente Acuerdo:</div><br><div class=\"p\">724-07-981224 - Tasa de inter&#xE9;s para pago diferido de derechos de Aduana.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3;, en conformidad a lo establecido en la letra c) del Art. N&#xBA;10 de la ley N&#xBA;18.634, que la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de derechos de Aduana durante el semestre que expira el 30 de junio de 1999, ser&#xE1; de 10,90% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.</div><br></div>", "i": 6144693}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de diciembre de 1998.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6144694}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "724", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-724"}, {"tipo": "5", "numero": "724-07", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-724-07"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SESION Nº724", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-12-24", "doble_articulado": false, "id_norma": "128776", "numero_fuente": "36251", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-12-30", "vigencias": [{"desde": "1998-12-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], 