{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 563, DE 2000 </div></div>", "i": 6313889}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA; 563, de 2 de octubre de 2000, se ha aprobado el Convenio de fecha siete de junio de 2000, celebrado entre el Ministerio de Educaci&#xF3;n y la I. Municipalidad de Andacollo, que modifica el Convenio de Traspaso de la Escuela B&#xE1;sica E N&#xBA; 118, de Andacollo, traspasada a dicha Corporaci&#xF3;n, por Convenio aprobado por decreto supremo de Educaci&#xF3;n N&#xBA; 10.118 de 15 de diciembre de 1981.</div><br></div>", "i": 6313890}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de diciembre de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6313891}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "563", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-563"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 563, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-02", "doble_articulado": false, "id_norma": "179472", "numero_fuente": "36846", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-12-26", "vigencias": [{"desde": "2000-12-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-12-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-12-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "2000-12-26", "fecha_version": "2000-12