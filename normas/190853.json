{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6354331}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.039, de 25 de septiembre de 2001, de esta Subsecretar&#xED;a, autor&#xED;zase a la ILUSTRE MUNICIPALIDAD DE PENCO, Departamento Educaci&#xF3;n Municipal, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en San Vicente N&#xBA; 51, Penco, VIII Regi&#xF3;n, con fines educacionales, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Congelado: Merluza com&#xFA;n; Conserva: Cholga.</div><div class=\"p\">&nbsp; &nbsp;  La materia prima deber&#xE1; provenir de pescadores artesanales e industriales debidamente autorizados. </div></div>", "i": 6354332}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de septiembre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6354333}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2039", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2039"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-09-25", "doble_articulado": false, "id_norma": "190853", "numero_fuente": "37090", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-10-20", "vigencias": [{"desde": "2001-10-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-10-20", "fin_vigencia": ""}, "vigencias_versi