{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 247 EXENTO DE 25 DE FEBRERO DE 2022 DEL MINISTERIO DE EDUCACI&#xD3;N</div></div>", "i": 10315672}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  En virtud de lo dispuesto en el inciso segundo del art&#xED;culo cuadrag&#xE9;simo noveno transitorio de la ley 20.903, por el presente decreto exento se modifica el convenio suscrito con la Corporaci&#xF3;n Educacional de la Sociedad Nacional de Agricultura FG.SNA Educa, cuyo objeto fue delegar la administraci&#xF3;n del establecimiento educacional Liceo Agr&#xED;cola de la Patagonia RBD 8369-0 cuyo convenio fue aprobado, mediante el <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=1060534\">decreto N &#xB0;9, de 2014, del Ministerio de Educaci&#xF3;n</a>.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10315673}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de febrero de 2022.- Jorge Poblete Aedo, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 10315674}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "247 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-247 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 247 EXENTO DE 25 DE FEBRERO DE 2022 DEL MINISTERIO DE EDUCACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2095359", "EXTRCTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-02-25", "doble_articulado": false, "id_norma": "1173394", "numero_fuente": "43196", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-03-07", "vigencias": [{"desde": "2022-03-0