{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CERTIFICADO </div></div>", "i": 5844929}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de enero de 1992, fue de 4,47% anual.</div><br></div>", "i": 5844930}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 17 de enero de 1992.- Isaac Telias Ergas, Ministro de Fe subrogante.</div><br></div>", "i": 5844931}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA INTERES PROMEDIO", "TIP", "ENERO 1992", "OPERACIONES CREDITO DINERO", "OPERACIONES REAJUSTABLES", "CAPTACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-01-17", "doble_articulado": false, "id_norma": "1710", "numero_fuente": "34170", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-01-18", "vigencias": [{"desde": "1992-01-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-01-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-01-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1992-01-18", "fecha_actualizacion_texto": "1992-01-18", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "es