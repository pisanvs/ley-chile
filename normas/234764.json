{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; EXTRACTO</div><br></div>", "i": 6513482}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En cumplimiento de lo dispuesto en el art&#xED;culo 10 del Reglamento para la Dictaci&#xF3;n de Normas de Calidad Ambiental y de Emisi&#xF3;n, D.S. N&#xBA; 93 de 1995, del Ministerio Secretar&#xED;a General de la Presidencia, procedo a publicar extracto del acuerdo N&#xBA; 260 de 26 de noviembre de 2004, del Consejo Directivo de la Comisi&#xF3;n Nacional del Medio Ambiente, que es del siguiente tenor:</div><div class=\"p\">&nbsp; &nbsp;  El Consejo Directivo de la Comisi&#xF3;n Nacional del Medio Ambiente acord&#xF3; en sesi&#xF3;n extraordinaria de fecha 26 de noviembre de 2004, incorporar al Noveno Programa Priorizado de Normas, la Norma Secundaria de Calidad Ambiental para el R&#xED;o Cruces, X Regi&#xF3;n de Los Lagos. </div></div>", "i": 6513483}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Paulina Saball Astaburuaga, Directora Ejecutiva. </div></div>", "i": 6513484}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "260", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-260"}], "organismos": ["MINISTERIO SECRETARÍA GENERAL DE LA PRESIDENCIA", "COMISIÓN NACIONAL DEL MEDIO AMBIENTE"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMISION NACIONAL DEL MEDIO AMBIENTE", "CONTAMINACION AMBIENTAL", "NORMA SECUNDARIA DE CALIDAD AMBIENTAL", "RIO CRUCES", "DECIMA REGION", "CISNES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-26", "doble_articulado": false, "id_norma": "234764", "numero_fuente": "38061", "tipo_version": "3", "t