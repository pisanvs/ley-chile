{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10302126}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;1.501 de 30 de diciembre 2021 de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n parcial, conforme art&#xED;culo 51 ley 16.391, de inmueble ubicado en Parr&#xF3;n Grande Hij A PC 1, Rol Aval&#xFA;o N&#xBA; 167-40, Comuna de Maule, superficie 645,133 M2, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Comit&#xE9; Vivienda Villa Francia. Comisi&#xF3;n integrada por peritos Patricio Ulises Dur&#xE1;n Marcos, Arquitecto; Rodrigo Antonio Silva Lazo, Constructor Civil y Pedro Pablo Cruz Weston, Arquitecto, seg&#xFA;n informe de fecha 14 diciembre de 2020, fij&#xF3; monto provisional indemnizaci&#xF3;n, legalmente reajustada, en la suma de $12.367.200.- pagados al contado.- </div></div>", "i": 10302127}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Claudio Daneck Mu&#xF1;oz, Director (S) Serviu Regi&#xF3;n del Maule.</div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><br></div>", "i": 10302128}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1501 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1501 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2069801", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-12-30", "doble_articulado": false, "id_norma": "1171412", "numero_fuente": "43153", "tip