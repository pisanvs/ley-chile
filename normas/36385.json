{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8296071}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.158, de 7 de Diciembre de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 1.527, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don MARCELINO CAIPICHUN CAIPICHUN, para operar un establecimiento de cultivo ubicado en el sector denominado Huay&#xFA;n, canal Quihua, comuna de Calbuco, provincia de Llanquihue, X Regi&#xF3;n, por haberse puesto t&#xE9;rmino a la respectiva concesi&#xF3;n mar&#xED;tima de acuicultura.</div><br><br></div>", "i": 8296072}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 7 de Diciembre de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8296073}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1158", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1158"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MARCELINO CAIPICHUN CAIPICHUN", "PESCA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-12-07", "doble_articulado": false, "id_norma": "36385", "numero_fuente": "35045", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-12-20", "vigencias": [{"desde": "1994-12-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-12-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-12-20", "fin_vigencia": "", "tip