{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8871653}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 58 de 30 de Diciembre de 1992, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se adjudic&#xF3; a MIDDLETON Y CIA. LTDA., la concesi&#xF3;n para operar, por un plazo de cinco a&#xF1;os a contar de la publicaci&#xF3;n del presente extracto, un establecimiento ubicado en el Longitudinal Sur, Km. 255 de la comuna de Talca, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de contaminantes de todo tipo de veh&#xED;culos motorizados, sus remolques y semirremolques, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.- </div></div>", "i": 8871654}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Carlos P&#xE9;rez Molina, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n del Maule. </div></div>", "i": 8871655}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "58", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-58"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION REVISION TECNICA", "PLANTA REVISION TECNICA", "VEHICULOS MOTORIZADOS", "TALCA", "MIDDLETON Y CIA. LTDA."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1992-12-30", "fecha_derogacion": "2004-02-19", "doble_articulado": false, "id_norma": "32696", "numero_fuente": "34536", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1993-04-07", "vige