{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,501.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6163532}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir la suma de nueve mil ochocientos veinte pesos ($ 9,820) en el pago de honorarios al injeniero don Domingo Canales por el levantamiento de planos topogr&#xE1;ficos&nbsp; en el territorio de Magallanes. </div></div>", "i": 6163533}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de diciembre de 1901.- JERMAN RIESCO.- Eliodoro Y&#xE1;&#xF1;ez.</div><br></div>", "i": 6163534}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1501", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1501"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-12-19", "doble_articulado": false, "id_norma": "134819", "numero_fuente": "7105", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-12-24", "vigencias": [{"desde": "1901-12-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1901-12-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1901-12-24", "fin_vigencia": "", "tipo_version": "3"}], "ev