{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 337 EXENTO, DE 2002 </div></div>", "i": 6382870}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 337 de fecha 23 de abril de 2002 del Ministerio de Educaci&#xF3;n, se aprueban las modificaciones introducidas al plan y programas de estudios del Centro de Formaci&#xF3;n T&#xE9;cnica Escuela Superior de Administraci&#xF3;n de Negocios del Norte-ESANE del Norte, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica para ser impartida a contar del a&#xF1;o 2002, en la Sede Central de Antofagasta y Sede N&#xBA; 3 de Calama, con la siguiente denominaci&#xF3;n:</div><br><div class=\"p\">Carrera : Turismo y Hoteler&#xED;a, cambia por:</div><div class=\"p\">Carrera : Turismo</div><div class=\"p\">T&#xED;tulo&nbsp; : T&#xE9;cnico de Nivel Superior en Turismo </div></div>", "i": 6382871}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de mayo de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6382872}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "337 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-337 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 337 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-04-23", "fecha_derogacion": "2020-12-16", "doble_articulado": false, "id_norma": "198538", "numero_fuente": "37268", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-05-28", "vigencias": [{"desde": "2020-12-16", "hasta": "", "tipo_version": "2", "tipo_version_s": "Úl