{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xBA; 481 EXENTA, DE 2003</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 571 exenta.- Santiago, 19 de junio de 2006.- Vistos: Lo dispuesto en el art&#xED;culo 192 del C&#xF3;digo Tributario, dicto la siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n:</div><br></div>", "i": 8050257}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.- Sustit&#xFA;yase en el art&#xED;culo primero transitorio de la resoluci&#xF3;n exenta N&#xBA; 481, de 15 de julio de 2003, en su texto modificado por la resoluci&#xF3;n exenta N&#xBA; 628, de 11 de julio de 2005, del Ministerio de Hacienda, la expresi&#xF3;n &quot;30 de junio&quot; por la expresi&#xF3;n &quot;31 de julio&quot;. </div></div>", "i": 8050258}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Andr&#xE9;s Velasco Bra&#xF1;es, Ministro de Hacienda.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a usted para su conocimiento.- Saluda atentamente a usted, Mar&#xED;a Olivia Recart Herrera, Subsecretaria de Hacienda.</div><br></div>", "i": 8050259}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "571 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-571 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA RESOLUCION Nº 481 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-19", "doble_articulado": false, "id_norma": "250877", "numero_fuente": "38500", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-06-29", "vigencias": [{"desde": "2006-06-29", "hasta": "", "tipo_version": "