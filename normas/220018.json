{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6458561}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.576, de 31 de diciembre de 2003, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 208 de 1983, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESCA CHILE S.A. para realizar actividades pesqueras con el buque f&#xE1;brica &quot;Betanzos&quot;, sobre el recurso bacalao de profundidad, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura. </div></div>", "i": 6458562}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de diciembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6458563}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3576 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3576 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-31", "doble_articulado": false, "id_norma": "220018", "numero_fuente": "37757", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-01-12", "vigencias": [{"desde": "2004-01-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-01-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-01-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2004-01-12", "