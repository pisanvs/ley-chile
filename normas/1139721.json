{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 5.416 EXENTA, DE 25.11.2019, DE LA DIRECCI&#xD3;N NACIONAL DE ADUANAS, QUE MODIFICA EL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10077784}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 5.416 de 25.11.2019, del Director Nacional de Aduanas, se incorpor&#xF3; en el Anexo 51-15, relativo a &quot;Almacenistas&quot; el siguiente operador: &quot;Puerto Las Losas S.A.&quot;.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\"> </div></div>", "i": 10077785}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de noviembre de 2019.- Gustavo Poblete Morales, Director Nacional de Aduanas (S).</div><br></div>", "i": 10077786}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5416 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-5416 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 5.416 EXENTA, DE 25.11.2019, DE LA DIRECCIÓN NACIONAL DE ADUANAS, QUE MODIFICA EL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1695107", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-11-25", "doble_articulado": false, "id_norma": "1139721", "numero_fuente": "42526", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-12-12", "vigencias": [{"desde": "2019-12-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "