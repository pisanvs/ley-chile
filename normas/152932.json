{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6224684}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n de la Fiscal&#xED;a del Ministerio de Obras P&#xFA;blicas F. No. 55, de 11 de Junio de 1986, se ha ordenado pagar la suma de $ 392.905 a la Sucesi&#xF3;n Cornejo, o a quien acredite derecho, por el saldo de aval&#xFA;o fijado por la Comisi&#xF3;n de Hombres Buenos para el lote &#xFA;nico, ubicado en la Comuna de Valpara&#xED;so, V Regi&#xF3;n, necesario para la ejecuci&#xF3;n de la obra Casa Caminero en subida Santos Ossa. Se deja constancia que el plazo para reclamar judicialmente del aval&#xFA;o es de 30 d&#xED;as contados desde la fecha de la segunda publicaci&#xF3;n que se har&#xE1; en un peri&#xF3;dico de la V Regi&#xF3;n. </div></div>", "i": 6224685}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas.</div><div class=\"p\">(29) </div></div>", "i": 6224686}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "55", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-55"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-11", "doble_articulado": false, "id_norma": "152932", "numero_fuente": "32534", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-07-29", "vigencias": [{"desde": "1986-07-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-07-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-07-29", "fin_vigencia": "", "tipo_version": "3"}], "eve