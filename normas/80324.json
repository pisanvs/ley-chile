{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 256, DE 1991 </div></div>", "i": 7215175}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 256 de 28 de agosto de 1991 se ha modificado el decreto supremo exento de Educaci&#xF3;n No. 196, de 1985, que aprob&#xF3; planes y programas especiales de estudio de segundo ciclo de educaci&#xF3;n media, modalidad t&#xE9;cnico - profesional, para el Liceo Agr&#xED;cola A No. 15 de Duao, provincia de Talca, VII Regi&#xF3;n del Maule. </div></div>", "i": 7215176}, {"t": "<div><div class=\"p\">Santiago, 16 Septiembre 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7215177}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "256 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-256 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 256, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-08-28", "doble_articulado": false, "id_norma": "80324", "numero_fuente": "34118", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-16", "vigencias": [{"desde": "1991-11-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-11-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-11-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "ALV", "fecha_ingreso": "1997-12-19", "fecha_version": "1991-11-