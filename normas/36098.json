{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.041, de 14 de agosto de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por JULIO ANTONIO FONTECILLA NIETO, para un centro de cultivo ubicado en Seno Ays&#xE9;n, Isla Partida, comuna y provincia de Ays&#xE9;n, XI Regi&#xF3;n, por no dar cumplimiento el respectivo proyecto t&#xE9;cnico a lo dispuesto en los art&#xED;culos 78&#xB0; y 87&#xB0; de la Ley General de Pesca y Acuicultura. </div></div>", "i": 8295382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 14 de agosto de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295383}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1041", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1041"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JULIO FONTECILLA NIETO", "CONCESION ACUICULTURA", "DENEGACION", "DECIMOPRIMERA REGION", "AYSEN"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-08-14", "doble_articulado": false, "id_norma": "36098", "numero_fuente": "35249", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-08-22", "vigencias": [{"desde": "1995-08-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-08-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-08-22", "fin_vigencia": "", "tipo_version": "3"}], "even