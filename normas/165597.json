{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6265120}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 514, del 17 de Diciembre de 1984, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la IV Regi&#xF3;n de Coquimbo, se autoriza Empresa Buses Libac Limitada para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de lomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6265121}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Serena, 17 de Diciembre de 1984.- Gustavo Garc&#xED;a Mujica, Secretario Regional Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n de Coquimbo.</div><br></div>", "i": 6265122}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "514 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-514 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IV REGIÓN COQUIMBO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-12-17", "doble_articulado": false, "id_norma": "165597", "numero_fuente": "32065", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-01-08", "vigencias": [{"desde": "1985-01-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-01-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-01-08", "fin_vigencia": "", "tipo_ver