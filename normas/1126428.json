{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 31A</div></div>", "i": 9974218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 4.168, de 30 de noviembre de 2018, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1121666&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xB0; 2.772, de 2018</a>, de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 31A, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para el centro de cultivo que indica en la resoluci&#xF3;n extractada.</div></div>", "i": 9974219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 30 de noviembre de 2018.- Rom&#xE1;n Zelaya R&#xED;os, Subsecretario de Pesca y Acuicultura (S). </div></div>", "i": 9974220}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4168 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4168 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 31A", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1507540", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-11-30", "doble_articulado": false, "id_norma": "1126428", "numero_fuente": "42224", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-12-07", "vigencias": [{"desde": "2018-12-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"