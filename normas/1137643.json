{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div><br></div>", "i": 10061940}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n Ex. N&#xBA; 3.227 de fecha 07/10/2019, conforme al art&#xED;culo 48 y 62 ley 19.880, de Serviu Regi&#xF3;n de la Araucan&#xED;a, se orden&#xF3; la rectificaci&#xF3;n de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1124027&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n Ex. N&#xBA; 3.173 de fecha 5 de octubre de 2018</a> de Serviu Araucan&#xED;a, que dispuso la expropiaci&#xF3;n del Lote 118-0, en el sentido que por un error de digitaci&#xF3;n en su resuelvo N&#xBA; 1, se indic&#xF3; lo siguiente: &quot;Superficie total a expropiar; 159,22 metros cuadrados&quot;, correspondiendo expresar aproximada correctamente, lo siguiente: &quot;Superficie aproximada total a expropiar; 263,60 metros cuadrados&quot;.- </div><br></div>", "i": 10061941}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n de la Araucan&#xED;a. </div><br></div>", "i": 10061942}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3227 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3227 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1666813", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-10-07", "doble_articulado": false, "id_norma": "1137643", "numero_fuente": "42477", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-10-15", "vigencias": [{"desde": "2019-10-15", "hasta": "", "tipo_version": "3", "