{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; AUTORIZA EMISOR ELECTRONICO </div></div>", "i": 6566150}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 33 de 29 de marzo de 2006, que autoriza a contribuyente como emisor electr&#xF3;nico. Se autoriza como emisor de documentos tributarios electr&#xF3;nicos a RUT 96.989.120-4, a contar del mes de abril de 2006. En la Oficina Virtual del SII en Internet se podr&#xE1; consultar los documentos que el contribuyente est&#xE1; autorizado a emitir en forma electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de marzo, de 2006.</div><br></div>", "i": 6566151}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "33 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-33 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISOR ELECTRONICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONTRIBUYENTES", "EMISORES ELECTRONICOS", "AUTORIZACION", "DOCUMENTOS TRIBUTARIOS ELECTRONICOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-03-29", "doble_articulado": false, "id_norma": "248675", "numero_fuente": "38431", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-04-04", "vigencias": [{"desde": "2006-04-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig