{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6575746}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (Exento) N&#xBA; 302 de fecha 31 de mayo de 2006, se expropi&#xF3; el lote de terreno N&#xBA; 124, superficie 1.160 m2, Rol N&#xBA; 305-225, comuna de Melipeuco, IX Regi&#xF3;n para la obra &quot;Camino Ruta S-61, sector: Cunco Melipeuco, tramo Km. 55,00 al Km.</div><div class=\"p\">87,46783, correspondiente al Sub-Tramo III Km. 76,068 al Km. 87,443&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Berta Gabriela Huenchum&#xE1;n Porma, ascendente a la cantidad de $698.288.- para el lote N&#xBA; 124.</div><br></div>", "i": 6575747}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6575748}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "302 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-302 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-05-31", "doble_articulado": false, "id_norma": "251278", "numero_fuente": "38514", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-07-15", "vigencias": [{"desde": "2006-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2006-07-17", "fecha_version": "2006-07-