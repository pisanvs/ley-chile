{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CRUZ DANIEL RAMIREZ Lei n&#xFA;m. 329.-Santiago, a 15 de Enero de 1896.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947546}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese por gracia al teniente coronel don Cruz Daniel Ram&#xED;rez la rehabilitacion que solicita para tramitar su espediente de invalidez en conformidad a las leyes.</div><br><br></div>", "i": 5947547}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.-Luis Barros Borgo&#xF1;o.</div><br></div>", "i": 5947548}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "329", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-329"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "CRUZ DANIEL RAMIREZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CRUZ DANIEL RAMIREZ", "REHABILITACION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-01-15", "doble_articulado": false, "id_norma": "22180", "numero_fuente": "5321", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1896-01-29", "vigencias": [{"desde": "1896-01-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1896-01-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1896-01-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_po