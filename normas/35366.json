{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293671}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 683, de 15 de Julio de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de las Resoluciones N&#xB0; 513, de 1988 y N&#xB0; 980, de 1989, ambas de esta Subsecretar&#xED;a, solamente en cuanto autorizaron a PESQUERA MAR DEL SUR S.A., R.U.T. N&#xB0; 96.513.090-K, domiciliada en Avda. 11 de Septiembre N&#xB0; 1860, Oficina 142, para operar la nave &quot;Mar del Sur III&quot;, en virtud de lo dispuesto en la letra b) del art&#xED;culo 143 del D.S. N&#xB0; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8293672}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 15 de Julio de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293673}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "683", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-683"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA MAR SUR S.A.", "CADUCIDAD", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-07-15", "doble_articulado": false, "id_norma": "35366", "numero_fuente": "34923", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-07-25", "vigencias": [{"desde": "1994-07-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-07-25", "fin_vigencia": ""}, "vigencias_version_norma