{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Gratificacion al jeneral don Alejandro Gorostiaga.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1823.- Santiago, a 10 de Febrero de 1906.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5951296}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, al jeneral de brigada don Alejandro Gorostiaga, una gratificacion correspondiente al veinticinco por ciento de la pension de retiro de que ha disfrutado o en adelante disfrutare, a contar desde el 22 de Diciembre de 1897.</div><br></div>", "i": 5951297}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Manuel F&#xF3;ster R.</div><br></div>", "i": 5951298}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1823", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1823"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "GRATIFICACION AL JENERAL DON ALEJANDRO GOROSTIAGA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ALEJANDRO GOROSTIAGA", "GRATIFICACION POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-02-10", "doble_articulado": false, "id_norma": "22941", "numero_fuente": "8429", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1906-02-13", "vigencias": [{"desde": "1906-02-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1906-02-13