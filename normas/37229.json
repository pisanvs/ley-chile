{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297841}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.599, de 10 de Noviembre de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, cad&#xFA;canse parcialmente las Resoluciones N&#xB0; 1.791, de 1989 y N&#xB0; 385, de 1991, ambas de esta Subsecretar&#xED;a, en cuanto autorizaron a PESQUERA SANTA LUCIA S.A., R.U.T. N&#xB0; 96.527.920-2, para operar la embarcaci&#xF3;n &quot;Luc&#xED;a&quot;, en virtud de lo dispuesto en el art&#xED;culo 143, letra b) del D.S. N&#xB0; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, que fij&#xF3; el texto refundido de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8297842}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 10 de Noviembre de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297843}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1599", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1599"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA SANTA LUCIA S.A", "PESCA", "AUTORIZACION", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-11-10", "doble_articulado": false, "id_norma": "37229", "numero_fuente": "35319", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-11-17", "vigencias": [{"desde": "1995-11-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-11-17", "fin_vigenc