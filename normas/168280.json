{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7269544}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 300, de 15 de Marzo de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por 6 meses, a contar de esta fecha, el plazo otorgado a MANAO BAY FISHERY S.A., R.U.T.</div><div class=\"p\">No. 96.540.080-k, domiciliada en Santiago, en el nuneral 5&#xB0; de la Resoluci&#xF3;n No. 778, de 1989, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 7269545}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de Marzo de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 7269546}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "300", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-300"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-03-15", "doble_articulado": false, "id_norma": "168280", "numero_fuente": "33936", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-06", "vigencias": [{"desde": "1991-04-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-04-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-04-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "IMH",