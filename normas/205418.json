{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7295768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;2.780, de 4 de diciembre de 2002, de esta Subsecretar&#xED;a, rectif&#xED;case la resoluci&#xF3;n N&#xBA;2.585 de 2002, de esta Subsecretar&#xED;a, que autoriz&#xF3; a&nbsp; PESQUERA SAN JOSE S.A. para sustituir la nave &quot;Pionero I&quot; por la nave &quot;El Conquistador&quot;, en la forma que se indica:</div><br><div class=\"p\">a) Rectif&#xED;case el n&#xFA;mero 1&#xBA;, en el sentido de se&#xF1;alar que la embarcaci&#xF3;n reemplazante es la nave &quot;Conquistador&quot;.</div><br><div class=\"p\">b) Rectif&#xED;case el n&#xFA;mero 3&#xBA;, en el sentido de reemplazar la expresi&#xF3;n &quot;Pionero I&quot; por</div><div class=\"p\">&nbsp;  &quot;Conquistador&quot;.</div><br></div>", "i": 7295769}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de diciembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7295770}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2780", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2780"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-12-04", "fecha_derogacion": "2006-03-17", "doble_articulado": false, "id_norma": "205418", "numero_fuente": "37431", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-12-11", "vigencias": [{"desde": "2006-03-17", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2