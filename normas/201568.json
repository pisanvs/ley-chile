{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6392803}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.104 de fecha 28 de junio de 2002, cursado con alcance por Contralor&#xED;a General de la Rep&#xFA;blica, seg&#xFA;n oficio N&#xBA;28.334 de 26 de julio de 2002, se expropi&#xF3; el lote de terreno N&#xBA;4, superficie 92.012,2 m&#xB2;, rol de aval&#xFA;o N&#xBA;671-41, comuna de Timaukel, para la obra &apos;&apos;Camino Estancia Vicu&#xF1;a-Yendegaia, sector Km.</div><div class=\"p\">5,00000 al 13,02000, 2&#xAA; Etapa, Tierra del Fuego&apos;&apos;, XII Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Gustavo Adolfo Leiva Balich y otras, ascendente a la cantidad de $11.642.654.-</div><br></div>", "i": 6392804}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6392805}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1104", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1104"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-28", "doble_articulado": false, "id_norma": "201568", "numero_fuente": "37335", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-08-16", "vigencias": [{"desde": "2002-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":