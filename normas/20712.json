{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 223 EXENTO, DE 1995 </div></div>", "i": 7161223}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 223 de fecha 07 de Abril de 1995 del Ministerio de Educaci&#xF3;n, se declar&#xF3; aprobada al Instituto Profesional Carlos Casanueva, inscrito en el Registro de Institutos Profesionales bajo el Folio C-N&#xB0; 89 de 1991, la siguiente carrera y t&#xED;tulo profesional para impartirse en su Sede de Santiago, de conformidad al acuerdo adoptado por el Consejo Superior de Educaci&#xF3;n, quien llevar&#xE1; a efecto la verificaci&#xF3;n progresiva de su desarrollo:</div><div class=\"p\">&nbsp; &nbsp; Carrera: Gesti&#xF3;n en Educaci&#xF3;n No Formal, conducente al t&#xED;tulo profesional de Gestor en Educaci&#xF3;n No Formal.</div><br><br></div>", "i": 7161224}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 27 de Abril de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161225}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "223 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-223 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 223 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO PROFESIONAL CARLOS CASANUEVA", "CARRERA", "PROFESIONAL", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1995-04-07", "fecha_derogacion": "2021-12-31", "doble_articulado": false, "id_norma": "20712", "numero_fuente": "35164", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1995-05-11", "vigencias": [{"desde": "2021-1