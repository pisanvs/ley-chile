{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6509329}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA; 1.568 de 11 de noviembre de 2004, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA; del decreto MOP exento N&#xBA; 210 de 28 de febrero de 2002, en la parte que se refiere al Convenio Directo de Precio Ad Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n de los lotes N&#xBA; 6, 7 y 9, fijada por la Comisi&#xF3;n de Peritos, con fecha 3 de mayo de 1999, ascendente a la cantidad de $60.760.- lote N&#xBA; 6;</div><div class=\"p\">$50.000.- lote N&#xBA; 7 y $180.740.- lote N&#xBA; 9. </div></div>", "i": 6509330}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6509331}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1568 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1568 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-11", "doble_articulado": false, "id_norma": "233700", "numero_fuente": "38036", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-15", "vigencias": [{"desde": "2004-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-12-15", "fin_vigencia": "", "tipo_ver