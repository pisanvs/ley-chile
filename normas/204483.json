{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6402524}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.569, de 8 de noviembre de 2002, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1.046 de 1994, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SERVICIOS PESQUEROS LIMITADA a operar una planta ubicada en Juan Macaya N&#xBA; 1372, San Vicente, Talcahuano, de acuerdo con lo informado por el Servicio Nacional de Pesca en oficio citado en Visto y lo dispuesto en el art&#xED;culo 7&#xBA; del D.S. N&#xBA; 175 de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 6402525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de noviembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6402526}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2569", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2569"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-11-08", "doble_articulado": false, "id_norma": "204483", "numero_fuente": "37409", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-11-15", "vigencias": [{"desde": "2002-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICAC