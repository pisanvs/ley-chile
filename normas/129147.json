{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8338086}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.874, de 30 de diciembre de 1998, de esta Subsecretar&#xED;a, autor&#xED;zase a EMPRESA DE DESARROLLO PESQUERO DE CHILE S.A., para realizar operaciones pesqueras, a contar del 1 de enero y hasta el 31 de diciembre de 1999, ambas fechas inclusive, con los barcos f&#xE1;brica denominados &apos;&apos;Unzen&apos;&apos; y &apos;&apos;Unionsur&apos;&apos;, en aguas exteriores, por fuera de las l&#xED;neas de base recta, al sur del paralelo 44&#xB0;30 de latitud sur, respecto de las &#xE1;reas y recursos y con las obligaciones establecidas en sus respectivas resoluciones. </div></div>", "i": 8338087}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de diciembre de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8338088}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1874", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1874"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-12-30", "doble_articulado": false, "id_norma": "129147", "numero_fuente": "36257", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-01-07", "vigencias": [{"desde": "1999-01-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-01-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-01-07", "fin_vigencia": "", "tipo_version": "3