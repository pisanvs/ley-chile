{"html": [{"t": "<div><br><div class=\"p\">DESIGNA FUNCIONARIO TITULAR Y SUPLENTE EN IMPLEMENTACI&#xD3;N DE SISTEMA QUE INDICA</div></div>", "i": 9825368}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta SII N&#xB0; 71, del 10 de agosto de 2017, que establece:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Designa funcionario titular y suplente para la coordinaci&#xF3;n e implementaci&#xF3;n del sistema preventivo contra delitos funcionarios, lavado de activos y financiamiento del terrorismo y delega facultad que indica, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1079822&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n Ex. SII N&#xBA; 63, de 2015</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de agosto de 2017.</div><div class=\"p\"> </div></div>", "i": 9825369}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "71 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-71 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESIGNA FUNCIONARIO TITULAR Y SUPLENTE EN IMPLEMENTACIÓN DE SISTEMA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1257325; EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-08-10", "doble_articulado": false, "id_norma": "1106642", "numero_fuente": "41836", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-08-17", "vigenci