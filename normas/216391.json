{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6445663}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.537, de 16 de octubre de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a SOUTHPACIFIC KORP S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Guanaye 3&quot;, en la VIII y X Regiones, por fuera de las 60 millas marinas, con arrastre de media agua, donde podr&#xE1; capturar los siguientes recursos hidrobiol&#xF3;gicos: Anchoveta o anchoa, Sardina com&#xFA;n, Jurel, Merluza de cola, Agujilla, Bonito, Caballa, Cojinoba del norte Seriolella violacea, Cojinoba del sur, Cojinoba moteada, Dorado, Machuelo o tritre, Palometa, Sardina espa&#xF1;ola, Jurel fino, Anchoa blanca, Sardina redonda, Vinciguerria.</div><br></div>", "i": 6445664}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de octubre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6445665}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2537 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2537 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-16", "doble_articulado": false, "id_norma": "216391", "numero_fuente": "37697", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-10-29", "vigencias": [{"desde": "2003-10-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-10-29", "fin_vigencia": ""}, "vigencias_version_norma"