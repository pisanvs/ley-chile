{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 017 DE 1992 </div></div>", "i": 7214434}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 017 de 21 de enero de 1992 se ha aprobado al &quot;Colegio Concepci&#xF3;n&quot;, de Concepci&#xF3;n, VIII Regi&#xF3;n del B&#xED;o B&#xED;o, un plan especial de estudio para 3er. a&#xF1;o de Educaci&#xF3;n B&#xE1;sica a 4to. a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica, para ser aplicado progresivamente a partir del a&#xF1;o escolar 1992. Adem&#xE1;s, se aprueba programa de estudio para la asignatura de Etica y Moral, desde 1er. a&#xF1;o b&#xE1;sico a 4to. a&#xF1;o medio. </div></div>", "i": 7214435}, {"t": "<div><div class=\"p\">Santiago, 07 de Febrero de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7214436}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "17 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-17 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 017 DE 1992EXTRACTO DE DECRETO EXENTO No. 017 DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-01-21", "doble_articulado": false, "id_norma": "79455", "numero_fuente": "34221", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-03-18", "vigencias": [{"desde": "1992-03-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-03-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-03-18", "fin_vigencia": "", "tipo_ve