{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6334377}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA;236, de fecha 30 de marzo de 2001, se expropi&#xF3; el lote de terreno N&#xBA;45, superficie 66 m&#xB2;, rol de aval&#xFA;o 2213-368, comuna de Chill&#xE1;n, para la obra &apos;&apos;Camino Ruta N-45, Sector Cruce N-49 (Chill&#xE1;n) - La Capilla - Tres Esquinas, Km. 6,26000M a Km.</div><div class=\"p\">28,548000&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Jos&#xE9; Eduardo Becerra Riquelme, ascendente a la cantidad de $210.022.-.</div><br></div>", "i": 6334378}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6334379}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "236 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-236 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-30", "doble_articulado": false, "id_norma": "185133", "numero_fuente": "36962", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-15", "vigencias": [{"desde": "2001-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2001-05-16", "fecha_version": "2001-05-15", "fecha_actualizacion_texto": "2001-05-15