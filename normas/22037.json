{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MONTEPIO Lei n&#xFA;m. 177.-Santiago, a 22 de Enero de 1894.- Por cuanto el Congreso Nacional ha aprobado el siguiente PROYECTO DE LEI:</div><br></div>", "i": 5947037}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese por gracia a do&#xF1;a Alejandrina Contreras, viuda de Cavada, el goce del Montep&#xED;o correspondiente al empleo de teniente de Ej&#xE9;rcito.</div><br><br></div>", "i": 5947038}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORGE MONTT.- Juan Antonio Orrego.</div><br></div>", "i": 5947039}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "177", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-177"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "MONTEPIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ALEJANDRINA CONTRERAS VDA. DE CAVADA", "MONTE PIO", "MILITAR", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-01-22", "doble_articulado": false, "id_norma": "22037", "numero_fuente": "4734", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-02-03", "vigencias": [{"desde": "1894-02-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-02-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-02-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-01-25", "fecha_version": "1894-02-03", "fecha_actuali