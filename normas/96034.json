{"html": [{"t": "<div><div class=\"p\">DESIGNA SECRETARIO SUPLENTE DEL TRIBUNAL ESPECIAL DE ALZADA DE LOS BIENES RAICES DE LA SEGUNDA SERIE DE COYHAIQUE </div></div>", "i": 6101806}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xBA; 279, de 07 de Abril de 92, el suscrito, Director Nacional del Servicio de Impuestos Internos, design&#xF3; a don Hern&#xE1;n Nicanor B&#xF3;rquez - Rut. N&#xBA; 7.064.516-5, como Secretario Suplente del Tribunal Especial de Alzada de los Bienes Ra&#xED;ces, no agr&#xED;colas, de Coyhaique, y a su vez, puso t&#xE9;rmino al nombramiento de don Francisco A. Ruiz Aguilar, en la misma calidad, por haber dejado de pertenecer a este Servicio.</div><br></div>", "i": 6101807}, {"t": "<div><div class=\"p\">Javier Etcheberry Celhay, Director.</div><br></div>", "i": 6101808}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "279", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-279"}], "organismos": ["MINISTERIO DE HACIENDA", "SUBSECRETARÍA DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESIGNA SECRETARIO SUPLENTE DEL TRIBUNAL ESPECIAL DE ALZADA DE LOS BIENES RAICES DE LA SEGUNDA SERIE DE COYHAIQUE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-04-07", "doble_articulado": false, "id_norma": "96034", "numero_fuente": "34274", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-05-25", "vigencias": [{"desde": "1992-05-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-05-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-05-25", "fin_vige