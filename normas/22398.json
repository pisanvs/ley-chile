{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento al Presupuesto del Interior Lei n&#xFA;m. 1.081.- Santiago, a 26 de Setiembre de 1898.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274083}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de catorce mil pesos al &#xED;tem 19 de la partida 2.a del presupuesto del Ministerio del Interior para gastos jenerales de la Secretar&#xED;a de la C&#xE1;mara de Diputados.</div><br><br></div>", "i": 8274084}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C. Walker Mart&#xED;nez.</div><br></div>", "i": 8274085}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1081", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1081"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "SUPLEMENTO AL PRESUPUESTO DEL INTERIOR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1898", "MODIFICACION", "MINISTERIO", "INTERIOR", "CAMARA DIPUTADOS", "SECRETARIA", "GASTOS", "GENERALES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-09-26", "doble_articulado": false, "id_norma": "22398", "numero_fuente": "6109", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-09-26", "vigencias": [{"desde": "1898-09-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-09-26", "fin_vigencia": ""}, "vigen