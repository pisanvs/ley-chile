{"html": [{"t": "<div><div class=\"p\">AUTORIZA A PESQUERA SUNNAN LIMITADA PARA AMPLIAR ACTIVIDADES PESQUERAS </div></div>", "i": 7264952}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 144, de 15 de Marzo de 1985, de la Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Pesquera Sunnan Limitada, domiciliada en Concepci&#xF3;n, para instalar y operar en un sector de playa de la Bah&#xED;a de Coronel, una planta Procesadora de harina de pescado, en la que podr&#xE1; utilizar como materia prima: jurel, sardina com&#xFA;n, sardina espa&#xF1;ola, caballa y anchoa.</div><br></div>", "i": 7264953}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de Marzo de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7264954}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "144", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-144"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA SUNNAN LIMITADA PARA AMPLIAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-03-15", "doble_articulado": false, "id_norma": "160617", "numero_fuente": "32142", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-04-10", "vigencias": [{"desde": "1985-04-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-04-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-04-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes"