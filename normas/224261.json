{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6475419}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 945, de fecha&nbsp; 6 de abril de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA PACIFIC STAR SOCIEDAD ANONIMA, para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Ruta V-815, kil&#xF3;metro 5,2 Panitao, Puerto Montt, X Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de Concentrado de prote&#xED;nas solubles estabilizado obtenido de fracciones l&#xED;quidas parcialmente desgrasadas extra&#xED;das durante la elaboraci&#xF3;n de harina y aceite de pescado, los recursos hidrobiol&#xF3;gicos individualizados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6475420}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6475421}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "945 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-945 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-04-06", "fecha_derogacion": "2005-07-08", "doble_articulado": false, "id_norma": "224261", "numero_fuente": "37846", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-04-27", "vigencias": [{"desde": "2005-07-08", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-04-27", "hasta": "2005-07-07", "tipo_version": "