{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 390 EXENTO, DE 1997 </div></div>", "i": 6035148}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Supremo exento de Educaci&#xF3;n N&#xBA; 390, del 8 de abril de 1997, se aprueba Plan Especial de Estudio para alumnos con trastornos graves en su capacidad de relaci&#xF3;n y comunicaci&#xF3;n a la Escuela Especial F N&#xBA; 86 &quot;Juan Sandoval Carrasco&quot;, el que ser&#xE1; aplicado por un per&#xED;odo de 4 a&#xF1;os, a contar del a&#xF1;o escolar 1997.</div><br></div>", "i": 6035149}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de abril de 1997.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 6035150}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "390 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-390 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 390 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "ESCUELA ESPECIAL F N 86 JUAN SANDOVAL CARRASCO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-08", "doble_articulado": false, "id_norma": "70965", "numero_fuente": "35754", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-30", "vigencias": [{"desde": "1997-04-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-04-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-04-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PRO", "fecha_ingreso": "1997-05-09", "fecha_vers