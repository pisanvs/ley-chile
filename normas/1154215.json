{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10190497}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xB0; 3.015, de 23 de diciembre de 2020, aprueba protocolo para la evaluaci&#xF3;n de puestos de trabajo con exposici&#xF3;n a radiaciones ionizantes asociadas a pr&#xE1;cticas con t&#xE9;cnicas fluorosc&#xF3;picas de uso m&#xE9;dico.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10190498}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Heriberto Garc&#xED;a Escorza, Director (S), Instituto de Salud P&#xFA;blica de Chile.</div><br></div>", "i": 10190499}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3015 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3015 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1875462", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-12-23", "doble_articulado": false, "id_norma": "1154215", "numero_fuente": "42846", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-01-05", "vigencias": [{"desde": "2021-01-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2021-01-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2021-01-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_p