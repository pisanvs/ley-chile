{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 538 EXENTO, DE 1998 </div></div>", "i": 6111470}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA;538 de 24 de</div><div class=\"p\">abril de 1998, se ha aprobado al Colegio &quot;Craighouse&quot; de</div><div class=\"p\">Santiago, un plan de estudio biling&#xFC;e para los alumnos de 1&#xBA;</div><div class=\"p\">a 4&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica (NB.1 y NB.2), que se aplicar&#xE1;</div><div class=\"p\">a partir del a&#xF1;o escolar 1998, de acuerdo con lo se&#xF1;alado en</div><div class=\"p\">el decreto supremo de Educaci&#xF3;n N&#xBA;40 de 1996 y sus</div><div class=\"p\">modificaciones.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio biling&#xFC;es para</div><div class=\"p\">los distintos subsectores del plan de estudio aprobado en el</div><div class=\"p\">art&#xED;culo anterior, correspondientes a 1&#xBA;, 2&#xBA;, 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica (NB.1 y NB.2).</div><br></div>", "i": 6111471}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de mayo de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6111472}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "538 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-538 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 538 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIO CRAIGHOUSE", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-24", "doble_articulado": false, "id_norma": "99317", "numero_fuente": "36068", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-05-19", "vigencias": [{"desde": "1998-05-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-05-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-05-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JRC", "fecha_ingreso": "1998-05-19", "fecha_version": "1998-05-19", "fecha_actualizacion_texto": "1998-05-19", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6111470}, {"n": "Artículo", "i": 6111471, "t": 6}, {"n": "Promulgación", "i": 6111472}]}