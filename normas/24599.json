{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><br></div>", "i": 7168406}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.o Desc&#xE1;rguese del</div><div class=\"p\">&nbsp; Cap&#xED;tulo&nbsp; &nbsp; &nbsp;  Item&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; La suma</div><div class=\"p\">&nbsp; &nbsp; II&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  19&nbsp; &nbsp; &nbsp; &nbsp;  $ 50,000</div><div class=\"p\">&nbsp; &nbsp; XV&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 429&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  50,000</div><br></div>", "i": 7168407}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2.o Aum&#xE9;ntase en la suma de cien mil pesos ($ 100,000) el &#xED;tem 26, del Cap&#xED;tulo II del Presupuesto de Marina vigente.</div><br></div>", "i": 7168408}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a treinta y uno de Diciembre de mil novecientos veintisiete.- Carlos Ib&#xE1;&#xF1;ez del Campo.- C.</div><div class=\"p\">O. Frodden.</div><br></div>", "i": 7168409}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4244", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4244"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1927", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1927-12-31", "doble_articulado": false,