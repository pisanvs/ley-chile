{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 341 EXENTO, DE 1996 </div></div>", "i": 5943926}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 341 de fecha 18 de junio de 1996 del Ministerio de Educaci&#xF3;n, se aprobaron los planes y programas de estudios del Centro de Formaci&#xF3;n T&#xE9;cnica ECI de las carreras y t&#xED;tulos t&#xE9;cnicos de nivel superior que se indican, para ser impartidas en la Sede Central de Osorno, a contar del a&#xF1;o 1996.</div><div class=\"p\"> Carrera&nbsp; &nbsp; &nbsp;  :&nbsp; T&#xE9;cnico en Construcci&#xF3;n</div><div class=\"p\"> T&#xED;tulo&nbsp; &nbsp; &nbsp; &nbsp; :&nbsp; T&#xE9;cnico de Nivel Superior en</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Construcci&#xF3;n</div><div class=\"p\"> Carrera&nbsp; &nbsp; &nbsp;  :&nbsp; T&#xE9;cnico Asistente de Arquitectura</div><div class=\"p\"> T&#xED;tulo&nbsp; &nbsp; &nbsp; &nbsp; :&nbsp; T&#xE9;cnico de Nivel Superior en</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Arquitectura</div><br></div>", "i": 5943927}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 9 de julio de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943928}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "341", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-341"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 341 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "APROBACION", "CENTRO FORMACION TECNICA ECI", "OSORNO", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion