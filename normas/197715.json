{"html": [{"t": "<div><div class=\"p\">APRUEBA ORDENANZA SOBRE PROTECCION Y CONSERVACION DEL MEDIO AMBIENTE </div></div>", "i": 8721061}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Municipalidad de Mulch&#xE9;n, pone en conocimiento de la comunidad, que por decreto administrativo N&#xBA; 417, de fecha 2 de abril de 2002, fue aprobada la ordenanza que norma sobre la protecci&#xF3;n y conservaci&#xF3;n del Medio Ambiente en la comuna.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto completo de la citada ordenanza, se informa que est&#xE1; a disposici&#xF3;n de quien lo solicite, en la Secretar&#xED;a Municipal.-</div><br><br></div>", "i": 8721062}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  H&#xE9;ctor Francisco Jara Delgado, Alcalde. </div></div>", "i": 8721063}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "417", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-417"}], "organismos": ["MUNICIPALIDAD DE MULCHÉN"], "titulo_norma": "APRUEBA ORDENANZA SOBRE PROTECCION Y CONSERVACION DEL MEDIO AMBIENTE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-02", "doble_articulado": false, "id_norma": "197715", "numero_fuente": "37250", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-04", "vigencias": [{"desde": "2002-05-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "IMH", "fecha_ingreso