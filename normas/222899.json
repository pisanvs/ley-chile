{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 225.- Santiago, 15 de Mayo de 1931.- Vistas las facultades que me concede la ley n&#xFA;mero 4,945, de 6 de febrero del presente a&#xF1;o,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 6470753}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Agr&#xE9;guese como inciso segundo del Decreto-Ley n&#xFA;mero 194, de 15 de Mayo de este a&#xF1;o, el siguiente:</div><div class=\"p\">&nbsp; &nbsp;  &quot;No se entender&#xE1;n derogadas por el presente decreto las disposiciones de car&#xE1;cter tributario y de fiscalizaci&#xF3;n de la calidad de la cerveza, contenidas en la ley n&#xFA;mero 4,536, y en su reglamento&quot;.</div><br></div>", "i": 6470754}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese Raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- C. IBA&#xD1;EZ C.- Carlos Castro Ruiz. </div></div>", "i": 6470755}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "225", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-225"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-05-15", "doble_articulado": false, "id_norma": "222899", "numero_fuente": "15984", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-05-29", "vigencias": [{"desde": "1931-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1931-05-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1931-05-29", "fin_vigencia": "", "tipo_ver