{"html": [{"t": "<div><div class=\"p\">EXPROPIACION PARCIAL DE INMUEBLE</div><div class=\"p\">(Extracto) </div></div>", "i": 6059506}, {"t": "<div><div class=\"p\">Por Dcto. Secc. 2&#xAA; No. 692 de 19 Noviembre de 1990 Alcalde I. Municipalidad de Santiago dispone expropiaci&#xF3;n parcial inmueble Esmeralda 808 y San Antonio 734. Rol 204.135 Stgo. dominio aparente Amador Brieba Alvarado y Otro. Superficie aprox. 268,75 m2. deslindes: Norte 34,40 mts. calle Esmeralda; Sur 33,30 mts. resto predio y 3,95 mts. ensanche San Antonio Oriente 32,60 mts. calle San Antonio. Poniente 28,25 mts. resto predio y 4,70 mts. Diagonal Cervantes. Indem. provisional $ 20.060.000.- pagadera contado. </div></div>", "i": 6059507}, {"t": "<div><div class=\"p\">Jaime Ravinet de la Fuente, Alcalde de Stgo.</div><br></div>", "i": 6059508}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "692", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-692"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "EXPROPIACION PARCIAL DE INMUEBLE\n(Extracto)", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-11-19", "doble_articulado": false, "id_norma": "81334", "numero_fuente": "33833", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-12-01", "vigencias": [{"desde": "1990-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1997-12-29", "fe