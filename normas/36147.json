{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295492}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.070, de 11 de junio de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2&#xB0; de la Resoluci&#xF3;n N&#xB0; 790, de 1996, de esta Subsecretar&#xED;a que autoriz&#xF3; a SOCIEDAD INDUSTRIAL PESQUERA MAC LEAN Y CIA. LTDA., para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a incluir en las l&#xED;neas de proceso de Congelado, Fresco-enfriado y Conserva, el recurso hidrobiol&#xF3;gico Erizo Loxechinus albus. </div></div>", "i": 8295493}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 11 de junio de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295494}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1070", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1070"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD INDUSTRIAL PESQUERA MAC LEAN CIA LTDA", "PESCA", "INDUSTRIA PESQUERA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-06-11", "fecha_derogacion": "1998-08-29", "doble_articulado": false, "id_norma": "36147", "numero_fuente": "35501", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-06-26", "vigencias": [{"desde": "1998-08-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1996-06-26", "hasta": "1998-08-28", "tipo_version": "0", "tipo_version_s": "Texto Ori