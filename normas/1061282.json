{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9430211}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 997, de 9 de abril de 2014 de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1058152&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.789 de 2013</a>, de esta Subsecretar&#xED;a, que estableci&#xF3; las toneladas asignadas a los Titulares de Licencias Transables de Pesca Clase A, inscritas en Registro P&#xFA;blico que lleva esta Subsecretar&#xED;a, a ser extra&#xED;das durante el a&#xF1;o 2014, en la unidad de pesquer&#xED;a de Jurel, en el &#xE1;rea mar&#xED;tima comprendida entre la XV a X Regiones, seg&#xFA;n se indica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Jurel XV-II Regiones</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/39257.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Jurel III-IV Regiones</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/39258.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Jurel V-IX Regiones</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/39259.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Jurel XIV-X Regiones</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/39260.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><br></div>", "i": 9430212}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de abril de 2014.- Paolo Trejo Carmona, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9430213}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "997 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-997 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-04-09", "doble_articulado": false, "id_norma": "1061282", "numero_fuente": "40835", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-04-16", "vigencias": [{"desde": "2014-04-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-04-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014-04-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "1795", "fecha_ingreso": "2014-04-16", "fecha_version": "2014-04-16", "fecha_actualizacion_texto": "2014-04-16", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9430211}, {"n": "Artículo", "i": 9430212, "t": 6}, {"n": "Promulgación", "i": 9430213}]}