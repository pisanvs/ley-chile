{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 5.095 EXENTA, DE 2007 </div></div>", "i": 7346538}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 5.095, de 20 de junio de 2007, se ha aprobado al Colegio Alem&#xE1;n de Santiago, en representaci&#xF3;n de la Asociaci&#xF3;n de Colegios Alemanes de Chile, planes de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media para los Colegios Alemanes que se individualizan en el art&#xED;culo 1&#xBA; de la presente resoluci&#xF3;n, los que ser&#xE1;n aplicados a contar del a&#xF1;o escolar 2007.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los cursos de 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media. </div></div>", "i": 7346539}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de junio de 2007.- M&#xF3;nica Luna Gonz&#xE1;lez, Jefa Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 7346540}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5095 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5095 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 5.095 EXENTA, DE 2007", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2007-06-20", "fecha_derogacion": "2014-04-22", "doble_articulado": false, "id_norma": "262244", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2007-07-03", "vigencias": [{"desde": "2014-04-22", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2007-07-03", "hasta": "2014-04-21", "tipo_version": "0", "tipo_version_s": "Text