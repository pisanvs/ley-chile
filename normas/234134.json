{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION (A) N&#xBA; 140, DE 2004</div><br><br><br></div>", "i": 8496751}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En cumplimiento de lo dispuesto en los decretos del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA; 291, de 11 de junio de 1999 y N&#xBA; 668, de 16 de noviembre de 1999, certifico que por resoluci&#xF3;n (A) N&#xBA; 140, de 13 de septiembre de 2004, del se&#xF1;or Vicepresidente Ejecutivo, totalmente tramitada, se dejaron sin efecto las resoluciones (A) N&#xBA;s. 59 y 172, de 2000 y N&#xBA; 99, de 2002, y se aprob&#xF3; el texto del Reglamento del Programa de Desarrollo de Proveedores -PDP- Administrados por Agentes Operadores Intermediarios P&#xFA;blicos y Privados. El texto completo de la antes referida resoluci&#xF3;n, estar&#xE1; a disposici&#xF3;n de los usuarios en la Secretar&#xED;a General de la Corporaci&#xF3;n y en las Direcciones Regionales.</div><br></div>", "i": 8496752}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de diciembre de 2004.- Yerko Koscina Peralta, Secretario General.</div><br></div>", "i": 8496753}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "140", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-140"}], "organismos": ["CORPORACIÓN DE FOMENTO DE LA PRODUCCIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION (A) Nº 140, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REGLAMENTO", "PROGRAMA DE DESARROLLO DE PROVEEDORES", "CORFO", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-09-13", "fecha_derogacion": "2007-08-23", "doble_articulado": false, "id_norma": "234134", "numero_fuente": "38049", "tipo_version": "2