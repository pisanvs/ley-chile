{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7310454}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 905, de 31 de marzo de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BIO BIO S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Mar&#xED;a Bernardita&quot;, en las &#xE1;reas mar&#xED;timas que se indican, donde podr&#xE1; capturar, el recurso Jibia:</div><div class=\"p\">a) En el &#xE1;rea mar&#xED;tima de la V a VII y IX Regiones, con cerco, y b) En el &#xE1;rea mar&#xED;tima de la V a VII y IX Regiones, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua.</div><br></div>", "i": 7310455}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de marzo de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7310456}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "905 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-905 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-03-31", "fecha_derogacion": "2007-12-04", "doble_articulado": false, "id_norma": "223461", "numero_fuente": "37832", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-04-08", "vigencias": [{"desde": "2007-12-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-04-08", "hasta": "2007-12-03", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2007-12-04", "fin_vigen