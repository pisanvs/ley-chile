{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6386733}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.255, de 18 de junio de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a SOUTHPACIFIC KORP S.A. para ampliar las actividades pesqueras extractivas con la nave &quot;Malleco&quot;, autorizada por las resoluciones N&#xBA; 836 y N&#xBA; 1.919, ambas de 2001, ambas de esta Subsecretar&#xED;a, en orden a realizar actividades pesqueras con la nave individualizada precedentemente, en el &#xE1;rea mar&#xED;tima comprendida entre la V a X Regiones, por fuera del &#xE1;rea de reserva artesanal, con arte de cerco, donde podr&#xE1; capturar los recursos hidrobiol&#xF3;gicos Jurel fino, Anchoa blanca o samasa, Sardina redonda y Vinciguerria. </div></div>", "i": 6386734}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de junio de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6386735}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1255", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1255"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-06-18", "fecha_derogacion": "2011-12-17", "doble_articulado": false, "id_norma": "199731", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-06-26", "vigencias": [{"desde": "2011-12-17", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2002-06-26", "hasta": "2011-12-16", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "v