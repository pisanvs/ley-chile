{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 382, DE 1990 </div></div>", "i": 5944195}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 382, de 28 de diciembre de 1990, se ha aprobado al Colegio Mar&#xED;a Inmaculada de Santiago, un plan especial de estudio para Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, para ser aplicado desde el a&#xF1;o 1991, simult&#xE1;neamente en todos los cursos.</div><div class=\"p\">&nbsp; &nbsp; El establecimiento seguir&#xE1; aplicando en Educaci&#xF3;n B&#xE1;sica plan de estudio aprobado por decreto supremo exento de Educaci&#xF3;n N&#xB0; 313, de 1986, siendo la asignatura de Computaci&#xF3;n evaluada en conceptos sin incidencia en la promoci&#xF3;n.</div><br></div>", "i": 5944196}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 20 de mayo de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5944197}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "382", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-382"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 382, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO MARIA INMACULADORA", "SANTIAGO", "PLAN ESPECIAL ESTUDIO", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-28", "doble_articulado": false, "id_norma": "21112", "numero_fuente": "33995", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-06-18", "vigencias": [{"desde": "1991-06-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-