{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DELEGA EN FUNCIONARIOS SE&#xD1;ALADOS, FACULTAD QUE INDICA </div></div>", "i": 6024021}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Mediante Resoluci&#xF3;n N&#xB0; Ex. 1.023 de fecha 28 de abril de 1995, el suscrito deleg&#xF3; en funcionarios que en la Resoluci&#xF3;n citada se establecen la facultad de autorizar las disminuciones de capital solicitadas por las sociedades, conforme a lo prescrito en el art&#xED;culo N&#xB0; 69 inciso final del C&#xF3;digo Tributario, de acuerdo a Resoluci&#xF3;n Ex. N&#xB0; 394 de fecha 23 de enero de 1995 del Director del Servicio, que autoriza dicha delegaci&#xF3;n.- </div></div>", "i": 6024022}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Jorge Villablanca Echegoyen, Director Regional. </div></div>", "i": 6024023}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1023", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1023"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DELEGA EN FUNCIONARIOS SEÑALADOS, FACULTAD QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DELEGACION", "FACULTAD", "DIRECTOR REGIONAL", "SEXTA REGION", "SERVICIO IMPUESTOS INTERNOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-04-28", "doble_articulado": false, "id_norma": "39461", "numero_fuente": "35176", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-05-25", "vigencias": [{"desde": "1995-05-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-05-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-05-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes":