{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292609}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 462, de 15 de marzo de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a RICO FOOD S.A.,</div><div class=\"p\">para iniciar actividades pesqueras de transformaci&#xF3;n, en</div><div class=\"p\">orden a instalar y operar una planta ubicada en Parque</div><div class=\"p\">Industrial Coronel, Manzana 24, Coronel, donde podr&#xE1;</div><div class=\"p\">procesar en la l&#xED;nea de elaboraci&#xF3;n de Deshidratado</div><div class=\"p\">artificial, los siguientes recursos: Cochayuyo, Chicorea de mar, Luga-Luga, Pelillo.</div><div class=\"p\">&nbsp; &nbsp; La presente autorizaci&#xF3;n es sin perjuicio de las que corresponda conferir a otras autoridades, de acuerdo a las disposiciones legales y reglamentarias vigentes o que se establezcan.</div><br></div>", "i": 8292610}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 15 de marzo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292611}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "462", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-462"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "RICO FOOD S.A.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-03-15", "fecha_derogacion": "1996-08-09", "doble_articulado": false, "id_norma": "34882", "numero_fuente": "35451", "t