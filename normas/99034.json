{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6110785}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. No 209, de 27 de febrero de 1998, se expropiaron los lotes de terreno Nos. 5 y 11, superficies 556,6 y 485,4 m2. respectivamente, roles de aval&#xFA;o 250- 19 y 406-14, comuna Los Muermos, para la obra: Camino Ruta V-46, Sector R&#xED;o Fr&#xED;o - Los Muermos y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Rogelio Olivares Torruella y Luis Tellez Paredes, ascendente a las cantidades de $188.890.-para el lote 5 y $173.681.- para el lote 11.- </div></div>", "i": 6110786}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6110787}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "209", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-209"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "LOS MUERMOS", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-02-27", "doble_articulado": false, "id_norma": "99034", "numero_fuente": "36054", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-05-02", "vigencias": [{"desde": "1998-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1998-05-13", "fecha_version": "1998-05-02", "fecha_actual