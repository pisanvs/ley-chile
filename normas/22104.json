{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; IGLESIA EPISCOPAL ANGLICANA DE VALPARAISO Lei n&#xFA;m. 250.-Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947288}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza a la corporacion denominada &quot;Iglesia Episcopal Anglicana de Valparaiso&quot; para que, en conformidad a lo dispuesto en el art. 556 del C&#xF3;digo Civil, pueda conservar por treinta a&#xF1;os la propiedad del inmueble que actualmente posee en el cerro de la Concepcion de esa ciudad.</div><br><br></div>", "i": 5947289}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 21 de Enero de 1895.-JORJE MONTT.-O. Renjifo.</div><br></div>", "i": 5947290}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "250", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-250"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "IGLESIA EPISCOPAL ANGLICANA DE VALPARAISO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["IGLESIA EPISCOPAL ANGLICANA DE VALPARAISO", "INMUEBLE", "POSESION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-01-21", "doble_articulado": false, "id_norma": "22104", "numero_fuente": "5019", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-01-21", "vigencias": [{"desde": "1895-01-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"