{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.453, DE 1988 </div></div>", "i": 7244493}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.453 de fecha 03 de Junio de 1988, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se aprobaron las adecuaciones introducidas a las carreras de Contabilidad, Programaci&#xF3;n Computacional y Secretariado Ejecutivo con menci&#xF3;n en Computaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica CEDECOM de Quillota las que podran aplicarse a contar del primer semestre acad&#xE9;mico 1988.</div><br></div>", "i": 7244494}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7244495}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1453", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1453"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N° 1.453, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-06-03", "doble_articulado": false, "id_norma": "130427", "numero_fuente": "33126", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-07-21", "vigencias": [{"desde": "1988-07-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-07-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-07-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-01-21", "fecha_version": "1