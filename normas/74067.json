{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8304384}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por Resoluci&#xF3;n N&#xBA; 858, de 23 de junio de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 1 de la Resoluci&#xF3;n N&#xBA; 925 de 1990, que fij&#xF3; las caracter&#xED;sticas n&#xE1;uticas de la nave &quot;Albimer&quot;, autorizada por Resoluci&#xF3;n N&#xBA; 813 de 1988, ambas de esta Subsecretar&#xED;a, a PESQUERA AURO SOCIEDAD ANONIMA, en el sentido de se&#xF1;alar que la capacidad de bodega de dicha nave es de 717,80 m3. </div></div>", "i": 8304385}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de junio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8304386}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "858", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-858"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "PESQUERA AURO SOCIEDAD ANONIMA", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-06-23", "fecha_derogacion": "2001-12-27", "doble_articulado": false, "id_norma": "74067", "numero_fuente": "35807", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-07-04", "vigencias": [{"desde": "2001-12-27", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1997-07-04", "hasta": "2001-12-26", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2