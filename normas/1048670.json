{"html": [{"t": "<div><br><div class=\"p\">MODIFICA PLAZO DE PILOTO ESTABLECIDO EN RESOLUCI&#xD3;N N&#xBA; 89 EXENTA, DE 2012</div><br></div>", "i": 9331829}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 13, de 31 de enero de 2013, que se&#xF1;ala:</div><br><div class=\"p\">&nbsp; &nbsp;  Modifica plazo de piloto establecido en la <a href=\"https://www.leychile.cl/Navegar?idNorma=1043096&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n Ex. SII N&#xBA; 89, de 16 de agosto de 2012</a>, que autoriza excepcionalmente reemplazo de boleta de ventas y servicios por el comprobante emitido por la empresa Transbank S.A.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de enero de 2013.</div><br></div>", "i": 9331830}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "13 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-13 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA PLAZO DE PILOTO ESTABLECIDO EN RESOLUCIÓN Nº 89 EXENTA, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN."], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-01-31", "doble_articulado": false, "id_norma": "1048670", "numero_fuente": "40478", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-02-06", "vigencias": [{"desde": "2013-02-06", "hasta": "", "tipo_version": "3",