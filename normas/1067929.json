{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9514061}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.336, de 8 de septiembre de 2014, de esta Subsecretar&#xED;a, ampl&#xED;ese por doce meses, a contar del 10 de agosto de 2014, el plazo otorgado en el numeral 7&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=266011&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.940 de 2007</a>, a Pesquera El Golfo S.A. hoy BLUMAR S.A, para continuar desarrollando las actividades pesqueras extractivas con la nave en construcci&#xF3;n &quot;BEC2940-2007&quot;, con excepci&#xF3;n de aquellas especies cuya caducidad haya sido declarada mediante resoluci&#xF3;n, en virtud de haberse acreditado una circunstancia de fuerza mayor.</div></div>", "i": 9514062}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de septiembre de 2014.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.&nbsp; &nbsp; &nbsp; </div></div>", "i": 9514063}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2336 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2336 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2014-09-08", "fecha_derogacion": "2017-11-29", "doble_articulado": false, "id_norma": "1067929", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2014-10-07", "vigencias": [{"desde": "2017-11-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2014-10