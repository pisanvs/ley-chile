{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 242.- Santiago, 5 de febrero de 1925.-</div><div class=\"p\">&nbsp; &nbsp; La Junta de Gobierno, de acuerdo con el Consejo de Secretarios de Estado, dicta el siguiente</div><div class=\"p\">&nbsp; &nbsp; DECRETO-LEI:</div><br></div>", "i": 5872214}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Agr&#xE9;guense los siguientes &#xED;tem a la Lei de Presupuestos del Ministerio de Guerra, correspondiente al a&#xF1;o 1925:</div><div class=\"p\"> Partida 1.a, &#xED;tem 28 a.- Asignacion al</div><div class=\"p\"> Sub-Secretario de Guerra______________________ $&nbsp; 6.000</div><div class=\"p\"> Partida 3.a, &#xED;tem 82 a.- Para gastos de</div><div class=\"p\"> instalacion de las nuevas unidades del</div><div class=\"p\"> Ej&#xE9;rcito______________________________________ $ 44,000</div><div class=\"p\">&nbsp; &nbsp; Ded&#xFA;zcase el total de cincuenta mil pesos ($ 50,000) del &#xED;tem 82 del mismo presupuesto.</div><br></div>", "i": 5872215}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese razon, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Boletin de las Leyes y Decretos del Gobierno.- Emilio Bello C.- Pedro P. Dartnell E.- C. A. Ward.- C. Ib&#xE1;&#xF1;ez. </div></div>", "i": 5872216}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "242", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-242"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GASTOS NACION", "A O", "1925", "MODIFICACION", "MINISTERIO GUERRA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1925-02-05", "doble_articulado": false, "id_norma": "5898", "numero_