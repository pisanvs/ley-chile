{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 179&nbsp; EXENTO, DE 1999</div><br><br></div>", "i": 6191484}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 179 de fecha 8 de julio de 1999 del Ministerio de Educaci&#xF3;n, se aprobaron las adecuaciones al plan y programas de estudios de la carrera de Asistente Judicial del Centro de Formaci&#xF3;n T&#xE9;cnica Centro Interamericano de Educaci&#xF3;n y Cultura Cidec, modific&#xE1;ndose en consecuencia, el decreto exento N&#xBA; 420 del 28 de diciembre de 1990, en el sentido de incorporar dichas adecuaciones.</div><div class=\"p\">&nbsp; &nbsp;  Las adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1999, en las sedes que ya contaban con su autorizaci&#xF3;n.- </div></div>", "i": 6191485}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6191486}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "179 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-179 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 179 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-07-08", "doble_articulado": false, "id_norma": "143490", "numero_fuente": "36467", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-17", "vigencias": [{"desde": "1999-09-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-09-17", "fin_vigencia": "", "tipo_version