{"html": [{"t": "<div><div class=\"p\">MODIFICA EXTRACTO DE RESOLUCION QUE INDICA </div></div>", "i": 8325310}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 1.095, de 21 de Agosto de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el extracto de la Resoluci&#xF3;n No. 596, de 1989 de esta Subsecretar&#xED;a, que autoriz&#xF3; a N&#xFA;&#xF1;ez Hermanos para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a se&#xF1;alar que el RUT de la Sociedad autorizada es el No. 85.820.100-4.</div><br></div>", "i": 8325311}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 21 de Agosto de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8325312}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1095", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1095"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA EXTRACTO DE RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-08-21", "doble_articulado": false, "id_norma": "94761", "numero_fuente": "33458", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-08-26", "vigencias": [{"desde": "1989-08-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-08-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-08-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JCT