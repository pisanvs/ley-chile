{"html": [{"t": "<div><div class=\"p\">REGULA SUBASTA ELECTR&#xD3;NICA DEL SERVICIO NACIONAL DE ADUANAS</div></div>", "i": 10227412}, {"t": "<div><div class=\"p\">&nbsp;  </div><div class=\"p\">&nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 1.170, de 10 de mayo de 2021, del Director Nacional de Aduanas, se regula la Subasta Electr&#xF3;nica del Servicio Nacional de Aduanas, en aplicaci&#xF3;n de lo dispuesto en el <a href=\"https://www.leychile.cl/Navegar?idNorma=238919&amp;idParte=8666235&amp;idVersion=\">art&#xED;culo 137</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=238919&amp;idParte=&amp;idVersion=\">Ordenanza de Aduanas</a>, sustituyendo la <a href=\"https://www.leychile.cl/Navegar?idNorma=1153086&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 3.361, del 19 de noviembre de 2020</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><br></div>", "i": 10227413}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de mayo de 2021.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><div class=\"p\"> </div><br></div>", "i": 10227414}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1170 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1170 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "REGULA SUBASTA ELECTRÓNICA DEL SERVICIO NACIONAL DE ADUANAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1944314", "EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promul