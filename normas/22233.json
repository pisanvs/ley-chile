{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplementos Lei n&#xFA;m. 384.- Santiago, a 14 de Setiembre de 1896.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional he tenido a bien aprobar el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947792}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de cuarenta mil pesos al &#xED;tem 1.&#xB0; de la partida 38, i de cincuenta mil pesos a la partida 42 del presupuesto de Guerra.</div><br><br></div>", "i": 5947793}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Luis Barros Borgo&#xF1;o.</div><br></div>", "i": 5947794}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "384", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-384"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "Suplementos", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1896", "MODIFICACION", "MINISTERIO", "GUERRA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-09-14", "doble_articulado": false, "id_norma": "22233", "numero_fuente": "5507", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1896-09-15", "vigencias": [{"desde": "1896-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1896-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1896-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM"