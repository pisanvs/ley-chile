{"html": [{"t": "<div><div class=\"p\">CAMBIA NOMBRE DE CALLE LA CARIDAD</div><br><br></div>", "i": 8924765}, {"t": "<div><div class=\"p\">Se pone en conocimiento de la Comunidad que por Decreto Alc. Secc. 1&#xAA; No. 576, de Abril de 1991, se ha ordenado el cambio de nombre de la calle La Caridad por el de &quot;Padre Dami&#xE1;n de Veuster&quot;. Este cambio de nombre de la calle indicada rige a contar de la fecha de esta publicaci&#xF3;n.-</div><br></div>", "i": 8924766}, {"t": "<div><div class=\"p\">Mar&#xED;a Cecilia Valderas Chamorro, Alcaldesa Subrogante. </div></div>", "i": 8924767}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "576", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-576"}], "organismos": ["MUNICIPALIDAD DE LAS CONDES"], "titulo_norma": "CAMBIA NOMBRE DE CALLE LA CARIDAD", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "87557", "numero_fuente": "33948", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-20", "vigencias": [{"desde": "1991-04-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-04-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-04-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1998-02-02", "fecha_version": "1991-04-20", "fecha_actualizacion_texto": "1991-04-20", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8924765}, {"n": "Artículo", "i": 8924766, "t": 6}, {"n": "Promulgación", "i": 8924767}]}