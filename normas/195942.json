{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6374089}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.272, de 31 de diciembre de 2001, se expropi&#xF3; el lote de terreno N&#xBA;95-D, superficie 8.523 m2., rol de aval&#xFA;o 1437-14, comuna de Llanquihue, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo R&#xED;o Bueno Puerto Montt. Sector Llanquihue Norte Km. 997,300 a Km. 998,00, se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietaria Rejina Sof&#xED;a Luisa Yunge Schroder, ascendente a la cantidad de $24.078.090.-</div><br></div>", "i": 6374090}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6374091}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2272", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2272"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-31", "doble_articulado": false, "id_norma": "195942", "numero_fuente": "37211", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-03-15", "vigencias": [{"desde": "2002-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2002-03-25", "fecha_version": "2002-03-15", "fecha_actualizacion_texto": "2002-03-15", "tipo_tratado": ""}, "alertas": [], "alerta_g