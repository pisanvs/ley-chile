{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 120 EXENTO, DE 1995 </div></div>", "i": 7160641}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 120 de 13 de Febrero de 1995, se declara v&#xE1;lida la aplicaci&#xF3;n de la asignatura de Alem&#xE1;n, durante los a&#xF1;os escolares 1984 y 1985 en el Liceo Industrial A N&#xB0; 60 de &#xD1;u&#xF1;oa, Regi&#xF3;n Metropolitana, impartida en reemplazo de la asignatura de Ingl&#xE9;s seg&#xFA;n planes de estudio para la ense&#xF1;anza industrial diurna aprobados por Decreto Supremo de Educaci&#xF3;n N&#xB0; 973, de 19 de Mayo de 1992.</div><br></div>", "i": 7160642}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 16 de Febrero de 1995.- Marcia Scantlebury Elizalde, Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 7160643}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "120 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-120 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 120 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LICEO INDUSTRIAL A N 60", "ÑUÑOA", "REGION METROPOLITANA", "PLANES ESTUDIOS", "ALEMAN"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-02-13", "doble_articulado": false, "id_norma": "20272", "numero_fuente": "35101", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-02-23", "vigencias": [{"desde": "1995-02-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-02-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-02-23", "fin_vigencia": "", "tipo_