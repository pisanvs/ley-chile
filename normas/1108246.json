{"html": [{"t": "<div><div class=\"p\">EXTRACTO RESOLUCI&#xD3;N N&#xB0; 4.640 EXENTA, DE 10 DE AGOSTO DE 2017</div></div>", "i": 9835422}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=1088197&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 8.079, de 2015</a>, del Ministerio de Educaci&#xF3;n que aprob&#xF3; plan y programas de estudio al Colegio The Mackay School, RBD 1788-4, comuna de Vi&#xF1;a del Mar, provincia y Regi&#xF3;n de Valpara&#xED;so, en el sentido de sustituir su plan de estudio de 1&#xBA; y 2&#xBA; a&#xF1;o de educaci&#xF3;n media por los que se indican en la presente resoluci&#xF3;n exenta y aprobar los programas especiales de estudio de las asignaturas que indica.</div></div>", "i": 9835423}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 21 de agosto de 2017.- Valentina Karina Quiroga Canahuate, Subsecretaria de Educaci&#xF3;n.</div></div>", "i": 9835424}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4640 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4640 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO RESOLUCIÓN N° 4.640 EXENTA, DE 10 DE AGOSTO DE 2017", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1275161; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-08-10", "doble_articulado": false, "id_norma": "1108246", "numero_fuente": "41866", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-09-23", "vigencias": [{"desde": "2017-09-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "v