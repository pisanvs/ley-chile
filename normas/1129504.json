{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10004863}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 625, de 21 de febrero de 2019, de este Servicio, se establece formato y contenidos m&#xED;nimos de los protocolos de manipulaci&#xF3;n de captura, descarte y pesca incidental en naves pesqueras industriales que indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n indicada, se encuentra publicado con esta fecha en el sitio de dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y de la Subsecretar&#xED;a de Pesca y Acuicultura.</div></div>", "i": 10004864}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En Valpara&#xED;so, a 21 de febrero de 2019.- Alicia Gallardo Lagno, Directora Nacional, Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 10004865}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "625 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-625 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1556480", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-02-21", "doble_articulado": false, "id_norma": "1129504", "numero_fuente": "42298", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-03-07", "vigencias": [{"desde": "2019-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-03-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"ini