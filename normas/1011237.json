{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8886044}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 769, de 16 de febrero de 2010, de esta Subsecretar&#xED;a, ac&#xF3;gese los descargos formulados y ampl&#xED;ese hasta el 31 de diciembre de 2010, el plazo otorgado por el numeral 5.- inciso 2&#xBA; de la resoluci&#xF3;n exenta N&#xBA; 287 de 1994 de esta Subsecretar&#xED;a, a PESQUERA B&#xCD;O B&#xCD;O S.A. para reiniciar actividades pesqueras extractivas con la nave &quot;Biomar III&quot; en el &#xE1;rea mar&#xED;tima comprendida entre la IV Regi&#xF3;n y el paralelo 41&#xB0;28,6&apos; L.S., sobre el recurso Besugo, con red de arrastre.</div><br></div>", "i": 8886045}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de febrero de 2010.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 8886046}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "769 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-769 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2010-02-16", "fecha_derogacion": "2014-01-04", "doble_articulado": false, "id_norma": "1011237", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2010-02-23", "vigencias": [{"desde": "2014-01-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2010-02-23", "hasta": "2014-01-03", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2014-01-04", "fin_vige