{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8309251}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 437 de 14 de Mayo de 1992, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por un a&#xF1;o a contar del 11 de diciembre de 1991, el plazo otorgado a SOCIEDAD DE ARMADORES ALFA LIMITADA, R.U.T No. 79.518.660-3, domiciliada en calle Moneda No. 920, oficina 201, Santiago, para reiniciar las actividades pesqueras que tiene autorizadas por resoluci&#xF3;n No. 16, de 1985, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la existencia de una fuerza mayor. </div></div>", "i": 8309252}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 14 de Mayo de 1992.- Jorge Marshall Rivera, Subsecretario de Pesca subrogante.</div><br></div>", "i": 8309253}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "437", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-437"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1992-05-14", "fecha_derogacion": "1993-03-17", "doble_articulado": false, "id_norma": "78732", "numero_fuente": "34283", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1992-06-04", "vigencias": [{"desde": "1993-03-17", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1992-06-04", "hasta": "1993-03-16", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1993-03-17", "fin_vigencia": ""}, "vigencias_version_no