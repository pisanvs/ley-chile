{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PENSION Lei n&#xFA;m. 304.-Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947463}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese una pension de mil pesos anuales a la viuda e hijos del ex-profesor contratado de la Universidad don Juan Schulze, de la cual gozar&#xE1;n en conformidad a la lei de montep&#xED;o militar i que percibir&#xE1;n aunque residan en el estranjero.</div><br><br></div>", "i": 5947464}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 21 de Setiembre de 1895.- JORJE MONTT.-</div><div class=\"p\">M. S&#xE1;nchez Fontecilla.</div><br></div>", "i": 5947465}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "304", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-304"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUAN SCHULZE", "MONTEPIO MILITAR", "BENEFICIO", "OTORGA", "VIUDA", "HIJOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-09-21", "doble_articulado": false, "id_norma": "22155", "numero_fuente": "5216", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-09-24", "vigencias": [{"desde": "1895-09-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-09-24", "fin_vigencia": ""}, "vigencias_version_norm