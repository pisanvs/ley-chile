{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 135 EXENTO, DE 1995 </div></div>", "i": 5941712}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 135 de 24 de Febrero de 1995, se aprobaron los Planes y Programas Especiales de Estudio para el Colegio &quot;International Country School&quot; de la comuna de Puente Alto, para la Educaci&#xF3;n B&#xE1;sica y la Ense&#xF1;anza Media Human&#xED;stico-Cient&#xED;fica, los que ser&#xE1;n aplicados a partir del a&#xF1;o escolar 1995.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban Programas de Estudio para la asignatura de Computaci&#xF3;n.</div><br></div>", "i": 5941713}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 28 de Febrero de 1995.- Juan Eduardo Garc&#xED;a-Huidobro S., Subsecretario de Educaci&#xF3;n (S). </div></div>", "i": 5941714}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "135", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-135"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 135 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "COLEGIO INTERNATIONAL COUNTRY SCHOOL", "PUENTE ALTO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-02-24", "doble_articulado": false, "id_norma": "20351", "numero_fuente": "35123", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-03-21", "vigencias": [{"desde": "1995-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-03-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-03-21", "fin_vigenci