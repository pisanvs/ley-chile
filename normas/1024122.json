{"html": [{"t": "<div><br><div class=\"p\">NOTIFICA POR AVISO A PERSONA QUE SE&#xD1;ALA</div></div>", "i": 9129491}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n O N&#xBA; 0542, de 18 de marzo de 2011, el Servicio Electoral dispuso la notificaci&#xF3;n por aviso a la persona individualizada a continuaci&#xF3;n, respecto del acto administrativo que se indica, relacionado con la ley N&#xBA; 19.884, sobre Transparencia, L&#xED;mite y Control del Gasto Electoral, y la ley N&#xBA; 20.285, sobre Acceso a la Informaci&#xF3;n P&#xFA;blica.</div><br><div class=\"p\">&nbsp;  ADMINISTRADOR ELECTORAL&nbsp;  DESTINATARIO&nbsp;  OBSERVACIONES</div><br><div class=\"p\">&nbsp;  Gabriela del Carmen&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; C&#xFA;mplase de&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp;  Guti&#xE9;rrez Canales&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 13/01/2011</div><br></div>", "i": 9129492}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div></div>", "i": 9129493}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "542", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-542"}, {"tipo": "3", "numero": "O-542", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-O-542"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "NOTIFICA POR AVISO A PERSONA QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-03-18", "doble_articulado": false, "id_norma": "1024122", "numero_fuente": "39925", "tipo_versio