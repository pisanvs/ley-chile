{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6054075}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xB0;824, de 29 de agosto de 1997, se expropiaron los lotes de terreno N&#xB0;s. 1, 2, 32 y 33, superficies 66, 194, 1.532,90 y 1.019 m2, respectivamente, roles de aval&#xFA;o 802-35, 70-22 y S/R, comunas de Traigu&#xE9;n y Galvarino, para la obra Camino Pavimentaci&#xF3;n Asf&#xE1;ltica, Sector Camino Traigu&#xE9;n-Galvarino y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Alejandro Schalchli Charles, Norton Lemp Novoa y Ernesto Caro Castillo, ascendente a las cantidades de $390.462.- para el lote 1 y 2,</div><div class=\"p\">$1.654.070.- para el lote 32 y $1.121.861.- para el lote 33.</div><br></div>", "i": 6054076}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6054077}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "824", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-824"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "TRAIGUEN", "GALVARINO", "NOVENA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-08-29", "doble_articulado": false, "id_norma": "79134", "numero_fuente": "35906", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-11-03", "vigencias": [{"desde": "1997-11-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-11-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-11-03", "fin_vigencia": "", "tipo