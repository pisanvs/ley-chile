{"html": [{"t": "<div><div class=\"p\">ACEPTA RENUNCIA DE DIRECTOR EJECUTIVO DEL PROGRAMA CHILE BARRIO</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 5 de marzo de 2002.- Hoy se decret&#xF3; lo que sigue:</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 76.- Visto: Los decretos supremos N&#xBA; 20 y N&#xBA; 34, ambos del Ministerio de Vivienda y Urbanismo, de 1998,</div><br><div class=\"p\">&nbsp; &nbsp;  D e c r e t o:</div><br></div>", "i": 6375298}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ac&#xE9;ptase a contar del d&#xED;a 1 de enero de 2002, la renuncia al rol de Director Ejecutivo del Programa Chile Barrio presentada por el se&#xF1;or Patricio Iv&#xE1;n Vallesp&#xED;n L&#xF3;pez.</div><br></div>", "i": 6375299}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, t&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- RICARDO LAGOS ESCOBAR, Presidente de la Rep&#xFA;blica.- Jaime Ravinet de la Fuente, Ministro de Vivienda y Urbanismo.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo para su conocimiento.- Sonia Tschorne Berestesky, Subsecretaria de Vivienda y Urbanismo.</div><br></div>", "i": 6375300}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "76", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-76"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "ACEPTA RENUNCIA DE DIRECTOR EJECUTIVO DEL PROGRAMA CHILE BARRIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PROGRAMA CHILE BARIO", "DIRECTOR EJECUTIVO", "PATRICIO IVAN VALLESPIN LOPEZ", "RENUNCIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-05", "doble_articulado": false, "id_norma": "196319", "numero_fuente": "37225", "tipo_version": "3", "tipo_v