{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 7374764}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 0,46% anual durante el mes de junio de 2008.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad con lo dispuesto en el N&#xBA; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de junio de 2008, fue de 0,42% anual. </div></div>", "i": 7374765}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de julio de 2008.- Juan Esteban Laval Zald&#xED;var, Ministro de Fe (S).</div><br></div>", "i": 7374766}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-07-04", "doble_articulado": false, "id_norma": "273714", "numero_fuente": "39106", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-07-07", "vigencias": [{"desde": "2008-07-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-07-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-07-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV"