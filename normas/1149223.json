{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10156791}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 2.681, de fecha 31.08.2020, del Director Nacional de Aduanas, fueron aprobadas las instrucciones para el caso de importaciones respecto de las cuales se impetre el beneficio previsto en el art&#xED;culo 7&#xB0; de la Ley de Donaciones para las Micro, Peque&#xF1;as y Medianas Empresas (Mipymes), las que regir&#xE1;n mientras se encuentre vigente la citada disposici&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10156792}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de agosto de 2020.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><div class=\"p\"> </div><br></div>", "i": 10156793}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2681 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2681 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1811924", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-08-31", "doble_articulado": false, "id_norma": "1149223", "numero_fuente": "42750", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-09-07", "vigencias": [{"desde": "2020-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia