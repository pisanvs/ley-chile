{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8344365}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;652, de 22 de abril de 1999, de esta Subsecretar&#xED;a, modif&#xED;case la resoluci&#xF3;n N&#xBA;1.902 de 1998, que fij&#xF3; la n&#xF3;mina&nbsp; de armadores y embarcaciones autorizados para operar en la unidad de pesquer&#xED;a de Merluza com&#xFA;n, declarada en estado de plena explotaci&#xF3;n y sometida a dicho r&#xE9;gimen de administraci&#xF3;n, en el litoral de la IV Regi&#xF3;n al paralelo 41&#xB0;28,6&apos; L.S., en la letra e) del art&#xED;culo 1&#xBA; del D.S. N&#xBA;354 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, en el &#xE1;rea se&#xF1;alada en su respectiva autorizaci&#xF3;n, en el sentido de incorporar en su&nbsp; numeral 1&#xBA; lo siguiente: &apos;&apos;Gast&#xF3;n Edmundo Mendoza G&#xF3;mez: Ikela&apos;&apos;. </div></div>", "i": 8344366}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de abril de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8344367}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "652", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-652"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-04-22", "fecha_derogacion": "1999-07-30", "doble_articulado": false, "id_norma": "135693", "numero_fuente": "36351", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-04-29", "vigencias": [{"desde": "1999-07-30