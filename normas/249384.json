{"html": [{"t": "<div><div class=\"p\">ACEPTA RENUNCIA VOLUNTARIA</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 270.- Santiago,15 de marzo de 2006.- Visto: La carta renuncia y lo establecido en el art&#xED;culo 146 letra a) de la ley N&#xBA; 18.834 y sus modificaciones, </div><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 6569058}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ac&#xE9;ptase, a contar del 20 de marzo de 2006, la renuncia voluntaria al cargo de Jefe de Divisi&#xF3;n, grado 2 E.U.S., en el Ministerio Secretar&#xED;a General de Gobierno, del funcionario don Fuad Eduardo Chahin Valenzuela, RUT. 10.526.592-1.</div><br></div>", "i": 6569059}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- Ricardo Lagos Weber, Ministro Secretario General de Gobierno.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Carlos Maldonado Curti, Subsecretario General de Gobierno.</div><br></div>", "i": 6569060}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "270", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-270"}], "organismos": ["MINISTERIO SECRETARÍA GENERAL DE GOBIERNO"], "titulo_norma": "ACEPTA RENUNCIA VOLUNTARIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MINISTERIO SECRETARIA GENERAL DE GOBIERNO", "JEFE DE DIVISION", "FUAD EDUARDO CHAHIN VALENZUELA", "RENUNCIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-03-15", "doble_articulado": false, "id_norma": "249384", "numero_fuente": "38455", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-05-05", "vigencias": [{"desde": "2006-05-05", "hasta": "", "tipo_vers