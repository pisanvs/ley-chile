{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N EXENTA N&#xBA; 8.378, DE 2008 </div></div>", "i": 6666576}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 8.378, de 25 de noviembre del 2008, se han aprobado planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media al Colegio Instituci&#xF3;n Teresiana, comuna de Las Condes, de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio de los Subsectores del Plan de Formaci&#xF3;n General y del Plan de Formaci&#xF3;n Diferenciada, que se indican en la presente resoluci&#xF3;n.</div><br></div>", "i": 6666577}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 5 de diciembre de 2008.- Jaime Veas S&#xE1;nchez, Jefe Divisi&#xF3;n de Educaci&#xF3;n General (S). </div></div>", "i": 6666578}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8378 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8378 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN EXENTA Nº 8.378, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-11-25", "doble_articulado": false, "id_norma": "283247", "numero_fuente": "39235", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-12-12", "vigencias": [{"desde": "2008-12-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-12-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-12-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes":