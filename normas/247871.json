{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6563542}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 806, de 7 de marzo de</div><div class=\"p\">2006, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de</div><div class=\"p\">la resoluci&#xF3;n N&#xB0;20 de 2002, de esta Subsecretar&#xED;a, que</div><div class=\"p\">autoriz&#xF3; a PESQUERA QUINTERO S.A., para ampliar</div><div class=\"p\">actividades pesqueras con la nave &quot;Crusoe I&quot;, en el &#xE1;rea</div><div class=\"p\">mar&#xED;tima comprendida entre I y III Regiones, sobre el</div><div class=\"p\">recurso Reineta, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado en informe t&#xE9;cnico citado en Visto.</div><br></div>", "i": 6563543}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de marzo de 2006.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6563544}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "806 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-806 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-03-07", "doble_articulado": false, "id_norma": "247871", "numero_fuente": "38412", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-13", "vigencias": [{"desde": "2006-03-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-03-13", "fin_vigencia"