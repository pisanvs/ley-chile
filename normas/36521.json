{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8296422}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.221, de 7 de Septiembre de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 791, de 1995, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don MARIO TADEO FIGUEROA INOSTROZA, R.U.T. N&#xB0; 5.505.107-0, para desarrollar actividades pesqueras extractivas con la nave &quot;Pac&#xED;fico I&quot;, por no haber sido publicada de conformidad con el art&#xED;culo 15 del D.S. N&#xB0; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8296423}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 7 de Septiembre de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8296424}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1221", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1221"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "AUTORIZACION", "PESCA", "MARIO TADEO", "FIGUEROA INOSTROZA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-09-07", "doble_articulado": false, "id_norma": "36521", "numero_fuente": "35271", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-09-20", "vigencias": [{"desde": "1995-09-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-09-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig