{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AGREGA INCISO AL ARTICULO 25 DEL CODIGO DEL TRABAJO Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5966381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Agr&#xE9;gase al art&#xED;culo 25 del C&#xF3;digo del Trabajo el siguiente inciso:</div><div class=\"p\">&nbsp; &nbsp; &quot;Lo dispuesto en los dos incisos anteriores no se aplicar&#xE1; al personal de cocinas que trabaja en los hoteles, restaurantes y clubes&quot;.</div><div class=\"p\">&nbsp; &nbsp; Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial&quot;.</div><br></div>", "i": 5966382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a seis de Octubre de mil novecientos cuarenta y ocho.- GABRIEL GONZALEZ VIDELA.- Ruperto Puga.</div><br></div>", "i": 5966383}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "9128", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-9128"}], "organismos": ["MINISTERIO DEL TRABAJO"], "titulo_norma": "AGREGA INCISO AL ARTICULO 25 DEL CODIGO DEL TRABAJO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "CODIGO TRABAJO", "PERSONAL COCINA", "HOTEL", "RESTAURANTE", "CLUB"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1948-10-06", "doble_articulado": false, "id_norma": "25931", "numero_fuente": "21197", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1948-11-08", "vigencias"