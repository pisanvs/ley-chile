{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 80 EXENTO, DE 2002 </div></div>", "i": 6374506}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 80, de fecha 28 de enero de 2002, se declara aprobada a la Universidad Aut&#xF3;noma del Sur la siguiente carrera conducente al t&#xED;tulo profesional que se indica:</div><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Ingenier&#xED;a de Ejecuci&#xF3;n en Gesti&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Industrial</div><div class=\"p\">T&#xED;tulo Profesional : Ingeniero de Ejecuci&#xF3;n en Gesti&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Industrial.</div><br><div class=\"p\">&nbsp; &nbsp;  Dicha carrera podr&#xE1; ser impartida en jornada diurna en su Sede de la ciudad de Temuco, a partir del primer semestre del a&#xF1;o 2002, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6374507}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de marzo de 2002.- Patricio Vilaplana Barberis, Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 6374508}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "80 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-80 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 80 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-01-28", "doble_articulado": false, "id_norma": "196074", "numero_fuente": "37221", "tipo