{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6068103}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n Exenta No. 134 de 20 de febrero de 1990, se adjudica a Avaria y Compa&#xF1;&#xED;a Limitada, la concesi&#xF3;n para operar, por un plazo de cinco a&#xF1;os a contar del 05 de marzo de 1990, un establecimiento ubicado en calle Las Tranqueras 952, Las Condes, destinado a la Revisi&#xF3;n T&#xE9;cnica y Verificaci&#xF3;n de Emisi&#xF3;n de Contaminantes de Autom&#xF3;viles, Station Wagons, Motocicletas, Veh&#xED;culos de carga de menos de 1.750 kg. de capacidad de carga &#xFA;til y sus remolques, ubicada en la Regi&#xF3;n Metropolitana, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.- </div></div>", "i": 6068104}, {"t": "<div><div class=\"p\">Carlos Silva Echibur&#xFA;, Ministro de Transportes y Telecomunicaciones.</div><br></div>", "i": 6068105}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "134", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-134"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-02-20", "doble_articulado": false, "id_norma": "84543", "numero_fuente": "33628", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-23", "vigencias": [{"desde": "1990-03-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-03-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-03-23", "fin_vigencia": "", "tipo_version": "3"}], "eve