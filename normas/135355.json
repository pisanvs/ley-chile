{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6165170}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. No. 66, de 25 de marzo de 1988, se autorizaron los Convenios Ad-Referendum de Precio Definitivo con propietarios de los lotes 2, 3 y 4, do&#xF1;a Raquel Gonz&#xE1;lez Balmaceda y otros, Domingo Garc&#xED;a-Huidobro Gonz&#xE1;lez y otro y Juan Garc&#xED;a-Huidobro Gonz&#xE1;lez y otra, expropiados por Decreto M.O.P. No. 64 de 14 de marzo de 1985, para la ejecuci&#xF3;n de la obra Camino Nuevo Acceso al Puerto de San Antonio, sector Bajada a Barrancas, ascendente a Ias cantidades de $ 3.540.706, $ 1.382.070 y $732.627.-</div><br></div>", "i": 6165171}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6165172}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "66", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-66"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-25", "doble_articulado": false, "id_norma": "135355", "numero_fuente": "33060", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-05-02", "vigencias": [{"desde": "1988-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "FMR", "fecha_ingreso": "1999-04-23", "fecha_version": "1988-05-02", "fecha_actualizacion_te