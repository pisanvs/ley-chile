{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA;3.522 EXENTA, DE 2015, DE ESTA SUBSECRETAR&#xCD;A</div><br></div>", "i": 9712697}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.034, de 24 de junio de 2016, de esta Subsecretar&#xED;a, modif&#xED;quese el numeral 1&#xBA;.- de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1085885&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.522, de 2015</a>, en el sentido de se&#xF1;alar que la distribuci&#xF3;n de la fracci&#xF3;n artesanal de Anchoveta de la III y IV Regiones, a&#xF1;o 2016, se efectuar&#xE1; de la siguiente manera:</div><br><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/58953.jpg\"></div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><br></div>", "i": 9712698}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de junio de 2016.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div><br></div>", "i": 9712699}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2034 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2034 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº3.522 EXENTA, DE 2015, DE ESTA SUBSECRETARÍA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1038979; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-0