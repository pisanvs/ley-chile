{"html": [{"t": "<div><div class=\"p\">SOLICITA CONSTITUCION LEGAL DEL PARTIDO HUMANISTA EN VII REGION DEL MAULE </div></div>", "i": 6265664}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Gabriel Feres N. y Wilfredo Alfsen O., Presidente y Secretario General, respectivamente, en representaci&#xF3;n del &apos;&apos;Partido Humanista&apos;&apos;, han solicitado la constituci&#xF3;n legal del partido en la VII Regi&#xF3;n del Maule, en la que se&#xF1;alan acompa&#xF1;ar 2.605 declaraciones de afiliaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17 de la ley N&#xBA;18.603, por resoluci&#xF3;n O-N&#xBA;158, de fecha 11 de abril de 2000. </div></div>", "i": 6265665}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de abril de 2000.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6265666}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "158", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-158"}, {"tipo": "3", "numero": "O-158", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-158"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCION LEGAL DEL PARTIDO HUMANISTA EN VII REGION DEL MAULE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO HUMANISTA", "CONSTITUCION LEGAL", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-11", "doble_articulado": false, "id_norma": "165769", "numero_fuente": "36641", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-15", "vigencias": [{"desde": "2000-04-15", "hasta": "", "tipo_version"