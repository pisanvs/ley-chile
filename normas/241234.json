{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6536914}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.303, de 21 de julio de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a PRO PESCA LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en camino a Yungay, Km. 3, Chill&#xE1;n Viejo, Chill&#xE1;n, VIII Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Seco Salado y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6536915}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de julio de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6536916}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2303 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2303 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-07-21", "doble_articulado": false, "id_norma": "241234", "numero_fuente": "38241", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-08-20", "vigencias": [{"desde": "2005-08-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-08-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-08-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2005-08-22", "fecha