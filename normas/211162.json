{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6426642}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.198, de 10 de junio de 2003, de esta Subsecretar&#xED;a, rectif&#xED;case el literal a) de los numerales 2&#xBA; y 3&#xBA; de la resoluci&#xF3;n N&#xBA; 975 de 2001, que autoriz&#xF3; a PESQUERA ITATA S.A. para realizar actividades pesqueras extractivas con la nave &quot;Petrohu&#xE9; I&quot;, en la forma y condiciones que la misma resoluci&#xF3;n indica, en el sentido de se&#xF1;alar que la interesada podr&#xE1; realizar actividades pesqueras con la nave individualizada precedentemente, en el &#xE1;rea mar&#xED;tima de la III y IV Regiones, sobre los recursos Anchoveta, Sardina espa&#xF1;ola, Jurel, Agujilla, Caballa y Sardina com&#xFA;n y no como all&#xED; se indica.</div><br></div>", "i": 6426643}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de junio de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6426644}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1198 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1198 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-10", "doble_articulado": false, "id_norma": "211162", "numero_fuente": "37584", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-14", "vigencias": [{"desde": "2003-06-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-06-14",