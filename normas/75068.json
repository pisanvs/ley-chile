{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8305745}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.142, de 8 de agosto de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case la Resoluci&#xF3;n N&#xBA; 901, de 1997, de esta Subsecretar&#xED;a, que fij&#xF3; la n&#xF3;mina de armadores y embarcaciones que cumplen con los requisitos legales para operar en la unidad de pesquer&#xED;a de Jurel, declarado en estado de plena explotaci&#xF3;n y sometido a dicho r&#xE9;gimen de administraci&#xF3;n, en el litoral de la I y II Regiones, en el &#xE1;rea se&#xF1;alada en sus respectivas autorizaciones, en el sentido de incorporar a la n&#xF3;mina se&#xF1;alada en el numeral 1&#xBA;, a la nave &quot;Guanaye 4&quot;, del armador industrial Pesquera Iquique-Guanaye S.A.</div><br></div>", "i": 8305746}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de agosto de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8305747}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1142", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1142"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ARMADORES INDUSTRIALES", "NOMINA", "PESCA", "JUREL", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-08-08", "fecha_derogacion": "1998-01-24", "doble_articulado": false, "id_norma": "75068", "numero_fuente": "35845", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-08-