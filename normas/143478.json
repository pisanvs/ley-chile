{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8350131}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.783, de 9 de septiembre de 1999, de esta Subsecretar&#xED;a, no ha lugar el recurso de reconsideraci&#xF3;n interpuesto por don OLEGARIO ERNESTO DELGADO DIAZ, en contra de la resoluci&#xF3;n N&#xBA; 928, de 1999, de esta Subsecretar&#xED;a, que caduc&#xF3; a la resoluci&#xF3;n N&#xBA; 1.060, de 1998, respecto de la nave &apos;&apos;Alborada&apos;&apos;, en atenci&#xF3;n a que&nbsp; no existen nuevos antecedentes que permitan reconsiderar dicha medida.</div><br></div>", "i": 8350132}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de septiembre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8350133}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1783", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1783"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-09-09", "doble_articulado": false, "id_norma": "143478", "numero_fuente": "36467", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-17", "vigencias": [{"desde": "1999-09-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-09-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-09-17", "fech