{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div></div>", "i": 9263215}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA; 40.279, de 5 de junio de 2012, se public&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1040735&amp;idParte=0&amp;idVersion=\">extracto decreto exento N&#xBA; 521</a> que &quot;ESTABLECE VEDA BIOL&#xD3;GICA PARA LOS RECURSOS ANCHOVETA Y SARDINA COM&#xDA;N EN &#xC1;REA Y PER&#xCD;ODO QUE INDICA&quot;, con el error que salva a continuaci&#xF3;n: I Cuerpo, p&#xE1;gina ocho, tercera columna: donde dice &quot; ... Por decreto exento N&#xBA; 520, de 1 de junio de 2012, ...&quot; debe decir &quot;... Por decreto exento N&#xBA; 521, de 1 de junio de 2012, ... &quot;.</div><br></div>", "i": 9263216, "v": ["RECTIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "209", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-209"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1040751", "numero_fuente": "40280", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-06", "vigencias": [{"desde": "2012-06-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-06-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-06-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "RECTIFICACION", "url_part": "rectificacion"}], "ingresado_por": "1289", "fec