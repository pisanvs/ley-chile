{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8740715}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.294, de 26 de junio de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a SANTIAGO DEL TR&#xC1;NSITO MU&#xD1;OZ HENR&#xCD;QUEZ para desarrollar actividades experimentales de cultivo con ejemplares de la especie Lisa, cuyo objetivo general consiste en desarrollar su tecnolog&#xED;a de cultivo en un sistema confinado en estanques en tierra.</div><div class=\"p\">&nbsp; &nbsp;  Las actividades experimentales se desarrollar&#xE1;n por el t&#xE9;rmino de 2 a&#xF1;os contados desde la fecha de la presente resoluci&#xF3;n, en un terreno privado de propiedad del peticionario ubicado a 4 kil&#xF3;metros del r&#xED;o Itata, VIII Regi&#xF3;n.</div></div>", "i": 8740716}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de junio de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8740717}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2294 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-2294 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-06-26", "doble_articulado": false, "id_norma": "1004146", "numero_fuente": "39410", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-07-13", "vigencias": [{"desde": "2009-07-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-07-13", "fin_vigencia": ""}