{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 11, DE 2000 </div></div>", "i": 6256729}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA; 11, de fecha 20 de enero del 2000, se aprob&#xF3; la reforma integral al estatuto de la Cooperativa de Ahorro y Cr&#xE9;dito Uni&#xF3;n y Patria Limitada, en los t&#xE9;rminos que da testimonio la escritura p&#xFA;blica suscrita con fecha 29 de diciembre de 1999, ante el Notario de Santiago don Eduardo Pinto Peralta.</div><br></div>", "i": 6256730}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Sr. Subsecretario.- Cecilia Gonz&#xE1;lez Mart&#xED;nez, Jefe Departamento de Cooperativas Subrogante, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 6256731}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "11", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-11"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 11, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-20", "doble_articulado": false, "id_norma": "162869", "numero_fuente": "36626", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-29", "vigencias": [{"desde": "2000-03-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente