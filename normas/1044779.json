{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9305863}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP Exento N&#xBA;2111 de 28 de septiembre de 2012, de conformidad a lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;2, superficie 152 m2, rol de Aval&#xFA;o N&#xBA;1150-43, comuna de Arauco, para la obra &quot;REPOSICI&#xD3;N PUENTE CONUMO Y ACCESOS EN RUTA P-24, PROVINCIA DE ARAUCO&quot;, VIII Regi&#xF3;n. La Comisi&#xF3;n de peritos, integrada por Roxana Cecilia Abarz&#xFA;a Gajardo, Consuelo Loreto Zuloaga Sanhueza y Mar&#xED;a Alejandra Guti&#xE9;rrez Flores, fij&#xF3; el valor de tasaci&#xF3;n con fecha 14 de febrero de 2012, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario don BELARMINO RA&#xDA;L RIVAS MEDINA, en la cantidad de $2.847.888.- suma que se pagar&#xE1; al contado. </div></div>", "i": 9305864}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9305865}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2111 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2111 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-09-28", "doble_articulado": false, "id_norma": "1044779", "numero_fuente": "40386", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-10-16", "vigencias": [{"desde": "2012-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-10-16", "fin_vigencia": ""}, "v