{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6036748}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 286, de 31 de marzo de 1997, se expropiaron los lotes de terreno N&#xBA;s 3, 4 y 5, superficies 836, 2.956 y 1.668, roles de aval&#xFA;os 419-96, 499-11 y 419-93, comuna de Retiro, para la obra Camino Ruta L-75, sector Cruce Long. (Parral), El Ajial, se acord&#xF3; precio de la indemnizaci&#xF3;n con sus propietarios Armando del Carmen Mu&#xF1;oz Fa&#xFA;ndez, Miguel Silvio Silva Escobar y otra y Pedro Jos&#xE9; Recabarren Alarc&#xF3;n, ascendente a las cantidades de $313.276, para el lote 3;</div><div class=\"p\">$1.104.596, para el lote 4 y $1.156,628, para el lote 5.-</div><br></div>", "i": 6036749}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6036750}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "286", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-286"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "RETIRO", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-31", "doble_articulado": false, "id_norma": "71355", "numero_fuente": "35766", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-15", "vigencias": [{"desde": "1997-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes"