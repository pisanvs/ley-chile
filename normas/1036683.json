{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA DECRETO N&#xBA; 1.251 EXENTO, DE 2011</div></div>", "i": 9229320}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;37, de 18 de enero de 2012, de este Ministerio, rectif&#xED;case el art&#xED;culo 10 del <a href=\"https://www.leychile.cl/Navegar?idNorma=1035605&amp;idParte=0&amp;idVersion=\">decreto exento N&#xBA; 1.251 de 2011, del Ministerio de Econom&#xED;a, Fomento y Turismo</a>, en el sentido de se&#xF1;alar que las cuotas globales anuales de captura de las unidades de pesquer&#xED;a de Merluza de cola de la V a la X Regiones y XI y XII Regiones, ascender&#xE1;n a 98.400 toneladas, fraccionadas de la siguiente manera:</div><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/23735.jpg\"></div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y del Servicio Nacional de Pesca.</div><br></div>", "i": 9229321, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de enero de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9229322}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "37 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-37 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "RECTIFICA DECRETO Nº 1.251 EXENTO, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-01-18", "doble_articulado": false, "id_norma": "1036683", "num