{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aprueba la Convenci&#xF3;n Postal de Encomiendas, celebrada entre Chile y los Estados Unidos, el 21 de Noviembre de 1919.</div><br><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><div class=\"ab\"><a href=\"Navegar/pdf/PDF/2350.PDF\">Descargar&nbsp; (PDF, 255 K)</a></div></div>", "i": 8801587}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Apru&#xE9;base la Convenci&#xF3;n Postal de Encomiendas celebrada entre Chile y los Estados Unidos de Am&#xE9;rica, subscrita en W&#xE1;shington el 21 de Noviembre de 1919.</div><br></div>", "i": 8801588}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintiocho de Julio de mil novecientos veintisiete.- Carlos Ib&#xE1;&#xF1;ez C.- Conrado R&#xED;os Gallardo. </div></div>", "i": 8801589}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4152", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4152"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES"], "titulo_norma": "APRUEBA LA CONVENCIÓN POSTAL DE ENCOMIENDAS, CELEBRADA ENTRE CHILE Y LOS ESTADOS UNIDOS, EL 21 DE NOVIEMBRE DE 1919.", "fuente": "", "resumenes": [], "materias": ["Convención Postal de Enmiendas"], "terminos_libres": ["ACUERDOS INTERNACIONALES", "CHILE - ESTADOS UNIDOS DE AMERICA", "CONVENCION POSTAL", "ENCOMIENDAS", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": ["Estados Unidos de América"], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1927-07-28", "doble_articulado":