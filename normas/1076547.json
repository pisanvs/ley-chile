{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N EXENTA N&#xBA;3.639, DE 2014</div></div>", "i": 9591107}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;983, de 13 de abril de 2015, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1073319&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA;3.639 de 2014</a> que estableci&#xF3; la distribuci&#xF3;n de la fracci&#xF3;n artesanal de Merluza del sur en la X Regi&#xF3;n de Los Lagos, correspondiente al &#xC1;rea Calbuco B, sometida al R&#xE9;gimen Artesanal de Extracci&#xF3;n, a&#xF1;o 2015, en sentido de adelantar 50 toneladas de la cuota autorizada para el periodo septiembre-diciembre, al periodo enero- julio.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n extractada se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de esta Subsecretar&#xED;a y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9591108, "v": ["MODIFICACION"]}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de abril de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9591109}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "983 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-983 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN EXENTA Nº3.639, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-04-13", 