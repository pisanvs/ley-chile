{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6428953}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.186 de 6 de junio de 2003 de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA LANDES S.A., para realizar actividades extractivas en aguas internacionales con la nave &quot;Bonito&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><br><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  2374-Valpara&#xED;so</div><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; CB-2102</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 33,99 m</div><div class=\"p\">T.R.G. (Internacional)&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  223,90</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  265,80 m3</div><div class=\"p\">Potencia motor principal&nbsp; &nbsp; &nbsp;  1060,00 Hp</div><div class=\"p\">Potencia motor auxiliar&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 78,00 Hp</div><br></div>", "i": 6428954}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de junio de 2003.- Edith Saa Collantes, Subsecretaria de Pesca (S).</div><br></div>", "i": 6428955}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1186", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1186"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-06-06", "fecha_derogacion": "2004-12-02", "doble_art