{"html": [{"t": "<div><div class=\"p\">APRUEBA ORDENANZA SOBRE SUBVENCIONES MUNICIPALES </div></div>", "i": 6452439}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Municipalidad de Mulch&#xE9;n pone en conocimiento de la comunidad que por decreto administrativo N&#xBA; 01896, de fecha 18 de noviembre de 2003, fue aprobada la Ordenanza que norma sobre el procedimiento a observar para el otorgamiento de las Subvenciones Municipales.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de la citada Ordenanza se informa que est&#xE1; a disposici&#xF3;n de quien lo solicite en la Direcci&#xF3;n Secretar&#xED;a Comunal de Planificaci&#xF3;n, cuyas oficinas se ubican en calle An&#xED;bal Pinto N&#xBA; 476.- </div></div>", "i": 6452440}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  H&#xE9;ctor Francisco Jara Delgado, Alcalde. </div></div>", "i": 6452441}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1896", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1896"}, {"tipo": "2", "numero": "01896", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-01896"}], "organismos": ["MUNICIPALIDAD DE MULCHÉN"], "titulo_norma": "APRUEBA ORDENANZA SOBRE SUBVENCIONES MUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-11-18", "doble_articulado": false, "id_norma": "218376", "numero_fuente": "37730", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-09", "vigencias": [{"desde": "2003-12-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-12-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-12-09", "fin_vig