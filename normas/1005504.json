{"html": [{"t": "<div><br><div class=\"p\">MODIFICA CONCESI&#xD3;N DE ACUICULTURA</div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n 1.168, de 4 de junio de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div></div>", "i": 8774003}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  I.&nbsp; &nbsp; Modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=246464&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n 1.526, de 11 de noviembre de 2005, del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina</a>, en el sentido de reemplazar el p&#xE1;rrafo 4.- por el siguiente:</div><div class=\"p\">&nbsp; &nbsp;  &quot;4.- El concesionario deber&#xE1; dar cabal cumplimiento al Proyecto T&#xE9;cnico y Cronograma de Actividades, aprobado por resoluci&#xF3;n exenta 2.478, de 3 de agosto de 2005, modificada por la resoluci&#xF3;n exenta 659, de 7 de marzo de 2008, ambas del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, Subsecretar&#xED;a de Pesca.&quot;</div></div>", "i": 8774004}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 6 de agosto de 2009.- Por la Sra. Subsecretaria, Humberto Ram&#xED;rez Navarro, Subjefe Subsecretar&#xED;a de Marina.</div></div>", "i": 8774005}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1168", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-1168"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "MODIFICA CONCESIÓN DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-06-04", "doble_articulado": false, "id_norma": "1005504", "nume