{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,118, que autoriza la construccion de un cuartel para la policia de Antofagasta</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,118.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274997}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir la suma de setenta i tres mil pesos ($ 73,000), en la construccion de un cuartel de la policia en la ciudad de Antofagasta.</div><br></div>", "i": 8274998}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 5 de Setiembre de 1908.- PEDRO MONTT.- Javier A. Figueroa.</div><br></div>", "i": 8274999}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2118", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2118"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 2,118, QUE AUTORIZA LA CONSTRUCCION DE UN CUARTEL PARA LA POLICIA DE ANTOFAGASTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ANTOFAGASTA", "CUARTEL POLICIA", "CONSTRUCCION", "FONDOS", "INVERSION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1908-09-05", "doble_articulado": false, "id_norma": "23131", "numero_fuente": "9185", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1908-09-11", "vigencias": [{"desde": "1908-09-11", "hasta": "", "tipo_version