{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 366, DE 1984 </div></div>", "i": 6265262}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 793, de 02 de Diciembre de 1985, de la Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n No. 366, de 1984, de la misma Subsecretaria, que autoriz&#xF3; a Pesquera Flamenco Ltda., domiciliada en Cha&#xF1;aral, para instalar y operar un establecimiento de cultivo de ostra japonesa, ostra chilena, osti&#xF3;n del Norte y choro zapato, en el sector La Caleta en Bah&#xED;a Flamenco, en orden a reemplazar su numeral 2&#xB0; por otro en el que se establece que el cultivo es suspendido, el &#xE1;rea del mismo es de 41.250 m2. y se se&#xF1;alan sus nuevas coordenadas.</div><br></div>", "i": 6265263}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 02 de Diciembre de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6265264}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "793", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-793"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 366, DE 1984", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-02", "doble_articulado": false, "id_norma": "165642", "numero_fuente": "32355", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-24", "vigencias": [{"desde": "1985-12-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-12-24", "