{"html": [{"t": "<div><div class=\"p\">NOMBRAMIENTO DE MINISTRO DE ESTADO.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 12 de 1824.</div></div>", "i": 10093470}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  A consulta de mi Consejo de Estado, y conforme a la Constitucion, he venido en nombrar para Ministro Secretario de Estado en el Departamento de Gobierno y Relaciones Exteriores al Brigadier D. Francisco Antonio Pinto, de cuya probidad y conocimientos me hallo satisfecho. El nombrado ser&#xE1; puesto inmediatamente en posesion de este destino, para lo cual se le comunicar&#xE1; el presente decreto, de que se tomar&#xE1; razon y se insertar&#xE1; en el Boletin.</div></div>", "i": 10093471}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Diego Jos&#xE9; de Benavente.</div></div>", "i": 10093472}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["DEPARTAMENTO DE GOBIERNO"], "titulo_norma": "NOMBRAMIENTO DE MINISTRO DE ESTADO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-07-12", "doble_articulado": false, "id_norma": "1140780", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1824-07-12", "vigencias": [{"desde": "1824-07-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-07-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-07-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresad