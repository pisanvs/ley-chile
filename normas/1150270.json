{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10164143}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.445, de 6 agosto 2020, de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n parcial, conforme art&#xED;culo 51 Ley 16.391, de inmueble ubicado en Av. Pdte. Ib&#xE1;&#xF1;ez 0388 Ram&#xF3;n Olate Z, Rol de Aval&#xFA;o N&#xB0; 272-11, Comuna Linares, superficie 11,39 metros cuadrados, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Villar Riquelme Jorge Patricio. Comisi&#xF3;n integrada por peritos Patricio Dur&#xE1;n Marcos, arquitecto; Rodrigo Silva Lazo, constructor civil y Pedro Pablo Cruz Weston, arquitecto, seg&#xFA;n informe tasaci&#xF3;n de 16 diciembre 2019, fij&#xF3; monto provisional indemnizaci&#xF3;n m&#xE1;s reajustes legales en $1.669.880.- pagados al contado.- </div></div>", "i": 10164144}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Claudio Daneck Mu&#xF1;oz, Director (S) Serviu Regi&#xF3;n del Maule.</div><br></div>", "i": 10164145}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1445 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1445 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "VII REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1822981", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-08-06", "doble_articulado": false, "id_norma": "1150270", "numero_fuente": "42769", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020