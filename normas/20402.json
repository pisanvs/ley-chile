{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 144 EXENTO, DE 1995</div><br><br></div>", "i": 5941874}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 144 de 2 de marzo de 1995, se han aprobado planes y programas especiales de estudio para Educaci&#xF3;n B&#xE1;sica y Media Human&#xED;stico-Cient&#xED;fica, al Instituto Ingl&#xE9;s de Rancagua, VI Regi&#xF3;n del Libertador Bernardo O&apos;Higgins.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio para las asignaturas que se se&#xF1;alan, aprobadas en el art&#xED;culo 1&#xB0; del presente decreto.</div><br></div>", "i": 5941875}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 13 de marzo de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5941876}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "144 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-144 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 144 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "INSTITUTO INGLES", "RANCAGUA", "SEXTA", "REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-03-02", "doble_articulado": false, "id_norma": "20402", "numero_fuente": "35125", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-03-23", "vigencias": [{"desde": "1995-03-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-03-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-03-23", "fin_vigencia": "", "tipo_version":