{"html": [{"t": "<div><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N EXENTA QUE INDICA</div></div>", "i": 10256248}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 215, del 4 de marzo de 2021, Serviu Regi&#xF3;n del Libertador General Bernardo O&apos;Higgins, orden&#xF3; la rectificaci&#xF3;n de la <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=1139268&amp;idVersion=2021-08-02\">resoluci&#xF3;n exenta N&#xB0; 2.565, de fecha 20 de noviembre de 2019</a>, en el sentido de excluir la expropiaci&#xF3;n del inmueble de aparente dominio de Reginato Yarza, Alejandro y otros, ubicado en Avenida Baquedano N&#xB0; 840, comuna de Rancagua, rol de aval&#xFA;o 603-20, individualizado como el lote 93 en plano de expropiaciones del proyecto &quot;Ampliaci&#xF3;n Avenida Baquedano&quot; en la comuna de Rancagua. Quedando de esta manera sin efecto esa expropiaci&#xF3;n dispuesta en la resoluci&#xF3;n rectificada.- </div><div class=\"p\">&nbsp; &nbsp;  </div><br></div>", "i": 10256249, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n Libertador Bernardo O&apos;Higgins.</div><div class=\"p\"> </div><br></div>", "i": 10256250}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "215 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-215 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DEL LIBERTADOR GENERAL BERNARDO O'HIGGINS"], "titulo_norma": "RECTIFICA RESOLUCIÓN EXENTA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1983226"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion"