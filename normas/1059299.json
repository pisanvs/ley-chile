.167.862-0, a contar del mes de febrero 2014.</div><div class=\"p\">&nbsp; &nbsp;  En la oficina Virtual del SII en internet se podr&#xE1;n consultar los documentos que los contribuyentes est&#xE1;n autorizados a emitir en forma electr&#xF3;nica.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de enero de 2014.</div></div>", "i": 9405539}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "13 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-13 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISOR DE DOCUMENTOS TRIBUTARIOS ELECTRÓNICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-01-31", "doble_articulado": false, "id_norma": "1059299", "numero_fuente": "40775", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-02-05", "vigencias": [{"desde": "2014-02-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-02-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014-02-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2014-02-05", "fecha_version": "2014-02-05", "fecha_actualizacion_texto": "2014-02-05", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i