{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6596888}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.522, de 27 de diciembre de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a EXPORTADORA Y COMERCIALIZADORA SAN DIEGO LIMITADA para ampliar las actividades pesqueras de transformaci&#xF3;n autorizadas por la resoluci&#xF3;n citada en Visto, en orden a incorporar a la planta ubicada en Phillippi N&#xBA; 465, Valpara&#xED;so, V Regi&#xF3;n, en las l&#xED;neas de proceso de Cocido, Fresco-Enfriado, Fresco-Refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6596889}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de diciembre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6596890}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3522 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3522 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-12-27", "doble_articulado": false, "id_norma": "257339", "numero_fuente": "38661", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-01-12", "vigencias": [{"desde": "2007-01-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-01-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-01-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc