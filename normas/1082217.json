{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  LEY NUM. 4,887</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div></div>", "i": 9639642}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico Se declara feriado el d&#xED;a veinte del presente mes.</div><div class=\"p\">&nbsp; &nbsp;  Esta ley regir&#xE1; desde la fecha de sn publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 9639643}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, he tenido a bien aprobarlo y sancionarlo, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, once de Septiembre de mil novecientos treinta. - CARLOS IBA&#xD1;EZ C. -Carlos O. Frodden.</div></div>", "i": 9639644}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4887", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "Ley-4887"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-09-11", "doble_articulado": false, "id_norma": "1082217", "numero_fuente": "15775", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-09-15", "vigencias": [{"desde": "1931-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1931-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1931-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "362", "fecha_ingreso":