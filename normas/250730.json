{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6573888}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.542, de 7 de junio de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a PACIFIC COLD STORAGE S.A. para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en El Tofo N&#xBA; 106, Barrio Industrial, Puerto Montt, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso fresco enfriado, fresco refrigerado y congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6573889}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de junio de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6573890}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1542 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1542 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2006-06-07", "fecha_derogacion": "2006-10-07", "doble_articulado": false, "id_norma": "250730", "numero_fuente": "38494", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2006-06-21", "vigencias": [{"desde": "2006-10-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2006-06-21", "hasta": "2006-10-06", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2006-10-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig