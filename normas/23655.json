{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suprime varios plazas de Oficiales en algunas Intendencias de Provincias</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,994.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275847}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Supr&#xED;mense los empleos de oficiales segundos de las Intendencias de Tarapac&#xE1;, Antofagasta, Atacama, Coquimbo, Aconcagua, Talca i Concepcion, i los de oficiales terceros de las Intendencias de Santiago i Valparaiso.</div><br></div>", "i": 8275848}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 1.&#xB0; de Marzo de 1915.- RAMON BARROS LUCO.- Pedro N. Montenegro.</div><br></div>", "i": 8275849}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2994", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2994"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Suprime varios plazas de Oficiales en algunas;Intendencias de Provincias", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INTENDENCIA", "TARAPACA", "ATACAMA", "COQUIMBO", "ANTOFAGASTA", "ACONCAGUA", "TALCA", "CONCEPCION", "SANTIAGO", "VALPARAISO", "OFICIALES", "CARGOS", "SUPRESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1915-03-01", "doble_articulado": false, "id_norma": "23655", "numero_fuente": "11115", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publica