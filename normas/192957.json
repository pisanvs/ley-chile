{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6362611}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica en conformidad a lo dispuesto en la letra b) del No. 2 del Art&#xED;culo 1&#xBA; de la Ley 18.653, publicada en el Diario Oficial de 03 de octubre de 1987, modificatoria de la Ley No. 18.480, que el Indice de Precios Promedio relevante para el comercio exterior de Chile en 1988 (Base: Promedio a&#xF1;os 1983 y 1984 = 100), fue de 128.44.</div><br></div>", "i": 6362612}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de Enero de 1989.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6362613}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-01-31", "doble_articulado": false, "id_norma": "192957", "numero_fuente": "33294", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-02-09", "vigencias": [{"desde": "1989-02-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-02-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-02-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2001-12-19", "fecha_version": "1989-02-09", "fecha_actualizacion_texto": "1989-02-09", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i"