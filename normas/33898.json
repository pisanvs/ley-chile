{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291308}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 238, de 8 de Marzo de 1995, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, se deneg&#xF3; la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por don RODRIGO</div><div class=\"p\">EDUARDO NEIRA MANRIQUEZ, para un sector ubicado en Punta</div><div class=\"p\">Putique, Bah&#xED;a Manao, comuna de Ancud, Provincia de</div><div class=\"p\">Chilo&#xE9;, X Regi&#xF3;n, en virtud de lo dispuesto en los</div><div class=\"p\">art&#xED;culos 76&#xB0;, 77&#xB0;, 78&#xB0; y 5&#xB0; transitorio inciso 6&#xB0;, de la Ley General de Pesca y Acuicultura y el art&#xED;culo 14&#xB0; del D.S. N&#xB0; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. Asimismo, se dej&#xF3; sin efecto la Resoluci&#xF3;n N&#xB0; 709, de 1991, de esta Subsecretar&#xED;a. </div></div>", "i": 8291309}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 8 de Marzo de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8291310}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "238", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-238"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "ACUICULTURA", "RODRIGO EDUARDO NEIRA", "MANRIQUEZ"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-03-08", "doble_articulado": false, "id_norma": "33898", "numero_fuente": "35121", "tipo_v