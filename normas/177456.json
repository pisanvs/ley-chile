{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6307441}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 2.269, de 18 de octubre de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a CORPESCA S.A., para ampliar las actividades pesqueras extractivas con la nave &apos;&apos;Toconao II&apos;&apos;, en el &#xE1;rea mar&#xED;tima de la I y II Regiones, donde podr&#xE1; capturar, con red de cerco, por fuera del &#xE1;rea de reserva artesanal, los recursos hidrobiol&#xF3;gicos Anchoa blanca, Jurel fino, Sardina redonda y Vinciguerria.</div><br></div>", "i": 6307442}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de octubre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6307443}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2269", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2269"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-10-18", "fecha_derogacion": "2019-09-26", "doble_articulado": false, "id_norma": "177456", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-11-06", "vigencias": [{"desde": "2019-09-26", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2000-11-06", "hasta": "2019-09-25", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2019-09-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-11-06", "fin_vigencia": "2019-09-25", "tipo_version": "0"}, {"inicio_vigenci