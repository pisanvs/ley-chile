{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n de gracia a do&#xF1;a Julia Ram&#xED;rez Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 8277355}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a do&#xF1;a Julia Ram&#xED;rez, viuda del oficial de sala del Senado, don Luis Aguilera Leiva por una sola vez, la cantidad correspondiente a un a&#xF1;o del sueldo que percib&#xED;a este empleado.</div><br></div>", "i": 8277356}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintitr&#xE9;s de Enero de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- Enrique Balmaceda. </div></div>", "i": 8277357}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4261", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4261"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE PENSIÓN DE GRACIA A DOÑA JULIA RAMÍREZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JULIA RAMIREZ", "PENSION GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-01-23", "doble_articulado": false, "id_norma": "24612", "numero_fuente": "14991", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-02-04", "vigencias": [{"desde": "1928-02-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-02-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1928-0