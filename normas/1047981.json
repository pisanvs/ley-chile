{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA RECEPTOR ELECTR&#xD3;NICO</div></div>", "i": 9326304}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 1, de 8 de enero de 2013, que autoriza a contribuyente como receptor electr&#xF3;nico.</div><br><div class=\"p\">&nbsp; &nbsp;  Se autoriza como receptor de documentos tributarios electr&#xF3;nicos al contribuyente RUT N&#xB0; 61.973.000-3 a contar del mes de enero 2013.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de enero de 2013.</div></div>", "i": 9326305}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA RECEPTOR ELECTRÓNICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-01-08", "doble_articulado": false, "id_norma": "1047981", "numero_fuente": "40457", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-01-12", "vigencias": [{"desde": "2013-01-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-01-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-01-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones