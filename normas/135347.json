{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,772.- Santiago, 24 de noviembre de 1905.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165149}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Manuela Z&#xFA;&#xF1;iga, v. de Lagos, madre del sarjento-mayor de Ej&#xE9;rcito don Francisco Lagos Z&#xFA;&#xF1;iga, fallecido en 1895, el derecho a gozar de una pension de treinta pesos ($ 30) mensuales, de la que disfrutar&#xE1; conforme a la lei de montep&#xED;o militar.</div><div class=\"p\">&nbsp; &nbsp;  Esta pension rejir&#xE1; desde la fecha de la presente lei. </div></div>", "i": 6165150}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Manuel F&#xF3;ster R.</div><br></div>", "i": 6165151}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1772", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1772"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-11-24", "doble_articulado": false, "id_norma": "135347", "numero_fuente": "8365", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-11-25", "vigencias": [{"desde": "1905-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1905-11-25", "fin_vigencia": ""}, "vigencias_version_norma":