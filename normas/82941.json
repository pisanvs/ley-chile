{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 141, DE 1990 </div></div>", "i": 8969164}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 141 de 25 de abril de 1990, se ha sustituido, a partir del a&#xF1;o escolar 1990, en el art&#xED;culo 1&#xB0; del decreto supremo exento de Educaci&#xF3;n No. 23 de 1985, el plan de estudio para Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica, que se aplicar&#xE1; simult&#xE1;neamente en todos los cursos de ese nivel de ense&#xF1;anza al Colegio Apoquindo, Ni&#xF1;as, de Santiago. </div></div>", "i": 8969165}, {"t": "<div><div class=\"p\">Santiago, 23 de Mayo de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8969166}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "141 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-141 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 141, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-04-25", "doble_articulado": false, "id_norma": "82941", "numero_fuente": "33694", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-06-13", "vigencias": [{"desde": "1990-06-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-06-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-06-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "PMZ", "f