{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6249536}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 27, de 03 de Abril de 1985 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la I Regi&#xF3;n se autoriza a Sr. Rocco Frontuto Capuro, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicio p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6249537}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan W. Flaquer Hern&#xE1;ndez, Secretario Regional Ministerial de Transportes y Telecomunicaciones, I Regi&#xF3;n Tarapac&#xE1;.</div><br></div>", "i": 6249538}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "27 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-27 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-04-03", "doble_articulado": false, "id_norma": "160666", "numero_fuente": "32143", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-04-11", "vigencias": [{"desde": "1985-04-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-04-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-04-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion