{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A LIBORIO MOLINA PARRA </div></div>", "i": 6472820}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE 08/N&#xBA; Ex.714, de fecha 31 de marzo de 2004, revoca a don Liborio Molina Parra, RUT N&#xBA; 8.795.880-9, la calidad de agente retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las ventas de ganado vivo, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 18 de la resoluci&#xF3;n 3.721 del 28-07-2000, de la Direcci&#xF3;n Nacional, a contar de la fecha de publicaci&#xF3;n en el Diario Oficial del presente extracto.- </div></div>", "i": 6472821}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Sergio Flores Guti&#xE9;rrez, Director Regional. </div></div>", "i": 6472822}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "714 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-714 EXENTA"}, {"tipo": "3", "numero": "DRE-08-714 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-714 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A LIBORIO MOLINA PARRA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-31", "doble_articulado": false, "id_norma": "223493", "numero_fuente": "37833", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-12", "vigencias": [{"desde": "2004-04-12", "hasta": "", "tipo_version": "3", "tipo_version_