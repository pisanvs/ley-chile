{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6265060}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 323 de fecha 19, de Diciembre de 1985.-, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la II Regi&#xF3;n, se autoriza a la Empresa de Transportes Tramaca Sociedad An&#xF3;nima, para efectuar todo tipo de Servicio de transporte de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de Locomoci&#xF3;n Colectiva de pasajeros. </div></div>", "i": 6265061}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - James Brown Rojas, SEREMI Subrogante de Transportes y Telecomunicaciones II Regi&#xF3;n.</div><br></div>", "i": 6265062}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "323 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-323 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL II REGIÓN DE ANTOFAGASTA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-12", "doble_articulado": false, "id_norma": "165575", "numero_fuente": "32351", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-19", "vigencias": [{"desde": "1985-12-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-12-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-12-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vi