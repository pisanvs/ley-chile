{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6467759}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 380, de 9 de febrero de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a la CORPORACION PRIVADA PARA EL DESARROLLO DE LA UNIVERSIDAD ARTURO PRAT, para efectuar actividades experimentales en el cultivo de Acha, San Pedro y Mulata, asimismo como para la captura de dichos ejemplares en el litoral costero de la provincia de Iquique, dentro de las cinco millas de mar territorial, entre Caleta Pisagua y Caleta San Marcos.</div><div class=\"p\">&nbsp; &nbsp;  Las actividades podr&#xE1;n realizarse por el t&#xE9;rmino de 18 meses a contar de la fecha de publicaci&#xF3;n de este extracto.</div><br></div>", "i": 6467760}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de febrero de 2004.- Jessica Fuentes Olmos, Subsecretario de Pesca (S).</div><br></div>", "i": 6467761}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "380", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-380"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-09", "doble_articulado": false, "id_norma": "222082", "numero_fuente": "37804", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-06", "vigencias": [{"desde": "2004-03-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-03-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-03-06", "fin_vigencia": "", "tipo