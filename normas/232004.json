{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6503188}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP. N&#xBA; 881, de 5 de octubre de 2004, se modific&#xF3; el decreto MOP N&#xBA; 222, de 26 de marzo de 2004, que orden&#xF3; la expropiaci&#xF3;n del lote de terreno N&#xBA; 219L4, de manera que se rectific&#xF3; el numeral 2&#xBA; , en cuanto a que la superficie a expropiar, qued&#xF3; en 210 m2 y no 247 m2, como se indic&#xF3; inicialmente. Asimismo, se modificaron los numerales 3&#xBA; y 7&#xBA; , en el sentido de que la indemnizaci&#xF3;n provisional es la suma de $44.012.100. </div></div>", "i": 6503189}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6503190}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "881", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-881"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-05", "doble_articulado": false, "id_norma": "232004", "numero_fuente": "38000", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-11-02", "vigencias": [{"desde": "2004-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "CMV", "fecha_ingreso": "2004-11-02", "fecha_version": "2004-11-02", "fec