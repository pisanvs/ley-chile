{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8302309}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 474, de 3 de abril de 1997, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la autorizaci&#xF3;n</div><div class=\"p\">solicitada por EMPRESA DE CONSTRUCCION Y CARPINTERIA</div><div class=\"p\">NAVAL CONCAR S.A., para prorrogar por un a&#xF1;o la vigencia</div><div class=\"p\">de la Resoluci&#xF3;n N&#xBA; 291, de 1989, de esta Subsecretar&#xED;a,</div><div class=\"p\">por cuanto los hechos invocados por la solicitante no</div><div class=\"p\">son constitutivos de fuerza mayor o caso fortuito,</div><div class=\"p\">verific&#xE1;ndose la causal denegatoria prevista en el</div><div class=\"p\">art&#xED;culo 19 letra e) de la Ley N&#xBA; 18.892 y sus modificaciones.</div><br></div>", "i": 8302310}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de abril de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8302311}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "474", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-474"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "PESCA", "EMPRESA DE CONSTRUCCION Y CARPINTERIA NAVAL CONCAR S.A.", "PRORROGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-03", "doble_articulado": false, "id_norma": "70504", "numero_fuente": "35737", "tipo_version": "3", "tipo_version_s": "Única", "fecha