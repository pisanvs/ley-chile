{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,228.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6162787}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados por el jefe de estaci&#xF3;n de San Bernardo, don Ramon Ar&#xED;stegui, se le concede, por gracia, derecho a jubilar con arreglo a la lei de 20 de agosto de 1857, tomando por base el setenta i cinco por ciento del sueldo de que disfruta. </div></div>", "i": 6162788}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, a 6 de junio de 1899.- FEDERICO ERRAZURIZ.-</div><div class=\"p\">D. Rioseco.</div><br></div>", "i": 6162789}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1228", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1228"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-06-06", "doble_articulado": false, "id_norma": "134566", "numero_fuente": "6345", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-07-11", "vigencias": [{"desde": "1899-07-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-07-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-07-11", "fin_vigencia": "", "tipo_version": "3"}], 