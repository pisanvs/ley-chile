{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION QUE INDICA </div></div>", "i": 6270853}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.165, de 29 de Septiembre de 1987, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deroga la resoluci&#xF3;n No. 48, de 1982, de esta Subsecretar&#xED;a que autoriz&#xF3; a operar la embarcaci&#xF3;n &quot;Corbeta&quot; de propiedad de la Sociedad Armaly e Hijo Limitada domiciliada en Caldera de conformidad con lo dispuesto en los art&#xED;culos 1&#xB0;, letra f), 2&#xB0; y 10&#xB0; del decreto No. 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 6270854}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de Septiembre de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 6270855}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1165", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1165"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "DEROGA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-29", "doble_articulado": false, "id_norma": "167296", "numero_fuente": "32899", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-10-21", "vigencias": [{"desde": "1987-10-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-10-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-10-21", "fin_vigencia": "", "tipo_version