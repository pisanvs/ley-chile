{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8682549}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile, en base a los antecedentes proporcionados por el Fondo Monetario Internacional y CORFO de Nueva York certifica, a requerimiento de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante, para los efectos de lo dispuesto en el Art&#xED;culo N&#xB0; 116 del Decreto Supremo de la Subsecretar&#xED;a de Marina N&#xB0; 427, de 25 de junio de 1979, que la variaci&#xF3;n experimentada por el I.P.C. de los Estados Unidos de Am&#xE9;rica, entre el 1&#xB0; de diciembre de 1991 y el 30 de noviembre de 1992, fue de 3,048%. </div></div>", "i": 8682550}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, diciembre 16 de 1992.- V&#xED;ctor Vial del R&#xED;o, Fiscal.</div><br></div>", "i": 8682551}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INDICE PRECIOS CONSUMIDOR", "IPC", "ESTADOS UNIDOS AMERICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-12-16", "doble_articulado": false, "id_norma": "1718", "numero_fuente": "34443", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-12-17", "vigencias": [{"desde": "1992-12-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-12-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-12-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "