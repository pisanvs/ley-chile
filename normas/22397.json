{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Tarifa Postal i Liberacion de Porte Lei n&#xFA;m. 1.080.- Santiago, a 26 de Setiembre de 1898.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274080}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Der&#xF3;gase el inciso 4.&#xB0; del art&#xED;culo 13 de la lei de 19 de Noviembre de 1874, sobre tarifa postal i liberacion de porte.</div><div class=\"p\">&nbsp; &nbsp; Esta lei rejir&#xE1; desde el 1.&#xB0; de Noviembre de 1898.</div><br><br></div>", "i": 8274081}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C. Walker Mart&#xED;nez.</div><br></div>", "i": 8274082}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1080", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1080"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "TARIFA POSTAL I LIBERACION DE PORTE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CORREOS", "CORRESPONDENCIA", "FRANQUEO", "LIBERACION", "PORTE", "MODIFICACION", "TARIFA POSTAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-09-26", "doble_articulado": false, "id_norma": "22397", "numero_fuente": "6109", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-09-26", "vigencias": [{"desde": "1898-11-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-11-01", "fin_vigencia": ""}, "vigencia