{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293404}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 617 de 24 de Mayo de 1995 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xB0; 400, de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a INDUSTRIA DE ALIMENTOS MARINOS LIMITADA, R.U.T. N&#xB0; 79.615.670-8, para iniciar actividades pesqueras extractivas con las naves &quot;Koln&quot;, &quot;Wien&quot;, &quot;Hessen&quot;, &quot;Saarbrucken&quot; y &quot;Mond&quot;, por haberse configurado la causal prevista en el art&#xED;culo 143, letra b) de la Ley N&#xB0; 18.892, citada en Visto.</div><br></div>", "i": 8293405}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 24 de Mayo de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293406}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "617", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-617"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "PESCA", "INDUSTRIA ALIMENTOS", "MARINOS LIMITADA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-24", "doble_articulado": false, "id_norma": "35226", "numero_fuente": "35186", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-06-06", "vigencias": [{"desde": "1995-06-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-06-06", "fin_vigencia": ""}, "vigencias_v