{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.690 EXENTA, DE 1998 </div><br></div>", "i": 6112186}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xBA;1.690 del 3 de junio de 1998, conforme art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, determin&#xF3; Derechos Aprovechamiento de Aguas que corresponden a la parte del Sector Quilapalo de la Parcelaci&#xF3;n de la Colonia B&#xED;o B&#xED;o, comuna de Quilaco, VIII Regi&#xF3;n, conformada por las Parcelas N&#xBA;s 85, 91, 93, 94, 95, 98, 99 y 100.</div><br><div class=\"p\">&nbsp; &nbsp;  Los derechos de aguas se extraen del estero Lirqu&#xE9;n por los canales Lirqu&#xE9;n y Solar y del desag&#xFC;e El Avellano Chico.</div><br><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13 ley N&#xBA;18.377.- </div></div>", "i": 6112187}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Nacional.</div><br></div>", "i": 6112188}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1690 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1690 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.690 EXENTA, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHO DE APROVECHAMIENTO DE AGUAS", "QUILACO", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-06-03", "doble_articulado": false, "id_norma": "99579", "numero_fuente": "36089", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-06-15", "vigencias": [{"desde": "1998-06-15", "hasta": "", "tipo_