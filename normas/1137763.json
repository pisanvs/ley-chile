{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 4.834, DE 08.10.2019, DE LA DIRECCI&#xD3;N NACIONAL DE ADUANAS, QUE MODIFICA EL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10062427}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0;4.834, de 08.10.2019, del Director Nacional de Aduanas, se modific&#xF3; el Anexo 51 del <a href=\"https://www.leychile.cl/Navegar?idNorma=248540&amp;idParte=&amp;idVersion=\">Compendio de Normas Aduaneras</a>, incorporando los c&#xF3;digos de tratado de libre comercio (831) y r&#xE9;gimen de importaci&#xF3;n (51) para el Acuerdo de Asociaci&#xF3;n Econ&#xF3;mica Integral suscrito entre la Rep&#xFA;blica de Indonesia y la Rep&#xFA;blica de Chile.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).- </div><br></div>", "i": 10062428}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><br></div>", "i": 10062429}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4834 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4834 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 4.834, DE 08.10.2019, DE LA DIRECCIÓN NACIONAL DE ADUANAS, QUE MODIFICA EL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1668789", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-10-08", "doble_articulado": false, "id_norma": "1137763", "nume