{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6327562}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por R.M. (Ex.) N&#xBA;48, de 15 de marzo de 2001, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ac&#xF3;gese parcialmente el recurso de reclamaci&#xF3;n interpuesto por Pesquera TravesIa S.A., en contra de las resoluciones N&#xBA;161, N&#xBA;176 y N&#xBA;177, todas de 2001, de la Subsecretar&#xED;a de Pesca. Consid&#xE9;rese en la determinaci&#xF3;n de su l&#xED;mite m&#xE1;ximo de captura de la unidad de pesquer&#xED;a Jurel, V a IX Regiones, las siguientes capturas totales de la nave &apos;&apos;Mar&#xED;a Jos&#xE9;&apos;&apos;, en los meses que se indica:</div><br><div class=\"p\">Abril de 2000&nbsp; : 1.697,290 toneladas Julio de 2000&nbsp; : 2.260,290 toneladas </div></div>", "i": 6327563}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; de Gregorio Rebeco, Ministro de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6327564}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "48 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-48 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-15", "doble_articulado": false, "id_norma": "183171", "numero_fuente": "36920", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-23", "vigencias": [{"desde": "2001-03-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-23", "fin_vigencia": ""}, "vigen