{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6160394}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile en conformidad con lo dispuesto en el N&#xBA; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de marzo de 1999, fue de 6,90% anual.</div><br></div>", "i": 6160395}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, marzo 16 de 1999.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6160396}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-03-16", "doble_articulado": false, "id_norma": "133874", "numero_fuente": "36318", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-03-19", "vigencias": [{"desde": "1999-03-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-03-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-03-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-03-19", "fecha_version": "1999-03-19", "fecha_actualizacion_texto": "1999-03-19", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6160394}, {"n": "Artículo", "i": 6160395, "t": 6}, {"n":