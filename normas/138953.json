{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,020.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6177072}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados por el cabo primero don Juan Agustin Torres, conc&#xE9;dese a su viuda do&#xF1;a Rosa M&#xE1;rquez, una pension de gracia&nbsp; de veinte pesos mensuales que gozar&#xE1; con arreglo a la lei de Montep&#xED;o Militar.</div><br></div>", "i": 6177073}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, a cuatro de setiembre de mil novecientos quince.- Ramon Barros Luco.- Guillermo Soublette. </div></div>", "i": 6177074}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3020", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3020"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1915-09-04", "doble_articulado": false, "id_norma": "138953", "numero_fuente": "11556", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-08-24", "vigencias": [{"desde": "1916-08-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1916-08-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1916-08-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc