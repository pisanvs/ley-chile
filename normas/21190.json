{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 414, DE 1990 </div></div>", "i": 8604629}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 414, de fecha 28 de Diciembre</div><div class=\"p\">de 1990, del Ministerio de Educaci&#xF3;n, que ampli&#xF3; la</div><div class=\"p\">autorizaci&#xF3;n de funcionamiento del Instituto Profesional</div><div class=\"p\">Santo Tom&#xE1;s otorgada mediante los Decretos Exentos N&#xB0;</div><div class=\"p\">114 de 1987; N&#xB0; 157 de 1989 y N&#xB0; 8 de 1989, a las sedes</div><div class=\"p\">que la Sociedad Organizadora mantiene en calle 18 de</div><div class=\"p\">Septiembre 109 de Arica y Salvador Reyes N&#xB0; 1032 de</div><div class=\"p\">Antofagasta.</div><div class=\"p\">&nbsp; &nbsp; Por este mismo cuerpo legal, se rectific&#xF3; el</div><div class=\"p\">Art&#xED;culo 1&#xB0; del Decreto Exento N&#xB0; 219 de 1990 en lo que respecta al domicilio de la Sede La Serena, debiendo decir: Brasil N&#xB0; 611.</div><br></div>", "i": 8604630}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 30 de Abril de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8604631}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "414", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-414"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 414, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO PROFESIONAL SANTO TOMAS", "ARICA", "ANTOFAGASTA", "FUNCIONAMIENTO", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-28", "doble_articulado": false, "id_norma": "21190", "numero