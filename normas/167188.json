{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6270541}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 779, de 24 de abril de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la resoluci&#xF3;n N&#xBA; 1.712 de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a do&#xF1;a LITA DEL CARMEN VILLARROEL GUTIERREZ, para operar la nave &apos;&apos;Juan Antonio II&apos;&apos;, matr&#xED;cula 570, de Constituci&#xF3;n, en virtud de haberse configurado las causales de caducidad del art&#xED;culo 143 letras b) y d) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 6270542}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de abril de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6270543}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "779", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-779"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-24", "doble_articulado": false, "id_norma": "167188", "numero_fuente": "36650", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-28", "vigencias": [{"desde": "2000-04-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-04-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-04-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}],