{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 2,344.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6171538}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- En atenci&#xF3;n a los servicios prestados al pais por don Fanor Velasco, se concede, por gracia, a su se&#xF1;ora viuda, hijos menores de edad e hijas solteras, una pensi&#xF3;n de cuatro mil pesos ($ 4,000) anuales, de la cual gozar&#xE1;n en conformidad a la lei de montep&#xED;o militar.&quot; </div></div>", "i": 6171539}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; i por tanto prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, a nueve de agosto de mil novecientos diez.- El&#xED;as Fern&#xE1;ndez Albano.- E. Figueroa&quot;. </div></div>", "i": 6171540}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2344", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2344"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-08-09", "doble_articulado": false, "id_norma": "137313", "numero_fuente": "9766", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-08-11", "vigencias": [{"desde": "1910-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-08-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1910-08-11", "