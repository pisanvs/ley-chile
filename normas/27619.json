{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N.o 13,581, DE 9 DE NOVIEMBRE DE 1959.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8281181}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Reempl&#xE1;zase el N&#xB0; 2 del art&#xED;culo 11 de la ley N.o 13,581, de 9 de Noviembre de 1959, por el siguiente:</div><div class=\"p\">&nbsp; &nbsp; &quot;2.- Para adquirir terrenos destinados a la construcci&#xF3;n por la Corporaci&#xF3;n de la Vivienda de poblaciones populares en Traigu&#xE9;n</div><div class=\"p\">_______________________________ $ 1.500.000&quot;.&quot;</div><br></div>", "i": 8281182}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, nueve de Agosto de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- S&#xF3;tero R&#xED;o G. </div></div>", "i": 8281183}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13987", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13987"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA LA LEY N.o 13,581, DE 9 DE NOVIEMBRE DE\n1959.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "LEY 13581", "INVERSION", "FONDOS", "RECURSOS", "MUNICIPALIDAD TRAIGUEN"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-08-09", "doble_articulado": false, "id_norma": "27619", "numero_fuente": "24725", "tipo_version": "3", "tipo_version_s": "Única", "fe