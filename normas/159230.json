{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6244463}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;3.638, de 30 de noviembre de 1999, se expropiaron los lotes de terreno N&#xBA;s 5-B, 6, 7, 8-A, 8-B, 8-C, 9, 10, 11, 14-A y 15-A, superficies 2.230, 5.940, 2.934, 376, 11.172, 1.428, 2.243, 759, 10.081, 3.300 y 1.959 M2 respectivamente, roles de aval&#xFA;o 524-253, 524-247, 524-254 y 521-61, comuna de Tir&#xFA;a, VIII Regi&#xF3;n, para la obra Camino Tir&#xFA;a Trovolhue - Carahue y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Alfonso Caripan Collipal, Patricio Caripan Collipal, Jaime Caripan Collipal y V&#xED;ctor Rivera D&#xED;az, ascendente a las cantidades de $6.546.954, $7.421.630, $6.705.101 y $2.696.680.</div><br></div>", "i": 6244464}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br><br></div>", "i": 6244465}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3638", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3638"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-11-30", "doble_articulado": false, "id_norma": "159230", "numero_fuente": "36602", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-01", "vigencias": [{"desde": "2000-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [],