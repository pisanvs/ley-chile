{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO MINISTROS DE FE A FUNCIONARIOS QUE INDICA </div><div class=\"p\">N&#xFA;m. 246.- Santiago, 30 de Septiembre de 1991.- Vistos: Lo dispuesto en el art&#xED;culo 4&#xB0; del decreto ley No. 2.974 de 1979.</div><br><div class=\"p\">Resuelvo:</div><br></div>", "i": 6075702}, {"t": "<div><div class=\"p\">Des&#xED;gnase como Ministros de Fe para actuar en las localidades ubicadas en la X Regi&#xF3;n, en que no hayan Notarios ni Oficiales del Registro Civil, a los siguientes funcionarios:</div><div class=\"p\">- Marcia Edith Vera Oyarz&#xFA;n</div><div class=\"p\">- Mauricio Antonio Mu&#xF1;oz Soto</div><div class=\"p\">- Ren&#xE9; Alfonso Garc&#xE9;s Alvarez</div><div class=\"p\">- V&#xED;ctor Leonel Benavente Fuentealba.</div><br></div>", "i": 6075703}, {"t": "<div><div class=\"p\">T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hugo Ortega Tello. Director Nacional. </div></div>", "i": 6075704}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "246", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-246"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO MINISTROS DE FE A FUNCIONARIOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-09-30", "doble_articulado": false, "id_norma": "87272", "numero_fuente": "34101", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-10-26", "vigencias": [{"desde": "1991-10-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-10-26", "fin_vig