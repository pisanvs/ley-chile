{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza la erecci&#xF3;n de un monumento al General Baquedano</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br><br></div>", "i": 5959324}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para erigir, por subscripci&#xF3;n popular, un monumento en la ciudad de Santiago, a la memoria del General don Manuel Baquedano, previo informe del Consejo de Bellas Artes, sobre el valor art&#xED;stico del monumento. </div></div>", "i": 5959325}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintisiete de Marzo de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- Bartolom&#xE9; Blanche. </div></div>", "i": 5959326}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "https://tramitacion.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=17392-24", "informacion": "Modifica la ley N° 4.328 para fijar la ubicación del monumento al General Manuel Baquedano", "nroBoletin": "17392-24"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4328", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4328"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "AUTORIZA LA ERECCION DE UN MONUMENTO AL GENERAL BAQUEDANO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MANUEL BAQUEDANO", "MONUMENTO", "SANTIAGO", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado