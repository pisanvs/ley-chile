{"html": [{"t": "<div><div class=\"p\">EXTRACTO&nbsp; DE&nbsp; DECRETO N&#xBA; 384&nbsp; EXENTO,&nbsp; DE 1998</div><br></div>", "i": 6124074}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 384, de fecha 6 de marzo de 1998, del Ministerio de Educaci&#xF3;n, se declar&#xF3; aprobada a la Universidad Nacional Andr&#xE9;s Bello, inscrita en el Registro de Universidades bajo el Folio C-N&#xBA; 23 del a&#xF1;o 1988, la carrera de T&#xE9;cnico de Nivel Superior en Construcci&#xF3;n conducente al t&#xED;tulo de T&#xE9;cnico de Nivel Superior en Construcci&#xF3;n, para ser impartida en jornada vespertina, en su sede de la ciudad de Santiago, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6124075}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de marzo de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6124076}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "384 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-384 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 384 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["UNIVERSIDAD NACIONAL ANDRES BELLO", "CARRERAS PROFESIONALES", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-03-06", "doble_articulado": false, "id_norma": "122620", "numero_fuente": "36130", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-08-03", "vigencias": [{"desde": "1998-08-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-08-03", "fi