{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6588370}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.884, de 18 de octubre de 2006, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 371 de 1997, modificada por resoluci&#xF3;n N&#xBA; 603 de 2003, de esta Subsecretar&#xED;a, que autoriz&#xF3; a COMPA&#xD1;&#xCD;A PESQUERA CAMANCHACA S.A., para desarrollar actividades pesqueras extractivas con la nave &quot;Corsario I&quot;, en el sentido de actualizar las siguientes caracter&#xED;sticas n&#xE1;uticas de la nave:</div><br><div class=\"p\">Potencia principal&nbsp; &nbsp; &nbsp;  4.720,00 Hp.</div><div class=\"p\">Potencia auxiliar&nbsp; &nbsp; &nbsp; &nbsp; 1.501,00 Hp.</div><br></div>", "i": 6588371}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de octubre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6588372}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2884 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2884 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2006-10-18", "fecha_derogacion": "2012-08-31", "doble_articulado": false, "id_norma": "254867", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2006-11-03", "vigencias": [{"desde": "2012-08-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2006-11-03", "hasta": "2012-08-30", "tipo_version": "0", "tipo_version_s": "Texto Origi