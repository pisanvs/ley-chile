{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6601183}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 361, de 2 de febrero de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a FRIOSUR X S.A. para ampliar actividades extractivas con la nave &quot;Friosur X&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre el paralelo 41&#xB0;28,6&apos; L.S. y el l&#xED;mite sur de la XI Regi&#xF3;n, con trampas, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar los siguientes recursos hidrobiol&#xF3;gicos: Centolla Lithodes wiracocha, Centolla Lithodes panamensis, Centolla Neolithodes diomedae, Centoll&#xF3;n Paralomis papillata, Centoll&#xF3;n Paralomis longipes, Centoll&#xF3;n Paralomis otsuae, Centoll&#xF3;n Paralomis spinosissima, y Congrio dorado.</div><br></div>", "i": 6601184}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de febrero de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6601185}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "361 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-361 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-02-02", "doble_articulado": false, "id_norma": "258292", "numero_fuente": "38686", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-02-10", "vigencias": [{"desde": "2007-02-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-02-10", "fi