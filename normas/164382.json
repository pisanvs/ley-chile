{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6957483}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 94, de 29 de Enero de 1985, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se cancela la autorizaci&#xF3;n otorgada por Resoluci&#xF3;n exenta N&#xB0; 415, de 04 de Mayo de 1982, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, a la sociedad &quot;Gonz&#xE1;lez y Compa&#xF1;&#xED;a Limitada&quot; (Transportes Aconcagua - Santiago T.A.S. Choapa Limitada o T.A.S. Choapa Limitada), para atender el servicio internacional de transporte terrestre de pasajeros entre &quot;Temuco y San Mart&#xED;n de Los Andes&quot;, por Paso Tromen. </div></div>", "i": 6957484}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de Enero de 1985.- Carlos Villegas Lorca, Subsecretario de Transportes subrogante.</div><br></div>", "i": 6957485}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "94", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-94"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-29", "doble_articulado": false, "id_norma": "164382", "numero_fuente": "32091", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-02-07", "vigencias": [{"desde": "1985-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio