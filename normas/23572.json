{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede fondos para socorrer a las v&#xED;ctimas del incendio del edificio Ross de Valparaiso</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m 2,892.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275696}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir de rentas jenerales, hasta la suma de cincuenta mil pesos ($ 50,000) para socorrer a las v&#xED;ctimas del incendio del edificio Ross de Valparaiso.</div><br></div>", "i": 8275697}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 20 de Mayo de 1914.- RAMON BARROS LUCO.- Rafael Orrego.</div><br></div>", "i": 8275698}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2892", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2892"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE FONDOS PARA SOCORRER A LAS VICTIMAS DEL INCENDIO DEL EDIFICIO ROSS DE VALPARAISO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VALPARAISO", "EDIFICIO ROSS", "PRESIDENTE DE LA", "REPUBLICA", "DAMMIFICADOS", "AUTORIZACION", "FONDOS", "DESTINACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1914-05-20", "doble_articulado": false, "id_norma": "23572", "numero_fuente": "10901", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1914-06-22", "vigencia