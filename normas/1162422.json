{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10249715}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; DN-01138/2021, de 30 de junio de 2021, de este Servicio, se constata la no concurrencia de causales de caducidad artesanal por parte de pescadores de conformidad a la <a href=\"https://www.leychile.cl/Navegar?idNorma=1149237&amp;idParte=&amp;idVersion=\">Ley 21.259</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra publicado con esta fecha en el sitio de dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y en el de la Subsecretar&#xED;a de Pesca y Acuicultura.</div><div class=\"p\"> </div></div>", "i": 10249716}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de junio de 2021.- Jessica Fuentes Olmos, Directora Nacional (S), Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\"> </div><br></div>", "i": 10249717}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1138 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1138 EXENTA"}, {"tipo": "3", "numero": "DN-01138/2021 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-DN-01138/2021 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1973880", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-06-30", "doble_articulado": false, "id_norma": "1162422", "numero_fuente": "42998", "t