{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 3.242 EXENTA, DE 2002 </div></div>", "i": 6380664}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 3.242, de 20 de marzo del a&#xF1;o 2002, se ha aprobado al Liceo A-43 (Siete de Ni&#xF1;as) de Santiago, un plan de estudio para 4&#xBA; a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; simult&#xE1;neamente en todos los cursos a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en la presente resoluci&#xF3;n.</div><br><br></div>", "i": 6380665}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de marzo de 2002.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6380666}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3242 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3242 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 3.242 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-20", "doble_articulado": false, "id_norma": "197854", "numero_fuente": "37254", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-09", "vigencias": [{"desde": "2002-05-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado