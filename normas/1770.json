{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5845101}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 6,55% anual duante el mes de enero de 1994.</div><div class=\"p\">&nbsp; &nbsp; Asimismo, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1 del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de enero de 1994, fue de 6,58% anual. </div></div>", "i": 5845102}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 3 de febrero de 1994.- Jorge Carrasco V&#xE1;squez, Ministro de Fe (S).</div><br></div>", "i": 5845103}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TIP", "TASA INTERES PROMEDIO", "CAPTACION", "OPERACIONES CREDITO DINERO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-02-03", "doble_articulado": false, "id_norma": "1770", "numero_fuente": "34783", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-02-05", "vigencias": [{"desde": "1994-02-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-02-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-02-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [