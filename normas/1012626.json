{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 452 EXENTA, DE 2010</div></div>", "i": 8912050}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Res. Ex. N&#xBA; 452, de 24.2.2010 autoriza al siguiente taller para adecuar veh&#xED;culos al uso de gas natural comprimido como combustible:</div><br><div class=\"p\">Empresa Habilitada&nbsp;  Nombre del Taller&nbsp;  Direcci&#xF3;n </div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  del Taller&nbsp; &nbsp;  Ciudad</div><div class=\"p\">Sociedad de </div><div class=\"p\">Proyectos y </div><div class=\"p\">Tecnolog&#xED;a </div><div class=\"p\">Gastech Ltda.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Halin Ltda.&nbsp; &nbsp; &nbsp; Exposici&#xF3;n </div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; N&#xBA; 1402&nbsp; &nbsp; &nbsp; &nbsp; Santiago</div><br><div class=\"p\">&nbsp; &nbsp;  Autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.- </div><br></div>", "i": 8912051}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gloria Hutt Hesse, Subsecretaria de Transportes.</div></div>", "i": 8912052}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "452 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-452 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 452 EXENTA, DE 2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_t