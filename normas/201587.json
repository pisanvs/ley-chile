{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6392860}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.113, de fecha 28 de junio de 2002, se expropi&#xF3; el lote de terreno N&#xBA;52-A, superficie 578 m2, rol de aval&#xFA;o 2213-125, comuna de Chill&#xE1;n, VIII Regi&#xF3;n, para la obra &apos;&apos;Camino Ruta N-45, Sector Cruce Ruta N-49 (Chill&#xE1;n) - La Capilla - Tres Esquinas, Km.</div><div class=\"p\">6,26000 al 28,54000&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria do&#xF1;a Lila Edith Carrasco Lanza, ascendente a la cantidad de $3.108.729.- </div></div>", "i": 6392861}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6392862}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1113", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1113"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-28", "doble_articulado": false, "id_norma": "201587", "numero_fuente": "37335", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-08-16", "vigencias": [{"desde": "2002-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PSO", "fecha_ingreso": "2002-08-16", "fecha_version": "2002-08-16", "fecha_actualizacion_texto": "2002-08-16",