{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA DE ASOCIACION GREMIAL QUE INDICA </div></div>", "i": 6239985}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 24, de 19 de Febrero de 1985, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la personalidad jur&#xED;dica de la &quot;Asociaci&#xF3;n Gremial de Empresarios Central Bus&quot;, inscrita bajo el N&#xB0; 1.251 en el Registro de Asociaciones Gremiales, por haberse configurado respecto de ella la causal establecida en el art&#xED;culo 5&#xB0; inciso 3&#xB0; del DL 2.757. El destino de los bienes ser&#xE1; determinado por el Presidente de la Rep&#xFA;blica.-</div><br></div>", "i": 6239986}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jorge Valenzuela Dur&#xE1;n, Coronel de Ej&#xE9;rcito, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 6239987}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "24", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-24"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA DE ASOCIACION GREMIAL QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-02-19", "doble_articulado": false, "id_norma": "157930", "numero_fuente": "32128", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-22", "vigencias": [{"desde": "1985-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-22