{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,867.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 7250107}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- El art&#xED;culo 5.&#xBA; de la Lei de Reorganizaci&#xF3;n de los Ferrocarriles del Estado, en lo referente al nombramiento de los&nbsp; consejeros, i la presente lei, comenzar&#xE1; a rejir desde su publicacion en el Diario Oficial.</div><br></div>", "i": 7250108, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintinueve de enero de mil novecientos catorce.- Ramon Barros Luco.- Rafael Orrego.</div><br></div>", "i": 7250109}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2867", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2867"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1914-01-29", "doble_articulado": false, "id_norma": "138416", "numero_fuente": "10786", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1914-01-30", "vigencias": [{"desde": "1914-01-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1914-01-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1914-01-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi