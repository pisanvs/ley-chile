{"html": [{"t": "<div><div class=\"p\">APRUEBA DISOLUCION ANTICIPADA DE LA COMPA&#xD1;IA DE SEGUROS DE VIDA &quot;SEGUROS PREBAN S.A.&quot; </div></div>", "i": 6076723}, {"t": "<div><div class=\"p\">Certifico: Que por resoluci&#xF3;n No. 86 de fecha 17.06.91, se aprob&#xF3; la disoluci&#xF3;n anticipada de la Compa&#xF1;&#xED;a de Seguros de Vida &quot;Seguros Preban S.A.&quot;, que consta de la escritura p&#xFA;blica de fecha 10.05.91, otorgada en la Notar&#xED;a de Santiago de don Aliro Veloso Mu&#xF1;oz, autoriz&#xE1;ndola a practicar su propia liquidaci&#xF3;n, la que estar&#xE1; a cargo de una Comisi&#xF3;n compuesta por don Patricio Latrach Guerrero, don Sergio Serrano Cavieres y do&#xF1;a Luz M. Vergara Fisher. </div></div>", "i": 6076724}, {"t": "<div><div class=\"p\">- Rodrigo O. Costa Aranda, Secretario General. </div></div>", "i": 6076725}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "86", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-86"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "APRUEBA DISOLUCION ANTICIPADA DE LA COMPAÑIA DE SEGUROS DE VIDA SEGUROS PREBAN S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-06-17", "doble_articulado": false, "id_norma": "87611", "numero_fuente": "34008", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-07-04", "vigencias": [{"desde": "1991-07-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-07-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-07-04", "fin_vigencia": "", "tipo_version": "3"}],