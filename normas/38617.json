{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6021517}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n Exenta N&#xB0; 238 de 18 de Febrero de 1994 del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Trasportes, se autoriz&#xF3; a la sociedad Gonz&#xE1;lez y Compa&#xF1;&#xED;a Limitada (Transporte Aconcagua Santiago T.A.S. Choapa Limitada o T.A.S. Choapa Limitada) para prolongar el servicio internacional de transporte terrestre de pasajeros entre Santiago (Chile) y San Luis-C&#xF3;rdoba (Argentina) hasta Villa Carlos Paz (Argentina) y Vi&#xF1;a del Mar (Chile) durante el per&#xED;odo comprendido entre el 1&#xB0; de Diciembre y el 30 de Abril de cada a&#xF1;o.-</div><br></div>", "i": 6021518}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Jaime Herrera Ferrada, Subsecretario de Transportes Subrogante.</div><br></div>", "i": 6021519}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "238", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-238"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD GONZALEZ COMPA IA LIMITADA", "TRANSPORTE ACONCAGUA SANTIAGO", "T.A.S. CHOAPA LIMITADA", "TRANSPORTE INTERNACIONAL", "SERVICIO PUBLICO TRANSPORTE PASAJEROS", "CHILE", "ARGENTINA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-02-18", "doble_articulado": false, "id_norma": "38617", "numero_fuente": "34813", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-03-12", "vigencias": [{"desde": "1994-03-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-03-12", "f