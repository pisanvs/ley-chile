{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8321758}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.851, de 29 de Noviembre de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n No. 201, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don Sixto Villarroel Molina, R.U.T. No. 2.290.281-4, domiciliado en la Comuna de Calbuco, lugar El Rosario, direcci&#xF3;n postal Correo de Calbuco, para iniciar actividades pesqueras, en orden a sustituir en su numeral 2&#xB0;, la expresi&#xF3;n &quot;en un &#xE1;rea de 4.000 m2.&quot; por &quot;en un &#xE1;rea de 4.000 m2. de sector de playa&quot;. </div></div>", "i": 8321759}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 29 de Noviembre de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8321760}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1851", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1851"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-11-29", "doble_articulado": false, "id_norma": "92403", "numero_fuente": "33557", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-12-29", "vigencias": [{"desde": "1989-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-12-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-12-29", "fin_vigencia"