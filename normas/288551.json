{"html": [{"t": "<div><div class=\"p\">&amp;#160;</div></div>", "i": 8499388}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA;456, de 27 de febrero de 2009, se dej&#xF3; sin efecto el decreto MOP N&#xB0; 928, de 18 de octubre de 2004, que ordenaba la expropiaci&#xF3;n del lote de terreno N&#xBA;13, para la obra &quot;Sistema Am&#xE9;rico Vespucio Nor - Poniente. Av. El Salto - Ruta 78. Tramo 1: El Salto - Avenida Pedro Fontova&quot;, debido a que se obtuvo el terreno necesario para la construcci&#xF3;n del colector respectivo, a trav&#xE9;s de la constituci&#xF3;n de una servidumbre de acueducto a favor del Fisco, y en consecuencia ya no fue necesaria la expropiaci&#xF3;n del citado lote N&#xBA;13. </div></div>", "i": 8499389}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 8499390}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "456 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-456 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-02-27", "doble_articulado": false, "id_norma": "288551", "numero_fuente": "39327", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-04-01", "vigencias": [{"desde": "2009-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "i