{"html": [{"t": "<div><div class=\"p\">PRORROGA AUTORIZACION QUE INDICA </div></div>", "i": 8321098}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.509 de 25 de Octubre de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por dos meses a contar del 25 de octubre de 1989, el plazo otorgado a Pesquera Split S.A., RUT No. 96.516.190-2, domiciliada en Iquique, para empezar a operar la embarcaci&#xF3;n autorizada por la resoluci&#xF3;n No. 889, de 1988, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor. </div></div>", "i": 8321099}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 25 de Octubre de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8321100}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1509", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1509"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-10-25", "doble_articulado": false, "id_norma": "92039", "numero_fuente": "33528", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-11-22", "vigencias": [{"desde": "1989-11-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-11-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-11-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_pa