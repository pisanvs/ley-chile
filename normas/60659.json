{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9047764}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento de Educaci&#xF3;n N&#xBA; 279 de 30 de Septiembre de 1986 se complement&#xF3;, ampli&#xF3; y modific&#xF3; el Decreto Exento de Educaci&#xF3;n N&#xBA; 57&nbsp; de 14 de Abril de 1982, que autoriza el funcionamiento del Instituto Profesional de Providencia.</div><div class=\"p\">&nbsp; &nbsp;  La complementaci&#xF3;n se refiere al organizador, la ampliaci&#xF3;n a la autorizaci&#xF3;n de nuevas Sedes y la modificaci&#xF3;n incorporaci&#xF3;n al reglamento a que se refiere el Art. 6&#xBA; del D.F.L. N&#xBA; 5, de 1981, nuevas condiciones para el otorgamiento de los t&#xED;tulos profesionales y t&#xE9;cnicos a contar del a&#xF1;o acad&#xE9;mico 1986.</div><br></div>", "i": 9047765}, {"t": "<div><div class=\"p\">Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 9047766}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "279 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-279 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO PROFESIONAL DE PROVIDENCIA", "FUNCIONAMIENTO", "AUTORIZACION", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-09-30", "doble_articulado": false, "id_norma": "60659", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-11-08", "vigencias": [{"desde": "1986-11-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-11-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v