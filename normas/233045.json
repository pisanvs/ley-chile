{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6506895}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 610 de 28 de octubre de 2004 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme D.L. N&#xBA; 2.186 de 1978, del Lote N&#xBA; 68 correspondiente a parte del inmueble denominado Parcela N&#xBA; 37, aparentemente sin Rol de Aval&#xFA;o, comuna de Estaci&#xF3;n Central, aparente dominio de Empresa Metropolitana de Disposici&#xF3;n y Tratamiento de Basuras Limitada. Comisi&#xF3;n integrada por peritos Paola Domingo Porcella, Constructor Civil; Claudio Correa Barahona, Arquitecto, y Pedro Almonacid Colin, Ingeniero Civil. Seg&#xFA;n informe de fecha 5 de abril de 2004 fij&#xF3; monto provisional indemnizaci&#xF3;n en $26.586.600.- pagadera al contado. </div></div>", "i": 6506896}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6506897}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "610", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-610"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-28", "doble_articulado": false, "id_norma": "233045", "numero_fuente": "38025", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-01", "vigencias": [{"desde": "2004-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}]