{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9216125}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  De conformidad a lo dispuesto en al art. 105 del DFL MOP NO 850 de 1997, por Decreto MOP Exento N&#xBA;4471,de 29 de noviembre de 2011, se expropi&#xF3; el lote de terreno N&#xBA;18, superficie 141 m2, rol de Aval&#xFA;o 67-211, comuna de Lago Ranco, para la obra &quot;CONSTRUCCI&#xD3;N PUENTES CAICAYEN Y HUEINAHUE CAMINO MAIHUE - HUEINAHUE - RUPUMEICA&quot;, XIV Regi&#xF3;n, tasado con fecha 18 de junio de 2010, por la Comisi&#xF3;n de Peritos designada mediante Resoluci&#xF3;n SRM XIV Regi&#xF3;n N&#xBA;576, de fecha 1 de junio de 2010, acord&#xE1;ndose el valor de la indemnizaci&#xF3;n con sus propietarios SOF&#xCD;A ELIANA CARRILLO SANTIB&#xC1;&#xD1;EZ Y OTROS, en la cantidad de $1.159.425.-, suma que se pagar&#xE1; al contado.- </div><br></div>", "i": 9216126}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9216127}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "4471 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-4471 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-11-29", "doble_articulado": false, "id_norma": "1034359", "numero_fuente": "40135", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-12-15", "vigencias": [{"desde": "2011-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-12-15", "fin_vigencia": ""}, "vigencias_version_n