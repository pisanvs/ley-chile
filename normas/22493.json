{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Espediente de do&#xF1;a Estefan&#xED;a Donoso Lei n&#xFA;m. 1,239.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948658}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se rehabilita a do&#xF1;a Estefan&#xED;a Donoso, viuda del soldado del Batall&#xF3;n Chacabuco Nicolas Arroyo, para que pueda iniciar el respectivo espediente a fin de hacer valer sus derechos, con arreglo a la lei de 22 de Diciembre de 1881.</div><br><br></div>", "i": 5948659}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 29 de Julio de 1899.- Federico Err&#xE1;zuriz.- J. A. Figueroa.</div><br></div>", "i": 5948660}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1239", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1239"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "ESPEDIENTE DE DOÑA ESTEFANIA DONOSO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ESTEFANIA DONOSO VDA ARROYO", "REHABILITACION", "EXPEDIENTE", "TRAMITACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-07-29", "doble_articulado": false, "id_norma": "22493", "numero_fuente": "6363", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-08-01", "vigencias": [{"desde": "1899-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-08-01", "fin_vigencia": ""}, "vigencias