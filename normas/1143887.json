{"html": [{"t": "<div><div class=\"p\">FIANZAS A FAVOR DEL FISCO.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Agosto 1.&#xB0; de 1825.</div></div>", "i": 10116196}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Para evitar dudas se declara que las fianzas rendidas a favor fiscal por los empleados de cargo son estensivas a todos los ramos que les fueren encargados en todo el tiempo de su manejo. En su consecuencia y para intelijencia de los fiadores, el Tribunal de Cuentas, har&#xE1; rectificar todas las fianzas de dichos funcionarios, verificando lo mismo las Tesorer&#xED;as por las que hubiesen rendido sus Tenientes de Ministros.</div></div>", "i": 10116197}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, trascr&#xED;base e impr&#xED;mase. </div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><div class=\"p\">&nbsp; &nbsp;  Correa de Saa.</div></div>", "i": 10116198}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "FIANZAS A FAVOR DEL FISCO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-08-01", "doble_articulado": false, "id_norma": "1143887", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fe