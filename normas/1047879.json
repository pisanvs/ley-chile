{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 8.542 EXENTA, DE 20.12.2012</div><br></div>", "i": 9325201}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta se han modificado las resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=139891&amp;idParte=0&amp;idVersion=\">N&#xB0;s. 4.091</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=166397&amp;idParte=0&amp;idVersion=\">12.883</a>, ambas de 1999; y <a href=\"https://www.leychile.cl/Navegar?idNorma=181632&amp;idParte=0&amp;idVersion=\">349, de 2001</a>, todas del Ministerio de Educaci&#xF3;n, que aprob&#xF3; planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Colegio Nido de &#xC1;guilas, comuna de Lo Barnechea, de Santiago.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio del Sector Chino Mandar&#xED;n, en el Plan de Formaci&#xF3;n General (Electivo) para 1&#xBA; y 2&#xBA; a&#xF1;o de Educaci&#xF3;n Media y en el Plan de Formaci&#xF3;n Diferenciada, para 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media.</div><br></div>", "i": 9325202}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de diciembre de 2012.- Ricardo H.C. Evangelista, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 9325203}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8542 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-8542 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "DIVISIÓN DE EDUCACIÓN GENERAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 8.542 EXENTA, DE 20.12.2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogaci