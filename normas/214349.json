{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp;  ACUERDO N&#xBA;34, DE 2003 </div></div>", "i": 6438276}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se pone en conocimiento del p&#xFA;blico de la Comuna de Colina que, por acuerdo N&#xBA;34/2003 del Honorable Concejo Municipal, adoptado en sesi&#xF3;n ordinaria N&#xBA;11, de fecha 12 de junio de 2003, se aprob&#xF3; la &quot;Ordenanza Local sobre mantenci&#xF3;n de &#xE1;reas verdes y especies vegetales en espacios de uso p&#xFA;blico&quot;. A contar de esta fecha y por el plazo de 30 d&#xED;as, el texto de esta Ordenanza se encontrar&#xE1; a la vista y disposici&#xF3;n del p&#xFA;blico en la Oficina de Partes, donde podr&#xE1; ser solicitado de lunes a viernes de 8:30 a 14:00 horas.- </div></div>", "i": 6438277}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mario Olavarr&#xED;a Rodr&#xED;guez, Alcalde de I. Municipalidad de Colina.</div><br></div>", "i": 6438278}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "34", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-34"}], "organismos": ["MUNICIPALIDAD DE COLINA"], "titulo_norma": "ACUERDO Nº34, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-12", "doble_articulado": false, "id_norma": "214349", "numero_fuente": "37651", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-03", "vigencias": [{"desde": "2003-09-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-09-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes"