{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6316953}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;5.017, de fecha 31 de octubre de 2000, se expropi&#xF3; el lote de terreno N&#xBA;1-B, superficie 192 m&#xB2;, rol de aval&#xFA;o 85-9, comuna de Marchigue, para la obra &apos;&apos;Camino Ruta I-150, Sector Nancagua-Santa Cruz, Tramo Km.</div><div class=\"p\">26,800 a Km. 42,321&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Agr&#xED;cola y Forestal Bandurrias Limitada, ascendente a la cantidad de $453.791.</div><br></div>", "i": 6316954}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6316955}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "5017", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-5017"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-31", "doble_articulado": false, "id_norma": "180373", "numero_fuente": "36862", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-15", "vigencias": [{"desde": "2001-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2001-01-16", "fecha_version": "2001-01-15", "fecha_actualizacion_texto": "2001-01-15", "tipo_tratado": ""}, "alertas": [], "alert