{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACION DE EMISOR ELECTRONICO </div></div>", "i": 6584898}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 115, de 29 de septiembre de 2006, que deroga autorizaci&#xF3;n otorgada a contribuyente para operar como emisor electr&#xF3;nico.</div><div class=\"p\">&nbsp; &nbsp;  Se deroga autorizaci&#xF3;n otorgada a contribuyente RUT N&#xBA; 10.188.557-7, para operar como emisor de Documentos Tributarios Electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de septiembre de 2006. </div></div>", "i": 6584899}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "115 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-115 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEROGA AUTORIZACION DE EMISOR ELECTRONICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-09-29", "doble_articulado": false, "id_norma": "253828", "numero_fuente": "38581", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-10-05", "vigencias": [{"desde": "2006-10-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-10-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-10-05", "fin_vigencia": "", "tipo_ve