{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6276334}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA; 33, de fecha 31 de marzo del a&#xF1;o 2000, se autoriz&#xF3; la existencia y se aprobaron los estatutos de la Cooperativa de Trabajo Central de la Construcci&#xF3;n Obispo Enrique Alvear Limitada, de Santiago, en los t&#xE9;rminos que dan testimonio los instrumentos protocolizados con fecha 5 de octubre de 1999, 21 de enero del a&#xF1;o 2000, y 6 de marzo del a&#xF1;o 2000, todos ante el Notario de Santiago, don Ra&#xFA;l Perry Pefaur, bajo los n&#xFA;meros 26, 129 y 45 respectivamente.</div><br></div>", "i": 6276335}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Sr. Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas.</div><br></div>", "i": 6276336}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "33", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-33"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-03-31", "doble_articulado": false, "id_norma": "169014", "numero_fuente": "36669", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-22", "vigencias": [{"desde": "2000-05-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-22", "fin_vigenc