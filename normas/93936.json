{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA N&#xB0; 3.007, DE 1988 </div></div>", "i": 7228305}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta N&#xB0; 3.007 de fecha 09 de Noviembre de 1988, de la Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica, se insertaron las adecuaciones introducidas a la carrera de Sonido del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto AIEP, que fuera aprobada por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xB0; 2.722 de 1984 y se reemplazaron las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro mencionado, las que podr&#xE1;n aplicarse a contar del a&#xF1;o acad&#xE9;mico 1988.- </div></div>", "i": 7228306}, {"t": "<div><br><div class=\"p\">Paulina Dittborn Cordua, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 7228307}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3007 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3007 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N° 3.007, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-11-09", "doble_articulado": false, "id_norma": "93936", "numero_fuente": "33276", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-01-19", "vigencias": [{"desde": "1989-01-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-01-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-01-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION