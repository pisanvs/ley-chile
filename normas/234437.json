{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6512390}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.638, de 23 de diciembre de 2004, de esta Subsecretar&#xED;a, ampl&#xED;ase por 10 meses respecto del recurso Alfonsino y por 5 meses respecto del recurso Besugo, a contar del 23 de agosto de 2004, el plazo otorgado a PESQUERA SAN JOSE S.A., para iniciar actividades pesqueras extractivas con la nave &quot;Don Nordlund&quot;, respecto de cada uno de los recursos reci&#xE9;n indicados, por fuera del &#xE1;rea de reserva artesanal, en el &#xE1;rea mar&#xED;tima correspondiente a la Isla de Pascua, Archipi&#xE9;lago de Juan Fern&#xE1;ndez, Islas Sala y G&#xF3;mez e Islas Desventuradas, con arrastre y palangre, en virtud de haberse acreditado la circunstancia de fuerza mayor invocada por la peticionaria.</div><br></div>", "i": 6512391}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de diciembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6512392}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3638 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3638 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-12-23", "fecha_derogacion": "2011-09-07", "doble_articulado": false, "id_norma": "234437", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-01-07", "vigencias": [{"desde": "2011-09-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "