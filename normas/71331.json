{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6036688}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 224, de 14 de marzo de 1997, el Fisco se desisti&#xF3; parcialmente de la expropiaci&#xF3;n para la Empresa Metropolitana de Obras Sanitarias S.A., correspondiente al lote N&#xBA; 2, destinado a la ejecuci&#xF3;n de la obra Programa de Tratamiento A.S., del Gran Santiago, Planta de Tratamiento A.S., Santiago Sur, aprobada por Decreto M.O.P. N&#xBA; 698, de fecha 22 de noviembre de 1995, en lo que respecta a una superficie de 80.000 m2., que se individualiza en el plano y cuadro de expropiaci&#xF3;n respectivo.</div><br></div>", "i": 6036689}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6036690}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "224", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-224"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SANTIAGO", "REGION METROPOLITANA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-14", "doble_articulado": false, "id_norma": "71331", "numero_fuente": "35766", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-15", "vigencias": [{"desde": "1997-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por"