{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede fondos para dotar de mobiliario la Intendencia de Valdivia</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1792.- Santiago, a 25 de Enero de 1906.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274691}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir la suma de seis mil pesos en dotar de mobiliario a la Intendencia de Valdivia i cuatro mil pesos a la Gobernacion de Pisagua. </div></div>", "i": 8274692}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Miguel Cruchaga.</div><br></div>", "i": 8274693}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1792", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1792"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE FONDOS PARA DOTAR DE MOBILIARIO LA INTENDENCIA DE VALDIVIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INTENDENCIA VALDIVIA", "MOBILIARIO", "ADQUISICION", "FONDOS", "INVERSION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-01-25", "doble_articulado": false, "id_norma": "22918", "numero_fuente": "8413", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1906-01-25", "vigencias": [{"desde": "1906-01-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1906-01-25", "fin_vigencia": ""}