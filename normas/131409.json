{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8340579}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;92, de 21 de enero de 1999, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por el t&#xE9;rmino de 6 meses, contados a partir de la fecha de t&#xE9;rmino de la veda del recurso Jurel, el plazo otorgado a PESQUERA IQUIQUE-GUANAYE S.A., para reiniciar operaciones de pesca con las naves &apos;&apos;Carmen&apos;&apos; e &apos;&apos;Icalma&apos;&apos; en la unidad de pesquer&#xED;a del recurso Jurel de la III y IV Regiones, autorizadas mediante resoluciones N&#xBA;609, de 1993 y N&#xBA;162, de 1996, ambas de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor.</div><br></div>", "i": 8340580}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de enero de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8340581}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "92", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-92"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-01-21", "fecha_derogacion": "2000-02-01", "doble_articulado": false, "id_norma": "131409", "numero_fuente": "36282", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-02-05", "vigencias": [{"desde": "2000-02-01", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"de