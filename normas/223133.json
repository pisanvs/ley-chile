{"html": [{"t": "<div><div class=\"p\">RESOLUCION EXENTA N&#xBA; 1.197, DEL 24 DE MARZO DE 2004 </div></div>", "i": 6471620}, {"t": "<div><div class=\"p\">1.&nbsp;  Susp&#xE9;ndase la entrada en vigencia de la aplicaci&#xF3;n de las normas para la transmisi&#xF3;n electr&#xF3;nica de los manifiestos de carga por v&#xED;a a&#xE9;rea en la Aduana Metropolitana, se&#xF1;alada en el segundo p&#xE1;rrafo del numeral 2 de la resoluci&#xF3;n N&#xBA; 428 del 30 de enero de 2004.</div><div class=\"p\">2.&nbsp;  Contin&#xFA;ese con el sistema de transmisi&#xF3;n electr&#xF3;nica de los manifiestos de carga por v&#xED;a a&#xE9;rea, en la Aduana Metropolitana, de acuerdo a lo se&#xF1;alado en el primer p&#xE1;rrafo del numeral 2 de la resoluci&#xF3;n N&#xBA; 428 de 2004.</div><br></div>", "i": 6471621}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Ra&#xFA;l Allard Neuman, Director Nacional de Aduanas. </div></div>", "i": 6471622}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1197 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1197 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS"], "titulo_norma": "RESOLUCION EXENTA Nº 1.197, DEL 24 DE MARZO DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ADUANA METROPOLITANA", "MANIFIESTOS DE CARGA POR VIA AEREA", "TRANSMISION ELECTRONICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-24", "doble_articulado": false, "id_norma": "223133", "numero_fuente": "37825", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-31", "vigencias": [{"desde": "2004-03-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigen