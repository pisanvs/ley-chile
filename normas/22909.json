{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AUTORIZA LA RESIDENCIA DE LOS CUERPOS DEL EJERCITO EN EL LUGAR DE LAS SESIONES DEL CONGRESO NACIONAL.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1780.-Santiago, a 14 de Diciembre de 1905.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7164415}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.-Perm&#xED;tese, por el t&#xE9;rmino de un a&#xF1;o, la residencia de los cuerpos de Ej&#xE9;rcito permanente en el lugar de las sesiones del Congreso Nacional i diez leguas a su circunferencia.</div><br></div>", "i": 7164416}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JERMAN RIESCO.-Manuel F&#xF3;ster R.</div><br></div>", "i": 7164417}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1780", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1780"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "AUTORIZA LA RESIDENCIA DE LOS CUERPOS DEL EJERCITO EN EL LUGAR DE LAS SESIONES DEL CONGRESO NACIONAL.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONGRESO NACIONAL", "LUGAR SESIONES", "CUERPOS EJERCITO", "RESIDENCIA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-12-14", "doble_articulado": false, "id_norma": "22909", "numero_fuente": "8380", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-12-14", "vigencias": [{"desde": "1905-12-14", "hasta": "", "tipo_version": "3", "ti