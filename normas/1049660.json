{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA A LOS DIRECTORES REGIONALES PARA DELEGAR FACULTAD QUE INDICA</div></div>", "i": 9340032}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 35 del 22 de marzo de 2013, que dispone:</div><br><div class=\"p\">.&nbsp; &nbsp; Autoriza a los Directores Regionales para delegar en los Jefes de Avaluaciones y en los Jefes de Unidades la facultad de requerir informaci&#xF3;n a las municipalidades, conforme a lo previsto en el art&#xED;culo 87 del C&#xF3;digo Tributario.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en marzo de 2013.</div></div>", "i": 9340033}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "35 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-35 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A LOS DIRECTORES REGIONALES PARA DELEGAR FACULTAD QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-03-22", "doble_articulado": false, "id_norma": "1049660", "numero_fuente": "40519", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-03-26", "vigencias": [{"desde": "2013-03-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-03-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig