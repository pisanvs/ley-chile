{"html": [{"t": "<div><div class=\"p\">DIRECTOR JENERAL DE PUENTES Y CAMINOS.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Marzo 6 de 1828.</div><div class=\"p\">&nbsp; &nbsp;  El Vice-Presidente de la Rep&#xFA;blica ha acordado y decreta:</div><br></div>", "i": 10237430}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. 1.&#xB0;&nbsp; N&#xF3;mbrase director jeneral de puentes y caminos al Teniente cononel de ingenieros D. Santiago Ballarna.</div><br></div>", "i": 10237431}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  2.&#xB0;&nbsp; Se le asistir&#xE1; con el sobre sueldo o gratificacion se&#xF1;alada por la ordenanza a los oficiales de injenieros en comision.</div><br></div>", "i": 10237432}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  3.&#xB0;&nbsp; Recibir&#xE1; de la Tesorer&#xED;a jeneral las cantidades que el Gobierno decretare en vista de los presupuestos de gastos que presente el nombrado, y que deber&#xE1; aquella cargar al ramo de caminos.</div><br></div>", "i": 10237433}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  4.&#xB0;&nbsp; T&#xF3;mese razon donde corresponda y comun&#xED;quese.</div></div>", "i": 10237434}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  PINTO</div><div class=\"p\">&nbsp; &nbsp;  Rodr&#xED;guez.</div></div>", "i": 10237435}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DIRECTOR JENERAL DE PUENTES Y CAMINOS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1828-03-06", "doble_articulado": false, "id_norma": "1155967", "numero_fuente": "