{"html": [{"t": "<div><div class=\"p\">DISPONE EXPROPIACION PARCIAL DE INMUEBLE</div><br><br><br></div>", "i": 6182242}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Decreto Secc. 2&#xAA; N&#xBA; 557, julio 26 de 1999, Alcalde I. Municipalidad de Santiago, dispone expropiaci&#xF3;n parcial conforme Art. 85 decreto 458 Ministerio Vivienda, inmueble Uni&#xF3;n Latinoamericana N&#xBA; 37, Rol 565-004, comuna Santiago, dominio aparente Reyscallah Nasser Nasar, superficie aproximada 19,52 m&#xB2; deslindes: Norte, 3,55 metros otro propietario; Sur, 3,55 metros otro propietario; Oriente, 5,50 metros calle Uni&#xF3;n Latinoamericana; Poniente, 5,50 metros resto predio. Indemnizaci&#xF3;n $6.684.332, pagadera contado con mayor valor experimente resto inmueble con expropiaci&#xF3;n.- </div></div>", "i": 6182243}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jaime Ravinet de la F. Alcalde Santiago. </div></div>", "i": 6182244}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "557", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-557"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "DISPONE EXPROPIACION PARCIAL DE INMUEBLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-07-26", "doble_articulado": false, "id_norma": "140495", "numero_fuente": "36440", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-08-16", "vigencias": [{"desde": "1999-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi