{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8347219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.265, de 9 de julio de 1999, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA COLOSO S.A., para ampliar actividades pesqueras extractivas con la nave &apos;&apos;Huayquique&apos;&apos;. La interesada podr&#xE1; operar dicha nave en el litoral de la I y II Regiones donde podr&#xE1; capturar por fuera del &#xE1;rea de reserva artesanal, y con red de cerco, los recursos Anchoa blanca y Vinciguerria. </div></div>", "i": 8347220}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de julio de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8347221}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1265", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1265"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-07-09", "fecha_derogacion": "2000-03-30", "doble_articulado": false, "id_norma": "139765", "numero_fuente": "36426", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-07-30", "vigencias": [{"desde": "2000-03-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-07-30", "hasta": "2000-03-29", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2000-03-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-07-30", "fin_vigencia": "2000-03-29", "tipo_version": "0"}, {