{"html": [{"t": "<div><div class=\"p\">AUTORIZA A EMISORES DE BOLETAS ELECTR&#xD3;NICAS </div></div>", "i": 8164859}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 28, de 26 de febrero de 2009, que autoriza a contribuyentes como emisores de boletas electr&#xF3;nicas.</div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisores de boletas electr&#xF3;nicas, a contar del mes de febrero de 2009, a los contribuyentes RUT N&#xBA;96.755.580-0 y RUT N&#xBA; 96.773.290-7.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de febrero de 2009.</div><br></div>", "i": 8164860}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "28 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-28 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A EMISORES DE BOLETAS ELECTRÓNICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-02-26", "doble_articulado": false, "id_norma": "287715", "numero_fuente": "39302", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-03-03", "vigencias": [{"desde": "2009-03-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-03-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-03-03", "fin_vigencia": "", "tipo_version": "3"}]