{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8331592}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 906, de 30 de junio de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 173 de 1997 de esta Subsecretar&#xED;a, que autoriz&#xF3; a ALIMENTOS MARINOS S.A., para operar por sustituci&#xF3;n la nave &apos;&apos;Ranquilhue&apos;&apos;, s&#xF3;lo en lo relativo a las especies Anchoveta y Sardina espa&#xF1;ola, en el litoral de la III y IV Regiones.</div><br></div>", "i": 8331593}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de junio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8331594}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "906", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-906"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "ALIMENTOS MARINOS S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-06-30", "fecha_derogacion": "1998-12-18", "doble_articulado": false, "id_norma": "120895", "numero_fuente": "36108", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-07-08", "vigencias": [{"desde": "1998-12-18", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-07-08", "hasta": "1998-12-17", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1998-12-18", "fin_vigencia": ""}, "