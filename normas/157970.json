{"html": [{"t": "<div><div class=\"p\">PRORROGA PLAZO QUE INDICA A LA SOCIEDAD PESQUERA INTERPESCA S.A.</div><br></div>", "i": 6240170}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 388 de 8 de Julio de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga hasta el 31 de Diciembre de 1985, el plazo de vigencia otorgado a la Sociedad Pesquera Interpesca S.A., para realizar actividades de pesca exploratoria del calamar, en los mismos t&#xE9;rminos establecidos en la resoluci&#xF3;n No. 613, de 1984, de la misma Subsecretar&#xED;a.</div><br></div>", "i": 6240171}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de Julio de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6240172}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "388", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-388"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA PLAZO QUE INDICA A LA SOCIEDAD PESQUERA INTERPESCA S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-07-08", "doble_articulado": false, "id_norma": "157970", "numero_fuente": "32221", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-07-13", "vigencias": [{"desde": "1985-07-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-07-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-07-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones