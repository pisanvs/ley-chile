{"html": [{"t": "<div><div class=\"p\">MODIFICACIONES AL ART&#xCD;CULO 21 Y 70 LIVS POR LEY N&#xBA; 21.398</div></div>", "i": 10329049}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de circular del Servicio de Impuestos Internos N&#xBA; 19, del 19 de abril de 2022, que imparte instrucciones sobre las modificaciones al art&#xED;culo 21 y 70 de la Ley sobre Impuesto a las Ventas y Servicios introducidas por el <a href=\"https://www.leychile.cl/Navegar?idNorma=1170464&amp;idParte=10296207&amp;idVersion=\">art&#xED;culo 4</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1170464&amp;idParte=&amp;idVersion=\">ley N&#xBA; 21.398</a>, que establece medidas para incentivar la protecci&#xF3;n de los derechos de los consumidores.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta circular ser&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl).- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10329050}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Hern&#xE1;n Andr&#xE9;s Frigolett C&#xF3;rdova, Director.</div><div class=\"p\"> </div><br></div>", "i": 10329051}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "19", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-19"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICACIONES AL ARTÍCULO 21 Y 70 LIVS POR LEY Nº 21.398", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2117960", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-04-19", "doble_articulado": false, "id_norma": "1175269", "numero_fuente": "43235", "tipo_version": "3", "tipo_versio