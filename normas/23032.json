{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,954 que concede jubilacion al preceptor don Pedro Anjel Barrenechea</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,954.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5952470}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, al preceptor jubilado don Pedro Anjel Barrenechea, derecho de acojerse a los beneficios que acuerda el art&#xED;culo 2.&#xB0; de la lei n&#xFA;m. 1,325, de 10 de enero de 1900.</div><br></div>", "i": 5952471}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 4 de Julio de 1907.- PEDRO MONTT.- E. Figueroa.</div><br></div>", "i": 5952472}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1954", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1954"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "LEI NUM. 1,954 QUE CONCEDE JUBILACION AL PRECEPTOR DON ANJEL BARRENECHEA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PEDRO ANGEL BARRENECHEA", "BENEFICIOS", "CONSECION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-07-04", "doble_articulado": false, "id_norma": "23032", "numero_fuente": "8842", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-07-06", "vigencias": [{"desde": "1907-07-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia