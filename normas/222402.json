{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACIONES QUE INDICAN</div><div class=\"p\">&nbsp; &nbsp;  NOTIFICACION </div></div>", "i": 6468781}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 89 de 26 de febrero de 2004 de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n conforme DL N&#xBA; 2.186 de 1978, parte inmueble ubicado en Arica N&#xBA; 3663, presunto rol de aval&#xFA;o N&#xBA; 907-08, comuna de Estaci&#xF3;n Central, aparente dominio de Elcader Marambio Juana. Comisi&#xF3;n integrada por peritos Roberto Correa Bezanilla, Arquitecto; Armando Antonio Pinochet Landero, Constructor Civil, y Germ&#xE1;n Alessandri Fabres, Ingeniero Civil. Seg&#xFA;n informe de 25 de octubre de 2003, fij&#xF3; monto provisional indemnizaci&#xF3;n en $6.347.300 pagadera al contado.-</div><br></div>", "i": 6468782}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Directora Serviu Metropolitano.</div><br></div>", "i": 6468783}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "89", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-89"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "ORDENA EXPROPIACIONES QUE INDICAN; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-26", "doble_articulado": false, "id_norma": "222402", "numero_fuente": "37811", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-15", "vigencias": [{"desde": "2004-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-03-15", "fin_vige