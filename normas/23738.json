{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aumenta el sueldo de los ayudantes del servicio de la Secretar&#xED;a del Senado</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,102.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275942}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- El&#xE9;vase a mil quinientos pesos ($ 1,500), el sueldo anual de cada uno de los ayudantes del servicio de la Secretar&#xED;a del Senado.</div><br></div>", "i": 8275943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 20 de Julio de 1916.- JUAN LUIS SANFUENTES.- Luis Izquierdo.</div><br></div>", "i": 8275944}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3102", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3102"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUMENTA EL SUELDO DE LOS AYUDANTES DEL SERVICIO DE LA SECRETARÍA DEL SENADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SECRETARIA", "SENADO", "AYUDANTES", "SUELDO", "REAJUSTE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-07-20", "doble_articulado": false, "id_norma": "23738", "numero_fuente": "11533", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-07-27", "vigencias": [{"desde": "1916-07-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1916-07-27", "fin_vigencia": ""}