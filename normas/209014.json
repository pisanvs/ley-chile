{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ley n&#xFA;m. 4,747</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6419525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- El&#xE9;vase, por gracia, a tres mil seiscientos pesos ($ 3,600) anuales la pensi&#xF3;n de montep&#xED;o de que actualmente disfruta la se&#xF1;ora Ema Claveau viuda de Vargas.</div><div class=\"p\">&nbsp; &nbsp;  El mayor gasto se imputar&#xE1; al &#xED;tem 06, cap&#xED;tulo 15, partida 06 del Presupuesto de Hacienda vigente. Esta ley regir&#xE1; desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 6419526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago treinta de Diciembre de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Bartolom&#xE9; Blanche E. </div></div>", "i": 6419527}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4747", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4747"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "Ley núm. 4,747", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-12-30", "doble_articulado": false, "id_norma": "209014", "numero_fuente": "15563", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-01-03", "vigencias": [{"desde": "1930-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1930-01-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1930-01-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PSO", "fecha_ingreso": "2003-04-03", "fecha_version": "1930-01-03", "fecha_actualizacion_texto": "1930-01-03", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6419525}, {"n": "Artículo UNICO", "i": 6419526, "t": 6}, {"n": "Promulgación", "i": 6419527}]}