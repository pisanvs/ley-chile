{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Internacion de Mercader&#xED;as para el Ej&#xE9;rcito Lei N&#xFA;m. 1,065.- Santiago, a 31 de Agosto de 1898.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948312}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir, durante el corriente a&#xF1;o, hasta la suma de ciento cincuenta mil pesos en pagos de derechos de Aduana por productos o mercader&#xED;as que se internen para el servicio del Ej&#xE9;rcito.</div><br><br></div>", "i": 5948313}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- V. Blanco.</div><br></div>", "i": 5948314}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1065", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1065"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "INTERNACION DE MERCADERIAS PARA EL EJERCITO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EJERCITO CHILE", "MERCADERIAS", "INTERNACION", "INVERSION", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-08-31", "doble_articulado": false, "id_norma": "22390", "numero_fuente": "6093", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-09-03", "vigencias": [{"desde": "1898-09-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-09-03", "fin_vigencia": ""}, "vigencias_