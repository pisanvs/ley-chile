{"html": [{"t": "<div><br><div class=\"p\">ESTABLECE CUOTA ANUAL DE CAPTURA DEL RECURSO ERIZO EN &#xC1;REA QUE INDICA</div></div>", "i": 10007929}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xB0; 42, de 14 de marzo de&nbsp; 2019, de este Ministerio, f&#xED;jase para el a&#xF1;o 2019 una cuota anual de captura de 15.500 toneladas del recurso erizo, a ser extra&#xED;das en el &#xE1;rea mar&#xED;tima de las regiones de Los Lagos y Ays&#xE9;n del General Carlos Ib&#xE1;&#xF1;ez del Campo, fraccionada de la siguiente forma:</div><div class=\"p\"> </div><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/90699.jpg\"></div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\"> </div></div>", "i": 10007930}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de marzo de 2019.- Eduardo Riquelme Portilla, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 10007931}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "42 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-42 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "ESTABLECE CUOTA ANUAL DE CAPTURA DEL RECURSO ERIZO EN ÁREA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1561966; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-03-14", "doble_articulado": false, "id_norma": "1129783", "numero_fuente": "42308", "tipo_version": "3", "