{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION EXENTA No. 0-2595, DE 1989 </div><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m.- 0-2.603 exenta.- Santiago, 08 de Septiembre de 1989.- Visto: Lo expuesto por el Director Regional del Servicio Electoral de la Novena Regi&#xF3;n, y la facultad que me conceden los art&#xED;culos 5 y 93 de la Ley No. 18.556,</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 7234419}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1&#xB0;. Modif&#xED;case el n&#xFA;mero 1&#xB0; de la Resoluci&#xF3;n Exenta 0-2595, de 01 de Septiembre de 1989, del Servicio Electoral, intercalando luego de la expresi&#xF3;n Collipulli, las palabras &quot;Traigu&#xE9;n, Lumaco, Capit&#xE1;n Pastene, Pichipellahu&#xE9;n&quot;.</div><div class=\"p\">&nbsp; &nbsp;  2&#xB0;. Rem&#xED;tase copia al se&#xF1;or Secretario de la Corte de Apelaciones de Temuco, para ser notificada conjuntamente con la Resoluci&#xF3;n que se modifica. </div></div>", "i": 7234420}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br><br></div>", "i": 7234421}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2603 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-2603 EXENTA"}, {"tipo": "3", "numero": "0-2603 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-0-2603 EXENTA"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "MODIFICA RESOLUCION EXENTA No. 0-2595, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-09-08", "