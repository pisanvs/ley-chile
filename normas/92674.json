{"html": [{"t": "<div><div class=\"p\">NOMBRA MINISTRO DE ESTADO EN CARTERA QUE INDICA </div><div class=\"p\">Santiago, 07 de Diciembre de 1989.- Hoy se decret&#xF3; lo que sigue:</div><br><div class=\"p\">N&#xFA;m. 1.909.- Visto: Lo dispuesto en el art&#xED;culo 32 No. 9 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica.</div><br><div class=\"p\">Decreto:</div><br></div>", "i": 8322200}, {"t": "<div><div class=\"p\">Art&#xED;culo &#xFA;nico.- N&#xF3;mbrase, a contar de esta fecha, como Ministro de Estado en la Cartera de Hacienda al Sr. Mart&#xED;n Costabal Llona.</div><br></div>", "i": 8322201}, {"t": "<div><div class=\"p\">An&#xF3;tese, t&#xF3;mese raz&#xF3;n, reg&#xED;strese y publ&#xED;quese.- AUGUSTO PINOCHET UGARTE, General de Ej&#xE9;rcito, Presidente de la Rep&#xFA;blica.- Carlos Francisco C&#xE1;ceres C.. Ministro del Interior.</div><div class=\"p\">Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Gonzalo Garc&#xED;a Balmaceda, Subsecretario del Inte rior. </div></div>", "i": 8322202}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1909", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1909"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARIA DEL INTERIOR"], "titulo_norma": "NOMBRA MINISTRO DE ESTADO EN CARTERA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-12-07", "doble_articulado": false, "id_norma": "92674", "numero_fuente": "33567", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-01-11", "vigencias": [{"desde": "1990-01-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-01-11", "f