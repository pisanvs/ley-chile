{"html": [{"t": "<div><br><div class=\"p\">CALIFICA A DEP&#xD3;SITO CENTRAL DE VALORES S.A. COMO ENTIDAD QUE INDICA</div></div>", "i": 9219615}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 144, del 15 de diciembre de 2011, que califica a Dep&#xF3;sito Central de Valores S.A., RUT N&#xBA; 96.666.140-2, como entidad susceptible de actuar como agente responsable para fines tributarios en Chile, de conformidad con la Res. Ex. SII N&#xBA; 36, de 2011.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de diciembre de 2011.</div></div>", "i": 9219616}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "144 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-144 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CALIFICA A DEPÓSITO CENTRAL DE VALORES S.A. COMO ENTIDAD QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-12-15", "doble_articulado": false, "id_norma": "1035184", "numero_fuente": "40139", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-12-20", "vigencias": [{"desde": "2011-12-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-12-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-12-20", "fin_vigencia