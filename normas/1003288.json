{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8683881}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.959, de 11 de noviembre de 2008, de esta Subsecretar&#xED;a, autor&#xED;zase a CECILIA DEL CARMEN WAGENKNECHT TORRES para iniciar actividades pesqueras de transformaci&#xF3;n, para iniciar y operar planta ubicada en Estero Quell&#xF3;n, pasaje Alberto Vanz s/n, Quell&#xF3;n, Chilo&#xE9;, X Regi&#xF3;n, para elaborar en las l&#xED;neas de proceso de Cocido, Fresco enfriado, Congelado, Ahumado, Conserva, Deshidratado y Sellado al vac&#xED;o, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div></div>", "i": 8683882}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de noviembre de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8683883}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2959 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-2959 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-11-11", "doble_articulado": false, "id_norma": "1003288", "numero_fuente": "39226", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-12-01", "vigencias": [{"desde": "2008-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-12-01", "fin_vigencia": "", "tipo_version": "3"}], "evento