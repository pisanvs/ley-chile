{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8655647}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.594, de 30 de abril de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a HERMAN NILO LILLO DUARTE para iniciar actividades pesqueras de transformaci&#xF3;n, para instalar y operar una planta ubicada en sector Carriel Norte, Parcela Uno, Lote Uno, Talcahuano, VIII Regi&#xF3;n, para elaborar en l&#xED;neas de Cocido, Fresco Enfriado, Fresco Refrigerado, Congelado, Ahumado, Conserva y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto las resoluciones N&#xBA; 1.087 de 2005 y N&#xBA;7 de 2008, ambas de esta Subsecretar&#xED;a.</div></div>", "i": 8655648, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de abril de 2009.- Mar&#xED;a &#xC1;ngela Barbieri Bellolio, Subsecretaria de Pesca (S).</div></div>", "i": 8655649}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1594 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-1594 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-04-30", "doble_articulado": false, "id_norma": "1002753", "numero_fuente": "39373", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-05-29", "vigencias": [{"desde": "2009-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-05-29