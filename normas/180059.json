{"html": [{"t": "<div><div class=\"p\">INFORMA DICTACION DE ORDENANZA Y REGLAMENTO </div></div>", "i": 6315976}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se comunica que la Ilustre Municipalidad de La Pintana, con fecha 20 de diciembre del 2000, ha dictado la ordenanza municipal N&#xBA; 1 del 2000, que aprueba la Ordenanza de Participaci&#xF3;n Ciudadana, y con fecha 21 de diciembre del 2000 el Reglamento N&#xBA; 2 del Consejo Econ&#xF3;mico y Social Comunal de La Pintana.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Los textos deben ser adquiridos en Secretar&#xED;a Municipal de la Ilustre Municipalidad de La Pintana. </div></div>", "i": 6315977}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese, publ&#xED;quese y arch&#xED;vese.- Jaime Pavez Moreno, Alcalde.- Angela Alvear Morales, Secretaria Municipal.</div><br></div>", "i": 6315978}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "1", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "ORZ-1"}], "organismos": ["MUNICIPALIDAD DE LA PINTANA"], "titulo_norma": "INFORMA DICTACION DE ORDENANZA Y REGLAMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-12-20", "doble_articulado": false, "id_norma": "180059", "numero_fuente": "36860", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-12", "vigencias": [{"desde": "2001-01-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-01-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por