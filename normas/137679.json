{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,695.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6172875}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a la viuda e hijas solteras del coronel don Vicente Montauban Z. una pensi&#xF3;n de doscientos pesos ($ 200)&nbsp; mensuales, de que gozar&#xE1;n con arreglo a la lei de montep&#xED;o militar. </div></div>", "i": 6172876}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese&nbsp; a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, cuatro de setiembre de mil novecientos doce.- Ramon Barros Luco.- Claudio Vicu&#xF1;a S.</div><br></div>", "i": 6172877}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2695", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2695"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-09-04", "doble_articulado": false, "id_norma": "137679", "numero_fuente": "10371", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-09-05", "vigencias": [{"desde": "1912-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-09-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-09-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresa