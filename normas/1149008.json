{"html": [{"t": "<div><div class=\"p\">ESTABLECE FORMA Y PLAZO PARA PRESENTAR DECLARACI&#xD3;N JURADA ANUAL QUE INDICA</div></div>", "i": 10155713}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 98, de fecha 28 de agosto de 2020, establece forma y plazo para presentar Declaraci&#xF3;n Jurada Anual sobre retiros, remesas y/o dividendos distribuidos y cr&#xE9;ditos correspondientes, efectuados por contribuyentes sujetos al r&#xE9;gimen de la letra a) y N&#xB0; 3 de la letra d) del <a href=\"https://www.leychile.cl/Navegar?idNorma=6368&amp;idParte=8656039&amp;idVersion=\">art&#xED;culo 14</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=6368&amp;idParte=&amp;idVersion=\">Ley sobre Impuesto a la Renta</a>, sobre saldo de retiros en exceso pendientes de imputaci&#xF3;n e informar y certificar lo que se indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento est&#xE1; publicado en &quot;www.sii.cl&quot;.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10155714}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fernando Javier Barraza Luengo, Director Nacional.</div><br></div>", "i": 10155715}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "98 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-98 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ESTABLECE FORMA Y PLAZO PARA PRESENTAR DECLARACIÓN JURADA ANUAL QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1809232", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "f