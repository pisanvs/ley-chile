{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N SII N&#xB0; 13 EX., DE 2016, RESPECTO UNIDAD QUE INDICA DEL DEPARTAMENTO SUBDIRECCI&#xD3;N DESARROLLO DE PERSONAS</div></div>", "i": 9828073}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 77 del 23 de agosto de 2017, que:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1088505&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n Ex SII N&#xB0; 13, de 2016</a>, reemplaza parte final Resolutivo Cuarto, agrega &#xC1;rea de Administraci&#xF3;n al Departamento de Formaci&#xF3;n de la Subdirecci&#xF3;n de Desarrollo de Personas.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de agosto de 2017.</div></div>", "i": 9828074}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "77 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-77 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCIÓN SII N° 13 EX., DE 2016, RESPECTO UNIDAD QUE INDICA DEL DEPARTAMENTO SUBDIRECCIÓN DESARROLLO DE PERSONAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1264155", "EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2017-08-23", "fecha_derogacion": "2021-12-28", "doble_articulado": false, "id_norma": "1107005", "numero_fuente": "4184