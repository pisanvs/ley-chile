{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 777 EXENTA, DE 16 DE FEBRERO DE 2017</div></div>", "i": 9840505}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=143739&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 5.885, de 1999, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; plan y programas de estudio para 1&#xBA; y 2&#xB0; a&#xF1;o de educaci&#xF3;n media, al Colegio Huel&#xE9;n, Comuna de Vitacura, Provincia de Santiago, Regi&#xF3;n Metropolitana, en el sentido de sustituir su plan de estudio de 1&#xB0; y 2&#xB0; a&#xF1;o de educaci&#xF3;n media por los que se indican en la presente resoluci&#xF3;n exenta y aprobar el programa de estudio para 1&#xB0; y 2&#xB0; a&#xF1;o de educaci&#xF3;n media de la asignatura de Ciencia Teol&#xF3;gica y &#xC9;tica que se acompa&#xF1;a en la presente resoluci&#xF3;n exenta.</div><br></div>", "i": 9840506}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de febrero de 2017.- Javier Jim&#xE9;nez D&#xED;az, Subsecretario de Educaci&#xF3;n (S).</div><div class=\"p\">\t</div></div>", "i": 9840507}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "777 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-777 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 777 EXENTA, DE 16 DE FEBRERO DE 2017", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1285994; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-02-16", "doble_articulado": false, "id_norma": "1108979", "numer