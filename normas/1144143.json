{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 10113727}, {"t": "<div><div class=\"p\">RESOLUCI&#xD3;N N&#xBA; 1.380 EXENTA, DE 01.04.2020, DEL DIRECTOR NACIONAL DE ADUANAS, QUE MODIFICA LOS ANEXOS N&#xBA;s 2 Y 3 DE LA RESOLUCI&#xD3;N N&#xBA; 487 EXENTA, DE 31.01.2020</div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.380, de 01.04.2020, del Director Nacional de Aduanas, se modifican los anexos N&#xBA;s 2 y 3 de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1142162&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 487, de 31.01.2020</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n exenta N&#xBA; 1.380, de 01.04.2020, se encuentra publicado en el sitio web del Servicio Nacional de Aduanas: www.aduana.cl.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10113728}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de abril de 2020.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><div class=\"p\"> </div><br></div>", "i": 10113729}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1380 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-1380 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "RESOLUCIÓN Nº 1.380 EXENTA, DE 01.04.2020, DEL DIRECTOR NACIONAL DE ADUANAS, QUE MODIFICA LOS ANEXOS Nºs 2 Y 3 DE LA RESOLUCIÓN Nº 487 EXENTA, DE 31.01.2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1748691", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-04-01", "doble_articulado": false, "id_norma": "1