{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6483975}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.470, de 25 de mayo de 2004 de esta Subsecretar&#xED;a, autor&#xED;zase a EMPRESA PESQUERA CRISTALMAR LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en calle Maip&#xFA; N&#xBA; 1221, Coquimbo, IV Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Fresco-Enfriado, Fresco-Refrigerado, Congelado, Seco-Salado, Ahumado, Conserva y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6483976}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de mayo de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6483977}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1470 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1470 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-05-25", "fecha_derogacion": "2006-10-06", "doble_articulado": false, "id_norma": "226595", "numero_fuente": "37890", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-06-21", "vigencias": [{"desde": "2006-10-06", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-06-21", "hasta": "2006-10-05", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2006-10-06", "fin_vigenci