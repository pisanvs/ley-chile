{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; RECTIFICACI&#xD3;N</div><br><br></div>", "i": 8573203}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n N&#xBA; 7, fecha 15 de enero de 2008, tramitada Contralor&#xED;a Regional con fecha 24 de enero de 2008, Direcci&#xF3;n Regional Serviu Regi&#xF3;n de Los Lagos rectific&#xF3; el resuelvo N&#xBA; 1 de la resoluci&#xF3;n N&#xBA; 178, de fecha 24 de septiembre de 2007, tramitada por Contralor&#xED;a con fecha 27 de septiembre de 2007, en el siguiente sentido: donde dice &quot;fojas 2.912 vuelta&quot;, debe decir &quot;291 vuelta&quot; y donde dice &quot;a&#xF1;o 1997&quot; debe decir &quot;a&#xF1;o 1999&quot;, la que orden&#xF3; la expropiaci&#xF3;n de terrenos en la ciudad de Quell&#xF3;n para la ejecuci&#xF3;n del Proyecto &quot;Habilitaci&#xF3;n Adquisici&#xF3;n Terrenos en Provincia de Chilo&#xE9;&quot;. La publicaci&#xF3;n se efect&#xFA;a conforme a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186. </div></div>", "i": 8573204}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  - Director (S) Regional Serviu Regi&#xF3;n de Los Lagos.</div><br></div>", "i": 8573205}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN X REGIÓN DE LOS LAGOS"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["1"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-01-15", "doble_articulado": false, "id_norma": "269021", "numero_fuente": "38976", "tipo_version": "3", "tipo_vers