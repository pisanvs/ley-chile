{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 158, DE 1984 </div></div>", "i": 6264899}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 158, de 14 de Septiembre de 1984, se ha aprobado al Liceo A N&#xB0; 12 de Santiago para organizar Talleres y Laboratorios destinados a profundizar aprendizajes, por un per&#xED;odo de 6 a&#xF1;os a contar de 1984, aplicaci&#xF3;n en forma gradual desde 7&#xB0; a&#xF1;o de Educaci&#xF3;n General B&#xE1;sica hasta 4&#xB0; a&#xF1;o medio.- Estas actividades ser&#xE1;n evaluadas en la forma que se indica, con incidencia en la promoci&#xF3;n.- </div></div>", "i": 6264900}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de Diciembre de 1984.- Marta Stefanowsky Bandyra, Subsecretario de Educaci&#xF3;n P&#xFA;blica, subrogante.</div><br></div>", "i": 6264901}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "158 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-158 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 158, DE 1984", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-09-14", "doble_articulado": false, "id_norma": "165517", "numero_fuente": "32064", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-01-07", "vigencias": [{"desde": "1985-01-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-01-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-01-07", "fin_vigencia": "", "tipo_version": "3"}], "even