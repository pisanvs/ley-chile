{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297886}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.613, de 28 de agosto de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2&#xB0; de la Resoluci&#xF3;n N&#xB0; 323, de 1991, que modific&#xF3; a la Resoluci&#xF3;n N&#xB0; 1.002, de 1990, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; a CAROLINA OSORIO FERNANDEZ, para operar la piscicultura ubicada en Laguna Rosales, comuna de Cocham&#xF3;, provincia de Llanquihue, X Regi&#xF3;n, en orden a reemplazar las coordenadas geogr&#xE1;ficas que all&#xED; aparecen indicadas por las siguientes:</div><div class=\"p\"> V&#xE9;rtice&nbsp;  Latitud (S)&nbsp; &nbsp; Longitud (W)</div><div class=\"p\"> A&nbsp; &nbsp; &nbsp; &nbsp;  41&#xB0;39&apos;23&quot;&nbsp; &nbsp; &nbsp; 72&#xB0;24&apos;45&quot;</div><div class=\"p\"> B&nbsp; &nbsp; &nbsp; &nbsp;  41&#xB0;39&apos;23&quot;&nbsp; &nbsp; &nbsp; 72&#xB0;24&apos;44&quot;</div><div class=\"p\"> C&nbsp; &nbsp; &nbsp; &nbsp;  41&#xB0;39&apos;24&quot;&nbsp; &nbsp; &nbsp; 72&#xB0;24&apos;44&quot;</div><div class=\"p\"> D&nbsp; &nbsp; &nbsp; &nbsp;  41&#xB0;39&apos;24&quot;&nbsp; &nbsp; &nbsp; 72&#xB0;24&apos;45&quot;</div><br></div>", "i": 8297887}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 28 de agosto de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297888}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1613", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1613"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "AUTORIZACION", "CAROLINA OSORIO", "FERNANDEZ", "PI