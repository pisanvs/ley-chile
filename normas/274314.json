{"html": [{"t": "<div><div class=\"p\">NOTIFICACI&#xD3;N </div></div>", "i": 7375675}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;4.002 de 27 de junio de 2008 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n parcial, conforme D.L. N&#xBA;2.186 de 1978, del inmueble ubicado en Ca&#xF1;ete N&#xBA;2043, Rol de Aval&#xFA;o N&#xBA;2234-4, comuna de Conchal&#xED;, de aparente dominio de Zamora Sep&#xFA;lveda Joanna Andrea; correspondiente al Lote N&#xBA;39, del Proyecto Vial &quot;Habilitaci&#xF3;n de Corredor de Transporte P&#xFA;blico Avda. Dorsal&quot;. Comisi&#xF3;n integrada por peritos Ricardo Strickler Arellano, Arquitecto; Leonardo Bast&#xED;as Tessada, Constructor Civil; y Carlos Montecinos Galleguillos, ingeniero ejecuci&#xF3;n, seg&#xFA;n informe de 30 de abril de 2008, fij&#xF3; monto provisional indemnizaci&#xF3;n en $562.600.-, pagadera al contado.</div><br></div>", "i": 7375676}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director (S) Serviu Metropolitano.</div><br></div>", "i": 7375677}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4002 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4002 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "DISPONE EXPROPIACIÓN PARCIAL Y TOTAL DE INMUEBLES QUE INDICAN; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-06-27", "doble_articulado": false, "id_norma": "274314", "numero_fuente": "39113", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-07-15", "vigencias": [{"desde": "2008-