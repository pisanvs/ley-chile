{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SUPLEMENTA EL PRESUPUESTO DE LA CAMARA DE DIPUTADOS EN LA SUMA DE $ 86,500</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8278024}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2.o El gasto que demande esta ley se deducir&#xE1; de la mayor entrada que produzca la cuenta C.25 </div></div>", "i": 8278025}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 3.o Esta ley comenzar&#xE1; a regir desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 8278026}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintisiete de Diciembre de mil novecientos treinta y cinco.- ARTURO ALESSANDRI.- Luis Cabrera.</div><br></div>", "i": 8278027}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "5778", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-5778"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "SUPLEMENTA EL PRESUPUESTO DE LA CAMARA DE DIPUTADOS\nEN LA SUMA DE $ 86,500", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1935", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1935-12-27", "doble_articulado": false, "id_norma": "25199", "numero_fuente": "17353", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1935-12-28", "vigencias": [{"desde": "1935-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"