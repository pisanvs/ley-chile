{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xDA;MERO 6.381 EXENTA, DE 2012</div></div>", "i": 9287777}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 6.381, de 17 de julio de 2012, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Centro de Capacitaci&#xF3;n en Salud Limitada (Cecapsa Ltda.)&quot;, RUT 76.580.380-2, contenida en la resoluci&#xF3;n exenta N&#xB0; 73 de 4 de enero de 2011, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xB0; 2, del Art. 21 de la ley 19.518.- </div></div>", "i": 9287778}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (PT).</div></div>", "i": 9287779}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6381 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6381 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN NÚMERO 6.381 EXENTA, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-17", "doble_articulado": false, "id_norma": "1042689", "numero_fuente": "40331", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-08-07", "vigencias": [{"desde": "2012-08-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-08-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-08-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes":