{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; LEI NUM. 4,037, QUE CONCEDE FONDOS PARA ATENDER AL PRINCIPE HEREDERO DE ITALIA</div><div class=\"p\">&nbsp; &nbsp; LEI NUM. 4,037.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5957781}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de doscientos mil pesos ($ 200,000) moneda corriente, en los gastos que demande la pr&#xF3;xima visita al pais de S. A. R. el Pr&#xED;ncipe Heredero de Italia.</div><br></div>", "i": 5957782}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 22 de agosto de 1924.- Arturo Alessandri.- Ramon Briones Luco.</div><br></div>", "i": 5957783}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4037", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4037"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES"], "titulo_norma": "LEI NUM. 4,037, QUE CONCEDE FONDOS PARA ATENDER AL PRINCIPE HEREDERO DE ITALIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTE DE LA REPUBLICA", "FONDOS", "CONCESION", "ITALIA", "PRINCIPE HEREDERO", "VISITA", "GASTOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1924-08-22", "doble_articulado": false, "id_norma": "24423", "numero_fuente": "13960", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1924-08-23", "vi