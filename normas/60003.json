{"html": [{"t": "<div><div class=\"p\">DISPONE EXPROPIACION PARCIAL DE INMUEBLE QUE INDICA </div></div>", "i": 8924412}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Decreto Secc. 2&#xAA; N&#xBA; 679, de 31/XII/96, Alcalde</div><div class=\"p\">Municipalidad de Santiago dispone expropiaci&#xF3;n parcial, conforme</div><div class=\"p\">art. 85 Decreto 458 Ministerio Vivienda y Urbanismo inmueble Chacabuco 1041, Rol N&#xBA; 1175, comuna Santiago, dominio aparente Carlos Andueza Sagredo, superficie aproximada 32,40 metros cuadrados.</div><div class=\"p\">&nbsp; &nbsp;  Deslindes. Norte, 3,10 mts. otro propietario; Sur, 3,10 mts. otro propietario; Oriente, 1045 resto predio, y Poniente:</div><div class=\"p\">10,45 mts. calle Chacabuco. Indemnizaci&#xF3;n $3.013.200.- pagadera contado.</div><br></div>", "i": 8924413}, {"t": "<div><div class=\"p\">Juan Infante Philippi, Alcalde (S) Santiago.</div><br></div>", "i": 8924414}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "679", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-679"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "DISPONE EXPROPIACION PARCIAL DE INMUEBLE QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-12-31", "doble_articulado": false, "id_norma": "60003", "numero_fuente": "35666", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-01-15", "vigencias": [{"desde": "1997-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_