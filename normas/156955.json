{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6237208}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 500, de 25 de Junio de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n se autoriza a Juan Eulogio Venegas Arena de la Asociaci&#xF3;n de Buses &quot;Nueva Talmocur&quot;, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6237209}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Manuel Coloma Amaro, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n del Maule.</div><br></div>", "i": 6237210}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "500 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-500 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-25", "doble_articulado": false, "id_norma": "156955", "numero_fuente": "32211", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-07-02", "vigencias": [{"desde": "1985-07-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-07-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-07-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v