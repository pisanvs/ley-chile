{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA</div><br><br><br></div>", "i": 8335390}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.301, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 3 de la resoluci&#xF3;n No. 814, de 1988, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Pesquera Lago Ri&#xF1;ihue Limitada, hoy Pesquera Lago Ri&#xF1;ihue S.A. R.U.T. No. 96.533.081-1 domiciliada en Santiago, para iniciar actividades pesqueras en el sentido de incluir el Jurel, Trachurus Murphyi, entre los recursos que tiene autorizados a extraer con la embarcaci&#xF3;n &quot;Vestliner&quot;.</div><br></div>", "i": 8335391}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de Noviembre de 1988.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8335392}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1301", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1301"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1988-11-25", "fecha_derogacion": "1994-02-05", "doble_articulado": false, "id_norma": "125412", "numero_fuente": "33254", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1988-12-24", "vigencias": [{"desde": "1994-02-05", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1988-12-24", "hasta": "1994-02-04", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigenci