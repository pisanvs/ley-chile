{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6487638}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 359 de 22 de junio de 2004 de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xBA; 2.186 de 1978, del Lote N&#xBA; 178 correspondiente a parte del inmueble ubicado en Santa Rosa 3320 Block 2, sin presunto rol de aval&#xFA;o, comuna de San Joaqu&#xED;n, aparente dominio de varios propietarios. Comisi&#xF3;n integrada por peritos Jes&#xFA;s D&#xED;az Pasmi&#xF1;o, Ingeniero Civil, Patricia Morales Rivera, Constructor Civil y Eric Ehrenfeld Allera, Arquitecto. Seg&#xFA;n informe de 16 de octubre de 2003, fij&#xF3; monto provisional indemnizaci&#xF3;n en $10.266.250.- pagadera al contado.</div><br></div>", "i": 6487639}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6487640}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "359", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-359"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES DE INMUEBLES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-06-22", "doble_articulado": false, "id_norma": "227622", "numero_fuente": "37910", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-15", "vigencias": [{"desde": "2004-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "200