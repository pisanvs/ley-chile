{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 194.- Santiago, 20 de agosto de 1894.- Por cuanto el Congreso Nacional ha aprobado el siguiente </div><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6169998}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese por gracia al sarjento 1.&#xBA; Florencio Diaz, un abono de tiempo necesario para obtener el cuarto premio i esti&#xE9;ndasele la c&#xE9;dula correspondiente. </div></div>", "i": 6169999}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica. MONTT.- S. Aldunate B.</div><br></div>", "i": 6170000}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "194", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-194"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-08-20", "doble_articulado": false, "id_norma": "136827", "numero_fuente": "4900", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-08-25", "vigencias": [{"desde": "1894-08-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-08-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-08-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-05-20", "fecha_version": "1894-08-25", "fecha_actualizacion_texto": "1894-08-25", "tipo_tratado": ""},