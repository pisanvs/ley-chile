{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6311493}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.554, de 27 de noviembre de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a INDUSTRIAL MAR DEL SUR LIMITADA para continuar desarrollando las actividades pesqueras autorizadas a Productos Diet&#xE9;ticos de Chile Limitada, del mismo RUT y domicilio, por resoluci&#xF3;n N&#xBA; 825, de 1995, de esta Subsecretar&#xED;a.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1.128, del 2000, en virtud de lo dispuesto en el art&#xED;culo 6&#xBA; del D.S. N&#xBA; 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6311494}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de noviembre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca. </div></div>", "i": 6311495}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2554", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2554"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-11-27", "doble_articulado": false, "id_norma": "178666", "numero_fuente": "36834", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-12-11", "vigencias": [{"desde": "2000-12-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-12-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-12-11", "fin_vigencia": "", "tipo_ve