{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6509506}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA; 1.676, de 30 de noviembre</div><div class=\"p\">de 2004, y en base a la facultad otorgada por el</div><div class=\"p\">art&#xED;culo 105 del DFL MOP N&#xBA; 850 de 1997, que fij&#xF3; el texto actualizado de la ley N&#xBA; 15.840, se expropi&#xF3; el lote de terreno N&#xBA; 29-A, para la obra: Camino Ruta 7 (Longitudinal Austral), sector Ex Pozos de Emprestitos, Tramo Km. 0,000 a Km. 13,07086, que figura a nombre de Echeverr&#xED;a Mu&#xF1;oz Patricio Hern, rol de aval&#xFA;o 204-87, comuna de Chait&#xE9;n, X Regi&#xF3;n, superficie 3.010 m&#xB2;. La Comisi&#xF3;n de Peritos, fij&#xF3; con fecha 11 de marzo de 2002, en la cantidad de $1.053.500. La indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.</div><br></div>", "i": 6509507}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6509508}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1676 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1676 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-30", "doble_articulado": false, "id_norma": "233759", "numero_fuente": "38036", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-15", "vigencias": [{"desde": "2004-12-15", "hasta": "", "tipo_version": "3", "ti