{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;446 EXENTO, DE 1999</div><br><br></div>", "i": 6242127}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA;446, de 29 de diciembre de 1999, se ha aprobado al &apos;&apos;Lincoln International Academy&apos;&apos;, comuna de Lo Barnechea, de Santiago, un plan de estudio para los cursos de 5&#xBA;, 6&#xBA;, 7&#xBA; y 8&#xBA; a&#xF1;o (NB.3, NB.4, NB.5 y NB.6) de Ense&#xF1;anza B&#xE1;sica, el que se aplicar&#xE1; en 5&#xBA; y 6&#xBA; a&#xF1;o a contar del a&#xF1;o escolar 2000 y en 7&#xBA; y 8&#xBA; a&#xF1;o, de acuerdo con lo se&#xF1;alado en el decreto supremo de Educaci&#xF3;n N&#xBA;40, de 1996 y sus modificaciones.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores de los cursos que se indican en el presente decreto.</div><br></div>", "i": 6242128}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de enero de 2000.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6242129}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "446 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-446 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº446 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-29", "doble_articulado": false, "id_norma": "158533", "numero_fuente": "36601", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-02-29", "vigencias": [{"desde": "2000-02-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ún