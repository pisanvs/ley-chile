{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7419559}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;518, de 6 de febrero de 2009, de esta Subsecretar&#xED;a, rectif&#xED;case el numeral 4&#xBA; inciso 1&#xBA; de la resoluci&#xF3;n exenta N&#xBA;93, de 2009, que autoriz&#xF3; a CONSULTORA PUPELDE LIMITADA para efectuar una pesca de investigaci&#xF3;n de conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del proyecto denominado &quot;Monitoreo de la pesquer&#xED;a artesanal de Merluza del sur (Merluccius australis) de aguas interiores de la D&#xE9;cima Regi&#xF3;n, Zona de Puerto Montt, a&#xF1;o 2009&quot;, en el sentido de se&#xF1;alar que las actividades de investigaci&#xF3;n de febrero se realizar&#xE1;n entre el 26 y el 28 de dicho mes, ambas fechas inclusive.</div><br></div>", "i": 7419560}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de febrero de 2009.- Mar&#xED;a &#xC1;ngela Barbieri Bellolio, Subsecretaria de Pesca (S). </div></div>", "i": 7419561}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "518 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-518 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-02-06", "doble_articulado": false, "id_norma": "287201", "numero_fuente": "39287", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-02-13", "vigencias": [{"desde": "2009-02-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig