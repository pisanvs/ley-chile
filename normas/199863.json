{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xB0; 369, DE 1983</div><br><br><br><br></div>", "i": 7292481}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 296, de 13 de Junio de 1984, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a comercial Gran Am&#xE9;rica y Compa&#xF1;&#xED;a Limitada, domiciliada en Santiago, para cambiar el domicilio de la planta de congelado y seco salado de recursos hidrobiol&#xF3;gicos, ubicada en la X Regi&#xF3;n, autorizada operar por resoluci&#xF3;n N&#xB0; 369, de 1983, de la misma Subsecretar&#xED;a, a la ribera Sur del r&#xED;o Pudeto s/n., Ancud. </div></div>", "i": 7292482}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de Junio de 1984.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7292483}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "296", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-296"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION N° 369, DE 1983", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1984-06-13", "fecha_derogacion": "2002-05-10", "doble_articulado": false, "id_norma": "199863", "numero_fuente": "31914", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1984-07-05", "vigencias": [{"desde": "2002-05-10", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1984-07-05", "hasta": "2002-05-09", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_v