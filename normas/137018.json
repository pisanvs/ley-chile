{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,253.-&nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170625}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.-&nbsp;  Ab&#xF3;nase, por gracia, al coronel don Lucio Mart&#xED;nez B. ocho a&#xF1;os un mes i seis dias que le faltan para obtener su retiro con el goce del sueldo &#xED;ntegro asignado a su empleo.</div><br></div>", "i": 6170626}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica. T&#xF3;mese razon, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Boletin de las Leyes i Decretos del Gobierno.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiseis de enero de mil novecientos diez.- Pedro Montt.-&nbsp; A. Rodr&#xED;guez H.</div><br></div>", "i": 6170627}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2253", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2253"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-01-26", "doble_articulado": false, "id_norma": "137018", "numero_fuente": "9611", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-02-05", "vigencias": [{"desde": "1910-02-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-02-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1910-