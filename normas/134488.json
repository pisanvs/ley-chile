{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8343229}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 487, de 29 de marzo de 1999, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 525 de 1995, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PACIFIC FISHERIES S.A., para operar la nave &apos;&apos;Ligrunn&apos;&apos;, s&#xF3;lo en lo relativo a la operaci&#xF3;n en el litoral de las regiones III y IV, respecto de los recursos Jurel, Agujilla, Anchoveta, Caballa, Machuelo o tritre, Sardina espa&#xF1;ola y Sardina com&#xFA;n, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8343230}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de marzo de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8343231}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "487", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-487"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-03-29", "doble_articulado": false, "id_norma": "134488", "numero_fuente": "36331", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-04-06", "vigencias": [{"desde": "1999-04-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-04-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-04-06", "fin_vigencia": "", "tipo_version": "3"}],