{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO No. 142 EXENTO, DE 1990 </div></div>", "i": 6525711}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 142, de 25 de abril de 1990, se aprob&#xF3; con car&#xE1;cter de experimental, a contar del a&#xF1;o lectivo 1990 y por un per&#xED;odo de seis a&#xF1;os, a la Escuela Especial D No. 76 de la Regi&#xF3;n Metropolitana, Plan Especial de Estudio de Orientaci&#xF3;n Laboral para deficientes mentales. Adem&#xE1;s, se aprueban los programas de estudio correspondientes a las asignaturas de dicho Plan.</div><br></div>", "i": 6525712}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de Mayo de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6525713}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "142 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-142 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO No. 142 EXENTO, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-04-25", "doble_articulado": false, "id_norma": "237855", "numero_fuente": "33669", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-05-14", "vigencias": [{"desde": "1990-05-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-05-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-05-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2005-05-11", "fecha_versio