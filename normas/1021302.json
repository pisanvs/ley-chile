{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9080325}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.708, de 10 de diciembre de 2010, de esta Subsecretar&#xED;a, la n&#xF3;mina de armadores y embarcaciones que cumplen con los requisitos legales para operar en la unidad de pesquer&#xED;a de Alfonsino, declarada en estado de plena explotaci&#xF3;n y sometida a dicho r&#xE9;gimen de administraci&#xF3;n, en el &#xE1;rea mar&#xED;tima de la XV a XII Regiones e Islas Oce&#xE1;nicas, en el &#xE1;rea se&#xF1;alada en sus respectivas autorizaciones, al 30 de noviembre de 2010, es la siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=1015524&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.156, de 2010</a>, de esta Subsecretar&#xED;a.</div><br><br></div>", "i": 9080326, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de diciembre de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9080327}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3708 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3708 EXENTA"}], "organismos": ["SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-10", "doble_articulado": false, "id_norma": "1021302", "numero_fuente": "39837", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-12-17", "vigencias": [{"desde": "2010-12-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigen