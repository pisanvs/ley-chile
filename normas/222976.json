{"html": [{"t": "<div><div class=\"p\">APRUEBA ORDENANZA SOBRE &quot;OTORGAMIENTO DE SUBVENCIONES, RECEPCION DE DONACIONES Y SU REGISTRO&quot; </div></div>", "i": 6471078}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Municipalidad de Angol pone en conocimiento de la comunidad que por decreto alcaldicio N&#xBA; 184 del 15 de marzo de 2004, fue aprobada la Ordenanza Municipal que norma el procedimiento a observar para el &quot;Otorgamiento de Subvenciones, Recepci&#xF3;n de Donaciones y su Registro&quot;.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de la citada ordenanza se informa que est&#xE1; a disposici&#xF3;n de quien lo solicite en la Secretar&#xED;a Municipal, cuya oficina se encuentra en calle Pedro Aguirre Cerda N&#xBA; 509 de Angol, en el 2&#xBA; piso.- </div></div>", "i": 6471079}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Enrique Sanhueza Burgoa, Alcalde.</div><br></div>", "i": 6471080}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "184", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-184"}], "organismos": ["MUNICIPALIDAD DE ANGOL"], "titulo_norma": "APRUEBA ORDENANZA SOBRE OTORGAMIENTO DE SUBVENCIONES, RECEPCION DE DONACIONES Y SU REGISTRO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-15", "doble_articulado": false, "id_norma": "222976", "numero_fuente": "37821", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-26", "vigencias": [{"desde": "2004-03-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-03-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-03-26", "f