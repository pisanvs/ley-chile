{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6743496}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xB0;364, de 30 de mayo de 1996, se expropiaron los lotes de terreno N&#xB0;s 2, 7 y 9, superficies 385, 1,970 y 3.420 m2, roles de aval&#xFA;o 1004-11, 1004-17 y 100419, comuna de Natales, para la obra Camino Habilitaci&#xF3;n y Construcci&#xF3;n Regad&#xED;o Huertos Familiares de Puerto Natales, Aducci&#xF3;n 2&apos; Etapa y se acord&#xF3; precio de la indemnizaci&#xF3;n con sus propietarios Jos&#xE9; del Carmen C&#xE1;rdenas Vargas, Jos&#xE9; Mateo Segundo Almonacid Mancilla y Jos&#xE9; Hern&#xE1;n Ojeda Vera, ascendente a las cantidades de $37.544, para el N&#xB0; 2, $192.158, para el lote N&#xB0;7 y $333.594, para el lote N&#xB0; 9. </div></div>", "i": 6743497}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6743498}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "364", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-364"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-30", "doble_articulado": false, "id_norma": "224189", "numero_fuente": "35516", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-07-15", "vigencias": [{"desde": "1996-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [