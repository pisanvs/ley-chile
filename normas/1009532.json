{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div><br></div>", "i": 8816089}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA; 39.506 de 9 de noviembre de 2009, se public&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1007863&amp;idParte=&amp;idVersion=2009-12-24\">Decreto N&#xFA;m. 4.397</a>, que &quot;RECTIFICA DECRETO N&#xB0; 3.985, DE 2009, QUE PROMULGA MODIFICACI&#xD3;N AL PLAN REGULADOR COMUNAL&quot;, con el error que se salva a continuaci&#xF3;n: p&#xE1;gina cinco, primera columna, donde dice: &quot;... RECTIFICA DECRETO N&#xB0; 3.985, DE 1999, QUE PROMULGA MODIFICACI&#xD3;N AL PLAN REGULADOR COMUNAL ...&quot; debe decir &quot;... RECTIFICA DECRETO N&#xB0; 3.985, DE 2009, QUE PROMULGA MODIFICACI&#xD3;N AL PLAN REGULADOR COMUNAL ...&quot;.</div><br><br></div>", "i": 8816090, "v": ["RECTIFICACION"]}, {"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8816091}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "73", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-73"}], "organismos": ["MUNICIPALIDAD DE LO BARNECHEA"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1009532", "numero_fuente": "39544", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-12-24", "vigencias": [{"desde": "2009-12-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-12-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-12-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincula