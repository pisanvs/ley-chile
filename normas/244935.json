{"html": [{"t": "<div><div class=\"p\">OTORGA RECONOCIMIENTO OFICIAL A LA ESCUELA DE CONDUCTORES PROFESIONALES SAN CRISTOBAL LTDA. </div></div>", "i": 6552461}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 840 de 30.11.2005, ot&#xF3;rgase reconocimiento oficial a la Escuela de Conductores Profesionales denominada &quot;San Crist&#xF3;bal Limitada&quot;, para impartir los cursos conducentes a la obtenci&#xF3;n de licencias profesionales clases A2, A3 y A4, en la sede ubicada en calle Baquedano N&#xBA;606, comuna de Castro, Regi&#xF3;n de Los Lagos.</div><br></div>", "i": 6552462}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Iv&#xE1;n Leonhardt C&#xE1;rdenas, Secretario Regional Ministerial Transportes y Telecomunicaciones, Regi&#xF3;n de Los Lagos.</div><br></div>", "i": 6552463}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "840 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-840 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "OTORGA RECONOCIMIENTO OFICIAL A LA ESCUELA DE CONDUCTORES PROFESIONALES SAN CRISTOBAL LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-30", "doble_articulado": false, "id_norma": "244935", "numero_fuente": "38335", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-12-13", "vigencias": [{"desde": "2005-12-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-12-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig