{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 7353722}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA;715 de 30 de julio de 2007 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n total, conforme D.L. N&#xBA; 2.186 de 1978, del inmueble ubicado en 5 de abril Lt.13, presunto Rol de Aval&#xFA;o N&#xBA;2009-13, comuna de Maip&#xFA;, de aparente dominio de V&#xED;ctor Manuel Loren Altamirano; correspondiente al Lote N&#xBA;3, del Proyecto Vial &quot;Habilitaci&#xF3;n Corredor de Transporte P&#xFA;blico Av. Pedro Aguirre Cerda, Est. Central, Cerrillos, Maip&#xFA;&quot;. Comisi&#xF3;n integrada por Ricardo Strickler Arellano, Arquitecto, Patricia Zavala Contreras, Constructor Civil y Gast&#xF3;n Bravo Hurtado, Ingeniero Civil, seg&#xFA;n informe de 20 de noviembre de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $48.857.500.- pagadera al contado.</div><br></div>", "i": 7353723}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 7353724}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "715", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-715"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-07-30", "doble_articulado": false, "id_norma": "264798", "numero_fuente": "38865", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-09-15", "vigencias": [{"desde": "2007-09-15", "ha