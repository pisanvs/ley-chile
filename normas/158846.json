{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 168, DE 1984</div><br><br></div>", "i": 6243223}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por DS exento de Educaci&#xF3;n N&#xB0; 168 de 14 de Septiembre de 1984 se ha procedido a autorizar a contar de 1985, a los Colegios de la Compa&#xF1;&#xED;a de Jes&#xFA;s, que se indican, para modificar el plan de estudio aprobado por DS exento de Educaci&#xF3;n N&#xB0; 136 de 1982, en el sentido de reemplazar en 4&#xB0; a&#xF1;o medio la asignatura de Castellano por Historia Universal y Contabilidad por F&#xED;sica Qu&#xED;mica correspondientes al Plan de Estudio Polivalente y se aprueban los respectivos programas de estudio. </div></div>", "i": 6243224}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de Marzo de 1985.- Marta Stefanowsky Bandyra, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 6243225}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "168 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-168 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 168, DE 1984", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-09-14", "doble_articulado": false, "id_norma": "158846", "numero_fuente": "32135", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-30", "vigencias": [{"desde": "1985-03-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-03-30", "fin_vigencia": "", "tipo_version