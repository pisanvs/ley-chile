{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; CERTIFICADO</div><br></div>", "i": 6149282}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 4.73% anual durante el mes de Agosto de 1988.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad a lo dispuesto en el No. 5 del Capitulo IV.B.8.1 del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables de 90 a 365 d&#xED;as, correspondiente a la segunda quincena mes de Agosto de 1988, fue de 4.92% anual.</div><br></div>", "i": 6149283}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 02.09.88.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6149284}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-09-02", "doble_articulado": false, "id_norma": "130190", "numero_fuente": "33164", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-09-05", "vigencias": [{"desde": "1988-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-09-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-09-05", "fin_vigencia": "", "tipo_version": "3"