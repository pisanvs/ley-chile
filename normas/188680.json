{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6346711}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.654 de 3 de agosto de 2001 de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; EMPRESA PESQUERA BRAVAMAR Y CIA. LTDA., para ampliar las actividades pesqueras extractivas con la nave &quot;Linda Kay&quot;, en el &#xE1;rea mar&#xED;tima que se indica, por fuera del &#xE1;rea de reserva artesanal, con arrastre, sobre los siguientes recursos hidrobiol&#xF3;gicos: a) En el &#xE1;rea mar&#xED;tima de la I a la III Regiones, sobre Merluza com&#xFA;n; b) En el &#xE1;rea mar&#xED;tima de la I a la VIII Regiones, sobre Gamba, Besugo, Congrio dorado y Pejerrata; c) En el &#xE1;rea mar&#xED;tima de la I a la VII Regiones, sobre Raya. </div></div>", "i": 6346712}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de agosto de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6346713}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1654", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1654"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-08-03", "fecha_derogacion": "2003-01-16", "doble_articulado": false, "id_norma": "188680", "numero_fuente": "37043", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2001-08-22", "vigencias": [{"desde": "2003-01-16", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2001-08-22", "hasta": "2003-01-15", "tipo