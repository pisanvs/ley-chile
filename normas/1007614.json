{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8799432}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. (EXENTO) N&#xBA; 1561 de 30 de septiembre de 2009, se modific&#xF3; el numeral segundo de los <a href=\"https://www.leychile.cl/Navegar?idNorma=281611&amp;idParte=0&amp;idVersion=\">Decretos MOP N&#xB0; 685 de 16 de septiembre de 2008</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1002089&amp;idParte=0&amp;idVersion=\">Decreto MOP (Exento) N&#xB0; 1086 de 20 de octubre de 2008</a>, que ordenaron, entre otros, la expropiaci&#xF3;n de los lotes N&#xB0; 8, 9, 11, 14, 16, 17, 18, 19 y lote 15 respectivamente, en la parte que se refiere al n&#xFA;mero del rol de aval&#xFA;o, comuna y al nombre de los propietarios seg&#xFA;n el Servicio de Impuestos Internos. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA; 2186, de 1978.</div></div>", "i": 8799433}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 8799434}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1561 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1561 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-09-30", "doble_articulado": false, "id_norma": "1007614", "numero_fuente": "39500", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-11-02", "vigencias": [{"desde": "2009-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia":