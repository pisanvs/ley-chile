{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xBA;. 1</div><br><div class=\"p\">Certifico que el Consejo de este Banco Central de Chile en su Sesi&#xF3;n No. 1, celebrada el 09 de Diciembre de 1989, adopt&#xF3; los siguientes acuerdos:</div><br></div>", "i": 6100318}, {"t": "<div><div class=\"p\">01-02-891209 - Nombramiento de Gerente General Interino. Se acord&#xF3; designar como Gerente General Interino, a contar del 09 de Diciembre de 1989, sin perjuicio de su calidad de Fiscal, a don Jos&#xE9; Antonio Rodr&#xED;guez Velasco. </div></div>", "i": 6100319}, {"t": "<div><div class=\"p\">Santiago, 09 de Diciembre de 1989.- V&#xED;ctor Vial del R&#xED;o, Secretario General Interino </div></div>", "i": 6100320}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-01"}, {"tipo": "5", "numero": "01-02", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-01-02"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE\nEN SU SESION Nº. 1", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-12-09", "doble_articulado": false, "id_norma": "95567", "numero_fuente": "33543", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-12-11", "vigencias": [{"desde": "1989-12-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-12-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-12-11", "fin_vigencia": "", "tipo_version"