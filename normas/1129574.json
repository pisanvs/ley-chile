{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 18B</div></div>", "i": 10005487}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 812, de 4 de marzo de 2019, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1120912&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 2.549, de 2018</a>, y de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 18B, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para el centro de cultivo que indica en la resoluci&#xF3;n extractada.</div></div>", "i": 10005488}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de marzo de 2019.- Eduardo Riquelme Portilla, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 10005489}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "812 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-812 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 18B", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1558057", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-03-04", "doble_articulado": false, "id_norma": "1129574", "numero_fuente": "42301", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-03-11", "vigencias": [{"desde": "2019-03-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia":