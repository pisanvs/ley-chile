{"html": [{"t": "<div><div class=\"p\">DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE SE&#xD1;ALA </div></div>", "i": 6183976}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 776 de 05 de Mayo de 1988, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a Sector no Expropiado y Sector Expropiado Predio &quot;Fundo La Pe&#xF1;a&quot; de la comuna de Yerbas Buenas, VII Regi&#xF3;n; y Derechos Aprovechamiento Aguas que corresponden a parcelas N&#xB0;s. 1 a la 11, sitios N&#xB0;s. 1 al 2 del Proyecto de Parcelaci&#xF3;n &quot;Santa Amelia&quot; formado por predio se&#xF1;alado y otro. Los derechos de agua se extraen del canal La Pe&#xF1;a, Villar. Publicaci&#xF3;n hecha conforme Art.</div><div class=\"p\">13, Ley No. 18.377.-</div><br></div>", "i": 6183977}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6183978}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "776 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-776 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE\nSEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-05-05", "doble_articulado": false, "id_norma": "140996", "numero_fuente": "33072", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-05-16", "vigencias": [{"desde": "1988-05-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig