{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7344086}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.654, de 1 de junio de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a FRIOSUR X S.A., para realizar actividades extractivas en alta mar con la nave &quot;Friosur X&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp;  : CB-4820</div><div class=\"p\">Puerto de Matr&#xED;cula&nbsp; &nbsp; : Valpara&#xED;so.</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : 2965</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp;  : 44,79 m.</div><div class=\"p\">T.R.G. (Internacional) : 902,00</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : 11,80 m.</div><div class=\"p\">Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  : 6,87 m.</div><br></div>", "i": 7344087}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de junio de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7344088}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1654 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1654 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FRIOSUR X S.A.", "ACTIVIDADES PESQUERAS EXTRACTIVAS", "NAVE FRIOSUR X", "AUTORIZA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-01", "doble_articulado": false, "id_norma": "261532", "numero_fuente": "38784", "tipo_version