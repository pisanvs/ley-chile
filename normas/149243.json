{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6211584}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 270 de 15 de Mayo de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se autoriza a don Eduardo C&#xE9;sar Dartes Vera, para prestar todo tipo de servicio de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6211585}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luc&#xED;a M. Leiva Madariaga, Secretario Regional Ministerial de Transportes y Telecomunicaciones VIII Regi&#xF3;n subrogante.</div><br></div>", "i": 6211586}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "270 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-270 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-05-15", "doble_articulado": false, "id_norma": "149243", "numero_fuente": "32778", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-05-25", "vigencias": [{"desde": "1987-05-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-05-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-05-25", "fin_vigencia": "", "tipo_version": "3"}], "e