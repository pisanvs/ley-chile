{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; TASA INTERES PROMEDIO </div></div>", "i": 5845296}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 5,39% anual durante el mes de agosto de 1995.</div><div class=\"p\">&nbsp; &nbsp; Asimismo, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de agosto de 1995, fue de 5,42% anual. </div></div>", "i": 5845297}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, Septiembre 4 de 1995.- V&#xED;ctor Vial del R&#xED;o, Ministro de Fe.</div><br></div>", "i": 5845298}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "TASA INTERES PROMEDIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA INTERES PROMEDIO", "TIP", "BANCO CENTRAL CHILE", "OPERACIONES REAJUSTABLES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-09-04", "doble_articulado": false, "id_norma": "1841", "numero_fuente": "35262", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-09-06", "vigencias": [{"desde": "1995-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-09-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-09-06", "fin