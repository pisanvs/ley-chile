{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5941424}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto exento N&#xB0; 119 de fecha 8 de Mayo de 1992 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a las sedes que se indican del Centro de Formaci&#xF3;n T&#xE9;cnica CIDEC, para impartir planes y programas de estudios, aprobados para la instituci&#xF3;n, de las carreras y t&#xED;tulos t&#xE9;cnicos de nivel superior que se se&#xF1;alan, a partir del a&#xF1;o 1992: - Sede N&#xB0; 2 - La Serena Carrera: Turismo (resoluci&#xF3;n exenta N&#xB0;3.053/83).</div><div class=\"p\"> T&#xED;tulo: T&#xE9;cnico en Turismo.</div><div class=\"p\"> Carrera: Dise&#xF1;o publicitario (resoluci&#xF3;n exenta N&#xB0; 3.186/85)</div><div class=\"p\"> T&#xED;tulo: T&#xE9;cnico en Dise&#xF1;o Publicitario.</div><div class=\"p\"> - Sede N&#xB0; 7 - Temuco.</div><div class=\"p\"> Carrera: Asistente Judicial (decreto exento N&#xB0; 420/90).</div><div class=\"p\"> T&#xED;tulo: T&#xE9;cnico Asistente Judicial.</div><br></div>", "i": 5941425}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 14 de Diciembre de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Justicia.</div><br></div>", "i": 5941426}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "119", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-119"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA CIDEC", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "TURISMO", "DISE O PUBLICITARIO", "ASISTENTE JUDICIAL", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-05-08", "doble_articulado": false, "id_norma": "