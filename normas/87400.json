{"html": [{"t": "<div><div class=\"p\">PARTIDO &quot;UNION DEMOCRATA INDEPENDIENTE&quot; </div></div>", "i": 7222123}, {"t": "<div><div class=\"p\">Julio Dittborn Cordua y Joaqu&#xED;n Lav&#xED;n Infante, en representaci&#xF3;n del Partido Uni&#xF3;n Dem&#xF3;crata Independiente, han solicitado la constituci&#xF3;n legal del Partido en la I Regi&#xF3;n de Tarapac&#xE1;. Se acompa&#xF1;an 881 afiliaciones. Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la Ley No. 18.303. Por Resoluci&#xF3;n Exenta No. O-1626 de fecha 28 de Agosto de 1991.</div><br></div>", "i": 7222124}, {"t": "<div><div class=\"p\">Santiago, 28 de Agosto de 1991.- Andr&#xE9;s Merino Espineira, Director Subrogante.</div><br></div>", "i": 7222125}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1626 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1626 EXENTA"}, {"tipo": "3", "numero": "O-1626 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-1626 EXENTA"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO UNION DEMOCRATA INDEPENDIENTE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-08-28", "doble_articulado": false, "id_norma": "87400", "numero_fuente": "34079", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-09-30", "vigencias": [{"desde": "1991-09-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-09-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-09-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vin