{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.135 EXENTO, DE 1997 </div><br><br></div>", "i": 6138111}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.135 de fecha 11 de noviembre de 1997 del Ministerio de Educaci&#xF3;n, se reemplazaron a contar de agosto de 1997 las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica Juan Bohon, que fueran aprobadas por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 3.356 del 13 de diciembre de 1988.</div><br></div>", "i": 6138112}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de diciembre de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6138113}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1135 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1135 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.135 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO DE FORMACION TECNICA JUAN BOHON", "LA SERENA", "EVALUACION", "PROMOCION", "TITULACION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-11-11", "doble_articulado": false, "id_norma": "126798", "numero_fuente": "36206", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-11-05", "vigencias": [{"desde": "1998-11-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-11-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-11-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACI