{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,189, que autoriza a la Municipalidad de Santiago para cobrar el tres por mil sobre los haberes muebles e inmuebles.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,189.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275068}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. El impuesto sobre haberes muebles e inmuebles, establecido en el n&#xFA;m. 2, del art&#xED;culo 34 de la Lei de Organizacion i Atribuciones de la Municipalidades de 22 de Diciembre de 1891, ser&#xE1; de un tres por mil para la Municipalidad de Santiago. </div></div>", "i": 8275069}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 7 de Agosto de 1909.- PEDRO MONTT.- Enrique A. Rodriguez.</div><br></div>", "i": 8275070}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2189", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2189"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 2,189, QUE AUTORIZA A LA MUNICIPALIDAD DE SANTIAGO PARA COBRAR EL TRES POR MIL SOBRE LOS HABERES MUEBLES E INMUEBLES.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDAD SANTIAGO", "IMPUESTO HABERES", "MUEBLES-INMUEBLES", "COBRO", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1909-08-07", "doble_articulado": false, "id_norma": "23182", "numero_fuente": "9460", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1909-08-09", "vigencias": [{"desde": "1909-08-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1909-08-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1909-08-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-02-09", "fecha_version": "1909-08-09", "fecha_actualizacion_texto": "1909-08-09", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8275068}, {"n": "Artículo UNICO", "i": 8275069, "t": 6}, {"n": "Promulgación", "i": 8275070}]}