{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,106.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6168048}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se autoriza al Presidente de la Rep&#xFA;blica para que con cargo a la lei n&#xFA;mero 1,835, de 12 de febrero de 1906, i con sujecion a sus disposiciones, contrate en licitacion p&#xFA;blica i a precio alzado los alcantarillados de las ciudades de la Rep&#xFA;blica que tengan mas de diez mil habitantes.</div><br></div>", "i": 6168049}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, diecinueve de febrero de mil novecientos ocho.- Pedro Montt.- Joaquin Figueroa.</div><br></div>", "i": 6168050}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2106", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2106"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1908-02-19", "doble_articulado": false, "id_norma": "136240", "numero_fuente": "9040", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1908-03-05", "vigencias": [{"desde": "1908-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1908-03-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1908-03-05", "