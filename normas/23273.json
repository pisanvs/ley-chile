{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza la ereccion en Santiago de un monumento a Manuel Rodriguez</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,365.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275217}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Se autoriza la ereccion, en la Plaza de la Estacion Mapocho de Santiago, de un monumento conmemorativo del Centenario de la Independencia, en honor de Manuel Rodriguez, el que ser&#xE1; costeado con fondos erogados por la colonia otomana. </div></div>", "i": 8275218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 29 de Agosto de 1910.- El&#xED;as Fern&#xE1;ndez Albano.- Luis Izquierdo.</div><br></div>", "i": 8275219}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2365", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2365"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA LA ERECCION EN SANTIAGO DE UN MONUMENTO A MANUEL RODRIGUEZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MANUEL RODRIGUEZ", "SANTIAGO", "MONUMENTO", "ERECCION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-08-29", "doble_articulado": false, "id_norma": "23273", "numero_fuente": "9787", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-09-06", "vigencias": [{"desde": "1910-09-06", "hasta": "", "tipo_versi