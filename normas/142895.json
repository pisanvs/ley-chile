{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6189695}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1 del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables de 90 a 365 d&#xED;as, correspondiente a la primera quincena de febrero de 1988, fue de 4.27% anual.</div><br></div>", "i": 6189696}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de febrero de 1988.- Loreto Moya Gonz&#xE1;lez, Secretario General Subrogante.</div><br></div>", "i": 6189697}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE HACIENDA", "BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-02-17", "doble_articulado": false, "id_norma": "142895", "numero_fuente": "32999", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-18", "vigencias": [{"desde": "1988-02-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-02-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAS", "fecha_ingreso": "1999-09-09", "fecha_version": "1988-02-18", "fecha_actualizacion_texto": "1988-02-18", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6