{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 209 EXENTO, DE 1994 </div></div>", "i": 5942714}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Supremo exento de Educaci&#xF3;n N&#xB0; 209 de fecha 9 de Mayo de 1994, se ha aprobado al Instituto de Humanidades Luis Campino de Santiago, un plan especial de estudio para 5&#xB0; y 6&#xB0; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica, que se aplicar&#xE1; a partir del a&#xF1;o escolar 1994.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa de Computaci&#xF3;n para los citados cursos.</div><br></div>", "i": 5942715}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 20 de Mayo de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n </div></div>", "i": 5942716}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "209", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-209"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 209 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO HUMANIDADES LUIS CAMPINO", "PROGRAMAS ESTUDIOS", "PLANES ESTUDIOS", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-05-09", "doble_articulado": false, "id_norma": "20664", "numero_fuente": "34884", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-06-08", "vigencias": [{"desde": "1994-06-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-06-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-06-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_ver