{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8305019}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.054, de 18 de julio de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 1&#xBA; de la Resoluci&#xF3;n N&#xBA; 1.435, de 1992, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD VASQUEZ Y CIA LTDA., para desarrollar actividades pesqueras con la nave &quot;Zuiderster 7&quot;, en el sentido de actualizar las caracter&#xED;sticas n&#xE1;uticas de esta &#xFA;ltima, en los t&#xE9;rminos que se indica:</div><br><br><div class=\"p\">Nombre&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &quot;Zuiderster 7&quot;</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  2334</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 32,8&nbsp; &nbsp;  m.</div><div class=\"p\">T.R.G. (Nacional)&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  236,3&nbsp; &nbsp;  t.</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp;  256,7&nbsp; &nbsp;  m3.</div><div class=\"p\">Arte de pesca&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Cerco</div><br></div>", "i": 8305020}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de julio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8305021}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1054", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1054"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "AUTORIZACION", "SOCIEDAD VASQUEZ Y CIA LTDA.", "PESCA"], "categorias_norma":