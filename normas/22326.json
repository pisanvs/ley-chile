{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Internacion de Ganados por tierra.- Se fija fecha de la Vijencia de la Lei Aduanera</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 989.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948097}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza al Presidente de la Rep&#xFA;blica para que ponga en vijencia el art&#xED;culo 8.&#xB0; de la lei aduanera de 23 de Diciembre de 1897, en la parte que afecte a los ganados que se internen por tierra quince dias despues de la publicacion de la presente lei en el Diario Oficial.</div><br><br></div>", "i": 5948098}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 13 de Enero de 1898.- FEDERICO ERRAZURIZ.- Alberto Gonz&#xE1;lez E.</div><br></div>", "i": 5948099}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "989", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-989"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "INTERNACION DE GANADOS POR TIERRA.- SE FIJA FECHA DE LA VIJENCIA DE LA LEI ADUANERA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ADUANAS", "INTERNACION", "GANADO", "VIGENCIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [