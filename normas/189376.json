{"html": [{"t": "<div><div class=\"p\">DISPONE EXPROPIACIONES PARCIALES QUE INDICA</div><br><br></div>", "i": 6349352}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 134, de 17 agosto 2001, Serviu V Regi&#xF3;n de Valpara&#xED;so dispuso expropiaci&#xF3;n parcial conforme art&#xED;culo 87 ley 8.946, art&#xED;culo 51 ley 16.391, decreto supremo Minvu N&#xBA; 61 de 2001 y D.L. N&#xBA; 2.186, de 1978, de inmueble ubicado en calle Rafael Arizt&#xED;a 491, lote 2, rol aval&#xFA;o 300-17, comuna Quillota, aparente dominio de Invica. Comisi&#xF3;n Tasadora integrada por Sres. Alvaro Verdejo Vidal (ingeniero constructor), Osvaldo Mu&#xF1;oz Quintana (arquitecto) y Pablo Caria Giurici (constructor civil), seg&#xFA;n informe de fecha 6 abril 2001 fij&#xF3; monto provisional indemnizaci&#xF3;n en $22.677.750. Indemnizaci&#xF3;n se pagar&#xE1; de contado.- </div></div>", "i": 6349353}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n Valpara&#xED;so.</div><br></div>", "i": 6349354}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "134", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-134"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAISO"], "titulo_norma": "DISPONE EXPROPIACIONES PARCIALES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-08-17", "doble_articulado": false, "id_norma": "189376", "numero_fuente": "37063", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-09-15", "vigencias": [{"desde": "2001-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Únic