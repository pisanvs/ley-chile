{"html": [{"t": "<div><div class=\"p\">COMPLEMENTA RESOLUCION EXENTA No. 683 DE 28.11.85 </div><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 699 exenta.- Santiago, 04 de Diciembre de 1985.- Considerando que en el texto de la Resoluci&#xF3;n Exenta de SEC No. 683/85, publicada en el Diario Oficial No. 32.337 de fecha 03.12.85, se omiti&#xF3; el p&#xE1;rrafo 1.2.</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 6264447}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Complem&#xE9;ntase dicha Resoluci&#xF3;n Exenta con el siguiente p&#xE1;rrafo:</div><div class=\"p\">&nbsp; &nbsp;  &quot;1.2.- E.T. Sec. C- 3/85, Artefactos de gas para calefacci&#xF3;n de ambientes - Calefactores Catal&#xED;ticos - Requisitos generales de fabricaci&#xF3;n y m&#xE9;todos de ensayo. </div></div>", "i": 6264448}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, notif&#xED;quese y publ&#xED;quese.- Francisco Cabello Riveros, Coronel (R) Superintendente.</div><div class=\"p\">&nbsp; &nbsp;  Lo que comunico a Ud. para su conocimiento.- Saluda atentamente a Ud.- Gregoria Castillo M. Jefe Div. Administraci&#xF3;n y Finanzas.</div><br></div>", "i": 6264449}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "699 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-699 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "SUPERINTENDENCIA DE ELECTRICIDAD Y COMBUSTIBLES"], "titulo_norma": "COMPLEMENTA RESOLUCION EXENTA No. 683 DE 28.11.85", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-04"