{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xB0; 314, DE 1986</div><br><br></div>", "i": 7260541}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xB0; 470 de 04 de Junio de 1986 de la Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n 314, de 03 de Abril de 1986, de la Subsecretaria de Pesca, que autoriz&#xF3; a &quot;Conservas Dalcahue S.A.&quot; para<span class=\"n\" id=\"n_0\">RECTIFICACION<br>D.O. 20.06.1986</span> desarrollar actividades pesqueras, en orden a dejar establecido que dicha autorizaci&#xF3;n se entiende conferida a &quot;Conserveras Dalcahue S.A.&quot;. </div></div>", "i": 7260542}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 04 de Junio de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7260543}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "3", "numero": "470", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-470"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION N° 314, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-04", "doble_articulado": false, "id_norma": "154567", "numero_fuente": "32499", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-06-18", "vigencias": [{"desde": "1986-06-20", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1986-06-18", "hasta": "1986-06-19", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1986-06-20", "fin_vigenci