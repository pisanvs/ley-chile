{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6242305}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. No. 91, de 22 de abril de 1986, se expropiaron los lotes N&#xB0;s. 1 y 2, superficies 1.900 m2 y 7.900 m2, rol de aval&#xFA;o 7.023-4, comuna de Talcahuano, para Camino Autopista Concepci&#xF3;n a Talcahuano, sector Autopista Avda. O&apos;Higgins, Km. 1.600 al 2.400 y se acord&#xF3; preci&#xF3; de indemnizaci&#xF3;n con sus propietarios don Juan Jos&#xE9; Herrera Riesco y otros, ascendente a $ 809.400 para el lote 1 y $ 2.776.455 para el lote 2, respectivamente.-</div><br></div>", "i": 6242306}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6242307}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "91", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-91"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-04-22", "doble_articulado": false, "id_norma": "158596", "numero_fuente": "32471", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-05-15", "vigencias": [{"desde": "1986-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-02-29", "fecha_version": "1986-05-15", "fecha_actualizacion_texto": "1986-05-15", "tipo_tratado": ""}, "aler