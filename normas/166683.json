{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  CERTIFICADO</div><br><br></div>", "i": 6268857}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile en conformidad con lo dispuesto en el N&#xBA;5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de abril de 2000, fue de 5,40% anual. </div></div>", "i": 6268858}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, abril 17 de 2000.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6268859}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-17", "doble_articulado": false, "id_norma": "166683", "numero_fuente": "36645", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-20", "vigencias": [{"desde": "2000-04-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-04-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-04-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2000-04-20", "fecha_version": "2000-04-20", "fecha_actualizacion_texto": "2000-04-20", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6268857}, {"n": "Artí