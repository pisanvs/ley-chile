{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8334525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.175, de 12 de agosto de 1998, de esta Subsecretar&#xED;a, autor&#xED;zase a SEABAY CHILE S.A., para ampliar actividades pesqueras autorizadas por resoluciones N&#xBA; 476, de 1989, N&#xBA; 754, de 1991 y N&#xBA; 1.608, de 1996, todas de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Camino Las Quemas Km. 12, Sector Tepual, Puerto Montt, la l&#xED;nea de elaboraci&#xF3;n de Ahumado respecto de los recursos hidrobiol&#xF3;gicos autorizados en las resoluciones citadas precedentemente.</div><br></div>", "i": 8334526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de agosto de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8334527}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1175", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1175"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "SEABAY CHILE S.A.", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-08-12", "fecha_derogacion": "2000-12-02", "doble_articulado": false, "id_norma": "124334", "numero_fuente": "36167", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-09-17", "vigencias": [{"desde": "2000-12-02", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-09-17", "hasta": "2000-12-01", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia"