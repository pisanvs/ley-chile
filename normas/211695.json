{"html": [{"t": "<div><div class=\"p\">ACLARA LA LEY N.o 7.078</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6428814}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Lo dispuesto en la ley N.o 7.078, de Octubre de 1941, regir&#xE1; solamente en lo que se refiere al reconocimiento de tiempo y ser&#xE1; aplicable para todos los efectos legales en la jubilaci&#xF3;n del empleado ferroviario don Mois&#xE9;s Salinas Bravo. </div></div>", "i": 6428815}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a ocho de Octubre de mil novecientos cincuenta y ocho.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Eduardo Urz&#xFA;a Merino.</div><br></div>", "i": 6428816}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13074", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13074"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ACLARA LA LEY N.o 7.078", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1958-10-08", "doble_articulado": false, "id_norma": "211695", "numero_fuente": "24174", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1958-10-21", "vigencias": [{"desde": "1958-10-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1958-10-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1958-10-21", "fin_vige