{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8938739}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;753, de 31 de mayo de 2010, se dej&#xF3; sin efecto los numerales 3&#xB0;, 4&#xB0;, 5&#xB0; y 6&#xBA;, del Decreto Exento N&#xB0;495, de 31 de marzo de 2009, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n, del lote de terreno N&#xBA;15, expropiado a CARLOS ANDR&#xC9;S PIZARRO, con motivo de la obra &quot;Mejoramiento Camino 64D485, Sector Pisco Elqui - Horc&#xF3;n&quot;, Provincia de Elqui, Comuna de Paihuano. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n, fijada por la Comisi&#xF3;n de Peritos, con fecha 3 de julio de 2007, ascendente a la cantidad de $196.000, para el lote N&#xB0;15. </div><br></div>", "i": 8938740}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 8938741}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "753 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-753 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-05-31", "doble_articulado": false, "id_norma": "1014914", "numero_fuente": "39699", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-07-01", "vigencias": [{"desde": "2010-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-07