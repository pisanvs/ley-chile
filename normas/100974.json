{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 2, DE 1989 </div></div>", "i": 6114464}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 2 de 11 de enero de 1989 se han aprobado a contar del a&#xF1;o escolar 1989 a la Escuela Industrial &quot;Casa de Talleres San Vicente de Paul&quot; de Santiago, planes de estudio de Educaci&#xF3;n Media T&#xE9;cnico-Profesional, en las especialidades de:</div><br><div class=\"p\">1.- Construcci&#xF3;n de Interiores.</div><div class=\"p\">2.- Mec&#xE1;nica de M&#xE1;quinas Herramientas.</div><div class=\"p\">3.- Instalaciones Sanitarias.</div><div class=\"p\">4.- Electromec&#xE1;nica.</div><br></div>", "i": 6114465}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Adelchi Colombo Breschi, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante.</div><br></div>", "i": 6114466}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 2, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-01-11", "doble_articulado": false, "id_norma": "100974", "numero_fuente": "33308", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-02-25", "vigencias": [{"desde": "1989-02-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-02-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-02-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": []