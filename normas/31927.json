{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA RESOLUCION DECRETO N&#xB0; 1, DE 1987 </div></div>", "i": 8605616}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Mediante Res. Dec. N&#xB0; 006 de fecha 19 de Noviembre de 1992, el Director Regional de la XII Direcci&#xF3;n Regional Punta Arenas, modific&#xF3; la Res. Dec. N&#xB0; 001, de 24 de Marzo de 1987, sobre Subrogancia de Jefe del Departamento Regional de Fiscalizaci&#xF3;n, en la siguiente forma:</div><div class=\"p\">&nbsp; &nbsp; 1&#xB0;) Don Javier Alvarez Carretero</div><div class=\"p\">&nbsp; &nbsp; R.U.T. N&#xB0; 6.465.216-8 Fiscalizador Grado 11&#xB0; 2&#xB0;) Do&#xF1;a Ixcia Montenegro Bolbar&#xE1;n</div><div class=\"p\">&nbsp; &nbsp; R.U.T. N&#xB0; 7.079.607-4 Fiscalizador Grado 13&#xB0; 3&#xB0;) Do&#xF1;a Rita&nbsp; Astorga Mc Donald</div><div class=\"p\">&nbsp; &nbsp; R.U.T. N&#xB0; 6.508.319-1 Fiscalizador Grado 13 </div></div>", "i": 8605617}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Bernardo Seaman Gonz&#xE1;lez, Director Regional. </div></div>", "i": 8605618}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-6"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA RESOLUCION DECRETO N° 1, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SUBROGACION", "JEFE DEPARTAMENTO FISCALIZACION", "DIRECCION REGIONAL", "SERVICIO IMPUESTOS INTERNOS", "FISCALIZADOR", "PUNTA ARENAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-11-19", "doble_articulado": false, "id_norma": "31927", "numero_fuente": "34439", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-12-12", "vigencias": [{"desde": "19