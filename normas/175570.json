{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6300936}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;3.156 de 31 de julio del 2000, y en base a la facultad otorgada por el art&#xED;culo 105 del DFL N&#xBA;850, de 1997, que fij&#xF3; el texto actualizado de la ley N&#xBA;15.840, se expropi&#xF3; el lote de terreno N&#xBA;88, para la ejecuci&#xF3;n de la obra Embalse Puclaro, Sector Gualliguaica - IV Etapa, que figura a nombre de Arzobispado de La Serena, rol de aval&#xFA;o 458-1, de la comuna de Vicu&#xF1;a, IV Regi&#xF3;n, superficie 1.650 m&#xB2;. La comisi&#xF3;n de peritos fij&#xF3; con fecha 10 de marzo de 1997, la indemnizaci&#xF3;n provisional en la cantidad de $25.750.000.- La indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA;2.186, de 1978.- </div></div>", "i": 6300937}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6300938}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3156", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3156"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-07-31", "doble_articulado": false, "id_norma": "175570", "numero_fuente": "36765", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-15", "vigencias": [{"desde": "2000-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-15", "fin_vigencia": ""