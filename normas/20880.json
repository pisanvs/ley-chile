{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 280 EXENTO, DE 1995 </div></div>", "i": 5943441}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 280 de 3 de mayo de 1995, se ha aprobado un plan especial de estudio para el Liceo Adventista de Molina, para la Ense&#xF1;anza B&#xE1;sica y Media Human&#xED;stico-Cient&#xED;fica, el que ser&#xE1; aplicado a partir del a&#xF1;o escolar 1996.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio de las asignaturas de: Introducci&#xF3;n a la Computaci&#xF3;n e Inform&#xE1;tica y Carpinter&#xED;a.</div><br></div>", "i": 5943442}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 16 de Mayo de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943443}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "280", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-280"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 280 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LICEO ADVENTISTA MOLINA", "PROGRAMAS ESTUDIO", "PLANES ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-03", "doble_articulado": false, "id_norma": "20880", "numero_fuente": "35174", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-05-23", "vigencias": [{"desde": "1995-05-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-05-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-05-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pend