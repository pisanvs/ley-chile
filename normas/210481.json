{"html": [{"t": "<div><div class=\"p\">OTORGA&nbsp; CALIDAD&nbsp; DE&nbsp; AGENTE RETENEDOR DE IVA A</div><div class=\"p\">AGROFORESTAL CORNECHE LIMITADA</div><br></div>", "i": 6424316}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 1.- Certifico que Agroforestal Corneche Limitada, RUT: 77.710.560-4 cumple los requisitos establecidos en la Res. N&#xBA; 4.916 Ex. del 31.10.2000 publicada en el Diario Oficial el 03.11.2000, que en consecuencia tiene la calidad de agente retenedor del Impuesto al Valor Agregado, en la venta de madera que efect&#xFA;e durante el per&#xED;odo comprendido entre el 1&#xBA; del mes siguiente al de la publicaci&#xF3;n de este certificado en el Diario Oficial con vigencia indefinida. </div></div>", "i": 6424317}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rancagua, 6 de mayo de 2003.- Luis Mu&#xF1;oz Arratia, Director Regional.</div><br></div>", "i": 6424318}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "1", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-1"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VI DIRECCIÓN REGIONAL DE RANCAGUA"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA A\nAGROFORESTAL CORNECHE LIMITADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-05-06", "doble_articulado": false, "id_norma": "210481", "numero_fuente": "37563", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-05-20", "vigencias": [{"desde": "2003-05-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-05-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig