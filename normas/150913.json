{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION No. 762 EXENTA, DE 1987 </div></div>", "i": 7258386}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 762 de fecha 13 de Abril de 1987 del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se aprobaron las moditicaciones introducidas al plan y programas de estudio de la carrera Programaci&#xF3;n de Sistemas del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto John Kennedy, Centro de Estudios y Capacitaci&#xF3;n Limitada de Santiago, para impartirse a contar de agosto de 1986 en la sede central y sede No. 1 de Rancagua, con la siguiente denominaci&#xF3;n:</div><br><div class=\"p\">Carrera: Programaci&#xF3;n en Computaci&#xF3;n.</div><div class=\"p\">T&#xED;tulo: Programador de Computadores.-</div><br></div>", "i": 7258387}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 7258388}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "762 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-762 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION N° 762 EXENTA, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-04-13", "doble_articulado": false, "id_norma": "150913", "numero_fuente": "32803", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-24", "vigencias": [{"desde": "1987-06-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-24", "fin_vigencia": ""}, "vigencias_version_nor