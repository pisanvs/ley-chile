{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9011895}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.802, de 10 de septiembre de 2010, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1016582&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.476 de 2010</a>, de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Evaluaciones hidroac&#xFA;sticas de Merluza com&#xFA;n, a&#xF1;o 2010&quot;, en el sentido de se&#xF1;alar que el estudio se extender&#xE1; hasta el 21 de septiembre de 2010, inclusive.</div></div>", "i": 9011896}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de septiembre de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9011897}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2802 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2802 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-09-10", "doble_articulado": false, "id_norma": "1017408", "numero_fuente": "39771", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-09-28", "vigencias": [{"desde": "2010-09-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-09-28", "fin_vigencia": ""}, "vigencias_ve