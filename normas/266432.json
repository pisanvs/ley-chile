{"html": [{"t": "<div><div class=\"p\">AUTORIZA EMISOR ELECTR&#xD3;NICO </div></div>", "i": 6629540}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 135 de 08.11.07, que autoriza a contribuyente como emisor electr&#xF3;nico.</div><div class=\"p\">Se autoriza como emisor de documentos tributarios RUT 96.800.460-3 a contar del mes de noviembre 2007. En la Oficina Virtual del SII en internet se podr&#xE1; consultar los documentos que el contribuyente est&#xE1; autorizado a emitir en forma electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de noviembre de 2007.</div><br><br><br></div>", "i": 6629541}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "135 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-135 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISOR ELECTRÓNICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-11-08", "doble_articulado": false, "id_norma": "266432", "numero_fuente": "38911", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-11-14", "vigencias": [{"desde": "2007-11-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-11-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-11-1