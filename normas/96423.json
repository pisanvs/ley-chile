{"html": [{"t": "<div><div class=\"p\">CERTIFICA CALIDAD DE AGENTE RETENEDOR DE IVA POR COMPRA DE ESPECIES HIDROBIOLOGICAS </div></div>", "i": 6690882}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional Metropolitana Santiago Oriente del Servicio de Impuestos Internos, por resoluci&#xF3;n N&#xBA; Ex. 131 de 1998, certifica que a contar del 1 del mes siguiente al de esta publicaci&#xF3;n y hasta el 30 de junio de 1998, la Sociedad Pesquera Seijo Ltda., Rut N&#xBA; 78.622.300-8, tiene la calidad de Agente Retenedor del Impuesto al Valor Agregado, por las compras de especies hidrobiol&#xF3;gicas, por cuanto cumple los requisitos establecidos en la&nbsp; resoluci&#xF3;n N&#xBA; Ex.</div><div class=\"p\">3.173 de 27-06-97.-</div><br></div>", "i": 6690883}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Bernardo Seaman Gonz&#xE1;lez, Director Regional. </div></div>", "i": 6690884}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "131 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-131 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO ORIENTE"], "titulo_norma": "CERTIFICA CALIDAD DE AGENTE RETENEDOR DE IVA POR COMPRA DE ESPECIES HIDROBIOLOGICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "SOCIEDAD PESQUERA SEIJO LTDA.", "ESPECIES HIDROBIOLOGICAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "96423", "numero_fuente": "35991", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-02-14", "vigencias": [{"desde": "1998-02-14", "hasta": "", "tipo_version": "3", "tipo_versio