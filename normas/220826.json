{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6462177}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 273, de 22 de enero de</div><div class=\"p\">2004 de esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA; de</div><div class=\"p\">la resoluci&#xF3;n N&#xBA; 2.727 de 2003, modificada por</div><div class=\"p\">resoluci&#xF3;n N&#xBA; 3.558 de 2003, ambas de esta</div><div class=\"p\">Subsecretar&#xED;a, que autorizaron al INSTITUTO DE FOMENTO</div><div class=\"p\">PESQUERO para efectuar una pesca de investigaci&#xF3;n de</div><div class=\"p\">conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del</div><div class=\"p\">proyecto denominado &quot;Operaci&#xF3;n de las redes de cerco</div><div class=\"p\">artesanal de Jurel en aguas interiores de la X Regi&#xF3;n, 2003&quot;, en el sentido de sustituir la embarcaci&#xF3;n artesanal &quot;Don Camilo&quot;, N&#xBA; de RPA 24.912, por la embarcaci&#xF3;n &quot;Don Diego II&quot;, N&#xBA; de RPA 915715. </div></div>", "i": 6462178}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de enero de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6462179}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "273 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-273 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-22", "doble_articulado": false, "id_norma": "220826", "numero_fuente": "37776", "tipo_version": "3", "tipo_version_s":