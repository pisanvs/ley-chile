{"html": [{"t": "<div><div class=\"p\">APRUEBA ORDENANZA MUNICIPAL QUE INDICA </div></div>", "i": 7369226}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante decreto exento N&#xBA; 3.211, de fecha 24 de abril a&#xF1;o 2008, la I. Municipalidad de Calbuco aprueba Ordenanza Municipal sobre &quot;Graffitis, rayados en muros, paredes, fachadas exteriores, postes de alumbrado p&#xFA;blico, elementos mobiliarios, ubicados en bienes nacionales de uso p&#xFA;blico, fiscales, municipales y de propiedad privada en la comuna de Calbuco&quot;.</div><div class=\"p\">&nbsp; &nbsp;  La Ordenanza &#xED;ntegra se encuentra a disposici&#xF3;n del p&#xFA;blico en el sitio web de la Municipalidad. </div></div>", "i": 7369227}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Calbuco, 24 de abril de 2008.- Rub&#xE9;n R. C&#xE1;rdenas G&#xF3;mez, Alcalde.- Leonel Villarroel Villarroel, Secretario Municipal.</div><br></div>", "i": 7369228}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3211 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3211 EXENTO"}], "organismos": ["MUNICIPALIDAD DE CALBUCO"], "titulo_norma": "APRUEBA ORDENANZA MUNICIPAL QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDAD DE CALBUCO", "GRAFFITIS", "RAYADOS", "ORDENANZA MUNICIPAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-04-24", "doble_articulado": false, "id_norma": "271101", "numero_fuente": "39058", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-05-10", "vigencias": [{"desde": "2008-05-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-05-10", "fin_vigencia": ""}, "vigencias_version_norm