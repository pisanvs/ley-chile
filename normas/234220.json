{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6511356}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 836 de 13 de diciembre de 2004 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n total, conforme D.L. N&#xBA; 2.186 de 1978, del Lote N&#xBA; 365 correspondiente al inmueble ubicado en calle Silva N&#xBA; 716, presunto Rol de Aval&#xFA;o N&#xBA; 640-17, comuna de San Miguel, aparente dominio de Gonz&#xE1;lez Mart&#xED;nez Juan. Comisi&#xF3;n integrada por peritos Carmen Pilar R&#xED;os Marcuello, Arquitecto; Luisa Ver&#xF3;nica Aracena Hern&#xE1;ndez, Constructor Civil, y Juan Alfredo D&#xED;az Velasco, Arquitecto. Seg&#xFA;n informe de 9 de noviembre de 2004, fij&#xF3; monto provisional indemnizaci&#xF3;n en $39.144.770.- pagadera al contado.</div><br></div>", "i": 6511357}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6511358}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "836", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-836"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES PARCIALES DE INMUEBLES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-13", "doble_articulado": false, "id_norma": "234220", "numero_fuente": "38050", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-01-03", "vigencias": [{"desde": "2005-01-03", "hasta": "", "tipo_version": "3", "tipo