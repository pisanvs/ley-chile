{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 394 EXENTO, DE 1996 </div></div>", "i": 5944263}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 394, de fecha 23 de julio de 1996, del Ministerio de Educaci&#xF3;n, se revoc&#xF3; la autorizaci&#xF3;n de funcionamiento y se elimin&#xF3; del Libro de Registro de Institutos Profesionales - N&#xB0; 48 - al Instituto Profesional CONANDES, de Arica, organizado por la Sociedad Instituto Profesional Conandes Limitada. Asimismo, se derogaron los Decretos Exentos de Educaci&#xF3;n N&#xB0; 92 de fecha 11 de Mayo de 1989 y N&#xB0; 43 de fecha 9 de febrero de 1990.</div><div class=\"p\">&nbsp; &nbsp; Lo dispuesto precedentemente importa la p&#xE9;rdida del reconocimiento oficial del Instituto Profesional CONANDES, de Arica.</div><br></div>", "i": 5944264}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 31 de julio de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5944265}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "394 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-394 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 394 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REVOCACION", "ELIMINACION", "LIBRO REGISTRO INSTITUTOS", "PROFESIONALES", "INSTITUTO PROFESIONAL CONANDES", "ARICA", "PRIMERA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-07-23", "doble_articulado": false, "id_norma": "21135", "numero_fuente": "35535", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-08-06", "vigencias": [{"desde": "1996