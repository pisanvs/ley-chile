{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA RECEPTORES ELECTR&#xD3;NICOS</div><br></div>", "i": 9213432}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA;139, de 6 de diciembre de 2011, que autoriza a contribuyentes como receptores electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como receptor de documentos tributarios electr&#xF3;nicos a los contribuyentes RUT N&#xBA;69.072.000-0, RUT N&#xBA;69.254.600-8, RUT N&#xBA;61.952.000-9, RUT N&#xBA;65.453.620-1, a contar del mes de noviembre 2011.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de diciembre de 2011.</div></div>", "i": 9213433}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "139 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-139 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA RECEPTORES ELECTRÓNICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-12-06", "doble_articulado": false, "id_norma": "1034026", "numero_fuente": "40131", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-12-10", "vigencias": [{"desde": "2011-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-12-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia":