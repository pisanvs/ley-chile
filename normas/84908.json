{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 13, DE 1990 </div></div>", "i": 6069111}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 13, de 16 de enero de 1990, se ha aprobado a contar del a&#xF1;o lectivo 1990 y por un per&#xED;odo de seis a&#xF1;os, planes especiales de estudio de orientaci&#xF3;n laboral para alumnos discapacitados para ser aplicados por la Escuela Especial F No. 13 de Punta Arenas. </div></div>", "i": 6069112}, {"t": "<div><div class=\"p\">Santiago, 23 de Enero de 1990.- Mar&#xED;a Sixtina Barriga Cuzm&#xE1;n, Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6069113}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "13 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-13 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 13, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-16", "doble_articulado": false, "id_norma": "84908", "numero_fuente": "33600", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-19", "vigencias": [{"desde": "1990-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MNV", "fecha_ingreso": "1998-01-15", "fecha_version": "1990-02-19", "fecha_actualizacion_texto": "1990-02-19", "tipo_tratado": ""}, "alertas": []