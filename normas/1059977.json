{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 10.076 EXENTA, DE 2013</div></div>", "i": 9410467}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 10.076, de 18 de diciembre de 2013, del Servicio Nacional de Capacitaci&#xF3;n y Empleo, fija para el a&#xF1;o 2014 la cantidad de $40.000 (cuarenta mil pesos), por cada Unidad de Competencia Laboral, tambi&#xE9;n denominada UCL, como valor m&#xE1;ximo a descontar por cada proceso de evaluaci&#xF3;n y certificaci&#xF3;n de competencias laborales efectuado, denominado valor proceso de evaluaci&#xF3;n y certificaci&#xF3;n de competencias laborales participante.</div></div>", "i": 9410468}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (S).</div></div>", "i": 9410469}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10076 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-10076 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 10.076 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-12-18", "doble_articulado": false, "id_norma": "1059977", "numero_fuente": "40798", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-03-04", "vigencias": [{"desde": "2014-03-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-03-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014-03-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [],