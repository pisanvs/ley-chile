{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8324568}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 732, de 30 de Junio de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n No. 1.350, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la Sociedad Industrial y Comercial Friocongelados Limitada R.U.T. No.</div><div class=\"p\">79.736.580-7, domiciliada en Puerto Varas, para desarrollar actividades pesqueras de transformaci&#xF3;n, en orden a sustituir en su numeral 2&#xB0; la expresi&#xF3;n &quot;Sector La Laja&quot;, Km. 11, ruta 5, Puerto Montt&quot;, por &quot;el Barrio Industrial de Puerto Montt, Polpaico No. 37, Puerto Montt, X Regi&#xF3;n&quot;. </div></div>", "i": 8324569}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 30 de Junio de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8324570}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "732", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-732"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-06-30", "doble_articulado": false, "id_norma": "94242", "numero_fuente": "33418", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-07-10", "vigencias": [{"desde": "1989-07-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-07-10", "fin_vigencia": ""}, "vigencias_versi