{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6047506}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. N&#xBA; 796, de 29 de agosto de 1997, se expropiaron los lotes de terreno N&#xBA;s. 4, 5 y 6, superficies 67.800, 79.200 y 306.350 m2.</div><div class=\"p\">respectivamente, roles de aval&#xFA;o 520-4, 520-15 y 520-14, comuna de Antuco, para la obra Camino Antuco - Los Barros - Pichachen y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Carmen Ortiz Carrasco y otros, Calixto Pinochet R&#xED;os y Calixto Pinochet R&#xED;os y otros, ascendentes a las cantidades de $3.046.624.- para el lote N&#xBA; 4, $3.977.274.- para el lote N&#xBA; 5 y $18.704.511.- para el lote N&#xBA; 6.-</div><br></div>", "i": 6047507}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6047508}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "796", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-796"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "ANTUCO", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-08-29", "doble_articulado": false, "id_norma": "76349", "numero_fuente": "35891", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-10-15", "vigencias": [{"desde": "1997-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-10-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_