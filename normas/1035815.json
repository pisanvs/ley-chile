{"html": [{"t": "<div><br><div class=\"p\">FIJA N&#xD3;MINA DE GRANDES CONTRIBUYENTES</div><br></div>", "i": 9223470}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 157 del 30 de diciembre de 2011, que Fija N&#xF3;mina de Grandes Contribuyentes.</div><div class=\"p\">&nbsp; &nbsp;  Fija N&#xF3;mina de Grandes Contribuyentes de conformidad a lo dispuesto en el art&#xED;culo tercero bis del DFL N&#xB0;7 de 1980. Se adjunta anexo &quot;A&quot; con contribuyentes que forman la n&#xF3;mina citada y anexo &quot;B&quot; con aquellos que dejan de pertenecer a la misma.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en diciembre de 2011.</div></div>", "i": 9223471}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "157 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-157 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "FIJA NÓMINA DE GRANDES CONTRIBUYENTES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-12-30", "doble_articulado": false, "id_norma": "1035815", "numero_fuente": "40152", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-01-04", "vigencias": [{"desde": "2012-01-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-01-04", "fin_vigencia": ""}, "v