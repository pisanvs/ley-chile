{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6068234}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 16 de 20 de Marzo de 1990, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se autoriza a don Pedro Pablo Vallejos M&#xE9;ndez para trasladar la ubicaci&#xF3;n de la Planta Revisora de la Clase A, desde la calle Brasil No. 991 Linares a calle Brasil No. 850 de la misma comuna.- </div></div>", "i": 6068235}, {"t": "<div><div class=\"p\">J. Hern&#xE1;n Poblete Rodr&#xED;guez, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n del Maule. </div></div>", "i": 6068236}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "16", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-16"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-20", "doble_articulado": false, "id_norma": "84586", "numero_fuente": "33630", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-26", "vigencias": [{"desde": "1990-03-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-03-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-03-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MNV", "fecha_ingreso": "1998-01-13", "fecha_version": "1990-03-26", "fecha_actualizacion_texto": "1990-03-26", "tipo_tratado": ""}, "alert