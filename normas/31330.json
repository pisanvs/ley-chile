{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA RESOLUCION N&#xB0; 48 DE 1991</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 92.- Santiago 31 de Octubre de 1991.- Visto: Lo dispuesto por los art&#xED;culos 56, 88, 89 y 98 de la Ley N&#xB0; 18.290 y por la Resoluci&#xF3;n N&#xB0; 48, de 18 de Julio de 1991.</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 8923916}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Modif&#xED;case la resoluci&#xF3;n N&#xB0; 48 de 1991 antes referida, en los siguientes t&#xE9;rminos:</div><div class=\"p\">&nbsp; &nbsp; En el inciso primero del n&#xFA;mero 1&#xB0;, supr&#xED;mise la expresi&#xF3;n &quot;o igual&quot;, y en el n&#xFA;mero 2&#xB0;, reempl&#xE1;zase &quot;mayor a 18 a&#xF1;os&quot; por &quot;mayor o igual a 18 a&#xF1;os&quot;. </div></div>", "i": 8923917}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- Germ&#xE1;n Correa D&#xED;az, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Saluda a Ud.- Patricia Mu&#xF1;oz Villela, Jefe Administrativo. </div></div>", "i": 8923918}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "92", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-92"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "MODIFICA RESOLUCION N° 48 DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LOCOMOCION COLECTIVA", "VEHICULO MOTORIZADO", "RESTRICCION", "CIRCULACION", "CONTAMINACION AMBIENTAL", "SANTIAGO", "SAN BERNARDO", "PUENTE ALTO", "BUSES", "TAXIBUSES", "MINIBUSES", "ASIENTO", "ANTIGUEDAD", "PLANTA REVISORA", "CERTIFICADO REVISION TECNICA", "REVISION TECNICA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_