{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10132554}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.358 de fecha 19/06/2020, conforme al art&#xED;culo 51 ley 16.391, DL 2.186/1978 y DS 1.128/2012 de Vivienda y Urbanismo, para destinarlo al Proyecto &quot;Mejoramiento Calle Alvarado entre Francisco Pizarro y Huichahue, Padre Las Casas&quot;, Serviu Regi&#xF3;n de la Araucan&#xED;a orden&#xF3; la expropiaci&#xF3;n de parte del Lote N&#xBA; 1-0 &quot;Lote propiedad del Fisco de Chile ubicado entre las calles Pleiteado y Alvarado de la comuna de Padre Las Casas&quot;, sin Rol de aval&#xFA;o. La superficie a expropiar aproximada es de 743,01 metros cuadrados, de aparente dominio del Fisco de Chile, Comisi&#xF3;n de Peritos designada al efecto, fij&#xF3; monto de indemnizaci&#xF3;n provisional en $39.250.297.- seg&#xFA;n Informe N&#xBA; 01-0 de fecha 16/06/2019, pagadero contado.- </div></div>", "i": 10132555}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director (S) Serviu Regi&#xF3;n de la Araucan&#xED;a.</div><br></div>", "i": 10132556}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1358", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1358"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1776078", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-06-19", "doble_articulado": false, "id_norma": "1147102", "numero_fuente": "42694", "tipo_version": "3", "tipo_