{"html": [{"t": "<div><div class=\"p\">PONE T&#xC9;RMINO AL NOMBRAMIENTO COMO ALCALDE DE MAR AD-HON&#xD3;REM</div></div>", "i": 9848018}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n D.G.T.M. y M.M. Ord. N&#xBA; 1.120/133 Vrs., de fecha 14 de septiembre de 2017, pone t&#xE9;rmino al nombramiento como Alcalde de Mar Ad-Hon&#xF3;rem del Sr. Juan Galleguillos Luna.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de estas resoluciones se encuentra publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl).</div></div>", "i": 9848019}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de octubre de 2017.- Guillermo L&#xFC;ttges Mathieu, Contraalmirante, Director General.- Rodrigo Ram&#xED;rez&nbsp; Daneri, Capit&#xE1;n de Nav&#xED;o JT, Jefe Depto. Jur&#xED;dico.</div></div>", "i": 9848020}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "133", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-133"}, {"tipo": "3", "numero": "1120/133", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1120/133"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "PONE TÉRMINO AL NOMBRAMIENTO COMO ALCALDE DE MAR AD-HONÓREM", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; CVE 1301106"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-09-14", "doble_articulado": false, "id_norma": "1110420", "numero_fuente": "41905", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-11