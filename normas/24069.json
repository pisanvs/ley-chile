{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,560, que crea un puesto de Vista Interventor de Aduanas.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,560.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 7166807}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Agr&#xE9;gase a continuaci&#xF3;n del Item 519 de la Partida 7.a del Presupuesto del presente a&#xF1;o, del Ministerio de Hacienda, el siguiente:</div><div class=\"p\"> Item 519a.- Vista interventor_____________$ 9,000</div><br></div>", "i": 7166808}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintiocho de Noviembre de mil novecientos diecinueve.- JUAN LUIS SANFUENTES.- Guillermo Subercaseaux.</div><br></div>", "i": 7166809}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3560", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3560"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LEI NÚM. 3,560, QUE CREA UN PUESTO DE VISTA INTERVENTOR DE ADUANAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1919", "MODIFICACION", "MINISTERIO", "HACIENDA", "VISTA INTERVENTOR ADUANAS", "CARGO", "CREACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1919-11-28", "doble_articulado": false, "id_norma": "24069", "numero_fuente": "12556", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1919-12-29", "vigencias": [{"desde": "1919-1