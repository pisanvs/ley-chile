{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6364250}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.800, de 31 de octubre de 2001, se expropi&#xF3; el lote de terreno N&#xBA;12, superficie 2.434 m2., rol de aval&#xFA;o 980-7, comuna de Villa Alemana, para la obra Concesi&#xF3;n Internacional Interconexi&#xF3;n Vial Santiago-Valpara&#xED;so, Vi&#xF1;a del Mar. Troncal Sur. Enlace Pe&#xF1;ablanca Kms. 86.440,00 al 87.860,00, Quinta Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Sergio Seleuco M&#xE1;rquez Jego, ascendente a la cantidad de $18.203.522.-. para el lote N&#xBA;12. </div></div>", "i": 6364251}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6364252}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1800", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1800"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-10-31", "doble_articulado": false, "id_norma": "193265", "numero_fuente": "37149", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-02", "vigencias": [{"desde": "2002-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2002-01-04", "fecha_version": "2002-01-02", "fecha_actu