{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7310930}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 937, de 6 de abril de 2004, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA; de la resoluci&#xF3;n N&#xBA; 1.989 de 2003, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA BIO BIO S.A. a realizar actividades pesqueras extractivas con la nave &quot;Oceanic II&quot;, en el sentido de indicar que la fecha para iniciar actividades pesqueras sobre los recursos autorizados, es de un a&#xF1;o contado desde la fecha de publicaci&#xF3;n de la citada resoluci&#xF3;n y no la que all&#xED; se indica. </div></div>", "i": 7310931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7310932}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "937 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-937 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-04-06", "fecha_derogacion": "2004-12-07", "doble_articulado": false, "id_norma": "224365", "numero_fuente": "37849", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-04-30", "vigencias": [{"desde": "2004-12-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-04-30", "hasta": "2004-12-06", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2004-12-07", "fin_vigencia"