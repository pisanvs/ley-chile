{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6522004}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;99, de fecha 11 de marzo de 2005, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme D.L. N&#xBA;2.186 de 1978, del Lote N&#xBA;221 correspondiente a parte del inmueble ubicado en Avenida Santa Rosa por Berman, presunto Rol de Aval&#xFA;o N&#xBA;6233-6, comuna de San Miguel, de aparente dominio de Vald&#xE9;s Zeballos Ram&#xF3;n. Comisi&#xF3;n integrada por peritos Eric Ehrenfelf Allera, Arquitecto; Dionisio Rodr&#xED;guez Astudillo, Constructor Civil, y Fernando Senerman Mandel, Arquitecto, seg&#xFA;n informe de fecha 22 de septiembre de 2004 fij&#xF3; monto provisional indemnizaci&#xF3;n en $14.420.860, pagadera al contado.-</div><br></div>", "i": 6522005}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Director Serviu Metropolitano.</div><br></div>", "i": 6522006}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "99", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-99"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "ORDENA EXPROPIACIONES PARCIALES DE INMUEBLES QUE INDICA; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-03-11", "doble_articulado": false, "id_norma": "237053", "numero_fuente": "38136", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-04-15", "vigencias": [{"desde": "2005-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci