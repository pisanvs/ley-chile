{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  AUTORIZA A PESQUERA SAN MIGUEL LTDA. PARA AMPLIAR SUS ACTIVIDDES PESQUERAS</div><br><br><br></div>", "i": 8543686}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 604, de 12 de Agosto de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, pronunci&#xE1;ndose sobre solicitud de 10 de Enero de 1986, se autoriza a Pesquera San Miguel Ltda., domiciliada en Talcahuano, para operar la embarcaci&#xF3;n denominada &quot;Westport&quot;, en el litoral de las regiones VII, VIII, IX y X en labores extractivas de los siguientes recursos, para reducci&#xF3;n: jurel, sardina espa&#xF1;ola, sardina com&#xFA;n, anchoa, merluza de cola, merluza de tres aletas y caballa.</div><br></div>", "i": 8543687}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de Agosto de 1986.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8543688}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "604", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-604"}], "organismos": ["MINISTERIO DE ECONOMÍA", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA SAN MIGUEL LTDA. PARA AMPLIAR\nSUS ACTIVIDDES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-08-12", "fecha_derogacion": "2003-09-17", "doble_articulado": false, "id_norma": "122944", "numero_fuente": "32573", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-09-15", "vigencias": [{"desde": "2003-09-17", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desd