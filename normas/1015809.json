{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA EMISORES DE BOLETAS ELECTR&#xD3;NICAS</div><br></div>", "i": 8955032}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 117, de 28 de julio de 2010, que autoriza contribuyentes como emisor de boleta electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de boleta electr&#xF3;nica a contribuyentes RUT 88.192.900-7 a contar del mes de agosto de 2010. En la Oficina Virtual del SII en Internet se podr&#xE1;n consultar los documentos que los contribuyentes est&#xE1;n autorizados a emitir en forma electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de julio de 2010.</div><br></div>", "i": 8955033}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "117 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-117 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISORES DE BOLETAS ELECTRÓNICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-07-28", "doble_articulado": false, "id_norma": "1015809", "numero_fuente": "39724", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-07-31", "vigencias": [{"desde": "2010-07-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-07-31", "fin_vigenc