{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9187885}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.289, de 25 de agosto de 2011, de esta Subsecretar&#xED;a, autor&#xED;zase a JAIME ROM&#xC1;N &#xC1;LVAREZ ARMIJO, para ampliar actividades pesqueras extractivas, con la nave &quot;Cazador&quot;, en el &#xE1;rea mar&#xED;tima de la V Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, con arrastre, sobre el recurso hidrobiol&#xF3;gico Jibia o Calamar Rojo.</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n exenta N&#xBA; 1.664 de 2011, de esta Subsecretar&#xED;a.</div></div>", "i": 9187886}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de agosto de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9187887}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2289 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2289 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2011-08-25", "fecha_derogacion": "2013-04-02", "doble_articulado": false, "id_norma": "1030214", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2011-09-26", "vigencias": [{"desde": "2013-04-02", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2011-09-26", "hasta": "2013-04-01", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2013-04-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci