{"html": [{"t": "<div><br><div class=\"p\">IMPARTE INSTRUCCIONES RELACIONADAS CON LA &quot;REVISI&#xD3;N DE LAS ACTUACIONES DE FISCALIZACI&#xD3;N DE LA AUTORIDAD QUE INDICA&quot;</div><br></div>", "i": 8957958}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de Circular del Servicio de Impuestos Internos N&#xBA;45 del 30 de julio de 2010, que imparte instrucciones relacionadas con la revisi&#xF3;n de las actuaciones de fiscalizaci&#xF3;n emanadas del Subdirector de Fiscalizaci&#xF3;n del Servicio de Impuestos Internos, o de los funcionarios en los cuales &#xE9;ste delegue sus facultades.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en julio de 2010.</div></div>", "i": 8957959}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "45", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-45"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-07-30", "doble_articulado": false, "id_norma": "1015914", "numero_fuente": "39727", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-08-04", "vigencias": [{"desde": "2010-08-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-08-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-08-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [],