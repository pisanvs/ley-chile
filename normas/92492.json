{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA</div><br><br><br></div>", "i": 8321875}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No 1.351, de 28 de Septiembre de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 1&#xB0; de la Resoluci&#xF3;n No. 179, de 1989, de esta Subsecretar&#xED;a, modificatoria de la Resoluci&#xF3;n No 573, de 1988, que autoriz&#xF3; a Pesquera Santa Luc&#xED;a S.A., R.U.T. No 96.527.920-2 domiciliada en Santiago, para desarrollar actividades pesqueras de extracci&#xF3;n, en el sentido de se&#xF1;alar que el n&#xFA;mero de Matr&#xED;cula de la nave &quot;VAMA II&quot; es 2564.</div><br><br></div>", "i": 8321876}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de Septiembre de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br><br></div>", "i": 8321877}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1351", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1351"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1989-09-28", "fecha_derogacion": "1994-03-14", "doble_articulado": false, "id_norma": "92492", "numero_fuente": "33503", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1989-10-23", "vigencias": [{"desde": "1994-03-14", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1989-10-23", "hasta": "1994-03-13", "tipo_version": "0", "tip