{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Biblioteca del Congreso Lei n&#xFA;m. 1,252.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274222}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de ocho mil pesos al &#xED;tem 4 de la partida 3.a del presupuesto del Ministerio del Interior, para fomento de la Biblioteca del Congreso.</div><br><br></div>", "i": 8274223}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 2 de Setiembre de 1899.- FEDERICO ERRAZURIZ.- R. Silva Cruz.</div><br></div>", "i": 8274224}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1252", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1252"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "BIBLIOTECA DEL CONGRESO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1899", "MODIFICACION", "BIBLIOTECA", "CONGRESO", "MINISTERIO INTERIOR", "SUPLEMENTO", "FOMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-09-02", "doble_articulado": false, "id_norma": "22505", "numero_fuente": "6390", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-09-02", "vigencias": [{"desde": "1899-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-09