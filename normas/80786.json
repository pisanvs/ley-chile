{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 188, DE 1991</div><br><br></div>", "i": 6058121}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 188 de 18 de julio de 1991 se ha aprobado para el L&#xED;ceo Agr&#xED;cola &quot;Los Guindos&quot; de Buin, un plan especial de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico - Profesional en la Especialidad de Hortofruticultura para aplicarse en 4&#xB0; y 5&#xB0; a&#xF1;o medio, durante los a&#xF1;os 1991 y 1992.</div><div class=\"p\">Adem&#xE1;s, se aprueban programas de estudio del Area de Asignaturas Profesionales que se se&#xF1;alan.</div><br></div>", "i": 6058122}, {"t": "<div><div class=\"p\">Santiago, 09 de Agosto de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6058123}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "188 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-188 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 188, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-07-18", "doble_articulado": false, "id_norma": "80786", "numero_fuente": "34056", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-08-30", "vigencias": [{"desde": "1991-08-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-08-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-08-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "