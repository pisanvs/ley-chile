{"html": [{"t": "<div><div class=\"p\">MODIFICA ORDENANZA LOCAL SOBRE DERECHOS MUNICIPALES </div></div>", "i": 6364119}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se comunica que la I. Municipalidad de La Pintana, seg&#xFA;n Acuerdo tomado por su Honorable Concejo Municipal en su sesi&#xF3;n ordinaria N&#xBA; 20 de 18 de diciembre del a&#xF1;o 2001, ha procedido a modificar su Ordenanza Local sobre Derechos Municipales, dichas modificaciones empezar&#xE1;n a regir a contar del 1&#xBA; de enero del a&#xF1;o 2002 y su nuevo texto podr&#xE1; ser adquirido en Secretar&#xED;a Municipal de la I. Municipalidad de La Pintana.</div><br></div>", "i": 6364120}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese, publ&#xED;quese y arch&#xED;vese.- Jaime Pavez Moreno, Alcalde.- Carlos Geerdts Z&#xFA;&#xF1;iga, Secretario Municipal (S).</div><br></div>", "i": 6364121}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "23", "numero": "20", "abreviacion": "SES", "descripcion": "Sesion", "compuesto": "SES-20"}], "organismos": ["MUNICIPALIDAD DE LA PINTANA"], "titulo_norma": "MODIFICA ORDENANZA LOCAL SOBRE DERECHOS MUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-18", "doble_articulado": false, "id_norma": "193234", "numero_fuente": "37148", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-12-31", "vigencias": [{"desde": "2001-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-12-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-12-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacione