{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,146, que concede un suplemento al Presupuesto de Guerra</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,146.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5952882}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de veintiocho mil pesos al &#xED;tem 141 de la partida 6.a del Presupuesto vijente de Guerra destinado a la compra de materiales, aseo de armamento, pago de jornales i gastos jenerales de la Direccion de Material de Guerra. </div></div>", "i": 5952883}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 23 de Noviembre de 1908.- PEDRO MONTT.- Guillermo Echavarr&#xED;a.</div><br></div>", "i": 5952884}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2146", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2146"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "LEI NUM. 2,146, QUE CONCEDE UN SUPLEMENTO AL PRESUPUESTO DE GUERRA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1908", "MODIFICACION", "MINISTERIO", "GUERRA MATERIAL ASEO ARMAMENTO", "COMPRA", "JORNALES", "PAGO", "DIRECCION MATERIAL GUERRA", "GASTOS GENERALES", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1908-11-23", "doble_articulado": false, "id_norma": "23151", "numero_fuente": "9253", "tipo_version": "3", "tipo_version_