{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7381102}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.042, de 20 de noviembre de 2008 de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad total de las resoluciones que a continuaci&#xF3;n se se&#xF1;alan, en virtud de lo dispuesto en el art&#xED;culo 143 letra d) de la Ley General de Pesca y Acuicultura:</div><div class=\"p\">a) resoluciones exentas N&#xBA; 2.957 de 2002, N&#xBA; 1.956 y N&#xBA; 1.957, ambas de 2003, N&#xBA; 2.669 y N&#xBA; 3.040, ambas de 2006, que autorizaron a SOCIEDAD PESQUERA MARLIMAR LIMITADA para realizar actividades extractivas con la nave &quot;Tiberiades&quot;; b) resoluciones exentas N&#xBA; 187 de 1984, N&#xBA; 269 de 1990, N&#xBA; 1.598 de 2001, que autorizaron a Pesquera Concepci&#xF3;n Limitada para realizar actividades extractivas con la nave &quot;Hecht&quot;.</div><br><br></div>", "i": 7381103}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de noviembre de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br><br></div>", "i": 7381104}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3042 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3042 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN NOMBRE"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-11-20", "doble_articulado": false, "id_norma": "282132", "numero_fuente": "39221", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-11-25", "vigencias": [{"desde": "