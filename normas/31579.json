{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE RESOLUCIONES EXENTA N&#xB0; 652, DE 1990 </div></div>", "i": 6001373}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 652 de fecha 26.12.90, la Secretar&#xED;a Ministerial de Educaci&#xF3;n de la Regi&#xF3;n de Antofagasta ha aprobado Plan y Programa de Estudio de 3&#xB0; y 4&#xB0; a&#xF1;o de la Educaci&#xF3;n Media T&#xE9;cnico Profesional, para el Liceo Polit&#xE9;cnico C-20 de Taltal, en la especialidad de Atenci&#xF3;n de P&#xE1;rvulos.</div><div class=\"p\">&nbsp; &nbsp; El plan y Programa aprobado tendr&#xE1; vigencia a contar del a&#xF1;o escolar 1991 y hasta el a&#xF1;o 1992.</div><br></div>", "i": 6001374}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Antofagasta, diciembre de 1990.- Secretario Ministerial Educaci&#xF3;n Regi&#xF3;n de Antofagasta. </div></div>", "i": 6001375}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "652", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-652"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCIONES EXENTA N° 652, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LICEO POLITECNICO C N 20", "TALTAL", "PLAN ESTUDIO", "PROGRAMA ESTUDIO", "APROBACION."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-26", "doble_articulado": false, "id_norma": "31579", "numero_fuente": "33972", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-05-20", "vigencias": [{"desde": "1991-05-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-05-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-05-20",