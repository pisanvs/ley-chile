{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.143 EXENTO, DE 1997 </div></div>", "i": 6063458}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto supremo exento de Educaci&#xF3;n N&#xBA; 1.143, de 12 de noviembre de 1997, se ha aprobado plan de estudio y programas especiales para 5&#xBA;, 6&#xBA;, 7&#xBA; y 8&#xBA; a&#xF1;o de ense&#xF1;anza b&#xE1;sica biling&#xFC;e al Colegio &quot;The English Institute&quot; de Santiago, Regi&#xF3;n Metropolitana, correspondiente a los niveles NB. 3, NB. 4, NB. 5 y NB.</div><div class=\"p\">6, respectivamente, que se aplicar&#xE1; gradualmente de acuerdo con lo se&#xF1;alado en el Decreto N&#xBA; 40, de 1996, y sus modificaciones.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se se&#xF1;alan en el presente Decreto. </div></div>", "i": 6063459}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de noviembre de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6063460}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1143 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1143 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.143 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIO THE ENGLISH INSTITUTE", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-11-12", "doble_articulado": false, "id_norma": "82861", "numero_fuente": "35943", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-12-18", "vigencias": [{"d