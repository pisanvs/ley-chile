{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10319842}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xB0; 136 de 2 febrero 2022, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos relativas a la actividad denominada &quot;Reparaci&#xF3;n Reductor de Velocidad de la Comuna de Coyhaique&quot;, y autoriz&#xF3; a la I. Municipalidad de Coyhaique, para realizar las siguientes intervenciones en la v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - Corte total de v&#xED;a en calle Arturo Prat con calle Dussen de la ciudad de Coyhaique, los trabajos se desarrollar&#xE1;n durante 15 d&#xED;as corridos, una vez aprobada la presente resoluci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10319843}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andrea Mac&#xED;as Palma, Gobernadora Regional.- Javier Gonz&#xE1;lez Jara, Asesor Jur&#xED;dico.</div><br></div>", "i": 10319844}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "136 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-136 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2102055", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-02-02", "doble_articulado": false, "id_norma": "1173987", "numero_fuente": "43209", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-03-22", "vigencias": [{"desde": "2022-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}],