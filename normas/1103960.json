{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 2.114 EXENTA, DE 8 DE MAYO DE 2017</div></div>", "i": 9805226}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=164746&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 12.878, de 1999, del Ministerio de Educaci&#xF3;n</a> que aprob&#xF3; plan y programas de estudio al Colegio Mar&#xED;a Auxiliadora, RBD 25509-2, Comuna y Provincia de Santiago, Regi&#xF3;n Metropolitana, en el sentido de sustituir su plan de estudio de 1&#xBA; y 2&#xBA; a&#xF1;o de educaci&#xF3;n media por los que se indican en la presente resoluci&#xF3;n exenta y aprobar los programas especiales de estudio de las asignaturas de Filosof&#xED;a y Cultura Religiosa para primer a&#xF1;o de educaci&#xF3;n media.</div></div>", "i": 9805227}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de mayo de 2017.- Valentina Karina Quiroga Canahuate, Subsecretaria de Educaci&#xF3;n.</div></div>", "i": 9805228}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2114 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2114 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 2.114 EXENTA, DE 8 DE MAYO DE 2017", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1227053; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-05-08", "doble_articulado": false, "id_norma": "1103960", "numero_fuente": "41783", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-06-14", "vigencias