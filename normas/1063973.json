{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 2.848 EXENTA, DE 2014</div></div>", "i": 9485559}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.848, de 5 de junio de 2014, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Balanced Training SpA (Balanced Training SpA)&quot;, RUT 76.139.648-K contenida en la resoluci&#xF3;n exenta N&#xBA; 6.980 de fecha 8 de agosto de 2011, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.</div></div>", "i": 9485560}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Marcia Pardo Gonz&#xE1;lez, Jefe Departamento de Evaluaci&#xF3;n y Organismos (PT).</div></div>", "i": 9485561}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2848 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2848 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 2.848 EXENTA, DE 2014", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2014-06-05", "fecha_derogacion": "2014-08-09", "doble_articulado": false, "id_norma": "1063973", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2014-07-04", "vigencias": [{"desde": "2014-08-09", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2014-07-04", "hasta": "2014-08-08", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2014-08-09", "fin_vigencia": ""},