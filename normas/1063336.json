{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.451 EXENTA, DE 2014</div></div>", "i": 9479741}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=236211&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 14.695, de 2004, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Colegio Cumbres, comuna de Las Condes, provincia de Santiago, Regi&#xF3;n Metropolitana. </div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas especiales de estudio para los Sectores de C&#xE1;lculo II y Juego de Negocios para 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media del Plan de Formaci&#xF3;n Diferenciada.</div></div>", "i": 9479742}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de junio de 2014.- Gonzalo Mu&#xF1;oz Stuardo, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 9479743}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3451 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3451 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.451 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-06-04", "doble_articulado": false, "id_norma": "1063336", "numero_fuente": "40882", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "