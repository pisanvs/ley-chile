{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 8.036 EXENTA, DE 1999 </div><br></div>", "i": 6195682}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 8.036 de 1&#xBA; de septiembre de 1999, se ha aprobado al Saint George&apos;s College, comuna de Vitacura, de Santiago, un plan especial de estudio para primer a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 1999. Adem&#xE1;s, se aprueban programas de estudio para primer a&#xF1;o de Ense&#xF1;anza Media de los subsectores que se indican en la presente resoluci&#xF3;n exenta.</div><br></div>", "i": 6195683}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de septiembre de 1999.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6195684}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8036 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8036 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 8.036 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-09-01", "doble_articulado": false, "id_norma": "144867", "numero_fuente": "36483", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-10-07", "vigencias": [{"desde": "1999-10-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-10-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-10-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones"