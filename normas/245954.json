{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6556100}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.200, de 30 de noviembre de 2005 de esta Subsecretar&#xED;a, autor&#xED;zase a LUIS ANTONIO GALLARDO OLIVARES para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Ruta N&#xBA; 5 Norte, Barrio Industrial, Cha&#xF1;aral, III Regi&#xF3;n de Atacama, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de picado de algas los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6556101}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de noviembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6556102}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4200 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4200 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-30", "doble_articulado": false, "id_norma": "245954", "numero_fuente": "38355", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-01-05", "vigencias": [{"desde": "2006-01-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-01-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-01-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2006-01