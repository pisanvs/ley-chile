{"html": [{"t": "<div><div class=\"p\">PARTIDO RADICAL SOCIALDEMOCRATA </div></div>", "i": 6477468}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Augusto Parra Mu&#xF1;oz, Presidente Subrogante del Partido Radical Socialdem&#xF3;crata, y Jean Pierre Warnier D. y Guillermo Escobar Reyes, Presidente y Secretario, respectivamente, del Tribunal Supremo de la colectividad, han comunicado la elecci&#xF3;n como Presidente de la Directiva Central del partido de don Enrique Silva Cimma, por renuncia de don Orlando Cantuarias Zepeda.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada en virtud de lo establecido en el Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por resoluci&#xF3;n O-N&#xBA; 692, de fecha 28 de abril de 2004.</div><br></div>", "i": 6477469}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director. </div></div>", "i": 6477470}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "692", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-692"}, {"tipo": "3", "numero": "O-692", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-692"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO RADICAL SOCIALDEMOCRATA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO RADICAL SOCIALDEMOCRATA", "PRESIDENTE", "ENRIQUE SILVA CIMMA", "NOMBRAMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-28", "doble_articulado": false, "id_norma": "224776", "numero_fuente": "37852", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-05-05", "vigencias": [{"desde": "2004-05-05", "hasta": "", "tipo_version":