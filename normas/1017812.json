{"html": [{"t": "<div><div class=\"p\">RECTIFICACI&#xD3;N</div></div>", "i": 9017325}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA; 39.782 de 12 de octubre del 2010, se public&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1017745&amp;idParte=0&amp;idVersion=\">Decreto N&#xFA;m. 761</a>, que DISPONE SUBROGACI&#xD3;N COMO VICEPRESIDENTE DE LA REP&#xDA;BLICA, con el error de transcripci&#xF3;n, que se salva a continuaci&#xF3;n: cuerpo I, p&#xE1;gina uno, tercera columna, donde dice &quot;... y teniendo presente que me ausentar&#xE9; del territorio nacional el d&#xED;a 21 de septiembre de 2020 para viajar a la ciudad de Nueva York, ...&quot; debe decir &quot;... y teniendo presente que me ausentar&#xE9; del territorio nacional el d&#xED;a 21 de septiembre de 2010 para viajar a la ciudad de Nueva York, ...&quot;.</div></div>", "i": 9017326, "v": ["RECTIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "141", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-141"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARÍA DEL INTERIOR"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1017812", "numero_fuente": "39785", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-10-15", "vigencias": [{"desde": "2010-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-10-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul