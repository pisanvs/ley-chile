{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7214166}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 11 de 13 de Enero de 1992 se ha aprobado un plan especial de estudio para educaci&#xF3;n media t&#xE9;cnico-profesional, especialidad Contabilidad de Adultos, conducente al t&#xED;tulo de t&#xE9;cnico de nivel medio: Contador.</div><div class=\"p\">Adem&#xE1;s, se aprueban programas de estudio para las asignaturas del Area Profesional que all&#xED; se mencionan. Asimismo, autoriza aplicar el plan de estudio y programas aprobados al Liceo Comercial A-26 &quot;Instituto Superior de Comercio Eduardo Frei Montalva&quot;, de Santiago. </div></div>", "i": 7214167, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">Santiago, 30 de Marzo de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7214168}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "11 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-11 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-01-13", "doble_articulado": false, "id_norma": "79225", "numero_fuente": "34240", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-04-09", "vigencias": [{"desde": "1992-04-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-04-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-04-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones