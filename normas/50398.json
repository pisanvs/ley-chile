{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8300390}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 2.196, de 31 de diciembre de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad parcial de la Resoluci&#xF3;n N&#xBA; 1.965, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA RIO SIMPSON S.A., para ampliar actividades pesqueras extractivas con la nave &quot;R&#xED;o Simpson&quot;, s&#xF3;lo en lo relativo a las especies Jurel, Anchoa, Caballa, Sardina com&#xFA;n y Albacora, por haberse configurado la causal de caducidad prevista en el art&#xED;culo 143 letra b) de la Ley N&#xBA; 18.892 y sus modificaciones.</div><br></div>", "i": 8300391}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de diciembre de 1996.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8300392}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2196", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2196"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA RIO SIMPSON S.A.", "CADUCIDAD", "PESCA", "AUTORIZACION", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-12-31", "fecha_derogacion": "2001-03-29", "doble_articulado": false, "id_norma": "50398", "numero_fuente": "35663", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-01-11", "vigencias": [{"desde": "2001-03-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde