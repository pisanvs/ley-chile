{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 13.683</div><br><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DO&#xD1;A BLANCA RIVERA ARCE</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6315856}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a do&#xF1;a Blanca Rivera Arce una pensi&#xF3;n mensual ascendente a la cantidad de $30.000.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que importe el cumplimiento de la presente ley se imputar&#xE1; al &#xED;tem respectivo de Pensiones del Presupuesto del Ministerio de Hacienda.&quot;</div><br><br></div>", "i": 6315857}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintiocho de Octubre de mil novecientos cincuenta y nueve. JORGE ALESSANDRI RODRIGUEZ.- Roberto Vergara H.</div><br></div>", "i": 6315858}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13683", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13683"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DOÑA\nBLANCA RIVERA ARCE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1958-10-28", "doble_articulado": false, "id_norma": "180018", "numero_fuente": "24496", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1959-11-18", "vigencias": [{"desde": "1959-11-18", "hasta": "", "t