{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xBA; 42 EXENTA, DE 2004 </div></div>", "i": 6488469}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modifica res. Ex. SII N&#xBA; 42 de 26.03.2004 que establece obligaci&#xF3;n de presentar Declaraci&#xF3;n Jurada Resumen Anual de IVA de Compras y Ventas.</div><div class=\"p\">Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 74 del 15 de julio de 2004.</div><div class=\"p\">Establece que, para el a&#xF1;o 2004, se ampl&#xED;a el plazo para presentar la Declaraci&#xF3;n Jurada Resumen Anual de IVA de Compras y Ventas, v&#xED;a Internet, indicado en el inciso tercero del resolutivo 11 de la resoluci&#xF3;n exenta SII N&#xBA; 42, de 26 de marzo de 2004, hasta el 31 de julio de 2004.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en julio de 2004.</div><br></div>", "i": 6488470}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "74 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-74 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCION Nº 42 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-07-15", "doble_articulado": false, "id_norma": "227892", "numero_fuente": "37915", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-21", "vigencias": [{"desde": "2004-07-21", "hasta": "", "tipo_version