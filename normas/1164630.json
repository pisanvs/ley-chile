{"html": [{"t": "<div><div class=\"p\">CREA REGISTRO ANUAL DE RETENCIONES DEL ART. 42 N&#xB0; 1 Y 74 N&#xB0;1 LIR</div></div>", "i": 10265591}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 103, de fecha 31 de agosto de 2021, crea registro anual sobre retenciones efectuadas conforme a los art&#xED;culos <a href=\"https://www.leychile.cl/Navegar?idNorma=6368&amp;idParte=8656074&amp;idVersion=\">42</a> N&#xB0; 1 y <a href=\"https://www.leychile.cl/Navegar?idNorma=6368&amp;idParte=8656115&amp;idVersion=\">74</a> N&#xB0; 1 de la <a href=\"https://www.leychile.cl/Navegar?idNorma=6368&amp;idParte=&amp;idVersion=\">Ley sobre Impuesto a la Renta</a>, y exime a contribuyentes que se indican de la obligaci&#xF3;n de presentar la Declaraci&#xF3;n Jurada Formulario N&#xB0; 1887, en los casos que se se&#xF1;alan.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento est&#xE1; publicado en &quot;www.sii.cl&quot;.</div><div class=\"p\"> </div><br></div>", "i": 10265592}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "103 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-103 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CREA REGISTRO ANUAL DE RETENCIONES DEL ART. 42 N° 1 Y 74 N°1 LIR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2004766", "EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-08-31", "doble_articulado": false, "id_norma": "1164630", "numero_fuente": "43046", "tipo_version": "3", "tipo_version_s": "Única", "fe