{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 209, DE 1984 </div></div>", "i": 7268044}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 209 de 20 de Diciembre de 1984 se ha autorizado al Liceo C.R.E.P. de Rancagua para aplicar el DS exento de Educaci&#xF3;n N&#xB0; 132 de 1983, que aprob&#xF3; planes y programas especiales de estudio de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica para adultos al Liceo C.R.E.P. de Quilpu&#xE9;.-</div><br></div>", "i": 7268045}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 7268046}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "209 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-209 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 209, DE 1984 ESCUELA DE ALTOS ESTUDIOS DE LA COMUNICACION Y EDUCACION, EACE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-12-20", "doble_articulado": false, "id_norma": "166443", "numero_fuente": "32084", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-01-30", "vigencias": [{"desde": "1985-01-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-01-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-01-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMZ", "fecha_ingreso": "2000-04-19", "fecha_version": "1985