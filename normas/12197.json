{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; NOMBRA SUBSECRETARIO DE ESTADO, EN LA CARTERA QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; Santiago, 11 de Marzo de 1994.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 307.- Visto: Lo dispuesto en el art&#xED;culo 32&#xB0;, N&#xB0; 9 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile,</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 8261345}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico: N&#xF3;mbrase a contar de esta fecha, como Subsecretario de Desarrollo Regional y Administrativo del Ministerio del Interior, al se&#xF1;or Jorge Rodr&#xED;guez Grossi, RUT: 5.141.013-0.</div><br></div>", "i": 8261346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n, reg&#xED;strese y publ&#xED;quese.- EDUARDO FREI RUIZ-TAGLE, Presidente de la Rep&#xFA;blica.-</div><div class=\"p\">V&#xED;ctor Germ&#xE1;n Correa D&#xED;az, Ministro del Interior.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud., para su conocimiento.- Saluda a Ud.- Belisario Velasco Baraona, Subsecretario del Interior.</div><br></div>", "i": 8261347}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "307", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-307"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "NOMBRA SUBSECRETARIO DE ESTADO, EN LA CARTERA QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMBRAMIENTO", "MINISTERIO INTERIOR", "JORGE RODRIGUEZ GROSSI", "SUBSECRETARIA DESARROLLO REGIONAL ADMINISTRATIVO", "SUBSECRETARIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-11", "doble_articulado":