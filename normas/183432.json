{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6328454}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 74, de 31 de enero de 2001, se expropi&#xF3; el lote de terreno N&#xBA; 30, superficie 28.025 m&#xB2;, rol de aval&#xFA;o 1543-138, comuna de Los Angeles, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: Chill&#xE1;n - Collipulli, By Pass San Carlos de Pur&#xE9;n, Octava Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Ana Alicia Higueras Fern&#xE1;ndez y otros, ascendente a la cantidad de $55.364.609.-</div><br></div>", "i": 6328455}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6328456}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "74", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-74"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-01-31", "doble_articulado": false, "id_norma": "183432", "numero_fuente": "36928", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-04-02", "vigencias": [{"desde": "2001-04-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-04-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-04-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2001-04-02", "fecha_version": "2001-04-02", "fecha_actualizacion_texto": "2001-04-02", "tipo_tratado": ""}, "alertas": [], "alert