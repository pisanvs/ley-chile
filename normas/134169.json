{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,083.- Santiago, 14 de setiembre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6161532}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Decl&#xE1;rase, por gracia, que el coronel de Ej&#xE9;rcito, retirado, don Gabriel Alamos, tiene derecho a la pension de retiro del setenta i cinco por ciento del sueldo asignado a su empleo, como si hubiese servido cuarenta a&#xF1;os en el Ej&#xE9;rcito.</div><br></div>", "i": 6161533}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Ventura Blanco.</div><br></div>", "i": 6161534}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1083", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1083"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-09-14", "doble_articulado": false, "id_norma": "134169", "numero_fuente": "6102", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-09-15", "vigencias": [{"desde": "1898-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha