{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 519, DE 1993 </div></div>", "i": 5945032}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 519 de 4 de Octubre de 1993 se ha aprobado al Colegio Don Bosco de Iquique, un plan especial de estudio para 3&#xB0; y 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 1993.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio para las asignaturas &quot;Prospectiva Moral y Axiolog&#xED;a del Comportamiento Humano&quot; de 3er. a&#xF1;o de Educaci&#xF3;n Media y &quot;Humanismo Cristiano y Doctrina Social&quot; de 4to. a&#xF1;o de Educaci&#xF3;n Media.-</div><br></div>", "i": 5945033}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 28 de Octubre de 1993. Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5945034}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "519", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-519"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 519, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "COLEGIO DON BOSCO", "IQUIQUE", "PROGRAMAS ESTUDIOS", "PRIMERA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-10-04", "doble_articulado": false, "id_norma": "21401", "numero_fuente": "34787", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-02-10", "vigencias": [{"desde": "1994-02-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vi