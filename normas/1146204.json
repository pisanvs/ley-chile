{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10126098}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 58, del 29 de mayo de 2020, donde se establece Registro de accionistas que debe ser considerado para los fines de determinar la obligaci&#xF3;n de retenci&#xF3;n del impuesto adicional y crea Certificado de Calificaci&#xF3;n Tributaria de Dividendos. Complementa resoluciones exentas SII <a href=\"https://www.leychile.cl/Navegar?idNorma=1107620&amp;idParte=&amp;idVersion=\">N&#xBA; 80</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1107621&amp;idParte=&amp;idVersion=\">N&#xBA; 81</a>, de 2017.</div><div class=\"p\">&nbsp; &nbsp;  Las medidas dispuestas en esta resoluci&#xF3;n tendr&#xE1;n vigencia desde su publicaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento, est&#xE1; publicado en &quot;www.sii.cl&quot;.</div><br></div>", "i": 10126099}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "58 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-58 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1768647; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-05-29", "doble_articulado": false, "id_norma": "1146204", "numero_fuente": "42672", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-06-04", "vigencias": [{"desde": "2020-06-04", "hasta": "", "tipo