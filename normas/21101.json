{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 376, EXENTO, DE 1994 </div></div>", "i": 5944161}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0;376 de 29 de agosto de 1994, se ha aprobado para ser aplicado en los establecimientos educacionales de la Congregaci&#xF3;n Hermanas de la Caridad Cristiana, Hijas de la Bienaventurada Virgen Mar&#xED;a de la Inmaculada Concepci&#xF3;n, los siguientes plan y programas de estudio para el segundo nivel de transici&#xF3;n (kinder), a contar del presente a&#xF1;o escolar.</div><br></div>", "i": 5944162}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 8 de Septiembre de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 5944163}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "376", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-376"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 376, EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONGREGACION HERMANAS CARIDAD CRISTIANA", "ESTABLECIMIENTOS EDUCACIONALES", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-06-13", "doble_articulado": false, "id_norma": "21101", "numero_fuente": "34979", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-09-30", "vigencias": [{"desde": "1994-09-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-09-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-09-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes":