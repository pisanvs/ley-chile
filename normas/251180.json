{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A CONTRIBUYENTE QUE INDICA </div></div>", "i": 6575453}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La IV Direcci&#xF3;n Regional La Serena, revoca la calidad de agente retenedor del Impuesto al Valor Agregado en las ventas que se indican, del contribuyente que se se&#xF1;ala:</div><br><div class=\"p\">Contribuyente&nbsp; RUT N&#xBA;&nbsp; &nbsp; &nbsp; &nbsp; Res. N&#xBA;&nbsp; Fecha&nbsp; &nbsp;  Venta de</div><div class=\"p\">Adelina</div><div class=\"p\">Garc&#xED;a</div><div class=\"p\">Molina&nbsp; &nbsp; &nbsp; &nbsp;  10.370.587-8&nbsp;  780&nbsp; 03-07-2006&nbsp; &nbsp; Harina</div><br><div class=\"p\">&nbsp; &nbsp;  A contar de la fecha de publicaci&#xF3;n de este extracto en el Diario Oficial conforme a la facultad delegada en el dispositivo N&#xBA; 17 de la resoluci&#xF3;n exenta N&#xBA; 5.282, de fecha 30/11/2000, emanada de la Direcci&#xF3;n Nacional de este Servicio.</div><br><br></div>", "i": 6575454}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Serena, 3 de julio de 2006.- Francisco C&#xE1;rcamo Avenda&#xF1;o, Director Regional.</div><br></div>", "i": 6575455}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "780", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-780"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IV DIRECCIÓN REGIONAL LA SERENA"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A\nCONTRIBUYENTE QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-03", "doble_articulado": false, "id_norma": "251180", "numero_fuente": "38513", "tipo_vers