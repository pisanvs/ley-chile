{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6326637}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;5.166, de fecha 30 de noviembre de 2000, se expropiaron los lotes de terreno N&#xBA;s. 28 y 32, superficies 339 y 44 m2, respectivamente, rol de aval&#xFA;o 58-24, comuna de San Esteban, para la obra &apos;&apos;Ruta E-755, San Esteban-Lo Calvo Tramo Km. 0.000 a Km.</div><div class=\"p\">7.001,8&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Salvador Sergio Catan Kort, ascendente a la cantidad de $11.741.519.</div><br></div>", "i": 6326638}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6326639}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "5166", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-5166"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-11-30", "doble_articulado": false, "id_norma": "182891", "numero_fuente": "36913", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-15", "vigencias": [{"desde": "2001-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2001-03-16", "fecha_version": "2001-03-15", "fecha_actualizacion_texto": "2001-03-15", "tipo_tratado": ""}, "alertas": [], "al