{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 13.435</div><br><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DON JUAN ERICES CAMPOS.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6318435}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a don Juan Erices Campos una pensi&#xF3;n de $ 20.000 mensuales.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande el cumplimiento de la presente ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda.&quot;</div><br><br></div>", "i": 6318436}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a catorce de Septiembre de mil novecientos cincuenta y nueve. JORGE ALESSANDRI RODRIGUEZ.- Roberto Vergara H.</div><br></div>", "i": 6318437}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13435", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13435"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DON JUAN ERICES CAMPOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1959-09-14", "doble_articulado": false, "id_norma": "180765", "numero_fuente": "24456", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1959-10-01", "vigencias": [{"desde": "1959-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}]