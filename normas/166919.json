{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.906, DE 1987 </div></div>", "i": 7268315}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.906, de fecha 26 de Agosto de 1987, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se modific&#xF3; el art. 1&#xB0; de la resoluci&#xF3;n exenta de Educaci&#xF3;n No. 247, de 1986, del Centro de Formaci&#xF3;n T&#xE9;cnica Crownliet de Santiago, en el sentido de modificar la secuencialidad curricular y autorizar plan especial de estudios de la carrera Laboratorista Dental por una sola vez, para los alumnos que cursaron en forma regular su cuarto nivel de la carrera en 1985. </div></div>", "i": 7268316}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7268317}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1906 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1906 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.906, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-26", "doble_articulado": false, "id_norma": "166919", "numero_fuente": "32891", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-10-10", "vigencias": [{"desde": "1987-10-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-10-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-10-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes