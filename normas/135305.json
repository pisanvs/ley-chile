{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Seccion 2.&#xAA;, n&#xFA;m. 1,671.- Santiago, 25 de agosto de 1904.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6164988}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- A contar desde la fecha de la presente lei, aum&#xE9;ntase a cien pesos ($ 100) mensuales la pension de cincuenta pesos ($ 50) que actualmente disfruta el soldado Francisco Gonz&#xE1;lez Pacheco, servidor de la campa&#xF1;a Restauradora del Per&#xFA; en los a&#xF1;os 1838-1839. </div></div>", "i": 6164989}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.-</div><div class=\"p\">A. Bascu&#xF1;an S. M.</div><br></div>", "i": 6164990}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1671", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1671"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-08-25", "doble_articulado": false, "id_norma": "135305", "numero_fuente": "7989", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1904-08-25", "vigencias": [{"desde": "1904-08-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1904-08-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1904-08-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendien