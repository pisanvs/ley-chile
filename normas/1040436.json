{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 4.996 EXENTA, DE 2012</div></div>", "i": 9259742}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 4.996 exenta, de 22 de mayo de 2012, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Capacitaci&#xF3;n Valpara&#xED;so Limitada (Capacival Ltda.)&quot;, RUT 78.877.110-K, contenida en la resoluci&#xF3;n exenta N&#xBA; 5.196, de 23 de julio de 2009, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la Ley 19.518.- </div></div>", "i": 9259743}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (PT).</div></div>", "i": 9259744}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4996 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4996 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 4.996 EXENTA, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-22", "doble_articulado": false, "id_norma": "1040436", "numero_fuente": "40272", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-05-28", "vigencias": [{"desde": "2012-05-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-05-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-05-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes