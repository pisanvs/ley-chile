{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6222971}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 667, de 09 de Octubre de 1986 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del Bio Bio se autoriza a la se&#xF1;ora Iris del Carmen Garc&#xED;a Riquelme para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.- </div></div>", "i": 6222972}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco Navarro Ruiz, Secretario Regional Ministerial de Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6222973}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "667 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-667 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-10-09", "doble_articulado": false, "id_norma": "152383", "numero_fuente": "32.598", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-10-16", "vigencias": [{"desde": "1986-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-10-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-10-16", "fin_vigencia": "", "tipo_ve