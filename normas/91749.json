{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA</div><br><br><br></div>", "i": 8320659}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 1.732 - 09.11.89, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 3&#xB0; de la Resoluci&#xF3;n No. 1.009, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Sociedad Aquiles, Gonz&#xE1;lez, Lastra y Otro, R.U.T. No.</div><div class=\"p\">79.786.250-9, domiciliada en Constituci&#xF3;n, Atenas No. 215, para iniciar actividades pesqueras, en el sentido de autorizar a la solicitante para extraer el recurso Albacora o pez espada, (Xiphias gladius), en el litoral de las Regiones II a X, no obstante lo se&#xF1;alado en dicha Resoluci&#xF3;n, respecto de las zonas a operar.</div><br></div>", "i": 8320660}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 09 de Noviembre de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8320661}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1732", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1732"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1989-11-09", "fecha_derogacion": "1999-05-22", "doble_articulado": false, "id_norma": "91749", "numero_fuente": "33527", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1989-11-21", "vigencias": [{"desde": "1999-05-22", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde":