{"html": [{"t": "<div><div class=\"p\">&quot;Santiago, a treinta de marzo de dos mil siete.</div><br><div class=\"p\">&nbsp; &nbsp;  Vistos y teniendo presente:</div><br><div class=\"p\">&nbsp; &nbsp;  Que esta Corte Suprema mediante Auto Acordado de 2 de marzo en curso pretendi&#xF3; facilitar la actividad de los periodistas y en caso alguno restringir la libertad de informaci&#xF3;n y ejercicio del periodismo.</div><br></div>", "i": 8663481}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  De conformidad a lo expuesto y teniendo en consideraci&#xF3;n la solicitud de fojas 16, deja sin efecto el mencionado Auto Acordado, contenido en el acta N&#xB0; 15-2007...&quot;.</div><br></div>", "i": 8663482}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "4", "numero": "S/N", "abreviacion": "AA", "descripcion": "Auto Acordado", "compuesto": "AA-S/N"}], "organismos": ["CORTE SUPREMA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REGLAMENTO", "TRIBUNALES DE JUSTICIA", "CREDENCIAL DE PRENSA", "VIGENCIA", "LIBERTAD DE PRENSA", "PERIODISTAS", "REPORTEROS", "CAMAROGRAFOS", "ASISTENTES DE CAMARA", "REPORTEROS GRAFICOS", "CENSURA DE PRENSA", "AUTO ACORDADO", "DEJA SIN EFECTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-03-30", "doble_articulado": false, "id_norma": "259947", "numero_fuente": "38737", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-04-13", "vigencias": [{"desde": "2007-04-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-04-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-04-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient