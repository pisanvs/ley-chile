{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6058816}, {"t": "<div><div class=\"p\">Por Decreto MOP No. 195, de 28 de agosto de 1991, se expropiaron los lotes No. s. 3, 10-A, 13 y 15, superficies 610 m2., 260 m2., 850 m2. y 470 m2., roles de aval&#xFA;o 503-4, 503-14, 503-13 y 50-13, Comuna de Santa Cruz, para la obra Camino Santa Cruz-Lolol-Bucalemu, Rol I-72, sector Santa Cruz, Cuesta La Lajuela y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Sres. Jos&#xE9; Catal&#xE1;n Pino, Manuel Ram&#xF3;n Orellana Allendes, Luis Becerra P&#xE9;rez y Carlos Enrique Vergara Duarte, ascendente a las sumas de $ 212.940.- para el lote 3; $ 231.840.- para el lote 10-A, $ 277.200.- para el lote 13 y $ 214.830.- para el lote 15, respectivamente. </div></div>", "i": 6058817}, {"t": "<div><div class=\"p\">Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 6058818}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "195", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-195"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-08-28", "doble_articulado": false, "id_norma": "81072", "numero_fuente": "34080", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-10-01", "vigencias": [{"desde": "1991-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-10-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [