{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6411038}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n, que suscribe, certifica que el Instituto Profesional Alem&#xE1;n de Valpara&#xED;so, autorizado a funcionar por decreto exento N&#xBA; 199 del 23 de Diciembre de 1988, ha presentado los planes y programas de estudio de la carrera de Ingenier&#xED;a de Ejecuci&#xF3;n industrial conducente al t&#xED;tulo profesional de Ingeniero de Ejecuci&#xF3;n Industrial, al Instituto Profesional de Santiago como entidad examinadora y revisados por &#xE9;ste, han sido aprobados en tiempo y forma, de acuerdo a convenio de examinaci&#xF3;n suscrito por ambas instituciones.</div><div class=\"p\">&nbsp; &nbsp;  La carrera profesional mencionada podr&#xE1; impartirse a contar del a&#xF1;o 1990 en su Sede de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de Enero de 1991.</div><br></div>", "i": 6411039}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Allard Neumann Subsecretario de Educaci&#xF3;n </div></div>", "i": 6411040}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-31", "doble_articulado": false, "id_norma": "206957", "numero_fuente": "33900", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-02-21", "vigencias": [{"desde": "1991-02-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vig