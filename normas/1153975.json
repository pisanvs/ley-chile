{"html": [{"t": "<div><div class=\"p\">DECLARA CADUCIDAD DE RESOLUCIONES QUE INDICA</div></div>", "i": 10188150}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.824, de 22 de diciembre de 2020, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las resoluciones exentas <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=1130807&amp;idVersion=2020-12-28\">N&#xBA; 250</a> y <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=1130808&amp;idVersion=2020-12-28\">N&#xBA; 254</a>, ambas de 2019, que otorgaron permisos extraordinarios de pesca a Pesquera La Cruz SpA, para el recurso Bacalao de profundidad, en virtud de lo dispuesto en el art&#xED;culo 143 letra i) de la Ley General de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><br></div>", "i": 10188151, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de diciembre de 2020.- Rom&#xE1;n Zelaya R&#xED;os, Subsecretario de Pesca y Acuicultura.</div><br></div>", "i": 10188152}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2824 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2824 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DECLARA CADUCIDAD DE RESOLUCIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1871195", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-12-22", "doble_articulado": false, "id_norma": "1153975", "numero_fuente": "42840", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-12-28", "vigencias": [{"desde": "2020-12-28", "hasta": "", "tip