{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6065905}, {"t": "<div><div class=\"p\">Por Decreto Secc. 2da. No. 73, de fecha 12 de Enero de 1990, Alcalde I. Municipalidad de Santiago, dispone expropiaci&#xF3;n parcial conforme DS No. 458 de Vivienda y Urbanismo, Decreto Ley 2.186 y Ley 18.695, inmueble Agustinas No. 2378, Rol 375-43 Santiago, aparente dominio Patricio Bilbao Guzm&#xE1;n, superficie aproximada a expropiar 60 m2. Deslindes: Norte, 17,35 mts. con calle Agustinas; Sur, 16,95 mts. resto predio; Oriente, 4,00 mts. con otro propietario y Poniente, 3,00 mts. con otro propietario. Indemnizaci&#xF3;n provisional $ 3.744.000.- pagadera contado.</div><br></div>", "i": 6065906}, {"t": "<div><div class=\"p\">M&#xE1;ximo Honorato Alamos Alcalde Santiago.</div><br></div>", "i": 6065907}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "73", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-73"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-12", "doble_articulado": false, "id_norma": "83646", "numero_fuente": "33585", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-01", "vigencias": [{"desde": "1990-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1998-01-09", "fecha_version": "1990-02-01", "fecha_actualizacion_text