{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,409.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6171677}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a F&#xE9;lix Mar&#xED;a Santiago, hija del herrero primero de la Armada, don Francisco Santiago, que falleci&#xF3; en el combate naval de 21 de mayo de 1879, una pension mensual de treinta pesos, de que disfrutar&#xE1; con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6171678}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, tres de setiembre de mil novecientos diez.- Emiliano Figueroa.- C&#xE1;rlos Larrain Claro. </div></div>", "i": 6171679}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2409", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2409"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-09-03", "doble_articulado": false, "id_norma": "137342", "numero_fuente": "9793", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-09-14", "vigencias": [{"desde": "1910-09-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-09-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1910-09-14", "fin_vigencia": "", "tipo_