{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8296689}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0;1.274 de 23 de Diciembre de 1992, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xB0;1.523, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don MARIO GUSTAVO GALLARDO OYARZUN, R.U.T.</div><div class=\"p\">N&#xB0;7.136.231-0, para iniciar actividades de cultivo del recurso alga Gracilaria spp., en el sector denominado R&#xED;o El Dao, Canal San Antonio, Comuna de Calbuco, Provincia de Llanquihue, X Regi&#xF3;n, en un &#xE1;rea de 24.000 m2, por renuncia total de su titular, ya individualizado.</div><br></div>", "i": 8296690}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 23 de Diciembre de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8296691}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1274", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1274"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "MARIO GUSTAVO GALLARDO OYARZUN"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-12-23", "doble_articulado": false, "id_norma": "36620", "numero_fuente": "34459", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-01-07", "vigencias": [{"desde": "1993-01-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-01-07", "fin_vigencia": ""}, "vigencias_version_norma":