{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,780, que concede derecho a jubilar a don C&#xE1;rlos Lira.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,780.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei: </div></div>", "i": 8276704}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese al actual Director Jeneral de Correos, Tel&#xE9;grafos i Tel&#xE9;fonos, don C&#xE1;rlos Lira Carrera, el derecho a jubilar con el sueldo &#xED;ntegro asignado a su empleo.</div><br></div>", "i": 8276705}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a diecinueve de Agosto de mil novecientos veintiuno.- ARTURO ALESSANDRI.- H&#xE9;ctor Arancibia Laso. </div></div>", "i": 8276706}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3780", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3780"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 3,780, QUE CONCEDE DERECHO A JUBILAR A DON CARLOS LIRA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CARLOS LIRA CORREA", "JUBILACION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1921-08-19", "doble_articulado": false, "id_norma": "24240", "numero_fuente": "13054", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1921-08-22", "vigencias": [{"desde": "1921-08-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1921-08-22", "fin_vigencia": ""}, "vigen