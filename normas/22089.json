{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SUPLEMENTOS Lei n&#xFA;m. 234.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947236}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dense los siguientes suplementos a los &#xED;tems que se espresan de la partida 133 del presupuesto de Instruccion P&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; Item 1, para pagar los suplentes de los empleados de Instruccion P&#xFA;blica, ocho mil pesos ($ 8,000);</div><div class=\"p\">&nbsp; &nbsp; Item 9, para jubilaciones, tres mil pesos ($ 3,000).</div><br><br></div>", "i": 5947237}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 29 de Diciembre de 1894.- JORJE MONTT.-</div><div class=\"p\">O. Renjifo.</div><br></div>", "i": 5947238}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "234", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-234"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "SUPLEMENTOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1894", "MODIFICA", "MINISTERIO", "INSTRUCCION PUBLICA", "PERSONAL", "SUELDO", "JUBILACION", "PAGO", "SUPLEMENTO."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-12-29", "doble_articulado": false, "id_norma": "22089", "numero_fuente": "5001", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-12-2