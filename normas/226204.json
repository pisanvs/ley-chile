{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6482683}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.311, de 10 de mayo de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a SOUTH PACIFIC KORP S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Libas&quot;, donde podr&#xE1; capturar los recursos hidrobiol&#xF3;gicos que a continuaci&#xF3;n se indican: a) En el &#xE1;rea mar&#xED;tima correspondiente a las Regiones V, VI, VII, IX y X, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua: Jibia; b) En el &#xE1;rea mar&#xED;tima correspondiente a las Regiones V, VI, VII, IX y X, por fuera del &#xE1;rea de reserva artesanal, con cerco: Jibia. </div></div>", "i": 6482684}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de mayo de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6482685}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1311 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1311 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-10", "doble_articulado": false, "id_norma": "226204", "numero_fuente": "37881", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-10", "vigencias": [{"desde": "2004-06-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-06-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-06-10", "fin_vigencia": "