{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DELEGA FACULTADES QUE INDICA </div></div>", "i": 6022469}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n Exenta N&#xB0; 441 de fecha 3 de Marzo de</div><div class=\"p\">1994, el Director Regional ha delegado en el Jefe de</div><div class=\"p\">Departamento de Avaluaciones de esta Direcci&#xF3;n Regional</div><div class=\"p\">la facultad de autorizar mediante resoluci&#xF3;n fundada,</div><div class=\"p\">para los efectos de determinar la base imponible del</div><div class=\"p\">Impuesto al Valor Agregado, en la venta o promesa de</div><div class=\"p\">venta de un bien inmueble gravado, que se deduzca del</div><div class=\"p\">precio estipulado en el contrato, el valor efectivo de</div><div class=\"p\">adquisici&#xF3;n del terreno, de acuerdo a lo dispuesto en el</div><div class=\"p\">art&#xED;culo 17, inciso quinto, del D.L. 825, sobre Impuesto a las Ventas y Servicios.</div><br></div>", "i": 6022470}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Jorge Ortega Vera, Director Regional Subrogante.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud., para su conocimiento y fines consiguientes.- Zunilda Eriza Galdamez, Secretaria Regional.</div><br></div>", "i": 6022471}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "441", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-441"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS"], "titulo_norma": "DELEGA FACULTADES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DELEGACION", "FACULTAD", "FUNCIONARIO", "SERVICIO IMPUESTOS INTERNOS", "AVALUO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-03", "doble_arti