{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6526399}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 484, de 28 de junio de 1996, se expropiaron los lotes de terrenos N&#xB0;s 1, 2 y 4, superficies 675, 5.118 y 770 m2 roles de aval&#xFA;os 310-80, 316-136 y 1185 comuna de Quirihue, para la obra Camino Cauquenes-L&#xED;mite Regional-Quinhue, Sector Acceso a Quirihue, se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios, Julio Alfonso Oviedo Montero, V&#xED;ctor Javier 0sorio Godoy y Juan Esteban Vera Chand&#xED;a, ascendente a las cantidades de $842.030 para el lote N&#xB0; 1 $7.513.251 para el lote N&#xB0; 2 y $1.424.652 para el lote N&#xBA; 4.</div><br></div>", "i": 6526400}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6526401}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "484", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-484"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-06-28", "doble_articulado": false, "id_norma": "238070", "numero_fuente": "35557", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-09-02", "vigencias": [{"desde": "1996-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-09-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-05