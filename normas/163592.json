{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6258869}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 741, de octubre 25 de 1985, del Ministerio de Transportes y Telecomunicaciones, Subsecretaria de Transportes, se autoriza en forma complementaria a la Empresa de origen peruano &quot;Expreso Internacional Orme&#xF1;o Sociedad An&#xF3;nima&quot; para efectuar servicio internacional de transporte terrestre de pasajeros entre Lima (Per&#xFA;) y Buenos Aires (Argentina), en tr&#xE1;nsito por territorio chileno, utilizando los Pasos Fronterizos de Chacalluta y Caracoles (T&#xFA;nel Cristo Redentor), con dos (2) frecuencias mensuales.</div><br></div>", "i": 6258870}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago de Chile, 30 de Octubre de 1985. Enrique Y&#xE1;var Martin, Coronel de Ej&#xE9;rcito, Subsecretario de Transportes.</div><br></div>", "i": 6258871}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "741 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-741 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-10-25", "doble_articulado": false, "id_norma": "163592", "numero_fuente": "32323", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-11-16", "vigencias": [{"desde": "1985-11-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-11-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1