{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8334528}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.202, de 13 de agosto de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a VLADIMIR REIMUNDO AVENDA&#xD1;O ASPILLAGA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada a 5 Km. al Este de Taltal, camino a basural municipal, II Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Secado y Molienda: Chasca, Chasc&#xF3;n, Chicorea de mar, Cochayuyo, Cotoni, Huiro, Huiro palo, Luche, Luga roja y Pelillo.</div><br></div>", "i": 8334529}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de agosto de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8334530}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1202", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1202"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "VLADIMIR REIMUNDO AVENDA O ASPILLAGA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-13", "doble_articulado": false, "id_norma": "124335", "numero_fuente": "36167", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-09-17", "vigencias": [{"desde": "1998-09-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-09-17", "fin_vige