{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8580943}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.219 de 09 de Octubre de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por 30 d&#xED;as a contar de la fecha de la presente resoluci&#xF3;n, el plazo para publicar en el Diario Oficial, el extracto de la resoluci&#xF3;n No. 217, de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don JOSE EZQUIVEL CAMPA&#xD1;A, R.U.T. No. 6.337.222-6, domiciliado en calle Jos&#xE9; Plaza No. 69, San Antonio, para desarrollar actividades pesqueras extractivas.</div><br></div>", "i": 8580944}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 09 de Octubre de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8580945}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1219", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1219"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-10-09", "doble_articulado": false, "id_norma": "81641", "numero_fuente": "33813", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-11-08", "vigencias": [{"desde": "1990-11-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-11-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-11-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MNV", "fecha_ing