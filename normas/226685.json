{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6484361}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 1.571, de 9 de junio de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BURCA LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Caica&#xE9;n kil&#xF3;metro 5.5, Calbuco, X Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n Fresco-Refrigerado, Congelado, Seco-Salado, Ahumado, Conserva, Salado, Harina y Aceite, los recursos hidrobiol&#xF3;gicos individualizados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;janse sin efecto las resoluciones N&#xBA; 384 y N&#xBA; 391, ambas de 2002 y N&#xBA; 470 de 2003, todas de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6484362}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de junio de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6484363}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1571 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1571 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-06-09", "doble_articulado": false, "id_norma": "226685", "numero_fuente": "37892", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-23", "vigencias": [{"desde": "2004-06-23", "hasta": "", "tipo_version": "3", "tipo_versi