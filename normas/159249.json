{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6244509}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 109 de 15 de Julio de 1985 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la I Regi&#xF3;n se autoriza a Freddy Amache Castro para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6244510}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan W. Flaquer Hern&#xE1;ndez, Secretario Regional Ministerial Transportes y Telecomunicaciones, I Regi&#xF3;n Tarapac&#xE1;.</div><br></div>", "i": 6244511}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "109", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-109"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-07-15", "doble_articulado": false, "id_norma": "159249", "numero_fuente": "32229", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-07-23", "vigencias": [{"desde": "1985-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-07-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-07-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2000-03-01", "fec