{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6387876}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.269, de 19 de junio de 2002, modif&#xED;case el numeral 6&#xBA; de la resoluci&#xF3;n N&#xBA; 712 de 2002, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto denominado &quot;Monitoreo y evaluaci&#xF3;n hidroac&#xFA;stica del Jurel, I y II Regiones&quot;, en el sentido de reemplazar la nave &quot;Oficina Germania&quot; por la nave &quot;Licant&#xE9;n&quot;, ambas de propiedad de Compa&#xF1;&#xED;a Pesquera Camanchaca S.A., de la n&#xF3;mina de naves participantes en la se&#xF1;alada pesca de investigaci&#xF3;n. </div></div>", "i": 6387877}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de junio de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6387878}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1269", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1269"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-19", "doble_articulado": false, "id_norma": "200116", "numero_fuente": "37302", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-08", "vigencias": [{"desde": "2002-07-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-08", "fin_vigencia": ""}, "vigencias_