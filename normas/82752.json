{"html": [{"t": "<div><div class=\"p\">PRORROGA PLAZO QUE INDICA</div><br><br></div>", "i": 8314114}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n N&#xB0;. 1.057 de 30 de Agosto de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n , se prorroga por 6 meses a contar de la fecha de la presente Resoluci&#xF3;n, el plazo otorgado a do&#xF1;a Julia Guerrero Armazabal, RUT N&#xB0;. 4.973.124-8, domiciliada en calle Carlos Arce s/n, Mehu&#xED;n, en el numeral 5&#xB0; de la Resoluci&#xF3;n N&#xB0;. 560, de 1989, de esta Subsecretar&#xED;a, que la autoriz&#xF3; para iniciar actividades de cultivo, en virtud que a la fecha a&#xFA;n no se ha dictado el Decreto de concesi&#xF3;n en la Subsecretar&#xED;a de Marina.</div><br></div>", "i": 8314115}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 30 de Agosto de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8314116}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1057", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1057"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "PRORROGA PLAZO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-08-30", "doble_articulado": false, "id_norma": "82752", "numero_fuente": "33770", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-09-14", "vigencias": [{"desde": "1990-09-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-09-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci