{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  EXTRACTO DE RESOLUCION </div></div>", "i": 6347556}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 159 de 25 de Febrero de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Sergio Trujillo Villarroel para efectuar el servicio p&#xFA;blico urbano de locomoci&#xF3;n colectiva de pasajeros en la ciudad de Osorno, L&#xED;nea No. 8, cuyo trazado fue autorizado por resoluci&#xF3;n No. 222, del 29 de Septiembre de 1982, de esta Secretar&#xED;a Regional. </div></div>", "i": 6347557}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Luis Boldt Quezada, Secretario Regional Ministerial Transportes y Telecomunicaciones X Regi&#xF3;n. </div></div>", "i": 6347558}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "159 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-159 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-02-25", "doble_articulado": false, "id_norma": "188894", "numero_fuente": "32418", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-03-10", "vigencias": [{"desde": "1986-03-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-03-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-03-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie