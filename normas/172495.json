{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6287710}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. No. 116, de 25 de mayo de 1987, se expropi&#xF3; el lote de terreno No. 1, superficie 18.400 m2., rol de aval&#xFA;o 1125-21, comuna de Valdivia. Obra Mejoramiento de los Sistemas de Regulaci&#xF3;n y Distribuci&#xF3;n del Servicio de Agua Potable de Valdivia, X Regi&#xF3;n y se acord&#xF3; el precio de indemnizaci&#xF3;n con su propietaria do&#xF1;a Mar&#xED;a Magdalena Mu&#xF1;oz Duarte, ascendente a la suma de $ 236.379.-</div><br></div>", "i": 6287711}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6287712}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "116", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-116"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-05-25", "doble_articulado": false, "id_norma": "172495", "numero_fuente": "32808", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-01", "vigencias": [{"desde": "1987-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2000-07-18", "fecha_version": "1987-07-01", "fecha_actualizacion_texto": "1987-07-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estru