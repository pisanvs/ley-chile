{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,748.- Santiago, 12 de agosto de 1905.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165113}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Se autoriza al Presidente de la Rep&#xFA;blica para que invierta hasta la cantidad de cincuenta mil pesos en ausiliar el funcionamiento del Congreso i de la Esposicion Industrial i Agr&#xED;cola que se celebrar&#xE1;n en la ciudad de Talca en el presente a&#xF1;o&quot;.</div><br></div>", "i": 6165114}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.-</div><div class=\"p\">E. Villegas.</div><br></div>", "i": 6165115}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1748", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1748"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-08-12", "doble_articulado": false, "id_norma": "135340", "numero_fuente": "8296", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-08-30", "vigencias": [{"desde": "1905-08-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1905-08-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1905-08-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [],