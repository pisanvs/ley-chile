{"html": [{"t": "<div><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N N&#xBA; 2.976 EXENTA, DE 2020</div></div>", "i": 10257403}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.164, de 30 de julio de 2021, de esta Subsecretar&#xED;a, rectif&#xED;quese el resuelvo 1&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1154325&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.976, de 2020</a>, de esta Subsecretar&#xED;a, y sus modificaciones posteriores, que estableci&#xF3; las toneladas que podr&#xE1;n capturar durante el a&#xF1;o 2021 los titulares de licencias transables de pesca clase A, en el sentido de reemplazar, en la parte final del cuadro correspondiente al recurso hidrobiol&#xF3;gico Jurel, de la unidad de pesquer&#xED;a de las Regiones de Valpara&#xED;so a La Araucan&#xED;a, la referencia a Sociedad Pesquera Genmar Ltda., por la de Sociedad Pesquera Enfemar Ltda.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10257404}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de julio de 2021.- Cristian Espinoza Montenegro, Subsecretario de Pesca y Acuicultura (S).</div><br></div>", "i": 10257405}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2164 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2164 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "RECTIFICA RESOLUCIÓN Nº 2.976 EXENTA, DE 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1989312", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-07-30", "doble_articulado": false, "id_norma": "1163412", "nume