{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 622 EXENTO, DE 1995 </div></div>", "i": 5945564}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 622, de 8 de noviembre de 1995, se ha autorizado, a partir del a&#xF1;o escolar 1996, al Colegio Nuestra Se&#xF1;ora del Huerto de Santiago, para agregar la asignatura de Computaci&#xF3;n en el plan de estudio de los cursos de 7&#xB0; y 8&#xB0; a&#xF1;os de Educaci&#xF3;n B&#xE1;sica.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s se aprueba programa de estudio para la citada asignatura.</div><br></div>", "i": 5945565}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 17 de noviembre de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5945566}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "622 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-622 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 622 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO NUESTRA SE ORA HUERTO", "SANTIAGO", "PLANES", "ESTUDIO", "PROGRAMA ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-11-08", "doble_articulado": false, "id_norma": "21584", "numero_fuente": "35326", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-11-25", "vigencias": [{"desde": "1995-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-11-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-11-25", "fin_vigencia": "", "tipo_version":