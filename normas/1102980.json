{"html": [{"t": "<div><br><div class=\"p\">MODIFICA <a href=\"https://www.leychile.cl/Navegar?idNorma=229846&amp;idParte=&amp;idVersion=\">RESOLUCI&#xD3;N SII N&#xBA; 83 EXENTA, DEL 30.08.2004</a></div></div>", "i": 9797666}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 48 de 12 de mayo de 2017, que establece:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n se elimina el requisito de se&#xF1;alar el domicilio del receptor de la Boleta de Honorarios Electr&#xF3;nica (BHE).</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes mayo de 2017.</div></div>", "i": 9797667}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "48 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-48 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCIÓN SII Nº 83 EXENTA, DEL 30.08.2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1215304; EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-05-12", "doble_articulado": false, "id_norma": "1102980", "numero_fuente": "41759", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-05-17", "vigencias": [{"desde": "2017-05-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-05-17", "fin_vigencia": ""}, "v