{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8333115}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.023, de 27 de julio de 1998, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA; de la resoluci&#xF3;n N&#xBA; 965 de 1998, de esta Subsecretar&#xED;a que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO, para efectuar la quinta etapa de la pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto FIP N&#xBA; 98-01 denominado &apos;&apos;Monitoreo de las Capturas de Jurel en la Zona Centro-Sur&apos;&apos;, en el sentido de modificar el l&#xED;mite m&#xE1;ximo de captura (toneladas) autorizado para los armadores, seg&#xFA;n se indica a continuaci&#xF3;n: Aries S.A. Industrial (1.239) y Bah&#xED;a Mansa S.A. Industrial (395). </div></div>", "i": 8333116}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de julio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8333117}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1023", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1023"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA DE INVESTIGACION", "INSTITUTO DE FOMENTO PESQUERO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-27", "doble_articulado": false, "id_norma": "122985", "numero_fuente": "36139", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-08-13", "vigencias": [{"desde": "1998-08-13", "hasta": "", "tipo_version": "3", "tipo_ver