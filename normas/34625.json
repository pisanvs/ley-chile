{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ORDENA EXPROPIACIONES DE INMUEBLES QUE INDICA </div></div>", "i": 6010023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 399, de 24 de abril de 1996, de</div><div class=\"p\">SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme</div><div class=\"p\">D.L. N&#xB0; 2.186 de 1978, del inmueble ubicado en calle</div><div class=\"p\">Artes y Oficios N&#xB0; 303, presunto rol de aval&#xFA;os N&#xB0; 2611-1 comuna de San Joaqu&#xED;n, de aparente dominio de don Pedro San Mart&#xED;n Pontigo. Comisi&#xF3;n integrada por peritos Carlos Pe&#xF1;a Vermejo, ingeniero civil; Jorge Navarro Navarrete y Roberto Correa Bezanilla, arquitectos, seg&#xFA;n informe de 25 de octubre de 1995 fij&#xF3; monto provisional de indemnizaci&#xF3;n en $9.125.000.- pagadera al contado. </div></div>", "i": 6010024}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director SERVIU Metropolitano.</div><br></div>", "i": 6010025}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "399", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-399"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN REGIÓN METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES DE INMUEBLES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DECRETO EXPROPIATORIO", "EXPROPIACION", "SAN JOAQUIN", "REGION METROPOLITANA", "BIEN INMUEBLE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-04-24", "doble_articulado": false, "id_norma": "34625", "numero_fuente": "35467-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-05-15", "vigencias": [{"desde": "1996-05-15", "hasta": "", "t