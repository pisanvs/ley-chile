{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DENOMINA &quot;ROSALINA PESCIO VARGAS&quot; A LA ESCUELA N&#xB0; 24 DE PE&#xD1;AFLOR</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha tenido a bien prestar su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5978738}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico: Denom&#xED;nase &quot;Rosalina Pescio Vargas&quot; a la Escuela N&#xB0; 24 de Pe&#xF1;aflor.</div><br></div>", "i": 5978739}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintinueve de Agosto de mil novecientos sesenta y siete.- EDUARDO FREI MONTALVA.- Juan G&#xF3;mez Millas.</div><div class=\"p\">&nbsp; &nbsp; Lo que comunico a Ud. para su conocimiento.- Saluda a Ud.- Patricio Rojas Saavedra, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 5978740}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "16663", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-16663"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "DENOMINA ROSALINA PESCIO VARGAS A LA ESCUELA N° 24 DE PEÑAFLOR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PE AFLOR", "ESCUELA ROSALINA PESCIO VARGAS", "DENOMINACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1967-08-29", "doble_articulado": false, "id_norma": "28616", "numero_fuente": "26840", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1967-09-09", "vigencias": [{"desde": "1967-09-09", "hasta": "", "ti