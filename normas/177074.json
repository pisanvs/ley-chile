{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 115, DE 2000 </div></div>", "i": 6306501}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Con fecha 16 de octubre de 2000 la Secretar&#xED;a Regional Ministerial de Bienes Nacionales de la IX Regi&#xF3;n, dict&#xF3; resoluci&#xF3;n N&#xBA; 115, por medio de la cual se le otorga al Grupo de Acci&#xF3;n Social del Adulto Mayor Adulan una concesi&#xF3;n de uso gratuito del inmueble fiscal ubicado en calle Rume N&#xBA; 160, Poblaci&#xF3;n Millaray, ciudad y comuna de Temuco, provincia de Caut&#xED;n, IX Regi&#xF3;n de la Araucan&#xED;a, por un plazo de 5 a&#xF1;os.-</div><br></div>", "i": 6306502}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Adolfo de la Jara Dur&#xE1;n, Secretario Regional Ministerial de Bienes Nacionales IX Regi&#xF3;n.</div><br></div>", "i": 6306503}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "115", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-115"}], "organismos": ["MINISTERIO DE BIENES NACIONALES", "SECRETARÍA REGIONAL MINISTERIAL", "IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 115, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-16", "doble_articulado": false, "id_norma": "177074", "numero_fuente": "36802", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-11-02", "vigencias": [{"desde": "2000-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente