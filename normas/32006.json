{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA DESIGNACION DE RECEPTORES JUDICIALES N&#xFA;m. 9.- Santiago, 20 de Enero de 1995.- Vistos: Lo dispuesto en el Art. 11 del Decreto Ley N&#xB0; 2.974 de 1979.</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 7193808}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Modif&#xED;case la Resoluci&#xF3;n N&#xB0; 167 de 22 de Octubre de 1990 y Resoluci&#xF3;n N&#xB0; 3 de 13 de Enero de 1986, que designan Receptores Judiciales, en la forma que se indica:</div><div class=\"p\">&nbsp; &nbsp; I Regi&#xF3;n Se elimina a don Jos&#xE9; Luis Rivas Deville, nombrado por Resoluci&#xF3;n N&#xB0; 167 y a don Abel Francisco Montoya Araya, nombrado por Resoluci&#xF3;n N&#xB0; 3.</div><br></div>", "i": 7193809}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Luis Marambio Canales, Director Nacional.</div><br></div>", "i": 7193810}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-9"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "MODIFICA DESIGNACION DE RECEPTORES JUDICIALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECEPTOR JUDICIAL", "NOMBRAMIENTO", "REVOCACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-01-20", "doble_articulado": false, "id_norma": "32006", "numero_fuente": "35091", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-02-11", "vigencias": [{"desde": "1995-02-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-02-11", "fin_vigencia": ""}, "vigen