{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CERTIFICADO </div></div>", "i": 5844881}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y: 365 d&#xED;as, fue de 5,46% anual durante el mes de mayo de 1991.</div><div class=\"p\">&nbsp; &nbsp; Asimismo, en conformidad a lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de mayo de 1991, fue de 5,43% anual. </div></div>", "i": 5844882}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 5 de junio de 1991.- Victor Vial del R&#xED;o, Secretario General.</div><br></div>", "i": 5844883}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "9999", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-9999"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA INTERES PROMEDIO", "TIP", "MAYO 1991", "OPERACIONES CREDITO DINERO", "OPERACIONES REAJUSTABLES", "CAPTACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-06-05", "doble_articulado": false, "id_norma": "1690", "numero_fuente": "33985", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-06-06", "vigencias": [{"desde": "1991-06-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-06-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-06-06