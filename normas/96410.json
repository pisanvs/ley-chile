{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8327358}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por&nbsp; resoluci&#xF3;n N&#xBA; 32, de 13 de enero de 1998, de esta Subsecretar&#xED;a del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 3 de la resoluci&#xF3;n N&#xBA; 1.468 del 5 de noviembre de 1997, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don Marcelino Simon Gonzalez Rivera, para iniciar actividades de pesqueras extractivas, en el sentido de incorporar en las especies cuya captura se autoriza la especie Jurel, con la utilizaci&#xF3;n de red de cerco, en el litoral de la V Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal. </div></div>", "i": 8327359}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de enero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8327360}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "32", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-32"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "MARCELINO SIMON GONZALEZ RIVERA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-01-13", "fecha_derogacion": "2008-07-31", "doble_articulado": false, "id_norma": "96410", "numero_fuente": "35991", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-02-14", "vigencias": [{"desde": "2008-07-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-02-14", "hasta": "2008-07-30", "tipo_version": "0", "tipo_vers