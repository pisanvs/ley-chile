{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7380488}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.838, de 29 de octubre de 2008, de esta Subsecretar&#xED;a, ampl&#xED;ese hasta el 30 de noviembre de 2008 el plazo otorgado por el numeral 4.- inciso 2&#xBA; de la resoluci&#xF3;n N&#xBA; 1.995 de 2003 de esta Subsecretar&#xED;a, a PESQUERA SAN JOS&#xC9; S.A. para reiniciar actividades pesqueras extractivas con la nave &quot;Ventisquero&quot; en el &#xE1;rea mar&#xED;tima correspondiente a Isla de Pascua, archipi&#xE9;lago de Juan Fern&#xE1;ndez, Islas Sala y G&#xF3;mez e Islas Desventuradas, por fuera del &#xE1;rea de reserva artesanal, con arrastre, sobre el recurso Alfonsino Beryx splendens.</div><br></div>", "i": 7380489}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de octubre de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7380490}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2838 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2838 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-10-29", "doble_articulado": false, "id_norma": "280980", "numero_fuente": "39205", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-11-06", "vigencias": [{"desde": "2008-11-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-11-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2