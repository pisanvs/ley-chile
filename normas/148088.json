{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br></div>", "i": 6206805}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 20, de 21 de enero de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Atacama, se autoriza al se&#xF1;or Alberto Francisco Barraza Cort&#xE9;s, para efectuar el servicio de taxi colectivo de la L&#xED;nea N&#xBA; 1 &quot;Candelaria - U.D.A. Atacama&quot;, cuyo trazado fue autorizado por resoluci&#xF3;n N&#xBA; 34, de 22 de junio de 1984, de esta Secretar&#xED;a Regional.</div><br></div>", "i": 6206806}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Sergio Antonio Acevedo Oyarce, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de Atacama.</div><br></div>", "i": 6206807}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "20 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-20 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-01-21", "doble_articulado": false, "id_norma": "148088", "numero_fuente": "32686", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-01-31", "vigencias": [{"desde": "1987-01-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-01-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-01-31", "fin_vigencia": "", "tipo