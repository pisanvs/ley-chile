{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6173924}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decretos MOP N&#xBA;s 594 y 802, de fechas 29 y 31 de marzo de 1999, se expropiaron los lotes de terreno N&#xBA;s 677-A, 679, 680 y 678, superficies 345, 12.600, 11.645 y 19.110 m2, respectivamente, roles de aval&#xFA;o 315-19, 387-215, 387-217 y 387-214, comuna de Pitrufqu&#xE9;n para la obra Regad&#xED;o Faja Maisan Canal Matriz y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios N&#xE9;stor Santini Venegas, Julio Huillin, Lefimil, Celestino Lefimil Colicheo y Mar&#xED;a Lefimil, ascendente a las cantidades de $159.541, $3.927.308, $2.991.351 y $8.274.036.</div><br></div>", "i": 6173925}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministeiro de Obras P&#xFA;blicas. </div></div>", "i": 6173926}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "594", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-594"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-03-29", "doble_articulado": false, "id_norma": "138024", "numero_fuente": "36388", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-06-15", "vigencias": [{"desde": "1999-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-06-21", "