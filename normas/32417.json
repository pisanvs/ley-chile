{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7194314}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 33, de 02 de Junio de 1993, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la V Regi&#xF3;n, se adjudic&#xF3; a Centromotori Ltda., la concesi&#xF3;n para operar, hasta el 09/08/97, un establecimiento ubicado en calle Sargento Aldea N&#xB0; 30 de San Felipe, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de emisi&#xF3;n de contaminantes de todo tipo de veh&#xED;culos motorizados, sus remolques y semirremolques, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 7194315}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Adolfo Tannenbaum Ram&#xED;rez, Secretario Regional Ministerial de Transportes y Telecomunicaciones V Regi&#xF3;n.</div><br></div>", "i": 7194316}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "33", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-33"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTROMOTORI LTDA", "CONCESION REVISION TECNICA", "PLANTA REVISION TECNICA", "VEHICULOS MOTORIZADOS", "SAN FELIPE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-06-02", "doble_articulado": false, "id_norma": "32417", "numero_fuente": "34614", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-07-14", "vigencias": [{"desde": "1993-07-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-07-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig