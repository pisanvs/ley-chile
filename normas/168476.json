{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO EXENTO N&#xBA; 25, DE 1985</div><br><div class=\"p\">&nbsp; &nbsp;  Num. 182 exento.- Ovalle, 26 de Abril de 1985.- Vistos: Lo dispuesto en el art&#xED;culo 43 del DL 3.063 de 1979, y las facultades que me confieren los Art. 12 y 13 del DL 1.289 de 1976,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 7269682}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Reempl&#xE1;zase el guarismo &quot;0,125 UTM&quot;, contenido en el art&#xED;culo 18, N&#xBA; 2 del decreto exento N&#xBA; 25, por &quot;100 pesos en estampillas municipales&quot;.</div><br></div>", "i": 7269683}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, publ&#xED;quese, comun&#xED;quese a los departamentos municipales, arch&#xED;vese.- Rodrigo Sugg Pierry, Alcalde.- Andr&#xE9;s Palma Rojas, Secretario Municipal subrogante.</div><br></div>", "i": 7269684}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "182 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-182 EXENTO"}], "organismos": ["MUNICIPALIDAD DE OVALLE"], "titulo_norma": "MODIFICA DECRETO EXENTO Nº 25, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-04-26", "doble_articulado": false, "id_norma": "168476", "numero_fuente": "32167", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-05-10", "vigencias": [{"desde": "1985-05-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-05-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-05-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente