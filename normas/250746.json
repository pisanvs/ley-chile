{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6573930}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.508, de 5 de junio de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a SALMONOIL S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en sector La Campana s/n, Calbuco, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso Harina y Aceite, el recurso hidrobiol&#xF3;gico indicado en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6573931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de junio de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6573932}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1508 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1508 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-05", "doble_articulado": false, "id_norma": "250746", "numero_fuente": "38495", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-06-22", "vigencias": [{"desde": "2006-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-06-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-06-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2006-06-22", "fecha_version": "2006-06-22", "fecha_actualizacion_texto