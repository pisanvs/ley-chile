{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 611 EXENTA, DE 2012</div></div>", "i": 9236104}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 611, de 18 de enero de 2012, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;English at Work S.A. (English at Work)&quot;, RUT 76.442.190-6 contenida en la resoluci&#xF3;n exenta N&#xBA; 1.468 de 2 de marzo de 2007, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del art. 21 de la ley 19.518.</div><br></div>", "i": 9236105}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  - Francisco Ag&#xFC;ero Larrondo, Director Nacional (Subrogante).</div></div>", "i": 9236106}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "611 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-611 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 611 EXENTA, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-01-18", "doble_articulado": false, "id_norma": "1037134", "numero_fuente": "40183", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-02-09", "vigencias": [{"desde": "2012-02-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-02-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-02-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac