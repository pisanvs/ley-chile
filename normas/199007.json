{"html": [{"t": "<div><div class=\"p\">MODIFICA FECHA DE VIGENCIA DE RESOLUCION N&#xBA; 413, DE 2002 </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 665 exenta.- Santiago, 31 de mayo de 2002.- Visto: El D.L. N&#xBA; 557 de 1974; las leyes n&#xFA;meros 18.059 y 18.290; el decreto supremo N&#xBA; 116, de 2001, el decreto supremo N&#xBA; 298, de 1994, resoluci&#xF3;n exenta N&#xBA; 413, de 2002; todos del Ministerio de Transportes y Telecomunicaciones,</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br></div>", "i": 6384370}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Reempl&#xE1;zase en el numeral 7 de la resoluci&#xF3;n exenta N&#xBA; 413, de 2002, de este Ministerio, la frase &quot;1 de junio&quot; por &quot;1 de septiembre&quot;.</div><br></div>", "i": 6384371}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese y publ&#xED;quese.- Javier Etcheberry Celhay, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo para su conocimiento.- Saluda a Ud., Patricia Mu&#xF1;oz Villela, Jefe Depto. Administrativo. </div></div>", "i": 6384372}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "665 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-665 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "MODIFICA FECHA DE VIGENCIA DE RESOLUCION Nº 413, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-31", "doble_articulado": false, "id_norma": "199007", "numero_fuente": "37277", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-07", "vigencias":