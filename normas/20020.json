{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 73 EXENTO, DE 1995 </div><br></div>", "i": 7160378}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 73 de 27 de enero de 1995, se ha modificado y complementado, a partir del a&#xF1;o escolar 1995, el plan especial de estudio del Saint John&apos;s School de Concepci&#xF3;n, aprobado por decreto supremo exento de Educaci&#xF3;n N&#xB0; 278 de 1985 y modificado por decreto supremo exento de Educaci&#xF3;n N&#xB0; 205 de 1988.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio de las asignaturas del Plan Electivo para 3&#xB0; y 4&#xB0; a&#xF1;o medio:</div><div class=\"p\">&quot;Chile y la Cuenca del Pac&#xED;fico&quot; y &quot;Administraci&#xF3;n y Organizaci&#xF3;n Empresarial&quot;.</div><br></div>", "i": 7160379}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 22 de Febrero de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160380}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "73 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-73 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 73 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SAINT JOHN#S SCHOOL CONCEPCION", "PROGRAMAS ESTUDIO", "PLANES ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-01-27", "doble_articulado": false, "id_norma": "20020", "numero_fuente": "35175", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-05-24", "vigencias": [{"desde": "1995-05-24", "hasta": "",