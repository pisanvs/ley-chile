{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,104.- Santiago, 7 de octubre de 1898.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6161544}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Amelia L&#xF3;pez, madre del sarjento-mayor don Alfredo Soruco, el goce de la pension que la lei de 22 de setiembre de 1890, acuerda a la madre-viuda de un sarjento-mayor, de la que gozar&#xE1; con esclusion de cualquiera otra pension.</div><br></div>", "i": 6161545}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Ventura Blanco.</div><br></div>", "i": 6161546}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1104", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1104"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-10-07", "doble_articulado": false, "id_norma": "134173", "numero_fuente": "6123", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-10-12", "vigencias": [{"desde": "1898-10-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-10-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-10-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresad