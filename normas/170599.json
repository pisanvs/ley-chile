{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6281065}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 22, de fecha 07 de Enero de 1988 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Va. Regi&#xF3;n, se autoriza a Mariana Breuer Lindemann para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6281066}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 07 de Enero de 1988.- Hern&#xE1;n V&#xE1;squez Wacquez, Capit&#xE1;n de Nav&#xED;o, Secretario Regional Ministerio de Transportes y Telecomunicaciones, Va. Regi&#xF3;n.</div><br></div>", "i": 6281067}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "22 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-22 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL V REGIÓN DE VALPARAÍSO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-07", "doble_articulado": false, "id_norma": "170599", "numero_fuente": "32969", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-01-14", "vigencias": [{"desde": "1988-01-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-01-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-01-14", "fin_vigencia": "", "