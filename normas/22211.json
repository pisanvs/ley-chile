{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; FORMA DEL PAGO DE LOS DERECHOS DE INTERNACION I ALMACENAJE</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 361.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947723}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. El pago de los derechos de internacion i almacenaje continuar&#xE1; haci&#xE9;ndose en las aduanas de la Rep&#xFA;blica en la misma forma i con los recargos actualmente establecidos, hasta el dia en que comiemce a rejir una nueva tarifa de Avaluos en que el valor de las mercader&#xED;as se esprese en pesos de a dieziocho peniques.</div><br><br></div>", "i": 5947724}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 18 de Junio de 1896.- JORJE MONTT.- Herm&#xF3;jenes P&#xE9;rez de Arce.</div><br></div>", "i": 5947725}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "361", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-361"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "FORMA DEL PAGO DE LOS DERECHOS DE INTERNACION I;ALMACENAJE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ADUANAS", "INTERNACION", "ALMACENAJE", "DERECHOS", "PAGO", "DISPOSICIONES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion