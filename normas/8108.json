{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5886754}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto MOP. N&#xB0; 43, de 23 de febrero de 1993, se expropiaron los lotes de terreno N&#xB0;s. 1 y 5, superficies 240 m2. y 537 m2., respectivamente, roles de aval&#xFA;o 337-95 y 335-10, Comuna de Cunco, para la obra Camino Temuco Cunco por Huichahue y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Ferm&#xED;n Huircaleo Coll&#xED;o y Reginio Beltr&#xE1;n Dom&#xED;nguez, ascendente a las cantidades de $ 372.621.- y $1.515.788.</div><br></div>", "i": 5886755}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 5886756}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "43", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-43"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DECRETO EXPROPIATORIO", "EXPROPIACION", "BIEN INMUEBLE", "BIEN RAIZ", "CUNCO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-02-23", "doble_articulado": false, "id_norma": "8108", "numero_fuente": "34531-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-04-01", "vigencias": [{"desde": "1993-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1993-04-01", "fecha_actualizacion_texto": "1993-04-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "e