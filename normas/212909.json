{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6433053}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n, que suscribe, certifica que la Universidad Aut&#xF3;noma Indoamericana inscrita bajo el n&#xFA;mero C-39 del Registro de Universidades del Ministerio de Educaci&#xF3;n, ha presentado el programa de estudio de la carrera de Psicolog&#xED;a conducente al grado de acad&#xE9;mico de Licenciado en Psicolog&#xED;a&nbsp; y al t&#xED;tulo profesional de Psic&#xF3;logo a la Universidad de Tarapac&#xE1; instituci&#xF3;n que lo ha aprobado y se ha constituido en entidad examinadora, conforme a lo dispuesto&nbsp; en el convenio suscrito entre ambas con fecha 19 de abril de 1991.</div><div class=\"p\">&nbsp; &nbsp;  La carrera mencionada podr&#xE1; impartirse a contar del a&#xF1;o 1991.</div><br></div>", "i": 6433054}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de Octubre de 1991.</div><div class=\"p\">&nbsp; &nbsp;  GASTON GILBERT BAETTIG Subsecretario de Educaci&#xF3;n (S) </div></div>", "i": 6433055}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-10-25", "doble_articulado": false, "id_norma": "212909", "numero_fuente": "34131", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-12-02", "vigencias": [{"desde": "1991-12-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vi