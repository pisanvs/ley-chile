{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 151 EXENTO, DE 2002 </div></div>", "i": 6380538}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 151, de fecha 4 de marzo de 2002, de Educaci&#xF3;n, se declara aprobada al Instituto Profesional Cepech la carrera y t&#xED;tulo profesional que se indica:</div><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Ingenier&#xED;a de Ejecuci&#xF3;n en Redes y</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Comunicaciones</div><div class=\"p\">T&#xED;tulo Profesional : Ingeniero de Ejecuci&#xF3;n en Redes</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  y Comunicaciones.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Dicha carrera podr&#xE1; ser impartida en jornada diurna y vespertina en su Sede de la ciudad de Santiago, a contar del primer semestre del a&#xF1;o 2002, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6380539}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de marzo de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6380540}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "151 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-151 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 151 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-04", "doble_articulado": false, "id_norma": "197815", "numero_fuente": "37253