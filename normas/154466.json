{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7260490}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 183, de 26 de enero de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.178 de 1994, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SERVICIOS MARINOS S.A., para operar la nave &apos;&apos;Corsario&apos;&apos;, s&#xF3;lo en lo relativo a la operaci&#xF3;n respecto de los recursos Anchoveta, Sardina espa&#xF1;ola, Jurel, Apa&#xF1;ado, Ayanque, Bonito, Caballa, Cabinza, Cachurreta, Cojinoba del norte, Dorado, Palometa, Rollizo, Roncacho y Sardina com&#xFA;n, en la III y IV Regiones, conforme lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7260491}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de enero de 2000.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 7260492}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "183", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-183"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-26", "doble_articulado": false, "id_norma": "154466", "numero_fuente": "36579", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-02-03", "vigencias": [{"desde": "2000-02-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-02-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v