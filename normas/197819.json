{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 4.191 EXENTA, DE 2002 </div></div>", "i": 6380550}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 4.191 de 5 de abril del a&#xF1;o 2002, se ha aprobado al Colegio San Luis de Antofagasta, un plan de estudio para 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s se aprueban programas de estudio para los Subsectores del Plan Diferenciado: Lenguaje y Sociedad, Literatura e Identidad y C&#xE1;lculo.</div><br></div>", "i": 6380551}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de abril de 2002.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6380552}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4191 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4191 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 4.191 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-05", "doble_articulado": false, "id_norma": "197819", "numero_fuente": "37253", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-08", "vigencias": [{"desde": "2002-05-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingr