{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE RESOLUCION EXENTA N&#xB0; 2.987, DE 1993 </div></div>", "i": 6026398}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n Exenta N&#xB0; 2.987 de fecha 12 de Agosto de 1993 del Ministerio de Educaci&#xF3;n, se declar&#xF3; que no se concede el reconocimiento oficial al Centro de Formaci&#xF3;n T&#xE9;cnica FLOEN, organizado por la Sociedad Centro de Formaci&#xF3;n T&#xE9;cnica FLOEN Limitada, de Santiago, y se elimin&#xF3; del Libro de Registros de Centros de Formaci&#xF3;n T&#xE9;cnica el N&#xB0; 224 de fecha 19 de Enero de 1993, correspondiente a la mencionada instituci&#xF3;n.- </div></div>", "i": 6026399}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 6026400}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2987", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2987"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N° 2.987, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECONOCIMIENTO OFICIAL", "CENTRO FORMACION", "TECNICA", "FLOEN", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-08-12", "doble_articulado": false, "id_norma": "40280", "numero_fuente": "34747", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-12-23", "vigencias": [{"desde": "1993-12-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-12-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-12-23", "fin_vigencia": "", "tipo_version": "3"}