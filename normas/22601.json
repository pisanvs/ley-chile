{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Enfermedades infecciosas Lei n&#xFA;m. 1,379.-Santiago, a 15 de Noviembre de 1900.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274296}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la cantidad de cien mil pesos en adoptar medidas destinadas a combatir las enfermedades infecciosas.</div><br></div>", "i": 8274297}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ E.- M. S&#xE1;nchez Fontecilla.</div><br></div>", "i": 8274298}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1379", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1379"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Enfermedades infecciosas", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ENFERMEDADES INFECCIOSAS", "PREVENCION", "FONDOS", "INVERSION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-11-15", "doble_articulado": false, "id_norma": "22601", "numero_fuente": "6743", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-11-15", "vigencias": [{"desde": "1900-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1900-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes