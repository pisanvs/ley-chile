{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CERTIFICADO </div></div>", "i": 5844884}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1 del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de octubre de 1991, fue de 5,28% anual. </div></div>", "i": 5844885}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 18 de octubre de 1991.- Isaac Telias Ergas, Ministro de Fe Subrogante.</div><br></div>", "i": 5844886}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "9999", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-9999"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA INTERES PROMEDIO", "TIP", "OCT", "1991", "OPERACIONES CREDITO DINERO", "CAPTACION", "OPERACIONES REAJUSTABLES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-10-18", "doble_articulado": false, "id_norma": "1694", "numero_fuente": "34095", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-10-19", "vigencias": [{"desde": "1991-10-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-10-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-10-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1991-10-19", "fecha_actualizacion_texto": "1991-10-19", "tipo_tratado": ""}, "alertas": [], "alerta_global": "",