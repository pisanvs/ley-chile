{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6130695}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP. No. 1.050, de 30 de julio de 1998, se expropiaron los lotes de terreno No. s.1, 2 y 3 Norte y No. 1 Sur, superficies 6.293, 17.292, 2.720 y 24.469 m&#xB2;, Roles de Aval&#xFA;o No. s.503-16, 503-1 y 503-2, comuna de Talagante, para la obra Camino Autopista Santiago - San Antonio, sector Area de Servicios Complementarios Norte, Km. 4.464,30 al 4.747,30 y sector Area de Servicios Complementario Sur, Km.</div><div class=\"p\">4.608,30 al 4.868,30, y se acord&#xF3; precio de la indemnizaci&#xF3;n con su propietario Compa&#xF1;&#xED;a de Petr&#xF3;leos de Chile S.A., ascendente a la cantidad de $ 514.045.400.- para los lotes No. s.1, 2 y 3 Norte y No. 1 Sur.-</div><br></div>", "i": 6130696}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6130697}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1050", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1050"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "TALAGANTE", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-30", "doble_articulado": false, "id_norma": "124431", "numero_fuente": "36165", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-09-15", "vigencias": [{"desde": "1998-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigen