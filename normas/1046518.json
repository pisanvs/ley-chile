{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9317020}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.102, de 28 de noviembre de 2012, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1045392&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.830, de 2012</a>, de esta Subsecretar&#xED;a, que autoriz&#xF3; a CAMANCHACA PESCA SUR S.A. para continuar desarrollando actividades pesqueras extractivas con la nave en construcci&#xF3;n &quot;BEC N&#xBA; 2583-00&quot;, en el sentido de se&#xF1;alar que la capacidad de bodega de dicha nave es 343,5 m&#xB3; y no la que all&#xED; se indica.</div></div>", "i": 9317021}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de noviembre de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9317022}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3102 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3102 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2012-11-28", "fecha_derogacion": "2017-11-29", "doble_articulado": false, "id_norma": "1046518", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2012-12-05", "vigencias": [{"desde": "2017-11-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2012-12-05", "hasta": "2017-11-28", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio