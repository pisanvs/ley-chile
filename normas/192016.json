{"html": [{"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 2,987.- Santiago, 16 de Agosto de 1943.- Vistos estos antecedentes; lo dispuesto en el decreto reglamentario n&#xFA;mero 2,736, de 31 de Octubre de 1925, y con lo informado por el Consejo de Defensa Fiscal;</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 6359056}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.o conc&#xE9;dese personalidad jur&#xED;dica a la corporaci&#xF3;n denominada &quot;Patronato Nacional de Reos&quot;, con domicilio en Santiago, y</div><div class=\"p\">&nbsp; &nbsp;  2.o Apru&#xE9;banse los estatutos por los cuales ha de regirse dicha corporaci&#xF3;n, en los t&#xE9;rminos de que da testimonio la escritura p&#xFA;blica adjunta, otorgada ante el notario p&#xFA;blico de Santiago don Francisco Javier Hurtado, con fecha 13 de Mayo de 1943.</div><br></div>", "i": 6359057}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- J. A. RIOS M.- E. L. Marshall.</div><br></div>", "i": 6359058}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2987", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2987"}], "organismos": ["MINISTERIO DE JUSTICIA", "SUBSECRETARIA DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1943-08-16", "doble_articulado": false, "id_norma": "192016", "numero_fuente": "19652", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1943-09-06", "vigencias": [{"desde": "1943-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1943-09-06", "fin_vigencia":