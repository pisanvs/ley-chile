{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div><br></div>", "i": 9122139}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La Ley N.o 13,959, que aprueba medidas jur&#xED;dicas en beneficio de las provincias que se&#xF1;ala, se public&#xF3; en el &quot;Diario Oficial&quot; N.o 24,683 con el error de transcripci&#xF3;n que se salva a continuaci&#xF3;n:</div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo 15, inciso 1o, tercera l&#xED;nea, debe decir:... que se hayan hecho o se hagan al Gobierno para ayudar a las zonas damnificadas.</div><br></div>", "i": 9122140, "v": ["RECTIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "157", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-157"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1023790", "numero_fuente": "24684", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-07-05", "vigencias": [{"desde": "1960-07-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1960-07-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1960-07-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "RECTIFICACION", "url_part": "rectificacion"}], "ingresado_por": "362", "fecha_ingreso": "2011-03-15", "fecha_version": "1960-07-05", "actualizado_por": "362", "fecha_actualizacion_texto": "2011-03-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9122139}, {"n": "Artículo", "i": 912214