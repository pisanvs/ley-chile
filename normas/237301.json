{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6523006}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. N&#xB0; 376, de 30 de mayo de 1996, se expropiaron los lotes de terrenos N&#xB0;s. 6-A1, 6-A2, 6-C, superficie 11.624 M2, 9.911 M2, 12.440 M2, rol de aval&#xFA;o 2-35 y 2-30, comuna de Cerrillos, para la obra Avda. paso Superior, Avda. General Vel&#xE1;squez, sector Nudo Avda. General Vel&#xE1;squez-Avda. Americo Vespucio y se acord&#xF3; precio de la indemnizaci&#xF3;n con los propietarios, Construcciones Ingenier&#xED;a Neut Latour y Compa&#xF1;&#xED;a Sociedad An&#xF3;nima Inmobiliaria Diez Hermanos S.A., ascendente a la cantidad de $231.238.899 para los lotes N&#xB0;s. 6-A1 y 6-A2 y para el lote N&#xB0; 6-C la cantidad de $114.495.345.</div><br><br></div>", "i": 6523007}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6523008}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "376", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-376"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-30", "doble_articulado": false, "id_norma": "237301", "numero_fuente": "35504", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-07-01", "vigencias": [{"desde": "1996-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendien