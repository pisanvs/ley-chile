{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMINO CARRETERO A LA ARJENTINA POR LA VIA DE USPALLATA</div><div class=\"p\">&nbsp; &nbsp; Lei N&#xFA;m. 217.-Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br></div>", "i": 7162557}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese la suma de cuarenta i cinco mil pesos ($ 45,000) para la terminacion del camino carretero a la Arjentina por la via de Uspallata.</div><br><br></div>", "i": 7162558}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 17 de Diciembre de 1894.-JORJE MONTT.-Elias Fern&#xE1;ndez A.</div><br></div>", "i": 7162559}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "217", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-217"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "CAMINO CARRETERO A LA ARJENTINA POR LA VIA DE USPALLATA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ARGENTINA", "USPALLATA", "CAMINO CARRETERO", "CONSTRUCCION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-12-17", "doble_articulado": false, "id_norma": "22073", "numero_fuente": "4992", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-12-18", "vigencias": [{"desde": "1894-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-12-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici