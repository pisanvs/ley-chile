{"html": [{"t": "<div><div class=\"p\">DESIGNA A JULIO ULE SUBIABRE COMO RECEPTOR JUDICIAL EN LA X REGION</div><br><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 106.- Santiago, 23 de marzo de 1999.- Vistos: Lo dispuesto en el Art. 11 del decreto ley N&#xBA; 2.974 de 1979.</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br><br></div>", "i": 6164112}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del decreto ley citado, X Regi&#xF3;n, al siguiente funcionario:</div><br><div class=\"p\">- Julio Ule Subiabre.</div><br></div>", "i": 6164113}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Luis Marambio Canales, Director Nacional.</div><br></div>", "i": 6164114}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "106", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-106"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA A JULIO ULE SUBIABRE COMO RECEPTOR JUDICIAL EN\nLA X REGION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-03-23", "doble_articulado": false, "id_norma": "135023", "numero_fuente": "36340", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-04-16", "vigencias": [{"desde": "1999-04-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia":