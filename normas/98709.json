{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8329770}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;618, de 30 de abril de 1998, de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n, modif&#xED;case la resoluci&#xF3;n N&#xBA;1.855 de 1997, de</div><div class=\"p\">esta Subsecretar&#xED;a, que fij&#xF3; la n&#xF3;mina de armadores y</div><div class=\"p\">embarcaciones habilitados para operar en las unidades de</div><div class=\"p\">pesquer&#xED;a de Sardina espa&#xF1;ola y Anchoveta, se&#xF1;aladas en el</div><div class=\"p\">art&#xED;culo primero del D.S. N&#xBA;493 de 1996, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, en el &#xE1;rea de sus respectivas autorizaciones, en el sentido de incorporar en el numeral 1 lo siguiente: &apos;&apos;Pesquera La Pen&#xED;nsula S.A.: Loa 1&apos;&apos;.</div><br></div>", "i": 8329771}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de abril de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8329772}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "618", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-618"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ARMADORES INDUSTRIALES", "NOMINA", "PESCA", "SARDINA ESPA OLA", "ANCHOVETA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-04-30", "fecha_derogacion": "1998-08-13", "doble_articulado": false, "id_norma": "98709", "numero_fuente": "360