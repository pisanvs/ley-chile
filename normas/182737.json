{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 783 EXENTA, DE 2001 </div><br></div>", "i": 6325900}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 783 de 2 de febrero del a&#xF1;o 2001, se ha aprobado al Colegio Villa Mar&#xED;a Academy, comuna de Las Condes, de Santiago, un plan de estudio para 3&#xBA; a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 6325901}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de febrero de 2001.- Gabriel Ar&#xE1;nguiz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General (S). </div></div>", "i": 6325902}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "783 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-783 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 783 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-02", "doble_articulado": false, "id_norma": "182737", "numero_fuente": "36910", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-12", "vigencias": [{"desde": "2001-03-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-03-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_p