{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 4.660 EXENTA, DE 2005 </div></div>", "i": 6528300}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 4.660, de 18 de mayo de 2005, se ha aprobado un plan de estudio para 1&#xBA;, 2&#xBA;, 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media al Liceo &quot;Obispo Augusto Salinas&quot;, comuna de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio de los M&#xF3;dulos de Formaci&#xF3;n Diferenciada: Arte y Dise&#xF1;o Gr&#xE1;fico. Recursos para una Comunicaci&#xF3;n Eficaz, Derecho Internacional Humanitario y Dise&#xF1;o Integral y Publicidad Creativa.</div><br></div>", "i": 6528301}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 1 de junio de 2005.- Xavier Vanni Cucurella, Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6528302}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4660 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4660 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 4.660 EXENTA, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-05-18", "doble_articulado": false, "id_norma": "238847", "numero_fuente": "38178", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-06-06", "vigencias": [{"desde": "2005-06-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-06-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-06-06", "fin_vigencia": "", "tipo_versi