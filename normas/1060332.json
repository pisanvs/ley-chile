{"html": [{"t": "<div><br><div class=\"p\">DERECHOS DE AGUA EN COMUNA DE ANGOL</div></div>", "i": 9419482}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero, mediante resoluci&#xF3;n exenta N&#xBA; 794, de 31 de enero de 2014, conforme art&#xED;culo 5&#xBA; transitorio del C&#xF3;digo de Aguas, complement&#xF3; la <a href=\"https://www.leychile.cl/Navegar?idNorma=153786&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta del Servicio Agr&#xED;cola y Ganadero N&#xBA; 1.906, de fecha 9 de septiembre de 1987</a>, que aprob&#xF3; el Estudio T&#xE9;cnico de Divisi&#xF3;n de los Derechos de Aprovechamiento de Aguas del predio &quot;Santa Helena, antes San Martin de Malleco&quot; y del Proyecto de Parcelaci&#xF3;n &quot;Unidad Campesina&quot;, ubicado en la comuna de Angol, Regi&#xF3;n de la Araucan&#xED;a, en el sentido de establecer que los derechos de aprovechamiento de aguas aprobados en la resoluci&#xF3;n que se complementa son consuntivos, de ejercicio permanente y continuo.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13&#xBA; de la Ley N&#xBA; 18.377.</div></div>", "i": 9419483}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director Nacional.</div></div>", "i": 9419484}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "794 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-794 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUA EN COMUNA DE ANGOL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-01-31", "doble_articulado": false