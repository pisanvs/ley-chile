{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 5.198 EXENTA, DE 2013</div></div>", "i": 9366299}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 5.198, de 9 de julio de 2013, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Organismo T&#xE9;cnico de Capacitaci&#xF3;n Vigias SpA (Otec Vigias SpA)&quot;, RUT 76.102.641-0, contenida en la resoluci&#xF3;n exenta N&#xBA; 6.217, de 22 de julio de 2011, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.- </div></div>", "i": 9366300}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (S).</div></div>", "i": 9366301}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5198 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5198 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 5.198 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-07-09", "doble_articulado": false, "id_norma": "1053070", "numero_fuente": "40615", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-07-23", "vigencias": [{"desde": "2013-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-07-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-07-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie