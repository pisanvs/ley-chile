{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6285886}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.742, de 28 de abril del 2000, se expropiaron los terrenos N&#xBA;s. 1, 2, 3 y 10, superficies 21,25; 665,50; 3.321,83 y 4.722,15 m&#xB2;, roles de aval&#xFA;os 1018-27 y 1018-55, comuna de Puerto Natales, para la obra Mejoramiento Camino Acceso a Balmaceda, 72D340, Sector Puerto Natales - Balmaceda, Kms. 0.000 al 10.500,00 Ultima Esperanza y se acord&#xF3; precio de las indemnizaciones con sus propietarios Ricardo Helmer Mansilla y Carmen Luisa Soto Mart&#xED;nez, ascendentes a las cantidades de $976.642, para los lotes N&#xBA;s. 1, 2 y 3 y $826.526, para el lote N&#xBA; 10.</div><br></div>", "i": 6285887}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6285888}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1742", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1742"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-28", "doble_articulado": false, "id_norma": "171953", "numero_fuente": "36702", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-01", "vigencias": [{"desde": "2000-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAS", "fecha