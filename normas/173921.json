{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL CONSEJO EN SU SESI&#xD3;N N&#xB0; 855 </div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xB0; 855, celebrada el 3 de agosto de 2000, adopt&#xF3; los siguientes Acuerdos:</div><br></div>", "i": 6295160}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  855-07-0000803&nbsp; Modifica Cap&#xED;tulo III.B.1.1 del Compendio de Normas Financieras.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; agregar el siguiente p&#xE1;rrafo segundo en el N&#xB0; 2 del Cap&#xED;tulo III.B.1.1 del Compendio de Normas Financieras:</div><br><div class=\"p\">&apos;&apos;Las cuentas a la vista tambi&#xE9;n podr&#xE1;n ser convenidas en moneda extranjera, en cuyo caso deber&#xE1;n ser abiertas en empresas bancarias establecidas en el pa&#xED;s y no devengar&#xE1;n intereses ni reajustes&apos;&apos;.</div><br></div>", "i": 6295161}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de agosto de 2000.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6295162}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "855", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-855"}, {"tipo": "5", "numero": "855-07", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-855-07"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL CONSEJO EN SU SESIÓN N° 855", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-08-03", "doble_articulado": false, "id_norma": "173921", "numero_fuente": "36733", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-07",