{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><br></div>", "i": 8277754}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Trasp&#xE1;sase del &#xED;tem 04/12/01, al &#xED;tem 04 12 04 g, del Presupuesto del Ministerio del Interior (Subsecretar&#xED;a de Aviaci&#xF3;n), correspondiente al a&#xF1;o 1930, la suma de doscientos treinta mil pesos ($ 230,000).</div><br></div>", "i": 8277755}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintitr&#xE9;s de Diciembre de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Carlos O. Frodden&quot;. </div></div>", "i": 8277756}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4917", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4917"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O 1930", "MODIFICACION MINISTERIO", "INTERIOR", "SUBSECRETARIA", "AVIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-12-23", "doble_articulado": false, "id_norma": "24967", "numero_fuente": "15860", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-12-30", "vigencias": [{"desde": "1930-12-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1930-12-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1930-12-30", "fin_vige