{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9142972}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.366, de 16 de mayo de 2011, de esta Subsecretar&#xED;a, rech&#xE1;zanse las solicitudes de concesi&#xF3;n de acuicultura n&#xFA;meros 207111299, 207111459, 205111288, 207122417, 208111655, 208111561, 208111534, 209111141, 208122228, 208122213, 208122229, 208121091, 208122290, 208122297, 207123084 y 208121188, se&#xF1;aladas en la resoluci&#xF3;n extractada, y publicada &#xED;ntegramente en la p&#xE1;gina web www.subpesca.cl, en virtud de los art&#xED;culos 78 de la Ley General de Pesca y Acuicultura, 11 y 13 del DS N&#xBA; 320, de 2001, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div></div>", "i": 9142973}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de mayo de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9142974}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1366 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1366 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-05-16", "doble_articulado": false, "id_norma": "1025639", "numero_fuente": "39966", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-05-23", "vigencias": [{"desde": "2011-05-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-05-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "20