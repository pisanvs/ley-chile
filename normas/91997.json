{"html": [{"t": "<div><div class=\"p\">PRORROGA PLAZO RESOLUCION QUE INDICA </div></div>", "i": 8321065}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 465, de 02 de Mayo de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por 9 meses a contar del 08 de marzo de 1989 el plazo otorgado a don Miguel Nenadovich del R&#xED;o, R.U.T. No. 3.949.126-5, domiciliado en calle San Antonio No. 427, piso 9&#xB0;, Santiago, para empezar a operar el establecimiento de cultivo autorizado por la resoluci&#xF3;n No. 143, de 1988, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor. </div></div>", "i": 8321066}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 02 de Mayo de 1989.- Roberto Cabezas Bello; Subsecretario de Pesca.</div><br></div>", "i": 8321067}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "465", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-465"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "PRORROGA PLAZO RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-02", "doble_articulado": false, "id_norma": "91997", "numero_fuente": "33368", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-05-10", "vigencias": [{"desde": "1989-05-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-05-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-05-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient