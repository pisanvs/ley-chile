{"html": [{"t": "<div><div class=\"p\">EXCEPCIONA DE LA RETENCION DEL 5% POR LA COMPRA DE PRODUCTOS CARNEOS </div></div>", "i": 6617973}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional Punta Arenas del SII, por resoluci&#xF3;n Ex. N&#xBA; 156, de 22 de junio de 2007, excepciona de la retenci&#xF3;n del 5% del Impuesto al Valor Agregado, que los proveedores c&#xE1;rneos cargan en las facturas de ventas, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n y hasta que se encuentre en las condiciones en cuya virtud le fue concedida la autorizaci&#xF3;n al Complejo Penitenciario Punta Arenas, RUT N&#xBA; 61.004.105-1.</div><br></div>", "i": 6617974}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jorge Lara Arriagada, Director Regional. </div></div>", "i": 6617975}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "156 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-156 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "XII DIRECCIÓN REGIONAL DE PUNTA ARENAS"], "titulo_norma": "EXCEPCIONA DE LA RETENCION DEL 5% POR LA COMPRA DE PRODUCTOS CARNEOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-22", "doble_articulado": false, "id_norma": "262999", "numero_fuente": "38822", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-07-26", "vigencias": [{"desde": "2007-07-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-07-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-07-26", "fin_vigencia": "", "tipo_version": "3"}], "event