{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6391539}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.578, de 31 de julio de 2002, de</div><div class=\"p\">esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las</div><div class=\"p\">resoluciones N&#xBA; 1.689 de 1989 y N&#xBA; 1.004 de 1991, ambas</div><div class=\"p\">de esta Subsecretar&#xED;a, que autorizaron a JOACHIM KRAUSE</div><div class=\"p\">GRONWALD, para operar la nave &quot;Cherne&quot;, tambi&#xE9;n conocida</div><div class=\"p\">como &quot;Grivia&quot;, ello en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura, y del memor&#xE1;ndum de la Divisi&#xF3;n de Desarrollo Pesquero de esta Subsecretar&#xED;a, citado en Visto.</div><br></div>", "i": 6391540}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de julio de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6391541}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1578", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1578"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-07-31", "doble_articulado": false, "id_norma": "201230", "numero_fuente": "37327", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-08-06", "vigencias": [{"desde": "2002-08-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-08-06", "fin_vigencia": ""}, "vigencias_ve