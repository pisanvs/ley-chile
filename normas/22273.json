{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Provision de Agua Potable a la Ciudad de Concepcion Lei n&#xFA;m. 925.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274001}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza por seis meses, al Presidente de la Rep&#xFA;blica para invertir hasta doscientos mil pesos en la compra o espropiacion de los terrenos i aguas necesarias para mejorar la provision de agua potable de la ciudad de Concepcion.</div><br><br></div>", "i": 8274002}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 10 de Marzo de 1897.- FEDERICO ERRAZURIZ.- C&#xE1;rlos Ant&#xFA;nez.</div><br></div>", "i": 8274003}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "925", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-925"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "PROVISION DE AGUA POTABLE A LA CIUDAD DE CONCEPCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCEPCION", "AGUA POTABLE", "PROVISION", "FONDOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-03-10", "doble_articulado": false, "id_norma": "22273", "numero_fuente": "5653", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1897-03-13", "vigencias": [{"desde": "1897-03-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1897-03-13", "fin_