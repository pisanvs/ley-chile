{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,500.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6163529}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- El plazo fijado por el art&#xED;culo 2&#xBA; de la lei n&#xFA;mero 999, de 17 de enero de 1898, se entender&#xE1; contando desde la fecha de la promulgacion de la presente lei.</div><br></div>", "i": 6163530}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, promulguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de diciembre de 1901.- RIESCO - Rafael Orrego.</div><br></div>", "i": 6163531}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1500", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1500"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-12-17", "doble_articulado": false, "id_norma": "134818", "numero_fuente": "7101", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-12-19", "vigencias": [{"desde": "1901-12-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1901-12-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1901-12-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-04-13", "fecha_version": "1901-