{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8561152}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 85, de 22 de Enero de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se caduca la Resoluci&#xF3;n No. 843, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don EDUARDO FIOL BERNAIN, R.U.T. No. 3.315.707-k, domiciliado en Santiago, calle Premio Nobel 2851-Q, para ampliar actividades de cultivo de Osti&#xF3;n del norte, en el sector se&#xF1;alado en las Resoluciones No. 597, de 1984 y No. 157, de 1987, de esta Subsecretar&#xED;a de Pesca, por renuncia de su titular.</div><br><br></div>", "i": 8561153}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de Enero de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br><br></div>", "i": 8561154}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "85", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-85"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-22", "doble_articulado": false, "id_norma": "80734", "numero_fuente": "34006", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-07-02", "vigencias": [{"desde": "1991-07-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-07-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-07-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion