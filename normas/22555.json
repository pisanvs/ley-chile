{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Mobiliario para el Congreso Lei n&#xFA;m. 1,321 Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI </div></div>", "i": 8274259}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza la inversion de cuarenta mil pesos en la adquisicion i reparaciones de mobiliario de la C&#xE1;mara de Senadores, i la de treinta i cinco mil pesos en la adquisicion i reparaciones de mobiliario de la C&#xE1;mara de Diputados.</div><br><br></div>", "i": 8274260}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 18 de Enero de 1900.- FEDERICO ERRAZURIZ.- El&#xED;as Fern&#xE1;ndez A.</div><br></div>", "i": 8274261}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1321", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1321"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MOBILIARIO PARA EL CONGRESO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONGRESO NACIONAL", "MOBILIARIO", "ADQUISICION", "REPARACION INVERSION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-01-18", "doble_articulado": false, "id_norma": "22555", "numero_fuente": "6499", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-01-18", "vigencias": [{"desde": "1900-01-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-01-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"ini