{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6177359}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 403, de 26 de febrero de 1999, se expropiaron los lotes de terreno N&#xBA;s. 25, 66, 70, 71, 72, 133 y 136, superficies 126,38; 1.381,58; 226,03; 520,44; 190,62; 951,16 y 61,87 m2 respectivamente, roles de aval&#xFA;o 122-69, 117-7, 146-16 y 5-11, comunas de Curaco de V&#xE9;lez y Quinchao, para la obra Camino Ruta W-59, Sector Dalcahue - Achao y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Galo Mu&#xF1;oz Espa&#xF1;a, Elba S&#xE1;nchez Gallardo y Otros, Mar&#xED;a Uribe Ru&#xED;z y Manuel Estefo Estefo, ascendente a las cantidads de $241.961, $807.819, $522.911 y $676.923.</div><br></div>", "i": 6177360}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6177361}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "403", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-403"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-02-26", "doble_articulado": false, "id_norma": "139039", "numero_fuente": "36413", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-07-15", "vigencias": [{"desde": "1999-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por"