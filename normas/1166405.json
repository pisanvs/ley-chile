{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10276062}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xBA; 915, de 3 septiembre 2021, prohibi&#xF3; circulaci&#xF3;n de veh&#xED;culos que indica en condiciones que se&#xF1;ala, relativas a Actividad de Aniversario Rinc&#xF3;n Patag&#xF3;n 2021, y autoriz&#xF3; a Rinc&#xF3;n Patag&#xF3;n de Coyhaique para realizar siguiente intervenci&#xF3;n en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - corte total de calle Francisco Bilbao entre calles Arturo Prat y 12 de Octubre, entre las 14:00 y las 19:30 hrs. del d&#xED;a s&#xE1;bado 4 de septiembre de 2021.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10276063}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andrea Mac&#xED;as Palma, Gobernadora Regional, Gobierno Regional de Ays&#xE9;n.- Jimena Guti&#xE9;rrez Jaramillo, Asesora Jur&#xED;dica, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10276064}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "915 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-915 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2024037", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-09-03", "doble_articulado": false, "id_norma": "1166405", "numero_fuente": "43077", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-10-14", "vigencias": [{"desde": "2021-10-14", "hasta": "", "tipo_version": "3", "tipo_ver