{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9501693}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. (EXENTO) N&#xBA; 636 de 13 de agosto de 2014, se desisti&#xF3; de la expropiaci&#xF3;n del lote N&#xBA;61, ordenada por el <a href=\"https://www.leychile.cl/Navegar?idNorma=1046887&amp;idParte=&amp;idVersion=\">Decreto MOP (Exento) N&#xBA;2730 de 21 de noviembre de 2012</a>, debido a que el lote expropiado no resulta necesario para la obra &quot;Mejoramiento Ruta Interlagos T-835, T-905, Sector Cayurruca - Trapi - Crucero&quot;. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA; 2186, de 1978.</div><br></div>", "i": 9501694, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9501695}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "636 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-636 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-08-13", "doble_articulado": false, "id_norma": "1065948", "numero_fuente": "40947", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-09-01", "vigencias": [{"desde": "2014-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text":