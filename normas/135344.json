{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,765.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165125}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese al conductor de trenes de primera clase, don Pedro Nolasco Valenzuela, empleado de los Ferrocarriles del Estado, derecho a jubilar con arreglo a la lei de 20 de agosto de 1857 i tomando por base el setenta i cinco por ciento del sueldo asignado a su empleo. </div></div>", "i": 6165126}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a doce de setiembre de mil novecientos cinco.- JERMAN RIESCO.- E. Villegas.</div><br></div>", "i": 6165127}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1765", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1765"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-09-12", "doble_articulado": false, "id_norma": "135344", "numero_fuente": "8316", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-09-27", "vigencias": [{"desde": "1905-09-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1905-09-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1905-09-27", "fin_vigencia": "", "tipo_version": "