{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO DELEGACIONES DE FACULTADES QUE INDICA EN FUNCIONARIOS QUE SE&#xD1;ALA Y DELEGANSE ESTAS EN EL JEFE DEL DEPARTAMENTO REGIONAL JURIDICO </div></div>", "i": 7231999}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n N&#xBA; Ex. 371 de fecha 19 de marzo de 1998, el suscrito dej&#xF3; sin efecto las delegaciones de facultades que se efectuaron en el Jefe de la Unidad de Vi&#xF1;a del Mar, mediante Res. Ex. 1.105 de fecha 17-11-97, Ex.</div><div class=\"p\">15.709 de 07-09-92, y Ex. 5.077 de 26-03-92, todas de esta Quinta Direcci&#xF3;n Regional Valpara&#xED;so, y deleg&#xF3; &#xE9;stas en el Jefe del Departamento Jur&#xED;dico de esta Quinta Direcci&#xF3;n Regional Valpara&#xED;so, a contar del 1&#xBA; de abril de 1998.- </div></div>", "i": 7232000}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco C&#xE1;rcamo Avenda&#xF1;o, Director Regional. </div></div>", "i": 7232001}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "371 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-371 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL DE VALPARAÍSO"], "titulo_norma": "DEJA SIN EFECTO DELEGACIONES DE FACULTADES QUE INDICA EN\nFUNCIONARIOS QUE SEÑALA Y DELEGANSE ESTAS EN EL JEFE DEL\nDEPARTAMENTO REGIONAL JURIDICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FACULTAD", "DELEGACION", "SERVICIO DE IMPUESTOS INTERNOS", "JEFE DE UNIDAD", "VI A DEL MAR", "DEROGACION", "JEFE DEL DEPARTAMENTO JURIDICO", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-03-19", "doble_articulado": false, "id_norma": "97665", "numer