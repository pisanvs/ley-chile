{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6225728}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n de la Fiscal&#xED;a del Ministerio de Obras P&#xFA;blicas F. N&#xB0; 104, de 25 de septiembre de 1986, se ha ordenado pagar la suma de $ 44.832 a la Empresa Nacional del Petr&#xF3;leo o a quien acredite derecho como valor del 100% del aval&#xFA;o fijado por la Comisi&#xF3;n de Hombres Buenos m&#xE1;s su reajuste, para el lote 18, de una superficie de 227.074 m2, Comuna de Vi&#xF1;a del Mar, para Variante Enap en Camino Internacional de Valpara&#xED;so a Caracoles. Se deja constancia que el plazo para reclamar judicialmente del aval&#xFA;o es de 30 d&#xED;as contados desde la fecha de la 2&#xAA; publicaci&#xF3;n que se har&#xE1; en un peri&#xF3;dico de la V Regi&#xF3;n.-</div><br></div>", "i": 6225729}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6225730}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "104", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-104"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-09-25", "doble_articulado": false, "id_norma": "153358", "numero_fuente": "32.610", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-10-30", "vigencias": [{"desde": "1986-10-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-10-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-10-30", "fin_vigencia": "", "tipo_v