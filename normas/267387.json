{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7360305}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.366, de 27 de noviembre de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a D&#xC1;VILA Y D&#xCD;AZ LIMITADA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en estero Quell&#xF3;n s/n, Quell&#xF3;n, para elaborar en las l&#xED;neas de proceso de Cocido, Fresco Enfriado, Congelado, Seco Salado, Ahumado, Conserva, Alga Seca y Cocido Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto las resoluciones N&#xBA; 798 de 1996 y N&#xBA; 441 de 2003, ambas de esta Subsecretar&#xED;a. </div></div>", "i": 7360306}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de noviembre de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7360307}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3366 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3366 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-11-27", "doble_articulado": false, "id_norma": "267387", "numero_fuente": "38935", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-13", "vigencias": [{"desde": "2007-12-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-12-13", "fin_vigencia": ""}, "vige