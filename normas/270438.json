{"html": [{"t": "<div><div class=\"p\">SOLICITA A LA COMISI&#xD3;N NACIONAL DE ENERG&#xCD;A INFORMAR EN LA FORMA Y PLAZO QUE SE SE&#xD1;ALAN </div></div>", "i": 8664065}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 46, del 11 de abril de 2008, que establece:</div><br><div class=\"p\">&nbsp; &nbsp;  Solicita a la Comisi&#xF3;n Nacional de Energ&#xED;a informar, en la forma y plazo que se se&#xF1;alan, la n&#xF3;mina de las empresas que cumplen con los requisitos para acceder a la devoluci&#xF3;n del remanente de cr&#xE9;dito fiscal establecido en la ley N&#xBA; 20.258, publicada en el D.O. el 29 de marzo de 2008.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en abril de 2008.</div><br></div>", "i": 8664066}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "46 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-46 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "SOLICITA A LA COMISIÓN NACIONAL DE ENERGÍA INFORMAR EN LA FORMA Y PLAZO QUE SE SEÑALAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMISION NACIONAL DE ENERGIA", "SERVICIO DE IMPUESTOS INTERNOS", "EMPRESAS GENERADORAS DE ENERGIA ELECTRICA", "PETROLEO DIESEL", "IVA", "IMPUESTO ESPECIFICO", "CREDITO FISCAL", "REMANENTE", "DEVOLUCION", "SII", "INFORMACION", "PLAZO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-04-