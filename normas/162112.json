{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6254339}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. N&#xBA; 148, de 28 de Mayo de 1985, se expropi&#xF3; el lote de terreno N&#xBA; 2, para Instalaci&#xF3;n del Servicio de aguas servidas de Frutillar Bajo, que figura a nombre de don Sergio Strauch Kaschel, rol de aval&#xFA;o 242-43, superficie 11.700 m2., comuna de Frutillar, X Regi&#xF3;n. La Comisi&#xF3;n de Peritos compuesta por los se&#xF1;ores Roald Dreyer Jark, Daniel Cisterna Espinoza y do&#xF1;a Anneliese Moebius Lutjens, fij&#xF3; con fecha 04 de Marzo de 1985, el valor provisional de la indemnizaci&#xF3;n en la cantidad de $ 409.500. La indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2. 186, de 1978.-</div><br></div>", "i": 6254340}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6254341}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "148", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-148"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-28", "doble_articulado": false, "id_norma": "162112", "numero_fuente": "32197", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-15", "vigencias": [{"desde": "1985-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia":