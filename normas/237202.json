{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6522545}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 997, de 6 de abril de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD MARQUEZ Y OCAMPO LIMITADA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en B&#xED;o B&#xED;o, sitio 10, Boca Sur Viejo, San Pedro de la Paz, VIII Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco enfriado, Fresco refrigerado, Congelado y Deshidratado los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6522546}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6522547}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "997 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-997 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-04-06", "doble_articulado": false, "id_norma": "237202", "numero_fuente": "38140", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-04-20", "vigencias": [{"desde": "2005-04-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-04-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-04-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [],