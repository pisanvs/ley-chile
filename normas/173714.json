{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6294600}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.451, de 30 de mayo del 2000, se expropi&#xF3; el lote de terreno N&#xBA;14, superficie 288 m2, rol de aval&#xFA;o 18-72, comuna de San Gregorio de &#xD1;iqu&#xE9;n, para la obra Concesion Internacional Ruta 5, Tramo: Talca-Chill&#xE1;n, Octava Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Alicia del Carmen Dur&#xE1;n M&#xE9;ndez, ascendente a la cantidad de $931.592. </div></div>", "i": 6294601}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6294602}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2451", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2451"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-30", "doble_articulado": false, "id_norma": "173714", "numero_fuente": "36728", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-01", "vigencias": [{"desde": "2000-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CAL", "fecha_ingreso": "2000-08-01", "fecha_version": "2000-08-01", "fecha_actualizacion_texto": "2000-08-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encab