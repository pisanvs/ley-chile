{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6499514}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.642, de 16 de septiembre de 2004, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de la resoluci&#xF3;n N&#xBA; 3.069, de 2003, de esta Subsecretar&#xED;a, que autoriz&#xF3; a JOSE MANUEL MARIN ASPILLAGA para efectuar una pesca de investigaci&#xF3;n de conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia de la pesca de investigaci&#xF3;n en el marco del proyecto &quot;Estudio de ecolog&#xED;a del Ping&#xFC;ino penacho amarillo y Ping&#xFC;ino macaroni&quot;, en el sentido de indicar que la pesca de investigaci&#xF3;n se extender&#xE1; hasta el 31 de diciembre de 2004, inclusive. En consecuencia, las actividades en terreno se podr&#xE1;n efectuar hasta la fecha antes indicada.</div><br></div>", "i": 6499515}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de septiembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6499516}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2642 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2642 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-09-16", "doble_articulado": false, "id_norma": "231004", "numero_fuente": "37977", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-10-04", "vigencias": [{"desde": "2004-10-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia