{"html": [{"t": "<div><div class=\"p\">TASA DE INTERES PROMEDIO QUINCENAL PARA OPERACIONES REAJUSTABLES ENTRE 90 Y 365 DIAS </div></div>", "i": 6073018}, {"t": "<div><div class=\"p\">El Banco Central de Chile en conformidad con lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de junio de 1992, fue de 5,06% anual.</div><br></div>", "i": 6073019}, {"t": "<div><div class=\"p\">Santiago, 25 de junio de 1992.- V&#xED;ctor Vial del R&#xED;o, Secretario General.</div><br></div>", "i": 6073020}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "TASA DE INTERES PROMEDIO QUINCENAL PARA OPERACIONES\nREAJUSTABLES ENTRE 90 Y 365 DIAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-06-25", "doble_articulado": false, "id_norma": "86393", "numero_fuente": "34301", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-06-26", "vigencias": [{"desde": "1992-06-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-06-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-06-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "ALV", "fecha_ingreso": "1998-01-26", "fecha_version": "1992-06-26", "fecha_actualizacion_texto": "1992-06-26", "tipo_tratado"