{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 3.250 EXENTA, DE 2011</div><br></div>", "i": 9211392}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 3.250, de 9 de noviembre de 2011, del Ministerio de Transportes y Telecomunicaciones, y en atenci&#xF3;n a la cl&#xE1;usula 2.3.2 de las Bases de &quot;Licitaci&#xF3;n de V&#xED;as de la ciudad de Iquique Servicios Urbanos de Transporte P&#xFA;blico Remunerado de Pasajeros prestado con Buses-Proceso II&quot;, se prorroga hasta el 11 de septiembre de 2012, el contrato de concesi&#xF3;n celebrado entre Transcavancha S.A. y el Ministerio de Transportes y Telecomunicaciones, que fue aprobado por <a href=\"https://www.leychile.cl/Navegar?idNorma=255879&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.054, de 2006</a>.- </div></div>", "i": 9211393}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Pedro Pablo Err&#xE1;zuriz Dom&#xED;nguez, Ministro de Transportes y Telecomunicaciones.</div></div>", "i": 9211394}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3250 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3250 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 3.250 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-11-09", "doble_articulado": false, "id_norma": "1033971", "numero_fuente": "40129", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-12-07", "vigencias": [{"desde": "2011-12-07", "hasta": "", "tipo_version": "3"