{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8332727}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;1.025, de 27 de julio de 1998, de esta Subsecretar&#xED;a autor&#xED;zase, a&nbsp;  PESQUERA ISABELLA LIMITADA para continuar desarrollando actividades pesqueras con la nave &apos;&apos;Chonos 73&apos;&apos;, en el litoral de la IV a la VII Regiones, por fuera del &#xE1;rea de reserva artesanal, respecto del recurso hidrobiol&#xF3;gico Merluza com&#xFA;n, con red de arrastre.</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA;1.409, de 1992, de esta Subsecretar&#xED;a, que autoriz&#xF3; a do&#xF1;a Ruth V&#xE1;squez Navarro para operar la nave &apos;&apos;Chonos 73&apos;&apos;.</div><br></div>", "i": 8332728}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de julio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8332729}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1025", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1025"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA ISABELLA LIMITADA", "AUTORIZACION", "RUTH VASQUEZ NAVARRO", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-07-27", "fecha_derogacion": "1998-11-06", "doble_articulado": false, "id_norma": "122483", "numero_fuente": "36128", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-07-31", "vigencias": [{"desde": "1998-11-06", "hasta": "", "tipo_version": "2", "tipo_vers