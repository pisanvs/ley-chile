{"html": [{"t": "<div><div class=\"p\">MODIFICA LA LEY NUMERO 12,649</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley </div></div>", "i": 6337774}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico. Reempl&#xE1;zase en el inciso primero de la ley N.o 12,649, las frases &quot;a la suma de $ 35.000 mensuales&quot;, por la siguiente: &quot;en la suma de $ 35.000 mensuales&quot;, y &quot;calculado a base de esta cantidad&quot; por la siguiente: &quot;calculado a base de su pensi&#xF3;n total&quot;.&quot; </div></div>", "i": 6337775}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a diecisiete de Noviembre de mil novecientos cincuenta y nueve. JORGE ALESSANDRI RODRIGUEZ. Roberto Vergara H.</div><br></div>", "i": 6337776}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13810", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13810"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA LA LEY NUMERO 12,649", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1959-11-17", "doble_articulado": false, "id_norma": "186167", "numero_fuente": "24512", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1959-12-07", "vigencias": [{"desde": "1959-12-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1959-12-07", "fin_vigencia": ""}, "vigencia