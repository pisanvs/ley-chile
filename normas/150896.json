{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION No. 1.006 EXENTA, DE 1987 </div></div>", "i": 6217696}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.006 de fecha 13 de Mayo de 1987, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se aprobaron las modificaciones introducidas al siguiente plan y programas de estudio del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto de Educaci&#xF3;n ZIPTER Limitada, de la carrera y t&#xED;tulo t&#xE9;cnico que se indica, para impartirse a contar del a&#xF1;o 1987, en la Casa Central Vi&#xF1;a del Mar y. Sede No. 1 de Santiago:</div><br><div class=\"p\">Carrera: T&#xE9;cnico Pesquero.</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico Pesquero.-</div><br></div>", "i": 6217697}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Mart&#xED;n, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6217698}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1006 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1006 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION No. 1.006 EXENTA, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-05-13", "doble_articulado": false, "id_norma": "150896", "numero_fuente": "32801", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-22", "vigencias": [{"desde": "1987-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-06-22", "f