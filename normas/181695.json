{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6322039}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA; 118, de fecha 6 de diciembre del a&#xF1;o 2000, se aprob&#xF3; la reforma integral al estatuto de la Cooperativa de Ahorro y Cr&#xE9;dito Libercoop Limitada, de sigla Libercoop Ltda., en adelante, Cooperativa de Ahorro y Cr&#xE9;dito Libercoop, de sigla Libercoop, en los t&#xE9;rminos que da testimonio la escritura p&#xFA;blica suscrita con fecha 6 de octubre del a&#xF1;o 2000, ante el Notario P&#xFA;blico de Santiago, don Fernando Opazo Larra&#xED;n.</div><br></div>", "i": 6322040}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas.</div><br></div>", "i": 6322041}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "118", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-118"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-12-06", "doble_articulado": false, "id_norma": "181695", "numero_fuente": "36887", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-02-13", "vigencias": [{"desde": "2001-02-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-02-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-02-13", "fin_vigencia": "", "tip