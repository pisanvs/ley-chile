{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><br></div>", "i": 7169432}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art. 1.o Trasp&#xE1;sanse la suma de ochocientos noventa y ocho mil ochocientos pesos ($ 898,800) del n&#xFA;mero 23 de la letra a) del &#xED;tem 05, cap&#xED;tulo 13, partida 06, y la cantidad de mil doscientos pesos ($ 1,200) del n&#xFA;mero 31 de la misma letra, &#xED;tem, cap&#xED;tulo y partida del Presupuesto vigente, del Ministerio de Hacienda para 1929, al &#xED;tem 08, cap&#xED;tulo 01, partida 03, correspondiente al Presupuesto de la Contralor&#xED;a General de la Rep&#xFA;blica.</div><br></div>", "i": 7169433}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 2.o Esta Ley comenzar&#xE1; a regir desde su publicaci&#xF3;n en el Diario Oficial&quot;.</div><br></div>", "i": 7169434}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, nueve de Julio de mil novecientos veintinueve.- Carlos Ib&#xE1;&#xF1;ez C.- Osvaldo Koch. </div></div>", "i": 7169435}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4607", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4607"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO ENTRADAS GASTOS", "A O", "1929", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-07-09", "doble_articulado": false, "id_norma": "24771", "n