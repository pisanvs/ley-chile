{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8947807}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.927, de 24 de junio de 2010, de esta Subsecretar&#xED;a, autor&#xED;zase al SINDICATO DE TRABAJADORES INDEPENDIENTES, RECOLECTORES Y COMERCIALIZADORES DE ALGAS CALETA LOS BRONCES, Provincia de Huasco, para iniciar actividades pesqueras de transformaci&#xF3;n, instalar y operar una planta ubicada en inmediaciones Poblaci&#xF3;n Jos&#xE9; Santos Ossa s/n&#xBA;, comuna de Freirina, III Regi&#xF3;n, para elaborar en l&#xED;nea de Alga Seca, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div></div>", "i": 8947808}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de junio de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 8947809}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1927 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1927 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-06-24", "doble_articulado": false, "id_norma": "1015538", "numero_fuente": "39714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-07-20", "vigencias": [{"desde": "2010-07-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-07-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-07-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci