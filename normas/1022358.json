{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9103001}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 176, de 19 de enero de 2011, de esta Subsecretar&#xED;a, ac&#xF3;gese los descargos formulados y ampl&#xED;ese por 12 meses a contar del 1&#xBA; de diciembre de 2010, el plazo otorgado por el numeral 4&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=35431&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 721 de 1996</a>, de esta Subsecretar&#xED;a de Pesca, a Pesquera Friosur S.A., hoy PESQUERA SUR AUSTRAL S.A., para reiniciar actividades pesqueras extractivas con la nave &quot;Friosur IX&quot;, respecto del recurso hidrobiol&#xF3;gico Raya volant&#xED;n, en el &#xE1;rea mar&#xED;tima comprendida entre la IX Regi&#xF3;n y el paralelo 41&#xBA;28,6&apos; L.S.</div></div>", "i": 9103002}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de enero de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div><br></div>", "i": 9103003}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "176 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-176 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-01-19", "doble_articulado": false, "id_norma": "1022358", "numero_fuente": "39868", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-01-25", "vigencias": [{"desde": "2011-01-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci