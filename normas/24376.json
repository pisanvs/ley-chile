{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,972, que concede derecho a jubilar a don Francisco Steck</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,972.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8276870}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Conc&#xE9;dese, por gracia, al ex-Intendente de Malleco, don Franciso Steck, el derecho a jubilar con una pension anual de seis mil pesos ($ 6,000).</div><br></div>", "i": 8276871}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 8 de Agosto de 1923.-ARTURO ALESSANDRI.- Domingo Amun&#xE1;tegui.</div><br></div>", "i": 8276872}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3972", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3972"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 3,972, QUE CONCEDE DERECHO A JUBILAR A DON FRANCISCO STECK", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FRANCISCO STECK", "JUBILACION", "CONCESION", "BENEFICIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1923-08-08", "doble_articulado": false, "id_norma": "24376", "numero_fuente": "13663", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1923-08-28", "vigencias": [{"desde": "1923-08-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1923-08-28", "fin_vigencia": ""}, "