{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  DEROGA RESOLUCION QUE SE&#xD1;ALA</div><br></div>", "i": 8340018}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 879, de 23 de Agosto de 1988, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, der&#xF3;gase la resoluci&#xF3;n No. 97, de 1986, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Sociedad Comercial y Pesquera Tornagaleones Limitada domiciliada en Valdivia, para desarrollar actividades pesqueras de transformaci&#xF3;n, por renuncia de su titular.</div><br></div>", "i": 8340019}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de Agosto de 1988.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8340020}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "879", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-879"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "DEROGA RESOLUCION QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-23", "doble_articulado": false, "id_norma": "130966", "numero_fuente": "33166", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-09-07", "vigencias": [{"desde": "1988-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-09-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-09-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "FMR", "fecha_ingreso": "1999