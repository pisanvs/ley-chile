{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6578542}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.025, de 18 de julio de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a HECTOR ENRIQUE ALFARO VALDIVIA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en sector Leoncito, a 128 kil&#xF3;metros al sur de Taltal, II Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Alga seca los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6578543}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de julio de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6578544}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2025 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2025 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-18", "doble_articulado": false, "id_norma": "251997", "numero_fuente": "38533", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-08-07", "vigencias": [{"desde": "2006-08-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-08-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-08-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2006-08-07", "fecha_ve