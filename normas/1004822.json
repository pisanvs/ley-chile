{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8763422}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.488, de 15 de julio de 2009, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3.- de la resoluci&#xF3;n exenta N&#xBA; 1.219 de 2009, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la UNIVERSIDAD AUSTRAL DE CHILE para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado, &quot;Monitoreo Biol&#xF3;gico de la Pesquer&#xED;a Artesanal de Anchoveta y Sardina com&#xFA;n, en la Regi&#xF3;n de Los R&#xED;os, Oto&#xF1;o 2009&quot;, en el sentido de extender el per&#xED;odo de ejecuci&#xF3;n de la presente pesca de investigaci&#xF3;n hasta el d&#xED;a 30 de septiembre de 2009, inclusive.</div></div>", "i": 8763423}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de julio de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8763424}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2488 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-2488 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-07-15", "doble_articulado": false, "id_norma": "1004822", "numero_fuente": "39429", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-08-05", "vigencias": [{"desde": "2009-08-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "20