{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9102240}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 16, de 7 de enero de 2011, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3.- de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1005407&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2702 de 2009</a>, modificada mediante resoluciones exentas N&#xBA;3752 de 2009, N&#xBA;739, N&#xBA;1662, N&#xBA;2193 y N&#xBA;3062, todas de 2010, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Monitoreo de la pesquer&#xED;a de jaibas extra&#xED;da por la flota artesanal trampera de Ancud, X Regi&#xF3;n&quot;, en el sentido de se&#xF1;alar que la pesca de investigaci&#xF3;n se extender&#xE1; hasta el 30 de abril de 2011, inclusive.</div></div>", "i": 9102241}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de enero de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9102242}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "16 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-16 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-01-07", "doble_articulado": false, "id_norma": "1022272", "numero_fuente": "39865", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-01-21", "vigencias"