{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,967, que autoriza el cambio de nombre de una calle de Valparaiso</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,967.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8276861}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Autor&#xED;zase a la Ilustre Municipalidad de Valparaiso para cambiar el nombre del Camino de Cintura, en el sector comprendido entre la Avenida playa Ancha i el Parque Alejo Barrios, por el de Avenida Gran Breta&#xF1;a.</div><br></div>", "i": 8276862}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 1.&#xB0; de Agosto de 1923.- ARTURO ALESSANDRI.- Domingo Amun&#xE1;tegui.</div><br></div>", "i": 8276863}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3967", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3967"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NÚM. 3,967, QUE AUTORIZA EL CAMBIO DE NOMBRE DE UNA CALLE DE VALPARAISO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VALPARAISO", "MUNICIPALIDAD", "CAMINOS", "DENOMINACION", "CAMBIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1923-08-01", "doble_articulado": false, "id_norma": "24372", "numero_fuente": "13643", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1923-08-03", "vigencias": [{"desde": "1923-08-03", "hasta": "", "tipo_ve