{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 1550 EXENTA, DE 1992 </div></div>", "i": 8316720}, {"t": "<div><div class=\"p\">Mediante Resoluci&#xF3;n Exenta No. 4.698, de 09 de Septiembre de 1992, el Director Regional de la Direcci&#xF3;n Regional Metropolitana Santiago Poniente, modific&#xF3; la Resoluci&#xF3;n No.</div><div class=\"p\">1.550 Ex., de 01 de Abril de 1992, sobre Delegaci&#xF3;n de Facultades, en la siguiente forma:</div><div class=\"p\">a) En la letra a) del dispositivo No. 1, interc&#xE1;lase a continuaci&#xF3;n de la expresi&#xF3;n &quot;n&#xFA;meros 6, 7, 10&quot;, el guarismo &quot;16&quot;.</div><div class=\"p\">b) En el dispositivo No. 3, interc&#xE1;lase a continuaci&#xF3;n de la expresi&#xF3;n &quot;n&#xFA;meros 6, 7, 10&quot;, el guarismo &quot;16&quot;.- </div></div>", "i": 8316721}, {"t": "<div><div class=\"p\">Angel Mena Zapata, Director Regional.</div><br></div>", "i": 8316722}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4698 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4698 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO PONIENTE"], "titulo_norma": "MODIFICA RESOLUCION No. 1550 EXENTA, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-09-09", "doble_articulado": false, "id_norma": "84877", "numero_fuente": "34392", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-10-17", "vigencias": [{"desde": "1992-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1