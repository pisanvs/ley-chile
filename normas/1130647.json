{"html": [{"t": "<div><br><div class=\"p\">C&#xC1;LCULO DE LAS COTIZACIONES PARA SALUD DE TRABAJADORES INDEPENDIENTES</div></div>", "i": 10016334}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 43 del 9 de abril de 2019.</div><div class=\"p\">&nbsp; &nbsp;  Regula el intercambio de informaci&#xF3;n entre la Superintendencia de Salud, el Servicio de Impuestos Internos y la Tesorer&#xED;a General de la Rep&#xFA;blica, referida a las cotizaciones de los trabajadores independientes del inciso primero del art&#xED;culo 89 del DL N&#xBA; 3.500, de 1980 y deroga la <a href=\"https://www.leychile.cl/Navegar?idNorma=1130304&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n Ex. SII N&#xBA; 42, de 2019</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en abril de 2019.</div><br></div>", "i": 10016335, "v": ["MODIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "43 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-43 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CÁLCULO DE LAS COTIZACIONES PARA SALUD DE TRABAJADORES INDEPENDIENTES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1575945", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-04-09", "doble_articulado": false, "id_norma": "1130647", "numero_fuente": "42332", "tipo_version": "3", "ti