{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que concede derecho a jubilar a don Jorje Brunton Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5950582}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, a don Jorje Brunton, derecho de jubilar en conformidad a los a&#xF1;os de servicio i al sueldo que disfruta actualmente como director de traccion de los Ferrocarriles del Estado. </div></div>", "i": 5950583}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 19 de Enero de 1903.- JERMAN RIESCO.- Agustin Gana Urz&#xFA;a.</div><br></div>", "i": 5950584}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1579", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1579"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "QUE CONCEDE DERECHO A JUBILAR A DON JORJE BRUNTON", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JORGE BRUNTON", "JUBILACION POR GRACIA", "DERECHO", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1903-01-19", "doble_articulado": false, "id_norma": "22761", "numero_fuente": "7487", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1903-01-20", "vigencias": [{"desde": "1903-01-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1903-01-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1903-01