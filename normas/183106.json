{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6327368}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por R.M. (Ex.) N&#xBA; 11, de 15 de marzo de 2001, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ac&#xF3;gese parcialmente el recurso de reclamaci&#xF3;n interpuesto por PESQUERA DEL NORTE S.A. en contra de las resoluciones N&#xBA; 161, N&#xBA; 162, N&#xBA; 176 y N&#xBA; 177, todas de 2001, de la Subsecretar&#xED;a de Pesca. Consid&#xE9;rese en la determinaci&#xF3;n de su l&#xED;mite m&#xE1;ximo de captura en la unidad de pesquer&#xED;a Jurel, V a IX Regiones, las siguientes capturas totales de la nave Marpro I en los meses que se indican:</div><br><div class=\"p\">Junio de 2000&nbsp; &nbsp;  :&nbsp; &nbsp;  749,620 toneladas.</div><div class=\"p\">Septiembre de 2000:&nbsp; &nbsp;  1.320,780 toneladas.</div><br></div>", "i": 6327369}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; de Gregorio Rebeco, Ministro de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6327370}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "11 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-11 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-15", "doble_articulado": false, "id_norma": "183106", "numero_fuente": "36919", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-22", "vigencias": [{"desde": "2001-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "