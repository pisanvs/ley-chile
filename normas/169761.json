{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6279012}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;789, de 29 de febrero de 2000, se expropi&#xF3; los lotes de terreno N&#xBA;s. 1 y 21-A, roles de aval&#xFA;o 12-23 y 137-20, comuna de Chonchi, X&#xAA; Regi&#xF3;n, para la obra Camino Chonchi-Teupa, y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Dolariza Alvarez Andrade y otros y Jos&#xE9; Alfonso Guaquin, ascendentes a las cantidades que se indican en dicho decreto.-</div><br></div>", "i": 6279013}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6279014}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "789", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-789"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-29", "doble_articulado": false, "id_norma": "169761", "numero_fuente": "36678", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-01", "vigencias": [{"desde": "2000-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2000-06-01", "fecha_version": "2000-06-01", "fecha_actualizacion_texto": "2000-06-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i"