{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.977 EXENTA, DE 2008 </div></div>", "i": 6701815}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.977, de fecha 2 de junio de 2008, del Ministerio de Educaci&#xF3;n, se ampl&#xED;a el per&#xED;odo de acreditaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica Salesianos Don Bosco de Santiago, por un per&#xED;odo de tres a&#xF1;os, a contar de diciembre del a&#xF1;o 2007.</div><div class=\"p\">&nbsp; &nbsp;  Se requiere del Centro de Formaci&#xF3;n T&#xE9;cnica Salesianos Don Bosco el cumplimiento de algunas acciones dentro del plazo se&#xF1;alado, lo que ser&#xE1; verificado por el Consejo Superior de Educaci&#xF3;n, como condici&#xF3;n previa para la obtenci&#xF3;n de la Plena Autonom&#xED;a.</div><br></div>", "i": 6701816}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de diciembre de 2008.- Cristi&#xE1;n Mart&#xED;nez Ahumada, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 6701817}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3977 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3977 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.977 EXENTA, DE 2008", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2008-06-02", "fecha_derogacion": "2014-01-07", "doble_articulado": false, "id_norma": "283480", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2008-12-13", "vigencias": [{"desde": "2014-01-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2008-12-13", "hasta": "2014-01-06", "tipo_ver