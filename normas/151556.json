{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6220089}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 1.299 de 29 de Julio de 1987, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a sector excluido y sector expropiado predio &quot;Las Nieves&quot; de la Comuna de Rengo, VI Regi&#xF3;n, y Derechos Aprovechamiento Aguas que corresponden a 11 parcelas N&#xB0;s. 1 a la 11 y al sitio No. 12 del Proyecto de Parcelaci&#xF3;n &quot;Las Nieves&quot; formado por predio se&#xF1;alado. Los Derechos de Agua se extraen del Canal Popeta y del Canal Talhu&#xE9;n, provenientes del R&#xED;o Claro.</div><div class=\"p\">Publicaci&#xF3;n hecha conforme Art. 13 Ley 18.377.-</div><br></div>", "i": 6220090}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6220091}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1299 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1299 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-29", "doble_articulado": false, "id_norma": "151556", "numero_fuente": "32835", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-01", "vigencias": [{"desde": "1987-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987