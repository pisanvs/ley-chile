{"html": [{"t": "<div><br><div class=\"p\">DESAFILIA DEL SISTEMA DE FACTURACI&#xD3;N ELECTR&#xD3;NICA</div></div>", "i": 8790700}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 155 de 14 de octubre de 2009, que desafilia autorizaci&#xF3;n otorgada a contribuyentes para operar como emisores electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase por desafiliados del Sistema de Facturaci&#xF3;n Electr&#xF3;nica, a los contribuyentes RUT N&#xBA; 78.886.570-8, RUT N&#xBA; 83.493.700-K, RUT N&#xBA; 76.744.690-K y RUT N&#xBA; 76.296.930-0.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de octubre de 2009.</div></div>", "i": 8790701}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "155 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-155 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SUBSECRETARÍA DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESAFILIA DEL SISTEMA DE FACTURACIÓN ELECTRÓNICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-10-14", "doble_articulado": false, "id_norma": "1007288", "numero_fuente": "39489", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-10-19", "vigencias": [{"desde": "2009-10-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-10-19", "fin_vigenci