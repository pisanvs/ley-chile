{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;43, DE 2000</div><br><br></div>", "i": 6275921}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n Ministerial N&#xBA; 43, del 24 de abril del a&#xF1;o 2000, se autoriz&#xF3; la existencia y aprob&#xF3; el estatuto de la Cooperativa de Trabajo Kibut Ltda., de nombre de fantas&#xED;a Kibut Ltda., del sector de Trinquicahu&#xED;n, Osorno, en los t&#xE9;rminos que da testimonio el acta constitutiva protocolizada al final de los registros del Notario de R&#xED;o Negro y Purranque, don Jos&#xE9; Robinson Dolmestch, bajo el N&#xBA; 31, con fecha 28 de marzo del 2000.</div><br></div>", "i": 6275922}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Se&#xF1;or Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6275923}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "43", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-43"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº43, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-24", "doble_articulado": false, "id_norma": "168874", "numero_fuente": "36666", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-18", "vigencias": [{"desde": "2000-05-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-18", "fin_vigencia": ""}, "vigenc