{"html": [{"t": "<div><div class=\"p\">APRUEBA REFORMA DE ESTATUTOS A &quot;COMPA&#xD1;IA DE SEGUROS DE VIDA SANTANDER S.A.&quot; </div></div>", "i": 6076864}, {"t": "<div><div class=\"p\">Certifico: Que por resoluci&#xF3;n No. 139 de fecha 22 de Agosto de 1991 se aprob&#xF3; la reforma de estatutos de la sociedad &quot;Compa&#xF1;&#xED;a de Seguros de Vida Santander S.A.&quot; que consta de la escritura p&#xFA;blica de fecha 08 de agosto de 1991 otorgada en la Notar&#xED;a de Santiago de don Ra&#xFA;l Iv&#xE1;n Perry Pefaur.</div><br><div class=\"p\">La reforma consiste en:</div><br><div class=\"p\">Crear el cargo de 5 directores suplentes.</div><br></div>", "i": 6076865}, {"t": "<div><div class=\"p\">Santiago, 22 de Agosto de 1991.- Rodrigo O. Costa Aranda, Secretario General.</div><br></div>", "i": 6076866}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "139", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-139"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "APRUEBA REFORMA DE ESTATUTOS A COMPAÑIA DE SEGUROS DE VIDA SANTANDER S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-08-22", "doble_articulado": false, "id_norma": "87659", "numero_fuente": "34056", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-08-30", "vigencias": [{"desde": "1991-08-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-08-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-08-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "