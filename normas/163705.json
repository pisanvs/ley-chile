{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br></div>", "i": 6259220}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 140, de fecha 12 de Junio de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la II Regi&#xF3;n, se autoriza a la Empresa de Transportes Geminis Ltda., para efectuar todo tipo de servicio de Transportes de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6259221}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Guido M. Ram&#xED;rez Maturana, SEREMI de Transportes y Telecomunicaciones II Regi&#xF3;n.</div><br></div>", "i": 6259222}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "140 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-140 EXENTA"}], "organismos": ["MINISTERIO DE TRANPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-12", "doble_articulado": false, "id_norma": "163705", "numero_fuente": "32250", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-08-17", "vigencias": [{"desde": "1985-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-08-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-08-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion