{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6271706}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 68 de 22 de Octubre de 1987 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se autoriza a la Pullman Chile Empresa de Transportes S.A., para efectuar todo tipo de servicios de Transportes de Pasajeros por calles y caminos, dentro del Territorio Nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de Locomoci&#xF3;n Colectiva de pasajeros.</div><br></div>", "i": 6271707}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rancagua, 21 de Octubre de 1987.- Rigoberto G&#xF3;mez Lav&#xED;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n.</div><br></div>", "i": 6271708}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "68 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-68 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-10-22", "doble_articulado": false, "id_norma": "167571", "numero_fuente": "32903", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-10-26", "vigencias": [{"desde": "1987-10-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-10-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-10-26",