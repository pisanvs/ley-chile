{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 677 EXENTO, DE 1998</div><br><br><br></div>", "i": 6118489}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 677 de 15 de junio de 1998, se ha aprobado al Colegio &apos;&apos;The Mayflower School&apos;&apos; de Santiago, un plan de estudio biling&#xFC;e para los alumnos de 5&#xBA; a 8&#xBA; a&#xF1;o (NB.3 a NB.6) de Ense&#xF1;anza B&#xE1;sica, que se aplicar&#xE1; a partir del a&#xF1;o escolar 1999, seg&#xFA;n la gradualidad se&#xF1;alada en el decreto supremo de Educaci&#xF3;n N&#xBA; 40 de 1996 y sus modificaciones.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los distintos subsectores del plan de estudio aprobado en el art&#xED;culo anterior, correspondientes a 5&#xBA;, 6&#xBA;, 7&#xBA; y 8&#xBA; a&#xF1;o (NB.3 a NB.6) de Ense&#xF1;anza B&#xE1;sica.</div><br></div>", "i": 6118490}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de junio de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6118491}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "677 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-677 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 677 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIO THE MAYFLOWER SCHOOL", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-06-15", "doble_articulado": false, "id_norma": "121201", "numero_fuente": "36115", "tipo_version": "3", "tipo_version_s": "Única", "fecha