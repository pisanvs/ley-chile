{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5844996}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entres 90 y 365 d&#xED;as, fue de 6,41 % anuel durante el mes de marzo de 1993.</div><div class=\"p\">&nbsp; &nbsp; Asimismo, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1 del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, corespondiente a la segunda quincena de marzo de 1993, fue de 6,41% anual.- </div></div>", "i": 5844997}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 5 de abril de 1993.- Jorge Carrasco V&#xE1;squez, Ministro de Fe (I) </div></div>", "i": 5844998}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA INTERES PROMEDIO", "TIP", "OPERACIONES CREDITO DINERO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-04-05", "doble_articulado": false, "id_norma": "1732", "numero_fuente": "34535", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-04-06", "vigencias": [{"desde": "1993-04-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-04-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-04-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacione