{"html": [{"t": "<div><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N N&#xB0; 2.977 EXENTA, DE 2020</div></div>", "i": 10192148}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 19, de 8 de enero de 2021, de esta Subsecretar&#xED;a, rectif&#xED;quese el resuelvo 1&#xB0; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1154326&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.977, de 2020</a>, de esta Subsecretar&#xED;a, que estableci&#xF3; las toneladas que podr&#xE1;n capturar durante el a&#xF1;o 2021 los titulares de licencias transables de pesca clase B, en el sentido de reemplazar la tabla correspondiente al recurso Jurel en la unidad de pesquer&#xED;a de las Regiones XV a II, ah&#xED; se&#xF1;alada por la siguiente:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Jurel XV a II Regiones</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/118121.jpg\"></div><div class=\"p\"> </div><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/118122.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10192149}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de enero de 2021.- Alicia Gallardo Lagno, Subsecretaria de Pesca y Acuicultura.</div><br></div>", "i": 10192150}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "19 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-19 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "RECTIFICA RESOLUCIÓN N° 2.977 EXENTA, DE 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "ob