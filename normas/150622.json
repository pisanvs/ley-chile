{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6216650}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 842 de fecha 29 de Mayo de 1987 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Va. Regi&#xF3;n, se autoriza al se&#xF1;or Jos&#xE9; del Carmen Maripangue Menares para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos d&#xE9; locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6216651}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de Mayo de 1987.- Hern&#xE1;n V&#xE1;squez Wacquez, Capit&#xE1;n de Navio, Secretario Regional Ministerial de Transportes y Telecomunicaciones Va. Regi&#xF3;n.</div><br></div>", "i": 6216652}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "842 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-842 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL V REGIÓN DE VALPARAÍSO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-05-29", "doble_articulado": false, "id_norma": "150622", "numero_fuente": "32788", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-05", "vigencias": [{"desde": "1987-06-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "