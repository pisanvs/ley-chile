{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 303, DE 1991</div><br><br></div>", "i": 6056083}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 303 de 14 de noviembre de 1991 se ha declarado interpretando lo que se&#xF1;ala el art&#xED;culo 1&#xB0; del decreto supremo exento de Educaci&#xF3;n No. 123 de 1984 que aprob&#xF3; planes y programas de estudio de educaci&#xF3;n media t&#xE9;cnico - profesional al Liceo Particular Hannover, de Santiago, que debe entenderse incluida como asignatura electiva la de &quot;Educaci&#xF3;n F&#xED;sico Deportiva&quot;, cuyos programas est&#xE1;n aprobados por el citado decreto de 1984.</div><br></div>", "i": 6056084}, {"t": "<div><div class=\"p\">Santiago, 22 de Noviembre de 1991.- Gast&#xF3;n Gilbert Baettig, Subsecretario de Educaci&#xF3;n, Subrogante.</div><br></div>", "i": 6056085}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "303 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-303 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 303, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-11-14", "doble_articulado": false, "id_norma": "79911", "numero_fuente": "34126", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-26", "vigencias": [{"desde": "1991-11-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-11-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-11-26", "fin_vigencia": "", "tipo_version": "3"}], "ev