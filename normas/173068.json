{"html": [{"t": "<div><div class=\"p\">EXCEPCIONA DEL REGIMEN DE RETENCION DEL 5% DEL IVA POR ANTICIPO EN LA ADQUISICION DEL PRODUCTO CARNE </div></div>", "i": 6292385}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La V Direcci&#xF3;n Regional del S.I.I., por resoluci&#xF3;n N&#xBA; Ex. 905 de 3 de julio de 2000, excepciona a contar del primero del mes siguiente al de esta publicaci&#xF3;n, a la H. C&#xE1;mara de Diputados, RUT N&#xBA; 60.202.000-2, del r&#xE9;gimen de retenci&#xF3;n del 5% de IVA, por anticipo, en la adquisici&#xF3;n del producto carne, establecido en la resoluci&#xF3;n N&#xBA; Ex. 5.087, de 28.07.99, que dispone la retenci&#xF3;n que indica, a los mataderos y otros en las ventas de carnes.-</div><br></div>", "i": 6292386}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco C&#xE1;rcamo Avenda&#xF1;o, Director Regional. </div></div>", "i": 6292387}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "905 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-905 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL DE VALPARAÍSO"], "titulo_norma": "EXCEPCIONA DEL REGIMEN DE RETENCION DEL 5% DEL IVA POR\nANTICIPO EN LA ADQUISICION DEL PRODUCTO CARNE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-07-03", "doble_articulado": false, "id_norma": "173068", "numero_fuente": "36713", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-14", "vigencias": [{"desde": "2000-07-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-14", "fin_vigencia": ""}, "vigencias