{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Eleva a categor&#xED;a de Embajada, Legaci&#xF3;n de Chile em M&#xE9;xico</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><br></div>", "i": 9042209}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- El&#xE9;vase, a partir del 1.o de Enero de 1928, a la categor&#xED;a de Embajada la Legaci&#xF3;n de Chile en M&#xE9;xico, Misi&#xF3;n que figurar&#xE1;, en consecuencia, en la forma que corresponde a esta resoluci&#xF3;n en la Ley de Presupuestos para el a&#xF1;o pr&#xF3;ximo.</div><br></div>", "i": 9042210}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4235", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4235"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES"], "titulo_norma": "ELEVA A CATEGORÍA DE EMBAJADA, LEGACIÓN DE CHILE EN MÉXICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LEGACION CHILENA", "MEXICO", "CATEGORIA DE EMBAJADA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1927-12-23", "doble_articulado": false, "id_norma": "24592", "numero_fuente": "14974", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-01-16", "vigencias": [{"desde": "1928-01-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-01-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1928-01-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-03-09", "fecha_version": "1928-01-16", "fecha_act