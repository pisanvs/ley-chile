{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ESTABLECE QUE EL LICEO DE HOMBRES DE OVALLE SE DENOMINARA &quot;ALEJANDRO ALVAREZ JOFRE&quot;</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5973525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Denom&#xED;nase &quot;Alejandro Alvarez Jofr&#xE9;&quot; al Liceo de Hombres de la ciudad de Ovalle&quot;. </div></div>", "i": 5973526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, dos de julio de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- Francisco Cereceda. </div></div>", "i": 5973527}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13961", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13961"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "ESTABLECE QUE EL LICEO DE HOMBRES DE OVALLE SE\nDENOMINARA \"ALEJANDRO ALVAREZ JOFRE\"", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMBRE", "LICEO ALEJANDRO ALVAREZ JOFRE", "OVALLE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-07-02", "doble_articulado": false, "id_norma": "27595", "numero_fuente": "24717", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-08-12", "vigencias": [{"desde": "1960-08-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1960-08-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia"