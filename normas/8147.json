{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESIGNA SUBSECRETARIO DEL TRABAJO</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 44.- Santiago, Marzo 11 de 1994.- Visto: Lo dispuesto por el art&#xED;culo 32&#xB0; N&#xB0; 9 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica,</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 5886923}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico: Des&#xED;gnase a contar de esta fecha, a don Guillermo An&#xED;bal P&#xE9;rez Vega, RUT 5.720.724-8, en el cargo de Subsecretario del Trabajo, quien por razones impostergables de buen servicio deber&#xE1; asumir de inmediato sus funciones.</div><br></div>", "i": 5886924}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n, reg&#xED;strese y publ&#xED;quese.- EDUARDO FREI RUIZ-TAGLE, Presidente de la Rep&#xFA;blica.- Jorge Arrate Mac Niven, Ministro del Trabajo y Previsi&#xF3;n Social.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud., para su conocimiento.- Saluda a Ud., Guillermo P&#xE9;rez Vega, Subsecretario del Trabajo.</div><br></div>", "i": 5886925}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "44", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-44"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL"], "titulo_norma": "DESIGNA SUBSECRETARIO DEL TRABAJO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SUBSECRETARIO", "SUBSECRETARIA TRABAJO", "MINISTERIO TRABAJO PREVISION SOCIAL", "GUILLERMO ANIBAL PEREZ VEGA", "NOMBRAMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-11", "doble_articulado": false, "id_norma": "8147", "numero_fuente": "34841", "tipo_version": "3", "tipo_vers