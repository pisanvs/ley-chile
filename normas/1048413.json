{"html": [{"t": "<div><br><div class=\"p\">DECLARA MONUMENTO HISTORICO QUE INDICA</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 1.559.- Santiago, 28 de Junio de 1971.</div><div class=\"p\">&nbsp; &nbsp;  Vistos estos antecedentes, el oficio N&#xB0; 57, de 22 de Junio de 1971, del Consejo de Monumentos Nacionales y lo dispuesto en el Art. 6&#xB0; de la ley 17.288, de 27 de Enero de 1970.</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div></div>", "i": 9329687}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Decl&#xE1;rase Monumento Hist&#xF3;rico el edificio de la Aduana de Iquique, ubicado en el Puerto de Iquique, provincia de Tarapac&#xE1;.</div></div>", "i": 9329688}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n y comun&#xED;quese, reg&#xED;strese en el Departamento de Bienes Nacionales y publ&#xED;quese.- S. ALLENDE G.- Mario Astorga Guti&#xE9;rrez, Ministro de Educaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Carlos Valdeavellano Sol&#xED;s, Subsecretario de Educaci&#xF3;n subrogante.</div></div>", "i": 9329689}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1559", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1559"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "DECLARA MONUMENTO HISTORICO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1971-06-28", "doble_articulado": false, "id_norma": "1048413", "numero_fuente": "28006", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1971-07-24", "vigencias": [{"desde": "1971-07-24", "hasta": "", "tipo_version": "3", "