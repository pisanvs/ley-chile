{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 4.661 EXENTA, DE 2001 </div><br></div>", "i": 6356741}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 4.661 de 10 de abril del a&#xF1;o 2001, se ha aprobado al Colegio del Verbo Divino de Las Condes, de Santiago, el siguiente plan de estudio para 3&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban los siguientes programas de estudio para los Subsectores que a continuaci&#xF3;n se se&#xF1;alan, excepto en los Subsectores de Artes Visuales o Artes Musicales, cuyos programas ser&#xE1;n los oficiales aprobados por el Ministerio de Educaci&#xF3;n.</div><br></div>", "i": 6356742}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de abril de 2001.- Juan Ruz Ruz, Jefe Divisi&#xF3;n Educaci&#xF3;n General.</div><br></div>", "i": 6356743}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4661 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4661 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 4.661 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-10", "doble_articulado": false, "id_norma": "191456", "numero_fuente": "37109", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-13", "vigencias": [{"desde": "2001-11-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-11-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic