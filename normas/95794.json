{"html": [{"t": "<div><div class=\"p\">PRORROGA AUTORIZACION QUE INDICA </div></div>", "i": 8326697}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 716, de 27 de Junio de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por un a&#xF1;o, a contar del 11 de junio de 1989, el plazo otorgado a Pesquera Colomba S.A., R.U.T. No. 96.530.830-K, domiciliada en Santiago, para empezar a operar las dos embarcaciones y la planta autorizadas por la resoluci&#xF3;n No. 547, de 1988 de esta Subsecretar&#xED;a en raz&#xF3;n de haberse acreditado la ocurrencia de fuerza mayor.</div><br></div>", "i": 8326698}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 27 de Junio de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8326699}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "716", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-716"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-06-27", "doble_articulado": false, "id_norma": "95794", "numero_fuente": "33428", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-07-21", "vigencias": [{"desde": "1989-07-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-07-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-07-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACI