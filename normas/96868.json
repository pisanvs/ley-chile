{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8328010}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 1.119, de 03 de Septiembre de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por un a&#xF1;o a contar del 19.12.90, el plazo otorgado a PESQUERA AURO S.A. No. RUT No.</div><div class=\"p\">95.268.000-5, domiciliada en la ciudad de Iquique, para empezar a operar las dos naves autorizadas por la Resoluci&#xF3;n No. 1.768, de 1989, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor. </div></div>", "i": 8328011}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 03 de Septiembre de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8328012}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1119", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1119"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-09-03", "doble_articulado": false, "id_norma": "96868", "numero_fuente": "34098", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-10-23", "vigencias": [{"desde": "1991-10-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-10-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-10-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "i