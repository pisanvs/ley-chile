{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292453}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 435 de 4 de Mayo de 1994 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2&#xB0; de la Resoluci&#xF3;n N&#xB0; 185, de 1994, de esta Subsecretar&#xED;a, que autoriz&#xF3; a AQUASUR FISHERIES SOCIEDAD PESQUERA LTDA., R.U.T. N&#xB0; 79.728.530-7, para ampliar actividades pesqueras de procesamiento, en el sentido de incorporar en su texto el siguiente p&#xE1;rrafo 3&#xB0;:</div><div class=\"p\">&nbsp; &nbsp; &quot;Los recursos Salm&#xF3;n del Atl&#xE1;ntico, Salm&#xF3;n del Pac&#xED;fico y Trucha arco iris, deber&#xE1;n provenir de centros de cultivo autorizados&quot;.</div><br></div>", "i": 8292454}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 4 de Mayo de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292455}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "435", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-435"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "AUTORIZACION", "AMPLIACION", "PESCA", "AQUASUR FISHERIES SOCIEDAD PESQUERA LTDA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-05-04", "doble_articulado": false, "id_norma": "34777", "numero_fuente": "34864", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-05-13", "vigencias": [{"desde": "1994-05-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenc