{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6277061}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;911 , de 18 de mayo de 2000, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA;1.125 de 1990, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a MANUEL ENRIQUE PEDREIRA, para instalar y operar un centro de cultivo en el sector 1 ubicado al sur del Islote Queten, en Isla Cheniao, comuna de Quemchi, provincia de Chilo&#xE9;, X Regi&#xF3;n, por haberse denegado la concesi&#xF3;n de acuicultura respecto de dicho sector.</div><br></div>", "i": 6277062}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de mayo de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo. Subsecretario de Pesca.</div><br></div>", "i": 6277063}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "911", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-911"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-18", "doble_articulado": false, "id_norma": "169223", "numero_fuente": "36671", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-24", "vigencias": [{"desde": "2000-05-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresa