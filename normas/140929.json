{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 581, DE 1988 </div></div>", "i": 7252053}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 581 de fecha 21 de marzo de 1988, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se aprob&#xF3; el siguiente plan y programas de estudio al Centro de &apos;Formaci&#xF3;n T&#xE9;cnica Instituto ALFA de Constituci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico que se indica, para impartirse a contar del a&#xF1;o 1988.</div><div class=\"p\">&nbsp; &nbsp;  Carrera: Administraci&#xF3;n de Empresas.</div><div class=\"p\">&nbsp; &nbsp;  T&#xED;tulo: T&#xE9;cnico en Administraci&#xF3;n de Empresas.</div><div class=\"p\">&nbsp; &nbsp;  Para optar al t&#xED;tulo t&#xE9;cnico, los alumnos deber&#xE1;n aprobar todas las asignaturas del plan de estudio y cumplir con las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n aprobadas por resoluci&#xF3;n exenta de Educaci&#xF3;n No. 1.578 de 1985, para el centro mencionado. </div></div>", "i": 7252054}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7252055}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "581 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-581 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N°  581, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1988-03-21", "fecha_derogacion": "2021-01-01", "doble_articulado": false, "id_norma": "140929", "numero_fuente": "33066", "tipo_ver