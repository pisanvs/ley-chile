{"html": [{"t": "<div><br><div class=\"p\">GUIAS.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 14 de 1825.</div><br><div class=\"p\">&nbsp; &nbsp;  He acordado y decreto lo siguiente:</div></div>", "i": 10111130}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1.&#xBA; Para el jiro de las mercader&#xED;as de que habla el art. 28 de la Ampliacion al Reglamento de libre comercio de 1813 las Aduanas de los puertos no dar&#xE1;n, ni las del interior recibir&#xE1;n guias, en que no se especifique el n&#xFA;mero, tiro, peso, medida y precios de las mercader&#xED;as, a efecto de esclarecer el mayor, o menor valor, para proceder en conformidad del art. 27 de la misma ampliacion. T&#xF3;mese razon, trascr&#xED;base e impr&#xED;mase.</div></div>", "i": 10111131}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Correa de Saa.</div><br><br></div>", "i": 10111132}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "GUIAS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-07-14", "doble_articulado": false, "id_norma": "1143272", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "", "vigencias": [{"desde": "1825-07-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-07-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-07-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion