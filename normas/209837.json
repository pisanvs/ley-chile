{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6422363}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 859, de 17 de abril de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; PESQUERA SAN JOSE S.A. para realizar actividades extractivas en aguas internacionales con la nave &quot;Don Nordlund&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2548-Valpara&#xED;so</div><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CB-3664</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  40,22 m</div><div class=\"p\">T.R.G. (Internacional)&nbsp; &nbsp; &nbsp;  464,70</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 579,88 m3</div><div class=\"p\">Potencia motor principal&nbsp; &nbsp;  1.500,00 Hp</div><div class=\"p\">Potencia motor auxiliar&nbsp; &nbsp; &nbsp; 344,00 Hp</div><br></div>", "i": 6422364}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de abril de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6422365}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "859", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-859"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-04-17", "doble_articulado": false, "id_norma": "209837", "numero_fuente": "37548", "tipo_version": "3", "tipo_version_s": "Únic