{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,484.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6163517}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a la viuda e hijas solteras del juez letrado de Osorno don Abelardo Contreras, una pension de mil doscientos pesos ($ 1,200) anuales, de que gozar&#xE1;n en conformidad a la lei de montep&#xED;o militar.</div><br></div>", "i": 6163518}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintinueve de noviembre de mil novecientos uno.- JERMAN RIESCO.- Rafael Balmaceda.</div><br></div>", "i": 6163519}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1484", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1484"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-11-29", "doble_articulado": false, "id_norma": "134813", "numero_fuente": "7086", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-12-02", "vigencias": [{"desde": "1901-12-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1901-12-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1901-12-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresa