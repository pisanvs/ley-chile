{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 2.125 EXENTA, DE 2007 </div></div>", "i": 7359467}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.125, de 05/11/2007, se autoriz&#xF3;, de conformidad a lo dispuesto en el N&#xBA; 5 de la resoluci&#xF3;n N&#xBA; 65, de 2000, del Ministerio de Transportes y Telecomunicaciones, al taller que a continuaci&#xF3;n se individualiza para adecuar veh&#xED;culos al uso de Gas Comprimido Natural (GNC) como combustible:</div><br><div class=\"p\">Empresa&nbsp; &nbsp; &nbsp;  Nombre del</div><div class=\"p\">Habilitada&nbsp;  Taller&nbsp; &nbsp;  Direcci&#xF3;n del Taller&nbsp; &nbsp;  Ciudad</div><div class=\"p\">Futurgas</div><div class=\"p\">Ltda.&nbsp; &nbsp; &nbsp;  RTI Ltda.&nbsp;  Santa Sof&#xED;a N&#xBA; 92&nbsp; &nbsp;  Concepci&#xF3;n</div><br><div class=\"p\">&nbsp; &nbsp;  La autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.</div><br></div>", "i": 7359468}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Danilo N&#xFA;&#xF1;ez Izquierdo, Subsecretario de Transportes.</div><br></div>", "i": 7359469}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2125 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2125 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 2.125 EXENTA, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-11-05", "doble_articulado": false, "id_norma": "266881", "numero_fuente": "38921", "tipo_version": "3", "tipo_v