{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA NOMBRE DE LA AVENIDA CENTRAL POR &quot;AVENIDA PADRE DOMINGO DEL ALAMO&quot; </div></div>", "i": 5854178}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Con fecha 1&#xB0; de diciembre de 1994, la I. Municipalidad de Renca dict&#xF3; el Decreto Alcaldicio N&#xB0; 2542, mediante el cual se cambia el nombre de la Avenida Central, por &quot;AVENIDA PADRE DOMINGO DEL ALAMO&quot;. Dicho cambio comenzar&#xE1; a regir, a contar de la fecha del presente Decreto y copia del mismo se colocar&#xE1; en sitios visibles de la Municipalidad, para conocimiento de los vecinos.-</div><br></div>", "i": 5854179}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Manuel Caballero Oyanedel, Alcalde.</div><br></div>", "i": 5854180}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2542", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2542"}], "organismos": ["MUNICIPALIDAD DE RENCA"], "titulo_norma": "CAMBIA NOMBRE DE LA AVENIDA CENTRAL POR \"AVENIDA\nPADRE DOMINGO DEL ALAMO\"", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDAD RENCA", "CAMBIO", "NOMBRE", "CALLE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-12-01", "doble_articulado": false, "id_norma": "2820", "numero_fuente": "35035", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-12-07", "vigencias": [{"desde": "1994-12-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-12-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-12-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1994-12-07", "fecha_actuali