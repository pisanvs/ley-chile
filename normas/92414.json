{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8321773}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.953 de 12 de Diciembre de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n se modifica el numeral 3&#xB0; de la resoluci&#xF3;n No. 978 de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Pesquera Surco Ltda. R.U.T. No. 79.863.880-7, domiciliada en la ciudad de Vi&#xF1;a del Mar, para iniciar actividades pesqueras, en el sentido de se&#xF1;alar que el peticionario podr&#xE1; extraer el recurso albacora o pez espada (xiphias gladius) en el litoral de la I a la X Regi&#xF3;n, no obstante lo indicado en dicha resoluci&#xF3;n respecto de las &#xE1;reas de pesca. </div></div>", "i": 8321774}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 12 de Diciembre de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8321775}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1953", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1953"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-12-12", "doble_articulado": false, "id_norma": "92414", "numero_fuente": "33557", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-12-29", "vigencias": [{"desde": "1989-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-12-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"ini