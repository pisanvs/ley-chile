{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7334758}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.232, de 23 de noviembre de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a COMPA&#xD1;IA PESQUERA CAMANCHACA S.A., para ampliar las actividades pesqueras de transformaci&#xF3;n, autorizadas por la resoluci&#xF3;n citada en Visto, en orden a incorporar a la planta ubicada en Rauco Rural s/n, Chilo&#xE9;, X Regi&#xF3;n, en las l&#xED;neas de proceso de Cocido, Fresco-enfriado, Fresco-refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 7334759}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de noviembre de 2006.- Mar&#xED;a Angela Barbieri Bellolio, Subsecretaria de Pesca (S). </div></div>", "i": 7334760}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3232 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3232 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMPAÑIA PESQUERA CAMANCHACA S.A.", "ACTIVIDADES PESQUERAS", "RECURSOS HIDROBIOLOGICOS", "DECIMA REGION", "AUTORIZA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-11-23", "doble_articulado": false, "id_norma": "256485", "numero_fuente": "38640", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-12-16", "vigencias": [{"desde": "2006-12-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-12-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"in