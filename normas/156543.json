{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6235911}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta N&#xB0; 161 de 31 de enero de 1986, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos de Aprovechamiento de Aguas proporcionales que corresponden a las parcelas N&#xB0;s. 14 a la 24, 28 a la 29, 34, 38 a la 44, 49 a la 50 y 52 a la 55, sitios N&#xB0; 1 al 47, 50 al 52, 54 y 56 y Reserva CORA s/n. del Proyecto de Parcelaci&#xF3;n &quot;Tierras Libres&quot;, formado por predio &quot;Munilque&quot; ubicado en la comuna de Mulch&#xE9;n, VIII Regi&#xF3;n. Los Derechos de Agua Se extraen del canal B&#xED;o B&#xED;o Negrete y Derrames conducidos por estero Mamuleo. Publicaci&#xF3;n hecha conforme Art. 13 Ley N&#xB0; 18.377. </div></div>", "i": 6235912}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6235913}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "161 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-161 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-01-31", "doble_articulado": false, "id_norma": "156543", "numero_fuente": "32411", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-03-01", "vigencias": [{"desde": "1986-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-03-