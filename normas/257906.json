{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6599361}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 134 de 16 de enero de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA FRIOSUR S.A., para ampliar las actividades pesqueras de transformaci&#xF3;n autorizadas por la resoluci&#xF3;n citada en Visto, en orden a incorporar a la planta ubicada en Jos&#xE9; Mar&#xED;a Caro N&#xBA; 300, Puerto Chacabuco, Ays&#xE9;n, XI Regi&#xF3;n, en las l&#xED;neas de proceso de cocido, fresco-enfriado, fresco-refrigerado y congelado, el recurso hidrobiol&#xF3;gico indicado en la resoluci&#xF3;n extractada. </div></div>", "i": 6599362}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de enero de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6599363}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "134 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-134 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-01-16", "doble_articulado": false, "id_norma": "257906", "numero_fuente": "38674", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-01-27", "vigencias": [{"desde": "2007-01-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-01-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-01-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "