{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE EXPROPIACION</div><br><br></div>", "i": 6063598}, {"t": "<div><div class=\"p\">Por Decreto Secc; 2a. No. 381, de 31 de Mayo de 1990 Alcalde de la I. Municipalidad de Santiago dispone expropiaci&#xF3;n total conforme DS No. 458 Vivienda y Urbanismo Ley No.</div><div class=\"p\">18.695 y Decreto Ley No. 2.186 de inmueble Santo Domingo 3620, Rol 282-001 aparentemente dominio Ester Caro Avila. Superficie aproximada 1184,50 m2. Deslindes Norte 23 mts. calle Santo Domingo; Sur, 23 mts. Quinta Normal; Oriente, 51,50 mts. resto predio; Poniente, 51,50 mts. resto predio. Indemnizaci&#xF3;n provisional $ 7.340.000.- Pagadera contado.- </div></div>", "i": 6063599}, {"t": "<div><div class=\"p\">Jaime Ravinet de la Fuente, Alcalde de Santiago. </div></div>", "i": 6063600}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "381", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-381"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "EXTRACTO DE EXPROPIACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-05-31", "doble_articulado": false, "id_norma": "82884", "numero_fuente": "33695", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-06-15", "vigencias": [{"desde": "1990-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1998-01-06", "fecha_version": "1990-06-15", "fecha