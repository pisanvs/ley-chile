{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5845323}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile, sobre la base de los antecedentes proporcionados por el Fondo Monetario Internacional y CORFO de Nueva York certifica, a requerimiento de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante, para los efectos de lo dispuesto en el Art&#xED;culo N&#xB0; 116 del Decreto Supremo de la Subsecretar&#xED;a de Marina N&#xB0; 427, de 25 de Junio de 1979, que la variaci&#xF3;n experimentada por el Indice de Precios al Consumidor de los Estados Unidos de Am&#xE9;rica, entre el 1&#xB0; de diciembre de 1994 y el 30 de noviembre de 1995, fue de 2,6%.-</div><br></div>", "i": 5845324}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, diciembre 19 de 1995.- V&#xED;ctor Vial del R&#xED;o, Ministro de Fe, Banco Central de Chile. </div></div>", "i": 5845325}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INDICE PRECIOS CONSUMIDOR", "ESTADOS UNIDOS AMERICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-12-19", "doble_articulado": false, "id_norma": "1850", "numero_fuente": "34345", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-12-19", "vigencias": [{"desde": "1995-12-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-12-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-12-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_