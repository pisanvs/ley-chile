{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6277524}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 868 de 23 de Octubre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Carlos Reyes Irigoyen, para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea N&#xB0; 45 &quot;Corvi - Centro&quot;, de Valdivia, cuyo trazado fue autorizado por resoluci&#xF3;n N&#xB0; 021 de 14 de enero de 1985 y modificado por resoluciones N&#xB0;s. 337 de 19 de agosto de 1985 y 643 de 03 de agosto de 1987, todas de esta Secretar&#xED;a Regional.</div><br></div>", "i": 6277525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6277526}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "868 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-868 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-10-23", "doble_articulado": false, "id_norma": "169376", "numero_fuente": "32925", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-20", "vigencias": [{"desde": "1987-11-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig