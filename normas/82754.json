{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6063163}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta No. 340 de 07.06.90 del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes se autoriza en forma complementaria a la Empresa de origen argentino Transportes Automotores de Cuyo Ltda.</div><div class=\"p\">(T.A.C.) para efectuar servicio internacional de transportes terrestre de pasajeros entre Vi&#xF1;a del Mar - Santiago (Chile) y Buenos Aires (Argentina), utilizando el Paso Fronterizo T&#xFA;nel Cristo Redentor (alternativa Puyehue), realizando dos frecuencias semanales de ida y vuelta.</div><br></div>", "i": 6063164}, {"t": "<div><div class=\"p\">- Sergio Gonz&#xE1;lez Tagle, Subsecretario de Transportes. </div></div>", "i": 6063165}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "340", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-340"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-06-07", "doble_articulado": false, "id_norma": "82754", "numero_fuente": "33717", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-07-12", "vigencias": [{"desde": "1990-07-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-07-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-07-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1998-01-05", "fecha_ver