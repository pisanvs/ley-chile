{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;453 EXENTO, DE 1999</div><br><br></div>", "i": 6245336}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA;453 de 29 de diciembre de 1999, se ha aprobado al Colegio Lirima de Iquique, un plan de estudio para 6&#xBA; a&#xF1;o (NB.4) de Ense&#xF1;anza B&#xE1;sica, el que se aplicar&#xE1; a contar del a&#xF1;o escolar 2000.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en el presente decreto. </div></div>", "i": 6245337}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de febrero de 2000.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6245338}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "453 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-453 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº453 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-29", "doble_articulado": false, "id_norma": "159499", "numero_fuente": "36604", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-03", "vigencias": [{"desde": "2000-03-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2000-03-03", "fecha_version": "2000-03-03", "fecha_actualiz