{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8758913}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.517, de 23 de julio de 2009, de esta Subsecretar&#xED;a, rectif&#xED;quese el numeral 1.- de la resoluci&#xF3;n exenta N&#xBA;2.139, de 2009, de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a PESQUERA EL GOLFO S.A., para operar por sustituci&#xF3;n una nave en construcci&#xF3;n, en el sentido de se&#xF1;alar que su capacidad de bodega de conformidad con lo informado por la Divisi&#xF3;n de Administraci&#xF3;n Pesquera de esta Subsecretar&#xED;a mediante Memor&#xE1;ndum T&#xE9;cnicos citados en Visto de la resoluci&#xF3;n extractada, es la siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  Capacidad de bodega: 400,30 m3</div><br></div>", "i": 8758914}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de julio de 2009.- Mar&#xED;a &#xC1;ngela Barbieri Bellolio, Subsecretaria de Pesca (S).</div></div>", "i": 8758915}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2517 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-2517 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2009-07-23", "fecha_derogacion": "2012-12-31", "doble_articulado": false, "id_norma": "1004608", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2009-07-30", "vigencias": [{"desde": "2012-12-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2009-07-30", "hasta": "2012-12-30", "tipo_vers