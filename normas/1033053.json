{"html": [{"t": "<div><br><div class=\"p\">ACLARA PROCEDIMIENTO DE C&#xC1;LCULO DEL CR&#xC9;DITO FISCAL PARA EFECTOS QUE SE&#xD1;ALA</div></div>", "i": 9206626}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de circular del Servicio de Impuestos Internos N&#xBA; 50 del 18 de noviembre de 2011, que establece:</div><div class=\"p\">&nbsp; &nbsp;  Aclara procedimiento de c&#xE1;lculo del cr&#xE9;dito fiscal para efectos de solicitar recuperaci&#xF3;n de IVA exportadores en virtud del <a href=\"https://www.leychile.cl/Navegar?idNorma=6369&amp;idParte=8675401&amp;idVersion=\">Art. 36&#xBA;</a>, en concordancia con el DS de Econom&#xED;a N&#xBA; 348, en el caso de las empresas a&#xE9;reas y navieras.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta circular est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de noviembre de 2011.</div></div>", "i": 9206627}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "50", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-50"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ACLARA PROCEDIMIENTO DE CÁLCULO DEL CRÉDITO FISCAL PARA EFECTOS QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO. NORMA SIN PROMULGACIÓN."], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-11-18", "doble_articulado": false, "id_norma": "1033053", "numero_fuente": "40118", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-11-24", "vigencias": [{"desde": "2011-11-24", "hasta": "", "tipo_version": "3", "tipo_ve