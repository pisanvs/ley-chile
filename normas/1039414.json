{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 3.681 EXENTA, DE 2012</div></div>", "i": 9252419}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 3.681, de 17 de abril de 2012, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Universidad Pedro de Valdivia&quot; (ex Universidad Mariano Ega&#xF1;a), RUT 71.541.900-9 contenida en la resoluci&#xF3;n exenta N&#xBA; 2.837 de 3 de octubre de 2006, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del art. 21 de la ley 19.518.- </div></div>", "i": 9252420}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (PT).</div></div>", "i": 9252421}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3681 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-3681 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 3.681 EXENTA, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-04-17", "doble_articulado": false, "id_norma": "1039414", "numero_fuente": "40247", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-04-26", "vigencias": [{"desde": "2012-04-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-04-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-04-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes":