{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DECRETO N&#xB0; 57, DE 1993, QUE MODIFICA ORDENANZA LOCAL</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 537/95 exento.- Licant&#xE9;n, Agosto 29 de 1995.</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 8959615}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Primero: modif&#xED;quese y complem&#xE9;ntese la Ordenanza Municipal de fecha 22 de Enero de 1993, en los siguientes t&#xE9;rminos.</div><div class=\"p\"> a)&nbsp; T&#xED;tulo IV Derechos Municipales sobre Transporte, Tr&#xE1;nsito y Veh&#xED;culos.</div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo 6, se complementa como sigue:</div><div class=\"p\">&nbsp; &nbsp;  4)&nbsp; Derechos para paradero Taxi colectivos,</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp;  mensuales&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; $55.000.-</div><br></div>", "i": 8959616}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Segundo: esta modificaci&#xF3;n a la Ordenanza Local, regir&#xE1; a contar del 1 de Junio de 1995.</div><br><br></div>", "i": 8959617}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, comun&#xED;quese, publ&#xED;quese y arch&#xED;vese.-</div><div class=\"p\">H&#xE9;ctor Reyes Reyes, Alcalde.- Jos&#xE9; Mu&#xF1;oz Medina, Secretario Municipal.</div><br></div>", "i": 8959618}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "537 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-537 EXENTO"}], "organismos": ["MUNICIPALIDAD DE LICANTÉN"], "titulo_norma": "EXTRACTO DECRETO N° 57, DE 1993, QUE MODIFICA;ORDENANZA LOCAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "ORDENANZA MUNICIPAL", "DERECHOS", "MUNICIPALES", "TRANSPORTES", "TRANSITO", "VEHICULOS", "MOTORIZADOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratad