{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6155599}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 2.887 de fecha 31 de Octubre de 1980, ratificada por Resoluci&#xF3;n Exenta No. 830 de 13 de Mayo de 1988, conforme Art. 5&#xB0; transitorio C&#xF3;digo Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a las parcelas N&#xB0;s. 1 a la 21; sitios 1 al 23 y Cancha del Proyecto de Parcelaci&#xF3;n &quot;Aparici&#xF3;n Sur&quot; de la comuna de Paine, Regi&#xF3;n Metropolitana, formado por predio &quot;Hijuela Sur del Fundo La Aparici&#xF3;n Sur&quot;. Los derechos de aguas se extraen del canal Huidobro del R&#xED;o Maipo, por los ramales Huelqu&#xE9;n y Cardonal. Publicaci&#xF3;n hecha conforme Art. 13 Ley No.</div><div class=\"p\">18.377.</div><br></div>", "i": 6155600}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Ejecutivo.</div><br></div>", "i": 6155601}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2887", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2887"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1980-10-31", "doble_articulado": false, "id_norma": "132206", "numero_fuente": "33085", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-06-01", "vigencias": [{"desde": "1988-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-06-01", "fin_vigencia":