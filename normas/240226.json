{"html": [{"t": "<div><div class=\"p\">RECTIFICA EL DECRETO NUMERO 3,016, DE 1956</div><br><div class=\"p\">&nbsp; &nbsp;  Rep&#xFA;blica de Chile.- Ministerio de Justicia.- Santiago, 24 de Julio de 1956.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 3,532.- Vistos estos antecedentes, </div><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 6533425}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rectif&#xED;case el decreto N.o 3,016, de 21 de Junio de 1956, en el sentido de que se substituye la palabra &quot;corporaci&#xF3;n&quot; por &quot;fundaci&#xF3;n&quot;, debiendo, en consecuencia, entenderse que se aprob&#xF3; por dicho decreto la reforma de los estatutos de la fundaci&#xF3;n &quot;Ropero del Pueblo Graciela Letelier de Ib&#xE1;&#xF1;ez&quot;.</div><br></div>", "i": 6533426}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- Benjam&#xED;n Videla V.- Mariano Fontecilla.</div><div class=\"p\">&nbsp; &nbsp;  Lo digo a U. para su conocimiento.- Saluda a U.- Ignacio Garc&#xE9;s, Subsecretario.</div><br></div>", "i": 6533427}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3532", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3532"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "RECTIFICA EL DECRETO NUMERO 3,016, DE 1956", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1956-06-24", "doble_articulado": false, "id_norma": "240226", "numero_fuente": "23519", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1956-08-08", "vigencias": [{"desde": "1956-08-08", "hasta": "", "tipo_version": "3