{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DEROGA RESOLUCION (EXENTA) N&#xB0; 1.186, DE 1991 N&#xFA;m. 71 exenta.- Santiago, 21 de Enero de 1992.- Vistos: estos antecedentes y teniendo presente lo dispuesto en el D.L. N&#xB0; 3274 de 1980; y, en virtud de la facultad que se me confiere mediante D.S. N&#xB0; 386, de 1981, modificado y complementado por D.S. N&#xB0; 596, de 1982, ambos del Ministerio de Bienes Nacionales, Resuelvo:</div><br></div>", "i": 8667423}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Der&#xF3;gase la Resoluci&#xF3;n (Exenta) N&#xB0; 1.186 del 24 de diciembre de 1991, de la Subsecretar&#xED;a de Bienes Nacionales, publicada en el &quot;Diario Oficial&quot; N&#xB0; 34.160, de fecha 7 de Enero de 1992.</div><br></div>", "i": 8667424}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, notif&#xED;quese, arch&#xED;vese y publ&#xED;quese.- Pia Figueroa E., Subsecretaria de Bienes Nacionales.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Jos&#xE9; Luis Acevedo Daza, Jefe Divisi&#xF3;n Administrativa.</div><br></div>", "i": 8667425}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "71 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-71 EXENTA"}], "organismos": ["MINISTERIO DE BIENES NACIONALES"], "titulo_norma": "DEROGA RESOLUCION (EXENTA) N° 1.186, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SECRETARIA REGIONAL MINISTERIAL BIENES NACIONALES", "REGION METROPOLITANA", "SEREMI BIENES NACIONALES", "CONTRATO", "ARRENDAMIENTO", "PLAZO MAXIMO", "FACULTAD", "DELEGA", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-01-21", "doble_articulado": false, "id_norma