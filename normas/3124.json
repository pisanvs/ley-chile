{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ADELANTA REAVALUO DE BIENES RAICES QUE SE&#xD1;ALA N&#xFA;m. 471 exento.- Los Muermos, 12 de Mayo de 1995.- Vistos y teniendo presente, la Ley 19.380, el art&#xED;culo 2&#xB0;; el acuerdo del Concejo Municipal, de fecha 11 de Mayo de 1995 acta N&#xB0; 110, y las facultades que me confiere la Ley Org&#xE1;nica Constitucional de Municipalidades N&#xB0; 18.695.</div><div class=\"p\">&nbsp; &nbsp; D e c r e t o </div></div>", "i": 5855365}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Adel&#xE1;ntese, el Reaval&#xFA;o de los Bienes Ra&#xED;ces No Agr&#xED;colas practicados por el Servicio de Impuestos Internos conforme lo dispuesto en el art&#xED;culo 3&#xB0; de la Ley N&#xB0; 19.000, a contar del Segundo Semestre de 1995. </div></div>", "i": 5855366}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, comun&#xED;quese, publ&#xED;quese y arch&#xED;vese.- Jos&#xE9; Alberto D&#xED;az Jara, Alcalde.- Luis Hto. Gonz&#xE1;lez Garc&#xED;a, Secretario.</div><br></div>", "i": 5855367}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "471", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-471"}], "organismos": ["MUNICIPALIDAD DE LOS MUERMOS"], "titulo_norma": "ADELANTA REAVALUO DE BIENES RAICES QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REAVALUO", "BIEN INMUEBLE", "CONTRIBUCIONES", "VIGENCIA", "BIEN INMUEBLE NO AGRICOLA", "CONTRIBUCIONES", "IMPUESTO TERRITORIAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-12", "doble_articulado": false, "id_norma": "3124", "numero_fuente": "35170", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-05-18", "vigencias": [{"desde": "1995-05-18",