{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 643, DE 1985</div><br><br></div>", "i": 8349659}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 992, de 23 de Diciembre de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n No. 643, de 1985, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a la Empresa Pesquera Brava Mar y Compa&#xF1;&#xED;a Limitada, domiciliada en Vi&#xF1;a del Mar, para operar una embarcaci&#xF3;n denominada &quot;Denise&quot;, en el siguiente sentido: a) en el numeral 4&#xB0; de dicha Resoluci&#xF3;n, ampl&#xED;ase la zona de pesca, adem&#xE1;s al litoral de la III Regi&#xF3;n; b) en el numeral 5&#xB0;, la peticionaria podr&#xE1; extraer adem&#xE1;s de los recursos all&#xED; individualizados el siguiente: Langostino colorado.</div><br></div>", "i": 8349660}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de Diciembre de 1986.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8349661}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "992", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-992"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 643, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-12-23", "doble_articulado": false, "id_norma": "142988", "numero_fuente": "32662", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1987-01-03", "vigencias": [{"desde": "2001-05-14", "hasta": "", "tipo_version": "2", "tipo_ve