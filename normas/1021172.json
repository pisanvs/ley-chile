{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9076915}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA;2924, de 19 de noviembre de 2010, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA;, del decreto exento MOP N&#xBA;371, de 30 de marzo de 2010, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n, del lote de terreno N&#xBA;9, expropiado con motivo de la obra &quot;Construcci&#xF3;n Variante Ruta C-46 Freirina Provincia de Huasco, Regi&#xF3;n de Atacama&quot;. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n, fijada por la Comisi&#xF3;n de Peritos, con fecha 07 de enero de 2009, fij&#xF3; el monto de la indemnizaci&#xF3;n provisional en la cantidad de $35.419.600. </div></div>", "i": 9076916}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9076917}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2924 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2924 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-11-19", "doble_articulado": false, "id_norma": "1021172", "numero_fuente": "39835", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-12-15", "vigencias": [{"desde": "2010-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-12-15", "fin_vi