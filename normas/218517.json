{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6453011}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.812, de 12 de noviembre de 2003, de esta Subsecretar&#xED;a, prorr&#xF3;gase el plazo otorgado a PESQUERA DEL ESTRECHO S.A. para reanudar actividades pesqueras extractivas con la nave &quot;Curaco&quot;, por el t&#xE9;rmino de un a&#xF1;o contado desde el t&#xE9;rmino de la vigencia de su autorizaci&#xF3;n, por haberse acreditado la ocurrencia de una causal de fuerza mayor. La peticionaria deber&#xE1; reanudar operaciones extractivas antes de 29 de agosto de 2005.</div><br></div>", "i": 6453012}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de noviembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6453013}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2812 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2812 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-11-12", "doble_articulado": false, "id_norma": "218517", "numero_fuente": "37733", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-12", "vigencias": [{"desde": "2003-12-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-12-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-12-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_i