{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 248, DE 1987 </div></div>", "i": 6487475}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 248 de 07 de diciembre de 1987 se ha aprobado para el Liceo Industrial B No. 5 de Rancagua, Provincia de Cachapoal, VI Regi&#xF3;n del Libertador General Bernardo O&apos;Higgins, un plan y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico-Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar 1988 y hasta el a&#xF1;o escolar de 1991, en la Especialidad de Instalaciones El&#xE9;ctricas.</div><br></div>", "i": 6487476}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de Diciembre de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6487477}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "248 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-248 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 248, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-12-07", "doble_articulado": false, "id_norma": "227570", "numero_fuente": "32954", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-26", "vigencias": [{"desde": "1987-12-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacione