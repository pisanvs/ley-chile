{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 581 EXENTA, DE 2011</div></div>", "i": 9131057}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 581 de fecha 15 de marzo del 2011, el Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, autoriz&#xF3; complementariamente a la empresa peruana &quot;Transportes Cruz del Sur S.A.C.&quot;, para efectuar servicio de transporte terrestre internacional de pasajeros entre Per&#xFA; y Chile y viceversa, atendiendo el servicio Lima (Per&#xFA;)/Santiago (Chile), utilizando los pasos fronterizos Concordia con Dos (2) frecuencias semanales de Ida y Vuelta.- </div></div>", "i": 9131058}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Enrique L. Arce Klein, Unidad de Permisos Internacionales, Subsecretar&#xED;a de Transportes.</div></div>", "i": 9131059}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "581 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-581 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 581 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-03-15", "doble_articulado": false, "id_norma": "1024353", "numero_fuente": "39931", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-04-08", "vigencias": [{"desde": "2011-04-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-04-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-04-08