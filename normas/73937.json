{"html": [{"t": "<div><div class=\"p\">610-06-970626 - Tasa de inter&#xE9;s para pago diferido de derechos&nbsp; de Aduana.</div><br></div>", "i": 7208650}, {"t": "<div><div class=\"p\">Se acord&#xF3;, en conformidad con lo establecido en la letra c) del Art. N&#xBA; 10 de la Ley N&#xBA; 18.634, que la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de derechos de Aduana durante el semestre que expira el 31 de diciembre de 1997, ser&#xE1; de 11,10% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.</div><br></div>", "i": 7208651}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de junio de 1997.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 7208652}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "610", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-610"}, {"tipo": "5", "numero": "610-06", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-610-06"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "TASA DE INTERÉS PARA PAGO DIFERIDO DE DERECHOS DE ADUANA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA DE INTERES", "PAGO DIFERIDO", "DERECHOS DE ADUANAS", "TASA DE INTERES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-06-26", "doble_articulado": false, "id_norma": "73937", "numero_fuente": "35804", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-07-01", "vigencias": [{"desde": "1997-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": []