{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 28 EXENTO, DE 1996 </div></div>", "i": 7160127}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 28, de fecha 22 de enero de 1996, del Ministerio de Educaci&#xF3;n, se elimin&#xF3; del Registro de Institutos Profesionales el N&#xB0; 78 correspondiente al Instituto Profesional del B&#xED;o-B&#xED;o de Concepci&#xF3;n, organizado por la Sociedad Vidal y Wulf Limitada, autorizado a funcionar por Decreto Exento de Educaci&#xF3;n N&#xB0; 65 de fecha 27 de febrero de 1990. Ello a solicitud de la propia instituci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Decl&#xE1;rase que lo dispuesto precedentemente importa la p&#xE9;rdida del reconocimiento oficial del Instituto Profesional del B&#xED;o-B&#xED;o de Concepci&#xF3;n.</div><br></div>", "i": 7160128}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 30 de enero de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160129}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "28 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-28 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 28 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REGISTRO INSTITUTOS PROFESIONALES", "ELIMINACION", "INSTITUTO PROFESIONAL BIO-BIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-01-22", "doble_articulado": false, "id_norma": "19769", "numero_fuente": "35384", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-02-05", "vigencias": [{"desde": "1996-02-05", "hasta": "", "tipo_version": "3", "tipo_versio