{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 787 EXENTO, DE 2004</div><br><br></div>", "i": 6518700}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 787 de fecha 22 de septiembre</div><div class=\"p\">de 2004 del Ministerio de Educaci&#xF3;n, se modifica el</div><div class=\"p\">art&#xED;culo 1&#xBA; del decreto exento de Educaci&#xF3;n N&#xBA; 1.217 del 26 de diciembre de 1997, que reconoce oficialmente al Centro de Formaci&#xF3;n T&#xE9;cnica Abacus I.T.C., en el sentido de reemplazar la raz&#xF3;n social del organizador y la actual denominaci&#xF3;n del Centro, por la siguiente: Nombre de la Instituci&#xF3;n&nbsp; :&nbsp; Centro de Formaci&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  T&#xE9;cnica Abacus.</div><div class=\"p\">Domicilio&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  :&nbsp; Santiago.</div><div class=\"p\">Organizador&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  :&nbsp; Sociedad Abacus Centro de</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Formaci&#xF3;n T&#xE9;cnica Limitada</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  o Abacus C.F.T.</div><br><br></div>", "i": 6518701}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de marzo de 2005.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6518702}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "787 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-787 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 787 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "termino