{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 483 EXENTO, DE 1998</div><br><br><br></div>", "i": 6119231}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 483, de fecha 31 de marzo de 1998 del Ministerio de Educaci&#xF3;n, se aprobaron los planes y programas de estudios al Centro de Formaci&#xF3;n T&#xE9;cnica de Tecnolog&#xED;as Contempor&#xE1;neas - Teccon, de las carreras y t&#xED;tulos t&#xE9;cnicos de nivel superior que se indican, para ser impartidas a contar del a&#xF1;o 1998:</div><br><br><div class=\"p\">Carrera: Asistente jur&#xED;dico.</div><div class=\"p\">T&#xED;tulo:&nbsp; T&#xE9;cnico asistente jur&#xED;dico de nivel superior. Carrera: Publicidad con menci&#xF3;n en gr&#xE1;fica.</div><div class=\"p\">T&#xED;tulo:&nbsp; T&#xE9;cnico de nivel superior en publicidad con menci&#xF3;n en gr&#xE1;fica.</div><br></div>", "i": 6119232}, {"t": "<div><div class=\"p\">Santiago, 23 de abril de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6119233}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "483 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-483 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 483 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "CENTRO DE FORMACION TECNICA DE TECNOLOGIAS CONTEMPORANEA", "TECCON", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-03-31", "doble_articulado": false, "id_norma": "121312", "numero_fuente": "36116", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-07-17", "vigen