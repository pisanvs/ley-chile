{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5944687}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Decreto Exento n&#xFA;mero 462, de 7 de marzo de 1996, Ilustre Municipalidad Rancagua dispuso expropiaci&#xF3;n de propiedad rol aval&#xFA;o 56-17 propietario seg&#xFA;n rol aval&#xFA;o Inmobiliaria Inversiones Ando S.A.: Norte, tramo C-K en 9,10 metros con otro propietario; Sur, tramo B-L en 9,10 metros con otro propietario; Oriente, tramo L-K en 94 metros con calle Diego Portales; y Poniente, tramo B-C en 94 metros con resto de la propiedad, tambi&#xE9;n expropiado. Monto indemnizaci&#xF3;n $10.745.073.-. Expropiaci&#xF3;n seg&#xFA;n Art&#xED;culo N&#xB0; 29 Ley N&#xB0; 18.695, por ensanche de calle Diego Portales en el tramo comprendido entre calle Brasil y calle Jorge Rivera. Pago contado.- </div></div>", "i": 5944688}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Esteban Valenzuela Van Treek, Alcalde de Rancagua. + </div></div>", "i": 5944689}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "462 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-462 EXENTO"}], "organismos": ["MUNICIPALIDAD DE RANCAGUA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDAD RANCAGUA", "EXPROPIACION", "BIEN INMUEBLE", "RANCAGUA", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-03-07", "doble_articulado": false, "id_norma": "21290", "numero_fuente": "35418-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-03-15", "vigencias": [{"desde": "1996-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-03-15", "fin_vigencia": ""}, "