{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA A GRANELES DE CHILE S.A.</div><br></div>", "i": 6475235}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VI Direcci&#xF3;n Regional Rancagua del Servicio de Impuestos Internos, por resoluci&#xF3;n N&#xBA; 103 de fecha 12 de abril de 2004, resuelve a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, otorgar a Graneles de Chile S.A., RUT N&#xBA; 96.725.160-7, la calidad de agente retenedor del IVA, en las ventas de trigo, de acuerdo a lo establecido por la resoluci&#xF3;n Ex. N&#xBA; 5.281 de fecha 30 de noviembre 2000, de la Direcci&#xF3;n Nacional. </div></div>", "i": 6475236}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Luis Mu&#xF1;oz Arratia, Director Regional. </div></div>", "i": 6475237}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "103", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-103"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VI DIRECCIÓN REGIONAL DE RANCAGUA"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA A GRANELES DE\nCHILE S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-12", "doble_articulado": false, "id_norma": "224219", "numero_fuente": "37844", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-24", "vigencias": [{"desde": "2004-04-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-04-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-04-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincula