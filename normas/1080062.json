{"html": [{"t": "<div><br><div class=\"p\">DELEGACI&#xD3;N DE FIRMAS</div></div>", "i": 9625162}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n D.G.T.M. y M.M. ord. exenta N&#xBA; 6.030/8 Vrs., del 16 de junio de 2015, &quot;Del&#xE9;gase bajo la f&#xF3;rmula &quot;Por orden del Sr. Director General, en la persona del Sr. Subdirector de esta Direcci&#xF3;n General, la facultad de firmar documentos que deban ser tramitados dentro de la Instituci&#xF3;n...&quot;.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n, se encuentra publicada en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl).</div><br></div>", "i": 9625163}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de julio de 2015.- Osvaldo Schwarzenberg Ashton, Vicealmirante, Director General.- Rodrigo Ram&#xED;rez Daneri, Capitan de Nav&#xED;o JT Jefe Depto. Jur&#xED;dico.</div></div>", "i": 9625164}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6030 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6030 EXENTA"}, {"tipo": "3", "numero": "8 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-8 EXENTA"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "DELEGACIÓN DE FIRMAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-06-16", "doble_articulado": false, "id_norma": "1080062", "numero_fuente": "41221", "tipo_version": "3", "tipo