{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6351374}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto exento&nbsp; MOP&nbsp; N&#xBA; 1.139, de 27 de agosto de 2001, y en base a la facultad otorgada por el art&#xED;culo 105 del DFL MOP N&#xBA; 850, de 1997, que fij&#xF3; el texto actualizado de la ley N&#xBA; 15.840, se expropi&#xF3; el lote de terreno N&#xBA; 2, para la obra Camino Ruta T-80, sector La Uni&#xF3;n-Las Trancas, Kms. 0,900 al 10,99034, que figura a nombre de Huenulef Aburto Vicente Suc., rol de aval&#xFA;o 524-119, superficie 128 m2., comuna de La Uni&#xF3;n. La comisi&#xF3;n de peritos, con fecha 21 de enero de 2000, fij&#xF3; la indemnizaci&#xF3;n provisional en la cantidad de $256.000, la que se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.</div><br></div>", "i": 6351375}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6351376}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1139 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1139 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-08-27", "doble_articulado": false, "id_norma": "190007", "numero_fuente": "37074", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-10-01", "vigencias": [{"desde": "2001-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-10-01", "fin_vi