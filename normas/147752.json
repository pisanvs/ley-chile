{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8353609}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.170, de 20 de octubre de 1999 de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA COLOSO S.A., para ampliar las actividades pesqueras extractivas con la nave &apos;&apos;Bandurria&apos;&apos;, matr&#xED;cula 2306, autorizadas por resoluciones N&#xBA; 500 de 1997 y N&#xBA; 1.036 de 1999 de esta Subsecretar&#xED;a, en orden a realizar actividades pesqueras con la nave &apos;&apos;Bandurria&apos;&apos; en el litoral de la I y II Regiones, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar con red de cerco el recurso hidrobiol&#xF3;gico Jurel fino y Sardina redonda. </div></div>", "i": 8353610}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de octubre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8353611}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2170", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2170"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-20", "doble_articulado": false, "id_norma": "147752", "numero_fuente": "36516", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-11-17", "vigencias": [{"desde": "1999-11-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-11-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-11-17", "fin_vige