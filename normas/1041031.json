{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9267056}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (exento) N&#xBA;952 de fecha 31 de mayo de 2012, y de conformidad a lo dispuesto en el Art. 105 del DFL. MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;76-B, superficie 151 m2, rol N&#xBA;40-33, para la obra &quot;Mejoramiento Ruta I-70-J, Sector Lolol - Ranguil, Tramo Km. 0,00000 a Km. 19,38878&quot;, Comuna de Lolol, VI Regi&#xF3;n. La Comisi&#xF3;n de Peritos integrada por Orlando Fari&#xF1;a V&#xE1;squez, Manuel D&#xED;az Farf&#xE1;n y Patricio Casagrande Ulloa, fij&#xF3; valor de tasaci&#xF3;n con fecha 20 de enero de 2010, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario NELSON DEL CARMEN VALENZUELA CORNEJO, en la cantidad de $1.138.344, suma que se pagar&#xE1; al contado. </div></div>", "i": 9267057}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9267058}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "952 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-952 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-31", "doble_articulado": false, "id_norma": "1041031", "numero_fuente": "40288", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-15", "vigencias": [{"desde": "2012-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici