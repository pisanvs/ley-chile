{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6492025}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 421 de 16 de julio de 2004 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme D.L. N&#xBA; 2.186 de 1978, del Lote N&#xBA; 10 correspondiente al inmueble ubicado en calle Tucapel N&#xBA; 4584, presunto Rol de Aval&#xFA;o N&#xBA; 556-09, comuna de Cerrillos, aparente dominio de C&#xE9;sar Ricardo Garc&#xED;a Navarrete. Comisi&#xF3;n integrada por peritos Carmen P. R&#xED;os Marcuello, Ingeniero Civil; Alfredo Irisarri Valderrama, Arquitecto y Armando Pinochet Landero, Constructor Civil. Seg&#xFA;n informe de fecha 26 de marzo de 2004 fij&#xF3; monto provisional indemnizaci&#xF3;n en $48.645.533.- pagadera al contado.</div><br></div>", "i": 6492026}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6492027}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "421", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-421"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES DE INMUEBLES QUE INDICA; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-07-16", "doble_articulado": false, "id_norma": "228988", "numero_fuente": "37937", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-08-16", "vigencias": [{"desde": "2004-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vige