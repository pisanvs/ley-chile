{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6087601}, {"t": "<div><br><div class=\"p\">El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 10,55% anual durante el mes de Enero de 1990.</div><div class=\"p\">Asimismo, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de Captaci&#xF3;n para operaciones raajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de Enero de 1990, fue del, 36% anual.</div><br></div>", "i": 6087602}, {"t": "<div><div class=\"p\">Santiago, 07 de Febrero de 1990.- V&#xED;ctor Vial del R&#xED;o, Secretario General Interino.</div><br></div>", "i": 6087603}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-02-07", "doble_articulado": false, "id_norma": "91011", "numero_fuente": "33591", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-08", "vigencias": [{"desde": "1990-02-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1998-02-2