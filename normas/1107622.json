{"html": [{"t": "<div><br><div class=\"p\">ESTABLECE PROCEDIMIENTO PARA DECLARACI&#xD3;N JURADA QUE INDICA</div></div>", "i": 9831090}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta SII N&#xB0; 82, del 31 de agosto de 2017.</div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Establece forma y plazo para presentar Declaraci&#xF3;n Jurada Anual sobre determinaci&#xF3;n de la renta l&#xED;quida imponible, renta a atribuir y renta atribuida a los propietarios, titulares, socios, accionistas de SpA o comuneros, Formulario N&#xBA; 1923 e informar y certificar lo que se indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de agosto de 2017.</div></div>", "i": 9831091}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "82 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-82 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ESTABLECE PROCEDIMIENTO PARA DECLARACIÓN JURADA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1267483; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-08-31", "doble_articulado": false, "id_norma": "1107622", "numero_fuente": "41853", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-09-06", "vigencias": [{"desde": "2017-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-