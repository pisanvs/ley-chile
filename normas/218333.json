{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6452306}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.027, de 21 de noviembre de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 826, de 2001, y el numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA; 373, de 2003, ambas de esta Subsecretar&#xED;a, que autorizaron a SOUTHPACIFIC KORP S.A. para realizar actividades pesqueras extractivas con la nave &quot;San Bosco&quot;, en el sentido de incorporar y actualizar, seg&#xFA;n corresponda, las siguientes caracter&#xED;sticas n&#xE1;uticas de &#xE9;sta:</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  36,82</div><div class=\"p\">Potencia principal&nbsp; &nbsp; &nbsp; &nbsp;  1774,00 Hp.</div><div class=\"p\">Potencia auxiliar&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  475,00 Hp.</div><br></div>", "i": 6452307}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de noviembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6452308}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3027 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3027 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-11-21", "doble_articulado": false, "id_norma": "218333", "numero_fuente": "37729", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-06", "vigencias": [{"desde": "2003-12-06", "hasta": "", "tipo_ve