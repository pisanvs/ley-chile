{"html": [{"t": "<div><div class=\"p\">SOLICITA CONSTITUCI&#xD3;N DEL PARTIDO REGIONALISTA DE LOS INDEPENDIENTES </div></div>", "i": 7370604}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Carlos Moraga Duque y Ricardo Fern&#xE1;ndez Sanhueza, Presidente y Secretario General del Partido Regionalista de los Independientes, respectivamente, han solicitado la constituci&#xF3;n legal del partido en las Regiones V de Valpara&#xED;so y Metropolitana de Santiago, acompa&#xF1;ando 5.744 y 17.577 fichas de afiliaciones, respectivamente.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xBA; de la ley N&#xBA; 18.603, por resoluci&#xF3;n O-N&#xBA; 0732, de fecha 13 de mayo de 2008. </div></div>", "i": 7370605}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director. </div></div>", "i": 7370606}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "732", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-732"}, {"tipo": "3", "numero": "O-732", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-732"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCIÓN DEL PARTIDO REGIONALISTA DE LOS\nINDEPENDIENTES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO REGIONALISTA DE LOS INDEPENDIENTES", "CONSTITUCION LEGAL", "REGION METROPOLITANA", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-05-13", "doble_articulado": false, "id_norma": "271435", "numero_fuente": "39068", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-05-23", "vigencias": [{"desde": "2008-05