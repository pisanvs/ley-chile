{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA EMISOR ELECTR&#xD3;NICO</div></div>", "i": 9177771}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 108, de 1 de septiembre de 2011, que autoriza a contribuyentes como emisores electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de documentos tributarios a contribuyentes RUT 76.237.450-1, RUT 78.420.320-4, RUT 78.713.060-7, RUT 76.042.696-2, RUT 76.909.170-K, RUT 86.116.800-K, RUT 76.140.725-2, RUT 99.575.120-8, RUT 76.150.964-0, RUT 86.438.200-2, RUT 96.766.580-0, RUT 76.090.722-7, RUT 59.000.370-0, RUT 12.675.639-9, RUT 83.377.700-9, RUT 76.582.260-2, RUT 99.522.540-9, RUT 77.478.330-K, RUT 78.119.320-8, RUT 76.123.089-1, RUT 76.470.320-0, RUT 76.144.683-5, RUT 84.411.700-0, RUT 02.779.013-5, RUT 76.145.906-6, RUT 76.017.748-2, RUT 76.014.445-2, RUT 76.071.133-0, RUT 77.712.750-0, RUT 76.148.643-8, RUT 76.112.370-K, RUT 76.653.500-3, RUT 78.748.930-3, RUT 76.047.903-9, RUT 76.808.130-1, RUT 76.139.803-2, RUT 76.517.270-5, RUT 84.060.600-7, RUT 76.765.030-2, RUT 77.755.770-K, RUT 99.599.520-4, RUT 83.639.600-6, RUT 96.870.780-9, RUT 99.517.430-8, RUT 76.152.753-3, RUT 90.684.000-6, RUT 99.595.910-0, RUT 89.989.700-5, RUT 76.107.725-2, RUT 11.917.669-7, RUT 82.698.300-0, RUT 76.105.214-4, RUT 70.543.600-2, RUT 77.217.720-8, RUT 96.562.040-0, RUT 76.129.486-5, RUT 59.104.910-0, RUT 96.954.590-K, RUT 77.902.720-1, RUT 13.677.712-2, RUT 78.276.930-8, RUT 76.709.910-K, RUT 76.042.353-K, RUT 77.334.290-3, RUT 78.790.500-5, RUT 76.106.530-0, RUT 84.071.200-1, RUT 76.223.460-2, RUT 99.575.640-4, RUT 77.539.370-K, RUT 76.001.342-0, RUT 77.858.490-5, RUT 96.582.680-7, RUT 77.709.380-0, RUT 76.116.394-9, RUT 52.002.303-8, RUT 05.288.325-3, RUT 78.885.410-2, RUT 96.800.950-8, RUT 76.117.512-2, RUT 76.087.735-2, RUT 76.143.206-0, RUT 78.196.220-1, RUT 08.885.396-2, RUT 76.110.319-9, RUT 76.105.700-6, RUT 78.418.920-1, RUT