{"html": [{"t": "<div><div class=\"p\">AUTORIZA A CONSERVERA PHILROY S.A. PARA AMPLIAR ACTIVIDADES PESQUERAS</div><br><br><br></div>", "i": 7259763}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 952, de 20 de Agosto de 1987 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Conservera Philroy S.A., domiciliada en Santiago para ampliar actividades pesqueras de transformaci&#xF3;n en su planta industrial de Coquimbo autorizada por resoluci&#xF3;n No. 14 de 1984 de esta entidad en orden a incorporar entre los recursos hidrobiol&#xF3;gicos que puede procesar el denominado cholga.</div><br></div>", "i": 7259764}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de Agosto de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 7259765}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "952", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-952"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS", "SUBSECRETARÍA DE ECONOMÍA"], "titulo_norma": "AUTORIZA A CONSERVERA PHILROY S.A. PARA AMPLIAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1987-08-20", "fecha_derogacion": "1991-07-04", "doble_articulado": false, "id_norma": "153126", "numero_fuente": "32865", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1987-09-07", "vigencias": [{"desde": "1991-07-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1987-09-07", "hasta": "1991-07-03", "tipo_ver