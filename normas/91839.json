{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 143, DE 1989 </div></div>", "i": 6090029}, {"t": "<div><div class=\"p\">Extracto de la Resoluci&#xF3;n Exenta No. 143 de 05 de Abril de 1989 de la Secretar&#xED;a Ministerial de Educaci&#xF3;n I Regi&#xF3;n, Tarapaca.</div><div class=\"p\">Por resoluci&#xF3;n exenta de la referencia se han aprobado planes y programas de estudio, para la Educaci&#xF3;n Media T&#xE9;cnico - Profesional, a contar del a&#xF1;o escolar 1989 y hasta el a&#xF1;o escolar 1994, inclusive, para el Liceo A - 6 &quot;Instituto Comercial de Iquique&quot;.</div><br><div class=\"p\"> ESPECIALIDADES:</div><div class=\"p\"> - Contabilidad</div><div class=\"p\"> - Secretariado Ejecutivo</div><div class=\"p\"> - Ventas y Publicidad.</div><br></div>", "i": 6090030}, {"t": "<div><div class=\"p\">Iquique, Benigno Barrios Herrera, Secretario Ministerial de Educaci&#xF3;n I Regi&#xF3;n, Tarapac&#xE1;.</div><br></div>", "i": 6090031}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "143 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-143 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 143, DE 1989 ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-04-05", "doble_articulado": false, "id_norma": "91839", "numero_fuente": "33394", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-06-10", "vigencias": [{"desde": "1989-06-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-