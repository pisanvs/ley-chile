{"html": [{"t": "<div><br><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9820431}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 963 de fecha 24 de julio de 2017, del Serviu Regi&#xF3;n de Coquimbo, se orden&#xF3; expropiar totalmente por causa de utilidad p&#xFA;blica, conforme al art&#xED;culo 51 ley 16.391 y DL 2.186/78, el inmueble denominado Lote 15 en plano de expropiaci&#xF3;n, ubicado en Calle Chacabuco N&#xBA; 104, de la comuna de Coquimbo, Rol de Aval&#xFA;o N&#xBA; 673-06, propietario aparente Mar&#xED;a Elena Sandoval Mendoza, superficie aprox. de terreno 98,00 m2. Comisi&#xF3;n de Peritos conformada por profesionales Marcia Aqueveque, Miguel Rubio y Alfredo Prieto, seg&#xFA;n informe de 8 de noviembre de 2016 fij&#xF3; indemnizaci&#xF3;n provisional en 1.522,92 Unidades de Fomento pagadera al contado.- </div><br></div>", "i": 9820432}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director (S) Serviu Regi&#xF3;n Coquimbo.</div></div>", "i": 9820433}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "963", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-963"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "IV REGIÓN DE COQUIMBO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1247731", "CVE 1247731", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-07-24", "doble_articulado": false, "id_norma": "1105924", "numero_fuente": "41823", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-08-01", "vigencias": [{"desde": "2017-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}]