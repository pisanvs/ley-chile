{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10287939}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0;4.766 de 22 de noviembre de 2021, Serviu Regi&#xF3;n de Valpara&#xED;so, dispuesto expropiaci&#xF3;n parcial conforme al art&#xED;culo 51 ley 16.391 y decreto ley 2.186 de 1978, del inmueble signado como lote 19 A, en el plano &quot;Proyecto de Expropiaciones DRS-P N&#xB0; 12624&quot; L&#xE1;mina 11 de 16, comuna de Conc&#xF3;n, para la Ejecuci&#xF3;n del Proyecto &quot;Mejoramiento Costero Re&#xF1;aca-Conc&#xF3;n Etapa I, Comuna de Conc&#xF3;n&quot; de presunto dominio de Inmobiliaria Estoril y Otro, Rol aval&#xFA;o 3411-105 / 3441-106. Comisi&#xF3;n Tasadora integrada por &#xC1;lvaro Verdejo Vidal; Jorge Giacaman Valle e Ismael Allendes Mar&#xED;n, seg&#xFA;n informe de 2019 fij&#xF3; monto indemnizaci&#xF3;n provisional en $17.074.327, que ser&#xE1; pagada al contado. </div></div>", "i": 10287940}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director Serviu.</div><div class=\"p\"> </div><br></div>", "i": 10287941}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4766 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4766 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DE VALPARAÍSO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2048362", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-11-22", "doble_articulado": false, "id_norma": "1168928", "numero_fuente": "43117", "tipo_version