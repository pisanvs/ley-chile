{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9090995}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.682 de 7 de diciembre de 2010 de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3.- de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1008313&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.640 de 2009</a>, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la UNIVERSIDAD DE ANTOFAGASTA para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Seguimiento regional de la Pesquer&#xED;a de las Algas Pardas en la II Regi&#xF3;n de Antofagasta&quot;, en el sentido de extender el per&#xED;odo de ejecuci&#xF3;n de la citada pesca de investigaci&#xF3;n hasta el 31 de octubre de 2011, inclusive.</div></div>", "i": 9090996}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de diciembre de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9090997}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3682 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3682 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO."], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-07", "doble_articulado": false, "id_norma": "1021685", "numero_fuente": "39848", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-12-31", "vigencias": [{"desde": "2010-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic