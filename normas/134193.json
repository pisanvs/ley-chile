{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,135.- Santiago, 10 de diciembre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br><br><br></div>", "i": 6161592}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atenci&#xF3;n a los servicios prestados al pais por el coronel de Ej&#xE9;rcito don Francisco&nbsp; Barcel&#xF3;, el&#xE9;vase, por gracia, a ciento veinte pesos la pensi&#xF3;n mensual de que actualmente disfruta su viuda e hijos. </div></div>", "i": 6161593}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Ventura Blanco.</div><br></div>", "i": 6161594}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1135", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1135"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-12-10", "doble_articulado": false, "id_norma": "134193", "numero_fuente": "6173", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-12-10", "vigencias": [{"desde": "1898-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-12-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-12-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-03-30", "