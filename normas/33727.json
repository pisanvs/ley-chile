{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ORDENA EXPROPIACIONES QUE SE&#xD1;ALA </div></div>", "i": 6007747}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 203 de 29 Septiembre 1994 del Serviu V Regi&#xF3;n Valpara&#xED;so se dispuso expropiaci&#xF3;n parcial, conforme art&#xED;culo 87 Ley 8.946 y Decreto Ley N&#xB0; 2.186 de 1978, de inmueble ubicado en calle San Enrique, comuna Villa Alemana, rol de aval&#xFA;o 372-1, de aparente dominio de Julia Marambio Tapia. Comisi&#xF3;n Tasadora integrada por Sres. Osvaldo Mu&#xF1;oz Quintana, arquitecto, Pablo Caria Giurici y Alvaro Verdejo Vidal, constructores civiles, fij&#xF3; monto provisional indemnizaci&#xF3;n en $253.500.-, que se pagar&#xE1; de contado.- </div></div>", "i": 6007748}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Alberto Ram&#xED;rez Urz&#xFA;a, Arquiecto, Director Serviu V Regi&#xF3;n.</div><br></div>", "i": 6007749}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "203", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-203"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "ORDENA EXPROPIACIONES QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "BIEN RAIZ", "VILLA ALEMANA", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-09-29", "doble_articulado": false, "id_norma": "33727", "numero_fuente": "34991-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-10-15", "vigencias": [{"desde": "1994-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici