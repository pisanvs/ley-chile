{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N 4.045, DE 2012</div></div>", "i": 9380281}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n 2.871, del 22 de julio de 2013, del Ministerio de Defensa Nacional, Subsecretar&#xED;a para las Fuerzas Armadas, se resolvi&#xF3; lo siguiente:</div><div class=\"p\">&nbsp; &nbsp;  1.- Rectif&#xED;case el numeral 2 del resuelvo de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1049134&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n 4.045, del 20 de diciembre de 2012, del Ministerio de Defensa Nacional, Subsecretar&#xED;a para las Fuerzas Armadas</a>, de la siguiente forma:</div><br><div class=\"p\">&nbsp; &nbsp;  Donde dice:</div><br><div class=\"p\">&nbsp; &nbsp;  V&#xE9;rtice A Lat. 44&#xBA;21&apos;07,29&quot; S. Long. 72&#xBA;54&apos;59,93&quot; W.</div><br><div class=\"p\">&nbsp; &nbsp;  Debe decir:</div><br><div class=\"p\">&nbsp; &nbsp;  V&#xE9;rtice E Lat. 44&#xBA;21&apos;07,29&quot; S. Long. 72&#xBA;54&apos;59,93&quot; W.</div><div class=\"p\">&nbsp; </div><br><br></div>", "i": 9380282, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Santiago, 1 de octubre de 2013.- Por orden del Subsecretario para las Fuerzas Armadas, Camilo Mirosevic Verdugo, Abogado, Jefe Divisi&#xF3;n Jur&#xED;dica.</div></div>", "i": 9380283}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2871", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-2871"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS"], "titulo_norma": "RECTIFICA RESOLUCIÓN 4.045, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "