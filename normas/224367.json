{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6475826}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 939, de 6 de abril de 2004, de esta Subsecretar&#xED;a, modif&#xED;case el n&#xFA;mero 4&#xBA; de la resoluci&#xF3;n N&#xBA; 1.962 de 2003, que autoriz&#xF3; a PESQUERA BIO BIO S.A. a realizar actividades pesqueras extractivas con la nave &quot;Loa 24&quot;, en el sentido de indicar que la fecha para iniciar actividades pesqueras sobre los recursos hidrobiol&#xF3;gicos autorizados, es de un a&#xF1;o contado desde la fecha de publicaci&#xF3;n de la citada resoluci&#xF3;n y no la que all&#xED; se indica.</div><br></div>", "i": 6475827}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6475828}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "939 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-939 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-04-06", "fecha_derogacion": "2006-11-23", "doble_articulado": false, "id_norma": "224367", "numero_fuente": "37849", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-04-30", "vigencias": [{"desde": "2006-11-23", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-04-30", "hasta": "2006-11-22", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2006-11-23", "fin_vigencia": ""