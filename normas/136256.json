{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,172.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6168104}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que invierta hasta la suma de trescientos mil pesos ($ 300,000) en la construccion de un ferrocarril de trocha de un metro que &#xFA;na la ciudad de San Felipe con la de Putaendo.&quot; </div></div>", "i": 6168105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, diecinueve de febrero de mil novecientos nueve.- Pedro Montt.- Manuel Espinosa Jara.</div><br></div>", "i": 6168106}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2172", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2172"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1909-02-19", "doble_articulado": false, "id_norma": "136256", "numero_fuente": "9329", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1909-03-05", "vigencias": [{"desde": "1909-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1909-03-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1909-03-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi