{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Prorroga hasta el 31 de Diciembre de 1930 el uso obligatorio del carnet de identidad</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional a dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 8277686}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.o Prorr&#xF3;gase hasta el 31 de Diciembre de 1930 el plazo fijado por el art&#xED;culo 1.o de la ley n&#xFA;mero 4,237, de 10 de Enero de 1928, sobre uso obligatorio del carnet de Identidad.</div><br></div>", "i": 8277687, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 2.o La presente ley comenzar&#xE1; a regir desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 8277688}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta y uno de Diciembre de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Enrique Berm&#xFA;dez.</div><br></div>", "i": 8277689}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4751", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4751"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Prorroga hasta el 31 de Diciembre de 1930 el uso;obligatorio del carnet de identidad", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CARNET DE IDENTIDAD", "OBLIGACION", "USO", "PLAZO", "PRORROGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-12-31", "doble_articulado": false, "id_norma": "24884", "numero_fuente": "15564", "tipo_version": "3", "tipo_versi