{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6338812}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA; 576, de 30 de abril de 2001, se expropiaron los lotes de terreno N&#xBA;s. 159-A y 159-B, superficies 2.538 m&#xB2; y 5.307 m&#xB2;, rol de aval&#xFA;o 161-26, comuna de R&#xE1;nquil, para la obra Camino Acceso Norte a Concepci&#xF3;n, Octava Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios H&#xE9;ctor Mois&#xE9;s Alarc&#xF3;n Torres y otros, ascendente a la cantidad total de $1.648.172.-</div><br></div>", "i": 6338813}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6338814}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "576 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-576 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-30", "doble_articulado": false, "id_norma": "186459", "numero_fuente": "36987", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-06-15", "vigencias": [{"desde": "2001-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2001-06-15", "fecha_version": "2001-06-15", "fecha_actualizacion_texto": "2001-06-15", "tipo_tratado": ""}, "alertas": [], "alerta_global":