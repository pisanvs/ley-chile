{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6218510}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 889 de 25 de Junio de 1987, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a las parcelas N&#xB0;s. 39 a la 43 y 48, sitios N&#xB0;s. 30 al 38, y parte del Proyecto de Parcelaci&#xF3;n &quot;El Mait&#xE9;n&quot;, formado por el predio &quot;Hijuela Tercera o Santa Ana del Fundo La Compa&#xF1;&#xED;a&quot; de la comuna de Graneros, provincia de Cachapoal, VI Regi&#xF3;n. Los Derechos de Aguas se extraen del canal Viejo de la Compa&#xF1;&#xED;a.- Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.-</div><br></div>", "i": 6218511}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6218512}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "889 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-889 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-25", "doble_articulado": false, "id_norma": "151081", "numero_fuente": "32808", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-01", "vigencias": [{"desde": "1987-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-07-01", "fin