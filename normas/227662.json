{"html": [{"t": "<div><div class=\"p\">AREA DE RESTRICCION ACUIFERO RIO LIGUA, PROVINCIA DE PETORCA, V REGION </div></div>", "i": 6487752}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n DGA N&#xBA; 204 de fecha 14 de mayo de 2004 se ha declarado Area de Restricci&#xF3;n para extracciones de aguas subterr&#xE1;neas del sector hidrogeol&#xF3;gico del Acu&#xED;fero del R&#xED;o Ligua ubicado en la provincia de Petorca, V Regi&#xF3;n. Los antecedentes se encuentran disponibles en las oficinas de la Direcci&#xF3;n General de Aguas de la V Regi&#xF3;n, del Nivel Central y en la p&#xE1;gina Web de la DGA.</div><br></div>", "i": 6487753}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Humberto Pe&#xF1;a T., Director General de Aguas. </div></div>", "i": 6487754}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "204", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-204"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "DIRECCIÓN GENERAL DE AGUAS"], "titulo_norma": "AREA DE RESTRICCION ACUIFERO RIO LIGUA, PROVINCIA DE\nPETORCA, V REGION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGUAS SUBTERRANEAS", "AREA DE RESTRICCION", "RIO LIGUA", "PETORCA", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-14", "doble_articulado": false, "id_norma": "227662", "numero_fuente": "37910", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-15", "vigencias": [{"desde": "2004-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-07-15", "fin_vigencia": "", "tipo_version": "3