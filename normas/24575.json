{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede, por gracia, al carabinero Filidor Urrutia, retiro con goce de una pensi&#xF3;n equivalente a sargento segundo.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente:</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 8277315}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al carabinero don Filidor Urrutia, el derecho a retiro, con el goce de una pensi&#xF3;n equivalente al sueldo de sargento 2.o del Cuerpo de Carabineros.</div><br></div>", "i": 8277316}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, siete de Diciembre de mil novecientos veintisiete.- Carlos Ib&#xE1;&#xF1;ez C.- Enrique Balmaceda. </div></div>", "i": 8277317}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4218", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4218"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE, POR GRACIAS, AL CARABINERO FILIDOR URRUTIA, RETIRO CON GOCE DE UNA PENSION EQUIVALENTE A SARJENTO SEGUNDO.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FILIDOR URRUTIA", "RETIRO POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1927-12-07", "doble_articulado": false, "id_norma": "24575", "numero_fuente": "14946", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1927-12-14", "vigencias": [{"desde": "1927-12-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}]