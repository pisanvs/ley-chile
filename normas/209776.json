{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 4,592</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente,</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY </div></div>", "i": 6422124}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Ab&#xF3;nese, por gracia, al ingeniero de la Armada, don Jorge Blau Kovats, para los efectos de su retiro, el tiempo que sirvi&#xF3; a contrata.</div><br></div>", "i": 6422125}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiuno de Febrero de mil novecientos veintinueve.- Carlos Ib&#xE1;&#xF1;ez del Campo.- C. O. Fr&#xF6;dden. </div></div>", "i": 6422126}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4592", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4592"}], "organismos": ["MINISTERIO DE MARINA", "SUBSECRETARIA DE MARINA"], "titulo_norma": "LEY NUM. 4592", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-02-21", "doble_articulado": false, "id_norma": "209776", "numero_fuente": "15333", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-03-26", "vigencias": [{"desde": "1929-03-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-03-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1929-03-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MAS", "f