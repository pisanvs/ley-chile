{"html": [{"t": "<div><div class=\"p\">CIRCULAR</div><div class=\"p\">COOPERATIVAS&nbsp; N&#xB0; 1</div><div class=\"p\">Santiago, 2 de diciembre de 1975.</div><div class=\"p\">Se&#xF1;or Gerente:</div></div>", "i": 9567369}, {"t": "<div><div class=\"p\">Como es de su conocimiento en el <a href=\"https://www.leychile.cl/Navegar?idNorma=6484&amp;idParte=8746682&amp;idVersion=\">art. 21</a> del <a href=\"https://www.leychile.cl/Navegar?idNorma=6484&amp;idParte=0&amp;idVersion=\">D.L. 1.097</a>, publicado en el </div><div class=\"p\">Diario Oficial del 25 de julio del a&#xF1;o en curso, se establece que las </div><div class=\"p\">Cooperativas de Ahorro y Cr&#xE9;dito quedan sujetas a la fiscalizaci&#xF3;n de esta </div><div class=\"p\">Superintendencia.</div><br><div class=\"p\">Con el fin de contar con antecedentes b&#xE1;sicos de esa Cooperativa, s&#xED;rvase </div><div class=\"p\">Ud. disponer el env&#xED;o a este Organismo Contralor, dentro de un plazo de </div><div class=\"p\">10 d&#xED;as h&#xE1;biles, contados desde la fecha de la presente, de la informaci&#xF3;n </div><div class=\"p\">que se solicita en anexo.</div><br><div class=\"p\">Su respuesta s&#xED;rvase dirigirla a: SUPERINTENDENCIA DE BANCOS E INSTITUCIONES </div><div class=\"p\">FINANCIERAS, Casilla 15-D Santiago.</div></div>", "i": 9567370}, {"t": "<div><div class=\"p\">Saludo atentamente a Ud.,</div><br><div class=\"p\">MIGUEL IBA&#xD1;EZ BARCELO</div><div class=\"p\">Superintendente de Bancos e</div><div class=\"p\">Instituciones Financieras</div></div>", "i": 9567371}, {"t": "<div><div class=\"p\">ANEXO</div><div class=\"p\">.<img class=\"img-responsive\" src=\"Navegar/imagen/JPG/37143.jpg\"></div><div class=\"p\">.<img class=\"img-responsive\" src=\"Navegar/imagen/JPG/37144.jpg\"></div><div class=\"p\">.<img class=\"img-responsive\" src=\"Navegar/imagen/JPG/37145.jpg\"></div></div>", "i": 9567372}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "Cooperativas 1", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-Cooperativas 1"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE BANCOS E INSTITUCIONES FINANCIERAS"], "titulo_norma": "Se establece que las Cooperativas de Ahorro y Crédito quedan sujetas a la fiscalización de esta Superintendencia", "fuente": "Recopilación de instrucciones SBIF", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1975-12-02", "doble_articulado": false, "id_norma": "1058666", "numero_fuente": "0", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1975-12-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1975-12-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1975-12-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresado_por": "153828", "fecha_ingreso": "2015-02-17", "fecha_version": "1975-12-02", "fecha_actualizacion_texto": "2015-02-17", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9567369}, {"n": "Artículo", "i": 9567370, "t": 6}, {"n": "Promulgación", "i": 9567371}, {"n": "Anexo ANEXO", "i": 9567372}]}