{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6526375}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. N&#xBA; 519, de 31 de julio de 1996, se expropiaron los lotes de terreno N&#xB0;s. 38, 39, 40, 41, 42 y 43, superficies 20.538 m2., 62.970 m2., 45.897 m2,11.404 m2., 900 m2. y 6.862 m2., respectivamente, roles aval&#xFA;o 334-437, 334-439, 334-441, 334-21 y 334- 436, comuna de Pe&#xF1;aflor, para la obra Camino Autopista Santiago-San Antonio, sector Empalme I. Riquelme - Bif. Malloco, y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Regina Tagle Err&#xE1;zuriz, Carlos A. Tagle Err&#xE1;zuriz, Jos&#xE9; Manuel Tagle Err&#xE1;zuriz y Jos&#xE9; Manuel Tagle Vald&#xE9;s, ascendente a las cantidades de $84.330.959, $231.396.491, $172.728.833, $64.639.673, $5.303.140, y $56.635.043.</div><br><br></div>", "i": 6526376}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6526377}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "519", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-519"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-07-31", "doble_articulado": false, "id_norma": "238062", "numero_fuente": "35557", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-09-02", "vigencias": [{"desde": "1996-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-09-02", "