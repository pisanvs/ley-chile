{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 523 EXENTO, DE 1997 </div></div>", "i": 6040338}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento n&#xFA;mero 523 de fecha 13 de mayo de 1997 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica INACAP, las adecuaciones al plan y programas de estudios de la carrera de Programaci&#xF3;n de Computadores, modific&#xE1;ndose en consecuencia, el Decreto exento N&#xBA; 271 de 1995. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1997, en las sedes que ya contaban con su autorizaci&#xF3;n. </div></div>", "i": 6040339}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de junio de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6040340}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "523 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-523 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 523 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO DE FORMACION TECNICA INACAP", "PLAN DE ESTUDIOS", "PROGRAMAS DE ESTUDIOS", "PROGRAMACION DE COMPUTADORES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-05-13", "doble_articulado": false, "id_norma": "73920", "numero_fuente": "35802", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-06-28", "vigencias": [{"desde": "1997-06-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-06-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-06-28", "fin_vigencia": "", "tipo_