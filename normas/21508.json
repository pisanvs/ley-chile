{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 581 EXENTO, DE 1995 </div></div>", "i": 8273185}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 581 de 20 de octubre de 1995, se ha aprobado un programa para la asignatura de Biolog&#xED;a del Plan de Estudio, Area B&#xE1;sica, del 2&#xB0; a&#xF1;o medio que se aplicar&#xE1; a contar del a&#xF1;o escolar 1995, en las especialidades de Contabilidad y Administraci&#xF3;n de Recursos Humanos que imparten los siguientes Liceos Comerciales: A-25; A-30 &quot;Joaqu&#xED;n Vera Morales&quot;; B-40 &quot;Nora Vivians Molina&quot;; B-61 &quot;Gabriel Gonz&#xE1;lez Videla&quot;; B-70 &quot;Molina Lav&#xED;n&quot;; B-106; B-113, todos de Santiago y B-130 de San Bernardo.</div><br></div>", "i": 8273186, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 6 de Noviembre de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.-</div><br></div>", "i": 8273187}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "581 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-581 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 581 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LICEO COMERCIAL A-25", "LICEO COMERCIAL A-30 JOAQUIN", "VERA MORALES", "LICEO B-40 NORA VIVIANS MOLINA", "LICEO", "COMERCIAL B-61 GABRIEL GONZALEZ VIDELA", "LICEO COMERCIAL", "B-70 MOLINA LAVIN", "LICEO COMERCIAL B-106", "LICEO", "COMERCIAL B-113", "LICEO  COMERCIALB-130", "PLANES ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-10-20", "doble_articulado": false, "id