{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8311129}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 850, de 23 de Julio de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 3&#xB0;, de la Resoluci&#xF3;n No. 1408, de 09 de Noviembre de 1990, que autoriz&#xF3; a do&#xF1;a SILVIA ANGELICA PINO MONTERO, RUT No. 9.859.930-4, domiciliada en calle Rub&#xE9;n Dar&#xED;o No. 323, Valdivia, para iniciar actividades pesqueras extractivas, en el sentido de autorizar a la embarcaci&#xF3;n Tit&#xE1;n del Mar para capturar el recurso Albacora o pez espada dentro de la Zona Econ&#xF3;mica Exclusiva de Chile Continental desde la I a la X Regi&#xF3;n, utilizando como aparejo de pesca red de enmalle y arp&#xF3;n.</div><br><br></div>", "i": 8311130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de Julio de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br><br></div>", "i": 8311131}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "850", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-850"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-07-23", "fecha_derogacion": "1993-04-12", "doble_articulado": false, "id_norma": "80555", "numero_fuente": "34050", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-08-23", "vigencias": [{"desde": "1993-04-12", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desd