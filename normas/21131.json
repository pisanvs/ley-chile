{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 394 EXENTO, DE 1990 </div></div>", "i": 5944252}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 394 de fecha 28 de diciembre de 1990 del Ministerio de Educaci&#xF3;n, se insert&#xF3; en las respectivas resoluciones exentas del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Celler las adecuaciones introducidas a las carreras de Turismo, Secretariado Ejecutivo, Comercio Exterior, Publicidad y Contabilidad. Asimismo se reemplazaron las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica mencionado, que fueran aprobadas por Resoluci&#xF3;n Exenta N&#xB0; 2463 de 1982.-</div><br></div>", "i": 5944253}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 29 de Abril de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5944254}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "394", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-394"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 394 EXENTO, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA INSTITUTO CELLER", "PLAN ESTUDIO", "PROGRAMA ESTUDIO", "MODIFICACION", "EVALUACION", "PROMOCION", "TITULACION", "REEMPLAZA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-28", "doble_articulado": false, "id_norma": "21131", "numero_fuente": "33973", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-05-22", "vigencias": [{"desde": "1991-05-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vige