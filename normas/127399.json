{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8336758}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.606, de 17 de noviembre de 1998, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de las resoluciones N&#xBA; 1.065 de 1988 y N&#xBA; 1.173 de 1991, ambas de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autorizaron a PESQUERA GUIMAR S.A. para ampliar actividades pesqueras extractivas con la nave &apos;&apos;Tobago&apos;&apos;.</div><div class=\"p\">&nbsp; &nbsp;  Decl&#xE1;rase la caducidad de las resoluciones N&#xBA; 1.095 de 1992 y N&#xBA; 609 de 1996, ambas de esta Subsecretar&#xED;a, que autorizaron a Pesquera Guimar S.A., antes individualizada, para ampliar actividades pesqueras extractivas con la nave &apos;&apos;Tobago&apos;&apos;.</div><br></div>", "i": 8336759}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de noviembre de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8336760}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1606", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1606"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA GUIMAR S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-17", "doble_articulado": false, "id_norma": "127399", "numero_fuente": "36220", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-11-21", "vigencias": [{"desde": "1998-11-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigen