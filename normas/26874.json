{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA NOMBRE A LA AVENIDA ITALIA DEL BALNEARIO DE EL QUISCO POR EL QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8279866}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- La &quot;Avenida Italia&quot; del Balneario de &quot;El Quisco&quot; se denominar&#xE1; en lo sucesivo &quot;Isidoro Dubourmais&quot;.&quot; </div></div>", "i": 8279867}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecis&#xE9;is de Agosto de mil novecientos cincuenta y cinco.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Osvaldo Koch.</div><br></div>", "i": 8279868}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11868", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11868"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA NOMBRE A LA AVENIDA ITALIA DEL BALNEARIO DE\nEL QUISCO POR EL QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "AVENIDA", "CALLE", "BALNEARIO", "QUISCO", "ISIDORO DUBOURMAIS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1955-08-16", "doble_articulado": false, "id_norma": "26874", "numero_fuente": "23232", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1955-08-26", "vigencias": [{"desde": "1955-08-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1955-08-26", "fin_vige