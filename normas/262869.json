{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.163 EXENTA, DE 2007 </div></div>", "i": 7348105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.163, de fecha 28 de junio de 2007, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se aprueban Planes y Programas de la Escuela de Conductores Profesionales &quot;Donoso y Blanco Limitada&quot; o &quot;Escuelas Col&#xF3;n Ltda.&quot;, representada legalmente por la se&#xF1;orita Jessica Roxana Donoso Rubio y el se&#xF1;or Nicol&#xE1;s Blanco Castro, para impartir cursos conducentes a la obtenci&#xF3;n de licencia de conductor profesional clases A2 y A4.</div><br></div>", "i": 7348106}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Pablo Rodr&#xED;guez Olivares, Secretario Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana.</div><br></div>", "i": 7348107}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1163 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1163 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.163 EXENTA, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-28", "doble_articulado": false, "id_norma": "262869", "numero_fuente": "38817", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-07-20", "vigencias": [{"desde": "2007-07-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "v