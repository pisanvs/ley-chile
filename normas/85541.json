{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9016915}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 236 de 13 de octubre de 1992, del SERVIU</div><div class=\"p\">V. Regi&#xF3;n de Valpara&#xED;so, se dispuso expropiaci&#xF3;n conforme</div><div class=\"p\">art&#xED;culo 87 Ley 8.946 y DL 2.186, de 1978, de parte inmueble ubicado calle Alvarez esquina Agua Santa, comuna Vi&#xF1;a del Mar, rol aval&#xFA;o 1101, de Comunidad Copropietarios Edificio Agua Santa. Comisi&#xF3;n Tasadora integrada por Sres. Osvaldo Mu&#xF1;oz Quintana, arquitecto; Alvaro Verdejo Vidal y Pablo Caria Giurici, constructores civiles, seg&#xFA;n informe fecha 12.08.92, fij&#xF3; monto provisional indemnizaci&#xF3;n $ 1.884.000.-. Indemnizaci&#xF3;n se pagar de contado.</div><br><br></div>", "i": 9016916}, {"t": "<div><div class=\"p\">- Manuel Hernandez Abarca, Director Serviu V. Regi&#xF3;n. </div></div>", "i": 9016917}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "236", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-236"}], "organismos": ["SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAISO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-10-13", "doble_articulado": false, "id_norma": "85541", "numero_fuente": "34405", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-11-02", "vigencias": [{"desde": "1992-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie