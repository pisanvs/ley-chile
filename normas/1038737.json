{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9246870}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 717, de 29 de marzo de 2012, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1008733&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.657, de 2009</a>, que autoriz&#xF3; a BUENA PESCA S.A. para realizar actividades pesqueras extractivas con la nave &quot;Nicomar&quot;, respecto del recurso hidrobiol&#xF3;gico Alfonsino, en el &#xE1;rea mar&#xED;tima comprendida entre la III a X Regiones, y Archipi&#xE9;lago de Juan Fern&#xE1;ndez, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante Memoranda T&#xE9;cnicos citados en Visto de la resoluci&#xF3;n extractada.</div></div>", "i": 9246871}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de marzo de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9246872}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "717 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-717 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-03-29", "doble_articulado": false, "id_norma": "1038737", "numero_fuente": "40230", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-04-04", "vigencias": [{"desde": "2012-04-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenc