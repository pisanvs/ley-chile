{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6065914}, {"t": "<div><div class=\"p\">Por Decreto Secc. 2da. No. 76, de fecha 12 de Enero de 1990, Alcalde I. Municipalidad de Santiago, dispone expropiaci&#xF3;n parcial conforme DS No. 458 de Vivienda y Urbanismo, Decreto Ley 2.186 y Ley 18.695, inmueble Agustinas 2431-2439, Rol 333-4 Santiago, aparente dominio Asociaci&#xF3;n General Buses Catedral Lourdes, superficie aproximada a expropiar 422 m2. Deslindes: Norte, 10,80 mts. resto predio Sur, 10,80 mts. calle Agustinas; Oriente 38,00 mts. con otro propietario en l&#xED;nea quebrada y Poniente, 38,00 mts. otro propietario. Indemnizaci&#xF3;n provisional $ 7.353.000.- pagadera contado. </div></div>", "i": 6065915}, {"t": "<div><div class=\"p\">M&#xE1;ximo Honorato Alamos, Alcalde Santiago.</div><br></div>", "i": 6065916}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "76", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-76"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-12", "doble_articulado": false, "id_norma": "83649", "numero_fuente": "33585", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-01", "vigencias": [{"desde": "1990-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1998-01-09", "fecha_version": "1990-