{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION QUE INDICA </div></div>", "i": 8344079}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 243 de 04 de Marzo de 1988 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deroga la resoluci&#xF3;n No. 150, de 1986, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la Sociedad Centro de Cultivos Marinos Limitada, domiciliada en Santiago, para instalar y operar un establecimiento de cultivo de alga Gracilaria spp., en un sector de Bah&#xED;a Calderilla, Comuna de Caldera, Copiap&#xF3;, IIIa. Regi&#xF3;n, en una superficie de 27.716,9 m2., por renuncia de su titular.</div><br></div>", "i": 8344080}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 04 de Marzo de 1988.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8344081}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "243", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-243"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "DEROGA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-04", "doble_articulado": false, "id_norma": "135421", "numero_fuente": "33022", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-03-16", "vigencias": [{"desde": "1988-03-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-03-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-03-16", "fin_vigencia": "", "tipo_version": "3"}], "event