{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10053485}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA; 779, de 26 de agosto de 2019, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA;, del <a href=\"https://www.leychile.cl/Navegar?idNorma=1130585&amp;idParte=&amp;idVersion=\">Decreto Exento MOP. N&#xBA; 139, de 26 de marzo de 2019</a>, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote de terreno N&#xBA; 176, expropiado con motivo de la obra: &quot;Reposici&#xF3;n Ruta 148, Sector: Cruce Ruta 5 - Puente Queime&quot;, Comuna de Quill&#xF3;n, Provincia de Diguill&#xED;n, Regi&#xF3;n de &#xD1;uble, Antes Regi&#xF3;n del Biob&#xED;o. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n fijada mediante tasaci&#xF3;n de 03 de junio de 2017, ascendente a la cantidad $490.056.-, para el lote N&#xBA;176.</div><br></div>", "i": 10053486}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "779 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-779 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1652887", "NORMA SIN PROMULGACIÓN", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-08-26", "doble_articulado": false, "id_norma": "1136183", "numero_fuente": "42456", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-09-16", "