{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 232 EXENTO, DE 1996 </div><br><br><br><br></div>", "i": 7161250}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 232 de fecha 24 de Abril de 1996 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; al Centro de Formaci&#xF3;n T&#xE9;cnica de Educaci&#xF3;n Superior Agr&#xED;cola Miguel Covarrubias Vald&#xE9;s, las adecuaciones al plan y programas de estudios de la carrera T&#xE9;cnico Agr&#xED;cola de Nivel Superior, modific&#xE1;ndose, en consecuencia, el Decreto Exento N&#xB0; 232 de 1993. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1996.</div><br></div>", "i": 7161251}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 11 de Junio de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161252}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "232", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-232"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 232 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA EDUCACION SUPERIOR AGRICOLA", "MIGUEL COVARRUBIAS VALDES", "PROGRAMAS ESTUDIO", "PLANES", "ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-04-24", "fecha_derogacion": "2004-10-06", "doble_articulado": false, "id_norma": "20748", "numero_fuente": "35536", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-08-07", "vigencias": [{"desde": "2004-10-06", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1996-08-07", "hasta": "2004-10-05", "tipo_versi