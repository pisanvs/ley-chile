{"html": [{"t": "<div><br><div class=\"p\">SOBRE EL MODO DE RESOLVER LOS ASUNTOS DE MONTEPIO.</div><br><br><div class=\"p\">&nbsp; &nbsp;  El Director Supremo del Estado de Chile &amp;a.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Soberano Congreso Constituyente ha decretado lo siguiente:</div></div>", "i": 10060611}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  &#xAB;Cont&#xE9;stese al Poder Ejecutivo que los asuntos de montep&#xED;o militar deben resolverse oyendo previamente a los Ministros Tesoreros y al Fiscal de Hacienda, y gobern&#xE1;ndose por las decisiones dadas en el reglamento del caso.&#xBB; </div><br><div class=\"p\">&nbsp; &nbsp;  Por tanto, ordeno que se publique por lei insert&#xE1;ndose en el Boletin. Dado en el Palacio Directorial de Santiago a 9 de Setiembre de 1823.</div></div>", "i": 10060612}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Fern&#xE1;ndez.</div><br></div>", "i": 10060613}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "33", "numero": "S/N", "abreviacion": "LEI", "descripcion": "Lei", "compuesto": "Lei-S/N"}], "organismos": ["DEPARTAMENTO DE GUERRA Y MARINA"], "titulo_norma": "SOBRE EL MODO DE RESOLVER LOS ASUNTOS DE MONTEPIO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-09-09", "doble_articulado": false, "id_norma": "1136862", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-09-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-09-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-09-