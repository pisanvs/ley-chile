{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6233870}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. N&#xBA; 253, de fecha 30 de Septiembre de 1986, se expropiaron los lotes de terrenos N&#xBA;s. 59, 64, 91 y 94, cuyas superficies son: 162,3 M2; 142,5 M2; 100 M2 y 15 M2, Roles de Aval&#xFA;os</div><div class=\"p\">46-174;.46-179; 46.78 y 46-75, respectivamente de la Comuna de Peumo, VI Regi&#xF3;n, para Ruta H-66-G Pelequ&#xE9;n Cruce Las Ara&#xF1;as, sector Codao Las Cabras, y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios se&#xF1;ores Tob&#xED;as del Carmen Fuentes Murillo, Vicente Antonio Soto Contreras, Juan Ram&#xF3;n Aliaga Osorio y Luis Ruperto Riquelme Flores, ascendente a las sumas de $ 138.873; $ 94.693; $ 82.943 y $ 59.442.-</div><br></div>", "i": 6233871}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6233872}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "253", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-253"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-09-30", "doble_articulado": false, "id_norma": "155939", "numero_fuente": "32612", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-11-03", "vigencias": [{"desde": "1986-11-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-11-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-11-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen