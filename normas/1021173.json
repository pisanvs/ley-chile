{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9076922}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (EXENT0) N&#xBA;2926 de 19 de noviembre de 2010, se modific&#xF3; el numeral segundo del decreto MOP N&#xB0; 1243 de 25 de agosto de 2009, que orden&#xF3; la expropiaci&#xF3;n del lote N&#xB0; 53, en la parte que se refiere al n&#xFA;mero del rol de aval&#xFA;o y al nombre del propietario seg&#xFA;n el Servicio de Impuestos Internos, quedando como VERGARA HERRERA EUFROSINA DEL, rol de aval&#xFA;o 633-111 de Molina. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto Ley N&#xBA;2186, de 1978. </div></div>", "i": 9076923}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9076924}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2926 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2926 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-11-19", "doble_articulado": false, "id_norma": "1021173", "numero_fuente": "39835", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-12-15", "vigencias": [{"desde": "2010-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-12-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2010