{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8891879}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.005, de 3 de marzo de 2010, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1010800&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 417, de 2010, de esta Subsecretar&#xED;a de Pesca</a>, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Distribuci&#xF3;n espacio-temporal de las capturas de Jurel, Regi&#xF3;n Arica y Parinacota, Tarapac&#xE1; y Antofagasta, a&#xF1;o 2010&quot;, en el sentido de incorporar a la embarcaci&#xF3;n artesanal Cayumanqui, RPA 925966, a la n&#xF3;mina de participantes en el estudio.</div></div>", "i": 8891880}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de marzo de 2010.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8891881}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1005 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1005 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-03-03", "doble_articulado": false, "id_norma": "1011658", "numero_fuente": "39609", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-03-12", "vigencias": [{"desde": "2010-03-12", "hasta": "", "tipo_version": "3", "tipo_ver