{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,767.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165116}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a la viuda del ex-conductor de los ferrocarriles del Estado don Basilio Arratia, por una sola vez, una asignacion de tres mil pesos. </div></div>", "i": 6165117}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a quince de setiembre de mil novecientos cinco.- JERMAN RIESCO.- E. Villegas.</div><br></div>", "i": 6165118}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1767", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1767"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-09-15", "doble_articulado": false, "id_norma": "135341", "numero_fuente": "8311", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-09-21", "vigencias": [{"desde": "1905-09-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1905-09-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1905-09-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-04-22", "f