{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6626921}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.832 de 1 de octubre de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA CHILE S.A. para ampliar actividades extractivas con la nave &quot;Diego Ram&#xED;rez&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 44&#xB0;30&apos; y 47&#xB0;L.S., por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; extraer con arrastre los siguientes recursos hibrobiol&#xF3;gicos: Anguila com&#xFA;n, Caballa, Calamar, Cojinoba del norte, Congrio negro, Corvina, Pejerrata o Granadero grande, Lenguado de ojos chicos, Lenguado de ojos grandes, Tibur&#xF3;n o marrajo, Pejegallo, Pejeperro, Pejerratas Coelorhynchus spp., Raya Raja spp., R&#xF3;balo, Tollo o fume, Tollo de cachos y Sierra.</div><br></div>", "i": 6626922}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de octubre de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 6626923}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2832 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2832 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2007-10-01", "fecha_derogacion": "2014-12-06", "doble_articulado": false, "id_norma": "265669", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2007-10-18", "vigencias": [{"desde": "2014-12-06", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"d