{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESIGNA COMO MINISTRO DE FE A FUNCIONARIOS QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 43.- Santiago, 6 de marzo de 1996.- Vistos: Lo dispuesto en el Art. 4&#xB0; del Decreto Ley N&#xB0; 2.974 de 1979.</div><div class=\"p\">&nbsp; &nbsp; R e s u e l v o:</div><br></div>", "i": 6004291}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Des&#xED;gnase como Ministro de Fe para actuar en las localidades ubicadas en la VII Regi&#xF3;n, en que no hayan Notarios ni Oficiales del Registro Civil, a los siguientes funcionarios:</div><div class=\"p\">&nbsp; &nbsp; -Fernando Patricio Zenteno Rosales</div><div class=\"p\">&nbsp; &nbsp; -Gast&#xF3;n Segundo Rojas Fuentes </div></div>", "i": 6004292}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Luis Marambio Canales, Director Nacional.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Encargado Oficina de Partes.</div><br></div>", "i": 6004293}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "43", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-43"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO MINISTRO DE FE A FUNCIONARIOS QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MINISTRO FE", "NOMBRAMIENTO", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-03-06", "doble_articulado": false, "id_norma": "32551", "numero_fuente": "35423", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-03-21", "vigencias": [{"desde": "1996-0