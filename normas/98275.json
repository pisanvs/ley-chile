{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 391 EXENTO, DE 1998 </div></div>", "i": 6108535}, {"t": "<div><div class=\"p\">&nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA;391 de 12 de marzo de 1998, se ha autorizado al Instituto Zambrano de Santiago, para modificar el actual plan de estudio de los cursos de 7&#xBA; y 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica regidos por el decreto supremo de Educaci&#xF3;n N&#xBA;4.002 de 1980 y sus modificaciones, suprimiendo las 2 clases de Franc&#xE9;s y agregando 2 clases de Castellano en dichos cursos, a partir del a&#xF1;o escolar 1998.</div><br></div>", "i": 6108536}, {"t": "<div><div class=\"p\">&nbsp;  Santiago, 23 de marzo de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6108537}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "391 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-391 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 391 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "INSTITUTO ZAMBRANO", "SANTIAGO", "REGION METROPOLITANA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-03-12", "doble_articulado": false, "id_norma": "98275", "numero_fuente": "36034", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-04-06", "vigencias": [{"desde": "1998-04-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-04-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-04-06", "fin_vigencia": "", "tipo_version": "3"}], "even