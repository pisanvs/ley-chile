{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xB0; 184, DE 1983 </div></div>", "i": 7262286}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xB0; 36, de 10 de Enero de 1986 de la Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n N&#xB0; 184, de 1983, de la misma Subsecretaria que autoriz&#xF3; a la Sociedad Pesquera Ral&#xFA;n Limitada, domiciliada en Santiago, para instalar y operar una planta elaboradora de conservas de recursos hidrobiol&#xF3;gicos en Puerto Varas, en el sentido de sustituir su numeral 2&#xB0; por el siguiente &quot;2&#xB0; La peticionaria podr&#xE1; instalar y operar una planta elaboradora de conservas y congelado de recursos hidrobiol&#xF3;gicos, en calle 6 Andina, sitios 41-46, del Barrio Industrial de la ciudad de Puerto Montt&quot;.</div><br></div>", "i": 7262287}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de Enero de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7262288}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "36", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-36"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION N° 184, DE 1983", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-01-10", "doble_articulado": false, "id_norma": "157325", "numero_fuente": "32374", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-01-17", "vigencias": [{"desde": "1986-01-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "