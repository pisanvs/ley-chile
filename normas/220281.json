{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N&#xBA; 1106 </div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 1106, celebrada el 15 de enero de 2004, adopt&#xF3; el siguiente Acuerdo:</div><br></div>", "i": 6459792}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1106-01-040115 Designa Ministro de Fe Subrogante. Se acord&#xF3; designar como Ministro de Fe Subrogante al abogado don Juan Esteban Laval Zald&#xED;var y, en caso de ausencia o imposibilidad de &#xE9;ste, circunstancia que no ser&#xE1; necesaria acreditar ante terceros, lo subrogar&#xE1; en el cargo de Ministro de Fe, el abogado se&#xF1;or Jorge Court Larenas.</div><br></div>", "i": 6459793}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de enero de 2004.- Jorge Court Larenas, Ministro de Fe (S).</div><br></div>", "i": 6459794}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1106", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1106"}, {"tipo": "5", "numero": "1106-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1106-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION Nº 1106", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-15", "doble_articulado": false, "id_norma": "220281", "numero_fuente": "37763", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-01-19", "vigencias": [{"desde": "2004-01-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-01-19", "fin_vigencia": ""}, "vigencias_vers