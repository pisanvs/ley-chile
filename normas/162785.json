{"html": [{"t": "<div><div class=\"p\"> EXTRACTO&nbsp; DE RESOLUCION&nbsp; N&#xBA; 12,&nbsp; DE 2000</div><br></div>", "i": 6256433}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n Ministerial N&#xBA; 12, de fecha 27 de enero</div><div class=\"p\">del a&#xF1;o 2000, del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n, se cancel&#xF3; la personalidad jur&#xED;dica de la</div><div class=\"p\">&apos;&apos;Asociaci&#xF3;n Gremial Due&#xF1;os de Veh&#xED;culos Motorizados de</div><div class=\"p\">Carga Menor de Concepci&#xF3;n&apos;&apos;, inscrita bajo el N&#xBA; 24-8, del</div><div class=\"p\">registro que para tal efecto lleva este Ministerio, por</div><div class=\"p\">haberse configurado respecto de ella las causales de</div><div class=\"p\">cancelaci&#xF3;n contempladas en el art&#xED;culo 18, N&#xBA; 2, letra d) y</div><div class=\"p\">art&#xED;culos 6, 16 y 21 del DL N&#xBA; 2.757, de 1979.- </div></div>", "i": 6256434}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alvaro D&#xED;az P&#xE9;rez, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6256435}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "12", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-12"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 12, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-27", "doble_articulado": false, "id_norma": "162785", "numero_fuente": "36624", "tipo_version": "3", "tipo_version_s": "Única", "fecha