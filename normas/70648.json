{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6034347}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. N&#xBA; 194, de 28 de febrero de 1997, se expropiaron los lotes de terreno N&#xBA;s. 196 y 222, superficies 22.486 m2. y 3.769 m2, rol de aval&#xFA;o 611-28 y 614-30, comuna de Tom&#xE9;, para la obra Camino Acceso Norte a Concepci&#xF3;n, y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Ana Luisa Cuevas Neira y Jos&#xE9; Orlando Ch&#xE1;vez Mu&#xF1;oz, ascendente a la cantidad de $8.655.888.- y $1.258.320.-, respectivamente.-</div><br></div>", "i": 6034348}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6034349}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "194", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-194"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "TOME", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-02-28", "doble_articulado": false, "id_norma": "70648", "numero_fuente": "35741", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-15", "vigencias": [{"desde": "1997-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-04-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CDG", "fecha_ingreso": "1997-04-22", "fecha_version": "1997-04-15", "fecha_actualizacion_texto": "1