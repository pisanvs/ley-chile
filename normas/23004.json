{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,912, que se&#xF1;ala la cabecera de la comuna de Pichiguao</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,912.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274832}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. La cabecera de la comuna de Pichiguao, creada por decreto supremo de fecha 3 de febrero de 1904, ser&#xE1; la poblacion Rosario.</div><br></div>", "i": 8274833}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 26 de enero de 1907.- PEDRO MONTT.- V. Santa Cruz.</div><br></div>", "i": 8274834}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1912", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1912"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 1,912, QUE SEÑALA LA CABECERA DE LA COMUNA DE PICHIGUAO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CABECERA COMUNA", "PICHIGUAO", "POBLACION ROSARIO", "ESTABLECE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-01-26", "doble_articulado": false, "id_norma": "23004", "numero_fuente": "8711", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-01-26", "vigencias": [{"desde": "1907-01-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-01-26", "fin_vigencia": ""}, "vigencias_version_n