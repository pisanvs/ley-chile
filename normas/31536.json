{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTOS DE RESOLUCIONES </div></div>", "i": 8288679}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 576, de 16 de Mayo de 1991, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, cad&#xFA;case la Resoluci&#xF3;n N&#xB0; 674,</div><div class=\"p\">de 1989, de esta Subsecretar&#xED;a de Pesca, por la cual se</div><div class=\"p\">autoriz&#xF3; a don JOSE RAMON GARCIA CORCES, R.U.T. N&#xB0;</div><div class=\"p\">4.690.909-7, domiciliado en Puerto Montt, Los Leones N&#xB0;</div><div class=\"p\">6, Villa Herdesol, para operar una planta industrial en</div><div class=\"p\">el sector de San Antonio, Comuna de Quell&#xF3;n, Provincia</div><div class=\"p\">de Castro, X Regi&#xF3;n, en virtud de lo expresado en el</div><div class=\"p\">art&#xED;culo 7&#xB0; del D.S. N&#xB0; 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8288680}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 16 de Mayo de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8288681}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "576", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-576"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "EXTRACTOS DE RESOLUCIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JOSE RAMON GARCIA CORCES", "PESCA", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-05-16", "doble_articulado": false, "id_norma": "31536", "numero_fuente": "33974", "tipo_version": "3