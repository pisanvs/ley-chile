{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6526402}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 485, de 28 de junio de 1996, se expropiaron los lotes de terrenos N&#xB0;s 19 y 69, superficies 1.752 y 882 m2 roles de aval&#xFA;os 1093-6 y 600-7 comuna de Cartagena y El Tabo, para la obra Camino Malvilla Orrego Abajo y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios, Gladys Pizarro Parraguez y Paulina del Carmen Vera Castillo y otros, ascendente a las cantidades de $2.503.857 para el lote N&#xB0; 19 y $489.836 para el lote N&#xB0; 69.</div><br></div>", "i": 6526403}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6526404}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "485", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-485"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-06-28", "doble_articulado": false, "id_norma": "238071", "numero_fuente": "35557", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-09-02", "vigencias": [{"desde": "1996-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-09-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-05-16", "fecha_version": "1996-09-02", "fecha_actualizacion_texto": "1996-09-02", "tipo_tratado": ""}, "al