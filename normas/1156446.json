{"html": [{"t": "<div><div class=\"p\">&#xFEFF;&nbsp; &nbsp;  NOMBRAMIENTO DE LOS MIEMBROS DE LA CORTE MARCIAL.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Noviembre 29 de 1827.</div></div>", "i": 10246015}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Satisfecho el Gobierno de la aptitud y celo del Jeneral de division D. Juan Prieto, y Coronel D. Manuel Antonio Recav&#xE1;rren ha venido en nombrarles jueces de la Corte Marcial conforme al art.7.&#xB0; del decreto de esta fecha aprobado por la Comision nacional en 26 del corriente. T&#xF3;mese razon, comun&#xED;quese al Presidente de la Corte de Apelaciones, Inspeccion jeneral de ej&#xE9;rcito e impr&#xED;mase.</div></div>", "i": 10246016}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  PINTO.</div><br><div class=\"p\">&nbsp; &nbsp;  Obejero. </div><div class=\"p\">&nbsp; &nbsp;  Pro-Secretario.</div></div>", "i": 10246017}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DE LA GUERRA"], "titulo_norma": "NOMBRAMIENTO DE LOS MIEMBROS DE LA CORTE MARCIAL.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1827-11-29", "doble_articulado": false, "id_norma": "1156446", "numero_fuente": "1827", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1827-11-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1827-11-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1827-11-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [],