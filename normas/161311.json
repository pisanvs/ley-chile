{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 18, DE 2000</div><br><br></div>", "i": 6251717}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA; 18, de fecha 4 de febrero del a&#xF1;o 2000, se aprob&#xF3; la reforma parcial al estatuto de la Cooperativa de Ahorro y Cr&#xE9;dito Uni&#xF3;n A&#xE9;rea Limitada, en los t&#xE9;rminos que da testimonio el instrumento protocolizado bajo el N&#xBA; 652, con fecha 21 de enero del a&#xF1;o 2000, al final de los Registros del Notario de Santiago don Eduardo Pinto Peralta. </div></div>", "i": 6251718}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Sr. Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6251719}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "18", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-18"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 18, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COOPERATIVA DE AHORRO Y CREDITO UNION AEREA LIMITADA", "ESTATUTO", "REFORMA PARCIAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-04", "doble_articulado": false, "id_norma": "161311", "numero_fuente": "36616", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-17", "vigencias": [{"desde": "2000-03-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-17", "fin_vigencia": ""}, "vigen