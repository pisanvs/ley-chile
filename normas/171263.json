{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 172 EXENTO, DE 2000 </div></div>", "i": 6283130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 172, de 26 de mayo de&nbsp; 2000, se ha aprobado al &apos;&apos;Saint Angela&apos;s School&apos;&apos;, comuna de Vitacura, de Santiago, un plan de estudio para 6&#xBA; a&#xF1;o (NB.4) de Ense&#xF1;anza B&#xE1;sica.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en el presente decreto. </div></div>", "i": 6283131}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de junio de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6283132}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "172 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-172 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 172 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-26", "doble_articulado": false, "id_norma": "171263", "numero_fuente": "36694", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-21", "vigencias": [{"desde": "2000-06-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-06-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "2000-06-21", "fecha_version": "2000-06-21", "fecha_actuali