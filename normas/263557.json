{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACION DE EMISOR ELECTRONICO </div></div>", "i": 7350080}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 91 de 6 de agosto de 2007, que deroga autorizaci&#xF3;n otorgada a contribuyente para operar como emisor electr&#xF3;nico.</div><br><div class=\"p\">&nbsp; &nbsp;  Se deroga autorizaci&#xF3;n otorgada a contribuyente RUT N&#xBA; 83.491.800-5, para operar como emisor de documentos tributarios electr&#xF3;nicos.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de agosto de 2007.</div><br></div>", "i": 7350081}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "91 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-91 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEROGA AUTORIZACION DE EMISOR ELECTRONICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-08-06", "doble_articulado": false, "id_norma": "263557", "numero_fuente": "38835", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-08-10", "vigencias": [{"desde": "2007-08-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-08-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-08-10", "fin_vigencia": "", "tipo_vers