{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 6.556 EXENTA, DE 2003 </div></div>", "i": 6427302}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 6.556, de 2 de junio de 2003, del Servicio Nacional de Capacitaci&#xF3;n y Empleo, se revoc&#xF3; la autorizaci&#xF3;n otorgada al organismo t&#xE9;cnico de capacitaci&#xF3;n &quot;Centro de Educaci&#xF3;n y Capacitaci&#xF3;n Tecnol&#xF3;gico Futuro&quot;, RUT N&#xBA; 77.545.030-4, cancel&#xE1;ndose su inscripci&#xF3;n en el Registro Nacional correspondiente, atendido a lo dispuesto en el art&#xED;culo 77, letra b) de la Ley N&#xBA; 19.518.</div><br></div>", "i": 6427303}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago.- Eduardo Rodr&#xED;guez Olivares, Jefe Departamento de Capacitaci&#xF3;n en Empresas.</div><br></div>", "i": 6427304}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6556 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-6556 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 6.556 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-02", "doble_articulado": false, "id_norma": "211384", "numero_fuente": "37587", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-19", "vigencias": [{"desde": "2003-06-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-06-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-06-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincula