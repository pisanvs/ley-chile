{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6342374}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;674 de fecha 31 de mayo de 2001, se expropi&#xF3; el lote de terreno N&#xBA;5, superficie 684,74 m&#xB2;, rol de aval&#xFA;o 387-168, comuna de Pitrufqu&#xE9;n, para la obra &quot;Dise&#xF1;o Definitivo Regad&#xED;o Faja Mais&#xE1;n, Expropiaciones Red Primaria 3/5, Derivado Mahuidanche, Sector Km. 0.000 al Km. 2.009,85&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Felicia Colicheo Colicheo y Otros, ascendente a la cantidad de $666.603.-</div><br></div>", "i": 6342375}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6342376}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "674", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-674"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-31", "doble_articulado": false, "id_norma": "187548", "numero_fuente": "37012", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-07-16", "vigencias": [{"desde": "2001-07-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-07-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-07-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2001-07-16", "fecha_version": "2001-07-16", "fecha_actualizacion_texto": "2001-07-16", "tipo_tratado": ""}