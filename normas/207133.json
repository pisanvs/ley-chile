{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6411949}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n, que suscribe, certifica que la Universidad Mar&#xED;tima de Chile inscrita bajo el n&#xFA;mero C-52 del Registro del Ministerio de Educaci&#xF3;n, ha presentado los programas de estudio de la carrera de Arquitectura conducente al grado acad&#xE9;mico de Licenciado en Arquitectura y al T&#xED;tulo Profesional de Arquitecto a la Universidad del B&#xED;o B&#xED;o, como entidad examinadora y revisados por &#xE9;sta han sido aprobados.</div><div class=\"p\">&nbsp; &nbsp;  La carrera mencionada podr&#xE1; impartirse a contar de 1991.</div><br><br></div>", "i": 6411950}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de Enero de 1991.</div><div class=\"p\">&nbsp; &nbsp;  RAUL ALLARD NEUMANN Subsecretario de Educaci&#xF3;n </div></div>", "i": 6411951}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-31", "doble_articulado": false, "id_norma": "207133", "numero_fuente": "33905", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-02-27", "vigencias": [{"desde": "1991-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-02-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-02-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie