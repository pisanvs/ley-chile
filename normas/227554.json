{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6487427}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;1.763, de 1 de julio de 2004, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA; de la resoluci&#xF3;n N&#xBA;1.117 de 2004, que autoriz&#xF3; a la UNIVERSIDAD ANDRES BELLO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia de la pesca de investigaci&#xF3;n en el marco del Proyecto denominado &quot;Assesment of the human interactive effect with enviromental variables determining distribution and population densities of the marine otter (Lontra felina) in Chile&quot;, en el sentido de aumentar a 14 el n&#xFA;mero de ejemplares vivos de Chungungo autorizados a capturar en el marco de la citada pesca de investigaci&#xF3;n.</div><br></div>", "i": 6487428}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 julio 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6487429}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1763 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1763 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-07-01", "doble_articulado": false, "id_norma": "227554", "numero_fuente": "37909", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-14", "vigencias": [{"desde": "2004-07-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia