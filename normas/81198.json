{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA;386, DE 1990 </div></div>", "i": 7216099}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n N&#xBA;386 de 28 de diciembre de 1990 se ha modificado, a partir del a&#xF1;o escolar 1991, plan especial de estudio del Colegio &quot;Villa Mar&#xED;a Academy&quot;, de Santiago, para la Ense&#xF1;anza Media Human&#xED;stico - Cient&#xED;fica que se aplicar&#xE1; en 1&#xBA;, 2&#xBA; y 3er. a&#xF1;o en 1991; y en 4&#xBA; a&#xF1;o en 1992.</div><div class=\"p\">Adem&#xE1;s, se aprueban programas especiales de estudio para las asignaturas que se indican.</div><br></div>", "i": 7216100}, {"t": "<div><div class=\"p\">Santiago, 3 de Septiembre de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7216101}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "386 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-386 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº386, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-28", "doble_articulado": false, "id_norma": "81198", "numero_fuente": "34081", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-10-02", "vigencias": [{"desde": "1991-10-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-10-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-10-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "M