{"html": [{"t": "<div><br><div class=\"p\">DECLARA CADUCIDAD TOTAL DE RESOLUCI&#xD3;N QUE SE&#xD1;ALA</div></div>", "i": 9844083}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 3.376, de 20 de octubre de 2017, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad total de la <a href=\"https://www.leychile.cl/Navegar?idNorma=222747&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 573, de 2004</a>, que autoriz&#xF3; a Corpesca S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Eperva 56&quot;, respecto del recurso hidrobiol&#xF3;gico Jibia en el &#xE1;rea mar&#xED;tima comprendida entre la XV a II regiones, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 9844084, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de octubre de 2017.- Paolo Trejo Carmona, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9844085}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3376 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3376 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DECLARA CADUCIDAD TOTAL DE RESOLUCIÓN QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1294045", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-10-20", "doble_articulado": false, "id_norma": "1109850", "numero_fuente": "41894", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-10-28", "vigencias": [{"desde": "2017-10-28", "hasta": "", "tipo_ve