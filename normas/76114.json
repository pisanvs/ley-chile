{"html": [{"t": "<div><div class=\"p\">Extracto de ResoluciON N&#xBA; 85 EXENTA, DE 1997 </div></div>", "i": 8306761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n exenta N&#xBA; 85 de fecha 9 de septiembre de 1997 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n se ha rechazado el Recurso de Reclamaci&#xF3;n Interpuesto por la Pesquera Peterseo S.A. RUT N&#xBA; 79.978.070-4, en contra de la Resoluci&#xF3;n N&#xBA; 874, de 1996, de la Subsecretar&#xED;a de Pesca, que declar&#xF3; la caducidad de las autorizaciones de pesca de las naves &quot;Peterseo I&quot; y &quot;Peterseo II&quot;.-</div><br></div>", "i": 8306762}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Oscar Landerretche Gacit&#xFA;a, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8306763}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "85 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-85 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION"], "titulo_norma": "Extracto de Resolución Nº 85 EXENTA, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECURSO DE RECLAMACION", "PESQUERA PETERSEO S.A.", "CADUCIDAD", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-09-09", "doble_articulado": false, "id_norma": "76114", "numero_fuente": "35882", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-10-04", "vigencias": [{"desde": "1997-10-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-10-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig