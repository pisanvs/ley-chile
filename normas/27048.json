{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AUTORIZA LA ERECCION DE UN BUSTO A LA MEMORIA DE DON PEDRO AGUIRRE CERDA</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8280128}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Autor&#xED;zase la erecci&#xF3;n de un busto a la memoria del ex Presidente de la Rep&#xFA;blica Exemo.</div><div class=\"p\">se&#xF1;or don Pedro Aguirre Cerda en la Plaza San Francisco de la ciudad de Quillota, provincia de Valpara&#xED;so.&quot; </div></div>", "i": 8280129}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintisiete de Septiembre de mil novecientos cincuenta y seis.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Benjam&#xED;n Videla V.</div><br></div>", "i": 8280130}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "12148", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-12148"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA LA ERECCION DE UN BUSTO A LA MEMORIA DE DON\nPEDRO AGUIRRE CERDA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONSTRUCCION", "ERECCION", "MONUMENTO", "EX PRESIDENTE PEDRO AGUIRRE CERDA", "QUILLOTA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1956-09-27", "doble_articulado": false, "id_norma": "27048", "numero_fuente": "23570", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1956-10-10", "vigencias": [{"desde": "1956-10-10", "hast