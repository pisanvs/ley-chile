{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,440.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170728}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al ex-Enviado Estraordinario i Ministro Plenipotenciario de Chile en Bolivia, don Manuel J. Vega, el derecho de jubilar con cuarenta a&#xF1;os de servicios, en conformidad a las leyes respectivas.</div><br></div>", "i": 6170729}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, treinta i uno de diciembre de mil novecientos diez.- Ramon Barros Luco.- Rafael Orrego. </div></div>", "i": 6170730}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2440", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2440"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-12-31", "doble_articulado": false, "id_norma": "137050", "numero_fuente": "9884", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-01-13", "vigencias": [{"desde": "1911-01-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-01-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-01-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient