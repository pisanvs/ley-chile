{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp;  EXTRACTO DE DECRETO EXENTO No. 178, DE 1988 </div></div>", "i": 6140692}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 178 de 22 de noviembre de 1988 se ha prorrogado la vigencia hasta el a&#xF1;o escolar de 1993 y se ha modificado en la forma que se indica el decreto supremo exento de Educaci&#xF3;n No. 104 de 1983, que aprob&#xF3; planes de estudio a la Corporaci&#xF3;n de Ayuda al Ni&#xF1;o Limitado (COANIL).</div><br></div>", "i": 6140693}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 07 de Diciembre de 1988.- Paulina Dittborn Cordua, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6140694}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "178 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-178 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 178, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-11-22", "doble_articulado": false, "id_norma": "127608", "numero_fuente": "33256", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-12-27", "vigencias": [{"desde": "1988-12-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-12-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-12-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "FMR", "fecha_ingreso": "1998-12-01", "fecha_version": "1988-12-27", "fec