{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 228 de 1986 </div></div>", "i": 6226218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento No. 228 de fecha 17 de Junio de</div><div class=\"p\">1986 del Sr. Ministro de Educaci&#xF3;n P&#xFA;blica, se ampli&#xF3; el</div><div class=\"p\">art&#xED;culo &#xFA;nico del Decreto Exento de Educaci&#xF3;n No. 116, de 1984, modificado por Decreto Exento de Educaci&#xF3;n No.</div><div class=\"p\">60; de 1985, que autoriza el funcionamiento del Instituto Profesional de Estudios Superiores Luis Galdames de Stgo., en el sentido de incorporar al Reglamento a que se refiere el art&#xED;culo 6&#xB0; del DFL No.</div><div class=\"p\">5, de 1981, nuevas condiciones para el otorgamiento de los t&#xED;tulos profesionales y t&#xE9;cnicos, a contar del a&#xF1;o 1986.</div><br></div>", "i": 6226219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de Julio de 1986.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6226220}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "228 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-228 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 228 de 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-17", "doble_articulado": false, "id_norma": "153512", "numero_fuente": "32546", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-08-12", "vigencias": [{"desde": "1986-08-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "