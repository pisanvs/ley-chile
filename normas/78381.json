{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 155, DE 1992 </div></div>", "i": 8162608}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 155 de 03 de junio de 1992 se han aprobado al Instituto de Formaci&#xF3;n y Capacitaci&#xF3;n Popular &quot;INFOCAP&quot; de la Regi&#xF3;n Metropolitana, planes y programas de estudio para cursos de Formaci&#xF3;n y Capacitaci&#xF3;n para el Trabajo destinados a Adultos, que se aplicar&#xE1;n a contar del presente a&#xF1;o escolar. Adem&#xE1;s, se aprueban programas de estudio de las asignaturas del plan de estudio de los cursos de Formaci&#xF3;n y Capacitaci&#xF3;n para el Trabajo, aprobado precedentemente. </div></div>", "i": 8162609}, {"t": "<div><div class=\"p\">Santiago, 19 de Junio de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8162610}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "155 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-155 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 155, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-06-03", "doble_articulado": false, "id_norma": "78381", "numero_fuente": "34309", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-07-07", "vigencias": [{"desde": "1992-07-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-07-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-07-07", "fin_vigencia": "", "tipo_version": "3"}], "