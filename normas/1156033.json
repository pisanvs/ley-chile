{"html": [{"t": "<div><br><div class=\"p\">INSTITUTO DE TALCA.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 5 de 1827.</div></div>", "i": 10245651}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Se concede la licencia que solicita el Vicario capitular de esta Di&#xF3;cesis para fundar un Instituto en la ciudad de Talca, asign&#xE1;ndose para este objeto el convento de Santo Domingo. El Gobierno cuidar&#xE1; de dar a dicho establecimiento con la brevedad posible el plan de estudios que debe seguir, sin perjuicio de que interinamente adopte el que permitan las circunstancias. Comun&#xED;quese a quienes corresponda.</div></div>", "i": 10245652}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  PINTO.</div><br><div class=\"p\">&nbsp; &nbsp;  Ramos.</div><div class=\"p\">&nbsp; &nbsp;  Pro-Secretario.</div></div>", "i": 10245653}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "INSTITUTO DE TALCA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1827-07-05", "doble_articulado": false, "id_norma": "1156033", "numero_fuente": "1827", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1827-07-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1827-07-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1827-07-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2021-06-23", "fecha_version": "1827-07