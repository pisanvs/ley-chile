{"html": [{"t": "<div><br><div class=\"p\">MODIFICA CONCESI&#xD3;N DE ACUICULTURA</div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n 2.261, del 19 de noviembre de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div></div>", "i": 8870396}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  I.- Modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=247203&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n 1.514, del 11 de noviembre de 2005, del Ministerio de Defensa Nacional, Subsecretaria de Marina</a>, en el sentido de reemplazar el p&#xE1;rrafo 4.- por el siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;4.- El concesionario deber&#xE1; dar cabal cumplimiento al Proyecto T&#xE9;cnico y Cronograma de Actividades, aprobado por resoluci&#xF3;n exenta 2.402, del 28 de julio de 2005 y modificada por la resoluci&#xF3;n exenta 1.266, del 8 de abril de 2009, ambas del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, Subsecretar&#xED;a de Pesca.&quot;.</div></div>", "i": 8870397}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 enero 2010.- Por la Sra. Subsecretaria.- Miguel A. Z&#xFA;&#xF1;iga Fern&#xE1;ndez. Subjefe Subsecretar&#xED;a de Marina Subrogante.</div></div>", "i": 8870398}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2261", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2261"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "MODIFICA CONCESIÓN DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-11-19", "doble_articulado": false, "id_norma"